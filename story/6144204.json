[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒想到鈴莓小姐的冒失",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "居然這麼地嚴重……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為這樣引發了很多慘況，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "考慮到之後還要繼續幫忙，",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還是來思考對策會比較好！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有沒有什麼好主意呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣的話",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "又會被弄得全身都是花蜜呀！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "下次說不定會被潑肥料……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這種事，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可不想接受！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我都沒想過有這種方法。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "具體來說該怎麼做才好呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n關於這部分……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "現在還想不出來呢。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我認為這個點子本身很不錯！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我再去找村長先生",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "和其他大人討論看看喔。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽媽有跟我說過，",
        "unit_id": 130711,
        "voice": "vo_adv_6144204_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n在遇到困難時將錯就錯是不好的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要好好思考才行喔？",
        "unit_id": 130711
    }
]