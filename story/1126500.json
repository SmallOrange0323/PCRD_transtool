    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗨嗨！",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_000"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "今天看起來也很有精神嘛！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "開玩笑的啦♪",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "今天會把未央找來這裡……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "代表你也知道那件事吧～？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哇～",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_001"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "謝謝你♪",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我的生日",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "原來你都記得啊！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "欸嘿嘿，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "想想還真是有點難為情耶～☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不過",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_002"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這真的很不容易喔！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n也許就是這種體貼",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "為你帶來你這麼好的人緣吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n連我這個一路看著你成長的人",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "都與有榮焉呢！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "開玩笑的啦～☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你該不會",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_003"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真的不知道吧？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼我就告訴你吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n今天其實是！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那個人氣超級巨星，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n未央的生日啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "來～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "掌聲鼓勵～☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……不對啦，",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_004"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你根本連禮物都準備好了！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "明明就清楚得很嘛！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真是的，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "知道的話就早講一聲吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣我才能",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "早一點聽你祝福我呀♪",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦……？",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_005"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "難不成",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是嚴肅話題？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你要是有困難，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "儘管找我商量！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "請說吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "吞口水……！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……哼嗯哼嗯。",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_006"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "因為不知該怎麼開口替未央我慶祝生日",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n正感到傷腦筋，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是嗎。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這聽起來的確……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "根本一點都不嚴肅嘛！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哎唷～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真是被你擺了一道了。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "喔！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是生日禮物！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "謝謝你啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼接下來",
        "unit_id": 112611,
        "voice": "vo_adv_1126500_007"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "在慶祝之餘，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "希望你能夠答應我一項要求！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你接下來必須",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "陪我一起出去玩☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "只要能跟你一起快樂地過，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我認為\n這一定會是個超級Happy的生日！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以你當然不介意吧☆",
        "unit_id": 112611
    }
]