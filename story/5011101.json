        "voice": "vo_adv_5011101_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟是一年一次的情人節嘛。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了能讓{player}感到高興，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐會加油的！",
