    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人應該不會收取我之外的女性",
        "unit_id": 109011,
        "voice": "vo_adv_5011101_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n贈送的巧克力才是……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是這樣嗎？",
