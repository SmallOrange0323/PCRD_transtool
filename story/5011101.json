        "voice": "vo_adv_5011101_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我認為{player}不會收下姐姐之外的人",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n給的巧克力才對喔？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然如此，",
        "unit_id": 109011,
        "voice": "vo_adv_5011101_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n那就必須排除障礙了呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是要做個了斷的意思嗎？",
        "unit_id": 109111,
        "voice": "vo_adv_5011101_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼……",
