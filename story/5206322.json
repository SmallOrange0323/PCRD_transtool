        "unit_id": 135011,
        "voice": "vo_adv_5206322_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可以說都是，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "前末端裝置的闇影吧……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n步調都被打亂了……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "總而言之，",
        "unit_id": 135011,
        "voice": "vo_adv_5206322_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想必不是普通的闇影。",
