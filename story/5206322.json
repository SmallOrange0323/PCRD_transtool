    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也許因為理想鄉的力量，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而有所強化也說不定。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就假設跟我的闇影一樣，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "以會復活為前提應戰吧。",
        "unit_id": 135011
    }
