        "voice": "vo_adv_5206322_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳仔細看。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n阿賀斗紫布菜的闇影也出現了。",
        "unit_id": 135011
