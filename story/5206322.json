        "words": "雖、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然我很高興妳有這份心意……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
