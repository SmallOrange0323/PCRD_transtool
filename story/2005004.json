[
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唔、",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊嗚？　",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n這裡是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哪裡……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是王宮的",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "王座聖殿？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我為什麼",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會在這種地方？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "直到剛才為止，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我明明都還在牧場的一座山上啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把蒂亞娜",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交給克莉絲提娜處理以後，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我盡全力地控制那些失控的魔物們，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓牠們冷靜下來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才剛鬆一口氣，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就找到{player}了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來是因為他擔心蒂亞娜……",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以跑過來找她了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙真是的，明明那麼弱。",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n竟然一個人跑到山裡，簡直就是自殺行為。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然當時我想辦法壓制了魔物，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但他那時候好像快從懸崖上掉下去嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以一慌張，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就出手幫忙了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟陛下說過，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不可以讓{player}死掉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可不是因為",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "重視{player}才這麼做的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "千萬不要誤會了哦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我這是在跟誰解釋啊……",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天感覺做什麼都不順呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我啊，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是真的就跟陛下說的一樣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是一個很糟糕的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "缺陷品呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯嗯？　",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你你你，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛抱著我啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n你是喜歡我是不是啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快放開啦殺了你哦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯～？　",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昏過去了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是因為睡迷糊了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以才抱我？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵。",
        "unit_id": 1,
        "voice": "vo_adv_2005004_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我建議妳別亂動比較好唷，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n如果妳很重視他的話。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看起來有點輕微的休克。",
        "unit_id": 1,
        "voice": "vo_adv_2005004_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但性命應該是無恙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "放心吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n他只是耐不住空間轉移，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以失去意識罷了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咿！？",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n陛、陛下……！",
        "unit_id": 106012
    },
    {
        "type": "still",
        "still": "200500401"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真討厭，這孩子真是的……",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n居然還發出了『咿』的聲音。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "簡直就像是",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看到怪物一樣的反應嘛。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真讓人傷心～",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是打算",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要好好地照顧妳一下的呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以別叫我『陛下』，那聽起來好有距離感，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我們是家人對吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非、",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非非非、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非常抱歉！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "尤絲蒂亞娜大人……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『大人』是多餘的呢。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_024"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不過算了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "因為今天我的心情還算不錯。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "因為，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_025"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "感覺可以一口氣解決掉那些礙眼的傢伙。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n畢竟打掃過後，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "心情都會很舒爽嘛。",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "話說回來。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_026"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你們幾個，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n還真的在山裡遇難了呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但我實在是等不及了。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_027"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n而且時間也晚了，想趕快上床睡覺，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以就直接把妳給叫來了♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "以妳為目標，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_028"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n順便連他也一併帶到這裡來了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所、",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以是用空間轉移……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把我跟{player}，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一起從山裡",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "瞬間移動到王宮裡來嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種事情，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算是用魔法也辦不到！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不會辦不到啊。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_031"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留，妳也真是的，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳以為我是什麼人啊？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "有一種東西叫做『傳送門』，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_032"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但因為有些狀況所以封印起來，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不太會讓一般人使用。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n在過去，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這可是稀鬆平常的移動方式唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我只是介入了那個『傳送門』的魔法迴路，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_033"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n稍微借用了一下而已。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但這讓我耗費了無謂的魔力呢，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_034"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "明明想要盡量多保留一些的說。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳要好好地感謝我唷，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_035"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可愛的凱留……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要是妳還繼續留在那座山上，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n說不定會被波及到，然後就地成佛了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……？　",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我有點搞不太清楚狀況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請問您找{player}有什麼事嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我收到陛下的命令後，",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就一直在觀察他……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他只是一個沒有任何優點，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很普通的男孩子而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我無法理解陛下如此在意他的理由。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以妳是想說，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_038"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要我放他一馬的意思嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "　\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "看來你們感情",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "培養的不錯嘛～？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "那是叫【美食殿堂】嗎？　",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_039"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n妳甚至還加入了那個奇妙的公會是吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那、那是臥底工作。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我想說如果能成為她們的夥伴，就能讓她們疏忽。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "嗯，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_041"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "那個我知道啦。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n可愛的凱留，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我的凱留……♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我跟妳說過對吧，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_042"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳就像是我的一部分一樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以妳的心情啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我可是很簡單地就能感受到的唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_043"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳很想要朋友嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "　\n不對，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不對，是想要被愛嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我懂的～",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "因為一個人會覺得很寂寞嘛。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "……但是啊，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_044"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n神明啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是不需要朋友的唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "只需要獨身一人，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_045"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "並且支配萬物。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n那就是我們的生存方式唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳明明應該就是我的一部分，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_046"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但為什麼連這麼簡單的道理都不懂呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "唉～",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_047"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是失敗啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "果然在這個世界裡，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n即使『預知未來』，感覺也無法信任。",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "200500402"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳可不要誤會囉",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_048"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這並不是什麼處罰，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳也沒有做錯什麼事情。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "雖然妳連一件我交待的事都沒達成，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_049"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n一副醜態畢露的樣子就是了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n不過，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這並不是妳的責任。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可愛的凱留，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_050"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "乖孩子凱留……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是我太天真了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n竟然把妳當成人類一樣對待。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "明明就只是個道具而已。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_051"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "因為『公主騎士』的力量太過強大，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_052"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n覺得妳的肉體可能無法承受……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以打算慢慢地一點一點，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "一邊給妳一邊讓妳習慣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但從結果看來，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_053"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n妳無法好好地控制魔物，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n沒能達成自己的使命。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "即使如此，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_054"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "累積經驗之後應該會有成長……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n還稍微期待了一下，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳或許還能拿出些成果來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但已經沒有那種時間了，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_055"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n因為我開始覺得有點麻煩。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我不想再顧慮妳的肉體，",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_056"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要直接把『公主騎士』的力量全部給妳。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就算妳可能因此壞掉……",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_057"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不過只要再重作一個就好了嘛。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "從錯誤中學習就是成功的秘訣唷。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_058"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『下一個凱留』，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n說不定會是一個更有用的孩子嘛。",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為、",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n為什麼",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要對我這麼殘忍……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n不要、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要啊啊啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106012,
        "voice": "vo_adv_2005004_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我有、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有努力當個乖孩子啊……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "……嗯？",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_061"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n哎呀、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n{player}醒來了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "都是因為妳大聲發出那種低俗的叫聲啦～凱留。",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_062"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不好意思哦{player}，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n很吵對吧？",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "200500403"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "嗯？",
        "unit_id": 106911,
        "voice": "vo_adv_2005004_063"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n怎麼了嗎，{player}？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你把兩手這樣張開，",
