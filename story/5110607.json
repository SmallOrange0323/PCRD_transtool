[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "期望成為世界第一大壞蛋的諾維姆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天也進行著非常認真（？）的鍛鍊。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哈哈哈哈～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……不，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "感覺有點不太一樣～？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n再稍微",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "壓低一點聲音可能比較好……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "唔……？",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_001"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n尾狗刀，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "諾維姆她在做什麼？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "看她突然笑出聲來，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "下一秒卻又沉默不語。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊，",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那個啊──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n她在練習壞蛋般的放聲大笑。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過她那種興趣，我完全無法理解。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_003"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你說什麼！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "放聲大笑應該是",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "正義一方的特權……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n看來我必須糾正她的認知！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我都忘了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這個人也是跟諾維姆同類型的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "只是所堅持的東西不一樣而已。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但願後續不會演變成麻煩事。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喔～呵呵呵呵……",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣也不對！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "耶嘿嘿嘿嘿……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這樣好像",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有點太沒品了。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n壞蛋的放聲大笑，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還真難練啊……！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "那是當然，",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_006"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "諾維姆！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n因為",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "會朝湛藍天空放聲大笑的，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n總是正義的一方啊！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你說什麼～！？",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n那麼，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你笑一次給我看！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你能辦到",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "充滿正義感的完美放聲大笑是吧！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "沒問題，",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_008"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳好好看清楚且聽清楚了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……啊～",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊～",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "咳咳。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "呵呵呵……",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_009"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哼哼哼……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊──哈哈哈！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n哼哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈哈！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如何，",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_010"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這放聲大笑很出色吧！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n我打算總有一天要在主人面前展現成果，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n所以每天都早起練習，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "練成了這獨門絕活！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好、",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "厲害……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真的好像",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "壞蛋的笑聲！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我太感動了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真軌！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "很有當壞蛋的才能呢！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n竟然可以放聲大笑得這麼邪惡！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "什麼，",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳說我的放聲大笑很邪惡！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "尾狗刀，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你覺得我「正義的」放聲大笑如何！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你不必有所顧忌，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我想聽聽你最真實的意見！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你的笑法，感覺就像是會在故事中盤被擊倒，",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n毫不起眼的中BOSS吧──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還有，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你最好別在你那主人面前這樣笑喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "咦，",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_014"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "有這麼糟嗎……？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "再這樣下去，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我不就沒法保護主人了……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不，",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我只是單純在說笑聲的部分。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不管你怎麼笑，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "並不會影響到你的能力強弱吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆、真軌",
        "words": "會影響！",
        "unit_id": 1,
        "voice": "vo_adv_5110607_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆、真軌",
        "words": "絕對會影響！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦……？",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我說啊，",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_018"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "惡與正義",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要不要暫時聯手？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "如果無法練成完美的放聲大笑，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我們倆都會兩敗俱傷！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我也正想這麼提議！",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_019"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "正義與惡的對決，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就先暫緩到我們練成放聲大笑之後吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不管是正義、是惡，還是高笑聲，我都無所謂，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n所以我要先走一步囉……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀，",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_021"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你也太不配合了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你以為你一個人可以逃得掉嗎！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "沒錯！",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_022"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "那麼，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我們一起來努力達成目標吧……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "練就最棒的放聲大笑！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "拜託你們",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "饒了我吧……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這很明顯不是我該扮演的角色啊……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你會覺得害臊，只有在剛開始的時候而已！",
        "unit_id": 191011,
