        "words": "羅蘭搜查官。",
        "unit_id": 194311
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "萬無一失。",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_004"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n……不。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "能不能請你",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_005"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "再把制服的輸出提高一些。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n打倒魔物累積經驗後所帶來的能力提升，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "現在已經明顯慢下來。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n要逮捕那些七冠，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "我認為照這樣下去還遠遠不夠。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "別說傻話了，羅蘭。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_006"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n就連現在的規格，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "都已經是貼近危險界線……",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "不。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "如果是一般人，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "早就負荷不了而發狂了。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "可、",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_007"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "可是──",
        "unit_id": 194211
    },
    {
        "type": "still",
        "still": "221600201"
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "阿澤爾德高級搜查官的孩子，",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_008"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n還有那些只有我一半大的小孩們，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "明明都在拚上性命戰鬥。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n我卻……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "黑灰色的龍",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 19512
    },
    {
        "type": "dialogue",
        "name": "格魯尼、羅蘭",
        "words": "！！",
        "unit_id": 1,
        "voice": "vo_adv_2216002_009"
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "黑灰色的龍",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 19511
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "羅蘭搜查官──",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_010"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n在追求表面的強大之前，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "先讓自己的心平靜下來。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n不然，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "到了關鍵時刻，只會落得功虧一簣的下場哦。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "唔……",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_011"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……是──",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哎呀呀。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_012"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n話說回來──",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "局長。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n你的身手，真是越來越好了呢。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "嗯。",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_013"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "不過……",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "羅蘭說的話，也是有點道理。",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_014"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n若LoA是個只靠劍與拳頭",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "便能決定一切的世界，那倒還好說。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "但事實並非如此。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "那些說到底，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_015"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "也只不過是在遊戲系統定好的規定內而已。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n然而，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "七冠們卻總是一副理所當然的樣子，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "輕易逾越那些規則。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "既然如此，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "我們這邊也得拿出王牌才行──",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_016"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "……",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_017"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "「芙蕾雅」。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n妳是不是來得太晚了？",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "明明我是在天剛亮就下達召集命令的。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "………………",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_018"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………真的……",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_019"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n非常抱歉……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……怎麼了？",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_020"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "妳的臉色，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "看起來不太好。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……身體狀況",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_021"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "沒有問題。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "比起那個……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我已經從格魯尼高級搜查官那裡",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_022"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "聽說了。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "接下來……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "妳們似乎要和",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "尤絲蒂亞娜一派進行「交涉」是嗎？",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……嗯，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_023"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "沒錯。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "眼下首要的課題，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n就是應對前幾天潛行進來的",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "「最後的七冠」。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……幻境龍后。",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_024"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n光憑她是七冠這點，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "就已經有充分理由逮捕她了。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n更別說她還在「現實」",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "四處散播那種叫做M４粒子的東西。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "而且根據聯合國軍的報告，",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_025"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "幻境龍后是就算用上軍用兵器，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n也無法處決的",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "極強大超能力者。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "既然如此──",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "趁她還在「VR」那一邊時，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_026"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "由我們來設法處理。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "雖然也很難說，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "和在「現實」那一邊逮捕她相比，究竟哪一邊比較困難。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "要是能在現實裡直接控制住她的人身，",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_027"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "事情就簡單多了。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n對方肯定也明白這一點，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "更何況她還擁有超能力……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "不過，",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_028"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "在「現實」裡沒有特殊力量的人，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n到了「VR」之中，卻能使用彷彿重現超能力般的力量。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n也就是說，可不能放過現在這個機會。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_029"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "原本的話，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_030"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "以人海戰術來補足戰力才是常規作法。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "但我們兵力單薄──",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "因為無法保證能夠返回現實，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n所以沒辦法再把更多的術士職員",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "帶到這邊來。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "再加上千里真那的駭入，",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_031"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n也把組織搞得一團亂，實在令人火大。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "所以，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "才想說設法就地招攬人手──",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "就是這麼回事。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……所以……",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_032"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n才要和",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "尤絲蒂亞娜一派……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "聯手……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……於妳這個對阿斯特賴亞皇族懷有怨恨的人來說，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_033"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "心情想必很複雜吧。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "但妳要把這當成任務。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n分清楚事情的輕重緩急。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……若是、",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_034"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "任務的話。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不打算摻入",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "任何私情。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "很好。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_035"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "──那麼芙蕾雅，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "我想把後援的工作交給妳。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n以防「交涉」破裂。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……了解。",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_036"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_037"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n局長……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "菲絲雷斯──",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_038"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "芙蕾雅那傢伙，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "樣子是不是有點不太對勁？",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n她平常明明都很沉著冷靜。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n可今天的她，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "看起來精神狀態相當混亂……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "八斗神、格魯尼",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2216002_039"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "菲絲雷斯那邊，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_040"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "我交給她一項「特別任務」。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n因此，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "她身上多半也背著不小的負擔吧。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "不過……",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……你在擔心她嗎？",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_041"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "羅蘭。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "這個嘛……",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_042"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "就算再怎麼有才能，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "那傢伙終究還年輕。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n我也不太清楚詳情，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "但她是孤兒吧？",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n雖然由我來說也怪怪的就是了……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "……真是的，",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_043"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "你還是一如往常地天真啊。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "可別因為對方是女人或小孩，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n就認定一定得保護她們，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "或是她們一定需要依靠。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n放在現代來看，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這種想法反倒可能會被視為歧視喔。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "尤其",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_044"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "是在這個電腦世界裡。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n畢竟肉體性能上的差距，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "可是能輕易被顛覆的。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "可、",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_045"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "可是……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_046"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "兩位",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "也都知道。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n我啊，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "也不是什麼普通的出身。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n算是「被改造過的人類」。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……我是在聯合國的實驗室裡誕生，",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_047"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "接受特殊部隊的訓練。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n被賦予任務，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "再去完成任務。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n可是……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "為什麼活著、",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "又是為了什麼而活，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "從來沒有人告訴過我。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "告訴我答案的，",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_048"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "是阿澤爾德高級搜查官。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n他告訴我，",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "要成為弱者的助力。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "要去守護年幼的孩子們。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "\n這就是我這副身軀的用途。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……所以，",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_049"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "我……",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "那就是你的「正義」吧，",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_050"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "羅蘭搜查官。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "不過我倒希望你別忘了，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "就算是女人和小孩，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n也一樣有可能犯下罪行。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "──哦呀。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_051"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n局長。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n差不多",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "也快到和【美食殿堂】",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "碰面的時間了吧？",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……嗯。",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_052"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "羅蘭──",
        "unit_id": 193611,
        "voice": "vo_adv_2216002_053"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "視交涉結果而定，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "也有可能與公主們交戰。",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n到時候，",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "我可不希望",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "還要去擔心背後的事，明白嗎？",
        "unit_id": 193611
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "……",
        "unit_id": 194211,
        "voice": "vo_adv_2216002_054"
    },
    {
        "type": "dialogue",
        "name": "羅蘭",
        "words": "是。",
        "unit_id": 194211
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "局長，你不必擔心。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_055"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n正如你所知，",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "他和我不一樣，是個非常認真的人。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n認真到甚至能高舉著那樣美好的「正義」呢。",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "──是啊。",
        "unit_id": 194312,
        "voice": "vo_adv_2216002_056"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "像我這種彆扭的人看來……",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n那簡直是愚蠢到",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "令人作嘔的「正義」啊──",
        "unit_id": 194312
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193712,
        "voice": "vo_adv_2216002_057"
    },
    {
        "type": "background",
        "background": "502680"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "…………",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_058"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……？",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_059"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……呼……",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_060"
    },
    {
        "type": "still",
        "still": "221600202"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "幻，",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_061"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "辛苦妳了♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n真是生出了一個",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "活力十足的孩子呢♡",
        "unit_id": 195611
    },
    {
        "type": "still",
        "still": "221600203"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "我要求更正，",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_062"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "阿爾莎特。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這不過是從艾爾皮斯島底部的隱藏資料夾裡，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "復原出來罷了。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "而且，",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_063"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "接下來才是讓它變得有精神的時候……",
        "unit_id": 107411
    },
    {
        "type": "background",
        "background": "502680"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──哎呀？",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_064"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "怎麼了嗎。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "黎薩。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n我記得，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "應該是請妳去負責讓「他」復活才對。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "那件事，",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_065"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "剛才已經結束了。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "不過……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "從靈魂施展「復活魔法」，",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_066"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我也是第一次使用。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n更何況「他」本身，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "就處在相當特殊的狀態，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "所以我也沒有多少自信",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n能把他恢復成原本的模樣。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "那部分就等之後再請妳們確認吧──",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──？",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_067"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……那個。",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_068"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我正在找芙蕾雅。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n妳們有看見她嗎？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "哎呀♡",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_069"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "黎薩真是的……",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n因為心愛的芙蕾雅不見了，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "所以寂寞得都快哭出來了嗎？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "既然這樣，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "那就由我來代替她陪妳睡吧……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "倒也不是那樣。",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_070"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "只是，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "她剛才還相當失態，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "結果之後就直接消失了，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n到現在都還沒回來。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……所以，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我才稍微有點擔心。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "呵呵。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_071"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n妳真溫柔呢，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "黎薩。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "能抱持夥伴意識，是件好事。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_072"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n總比彼此針鋒相對、",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "互相傷害來得好。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "哎呀……",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_073"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "♡\n女孩子之間，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "針鋒……？",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……我並不是",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_074"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "溫柔……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……看來妳是不會",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_075"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "擔心她呢。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n阿爾莎特應該也知道內情才對。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……而且──",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "……吶。",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_076"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n我從剛才開始，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "就一直很在意……",
        "unit_id": 195214
    },
    {
        "type": "still",
        "still": "221600202"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "幻境龍后。",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_077"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n妳手上拿著的那個……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "是蛋？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "我也不太確定。",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n不過看起來，似乎不是普通的東西……",
        "unit_id": 195214
    },
    {
        "type": "still",
        "still": "221600203"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "嗯。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_078"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n這是──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "是幻生下來的，",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_079"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "小‧",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "蛋‧",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "蛋♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n唷♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "……雖然並非我親自生養的。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_080"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "但這是曾經的我，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "熬夜製作出來的程式。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "同時，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也是我的王牌。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "話雖如此。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_081"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n若要讓它「孵化」，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "並做為卡片來使用，",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "接下來還得餵它很多飼料──",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "也就是資源才行。",
        "unit_id": 107411
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "哦呵呵♡",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_082"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n明明是蛋，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "竟然還會吃飼料。",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "\n",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "像幻一樣，",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "是個貪心鬼呢……♡",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "蛋的，",
        "unit_id": 195214,
        "voice": "vo_adv_2216002_083"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "飼料？",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "那到底，",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "是指什麼……",
        "unit_id": 195214
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "當然是，",
        "unit_id": 195611,
        "voice": "vo_adv_2216002_084"
    },
    {
        "type": "dialogue",
        "name": "阿爾莎特",
        "words": "幻的奶──",
        "unit_id": 195611
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "──不。",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_085"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "\n所謂的資源……",
        "unit_id": 107411
    },
    {
        "type": "still",
        "still": "221600202"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "就是像嬰兒副食品那樣被細細磨碎的，",
        "unit_id": 107411,
        "voice": "vo_adv_2216002_086"
    },
    {
        "type": "dialogue",
        "name": "幻境龍后",
        "words": "「這個世界」。",
        "unit_id": 107411
    },
    {
        "type": "still",
        "still": "end"
    }
]