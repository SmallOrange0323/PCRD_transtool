[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天在蘭德索爾全境內，盛大舉行著豐年祭。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【美食殿堂】一行人逛著豐年祭的攤販、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n充分享受著她們的公會活動：吃遍美食。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在慶祝豐收的祭典裡吃遍美食。",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是最適合我們的公會活動了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不管有沒有舉行祭典，",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不是隨時都在吃東西嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家都在感謝著食物，",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這種團結的感覺很不錯嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感謝今年的收成，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "祈求明年的豐收。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的是很棒的祭典。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真希望每天都舉辦☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的嘴角黏到飯了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下幫您拿下來哦……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊呣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這邊還是平常的老樣子……",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有點分寸好不好，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留你雖然說這種話，",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自己不是也買了各種東西嗎～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又是棉花糖又是可麗餅。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後還有蘋果糖。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "祭典的必備名產",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一項不差地蒐集齊全了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很，",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很囉唆耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼關係。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正看起來都很好吃嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯，",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來好吃的東西最難抗拒了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　這個聲音。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吵哦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是器材故障了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺好像是從空中傳來的聲音……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇！？",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "您沒事吧！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風，",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風太強了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根本站不起來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105913,
        "voice": "vo_adv_4007001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要麻煩您出手相助，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真對不起。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位！",
        "unit_id": 190811,
        "voice": "vo_adv_4007001_015"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n來得正好！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼慌張的樣子，怎麼了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳會這麼慌張，就表示",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有麻煩的事要委託我們對吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說來聽聽。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們會聽的，所以趕快說吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "剛才那陣奇怪的聲音和陣風，",
        "unit_id": 190811,
        "voice": "vo_adv_4007001_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n已經確認在蘭德索爾各地",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "頻繁地發生……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n也開始連絡不上",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "前去調查的公會們。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然公會管理協會已經展開行動，",
        "unit_id": 190811,
        "voice": "vo_adv_4007001_019"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但事件的範圍太廣了",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "，人手實在不夠……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "希望【美食殿堂】的各位",
        "unit_id": 190811,
        "voice": "vo_adv_4007001_020"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能去調查",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n失去連絡的那些公會。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為這次委託具有危險性，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "付給你們的報酬也會比平常多些。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012,
        "voice": "vo_adv_4007001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就沒辦法了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們接受。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天是難得的豐年祭耶。",
        "unit_id": 105812,
        "voice": "vo_adv_4007001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n竟然有人無法享受，實在看不下去！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500333"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這，這是",
        "unit_id": 106011,
        "voice": "vo_adv_4007001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼回事……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "建築物都東倒西歪，",
        "unit_id": 105811,
        "voice": "vo_adv_4007001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居民們也都不見蹤影。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n根本人去樓空……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只建築物，",
        "unit_id": 105911,
        "voice": "vo_adv_4007001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連農田也",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到處被翻成奇怪的模樣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是那陣聲音！？　",
        "unit_id": 106011,
        "voice": "vo_adv_4007001_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的很難聽！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定又會吹起狂風了！",
        "unit_id": 105811,
        "voice": "vo_adv_4007001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家緊緊聚在一起吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（緊緊抱住～～～）。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！？　",
        "unit_id": 106011,
        "voice": "vo_adv_4007001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要突然抱過來啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_4007001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子好溫暖哦。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您再靠近一點。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……唔！",
        "unit_id": 105811,
        "voice": "vo_adv_4007001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n比剛才更強的風呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幸好我們緊緊抱在一起了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_4007001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真謝謝您。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n多虧這樣才沒有被吹倒。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？　",
        "unit_id": 106011,
        "voice": "vo_adv_4007001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼突然變暗了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是什麼啊！？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有東西漂浮在空中！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……是巨大的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "圓盤？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是那個東西",
        "unit_id": 105911,
        "voice": "vo_adv_4007001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把這座村莊弄得亂七八糟的吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "越來越靠近了唷！？",
        "unit_id": 105811,
        "voice": "vo_adv_4007001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106011,
        "voice": "vo_adv_4007001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼東西啦！",
        "unit_id": 106011
