    },
    {
        "type": "background",
        "background": "510125"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "久等了～！",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明是我指定的時間，我自己卻遲到了……！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為工作……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我不應該找理由推託的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "遲到的部分",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我總有一天一定會還給你的！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再加上之前無數次讓你等的時間……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我大概得給你",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "整整一天的時間才行啊！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "言歸正題，",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "關於",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天的事。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你知道……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我為什麼找你出來嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了，",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就知道你記得我的生日！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "特地把你叫出來",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "幫我慶祝生日。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是擔心{player}搞不好會有所顧慮",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n而難以開口約我──",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我乾脆就主動約他了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你怎麼好像很心虛的樣子？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……♪",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我確實是偶像「櫻井望」沒錯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但也不必特別去考慮",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼樣的禮物才配得上我啦。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……這是你送我的東西。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "光是這點",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就價值非凡了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還是覺得過意不去嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就這麼想要討我的歡心啊？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那不然，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可以拜託你一件事嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有點想要……",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你身上",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "帶著的東西。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、",
        "unit_id": 102931,
        "voice": "vo_adv_4010241_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你千萬不要誤會喔！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可不是想說",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「真希望身邊一直都有你的味道～」",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之類的喔！？",
        "unit_id": 102931
    }
]