[
    {
        "type": "background",
        "background": "501032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從打西瓜開始，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n厄莉絲跟{player}盡情享受了夏天的海邊。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "結果，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "美空在那之後都沒有現身──",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……她",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可能會裝作如此。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "之後出乎意料地來嚇我們。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n畢竟美空似乎偏好採取那種行動。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……如果突然被嚇到，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "露出了奇怪的表情……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "唯獨被騎士先生",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "看到奇怪表情的這種情況，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "絕對要避免。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼都沒有喔。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n雖然有稍微在意的事，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是已經沒關係了。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……現在就別想了。",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這個地方，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有騎士先生在。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我正跟騎士先生",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一起度過夏天。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "應該專注於這件事上。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要日落了呢。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n被騎士先生邀請來到海邊……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的很開心。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "開心的時間，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "過得很快呢。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在看著輪迴的時間，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "明明讓我感到那麼漫長。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真不可思議。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這就是",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所謂的忘了時間嗎……？　",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要是今天，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還不要結束就好了。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那樣的話，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就還能──",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你說走，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是要去哪……？",
        "unit_id": 135012
    },
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………\n……………………",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生的手。",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好大……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n沒想到能像這樣",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "跟他牽手。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "明明已經日落，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有了白天的艷陽照射，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n跟騎士先生牽在一起的手，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "卻熱得像是要被燙傷了。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "明明很溫柔卻有力，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生的手。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "永遠都不想放開……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有交談，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只是一起行走而已。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就感覺胸口深處像是被緊緊抓住一般。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這就是",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "美空所說的，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「心動★」",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是嗎……？　",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要是我能夠回握",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這隻手就好了。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那樣的話，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我就不會害怕。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就算不進行那樣丟臉的彩排，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n也能傳達這份心意了。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……如果能被允許，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想抱住這隻手。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n抱住騎士先生、",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "抱住騎士先生的一切。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "………………\n………………………………",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你想讓我看的東西，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "到底是什麼？",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "海岸邊在發光……",
        "unit_id": 135012
    },
    {
        "type": "still",
        "still": "135000301"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "發光的",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "海。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能在這個時期，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "特定的潮汐條件下觀測到的現象……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對吧？",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為我在過去的「紀錄」裡看了好幾次。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我還是第一次像這樣親眼看到。",
        "unit_id": 135012
    },
    {
        "type": "still",
        "still": "135000302"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這些光呀，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "每一顆",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是一隻微小的生物喔。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n牠們是受到刺激就會發光，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "非常微小的存在。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你看……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "來摸摸看吧？",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n閃閃發光著……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "很漂亮喔。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵……",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n波浪很癢呢……",
        "unit_id": 135012
    },
    {
        "type": "still",
        "still": "135000301"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果沒被碰觸、",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有波浪的話。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n連在這裡的事情都不會被注意到，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "微小的生物。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "發光後便消失……",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n要是沒被人碰觸，",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連在哪裡都不知道。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "之前也沒有被人碰觸過。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "感覺……",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "牠們有一點",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "像我呢。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 135012,
        "voice": "vo_adv_1350003_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊。",
        "unit_id": 135012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n之前覺得",
