[
    {
        "type": "dialogue",
        "name": "小棉花糖",
        "words": "汪汪！",
        "unit_id": 15211,
        "voice": "vo_adv_5076321_000"
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "喔，",
        "unit_id": 7711,
        "voice": "vo_adv_5076321_001"
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "渺小的人類之子們，",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "總算找到你們了。",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "幸好靈界和現實世界之間的大門還開著。",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊，",
        "unit_id": 117911,
        "voice": "vo_adv_5076321_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小棉花糖！？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有靈界之王陛下！？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖說很高興能再相見，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼了嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小棉花糖……",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "氣噗噗的？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "不，",
        "unit_id": 7711,
        "voice": "vo_adv_5076321_003"
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "其實……",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "小地獄犬是乖乖回到靈界了，",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n然而，牠卻撒嬌說",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "還想再和你們玩耍……",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "看來",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "牠真的很喜歡你們呢……",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 117711,
        "voice": "vo_adv_5076321_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們也",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很喜歡小棉花糖喔～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "再來一起盡情地玩吧～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對了，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛剛就有注意到……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在陛下身邊",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有一群跟我們長得很像的孩子，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他們是誰啊～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "我認為在和小地獄犬玩耍之前，",
        "unit_id": 7711,
        "voice": "vo_adv_5076321_005"
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n必須要先暖身一下，",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n所以，他們是由我從靈界帶來的靈體",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "所喬裝而成的。",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "即便如此，",
        "unit_id": 7711,
        "voice": "vo_adv_5076321_006"
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "他們可是相當難纏的喔。",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "\n再怎麼說，",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "靈界之王",
        "words": "這就像是跟你們自己戰鬥一樣。",
        "unit_id": 7711
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……",
        "unit_id": 117811,
        "voice": "vo_adv_5076321_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "別小看我們是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是也身經百戰是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "像這種喬裝成我們的冒牌貨，",
        "unit_id": 117811,
        "voice": "vo_adv_5076321_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒什麼好怕的是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "讓你們",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "見識一下萬聖節拯救隊",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "貨真價實的強大實力是也！",
        "unit_id": 117811
    }
]