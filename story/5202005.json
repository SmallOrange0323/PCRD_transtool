    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「失敗為成功之母」",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……！",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下以前也說過這句話……",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但現在該做的事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是垂頭喪氣",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或原地踏步。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下過去也對這個村子",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱有同樣的自責感。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然事情演變成如此，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就更該靠自己的力量想辦法解決……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也曾這麼想過。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在大家的幫助下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不要獨自一人陷入絕望。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下絕對",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是獨自一人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就相信夥伴，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做自己力所能及的事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唯有這麼做，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才能改變情勢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是洗刷心中的後悔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "可可",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_060"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "蘿……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n{player}……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我又……",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_061"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "從妳身上學到了一課呢。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n還有{player}也是……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "謝謝。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我……",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_062"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "要去幫千歌",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的忙。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n雖然我",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "還只是",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "半吊子……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "但是同樣，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "作為唱喚士……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下先暫時告辭了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人的事情，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只在現在破例交給您了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……！",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_064"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n{player}，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "請多指教",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "喔……？",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭法在可可蘿和{player}的鼓勵下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n下定決心對抗失控的精靈，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並且為了與千歌等人一同戰鬥而奔跑起來。"
    }
]