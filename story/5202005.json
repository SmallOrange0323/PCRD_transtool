    },
    {
        "type": "dialogue",
        "name": "扭曲的音寵之精靈",
        "words": "──！！！",
        "unit_id": 19212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}透過夢境"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "收到了愛梅斯的警告，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而緊接著"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就得知村子四周的精靈失控了。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等……",
        "unit_id": 105411,
        "voice": "vo_adv_5202005_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是怎麼回事啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼會有數量這麼驚人的精靈到處在飛！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……！",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_001"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n那孩子……！",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "為什麼，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "會變成這樣……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不行，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "必須阻止它……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在正中央的是……",
        "unit_id": 134411,
        "voice": "vo_adv_5202005_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "干涉了蘭法小姐的那隻精靈？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼……？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "精靈的bug……？",
        "unit_id": 106411,
        "voice": "vo_adv_5202005_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但就現況來看，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎不只是它，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n連其他的精靈也變得很奇怪……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關於這部分，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就由我來說明吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人！",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿……♪",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在不是做這種事的時候……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "精靈們的情況，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實際一看還真不妙呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是我能早點注意到就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106411,
        "voice": "vo_adv_5202005_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所謂的bug到底是指什麼？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n精靈們",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "出了什麼事？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個嘛……",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要說明這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就得先從現在這個世界",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以及精靈這種存在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說起才行呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先來複習一下。",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在的阿斯特朗之所以不穩定",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的原因，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們應該都明白吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對。",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使你們想去救雪菲，卻很多事有口難言，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n歸根究柢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原因也是出在這裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的！",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原因是沒有管理者啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才會在背面世界也遇到了很多麻煩不是嗎。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有管理者的世界",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是非常脆弱的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "目前的狀態",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是靠著大家的「共同幻想」才勉強成立……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要走錯一步，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就很可能會從基底開始崩潰。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許就是因為根基處於這種狀態，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以最近，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個世界的結構",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也慢慢開始受到影響。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次的精靈bug",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是其中之一喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說起來精靈原本",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就被包含在這個世界的系統內，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n它們屬於環境的一部分，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是自然而然便會產生的存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關於精靈的行為，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "除了一部分擁有力量的精靈之外，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n基本上",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是依照簡單的演算法來行動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這部分",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要想成是類似野生動物那樣",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但在最近，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "它們不只是運作不穩定，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n甚至還產出了傾向採取不規則行動的個體。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這個個體，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是位在混亂中心",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的精靈。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一次的失控，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n恐怕就是起因於那隻精靈發生了某種錯誤呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n無法正常運作的結果，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是將錯誤也傳給了其他精靈。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是錯誤持續不斷向其他精靈擴散……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n最終，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "整個阿斯特朗的精靈",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可能全都會出問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這麼一來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟精靈息息相關的自然環境也會變得一團亂呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼會……！",
        "unit_id": 105911,
        "voice": "vo_adv_5202005_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……但是，",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實在令人想不通呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我剛剛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說精靈",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該只會依照簡單的演算法行動",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為一般的精靈",
        "unit_id": 190011,
        "voice": "vo_adv_5202005_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是相當單純的存在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像這樣",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "牽連周遭",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "引發錯誤的胡亂作為，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "它們應該根本辦不到才對……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "都是……",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_022"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我的",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "錯……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐？",
        "unit_id": 134411,
        "voice": "vo_adv_5202005_023"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "因為我……",
        "unit_id": 134311,
        "voice": "vo_adv_5202005_024"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n在那時候，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "說了「快停止」",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
