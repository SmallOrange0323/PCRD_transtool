[
    {
        "type": "background",
        "background": "501880"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "除夕，這天是為一整年劃下尾聲的日子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帆稀與{player}依舊"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n作為小老闆娘與小老闆在手腳俐落地工作著。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──呼～",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大掃除",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "結束了♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n像是擦地板、擦窗戶等等，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你也打掃了很多地方，辛苦了☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "環境變得相當整潔明亮呢～",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "由於旅館不僅大還正在營業，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以有約九成，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都是用我的魔法迅速打掃乾淨的。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但是，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果不多少自己親手打掃，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就沒情調了呢♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "順帶一提，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們的據點早就大掃除完囉☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "主要都是讓祈梨打掃的♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "人懷著真心打掃乾淨的房間，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n比起用魔法整理的房間，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感覺住起來更舒服不是嗎？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這是心情上的問題，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先不說這些……",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大掃除已經結束了，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n工作方面目前也沒那麼忙了。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n暫時有點空閒了呢。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……像這樣",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "稍微閒下來後，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就開始有種今年真的即將結束的感覺呢。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除夕",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果是平時，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就會去買同人誌之類的了。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯。",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖是這麼說，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但那是我在現實世界時的事情。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n現實世界在除夕時，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "會舉辦大規模的同人誌販售會。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以這裡來比喻的話，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就類似蘭祭吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我呀，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "經常會去參加那個活動♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我沒有參加社團就是了。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的同人誌",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都只會用寄售的。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我每次都是",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作為一般參加者參加活動的～☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真懷念……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……啊啊，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "話說回來，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n在「米奈娃的禁錮」",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "之前舉辦的那場活動，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我好像因為太忙沒時間參加。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "早知道就去參加了……",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在發生這種事情後，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n《阿斯特朗傳奇》的同人誌",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該會急遽減少吧。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唔～嗯……",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛～",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖然也不是說只要是同人誌就什麼都可以……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但如果是有趣的作品，我應該會想看。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "身為漫畫家，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該要多接觸各種作品，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n盡量充實自己的知識才行呀☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你果然",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都會想些有趣的事呢～☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在旅館畫漫畫這種想法，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說不定",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還滿合乎道理的。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在現實世界中，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有人是在閉關在旅館中完成原稿的呀。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡或許是個",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能專心作業的好地方呢♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然都這麼決定了，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我幫你準備空客房，當你作業用的房間喔☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你可以",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在那裡",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "盡情地作畫♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……啊，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說不定想到了好點子。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你在作業時，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會去確認你的進度喔♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要讓作品完成，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有人督促和遵守期限很重要呀☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你要加油喔？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我很期待你會創作出",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "什麼樣的作品♪",
        "unit_id": 124511
    },
    {
        "type": "background",
        "background": "501890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──數小時過後……"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "辛苦了～☆",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我拿了點東西來給你吃♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有順便",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我確認一下你的進度吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哦哦，",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你這真是誇下海口了呢～☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "居然只靠一天就要完成同人誌，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一般來說這是很魯莽的行為……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你或許做得到呢。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但是",
        "unit_id": 124511,
        "voice": "vo_adv_1245002_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要獨自畫漫畫，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這還是會很辛苦吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也來幫你忙吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "無論是塗黑、貼網點我都會，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n當然",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就算是畫背景，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
