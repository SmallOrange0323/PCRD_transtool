        "words": "就跟作夢一樣！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n離開這熱死人的城市，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "享受南方海邊的假期～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
