[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼哼～哼♪",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼，",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天也是吃到幾乎不想再吃了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　吃了各種各樣的東西！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的肚子",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃得飽飽的超滿足！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼哼♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5004000_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實是十分美味、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這個量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "餐點份量真的好多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肚子都要撐破了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也是～",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都是貪吃佩可這個大笨蛋起的頭，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼「一起挑戰誰是大胃王吧！」",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的緣故啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要玩自己去玩，",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可以不要把我們牽連進去嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是可是，",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能整個公會參加的大胃王比賽很少見呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們都是同屬【美食殿堂】的伙伴，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n偶爾也想和大家一起努力嘛……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "靠大家的力量一起共同面對困難！",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是所謂的連帶感吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　或著是說團體意識吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很想體驗這種感覺～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨便妳想幹嘛我是無所謂……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但每天一直吃，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都要變胖了啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明馬上就是瑪爾傑海岸",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n海水浴場的泳裝季了不是嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得妳豐滿點也很可愛喔，",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不如說還請妳再吃胖一點吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "帶點油脂感覺更美味～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要一副飢渴難耐的模樣盯著我！",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳這玩笑我可承擔不起啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_011"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "晚上好～",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位感情還是那麼好呢♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳在這種地方",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做什麼呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_013"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "稍微來兼差一下，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n應該說是要幫忙政府機關的其他部署而被召集了過來。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "最近不知為何，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不管哪裡都人手不足呢……♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "話說回來，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_014"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位要來抽個獎嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抽獎？",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_015"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_016"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在鬧區只要購買或吃飯",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "達到一定金額，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就可以在集點卡上蓋章集點……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n章數集滿一張，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就能來轉搖獎機抽獎了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊……",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來最近好像每間店，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都有在幫人蓋像那樣的集點卡。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我這邊好像有幾張？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有了！",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要有這個卡片",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能抽獎了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_019"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是這個就是這個。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一二三四……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "填滿章數的卡有四張，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n可以抽四次哦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有空的話，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_020"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請務必來試試手氣吧♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那來挑戰看看吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很想要那個呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三獎的高級水果禮盒……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是些不怎麼樣的獎品嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好窮酸的感覺。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正抽不中也沒損失，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就抽抽看吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗚嗚，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_023"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "記得凱留小姐之前也是王宮內勤，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n那應該是知道的吧……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "最近可能是軍事開銷提高，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_024"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n各個公家機關",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都受到影響而資金短缺。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "即使如此，還是為了活化各地區，",
        "unit_id": 190811,
        "voice": "vo_adv_5004000_025"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n絞盡腦汁，相當努力喲。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了不起！",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　不愧是花凜小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是個出色的社會人士！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也要好好效仿人家才是啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼要對我說！",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也是每天都有工作啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和妳這個",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成天只會吃飯睡覺的傢伙可不一樣！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105812,
        "voice": "vo_adv_5004000_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我偶爾也是會打打工的～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我很有幹勁的……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實際上，",
        "unit_id": 106012,
        "voice": "vo_adv_5004000_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙也不需要工作吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
