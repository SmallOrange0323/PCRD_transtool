[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了修補破掉的衣服，\n向紡希的店鋪而去。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歡迎光臨――！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼嘛是騎士先生啊。你來這裡有什麼事嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只是看看不買的話就請回吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、我知道了啦！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請不要這麼靠近我！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……讓我看看吧。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種程度的馬上就能補好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我是真的不想和你有任何瓜葛了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但衣服本身是沒有罪過的。你拿過來給我看看吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔哇……這是怎麼回事啊？這不是破的亂七八糟的嗎。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "稍微等我一下。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，我都補好了。請你別再弄壞它了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n錢就不必了，以後穿衣服自己多小心一點。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "之後還有工作嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、我才不是想知道，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你是在哪裡做什麼工作的喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喂，快點到其他地方去吧！出去出去！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊真是的氣死我了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼怜大人要和這種人……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那時候怜大人的神情……如此明亮，我還是第一次見到。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……為什麼是騎士先生，為什麼能和怜大人如此的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "越想就越～覺得一肚子火！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼不乾脆搞砸工作，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓流言什麼的傳開來算了……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──就是這個！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我要想個辦法讓他工作失敗，",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這件事傳開來的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人對他的信賴也會消失殆盡才對……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我的計劃，真是完美！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天也該打烊了！趕快付諸行動吧──！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生跑哪去了……找到了！一定要在他出了街上之前，",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n搶先一步才行！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這地方和平原接壤的只有這麼一條道路……我一定要搶先在此先設置好！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_017"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這裡應該不錯吧。接下來……設下我最高超的陷阱──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "首先用這魔物的毛編織的透明細線絆倒他……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──好了。完成了！這樣應該就不會被騎士先生察覺出來了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來吧快過來吧！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n膽敢接近怜大人的蟲子都由我來驅除掉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在那之後紡希足足等了一個多小時，\n但{player}還是沒有出現。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……沒有過來。他絕對會通過這裡的才對啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難道騎士先生遇上什麼情況了……？還是遭到魔物襲擊了！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不不我怎麼能擔心這種事。總之得先去偵察一下！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "找到了！還在那邊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n站得好好的也沒昏過去啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "謝謝你了啊～小哥！",
        "unit_id": 611,
        "voice": "vo_adv_1054002_024"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n行李，會不會太重啊？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我這裡連點謝禮都給不出來，真是不好意思啊……",
        "unit_id": 611,
        "voice": "vo_adv_1054002_025"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真的很謝謝你……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼嘛，裝什麼好人啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n明明只是隻想接近怜大人的蟲子……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不對。才不是那樣。騎士先生真的是個好人啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣的人，我居然還想陷害他……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我還是……把陷阱收回來吧。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_029"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會想了這麼愚蠢的事情啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀──！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好痛痛痛……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是誰啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n竟然在這種地方挖洞！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是我啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我居然中了自己設下的陷阱……",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你覺得我看起來像沒事嗎！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你以為是誰的緣故才把我搞成這個樣子的啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要一副如此關心的眼神看著我啦！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n會變成這樣子還不是因為……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還不是因為騎士先生你跑去幫忙老婆婆的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n多虧了你我才會中了自己設下的陷阱啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是因為……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不希望騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n和怜大人的關係再變得更加親密了……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就只是這樣！所以你就不要再管我了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明就叫你，不要來幫我了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "居然會被想設陷阱陷害的對象給救出來……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真是羞愧的想去死了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那個！謝謝你。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後那個，還給你設下陷阱……真的很對不起。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過我才不會把怜大人交給你呢！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我都不知道我何時變成紡希的東西了。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是怜大人！？怎、怎麼會！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我看他一直沒來工作，我就很擔心地過來接他了。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "結果我就來路中間看到一個大洞。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "居然和怜大人一起工作……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可沒聽說過有這件事啊騎士先生……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼會變成這樣，可以給我好好說明一下嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是。這是──",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……就是這樣。",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哎……他不是紡希妳想的那種卑劣的人。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣妳明白了吧？為什麼要幹出這種事情來呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不想讓怜大人只對騎士先生一個人好啊──！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為怜大人，您不是和騎士先生有說有笑的嗎！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什！我、我才沒有……！",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在還羞紅了臉……！我越來越不能原諒你了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生太狡猾了啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "魔物！？為什麼會出現在這種地方？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "消滅出沒在這一處原野的魔物就是我們今天的工作。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n紡希來得正好，妳也過來幫忙！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也要嗎！？但、但我該做些什麼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，你這話是認真的嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "辦得到嗎…？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不錯的提案。我會和他一起引誘魔物上鉤的，",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以就麻煩紡希把陷阱給準備好了！喂你，一起上了哦！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！怜大人！騎士先生！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那兩個人，我做了那種事了還這麼信任我……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的！真是兩個爛好人！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我做就是！我做就是了啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希！準備好了嗎？",
        "unit_id": 100312,
        "voice": "vo_adv_1054002_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你來給我強化吧！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "準備好了！再稍微後退一點，",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就要請你們要用跳的避開了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……就是現在！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要往後跳了哦！",
        "unit_id": 100312,
        "voice": "vo_adv_1054002_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拜託了，一定要成功！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_064"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太好了！怜大人，再來就麻煩您了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊！",
        "unit_id": 100312,
        "voice": "vo_adv_1054002_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看我一口氣切碎你！斬擊風暴！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呼。總算是結束了。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好厲害……！怜大人您好厲害！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也是，剛才那個像是魔法的技能是什麼啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是他所擁有的特別的力量哦。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希也做得很棒呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來妳就把魔物搬到城裡去吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這個，要我一個人來嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，不要啊怜大人。您也真是會開玩笑呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是認真的。這是對妳想陷害他的懲罰。",
        "unit_id": 100311,
        "voice": "vo_adv_1054002_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不趕緊點的話，還沒到鎮上太陽就要下山了哦。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼會～！怜大人請放過我吧～！",
        "unit_id": 105411,
        "voice": "vo_adv_1054002_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生對不起啦！我下次不敢了～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}見紡希眼眶泛淚纏著怜求饒的樣子，\n也向怜求情讓她饒過紡希。"
    }
