[
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸，",
        "unit_id": 127311,
        "voice": "vo_adv_5126302_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果是人家誤會那很抱歉……",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不過阿爾杰什寶",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是變得比剛才更有精神了啊～！？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 127211,
        "voice": "vo_adv_5126302_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "起床運動已經做完了是吧？",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "挺有趣的嘛！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "阿爾杰什",
        "words": "真是個囂張的小姑娘。",
        "unit_id": 17711,
        "voice": "vo_adv_5126302_002"
    },
    {
        "type": "dialogue",
        "name": "阿爾杰什",
        "words": "\n然而妳的魔力，",
        "unit_id": 17711
    },
    {
        "type": "dialogue",
        "name": "阿爾杰什",
        "words": "根本遠遠不及安布羅斯……！",
        "unit_id": 17711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哼，",
        "unit_id": 127211,
        "voice": "vo_adv_5126302_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以不要擅自拿我來比較嗎？",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種800年前的偉人，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我哪知道是誰啊！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且，不管我",
        "unit_id": 127211,
        "voice": "vo_adv_5126302_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "究竟比不比得上那個偉人，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都跟你沒關係。",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "阿爾杰什",
        "words": "……妳想說什麼？",
        "unit_id": 17711,
        "voice": "vo_adv_5126302_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的意思是，無論如何",
        "unit_id": 127211,
        "voice": "vo_adv_5126302_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你都會被我打倒！！",
        "unit_id": 127211
    }
]