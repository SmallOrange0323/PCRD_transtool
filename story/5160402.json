    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總、",
        "unit_id": 133512,
        "voice": "vo_adv_5160402_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總算是打倒了呢……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "梅杜莎，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大蛇的狀態如何？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "沒問題，",
        "unit_id": 133611,
        "voice": "vo_adv_5160402_001"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "牠沒死喔。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n明明就使出全力跟我們戰鬥了……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "你真的",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "很強呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "接下來就只剩下",
        "unit_id": 133212,
        "voice": "vo_adv_5160402_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "華音妳了！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不要再袖手旁觀，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "放馬過來吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我會讓妳成為我劍下亡魂的！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "嗚唔唔唔唔唔……",
        "unit_id": 134912,
        "voice": "vo_adv_5160402_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不要得意忘形了啊，小矮子！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n要成為本小姐的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "蠍獅流毒殺劍術下的亡魂的人是妳\n──",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "大蛇",
        "words": "…………！！",
        "unit_id": 18911
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呀啊啊啊啊啊嗯！？",
        "unit_id": 134912,
        "voice": "vo_adv_5160402_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……大蛇",
        "unit_id": 133512,
        "voice": "vo_adv_5160402_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把華音",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "砸扁了呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n「噗滋」一聲地……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "洗腦被解除的大蛇",
        "unit_id": 133212,
        "voice": "vo_adv_5160402_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "擠出剩下的力氣了嗎……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……應該說華音那傢伙，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該不會死掉了吧？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "沒事的啦。",
        "unit_id": 133611,
        "voice": "vo_adv_5160402_007"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "大概。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n因為妖魔人身體很強韌啊。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給華音的處罰",
        "unit_id": 133212,
        "voice": "vo_adv_5160402_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就跟涅妃‧涅羅閣下商量後再決定……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這隻大蛇要怎麼處理？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然原本應該",
        "unit_id": 133512,
        "voice": "vo_adv_5160402_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要把牠放回",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n牠原本在吉歐‧格黑納的住處才對……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是梅杜莎",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "想要跟這孩子",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在一起吧？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……這一點，",
        "unit_id": 133611,
        "voice": "vo_adv_5160402_010"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讓這孩子決定就好了。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "因為我",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不想像華音一樣強迫牠服從我。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "而且……",
        "unit_id": 133611,
        "voice": "vo_adv_5160402_011"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我現在",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "非──",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "常累啊！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "所以說莫妮卡，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讓我吃",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "蘭德索爾的又甜又好吃的東西吧！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵，",
        "unit_id": 133212,
        "voice": "vo_adv_5160402_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "了解了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就帶妳到我的咖啡廳吧！",
        "unit_id": 133212
    },
