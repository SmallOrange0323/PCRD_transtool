[
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚嗚，",
        "unit_id": 131011,
        "voice": "vo_adv_5146308_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼會這麼強……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這就是賭場王先生",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "的真正力量嗎……？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 131011,
        "voice": "vo_adv_5146308_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也不能輸給他。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是為了客人，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了特地聚集",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來這裡的魔物們。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最重要的是──",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了拚盡全力至今的",
        "unit_id": 131011,
        "voice": "vo_adv_5146308_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "庫露露小姐！",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為了",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們的經理！",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "沒……",
        "unit_id": 130911,
        "voice": "vo_adv_5146308_003"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "沒有沒有，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "妳太誇獎我了！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "要是沒有真步小小姐在，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我的遊樂園早就已經……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗚嗚。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……不對，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "現在不是哭的時候！！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "真步小小姐！",
        "unit_id": 130911,
        "voice": "vo_adv_5146308_004"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n雖然已經被妳幫助過不知道多少遍了，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "雖然已經欠了妳花上100次人生也還不完的恩情！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "妳還願意",
        "unit_id": 130911,
        "voice": "vo_adv_5146308_005"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "跟我一起戰鬥嗎！？",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那當然♪",
        "unit_id": 131011,
        "voice": "vo_adv_5146308_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那麼",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們走吧？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "好的──！！",
        "unit_id": 130911,
        "voice": "vo_adv_5146308_007"
    }
]