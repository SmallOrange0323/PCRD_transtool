[
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一天，{player}等人收到了萊拉耶爾的聯絡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前往帕菲之城。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "首先，我得要感謝",
        "unit_id": 126511,
        "voice": "vo_adv_9007001_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位平日的辛勞。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "多虧了各位，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「吉歐‧提格尼亞」受到的魔物攻擊",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才日漸減少。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那真是太好了！",
        "unit_id": 105812,
        "voice": "vo_adv_9007001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟克蘿茜她們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也非常努力啊☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不會不會，",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "如果只有我的話，那可要辛苦到不行了～～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "能有大家幫忙，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真的讓我輕鬆不少！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的要說的話，",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來就算是我們的世界\n在造成你們的麻煩啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該道謝的反而是我們呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們在這個世界的活動，",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是受到了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個世界的居民們種種幫助呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們才是，",
        "unit_id": 126511,
        "voice": "vo_adv_9007001_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今後還請各位多多幫忙。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今天……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我有一件在意的事想要告訴各位。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "其實這一陣子，",
        "unit_id": 126511,
        "voice": "vo_adv_9007001_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各地開始目擊到",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "與至今為止",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不同類型的奇怪魔物。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪的",
        "unit_id": 105812,
        "voice": "vo_adv_9007001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對啊～！",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我之前也是第一次看到，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n跟其他的魔物乍看一樣，但又有些不同呢。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "意思是說，",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出現了更強大的魔物了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是這樣的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就必須想出對策。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不是不是，",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "跟其他魔物比起來，它們好像比較安分。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇怪的地方是，該怎麼說？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "叫聲跟其他魔物不同。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說叫聲，",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是平常那種",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「咕哦哦哦哦哦！」的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "叫聲嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對。",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呃，我記得是──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「5.5──！」",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "或是",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「恭喜──！」",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "之類的叫聲！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "恭喜……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此！",
        "unit_id": 105812,
        "voice": "vo_adv_9007001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也就是說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它們是慶祝5.5周年的魔物！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是什麼鬼魔物啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下居然完全忘了這件事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在５周年之後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回過神來已經過了半年……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是光陰似箭呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅對我們來說，",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對很多人來說都是個重要的日子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n魔物們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定也有著同樣的感受呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "即使如此，為什麼連叫聲都變了！？",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道說現在",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反而是吐嘈的我不對嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "既然是在慶祝，",
        "unit_id": 126411,
        "voice": "vo_adv_9007001_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "意思就是說它們不是壞魔物囉？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不去消滅也沒關係嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使它們沒造成危害，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟還是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "外來的魔物。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為不能置之不理。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意思就是說最好還是捉起來。",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我事先聲明哦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳可別又說些好奇它們會是什麼味道之類的話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇……♪",
        "unit_id": 105812,
        "voice": "vo_adv_9007001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的想法小凱留都知道得一清二楚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我好開心哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少把這件事說得好像很溫馨一樣！",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511,
        "voice": "vo_adv_9007001_025"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就容我再次委託各位……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以請各位捕獲",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那些奇怪的魔物嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，",
        "unit_id": 105812,
        "voice": "vo_adv_9007001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請交給我們吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在慶祝5.5周年那天到來之前，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們就先快點把它們通通抓起來吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012,
        "voice": "vo_adv_9007001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒問題嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到周年紀念日當天",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒剩多少時間了耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剩兩個星期左右不是？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼",
        "unit_id": 105913,
        "voice": "vo_adv_9007001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也聯絡其他公會的成員們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請他們一起協助捕捉吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n萊拉耶爾殿下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣可以嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我明白了。",
        "unit_id": 126511,
        "voice": "vo_adv_9007001_029"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n關於那些奇怪的魔物，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
