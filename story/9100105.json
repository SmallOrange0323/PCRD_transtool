        "voice": "vo_adv_9100105_023"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "太慢了。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "既然要來就要早點過來啊。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "是。",
        "unit_id": 13311,
        "voice": "vo_adv_9100105_024"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "我們來晚的罪過，",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "還請妳見諒……",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "吾等的公主。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "公……",
        "unit_id": 1,
        "voice": "vo_adv_9100105_025"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "公主～！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "……那是襲擊了妳們的牧場後所發生的事。",
        "unit_id": 13311,
        "voice": "vo_adv_9100105_026"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n我們捨棄原先的主人，",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "成了無所適從的叛忍。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n背負著不忠之徒的汙名。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "當然……",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "我們也",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "無處可去。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "然而，",
        "unit_id": 13311,
        "voice": "vo_adv_9100105_027"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "這位公主卻不一樣。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n不顧我們惡名昭彰，",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n她接納了渴望再守忠盡義",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "而四處漂泊的我們。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "這份恩情，",
        "unit_id": 13311,
        "voice": "vo_adv_9100105_028"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "我們必定會傾力報答。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n所以，我們絕不能讓世界被摧毀。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n走吧……",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "眾忍者們！",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "下忍們",
        "words": "是！",
        "unit_id": 1,
        "voice": "vo_adv_9100105_029"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "呵呵呵……",
        "unit_id": 7011,
        "voice": "vo_adv_9100105_030"
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "如果只聽信傳言……",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "只看表面，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "根本沒有什麼是可以信賴的。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "\n若不是這樣，",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "妾身",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "魔物的公主",
        "words": "也只不過是一介魔物。",
        "unit_id": 7011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "半藏這傢伙……",
        "unit_id": 103311,
        "voice": "vo_adv_9100105_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這次找到一個好主人了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然這樣，那也沒辦法了～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你先前想徵收牧場的那件事，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就當作沒發生過吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦～？",
        "unit_id": 102611,
        "voice": "vo_adv_9100105_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是還感到耿耿於懷喔～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好啦好啦，",
        "unit_id": 105211,
        "voice": "vo_adv_9100105_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣也不錯啊♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n他們願意一起作戰，就讓我們信心大增了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "嗯，",
        "unit_id": 4611,
        "voice": "vo_adv_9100105_034"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "沒錯。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n多虧大家的協助，我們聚集到了不少希望！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n有了這些希望，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "應該多少能削弱黑之王的力量……！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喔喔！？",
        "unit_id": 106611,
        "voice": "vo_adv_9100105_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣我們就能打倒牠了吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就讓我狠狠地痛扁牠一頓吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n趕快把牠趕回",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "繪本的世界！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "繪本的……",
        "unit_id": 112911,
        "voice": "vo_adv_9100105_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n……那個，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲。",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果打倒黑之王，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳也得回去對吧？",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "因為我只是趁亂跟過來的～",
        "unit_id": 4611,
        "voice": "vo_adv_9100105_037"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "當事情告一段落，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "黑之王就會回到繪本的世界。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n這樣一來，我也一樣",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "得回到繪本裡去。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣啊……",
        "unit_id": 112911,
        "voice": "vo_adv_9100105_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n難得我們又見到面，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是可惜……",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳幹嘛那麼垂頭喪氣。",
        "unit_id": 4611,
        "voice": "vo_adv_9100105_039"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n說是離別……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "其實我們一直都在一起喔。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "無論",
        "unit_id": 4611,
        "voice": "vo_adv_9100105_040"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "什麼時候，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我都是妳的好夥伴。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "就這一點，妳一定要永遠記著……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲……",
        "unit_id": 112911,
        "voice": "vo_adv_9100105_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那麼，我們走吧……！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n將所有的希望",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "統統都灌注在這弓箭上──",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "上吧──！！",
        "unit_id": 112911,
        "voice": "vo_adv_9100105_042"
    }
