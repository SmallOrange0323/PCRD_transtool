[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚……",
        "unit_id": 127211,
        "voice": "vo_adv_5126204_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙的魔力",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n感覺比剛才更強了……！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶，",
        "unit_id": 127311,
        "voice": "vo_adv_5126204_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳在發抖欸，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒事嗎……？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "借妳用人家的披肩吧！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不用啦，",
        "unit_id": 127211,
        "voice": "vo_adv_5126204_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳應該也會冷吧？",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳不會用魔法，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該也感受得到這股寒氣才對……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？",
        "unit_id": 127311,
        "voice": "vo_adv_5126204_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的不要緊啦。",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在制服底下",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有穿運動服喔。",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼！？",
        "unit_id": 127211,
        "voice": "vo_adv_5126204_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？",
        "unit_id": 127311,
        "voice": "vo_adv_5126204_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有需要那麼驚訝嗎？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事……",
        "unit_id": 127211,
        "voice": "vo_adv_5126204_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是想到妳裡面穿著運動服，身材看起來還那麼好，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就覺得超級模特兒真可怕……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不對，",
        "unit_id": 127211,
        "voice": "vo_adv_5126204_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不是說這些的時候。",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們趕快去追那傢伙吧！",
        "unit_id": 127211
    }
]