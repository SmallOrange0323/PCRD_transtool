    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "趴搭趴搭",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_000"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "……",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "啊，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "中獎了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "又拿到一個點心了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n太好了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "{player}氏。\n我好像",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_001"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "死過之後就覺醒了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "獲得了找出中獎的懷舊點心的能力──",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "當然是開玩笑的。",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_002"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "不過，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "應該是生日運氣比較好吧。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n我可沒有變透明偷看喔。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "那太不解風情了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "話說回來。",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_003"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n居然帶今天的主角到懷舊點心店，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n你的品味還真特別，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "{player}氏。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "我",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_004"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "再怎麼說都是成人女性喔。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "不過我玩得很開心",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "所以也沒關係就是了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "這個拉繩子抽糖果也很令人懷念。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "……原來如此。",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_005"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n也就是說{player}氏",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "是為了失去記憶的小飛白，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n特地挑了這個地方？",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "{player}氏。\n那真是──",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_006"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "很好的判斷。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "以前的事情，",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_007"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "雖然還想不起來。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "但見到自己熟悉的東西，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n老實說我有感到安心。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "沒想到會有這種出其不意的禮物，",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_008"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "你果然",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "很擅長泡妞呢。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "啊啊，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "我也要被吃掉了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "真有道理。",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_009"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "……嗯，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "不開玩笑了。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n畢竟是難得的禮物。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "謝謝你。",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_010"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "沒想到，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "死掉之後還有機會被慶祝生日──",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "剛好這裡",
        "unit_id": 133031,
        "voice": "vo_adv_4010213_011"
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "有兩個剛剛中獎的糖果。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n我們分著吃，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "像小孩子一樣聊天吧。",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "\n",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "給",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "你，",
        "unit_id": 133031
    },
    {
        "type": "dialogue",
        "name": "飛白",
        "words": "啊──",
        "unit_id": 133031
    }
]