        "name": "覺醒‧花心星",
        "words": "可惡！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": " 不過，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "這傢伙不會用魔法吧！？",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n那麼，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺讓她和你們自相殘殺──！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喝！！",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_064"
    },
    {
        "type": "background",
        "background": "501080"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "哇呀！",
        "unit_id": 13511,
        "voice": "vo_adv_5044006_065"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": " 為、",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "為什麼……！？",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你該不會以為，",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種雕蟲小技對我會有用吧？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n分辨敵我這種事，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "根本不必依靠雙眼啊！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐的一擊，很痛吧～♪",
        "unit_id": 113311,
        "voice": "vo_adv_5044006_067"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你看起來也沒有餘力迷惑我們了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "乾脆投降吧～？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "可惡……",
        "unit_id": 13511,
        "voice": "vo_adv_5044006_068"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "可惡──！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": " 你們給我記住了──！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼能讓你逃跑！",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_069"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 七七香、杏奈！！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒問題！",
        "unit_id": 113211,
        "voice": "vo_adv_5044006_070"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " ",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "把力量通通交給流夏！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好的說！",
        "unit_id": 113311,
        "voice": "vo_adv_5044006_071"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就用這一劍",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_072"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "了結你！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 喝啊啊啊啊！！",
        "unit_id": 113111
    },
    {
        "type": "background",
        "background": "501080"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "嘰呀啊啊啊啊！？",
        "unit_id": 13511,
        "voice": "vo_adv_5044006_073"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "贏了！",
        "unit_id": 113311,
        "voice": "vo_adv_5044006_074"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 第三部，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "完！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "啾嗚……",
        "unit_id": 13611,
        "voice": "vo_adv_5044006_075"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看來他已經失去戰鬥力了。",
        "unit_id": 113211,
        "voice": "vo_adv_5044006_076"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，現在要怎麼做……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "唔唔……",
        "unit_id": 4711,
        "voice": "vo_adv_5044006_077"
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "請、請等一下……",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "\n能不能請你們",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "別責怪花心星……",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "牛郎！ ",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_078"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "你已經沒事了嗎？",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "除了頭還有點暈，",
        "unit_id": 4711,
        "voice": "vo_adv_5044006_079"
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "已經沒事了。",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "\n……花心星會附身在我身上",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "是有原因的。",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……原因？",
        "unit_id": 113211,
        "voice": "vo_adv_5044006_080"
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "是的，",
        "unit_id": 4711,
        "voice": "vo_adv_5044006_081"
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "在星空中",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "看見孤單的他，",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "\n而先向他搭話的，是我。",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～",
        "unit_id": 113311,
        "voice": "vo_adv_5044006_082"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我好像有在繪本中讀過這樣的內容……？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "和星星有關的傳說中，",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_083"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "由於花心星有迷惑他人的力量，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n因此也使得他成為被其他星星疏遠的存在。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "花心星。",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_084"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "牛郎剛才說的",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是真的嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "喔，對啦。",
        "unit_id": 13611,
        "voice": "vo_adv_5044006_085"
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "牛郎向本大爺搭話的時候，本大爺很開心呢……",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "\n然後，",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "這傢伙說他因為見不到織女而寂寞，",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "\n本大爺才想說要為他做點什麼。",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後，",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_086"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你就引起了這場騷動嘛。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "放心吧，本大爺已經要走了……",
        "unit_id": 13611,
        "voice": "vo_adv_5044006_087"
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "\n就這樣回到在空無一人的星空盡頭，",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "\n大概就也不會",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "再和你們見面了吧。",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的，",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_088"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真拿你沒辦法呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "織女、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "牛郎！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 要是你們願意的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這之後",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要和花心星一起，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在銀河生活呢？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "和花心星……",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_089"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "嗎？",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯。",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_090"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在你們兩個無法相見的日子裡，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓花心星為你們聯繫感情。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這樣一來，你們既能夠聽到對方的近況，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "花心星也能和你們說說話不是嗎。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "這是個好主意！",
        "unit_id": 4711,
        "voice": "vo_adv_5044006_091"
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "\n這樣既多了一個聊天對象，",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "牛郎",
        "words": "也能期待聽到織女的事了。",
        "unit_id": 4711
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "是啊，",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_092"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "感覺像是有點奇特的書信往來，很有趣呢。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "呵呵。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "你、",
        "unit_id": 13611,
        "voice": "vo_adv_5044006_093"
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "你們……",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "願、",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "願意原諒本大爺嗎？",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我還是對於你附身在牛郎身上作惡這件事",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_094"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "感到相當地生氣。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n想必往後好一陣子，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我仍會時不時地回憶起來吧。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "不過……",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_095"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我也能夠理解你的心情。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "所以，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "你要是能和我們一起在銀河生活，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我就原諒你吧。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "……真、",
        "unit_id": 13611,
        "voice": "vo_adv_5044006_096"
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "真沒辦法啊！",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "\n既然如此，",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "花心星",
        "words": "本大爺就陪陪你們吧。",
        "unit_id": 13611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣事情就算是解決了，",
        "unit_id": 113111,
        "voice": "vo_adv_5044006_097"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 113311,
        "voice": "vo_adv_5044006_098"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可喜可賀可喜可賀。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣祭典也能順利進行了吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "走吧，牛郎。",
        "unit_id": 4811,
        "voice": "vo_adv_5044006_099"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我們來讓這一年一度的盛宴……",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "讓七夕開幕吧！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在流夏、杏奈、七七香及{player}的活躍表現下"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n順利消除了織女、牛郎和花心星之間的芥蒂，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也終於能為接下來的七夕祭做準備了。"
    }
]