[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}康復後過了一段時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但靜流卻始終沒有現身。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……偷偷摸摸。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……鬼鬼祟祟。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "──再見了，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然我說了那樣的話。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐實在是太擔心{player}了，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n沒辦法讓他遠離自己的視線。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}的情況還是很危險呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是姐姐不在的話……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚……",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是因為有我在，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n才害{player}生病的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我沒資格當姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，別擔心。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從今以後，姐姐會像這樣",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n遠遠地守護著{player}的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對於熟悉{player}的姐姐來說，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要避開他的視野行動，簡直是小菜一碟！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要姐姐拿出真本事，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還可以在{player}",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "完全沒有察覺的情況下，\n照顧他的日常生活呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然不能見見他、摸摸他、抱抱他，有點空虛。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但{player}健健康康的模樣",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是姐姐的生存意義！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……我得",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "忍住。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說回來。",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在做什麼呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這幾天",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他經常出門……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但好像又不是去做平時的兼職工作。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他還跟很多人見面說話。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……大多數還都是女生，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這個做姐姐的有點在意。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好好奇，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好好奇啊……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是，不可以，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我得忍住！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了預防萬一，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我去撿一顆大小適中，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就算被擊中，疼痛程度也不上不下的小石頭好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥──！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓你久等了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你還回什麼",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「我也才剛到」～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們這樣簡直就像是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "碰面約會呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是偷跑嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n她這是在偷跑嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n她是不是忘記我們約好禁止偷跑了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這麼說起來，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我最近也好一陣子沒有見到璃乃了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最後一次見面的時候，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "她只丟下一句「姐，我要去修行了！」",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後就沒下文了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "居然",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "偷偷和{player}見面……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃這個叛徒～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得剛才",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有一股非常不苟同的氣息！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "覺得自己被置之不理的氣息！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……應該是我的錯覺吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們重新調整好心情",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "出發吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "找個安靜的地方呀～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……安靜的",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……地方？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃打算在安靜的地方做什麼啊？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要討論重要的事情時，",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最好是在沒有其他人的地方。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "兩個人獨處……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得有點緊張呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇啊！？",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n怎麼突然飛來一個大小適中，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n砸起來疼痛程度不上不下的小石頭呀！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這、",
        "unit_id": 101112,
        "voice": "vo_adv_1049012_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這裡很危險呀，哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我感受到一股靜謐的殺氣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們快走吧～！",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在那之後，",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他和璃乃聊幾句話就分開了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這次要去哪裡呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "到城鎮外",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是很危險的呀～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "像他那樣走路還東張西望的，一定會……",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "腳邊有顆很大的石頭啊～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～",
        "unit_id": 104911,
        "voice": "vo_adv_1049012_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他跌倒了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
