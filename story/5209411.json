    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我的復活祭就到今天為止啊。",
        "unit_id": 135912,
        "voice": "vo_adv_5209411_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你們，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "吃得還真多呢……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "素的。",
        "unit_id": 195512,
        "voice": "vo_adv_5209411_001"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "奧洛克伯爵他，",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "也淚眼汪汪的呢。",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "啊，",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_002"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是嗎。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n話說復活祭的錢，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "好像是伯爵自掏腰包的呢……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不過，",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_003"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "現在",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "回想起來也很不可思議呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n剎鬼差點就死去，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "然後",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "又復甦……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "而且，",
        "unit_id": 195512,
        "voice": "vo_adv_5209411_004"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "復甦的方法竟然素親親。",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n驚訝程度又加倍了呢。",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……不要讓我想起來。",
        "unit_id": 135912,
        "voice": "vo_adv_5209411_005"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "話說，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "親吻是妳的主意吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那、",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_006"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那時，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "真的是走投無路了呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "但是。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "究竟為什麼",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "會有效……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "按照公主姐接的書上所縮，",
        "unit_id": 195512,
        "voice": "vo_adv_5209411_007"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n親親會產生愛的力量，",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "可以抵銷詛咒。",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……還要繼續這個話題嗎。",
        "unit_id": 135912,
        "voice": "vo_adv_5209411_008"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那麼，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我來告訴妳們原因吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然前提是我原本處於假死狀態。",
        "unit_id": 135912,
        "voice": "vo_adv_5209411_009"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那時，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雪野和騎士公的心意與我產生了共鳴。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是兩人的勇氣，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓我甦醒過來的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這、",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_010"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這樣啊……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "原來是勇氣啊。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "嗯，",
        "unit_id": 135912,
        "voice": "vo_adv_5209411_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我隨便說說的就是。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這話題可以結束了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "咦，",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_012"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "哪一個才素真的……！？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "好讓人在意！",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n剎鬼姐接～！",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "咦……",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_013"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼她，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "好像",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在害羞？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這樣啊……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "呵呵……",
        "unit_id": 135812,
        "voice": "vo_adv_5209411_014"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "哪一個才是真的呢。",
        "unit_id": 135812
    }
]