        "voice": "vo_adv_5144000_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "還是老實說出口了啊……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不說的話也許他還不會曉得呢。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們接下來要一起準備祭典，",
