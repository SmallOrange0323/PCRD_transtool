    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雖然是個冒失的人，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但卻溫柔又誠實，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n是個讓人打從心裡信賴的隨從。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咦？",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說了那樣的話？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "和她一起工作時會聊到的話題，",
        "unit_id": 511,
        "voice": "vo_adv_5144000_029"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不是關於育幼院的孩子，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n就是在「炫耀」妳的事呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n她一定",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "相當喜歡妳的個性吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "竟然那樣子稱讚我……",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我卻一來就這麼冒失，對不起～！！　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這次請各位幫忙籌備的「鮮花祭」，",
        "unit_id": 511,
        "voice": "vo_adv_5144000_031"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n既是慶祝春天的祭典，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "也是祈求當年能豐收的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "神聖儀式。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "從準備階段起就得愛護自然，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "並抱持著純淨的心",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "來對待。",
