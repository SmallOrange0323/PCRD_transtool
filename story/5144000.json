        "voice": "vo_adv_5144000_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n來幫忙的人增加了也是件好事♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是說啊。",
