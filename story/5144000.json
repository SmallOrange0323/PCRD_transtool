    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "鏡華說的對。",
        "unit_id": 511,
        "voice": "vo_adv_5144000_044"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n因為這裡實在太鄉下了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "所以年輕人都漸漸往城市移動。",
