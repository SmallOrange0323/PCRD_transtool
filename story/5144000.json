        "voice": "vo_adv_5144000_049"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n尤其有像鈴莓小姐這樣，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "比我們年長的人在就讓人很安心。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "工作碰上困難的時候，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可以找妳商量嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "當、",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "當然好囉～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能聽妳這樣說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓我有點害羞呢～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你",
        "unit_id": 103611,
        "voice": "vo_adv_5144000_051"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "時不時就會做出可疑的舉動……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "倒不如",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "由我來好好看著你！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓也是，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_052"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "與其說是可疑，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不如說是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n常常做出讓人心驚膽跳的事呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓就由我來看著，放心吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「趕緊把真相告訴他們比較好吧？",
        "unit_id": 2111,
        "voice": "vo_adv_5144000_053"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n反正妳很冒失的事",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "遲早會曝光的啊。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咳咳！",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐說過，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然說謊不好，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但不把沒有必要告知的事情說出口，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "才是名能幹的女僕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_055"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對於鈴莓妳不小心失言時的建議，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不是可以隱瞞事情的意思吧……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
        "unit_id": 103611,
        "voice": "vo_adv_5144000_056"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n剛才的發言，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可以收回嗎……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華已經露出不安的表情了！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒問題的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "放心吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我這次一定",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會完美地完成任務的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我知道了。",
        "unit_id": 103611,
        "voice": "vo_adv_5144000_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我也會努力幫忙的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家一起將鮮花祭辦得很盛大吧！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "哈哈哈，",
        "unit_id": 511,
        "voice": "vo_adv_5144000_059"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "馬上就熱鬧起來了呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n請各位",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "務必好好地合作。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是！",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐，請放心吧，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鈴莓我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一定會不冒失地完成任務的！",
        "unit_id": 102511
    }
]