[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在某個春暖花開的日子裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和鈴莓、綾音一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了某座村莊……"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然咲戀媽媽說",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "村子距離還滿遠的……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但沒有想到竟然會這麼遠呢～！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要不是有在上次的冒險裡鍛鍊到，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可能中途就累癱了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "辛苦了，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "綾音。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "去跟村長打聲招呼後，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該就能休息一下了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「打招呼啊，",
        "unit_id": 2111,
        "voice": "vo_adv_5144000_002"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "感覺會很冗長吧？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不讓綾音休息一下可不行啊。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會盡量長話短說的。",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對方每次都會將作物分送給育幼院，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以噗吉也要有禮貌喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的～♪",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然育幼院的經營也穩定下來了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但對於有人提供幫助還是很感激呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這座村莊……",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「芙菈瓦村」的各位，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n分給了我們很多的蔬菜。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "作為回禮，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這座村莊在春天舉行祭典時，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n育幼院也會來幫忙。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然我是第一次參加……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我記得去年參加的是咲戀媽媽和胡桃吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是啊～",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "根據大小姐所說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像是幫忙製作了祭典的裝飾♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔嗯……",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "根據咲戀媽媽所說，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是嗎……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "綾音，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳有什麼在意的事嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一直以來，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都有咲戀媽媽同行，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "或者說都是由她所帶領的吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓妳",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有來這座村莊幫忙",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "準備過祭典嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "放心吧，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也是第一次來呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們一起請村民們",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "教導我們該怎麼做吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是沒什麼關係，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "倒是鈴莓妳沒問題嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是發生什麼萬一的話，我也會幫忙的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如、",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果是關於我的冒失，那請不用擔心！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "即使是我，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "至今為止也是經歷過很多事情的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這一次來幫忙，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我要扭轉大家",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "聽到鈴莓就會想到冒失的印象！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請看著我可靠、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "俐落，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "並且毫無失誤地工作的模樣吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先要將這份伴手禮交給村長……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂，",
        "unit_id": 2111,
        "voice": "vo_adv_5144000_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "等一下。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n咲戀大小姐要妳帶來的伴手禮，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "外盒是那個形狀嗎？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊～！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼辦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不小心",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "把本來應該交給",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐的便當給帶過來了～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "突然就冒失起來了！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n出發時為了怕忘記，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還特地放在行李旁邊的說！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「這種失誤很有鈴莓小姐的風格呢。",
        "unit_id": 2111,
        "voice": "vo_adv_5144000_018"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不過，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "既然都忘了那也沒有辦法吧。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一瞬間",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就失去信心了……",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "歡迎各位",
        "unit_id": 511,
        "voice": "vo_adv_5144000_020"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "遠道而來。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我是芙菈瓦村的村長。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n今年也要麻煩你們了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "育幼院的各位。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們才要請你多多關照♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是伴手禮……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為發生了各種事，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "希望還合你的胃口……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "哦哦，",
        "unit_id": 511,
        "voice": "vo_adv_5144000_022"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這還真是不好意思。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "非常感謝",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "各位如此周到。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "有飯糰和小香腸，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "還有玉子燒啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "與其說是伴手禮，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "更像是便當呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "畢竟，",
        "unit_id": 102311,
        "voice": "vo_adv_5144000_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那就是便當嘛……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，",
        "unit_id": 102511,
        "voice": "vo_adv_5144000_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "村長先生……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實是因為我的冒失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "把本來該交給大小姐的便當，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "當成伴手禮帶過來了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「結果",
