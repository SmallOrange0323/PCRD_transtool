        "voice": "vo_adv_5144000_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我又沒有那樣說！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n只是有點嚇一跳而已！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺好久沒見到",
