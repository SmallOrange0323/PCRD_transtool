    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "連會場的裝飾，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "如果不借助外部的人力就很難準備……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "原來是這樣啊……",
