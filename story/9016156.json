        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到還真難對付呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都出汗了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀呀……",
        "unit_id": 105911,
        "voice": "vo_adv_9016156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被這麼多的噴嚏給波及……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n態度還是如此堅毅，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很佩服。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙只要是為了吃，",
        "unit_id": 106011,
        "voice": "vo_adv_9016156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n無論是火海～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是有毒的沼澤～她也都一副無所謂的樣子。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "若現在因為區區噴嚏這種事就害怕，我反而才會擔心呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 106011,
        "voice": "vo_adv_9016156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣任務就完成了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　\n我們也快點回公會小屋，",
