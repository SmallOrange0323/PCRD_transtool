[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要想達成目的，",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n有時也得現身檯面，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "承受必要的風險。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而要應付這一切，準備自然是不可或缺的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這……",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想這不是該讓你聽見的內容。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n總而言之，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "凡事最重要的就是做好準備。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n關於這點請你務必銘記在心。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明白了嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我並不是為了見你才現身的。",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話雖如此，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能和你面對面交談，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "其實感覺倒也不錯。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n何況這樣也能得到某些",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "光靠遠端觀察所得不到的寶貴資訊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的，",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個身體是我的分身。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但雖說",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是分身，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知覺目前設定為與本體互通。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請不要基於好奇，像戳棉花糖一樣戳我的臉頰。",
        "unit_id": 107011
    }
]