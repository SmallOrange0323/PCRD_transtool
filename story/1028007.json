[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～該怎麼辦，忽然多出了半長不短的時間呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "由於商談對象在沒有通知的狀態下取消會面，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n害我的行程空出了一小時左右的時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭～真希望這種事能早點通知呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然是因為我還年輕，所以就被小看了嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過沒關係，就用這次的事，讓下次的商談導向有利的方向。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，該怎麼辦……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然回【咲戀育幼院】露個臉也不錯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，這樣光是來回，就會到下一個商談的時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是因此遲到，那就糗了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是，要待在廣場發呆接近快一個小時也很空虛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我真的不太擅長消磨時間呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好久沒有像這樣，沒什麼事情做……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該去逛逛街嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，我也想要省錢，",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果逛街，就會忍不住想買呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n咦？{player}！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在這種地方做什麼呢……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看你坐在這裡發呆，是肚子痛嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你很閒嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒有工作要做？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也是，看了就知道了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你總是這麼悠閒……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "人生是有限的哦，我認為什麼都不做的話就是浪費時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，這也是因人而異吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "加什麼「小」，你啊……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n裝得跟我太熟了吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但畢竟我們年紀也差不多。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最近我都是與成年人在交涉事情，",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很久沒被人用「小」來稱呼了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我呢……嗯～沒有什麼特別的事要做。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "由於商談對象在沒有通知的狀態下取消會面，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以我多了快一個小時的閒暇時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你如果不介意，能不能陪我消磨時間？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正你現在也有空對吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果你不想，我也不會逼你就是了……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不是不想？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是嘛，太好了太好了♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話是這麼說，我也沒有消磨時間的主意。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我從小啊，總是在讀書或者是幫家裡的忙，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒什麼特別的興趣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最近也總是在工作……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "早知道當初多玩一點就好了，害得現在有空卻不知道做什麼。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我實在是個無趣的人呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "回想起小時候，",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有個人總是會想些無聊的遊戲，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n來邀我一起玩……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不知道那個人，現在在哪裡做什麼呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，之前也有說過吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就是那個讓我喜歡上炒麵麵包",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的那位男孩子哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在那之後，我們就常常玩在一起。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嗯，就是青梅竹馬呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，我卻完全不記得那個人的臉和名字了……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是奇怪。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明關係那麼要好，我還蠻喜歡他的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個人，難道說……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是過於寂寞的小孩想像出來的朋友嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是所謂的幻想朋友嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該不會吧～♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}在做什麼……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，你在看螞蟻？為什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你啊～你也不是小孩子了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看著那種東西，很有趣嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈……其他的螞蟻明明都在努力的搬運點心碎片。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n卻還是有不工作，在一旁發楞的小傢伙在。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不論是什麼團體，都會有懶惰的傢伙存在呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你問我有沒有帶食物嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你肚子餓了嗎？{player}？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要玩給懶惰螞蟻食物，然後讓牠工作的遊戲？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以前啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也和那個青梅竹馬，做過類似的事情消磨時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他是個不論玩什麼都會很開心的人。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我每天每天，都快樂得不得了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "玩到工作、讀書甚至是將來的事，全都拋在腦後。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是啊，我一點都不後悔。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和他在一起什麼玩些無所謂的遊戲，真的非常幸福……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我深愛著那段時光。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}。\n我記得，你是喪失了記憶沒錯吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個……",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}該不會。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這怎麼可能呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028007_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果他就是你的話……那就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
