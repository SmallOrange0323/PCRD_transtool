[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "辺りに誰もいない広々とした平原に、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n気合のこもった声が響いていた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ふんっ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はぁっ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nどおりゃあああ！",
        "unit_id": 106114
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "遅いっ！",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_001"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nその程度の打ち込みでは、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "羽虫の一匹すらも倒せんぞ！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なになに、",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_002"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なにやっちゃってんのノウェム。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n……ストライキ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そんなわけっ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_003"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ないだろっ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nおおりゃああああっ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ふん、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_004"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "気合だけだな！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "勢い任せだと──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "こうなるっ！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ぐへぇぇ",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_005"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ぇーーー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あーあー、",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "思いっきり吹っ飛んじゃって。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今のって",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "能力発動してなかった？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nなら当たるわけないじゃん。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "けほっ……",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "だってさー、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "血が騒がないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "絶対防御とか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "名前の響きだけで破りたくなるだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ふっ。",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_008"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ノウェム、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "オマエは阿呆だな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n破れないから絶対と言うんだよ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "そういう反骨精神は、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_009"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ワタシも分からんでもないがね。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "それでどうする？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "まだ続けてみるか？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おう、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もちろんだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nあっ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうだ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーも──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そろーり、",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_011"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そろりと……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おいこら、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_012"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "逃げるな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ほら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーも手伝ってくれ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nアタシたち二人なら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "絶対を打ち破れるかも！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なにそれ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "意味分かんないんだけどー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシたちに不可能はないってことだ！",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_014"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……はぁ。",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "分かった。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "分かりましたよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n面倒だけど、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "手伝ってあげるよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ふっ、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_016"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "何人でもかかってくるがいいさ！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "では、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "能力の発動を……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今だよ",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_017"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェム。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "えっ？",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "は？　",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "おい待てオクトー！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n絶対防御を破りたいという話だろうが！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nまだ能力を発動してな──",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクは別にそういうのじゃないんでー",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_020"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "オマエは～！",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nノウェム、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "それでいいのか！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "さっすがオクトーだな！",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_022"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……なるほど、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_023"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "想定以上の阿呆だったな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "いいだろう、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ならばワタシも負けてはいられまいよ！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "手加減はできんぞ、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_024"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ノウェム、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "オクトー！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "自身に立ち向かってくるノウェムとオクトーを見据え、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n誓約女君は愉しそうに武器を構えるのであった。"
    }
]