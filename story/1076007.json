[
    {
        "type": "background",
        "background": "501032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在海之家養足精神的{player}和可可蘿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在夕陽西下的海邊聊天。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就快要入夜了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "終於到了",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "冒險的時候。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在「星海」，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟有什麼樣的景色在等著我們呢……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下相信",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡會是",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比文獻中描述得還要美的世界。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "文獻",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只不過是他人寫下的話語……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等著我們的，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肯定是筆墨難以形容的絕美景象。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "觸感……",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "氣味……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫度……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每個人",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會有不同的感受，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有一百個人，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會有一百種答案。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓我們親自去",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "找出自己的答案吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那道光是……？",
        "unit_id": 107612
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……不好意思，",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "很抱歉",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "突然就來打擾您……！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您還記得",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "之前您教在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "游泳的事情嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "關於這件事，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有件事要向您報告……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "其實今天",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有游泳課，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下在同學面前",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "展現了泳技……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下成功游完了",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "25m，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n結果其他同學",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "跑來找在下說話。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "多虧有主人，",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下除了學會游泳之外，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雖然只有一點點……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但也和同學",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "相處得更融洽了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人的指導收穫了成果，",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n讓在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好開心好開心……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下無論如何",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都想和您道謝，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因此才會在",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "學校前面等您。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯，",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這全都多虧了主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不好意思……",
        "unit_id": 105931,
        "voice": "vo_adv_1076007_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下有一件事",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "想要和您商量……",
        "unit_id": 105931
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇……！",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這就是大海……！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是壯闊的景象……！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然已經在書籍和電視上看過了，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但沒想到居然會這麼寬廣……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "遠遠超乎在下的想像。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "果然有些事物",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的得親眼見到，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n才能體會這種感動。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下平常",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "只會在",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "自家和學校間往來而已，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "別說海洋了，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "連居住的城市都不太瞭解。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因此，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "對在下而言，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n是主人您讓在下見識到了未知的世界。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在在下拜託您之後，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您在當週的週末馬上就帶在下來海邊了，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真不愧是主人。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下打從心底感謝您♪",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好的。",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下想利用主人教授的泳技，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "來親身感受這片大海。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "噗！？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "海、",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "海水跑到嘴裡……！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "怎麼會這麼鹹……！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這裡的海浪……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "只有膝蓋左右的高度，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n卻讓人覺得整個身體都要被沖走了……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "讓在下清楚體認到",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "人在大自然面前",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有多麼無力……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "看來憑在下",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "稚嫩的泳技，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n還沒有辦法順利前進……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不好意思，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人……",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n可以的話，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能請您拉著在下的手嗎……？",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "握……！",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一握住主人的手手，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n之前感受到的不安全都消失了。",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣肯定就沒問題了……",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那麼，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下要出發了！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嘿咻……",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嘿咻……！",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有您強而有力的牽引，",
        "unit_id": 107631,
        "voice": "vo_adv_1076007_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下游得輕鬆了不少……♪　",
