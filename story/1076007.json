        "name": "可可蘿",
        "words": "\n和會使用水中呼吸魔法的凱留小姐都不在，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一開始在下還不太放心。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想和主人一起看",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「星海」的強烈想法，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓在下學到了新的加護，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們才能走到現在這一步。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "作為嚮導侍奉主人，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓在下發現了",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未知的風景、",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "增長了不少見聞。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有主人，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就不會有這些成長了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該感謝您的，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實是在下。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今晚，",
        "unit_id": 107612,
        "voice": "vo_adv_1076007_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶著感謝的心情，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一定會",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您看見",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "閃耀的「星海」♪",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就像緩緩沉入水平線的夕陽一樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿的決心靜悄悄地燃燒著。"
