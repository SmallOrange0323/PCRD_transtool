    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然有主人拉著，",
        "unit_id": 107631
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這裡還是和游泳池很不一樣……！　",
