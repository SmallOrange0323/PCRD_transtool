[
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個異常程度，",
        "unit_id": 121911,
        "voice": "vo_adv_5092301_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還有強度……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不愧是守護財寶的守護者。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "作為對手來說無可挑剔！",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "面對這樣的強敵，妳還能說出這種話，",
        "unit_id": 122011,
        "voice": "vo_adv_5092301_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是讓我無比安心。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼杏奈，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來就拜託妳了。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦？",
        "unit_id": 121911,
        "voice": "vo_adv_5092301_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哎呀，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然我一個人也沒問題，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過要我獨占功勞，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總、",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總覺得不太好……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是開玩笑的。",
        "unit_id": 122011,
        "voice": "vo_adv_5092301_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算是杏奈",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要單挑這種強敵也是很難的吧。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們兩個真有閒情逸致啊。",
        "unit_id": 101411,
        "voice": "vo_adv_5092301_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n財寶就在眼前了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "集中精神，小心應戰！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵，",
        "unit_id": 121911,
        "voice": "vo_adv_5092301_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳們這麼關心我，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那我可不能辜負這份心意。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "很好，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "跟著我上！",
        "unit_id": 121911
    }
]