[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依照慣例，{player}\n在優妮送來的信件上，收到了要他到「象牙之塔」來的指示。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "歡迎回來，朋友啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天的工作也辛苦你了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你要洗澡呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還是要吃飯呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n還是說……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣啊。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我畫一張最靠近這裡的大眾澡堂的地圖給你，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n待會你就自己過去吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦？",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n前些日子招待你吃的滋養強壯的營養食品，你很喜歡啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那可真是太好了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮笑嘻嘻。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你在",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說什麼啊？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這種經典的歡迎笑話，你別當真啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該被責備的人是我。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我這嬌小身體中藏不住的成熟美色",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "魅惑了你吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這麼性感的優妮還真是對不起你呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在創作時學到的新婚辦家家酒遊戲",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就到此結束。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志啊。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n今天找你來不為別的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我有個重大的任務",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只能拜託你這個朋友。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是聽我發牢騷。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "題目是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n關於遺失的筆記本至今尚未尋見一事～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "掌聲加尖叫～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "姑且會在意自己在學院內的門面，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以一直以來，我都極力地在避免",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "公然使用「特例」的權限呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n除了探查魔法之外，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "甚至就連祈禱和占卜，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我都已經用盡所有我能做的手段了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1110006_012"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n雙魚座的妳，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "本週運氣超級無敵糟糕！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n不論是弄丟的東西，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "還是光明的未來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "想必都是百分之百找不到吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "占卜就是這種感覺。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然這樣，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再來就是用人海戰術，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在學院裡展開地毯式搜索了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "實在不得己，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我請教務主任組了一個特別搜索隊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我遊說他說那本手冊",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我寫論文不可或缺的東西，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n於是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "幾名教職員迅速地",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "開始進行了搜索。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而那卻是三天前的事了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後今天稍早時，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我收到了搜尋隊解散的悲報。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n師曰，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再繼續這樣找下去也不是辦法妳就放過我們吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這件事至今完全沒有進展了呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哭哭。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是沒錯啦？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n當初我也說了因為有備份，不會影響到我繼續作業，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n等等諸如此類從容的話啦？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "安穩的生活終究是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n以原版的筆記本遲早會回到手邊做為前提的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若那本筆記",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "交到了素未謀面的第三人手上的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "老實說，或多或少都會使我坐立難安的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n若要說會不會困擾，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼講，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "基本上是不會困擾。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過在無法成眠的夜晚，一時衝動寫下的",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感情充沛的耽美詩，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要被暴露在眾人的眼前，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "著實是會令人有些害臊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話雖如此……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，可是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不會吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "究竟該如何是好呢。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我一直在問自己那個問題。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我實在是無法釋懷。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "大概是預感吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那本筆記本裡大致上記載的內容，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都只是將平日閒暇時想到的無聊事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "以毫無規律",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "且約略的方式寫成的雜文而已。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比方說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "某個身體上的測量值與變化記錄 ，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n對我來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖是關係到少女身價的最重要機密，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但反正在他人眼裡看起來",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過是一串數字排列。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "裡面也有一些記載內容並非是這些。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比方說這次的研究論文，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的根源性虛構」的備忘錄之類的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我並不是害怕可能會被人抄襲。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n若要問為何，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是因為研究內容的概要，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我早已經由學院提交給學會了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "抄了就會被抓到。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話雖如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這種靜不下心的感覺",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "究竟是怎麼回事？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想單純是杞人憂天，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "或是神經質的瞎猜吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你真溫柔啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你的安慰我感激地收下了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過你那就只是毅力論。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還是說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你剛才沒有在聽我說話嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我再說一次，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我已經讓人找遍學院內各個角落了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然這樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還要再找哪裡呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這裡？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這間房間……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這間房間的確沒找過。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n理由很簡單。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果它在這裡的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的探查魔法應該會有反應。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的確，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不能保證我的魔法絕對有效……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不在……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這裡吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔呣呣，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個房間……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然主要是放書，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但因為東西實在太過於散亂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是俗稱的骯髒房間。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我甚至還很佩服自己竟然可以",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓房間亂成這個樣子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不是在找藉口，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但我是比起過度的秩序，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更愛適度的混沌的主義呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就像種子的進化，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "必然會使遺傳基因產生何種錯誤一樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "名為房間的日常小宇宙中，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "由偶發性的變異中",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n產生了混沌的熵的緩衝……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我本想試著祭出什麼偉大的寓言故事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n來讓它在理論上合理化，但還是沒辦法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這就只是間骯髒的房間。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從這混沌之中，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n尋找不知是否存在的筆記本，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n根本像在沙漠裡挖掘寶石一樣大海撈針——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "其實更像是",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一般的大掃除——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "順帶一提，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我最討厭的四個字就是整理收拾了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既使那樣……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你還是要找嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你加油，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "Fight。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦～？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也要找嗎？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好麻煩～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真聰明。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在極東的一個小島國，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "據說有這樣的格律詩。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「白河　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "之清　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "魚也避之」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n儘管我也不是很清楚，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我記得沒錯的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "大概是「房間很亂也OK」的意思。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "果然還是放棄吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這有限的時間，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我覺得應該要合理地",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使用啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有關係呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說的對。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說得真好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我剛才的想法有點走偏了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剛才在一瞬間",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "萌生了「真麻煩，算了吧。」的想法後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的意願便漸漸地往那個方向流瀉而去了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它以稱不上是精神操控",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那般不自然的強度，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "緩慢地進行著。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唉呀唉呀。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n其實，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "開始現在的研究後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很常有這種事，讓我很困擾。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為我已經非常習慣做日常記錄及參考記錄，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以在下意識重新觀看筆記時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "才偶然地對這個世界產生了違和感——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一般來說，應該會像這樣，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "慢慢地失去了興趣與關心才是呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妨礙認知。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "果然這個世界對我們造成著什麼影響。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_057"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n現在是那也不過是胡說八道的陰謀論。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我失言了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你就當作耳邊風沒關係。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n現在就讓我們",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在這間房間裡尋找遺失物吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個嘛……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "總之，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就負責自己的桌子周遭吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你就負責整個房間的打掃……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "搜索就交給你了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "首先將散落在地的大量書籍",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "放回書架上吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那本是圖鑑，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要放在那邊的書架。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你要看分類標籤啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那本是字典吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "慢著，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是人文科學類的，是在第三層的——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我知道了我知道了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "夠了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n藏書相關的我自己來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……唔，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有種不好的預感。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n原本我是預定要若無其事地把大掃除這事全部推給他來做，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是照這樣看來，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像會落得最後幾乎都是我自己做的下場……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒什麼。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那樣的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就麻煩你……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "去收集和分類",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學術性廢棄物吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是去倒垃圾。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對，等一下，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_065"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那顆乾巴巴的植物不是垃圾。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是識別魔法要用的罕見觸媒。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為它易碎又容易壞掉，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_066"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拿的時候給我小心點啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乍看之下儘管像個垃圾，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n然而一顆的市價，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "幾乎可以抵上蘭德索爾市民平均的月收入——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊！　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_067"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "小心輕放！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要倒了要倒了！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "平均月收入，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要倒了！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_068"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這次又怎麼了？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個卷軸啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個是……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_069"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然那看起來像古代流傳下來的祕術紋樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但其實是我前一陣子畫的自畫像。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我曾有過一段摸索藝術來解悶的時期呢。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_070"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如你所見，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那就是不值一提的練習作品。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n硬要留給後代也沒什麼意義吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_071"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "垃圾……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是沒錯啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如果單以是垃圾或不是垃圾來做分類的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那它的確實是垃圾，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但學姐我對那種講法有點介意呢……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊～",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_072"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "給我等一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那裡面有我的衣服。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那邊我會自己整理，不用你——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼哇，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_073"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是內衣！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呀啊啊啊！　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_074"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別摸啊啊啊啊！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈啊……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_075"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "累死我了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "結果到最後……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_076"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就只是雷聲大雨點小……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_077"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是什麼都沒找到……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_078"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如此一來果然只能猜想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的筆記本",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在應該是在某個人的手上才是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n既擅長說謊和隱瞞，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "並且具有強大力量的某個人——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "——若非如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_079"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那希望就只是個單純對詩狂熱的奇葩就好了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼……",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_080"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天謝謝你。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n太陽已經下山，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是時候解散了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_081"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "右邊臉頰沾到灰塵了喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_082"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是那裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "變乾、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "淨了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……慢著。",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_083"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n喂，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你剛才",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用什麼擦臉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼哇，",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_084"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呀啊啊啊啊！　",
        "unit_id": 111011,
        "voice": "vo_adv_1110006_085"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就跟你說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是我的內衣呀呀呀！！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "少女的慘叫聲響徹了整座「象牙之塔」。"
    }
]