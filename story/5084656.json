    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我聽說了喔。",
        "unit_id": 106113,
        "voice": "vo_adv_5084656_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一直在沉睡啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要是我的超能力沒被封印，可能還有辦法做點什麼……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在的我什麼也辦不到。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，",
        "unit_id": 106113,
        "voice": "vo_adv_5084656_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果是你，我相信會沒事的喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和尾狗刀就是壞蛋。",
        "unit_id": 106113,
        "voice": "vo_adv_5084656_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n以前的你",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總是把那樣的我們打得落花流水。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "打倒壞蛋的就是英雄吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就是英雄！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "英雄不管陷入什麼樣的危機，",
        "unit_id": 106113,
        "voice": "vo_adv_5084656_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都絕對能設法解決的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果是你，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這次一定也能度過危機！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我絕對不接受",
        "unit_id": 106113,
        "voice": "vo_adv_5084656_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不能再見到你啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快點醒來喔！",
        "unit_id": 106113
    }
]