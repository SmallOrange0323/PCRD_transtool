[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一片祥和的蘭德索爾"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在盛大舉行著自古以來的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n例行建國慶典「女神祭典」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "公主貪吃佩可和{player}一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到慶典進行視察。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然很棒呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n城鎮上的人們能帶著笑容過日子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當回公主後",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然經歷了很多辛苦的事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過大家的幸福是最重要的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊──！",
        "unit_id": 211,
        "voice": "vo_adv_5110000_002"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是陛下──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "陛下──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗨──！",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要盡情享受慶典喔──！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "喔喔，",
        "unit_id": 611,
        "voice": "vo_adv_5110000_004"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "陛下……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒想到有幸在這裡親眼見到您……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我已經沒有遺憾了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "千萬別這麼說。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明年我還會再來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到時候再見面吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦，",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從那邊的攤販傳來不可思議的香味……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像是異國料理呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好想吃……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在還在視察中……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也、",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們快去買吧，{player}！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "等等，",
        "unit_id": 711,
        "voice": "vo_adv_5110000_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "陛下！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "請不要離我們太遠！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "\n啊……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "真是隨心所欲啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "\n隨從甚至還是個普通少年，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "真令人困擾。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "不能這麼說。",
        "unit_id": 712,
        "voice": "vo_adv_5110000_009"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "他可是最理解陛下的人，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n而且親民",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "正是陛下的魅力。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "話是這麼說沒錯，",
        "unit_id": 711,
        "voice": "vo_adv_5110000_010"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "但是作為騎士團的一員，果然還是會擔心。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "\n萬一陛下遭遇不測……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "你想太多了。",
        "unit_id": 712,
        "voice": "vo_adv_5110000_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "別說是一般的壞蛋，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n就連我們團員全部一起出擊，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n都不會是陛下的對手。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "現在我們的工作，",
        "unit_id": 712,
        "voice": "vo_adv_5110000_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n就是讓陛下和城鎮的人們",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "能夠無憂無慮地",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "好好享受慶典。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "我覺得",
        "unit_id": 712,
        "voice": "vo_adv_5110000_013"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "這樣就是在報答",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n為蘭德索爾帶來和平的",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "陛下。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "……也",
        "unit_id": 711,
        "voice": "vo_adv_5110000_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "是呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "隊長，",
        "unit_id": 711,
        "voice": "vo_adv_5110000_015"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "能夠耽誤您一點時間嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "怎麼了？",
        "unit_id": 712,
        "voice": "vo_adv_5110000_016"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "是發生事件了嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "不是，",
        "unit_id": 711,
        "voice": "vo_adv_5110000_017"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "雖然不到那種程度。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "不過，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "有人回報在街上目擊可疑人士，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "\n另外還",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "收到報告說",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "有發生一些小騷動。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "再來就是",
        "unit_id": 711,
        "voice": "vo_adv_5110000_018"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "收到了幾件通報",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "\n表示和同行者走散了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "雖然都不是嚴重的案件，",
        "unit_id": 711,
        "voice": "vo_adv_5110000_019"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "\n但是",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "數量太多──",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "嗚哇！陛、",
        "unit_id": 712,
        "voice": "vo_adv_5110000_021"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "陛下……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "回來得真快……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n東西都已經買好了嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "買了好多好吃的東西☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也買了大家的份，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們邊吃邊逛吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "呃、",
        "unit_id": 711,
        "voice": "vo_adv_5110000_023"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "可是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "謝謝您，陛下。",
        "unit_id": 712,
        "voice": "vo_adv_5110000_024"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "很榮幸能與您同行。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n那麼，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "我們走吧。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "聽好了，",
        "unit_id": 712,
        "voice": "vo_adv_5110000_025"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "這件事別傳到陛下耳裡，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "我們自己解決。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "也許民眾只是對慶典感到太興奮而引起糾紛，",
        "unit_id": 712,
        "voice": "vo_adv_5110000_026"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n或只是在人潮中走散而已，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n我不想",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "讓陛下擔心。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "是！",
        "unit_id": 717,
        "voice": "vo_adv_5110000_027"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "遵命！",
        "unit_id": 711,
        "voice": "vo_adv_5110000_028"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "希望",
        "unit_id": 712,
        "voice": "vo_adv_5110000_029"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "真的什麼都不會發生……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5110000_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──謝謝惠顧──！",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "賣得超級好呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n祈梨，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "趁現在把香腸都烤起來。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我怎麼會落到這個地步……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我做不下去啦混蛋！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好想去看",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "慈樂之音演唱會……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "本來還想把特地為了這天存的零用錢，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀哈──！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "地全部用掉……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我懂妳的心情，",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但抱怨的話不要對我說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n去找突然消失、翹掉這個攤販生意的傢伙說。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就因為哪裡都找不到這傢伙，我才這麼辛苦啊！",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n在工作的時候突然搞消失",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是在想什麼！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都是因為他，我才會被叫來這裡……",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在老大不在，所以才被小看了啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這只能問本人了。",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再怎麼想也無濟於事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就做好我們該做的──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊──！",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在那裡，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那傢伙在那裡！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦，",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的假的啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "翹掉工作在那邊閒晃……",
        "unit_id": 106611,
        "voice": "vo_adv_5110000_040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n可別想逃！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸，",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等，祈──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那傢伙，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "自己這樣不也翹班了嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511,
        "voice": "vo_adv_5110000_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一般來說翹班的話不會這麼大搖大擺地讓人找到吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……希望不是什麼麻煩事就好。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500584"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大家──！",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你們今天來聽演唱會──！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慶典才剛剛開始，",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n好好盡情享受吧。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們是",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們下個演唱會見──！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "哇啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5110000_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼──",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "恭喜我們第一天非常成功！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然久違地開演唱會讓我很緊張，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但一站上舞台，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "緊張感就一掃而空了。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為新歌跟表演，",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有服裝跟演出，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n都忍不住想趕快公開而心癢癢的呢。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "觀眾們的反應也很不錯，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是最棒的起跑狀態喔。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慶典期間",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有好幾次的演出呢。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們別鬆懈，下次也要加油！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也是呢。",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n時不時注意騎士先生有沒有在觀眾席上的小動作也得小心一點，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n對吧，小望？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什什……！",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我覺得自己是有小心的耶……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "給他門票的時候，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他說今天要當貪吃佩可小姐的隨從，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以不能來，不是嗎？",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我在想",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他有沒有可能把行程調整一下，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n然後就來看我們……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們兩個也很在意吧？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個嘛……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對我來說騎士先生怎麼樣都不重要，",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然他如果來了至少是能幫我們炒熱演唱會氣氛啦？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比起這個，",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們快點換衣服去慶祝吧！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為還是第一天，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就我們三人簡單地慶祝一下今天的成功──",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊！",
        "unit_id": 311,
        "voice": "vo_adv_5110000_058"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "太好了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "妳們三位",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "都沒事吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "問我們有沒有事……",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是發生了什麼事嗎？",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "不是什麼大事，",
        "unit_id": 311,
        "voice": "vo_adv_5110000_060"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "只是聽說舞台周圍有奇怪的傢伙出現。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n為了不讓三位出事，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "所以工作人員正在巡邏。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那真是令人困擾呢……",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "找到那位可疑人士了嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "不，",
        "unit_id": 311,
        "voice": "vo_adv_5110000_063"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這倒是還沒……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明天演唱會還會繼續舉辦。",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_064"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "保險起見",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也一起過去看看。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒辦法呢。",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣的話也需要負責捕獲的人對吧。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也一起去，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然如此我也──",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_066"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這不是需要三個人都出馬的事情。",
        "unit_id": 104212,
        "voice": "vo_adv_5110000_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望就先去休息吧。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只是慶功前簡單的消化運動而已。",
        "unit_id": 105412,
        "voice": "vo_adv_5110000_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們很快就會把他解決掉的。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 102912,
        "voice": "vo_adv_5110000_069"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要小心喔，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩位。",
        "unit_id": 102912
    },
    {
        "type": "background",
        "background": "500034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "慶典啊……",
        "unit_id": 106113,
        "voice": "vo_adv_5110000_070"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好棒呢，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種歡樂的氣氛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我不討厭喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然為了尾狗刀的事情而感到低落，",
        "unit_id": 106113,
        "voice": "vo_adv_5110000_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就先試著盡情享受這場慶典吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是",
        "unit_id": 106113,
        "voice": "vo_adv_5110000_072"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
