[
    {
        "type": "background",
        "background": "502310"
    },
    {
        "type": "still",
        "still": "514807301"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "跟大家一起",
        "unit_id": 131611,
        "voice": "vo_adv_5148073_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "圍繞著營火……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那變成了一個",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常美好的回憶呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然對不成熟的我來說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那可能是個受益過甚的體驗……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那挺費工夫的啊～",
        "unit_id": 131111,
        "voice": "vo_adv_5148073_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小莉莉雖然有跟小騎士他們一起旅行，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n但是也不是每次都生火煮飯吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 131611,
        "voice": "vo_adv_5148073_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因為美食獵人號上",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有爐灶。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n而且，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是為了食用目的，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而是為了一起度過的時間而生的火……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至今為止我都不知道",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還有這種度過時間的方法。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不覺得火這東西，",
        "unit_id": 131213,
        "voice": "vo_adv_5148073_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要是看著它就能讓心情平靜下來。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n然後會覺得很多事情都無所謂了嗎？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我不是在指危險的意思喔？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在不是。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我明白。",
        "unit_id": 131611,
        "voice": "vo_adv_5148073_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在寂靜的夜晚海邊，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "傾聽著樹枝",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "劈啪作響，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我認為有調整身心的效果。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "比起那個，我比較喜歡好吃的東西啊。",
        "unit_id": 131111,
        "voice": "vo_adv_5148073_005"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "棉花糖很難烤好呢～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "順帶一提，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "妳們覺得味道如何？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "非常好吃喔★",
        "unit_id": 131213,
        "voice": "vo_adv_5148073_006"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過莉莉她皺起臉了就是了～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "哎呀？",
        "unit_id": 131111,
        "voice": "vo_adv_5148073_007"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n不合妳的胃口嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不、",
        "unit_id": 131611,
        "voice": "vo_adv_5148073_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n因為涅婭小姐津津有味地吃著，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n所以我模仿您的吃法……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為剛烤好，",
        "unit_id": 131213,
        "voice": "vo_adv_5148073_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以非常燙的樣子♪",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯呼呼～",
        "unit_id": 131111,
        "voice": "vo_adv_5148073_010"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小莉莉是冒失系嗎～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不、",
        "unit_id": 131611,
        "voice": "vo_adv_5148073_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是的……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然我想那麼說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但真是很不好意思……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要給騎士同學吃的時候，",
        "unit_id": 131213,
        "voice": "vo_adv_5148073_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要好好把它呼～呼～吹涼喔★",
        "unit_id": 131213
    },
    {
        "type": "still",
        "still": "end"
    }
]