    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為跟老哥對話實在太開心，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n讓我都忘了最重要的事啦。",
