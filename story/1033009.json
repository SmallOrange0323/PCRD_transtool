[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在牛鳴聲響徹四方的牧場裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真陽正抱頭苦腦著。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有沒有～",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有沒有～什麼新哏好用啊……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有哞有？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "用牛的叫聲來當哏",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣如何啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好像太冒險了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n而且去兜售的時候",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不會帶牛去嘛。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "得想個我一個人也能說得好的哏。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總覺得還是這種的最好呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n畢竟我本來也是跟伊麗莎白一起",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "表演搞笑的嘛。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你什麼時候！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n嚇死人了啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在的話就好好打招呼啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "迎頭而來的裝傻嗎！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果是那樣的話，沒能吐槽的我才不對呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n抱歉啊，老哥。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "表情看起來那麼擔心。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該不會是以為",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還在沮喪吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有沒有！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多虧了老哥，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我已經恢復活力了！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是在專心想新的哏的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉不能回應你的期待，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我還在思考中的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為嘗試了",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟以往完全不同方向的哏，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "無論如何不管怎樣",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就是不太順利呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是要用反覆鋪墊的技巧嗎！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這次我一定要好好吐槽！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "第二次的哞要……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "需要哞索！！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "　…………",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我到底",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在說什麼啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n連吐槽都算不上。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且這種冷門的回答根本不行的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n得讓客層",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "更廣才行啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一個人埋頭想，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就總是只會想到工作相關的東西。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然不懂的東西也可能讓人笑出來，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但那和我追求的有點不同啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以說啊，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很抱歉不能回應你的期待。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "下次見面前",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我絕對會先想好新哏的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的嗎！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我有",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想請老哥幫忙的事！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "絕對不難，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要在說好的時機點",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哞哞叫就好了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n可以請你幫忙嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太好了，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥願意幫忙。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就來",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "確認一下段子的哏吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我就對他這樣說了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那可不是模仿，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是磨坊啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "磨下去可要變成粉啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "伊麗莎白～～～～！！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……啊！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "糟、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "遭啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為老哥",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一直發出跟伊麗莎白一樣的叫聲，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n害我不小心抱下去啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱、",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱抱抱歉啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為牧場的工作",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "滿身大汗的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的意思不是沒流汗",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就可以抱你！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你這麼討厭被抱啊！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n……咦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你以為還在表演相聲呀？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒啦，",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "相聲已經結束了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n剛才的就是結尾。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是太難理解了？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然還是要用更容易懂的方式來收尾才行呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯！",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的意見",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然很值得參考！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太、",
        "unit_id": 103311,
        "voice": "vo_adv_1033009_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太好了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥看起來對我抱他這件事",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有多想。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼都沒想",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也讓人挺哀傷的……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、",
