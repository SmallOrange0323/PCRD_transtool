[
    {
        "type": "dialogue",
        "name": "奄美魔物",
        "words": "……！",
        "unit_id": 11911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼回事，",
        "unit_id": 110611,
        "voice": "vo_adv_5021321_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "奄美魔物的樣子怪怪的呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比起之前",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "邪惡的氣息又變得更濃了……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主你看，",
        "unit_id": 110411,
        "voice": "vo_adv_5021321_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n從那個壺裡冒出了好像人類靈魂的東西……！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚～～～",
        "unit_id": 110511,
        "voice": "vo_adv_5021321_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總覺得身體好重呀～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就好像沉到了",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "深海裡面一樣呀～……",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看起來",
        "unit_id": 110611,
        "voice": "vo_adv_5021321_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原因是那個人類靈魂呢……！",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們的力量",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像被那個壓制了呢……！",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不能想些辦法嗎～……",
        "unit_id": 110511,
        "voice": "vo_adv_5021321_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優點是很有活力的香織都變成這樣嗎……",
        "unit_id": 110411,
        "voice": "vo_adv_5021321_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看起來",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會變成跟至今為止完全不一樣的戰鬥呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算沒辦法出全力，",
        "unit_id": 110611,
        "voice": "vo_adv_5021321_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還是有很多辦法的。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒錯呀～！　",
        "unit_id": 110511,
        "voice": "vo_adv_5021321_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "靠毅力呀～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不對，",
        "unit_id": 110411,
        "voice": "vo_adv_5021321_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我覺得公主應該不是這個意思喔……？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管怎麼樣，",
        "unit_id": 110411,
        "voice": "vo_adv_5021321_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是以為這樣就能打倒我們可就大錯特錯囉！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "覺悟吧！",
        "unit_id": 110411
    }
]