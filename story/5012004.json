        "words": "能這麼輕易的就脫口說出這種話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n可以說是你的罪惡之處吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411,
        "voice": "vo_adv_5012004_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺不差呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真不可思議。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被你稱讚是我的光榮，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什、",
        "unit_id": 104311,
        "voice": "vo_adv_5012004_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼心跳加速啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種話，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要直視著對方說啦！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的。",
        "unit_id": 104311,
        "voice": "vo_adv_5012004_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這種說話方式，對心臟不好啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你給我自重點。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然這直率的感言很像助手先生的作風，",
        "unit_id": 101411,
        "voice": "vo_adv_5012004_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但在這狀況下，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真的有點不好意思呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊哈哈。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前、",
