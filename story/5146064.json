[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "クリスマスイベントの準備が進む中、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nクレジッタは一人、会場を見回っていた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "はぁ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_000"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "やれやれですわね。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "最初はどうなるかと思いましたけれども、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "どうにか形になってきましたわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "この調子ならきっと、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_001"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下に喜んでいただける",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nイベントにできそうですわ。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あとは当日を待つばかりですわね！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……駄目だな。",
        "unit_id": 1,
        "voice": "vo_adv_5132064_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\nてんで駄目だ☆",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "むむっ……！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_003"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちょっとちょっと、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしのイベントにケチをつけるのは",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nどこのどなたですことかしら！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "成金女、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_004"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "オマエがこのイベントの責任者か？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_005"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええそうですわ！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いったいどこの馬の骨だか",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n存じ上げませんが、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ずいぶん偉そうにしてくれちゃって！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "というか",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n何を勝手に見て回っておりますの関係者以外立ち入り禁止ですわよ！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "まずはこのモニュメントを別の場所に移すんだ。",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_006"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "話聞いてまして！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nなんで馬の骨の言うことを聞かなくちゃいけないんですの！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いい加減警備を呼びますわよ、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まったくなんなんですのも、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "うっ……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……あら？　",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_008"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あらあら？　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "この顔……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "どこかで見たことがあるような。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そう、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしがまだ陛下と出会う前のこと。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n御用聞きの商人として、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "王宮に出入りしていた頃……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ツリーの近くにモニュメントなんて置いたら、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_009"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n人の流れが滞って混雑の原因になるだろう。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n無用な混乱を呼ぶことになるぞ？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "見せ場は分散し、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_010"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "人の流れをしっかり確保しろ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "それとも何か？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "混乱させるのが本来の目的か。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "うん、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "それはそれで悪くない。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "闘争も祭りの一種だからな☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ち、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちち違いますわよっ！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そのような野蛮なこと、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n王家主催のクリスマスイベントで考えるわけがないでしょうっ！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "なんだ、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_012"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "それは残念だ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ほら、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "屋台の数に対して、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "飲食のスペースが足りんぞ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n食べ歩きしにくいメニューも多いんだ、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ちゃんと確保しておけ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "あとは",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_013"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ゴミ箱の数も足りないな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "せっかくの美麗なイベントも",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\nゴミだらけでは興覚めだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ゴミ箱に飾りつけでもしておけば、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n景観の問題もクリアできるはずだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "おい、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_014"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "仮設トイレの数が少なすぎるぞ！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n大型イベントの人出をなめるんじゃない！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "こうなったら徹底的に改善点を洗い出すぞ。",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_015"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "さあ、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "とっとと案内するんだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "これでもワタシは忙しい身だからな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……はっ！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_016"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "思わず聞き入ってしまいましたが、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしだって無策でやってるわけじゃありませんわ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "好き放題言わないでくださる！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "しっかりと企画書も作り、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_017"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "関係各所への手配も完璧ですわよ！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "なめるなよ、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_018"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "オマエがそれなりに有能で、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n真面目にいい物を作ろうとしてることくらい見れば分かる。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "だがな、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_019"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "オマエに欠けているものがある。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "それは",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "イベント企画の経験値と",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "客の目線だ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "経験だけは",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_020"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "一朝一夕ではどうにもならん。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "場数を踏むしかない。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "だが、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "客が楽しむためにどうすればいいか、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\nそこに想像を馳せることは",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "できるんじゃないのか？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "くっ、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_021"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "悔しいですが……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女の言う通りですわね。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n確かにわたくし、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "イベンターとしての経験値は足りないかもしれません。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "というか",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "この洞察力と知識……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女いったい何者なんですの？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "なに、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_022"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "通りすがりのプロデューサーさんだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "別にオマエのイベントを乗っ取ろうだなんて思っちゃいないさ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "さあ、",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_023"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ついて来い成金女！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\nイベント運営というものを叩き込んでやろう。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "もー！　",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_024"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お待ちなさいな！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nちょっと警備！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n警備の方～っ！！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "クリスティーナのチェックを受けてから数日後──"
