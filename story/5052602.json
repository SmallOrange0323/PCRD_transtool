[
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "あれ、",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_000"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "お姉ちゃん。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "またラフィちゃんのお手紙読んで、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "どうしたの？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ア、",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_001"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "アカリ……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "えっと……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "あの子の手紙を読み返してると、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "どうしてかしら、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n元気と勇気が湧いてくる気がするから、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "なんとなく、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "そうなの？　",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_002"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "えへへ、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "実は私もなんだ♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんが頑張ってる姿を想像するだけで、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "何だか心があったかくなって、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "幸せが湧いてくるんだよ。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "それで、",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_003"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "この幸せを",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "エンジェルとしてみんなにおすそ分けするの。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "そうやってみんなの笑顔が見れたら、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "また幸せになるの。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "幸せが巡り巡って、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "世界中が幸せになれたら最高だよね！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ふふ、",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_004"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "やっぱりアカリはすごいわね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\nもう立派なエンジェルじゃない。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "そういうお姉ちゃんだって、",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_005"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "最高のエンジェルだよ♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n双子エンジェルとして",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "アカリも鼻が高いよ！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "……何言ってるのよ、",
        "unit_id": 102211,
        "voice": "vo_adv_5048602_006"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "もう。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "さて、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "元気も勇気ももらったことだし、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "頑張らなくちゃね！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "うん、",
        "unit_id": 100611,
        "voice": "vo_adv_5048602_007"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ランドソルのみんなに、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "い～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "っぱい幸せを届けちゃおう！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "美少女エンジェル",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "降臨だよ♪",
        "unit_id": 100611
    }
]