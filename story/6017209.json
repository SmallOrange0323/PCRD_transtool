[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人嗎？",
        "unit_id": 109711,
        "voice": "vo_adv_6017209_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "她是一位很棒的人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你問我",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "優秀的地方是哪裡嗎……？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你覺得呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 109711,
        "voice": "vo_adv_6017209_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不過，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "她也因為妖精族的美貌",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而吃了不少苦頭。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還請你不要單用外表",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "來評斷愛蜜莉雅大人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的，",
        "unit_id": 109711,
        "voice": "vo_adv_6017209_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "她是一位很善良的人。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "正因為這樣，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴他才會……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "沒事……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人她和大精靈大人締結契約，",
        "unit_id": 109711,
        "voice": "vo_adv_6017209_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n在露格尼卡也是首屈一指的精靈術師。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還請你千萬不得無禮。",
        "unit_id": 109711
    }
]