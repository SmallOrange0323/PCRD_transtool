[
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "哎呀，小兄弟，你可是買了好東西呢――！ 謝謝惠顧――！",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_000"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在道具店購物，\n當他得意洋洋地走出店門時，被精靈族的女性搭話了。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以耽誤你一下嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1034001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛剛我從那個露天陽台，",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看見你在買東西……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是不是花了5000盧幣左右買了那一瓶創傷藥？",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好東西……？\n",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以讓我看一下嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……果然。\n這個是接近最低等的商品喔。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一般來說，3瓶頂多只值200盧幣吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "老實說……你被敲竹槓了喔。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很吃驚吧。\n你從道具店出來時似乎非常高興呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你……真溫柔呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是去拜託也太懦弱了吧，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我覺得你最後又會被哄騙。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……嗯――。\n雖然我不太擅長處理這種事……",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但我還是努力看看吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？ 你問我在想什麼？",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這個嘛……你跟我來的話就知道了喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵，放心。交給姐姐吧。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_011"
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "妳好，歡迎光臨！\n漂亮的小姐，今天要找什麼呢？",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是呢……有創傷藥嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_013"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "喔！ 小姐妳運氣真好！",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_014"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n今天有珍藏的好東西到貨了喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊，好東西。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說的是……賣給這孩子的低等貨嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "什……那個小傢伙是剛剛的……",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很明顯的，\n你以不合理的價格將創傷藥強迫推銷給這孩子。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欺騙尚未成年的冒險者，\n將便宜貨以高價強迫推銷……",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n請你別在這個城鎮裡做這種貪得無厭的生意好嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "……嘖。女孩子別太自以為是。",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說什麼？",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_020"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "我哪裡錯了啊？\n在這個充斥著魔物、弱肉強食的世界啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_021"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n我只是從弱小的傢伙身上榨取金錢而已啊！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這孩子是因為相信你才付錢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你這",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "樣做不會良心不安嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "才不會呢！\n",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_023"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "是他自己像笨蛋一樣乖乖聽信我的話！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "怎麼想都是錯在被騙的他吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……這樣啊，我明白了",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "啊？ 妳又明白什麼了――",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――蘭德索爾商法第19條：於城邑經商者，",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不得以不正當的買賣從冒險者身上獲取利益。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "……什麼！？",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "或是蘭德索爾商法第24條：所有買賣商品的商家，",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n其商品價格必須統一，不得因種族、職業等而有差別。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的行為或許也會涉及這部分的法條？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "那、",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_029"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "那是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有必要的話，要打官司也沒問題喔。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為我熟記蘭德索爾經濟相關的法律。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要好好戰到最後一刻嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "對――",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_031"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "對不起！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n請不要公開這件事……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n我為我剛才的失言道歉！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "賣給這孩子藥的錢呢？",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_032"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "當、當然會全額退還！",
        "unit_id": 1411,
        "voice": "vo_adv_1034001_033"
    },
    {
        "type": "dialogue",
        "name": "道具屋店長",
        "words": "\n所以，請、請放過我吧……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――你能理解真是再好不過了。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "以後請親切地對待冒險者，正派地做生意喔。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_035"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給你，",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是退回來的錢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的，你不覺得他應該多給一點嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊啊，不用給我謝禮了啦。我是優花梨。",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_037"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我在墨丘利財團公會擔任類似會計的職位，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以擅長與錢有關的事情。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒……怎麼見過你，",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你是最近才來這裡的？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊，你叫這個名字啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，真是個天真又可愛的孩子呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不對壞大人小心一點可是不行的喔♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，我們可能還會再見也說不定呢。下次見喔！",
        "unit_id": 103411,
        "voice": "vo_adv_1034001_040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}邂逅了突然瀟灑出現，\n並替自己解圍的出色姐姐，\n而為此感動。"
    }
]