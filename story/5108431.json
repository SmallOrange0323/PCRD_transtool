        "voice": "vo_adv_5108431_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳們兩位，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不能讓客人看到這種表情喔。",
