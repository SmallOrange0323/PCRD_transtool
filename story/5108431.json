    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們還在營業中呢。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……說得對。",
        "unit_id": 124611,
        "voice": "vo_adv_5108431_003"
    },
    {
        "type": "dialogue",
