[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喂～",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先～生……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然是王子先生。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家正想著好想見到王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還以為看到了海市蜃樓呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您好呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然在這種地方見到面。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生在這海邊做什麼呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來抓晚餐的材料？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這麼說起來，王子先生拿著釣竿呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生還是沒變，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n過著冒險求生的人生呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要拜託人家……",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就可以讓王子先生住在【哞哞自衛隊】的公會之家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n享受附三餐還加午睡的好待遇～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，不過王子先生是普通人類，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n說不定其他獸人夥伴們會討厭呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "種族之間，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那種難以言喻的嫌惡感還是無法抹去呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是人家相信不放棄繼續努力的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n總有一天這個環境的空氣一定會更自由的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是如此堅信的……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……人家是因為【哞哞自衛隊】的工作，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以到海邊來的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "正確地說，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是為了幫忙其他公會的獸人，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以在海之家工作。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然海之家的人，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不隸屬【哞哞自衛隊】的公會。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但只要是獸人，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n大概都有在上層組織【動物苑】註冊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們都有些橫向的聯繫唷。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然只有偶爾才辦交流會，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但我們會互相幫忙工作上的事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這次也是那樣的感覺。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "【動物苑】是獸人們的互助組織，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以會互相幫助唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們偶爾也會從【哞哞自衛隊】以外的獸人公會",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n招募人手。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家互助合作。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n海之家的工作，沒想到是很費體力的工作呀……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為人家很怕日曬，所以覺得累癱了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "結果其他人",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就說『公主快休息！』……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n於是人家就在這陰涼處一個人抱著膝蓋發呆了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是沒用呀……",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家得要再更有體力才行。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "獸人當中有很多精力充沛的孩子，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣人家會拖累大家的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家以前是溫室裡的花朵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來是基礎體力不大夠……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的是太丟臉了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家真羨慕其他獸人們和王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n總是那麼健康有活力♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生，又在發光了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好刺眼呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比海邊的太陽來得更燦爛耀眼♪",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先生。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真巧呀～♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，來散步嗎？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是好天氣呢♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也是因為難得的假日，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n覺得關在家裡太蠢了……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就想說到城鎮外的公立庭園走走。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果王子先生",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒有其他事情，要不要一起散步呢？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "庭園中有很美麗的池塘～",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可以在那裡划著小船，度過悠閒時光唷♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\nOK呀，真的嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家太開心了，那我們走吧♪",
        "unit_id": 101031
    },
    {
        "type": "still",
        "still": "101000801"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n吹著微風真是太舒服了……♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明是假日，人卻很少呢。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n又寧靜又浪漫的……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿，好像身在繪本裡面一樣♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝王子先生幫忙划船。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "累了的話就換人家來唷。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一直讓王子先生做苦力，人家會心疼的。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看起來很有趣呢～",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有時候像小孩一樣，雙眼會閃閃發亮呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那樣的王子先生好可愛，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家好喜歡♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇～……",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生興致勃勃呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為活動了身體，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以興奮起來了嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是可愛，好帥呀～……♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……哎呀？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好可怕……",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n撞到其他小船了呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是抱歉。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總覺得",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n小船越來越多了。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "小心呀，王子先生。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要是翻船就糟了。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家不會游泳的。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇、哇？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼那麼多小船撞過來呢？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生說船划得不好很抱歉？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生在說什麼啊。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這不用道歉的～♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生為了人家",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n拼命地划船……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家太高興了，真是好有魅力呀，王子先生♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n周圍的小船上",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像都是情侶呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其他人",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是不是也覺得咱們看起來是情侶呢？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為這可是約會的經典橋段。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n以前人家看過這樣的電影……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為愛私奔的公主和王子，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就是在小船上親吻的唷。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有點憧憬那樣的情境呢……♪",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生……♪",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……啊，不要亂動。",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n怎麼了，突然這麼慌張？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家看王子先生的臉上沾了個髒東西，",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只是想幫忙拿下來呀。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是不是做了奇怪的聯想呀？",
        "unit_id": 101031,
        "voice": "vo_adv_1010008_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是的，王子先生……♪",
        "unit_id": 101031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們這兩個人……",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在『那邊』也稀鬆平常地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n互稱王子和公主呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然應該是很奇妙的情境，",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但你們看起來好像很幸福，那就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喪失記憶的你，",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n基本上和『以前的你』比起來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎是比較沉穩，或是可以說比較難相處。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也無法評斷",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n哪個比較好哪個比較壞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論如何，",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的一舉一動已經按著真步的希望，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像個王子一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那樣就足夠了。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要有一個人願意接受，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n幻想就會變成現實唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你真是太棒了。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總覺得就像我自己的事情一樣開心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以和某個人分享同樣的世界觀，",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是很幸福的事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真好。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會不會有帥氣的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "王子前來迎接我呢……♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像被真步的氣氛給影響，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n連我都開始幻想些浪漫的事了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你一定要\n把該做的事做好才行。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我這裡的作業",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "進行地還算順利，所以交給我吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就努力在",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嚴峻的現實中努力生存下去吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但偶爾可以到夢中或幻想中逃避一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做為真步理想中的",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n帥氣王子……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n華麗地吹跑嚴峻的命運吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，這次就先聊到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1010008_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰～，下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_072"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，您起來了？",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_073"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "快來幫忙～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生的釣竿被一股很大的力量拉扯呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想說釣竿掉到海裡就麻煩了……",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_074"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以很努力地撐著。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_075"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家腕力也不夠，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n撐不到最後。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_076"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n啊哈哈，不用道歉呀，王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生又沒做什麼壞事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會站著睡著，應該是累了吧。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_077"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n偶爾休息一下也沒關係唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_078"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生做了什麼夢呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "睡臉看起來很開心呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔？",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_079"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在夢中和人家相見了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_080"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n什麼呀，好開心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也常常夢見王子先生唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真幸福呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010008_081"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們不論在夢裡還是在現實世界，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都要一直在一起喔～……♪",
        "unit_id": 101011
    }
]