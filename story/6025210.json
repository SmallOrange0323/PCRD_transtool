    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果沒有美美和禊，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我一定很意氣消沉。",
