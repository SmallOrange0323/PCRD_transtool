        "type": "dialogue",
        "name": "鏡華",
        "words": "可是，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊在重要的時刻",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也會責備我、鼓勵我。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我很感謝她，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這點要保密哦？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是的。",
        "unit_id": 111111,
        "voice": "vo_adv_6025210_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很相信美美和禊。",
