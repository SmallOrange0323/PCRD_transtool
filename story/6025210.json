        "voice": "vo_adv_6025210_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我感覺自己",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n老是在責備禊……",
