[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "度假在一片好評之中展開，第二天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}不知道如何使用到晚上前的自由時間，\n因此放空地眺望著海，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這時候，雪菲來到他身邊。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n到晚上之前還有時間，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果你願意……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要不要",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟我約會？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是你沒有",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "其他預定的話……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝、",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝你。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話雖如此，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是我沒決定好要去哪裡就是了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總之……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們就一起去散個步吧。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突破第一關了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "比我想得",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還要輕易地就得到OK的回答了呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "接下來才是正題。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "到晚上之前，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要問出那時候告白的答覆……",
        "unit_id": 135111
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──昨天真的很謝謝你。",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最後的按摩，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是不是",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點做過頭了啊……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱歉喔。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是那樣嗎？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然最後，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們幾乎都是在互相搔癢了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但是包含我在內，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家看起來都很開心，真是太好了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家幫我按摩之後，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我好像也有稍微消除了疲勞。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最近不時會遇上在海邊被魔物包圍的狀況，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很辛苦呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話題聊得很熱烈，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這可能是個好時機。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n只要不經意地問出口，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "氣氛應該也不會變得奇怪……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「你覺得怎麼樣呢？",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我那時候的告白。」",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……沒錯，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要用盡可能自然的感覺。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "隨口說出來喔。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那、",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個啊……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我稍微有點事情",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想問你一下。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你、",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你覺得",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼樣──",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我──",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──我在想你會不會有點餓了？",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你也",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還沒",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "吃午餐吧？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果、",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果然",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會餓吧！",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我去海之家買點什麼回來。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你在這裡等我。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒、",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒問題，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不需要著急。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為還有時間……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓你久等了。",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我買了炒麵回來喔。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "薯條跟烤雞串。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是不是",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點買太多了呢……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為我太慌張，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以說出從菜單上面開始",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "到下面全部都要，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這件事要保密就是了……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們開動吧。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這麼說來……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "昨天，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我沒能",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「啊～嗯」地餵你吃呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要來試試看嗎？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要餵了喔？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊～嗯……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好吃嗎？",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太好了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要再吃一口嗎？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊～嗯。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦，",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你要餵我嗎？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我知道了……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊～嗯……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嚼嚼……",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好好吃～♪",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n葛格，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還要～♪",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──啊！？",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚啊啊啊……",
        "unit_id": 135111
    },
    {
        "type": "background",
        "background": "501181"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒想到",
        "unit_id": 135111,
        "voice": "vo_adv_1351003_024"
    },
    {
