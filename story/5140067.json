    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "はい。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_031"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "仲間同士の他愛もない話です。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "な、",
