        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n付き合ってもらいますから！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_037"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お待ちください陛下！　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "せっかくの【美食殿】のパーティーなのに",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしがいては台無しになってしまいますわ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "おかしなことをおっしゃいますね。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_038"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "仲間同士で鍋を囲むだけですのに、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nなぜ台無しになるのでしょう？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "くっ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_039"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そんな曇りなき瞳で見つめないでくださいな！",
