        "voice": "vo_adv_5132067_032"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "仲間……！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そうだったんですか～",
