[
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "クレジッタは打ち合わせのため【美食殿】のギルドハウスを訪れた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下ー、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_000"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いらっしゃいますかー？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "親愛なる忠臣、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "クレジッタ・キャッシュですわー！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あ、",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_001"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさん！　",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "すみません、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わたしちょっと出かけるので、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "中で待っててくださーい！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "え、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_002"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "へ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nちょっと、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "どちらへ行かれますのーっ！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさま、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_003"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "誰かいらっしゃったのです──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "おや、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "クレジッタさま。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "いらっしゃいませ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさまにご用事ですか？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_004"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "チビ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "い、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いえ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "コッコロさん、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ごきげんよう。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下にお話があったのですが……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "申し訳ありません。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_005"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさまは",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "今晩の鍋パーティーで使う",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nポン酢を買いに行かれました。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お鍋に浮かれすぎたあまり、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_006"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "材料ばかりに気をとられ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nポン酢が切れていたことに",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "先ほど気付かれたようです。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "すぐにお戻りになりますから、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "中でお待ちください。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あまりスケジュールに余裕はないのですけれど……",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "出直す方が時間がもったいないですわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n仕方ありません。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "この際ですし、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "もてなされて差し上げますわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "はい。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_008"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nお任せくださいませ。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "粗茶ですが、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_009"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "よろしければどうぞ。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n外は冷えますから、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "熱く淹れております。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お気を付けくださいまし。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "フン、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_010"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "粗茶ですって？　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こちらではそんなものしか出せないのかしら。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nもし万が一陛下にやっすい茶葉の出涸らしなど飲ませていたら",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくし承知しませんことよ──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "（ごくっ）",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……これは……！　",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "決して高級ではありませんけれど、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n確かな技術と真心を感じる一杯ですわね……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "何より、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "少し熱めに",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n煎じられた茶の温かさが、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "凍えた身体に染み渡りますわ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "こちら頂き物ではありますが、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_012"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お茶請けでございます。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n【メルクリウス財団】からのお歳暮ですので、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "味は折り紙つきですよ。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nわたくしが手塩にかけた漬物もございます。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "あとそれから──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "クレジッタさまは、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_013"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "魔物料理を抵抗なく召し上がっておられましたね。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "では",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "こちらを──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさまが狩った魔物の燻製です。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n後ほど感想をいただければ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさまも喜ぶかと。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ああ、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_014"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ひょっとしてお昼ご飯がまだでいらっしゃいますでしょうか。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "それでしたら、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ただちにご用意させていただきます。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "取り急ぎ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "おにぎりとラーメンとサンドイッチとスパゲッティと──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちょっとお待ちなさいな！？　",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_015"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしそんなに食べられませんわよ",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "っていうかどれだけ食べ物出てきますのこのお家は食堂か何かでしたの",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ああそうでしたわね【美食殿】でしたわねこちらのギルド！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "えっ？",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_016"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "「待て」と言われましても……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "その前に",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "「もてなせ」と",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nおっしゃられたのは、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "クレジッタさまではありませんか。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "限度というものがあるでしょう！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_017"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "それにあれは、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そう、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちょっとした軽口でございましてよ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そもそも。",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_018"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女のほうだって、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "赤の他人どころか",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nかつては敵のようなものだったこのわたくしを",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nこれほどもてなす義理はないでしょうにっ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "……キャルさまは",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_019"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "否定されるかもしれませんが、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "わたくしは",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "クレジッタさまに悪感情はありません。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "むしろ今回のクリスマスを通じ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "感謝の気持ちを抱いております。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "少し前……",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_020"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "わたくしたちは、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "辛い別れを経験しました。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nぺコリーヌさまも、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "明るくふるまってはおられますが……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n折に触れて、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "悲しいお顔をされることがございます。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_021"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ですが、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_022"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "このところ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ペコリーヌさまは心の底から楽しそうなのです。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "一時であれ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "楽しく過ごしていただけたら。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "なので本当に、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_023"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ありがとうございます、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "クレジッタさま。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……べっ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_024"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "別に貴女たちのためではございませんわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n全ては陛下のためにやったこと、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女たちのことなんて",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nその副産物みたいなものですわよ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "はい。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_025"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n存じておりますが、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "それでもわたくしは",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お礼を申し上げたいのです。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……全く、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_026"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "調子狂いますわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これだから甘ちゃんのお子ちゃまは……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ただいまー！　",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_027"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "はぁー、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ギルドハウスの中はぽかぽかですねぇ……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あ、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさん、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "お待たせしてすみません！",
