        "voice": "vo_adv_5132067_033"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "でも、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "二人だけで楽しんでちょっとずるいです。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わたしもまぜてください！",
