        "voice": "vo_adv_5132067_029"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "なんだか、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "部屋の中がいい雰囲気ですね。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "二人で何を話してたんですか？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "べ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_030"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "別にそんな……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ただの世間話ですわ。",
