    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "コッコロさんから、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "厚くもてなしていただいておりましたので。",
