    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "しかし貴女たちがよろしくても、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あのネコ助はどう思うか……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それは大丈夫です。",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_040"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "キャルちゃんだって",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "口では悪ぶっていても",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\nちゃんとクレジッタさんのことは理解しているはずです☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……だといいのですが。",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_041"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "そうと決まれば、",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_042"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "主さまとキャルさまがお戻りになる前に、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nお鍋の準備を進めておきましょう。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "では、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_043"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "せめてお手伝いさせてくださいませ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "客人ではなく、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "仲間と呼んでいただけるのでしたら、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
