    {
        "type": "dialogue",
        "name": "優妮",
        "words": "羅塞塔的狀況？",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "　啊～原來如此，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為之前跟優妮升機一起燒起來了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以你很在意那之後它是否平安嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "放心吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它是石頭，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "燒不起來的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就當作是打招呼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "隨便試著跟它說些什麼吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_001"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　♪啵啵嘎啵",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "（喝呀）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　♪啵啵嘎啵",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "（嘿咻）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n表情很恐怖喔克蘿依",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　腦袋切嚕了的琪愛兒",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　才貌雙全的優妮學姐",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n三人聚在一起就是優妮們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　優妮帶頭唱太陽大放晴",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "（耶～）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_002"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　該筆資訊",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "「管理者的3圍」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "受到嚴密的保護，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n取得相關情報，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "克蘿依小姐的數據！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n順序由上而下為，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "80――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔快停止。",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會被殺掉的！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算你沒事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我跟他也會被殺掉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "心跳加速！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_004"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　剛剛的指令",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "使我發現了少女的脆弱！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n我們已經沒辦法再做朋友了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "　這石頭的心跳聲，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "難道",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "這就是愛情嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "羅塞塔，",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來你是母的啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話說回來，你有雌雄之分嗎……",
        "unit_id": 111011
    }
