    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "魚介の本場、",
        "unit_id": 105812,
        "voice": "vo_adv_6056101_000"
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "オーマの海♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "究極のお魚以外にも、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "たくさんの海の幸がとれるそうですよ♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\nあなたはどんなお魚が食べたいですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "おおっ、",
        "unit_id": 105812,
        "voice": "vo_adv_6056101_001"
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "焼き魚ですか！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "そのままいただくのもおいしいですけど、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "やっぱり焼くのは定番です♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "炎の上でしたたる脂……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "ぜひ釣りましょう！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "あっ、",
        "unit_id": 105812,
        "voice": "vo_adv_6056101_002"
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "もしかして前に食べたサラダのことですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "えへへ、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "確かにあの味は簡単に忘れられません♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "ニュルニュルが釣れたら、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "ぜひサラダにしていただきましょう！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "へ？　",
        "unit_id": 105812,
        "voice": "vo_adv_6056101_003"
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "手足のあるサメなんているんですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "……海で野球をしている時に見たことある……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "そ、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "そのお話、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ぺコリーヌ",
        "words": "もう少し詳しくお願いしますっ！",
        "unit_id": 105812
    }
]