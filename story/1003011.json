        "voice": "vo_adv_1003011_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "開玩笑的啦。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算是我",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "行動力也沒那麼強。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是要表示我會多麼依賴你的程度而已。",
