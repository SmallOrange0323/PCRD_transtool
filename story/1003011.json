[
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——與怜一同參加視察之旅的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n視察完第一個村莊，乘坐馬車前往下個村莊。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……好。",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "報告應該這樣做就行了吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然想趁勢前往下個村莊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但你會不會覺得無聊？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然我很開心……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但那個",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得有點不好意思。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是報告的份量就滿多的了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剩下的就留到下個村莊時再做吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就簡單的吃點東西休息一下吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在剛剛的村裡",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "買了點三明治，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要不要一起……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這道光是！　",
        "unit_id": 100311,
        "voice": "vo_adv_1003011_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都已經離開蘭德索爾了竟然又出現了…！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "意識",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又……！",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "——你好啊。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n沒想到假日還能在這裡遇到你，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真巧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你是來買東西的？　",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對啊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n硬要說的話",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是來『散心』",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……今天被父親擺了一道。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他硬拖我出來參加飯局，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n原來是要我參加政治人物和他們兒子的聚會。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以我就騙他們說我有事，",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "提早跑出來了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……要我乖乖待在那種地方，",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n乾脆讓我死了算了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總是希望我什麼事都順著他的想法走，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我對父親的那種做法早就厭煩了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……對了。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你現在有空嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得都遇到了，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一起去哪裡走走吧？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像把你捲入了什麼事件一樣，抱歉啊。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我、",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒想到你竟然會那麼開心。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像能懂你的心情。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一想到能和你一起出去走走，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "心情就很雀躍。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們去遠一點的地方吧。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我一直想再和你一起去看海。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以吧？",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "100301101"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "——沉靜的大海……",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n終於能兩人一起來看海了呢。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還吹著舒服的風……",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有帶釣具來就好……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊！？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……討厭。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我以為是很舒適的風，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但好像有點強。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那個……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的髮型",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有沒有變得怪怪的？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在你面前",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不想露出不體面的樣子。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……什麼！？",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別捉弄人啦。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "海多麼的寬廣",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多自由……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……『希望孩子別被嘲笑為世襲議員』。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我至今，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在父親的這個教育方針下栽培長大的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論是讀書、",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "學校、",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "交友狀況……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "甚至是我的想法，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n幾乎沒有一樣是我自己選擇的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n簡直就像飼養在魚缸裡的魚一樣。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但現在不同了。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是我自己選擇投入的世界",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在阿斯特朗遇到的同伴",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "改變了我。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這段羈絆",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比什麼事物都更讓我想珍惜。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身邊有好夥伴。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是這點",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就讓我湧現想依照自己意願活下去的勇氣。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使一步一步慢慢來也沒關係。",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一點一點的抗爭……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總有一天一定",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能像這片大海一般",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "生活在自由的世界中……！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過嘛",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若我是淡水魚的話，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n出海可是會死掉的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即便如此我也不在乎。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為那不是父母幫我舖好的路，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而是我自己選擇的結果……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並不是在說真的會死，請放心。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是在說我的決心。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即便真的遇到可能死亡的情形，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要你像今天這樣陪在我身邊，",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那我一定",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論發生了什麼事都能活下去的……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 100332,
        "voice": "vo_adv_1003011_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我並不是想把你捲入事件。",
