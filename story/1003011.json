        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要你在身邊，我就覺得能夠堅強……",
