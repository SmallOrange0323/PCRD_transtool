[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喂～，哥哥！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這裡遇到哥哥，真是讓我精神百萬倍♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "午安！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我是璃乃，我很好！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥在這種地方做什麼呢？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n又在散步嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔喔。哥哥是因為最近這個洞穴的內部結構正在改變，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以受託來調查這件事？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來哥哥在做這種工作呀，辛苦了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（嗯～……洞穴的內部結構改變，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n說不定是我們家會長所造成的？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（因為那個人有能力改變地形，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n能使用一種叫作『物件變更』的能力？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（話說回來，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n會長好像說過～她要在這一帶設置祕密基地。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（會長為了設置祕密基地而變動地殼，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n洞穴內的結構才會因此改變了吧。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……嗯？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥問我為什麼會在這樣的洞穴裡？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就是為了那件事呀，我在收集做衣服的材料！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "前陣子，哥哥不是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也幫我取得了可以做染料的植物嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "託哥哥的福，雖然調製過程很辛苦，不過我做好染料了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，重點是我沒有可以用來染製的布料。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以最近我都在收集這方面的材料。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然店裡就有賣便宜的布料之類的，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過我要是連所有布料都能",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n自己張羅的話，就能省錢了吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿，算起來就是替未來投資。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我要一面磨練技術，一面收集便宜的服裝材料！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是勤儉持家的璃乃，感覺我好像可以成為一個好妻子呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，對吧對吧！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥可以把我娶回去喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不是的，那個，我也有在讀書……喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我下次一定要考上！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因此每天都有好好地讀書讀到深夜喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個應該算是在辛苦準備考試之餘的消遣～？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我報考的是製作衣服的專門學校，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以也有術科考試。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也就是說，那個，光是坐在書桌前讀書也沒用！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不論是實際製作服裝，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n或是收集服裝的材料，都算是為了考試在做準備！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "先不說那些了，哥哥也不是那麼強……",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以哥哥獨自一人探索這種地方是很危險的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為這個洞穴也會出現頗危險的魔物。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會保護哥哥的。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "作為交換……如果哥哥能陪我收集",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n製作服裝所需的材料，我會很開心。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為俗話說出門靠朋友，處世不用人情♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒問題嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼我們走吧，出發囉♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我在找的是蜘蛛形態的魔物。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "牠似乎是棲息在這個洞穴裡。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n聽說牠會吐出七彩的蛛絲，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這種絲可以成為很好的服裝材料喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "蜘蛛捕食獵物，從中取得的色素",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n似乎會沉澱到蛛絲裡，形成七彩的顏色。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也就是說，這種蛛絲非常容易染色。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "它能使之前取得的染料充分發揮特色，是最棒的素材。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果不將其脫色，直接使用的話，由於蛛絲原本就染上了七彩，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因此可以運用在任何服裝上。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想盡可能地大量採集。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只是那種蜘蛛本身是非常強悍的魔物。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我們要盡量趁牠沒發現時，只回收蛛絲……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥不見了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥跑到哪裡去了呢，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請不要拋下我自己走掉！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我好寂寞喔，哥哥～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "從我的正上方傳來聲音呢！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這個聲音是……哥、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥為什麼會在我的頭頂上？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚哇，有蜘蛛垂吊在洞穴的天花板上！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥被蛛絲纏住，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n蜘蛛似乎正要從哥哥的頭開始大快朵頤！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大事不妙！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我現在就去救哥哥！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請不要亂動！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，哥哥擋住了蜘蛛，我沒辦法瞄準牠！",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不對，蜘蛛正拿哥哥當人質？",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "牠的智商真高！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（怎怎怎、怎麼辦？",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我又不能一箭射穿哥哥和蜘蛛，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可是放著不管的話，哥哥會被吃掉的！）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（嗯？哥哥正用下巴指向天花板？",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個動作是什麼意思呢，哥哥！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我不懂！）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（啊……",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n蜘蛛垂吊的天花板有許多裂痕，正不穩地搖晃？）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（原來如此。",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為洞穴的結構改變，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n導致岩層歪斜而變脆弱了吧！）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（雖然蜘蛛是無法一擊就能打倒的強大魔物，",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過只要我瞄準天花板的話……）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（蜘蛛就會掉下來受到很大的傷害，",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n或者可能順利地被埋在瓦礫堆裡動彈不得？）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然哥哥一起掉下來也很危險，",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過我會想辦法安全地接住哥哥的！）",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了，哥哥！",
        "unit_id": 101111,
        "voice": "vo_adv_1011006_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要上了喔，嘿呀！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請射中！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了，準確命中！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n欸嘿，我是個只要肯努力就辦得到的孩子☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "天花板崩塌，蜘蛛要掉下來了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n蜘蛛似乎趁機切斷蛛絲逃走了的樣子？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再來只要我能好好地接住哥哥的話～……嘿咻♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呀嗯！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果、果然憑我的臂力",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n是難以接住哥哥的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我們一起倒下去了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥沒事吧？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿，哥哥平安無事真是太好了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不、不好意思，可以請哥哥挪開身體嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n感覺我好像被哥哥撲倒在地，動不了喔～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，哥哥是被蛛絲纏住了才會無法動彈吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，我有帶捲線器。",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我把蛛絲捲一捲回收喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請哥哥稍等一會，蛛絲也平安到手，真是萬萬歲♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥說謝謝我救了你？",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_047"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不會不會，要道謝的人是我！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥從以前開始，",
        "unit_id": 101112,
        "voice": "vo_adv_1011006_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就總是會帶給我很棒的東西喔♪",
        "unit_id": 101112
    }
]