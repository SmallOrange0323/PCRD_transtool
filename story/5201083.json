[
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_000"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "長老，",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_001"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "關於我之前提交的",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "世界觀設定──",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "──我現在正在看。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_002"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n拉基庫瑪爾‧拉基尼卡東。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是這樣啊。",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_003"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "啊",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "啊",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那套裝束，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n因為是精靈族流傳的儀式中",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "所使用的服飾，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n所以我特別採用了與大自然",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "融為一體的設計。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯，",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_004"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "可以說很出色。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "不過……",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "有什麼讓您在意的點嗎？",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_005"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "…………",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_006"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "棗宙……",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_007"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "嚮導老君。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "在怪才齊聚的七冠中",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "可說是最老成的人。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "他的觀點總是",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "能放眼於",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "擺脫世俗的某些事物。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那麼，",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_008"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "這次您會看見什麼，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "又會引導什麼呢……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……我在擔心設計是否會太大膽。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "…………",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_010"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "不，",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "絕無此事。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我認為所謂的裝束，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "與現代衣服",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n光是從設計理念來看",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就有根本上的不同──",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "原來如此。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_012"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "但是，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "然而，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這個要……",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "蘿穿……",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……話說回來，",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n世界觀之類的設定",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "雖是由我負責，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n但這座精靈族之村，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是長老親自打造的吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "長老，難不成",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_014"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "您想讓令千金",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "擔任村落的巫女嗎？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_015"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n也並非沒有變成那樣的可能。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n畢竟未來是無法肯定的。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "長老，",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_016"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "請別打算蒙混過去。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "您是以令千金為前提",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "在考量的對吧？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……用這個設計就行了。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_017"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "很感謝",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_018"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "您的認可。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "不過第二張再讓我考慮一下吧。",
        "unit_id": 107231,
        "voice": "vo_adv_5201083_019"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這樣會感冒的。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……好的。",
        "unit_id": 107331,
        "voice": "vo_adv_5201083_020"
    }
]