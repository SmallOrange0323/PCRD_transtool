[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被怜叫來海邊。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來得正好。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "事不宜遲，我們開始吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你拔劍做什麼？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拿去，我也準備了你的釣竿，快點準備吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……當然是來釣魚囉……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道你以為是修練？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算是我，偶爾也會有想休息的時候喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你也有這種時候吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天就把修練的事情忘掉，盡情的玩吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n偶爾也需要像這樣的假日呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "釣魚的準備完成了吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接著只要等魚上鉤就行了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……一個人在等魚上鉤的時候，什麼都不做也沒關係。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但今天難得一起來， 我們來聊點什麼吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是這種話題啦。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你是明知故犯吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，天氣確實很好。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………話題好像結束了？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來聊點長一點的話題吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，來聊點你的事情吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n沒跟我在一起的時候，你都在做些什麼呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……翻越了那座山？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就你一個人！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是因為工作關係……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使如此也很厲害呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那座山明明也會出現魔物，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你沒問題嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n和我的修練發揮了作用，真是太好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是連那座山都能翻越，",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n驅逐魔物的委託不也能一個人接下了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你真的越來越強了呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n作為帶你修練的人，我真的很開心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是不是說我也該卸下重任了？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "――咦！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，那個……就算你這麼認真地回答我……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱，抱歉。我本來只想開個小玩笑。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n當然今後我也會在你身邊喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喂，你！",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n有魚上鉤了喔！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "釣竿彎曲的這麼厲害，一定是條大魚！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一個人有點困難……我們一起把牠拉起來吧！",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n仔細地看準時機――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是現在！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼！？ 把魔物釣上來了！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到魔物會出現呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們來打倒牠吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我來吸引牠的注意。",
        "unit_id": 100312,
        "voice": "vo_adv_1003005_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你趁機給牠致命一擊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n喝，呀！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "敵人膽怯了喔！",
        "unit_id": 100312,
        "voice": "vo_adv_1003005_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n趁現在！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做得很好喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你的動作也變得相當流暢了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是今天的釣魚只能到此為止了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n魔物在的話，這裡暫時不會有魚聚過來了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連一條魚都還沒釣到的說……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也有像這樣的日子，",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正是釣魚的有趣之處呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總之我們回城鎮去吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，時間正好，要不要去吃飯啊？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還、還有，關於剛才話題的後續……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是你說不想要我卸下教你的重任這件事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這還是我第一次感受到，",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n被他人所需要是那麼令人開心的事情。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以，謝謝你。",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……那個……",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我來說，你也是不可或缺的喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我只是想告訴你那、那件事而已！",
        "unit_id": 100311,
        "voice": "vo_adv_1003005_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "走吧，快點回城鎮去了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在回去的路上，怜一直走在前面，\n盡量不讓人看到她滿臉通紅。"
    }
]