[
    {
        "type": "background",
        "background": "509011"
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "英雄先生～！",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_000"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n謝謝你",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "邀請樞一起出門！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "不過，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "為什麼突然之間……",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "咦──",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_001"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "你說因為是樞的生日，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "所以不管哪裡都會帶樞去……？",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "你、",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "你記得",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "樞的生日嗎！？",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n連樞自己都忘記了說……",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "謝謝你～！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "可是可是，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_002"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "樞平常就一直受到英雄先生照顧了，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n居然還讓你來慶祝樞的生日……",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "該、",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "該怎麼辦才好…………",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "啊！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "那個，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_003"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "樞想到",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "要去哪裡了！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n所以，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "能請你跟樞一起來嗎？",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n就在附近而已！",
        "unit_id": 130931
    },
    {
        "type": "background",
        "background": "510330"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "這間手工藝店，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_004"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "是樞常來的地方♪",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n鈕扣什麼的都很便宜，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "旁邊還有能作業的地方，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n對樞的家裡幫助很大～！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "嗯，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_005"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "穿過剛剛買的串珠，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "最後裝上兔子的裝飾……",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "完成了♪",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n這是給英雄先生",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "的禮物！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "作為平時的回禮，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_006"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "樞做了一個鑰匙圈！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n雖然只是個小東西，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "但如果你不介意的話就收下吧！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "啊啊！",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_007"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "經、",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "經你這麼一說……！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "不、",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "不過",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "對樞來說，因為一直受到很多照顧，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n倒不如說",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "只有這樣還遠遠不夠呢……",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "哇，",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_008"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "是交換禮物！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "這樣的話，做的時候，樞可以在旁邊幫忙，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "感覺好有趣♪",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "嘿嘿……♪",
        "unit_id": 130931,
        "voice": "vo_adv_4010190_009"
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n樞會把它當成一輩子的寶物！",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "\n謝謝你送樞",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "這麼棒的禮物，",
        "unit_id": 130931
    },
    {
        "type": "dialogue",
        "name": "樞",
        "words": "英雄先生♪",
        "unit_id": 130931
    }
]