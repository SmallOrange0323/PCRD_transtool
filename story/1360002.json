    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n阿剌克涅從暗處朝著有人往來的方向，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n目不轉睛地凝視著。"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_000"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不在……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_001"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不在……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不在……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊──",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_002"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "在那裡……！　",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_003"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是的，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_004"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我在等待騎士先生。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……雖然並沒有，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "什麼特別的事……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那個……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_005"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n如果沒有什麼事的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就不可以來見您嗎……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我也是，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼騎士先生，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "今天在做什麼呢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "既然如此，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_007"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請務必讓我也",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "一起同行。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n有行李的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "由我來拿就可以了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "食品店店員",
        "words": "謝謝惠顧！",
        "unit_id": 50611,
        "voice": "vo_adv_1360002_008"
    },
    {
        "type": "dialogue",
        "name": "食品店店員",
        "words": "\n因為買了很多，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "食品店店員",
        "words": "所以額外給您贈品喔！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我來拿吧。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_009"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "畢竟身體巨大，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我的力氣似乎也很大呢。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "接下要去哪裡呢？",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_010"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "無論天涯海角都會跟著您的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……是這樣嗎？",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_011"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我和小拿，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "也有在這個距離說過話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n所以並不介意……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "倒不如說，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "心裡雀躍不已……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n變得溫暖了起來……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但是……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_013"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "如果騎士先生",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "感到不舒服的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n請告訴我。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我會在不跟丟騎士先生的範圍內，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_014"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "保持距離行走的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "只是對我而言，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n是希望能盡量走在騎士先生附近的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "謝謝您，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_015"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_016"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "您是我的光芒。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n所以，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我想盡可能待在您身邊──",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "來喔，",
        "unit_id": 50811,
        "voice": "vo_adv_1360002_017"
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "限時特賣開跑啦啊啊啊！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "\n數量限定！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "先搶先贏！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "隨便拿儘管拿！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "\n而且還有超稀有的",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "「萬花菲尼克斯不老藥」",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "超低價店家的店員",
        "words": "緊急進貨啦！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "購物的客人們",
        "words": "限時特賣……！！！",
        "unit_id": 1,
        "voice": "vo_adv_1360002_018"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎、",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_019"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生～！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "怎、",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "怎麼辦……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生被",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "人潮吞沒了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請等等我，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_020"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我一定會，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "找到您的……！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "呼、",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_021"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "呼……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "到底在哪裡呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n應該還沒被擠到太遠的地方才對……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_022"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊啊，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_023"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "太好了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "終於找到您了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n看起來也沒有受傷呢。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "呵呵……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_024"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n這巨大的身體，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "偶爾也能派上用場呢。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n因為馬上就能找到，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "被埋沒在人潮中的騎士先生了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……我，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_025"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "在和騎士先生分開的期間，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n感覺就像死了一樣……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "甚至以為您是不是消失到哪裡去了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請不要道歉。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_026"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "因為騎士先生",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "並沒有做錯任何事。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "如果我，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_027"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "能再靠近騎士先生一點的話……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n那樣的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這樣的心情就……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是、",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_028"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生需要採買的東西，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_029"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n能全部買齊真是太好了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "行李我會",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_030"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "搬到騎士先生的住處的，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n雖然很不好意思，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但要請您帶路──",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊……！",
        "unit_id": 111,
        "voice": "vo_adv_1360002_031"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好痛。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "非常抱歉。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_032"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n是我沒注意周圍，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "才會撞到您……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……",
        "unit_id": 111,
        "voice": "vo_adv_1360002_033"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "膝蓋。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……",
        "unit_id": 111,
        "voice": "vo_adv_1360002_034"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好啊。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_035"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_036"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "真是個溫柔的人。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "因為很溫柔，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "所以對小孩子也很溫柔。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "所以，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "一定……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "對我也很溫柔。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不只是我……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_037"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "並不是只對我一個人綻放光芒……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "而是照耀著所有人……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……呼……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_038"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "既然如此……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_039"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "既然如此……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "既然如此，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_040"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "乾脆……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n為了讓他成為只能照耀我的光芒，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n用我的絲線，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "把騎士先生……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……謝謝，",
        "unit_id": 111,
        "voice": "vo_adv_1360002_041"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……大姐姐也是，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "掰掰。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………？",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_042"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "在想什麼……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……沒什麼。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_043"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "只是，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "稍微想了些事情。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "路過的居民",
        "words": "是隨從嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1360002_044"
    },
    {
        "type": "dialogue",
        "name": "路過的居民",
        "words": "\n真好啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的居民",
        "words": "有隨從！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的居民",
        "words": "\n我也想要一個能隨時陪在身邊的隨從啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "路過的居民",
        "words": "哈哈哈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "隨從……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_045"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊啊，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是那樣啊……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "只要作為隨從侍奉騎士先生的話，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_046"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n不就能更常待在他的身邊了嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n好一陣子沒見到身影的阿剌克涅。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n久違地出現在{player}面前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但那副打扮卻──"
    },
    {
        "type": "still",
        "still": "136000201"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我拜託了紡希小姐，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_047"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請她幫我製作的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n試穿之後，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "雖然獲得了紡希小姐的稱讚……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "您覺得如何呢？",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_048"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n為了能配得上作為騎士先生隨從的模樣，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我試著",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "先從衣服開始改變起。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……因為我想幫上騎士先生的忙。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_049"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n一直以來都只給您添麻煩，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還沒能好好道謝。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "所以……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_050"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "現在是不是",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "要去買東西呢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n那麼",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請容許我同行吧，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生。",
        "unit_id": 136011
    },
    {
        "type": "still",
        "still": "136000202"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "今天也，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_051"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請讓我來拿行李吧。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n無論再多再重，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "都請交給我。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "因為我是隨從。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_052"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n對於上次",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "和您走散的這件事，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我一直都很後悔。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "心想著與其和騎士先生分開，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_053"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n不如一開始就讓人無法分開就好了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_054"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不行……！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n人潮又湧過來了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請來這邊。",
        "unit_id": 136011
    },
    {
        "type": "still",
        "still": "136000203"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請您放心。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_055"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n無論有多少人潮湧來，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我都不會放開騎士先生的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……騎士先生，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_056"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "您怎麼了？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……？",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_057"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n雖然不太明白，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但我被東西包住時就會感到安心，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n這對騎士先生來說",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "也是件好事吧。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "凹凸不平的堅硬石頭等等，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_058"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "當作床鋪的話會又痛又冷……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n對於棉被的柔軟與包容力，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我最近，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "每天晚上都很感激。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "來吧，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_059"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼就繼續去買東西──",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n啊……！",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "衣、",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_060"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "衣服……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "破掉了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n明明是和紡希小姐，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "特別訂製的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是的……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_061"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "明明是騎士先生中意的衣服，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "真的很抱歉。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我去換一件，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "可以請您稍等一下嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我馬上就回來……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "真的馬上就回來喔。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……拜託您了，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_062"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n那麼暫時，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "失陪了……",
        "unit_id": 136011
    },
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我失敗了……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_063"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "真是困難呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n想要作為隨從侍奉騎士先生這件事……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我明明，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "只是想待在他身邊而已。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……不管怎樣，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_064"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "都揮之不去。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n騎士先生對我以外的人，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "溫柔相待的樣子……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n明明我知道，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那正是騎士先生的優點。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……不想讓給別人。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_065"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不管是誰。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我的光芒……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "希望他能成為只屬於我的光……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_066"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n為了那個目的，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_067"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_068"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "又，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "把絲線……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不行……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_069"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "過去的我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "奪走了許多人的「光」。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n這樣的我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "又想做同樣的事，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "試圖用蠻力得到些什麼，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n這種事，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是不可能被原諒的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "呃，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_070"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這個是，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那個……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……我是打算這麼做的。",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_071"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "將絲線纏繞在我的身上……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "再把絲線的前端，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "交給騎士先生。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這樣一來騎士先生，",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_072"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就是我的主人。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……了",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "汪？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "絲線是不是",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_073"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "纏繞在脖子上比較好呢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "誤會……",
        "unit_id": 136011,
        "voice": "vo_adv_1360002_074"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "被誤會也無所謂。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n如果那樣就能待在騎士先生身邊的話……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然勉強打消了強行奪取的念頭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但為了待在{player}身邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n阿剌克涅展現出了無論什麼事都做得出來的模樣。"
    }
]