[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈、",
        "unit_id": 106011,
        "voice": "vo_adv_0000133_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經收集完所有的道具了對吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在我們抵達這前，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底總共遇過多少次的危機了呀。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和好多強大的敵人戰鬥了啊，",
        "unit_id": 105811,
        "voice": "vo_adv_0000133_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們真的超努力的呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以可蘿仔，",
        "unit_id": 106011,
        "voice": "vo_adv_0000133_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來該怎麼辦？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據傳聞所云，",
        "unit_id": 105911,
        "voice": "vo_adv_0000133_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最後的試煉",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得將那擁有龐大力量",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的自身幻影給擊倒才行的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "藉由擊敗強大的幻影，",
        "unit_id": 105911,
        "voice": "vo_adv_0000133_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才能將那龐大的力量",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真正歸於自身之物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～！",
        "unit_id": 105811,
        "voice": "vo_adv_0000133_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正巧能夠好好試一下身手了呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011,
        "voice": "vo_adv_0000133_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真拿妳們沒辦法呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然都到這了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管它要來什麼都一樣了唷",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一次把你們通通清得一乾二淨！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是您們兩位。",
        "unit_id": 105911,
        "voice": "vo_adv_0000133_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請務必要繃緊神經來一同面對這場挑戰吧。",
        "unit_id": 105911
    }
]