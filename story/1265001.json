        "voice": "vo_adv_1265001_042"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「吉歐‧提格尼亞」，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n鑑於兩國今後",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會有增加交流的可能性，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n請務必",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "親臨蘭德索爾一回。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "信上是這麼寫的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而且",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_043"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並非是作為一國公主……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以她朋友的身分。",
