[
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "背面世界「吉歐‧提格尼亞」──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n統治此地的萊拉耶爾公主，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天也坐在王座上，讀著家臣送上來的報告。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣一來文件就全部讀完了吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這次的報告",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來是沒有發生什麼大問題呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是太好了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n既然工作也結束了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我來",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "睡一下午覺吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呼",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咳咳。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "午安，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊啊……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n果然",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "被你看見了呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我還在想",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說不定沒有被看到……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n沒想到會讓人看見我嘴巴張得那麼開的模樣……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是不好意思……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你真的是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很溫柔呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那樣的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也請你",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將這件事當成我們兩人的祕密吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可愛……？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是的，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請你別捉弄我了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你這個人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也是有壞心眼的地方呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你今天來是有什麼事嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "伴手禮……？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊啊，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這麼說來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你有說過為了處理事情，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n所以要回去你們的世界呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "異國的伴手禮……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有股好香的氣味。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是食物嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們就一起享用吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "到我的身旁來。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀……！",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這是你們的世界的甜點對吧？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "巧克力、餅乾……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這個是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "馬卡龍嗎。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "原來如此，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒有放太多的奶油呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "每個看起來都好好吃♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好的。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我就先來吃這個馬卡龍吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我開動了…………",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊嗯。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊啊……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n好好吃……♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能襯托出素材味道，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "恰到好處的甜度……♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n而且",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吃起來清脆爽口。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這會讓人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "忍不住一口接一口呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n甜點能夠跨越世界的藩籬呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_018"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這些",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都跟「吉歐‧提格尼亞」的甜點很像似。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "卻不盡然相同，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而有著自己的獨特之處。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然我們的確是屬於不同的世界，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_019"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "然而",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "心中對於「美味」的感受卻沒有不同。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這是件很美好的事情。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "透過這點讓我體會到了，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_020"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n即使生長的世界不同……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們的心還是能夠相通。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……阿斯特賴亞大陸。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_021"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還有蘭德索爾。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在聽過你和克蘿茜的描述後，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我心裡是這麼想的……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n說不定我們的世界比我們想像的，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還要更靠近彼此。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要說不好奇的話，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_022"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那是騙人的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n無論是身為國家與人民的守護者……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以個人的身分來說。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……騎士。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_023"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n今後，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也請告訴我關於你們世界的事情吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n無論是多麼微不足道的事情都無所謂……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一起到那邊……？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_024"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……呵呵。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_025"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n俗話說「百聞不如一見」，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我過去，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也曾經跟克蘿茜這麼說過。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "對於你的心意",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_026"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我感到很高興……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "然而我是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "萊拉耶爾公主。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "身負守護這個國家的和平，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以及人民安全的責任。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我不能離開這座城堡。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "比起一見，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_027"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我選擇百聞。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n……所以說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請你",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "告訴我更多的旅行趣聞吧，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_028"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我很期待哦。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……咦？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_029"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這邊的甜點是……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "餅乾嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這形狀還真是古怪呢。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_030"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n簡直",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就像是包了什麼東西在裡面。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_031"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "餅乾還能占卜嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這份巧思真不錯呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那我就",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "快點來占卜看看吧……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊嗯。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊啊，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真的有紙條在裡面。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n到底會是什麼樣的結果呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我好期待♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n數到三我就打開囉？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一、二、三。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「出外旅行會發生好事。」"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_033"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……嚇、",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_034"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嚇了我一跳。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這真是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "想什麼來什麼呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才剛剛聊完關於你的世界，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "竟然就出現這樣的結果……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好事……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_035"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "究竟會發生什麼事呢……？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……啊。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_036"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我真是的，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一不留神",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就想了些不該想的事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好了，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_037"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "接下來要吃哪種甜點呢？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你推薦哪一種？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}再次前往了萊拉耶爾的所在之處。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_038"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n今天有什麼事嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你又帶了蘭德索爾的伴手禮來嗎……？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝你。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_039"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這是……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "邀請函，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這還真是稀奇。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會是誰送來的呢……？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──貪吃佩可公主？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_040"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……原來是這樣。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_041"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "關於蘭德索爾與",
