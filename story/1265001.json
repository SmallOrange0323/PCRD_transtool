        "voice": "vo_adv_1265001_047"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我非常感激。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "當然，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也很感謝貪吃佩可公主的用心……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我忍不住會去思考，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_048"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然說只是暫時的，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是身為公主的我……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "離開國家真的好嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咦？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_049"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的、",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_050"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的確……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是這樣沒錯呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n貪吃佩可公主",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然和我一樣身為公主……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n卻時常來到這邊的世界。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這是我沒有想過的呢。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_051"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……說不定，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是我把事情想得太過嚴重了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n連我自己都沒有意識到。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只要指示女僕長等人在留守時該如何應對，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_052"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再讓克蘿茜擔任護衛隨行……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n如果是短期間的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "應該沒有問題才對。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…我了解了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "貪吃佩可公主的邀請，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我很樂意接受。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能請你幫忙帶路嗎？",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_053"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "帶我到你們的世界──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "阿斯特賴亞大陸去。",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在隔天──"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "時間差不多了，",
        "unit_id": 126411,
        "voice": "vo_adv_1265001_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "時間差不多了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n差不多是普蕾西亞告訴過我",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n天上要開洞的時候了♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "克蘿小姐",
        "unit_id": 127812,
        "voice": "vo_adv_1265001_055"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "也太興奮了吧。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳是有多想去蘭德索爾啊？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為因為！",
        "unit_id": 126411,
        "voice": "vo_adv_1265001_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n之前去蘭德索爾的時候，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我就有在想了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n下次一定要和萊拉耶爾殿下一起來！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以我現在才會這麼興奮！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "克蘿茜小姐。",
        "unit_id": 127712,
        "voice": "vo_adv_1265001_057"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這次可不是單純去觀光而已哦？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳可要好好保護萊拉耶爾殿下，知道嗎？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我知道的～！",
        "unit_id": 126411,
        "voice": "vo_adv_1265001_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我可是",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n護衛的事情交給我就沒問題！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真、",
        "unit_id": 127712,
        "voice": "vo_adv_1265001_059"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真的沒問題嗎……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n妳可別在其他世界迷路了哦？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊，",
        "unit_id": 127812,
        "voice": "vo_adv_1265001_060"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳操心過頭了。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "如果妳那麼擔心，不如一起跟去如何？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦咦！？",
        "unit_id": 127712,
        "voice": "vo_adv_1265001_061"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這個的話，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我還沒有做好心理準備……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "哈哈，",
        "unit_id": 193511,
        "voice": "vo_adv_1265001_062"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "沒事啦。",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "這次不僅有小子在，",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "佩可小妹也在對面等著。",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n不會有問題的。",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沃爾加諾。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_063"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們不在的這段期間，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "國家就交給你守護了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "遵命！",
        "unit_id": 193511,
        "voice": "vo_adv_1265001_064"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "請交給臣吧，公主殿下！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "……開玩笑的啦。",
        "unit_id": 193511,
        "voice": "vo_adv_1265001_065"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n放心，",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "我們這裡會照常工作的，",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n請您好好去放鬆一下吧。",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝你。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_066"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那麼就交給各位了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……啊。",
        "unit_id": 127812,
        "voice": "vo_adv_1265001_067"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n現在的天空，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好像比較有那種感覺了。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n是跟對面連在一起了嗎？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒錯沒錯！",
        "unit_id": 126411,
        "voice": "vo_adv_1265001_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n萊拉耶爾殿下，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "您準備好了嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_069"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我隨時都能出發。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_070"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n琳德，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "烏爾姆，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沃爾加諾。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我出發了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "祝您一路順風。",
        "unit_id": 1,
        "voice": "vo_adv_1265001_071"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_072"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們踏上旅程吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "朝著未曾探訪的異國之地──",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_073"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n阿斯特賴亞大陸啟程。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……就這樣。",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_074"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們一行人",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "離開了「吉歐‧提格尼亞」。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "對我而言，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_075"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這是第一次的旅行……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "或許該說是第一次的冒險。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "冒險……",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_076"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n對於在城堡裡生活至今的我而言，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那是個極為陌生的詞彙。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……啊啊，",
        "unit_id": 126511,
        "voice": "vo_adv_1265001_077"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "怎麼辦呢？",
        "unit_id": 126511
    },
    {
