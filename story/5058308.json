[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "追尋神祕美食的旅程，",
        "unit_id": 105911,
        "voice": "vo_adv_5058308_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "終於也漸入佳境了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個魔物……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令在下感受到前所未見的魄力。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的確如此呢。",
        "unit_id": 105811,
        "voice": "vo_adv_5058308_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠似乎和過去那些魔物截然不同。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可有絲毫疏忽……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得魔物料理什麼的都無所謂啦，",
        "unit_id": 106011,
        "voice": "vo_adv_5058308_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過與這麼強的魔物戰鬥，就只為了吃掉人家，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想想還真是很奇怪呢，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_5058308_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可不是只為了",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃掉而已唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_5058308_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……大家一起開心的坐在餐桌前吃飯。",
        "unit_id": 105911,
        "voice": "vo_adv_5058308_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這也是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的目的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、",
        "unit_id": 105911,
        "voice": "vo_adv_5058308_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們四人坐在一起吃飯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "臉上洋溢著笑容，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這對在下來說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是無可取代的時光。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是對「我們」來說",
        "unit_id": 105811,
        "voice": "vo_adv_5058308_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唷☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是的，",
        "unit_id": 105911,
        "voice": "vo_adv_5058308_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正是如此呢……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哼，",
        "unit_id": 106011,
        "voice": "vo_adv_5058308_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然如此，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就趕快擊敗這傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好好享受那什麼無可取代的時光吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_5058308_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "動手囉☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_5058308_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起上吧♪",
        "unit_id": 105911
    }
]