    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天午後，{player}和可可蘿兩人\n來到了蘭德索爾外。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天能陪在下出來散步",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是謝謝您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常因為有",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物出沒，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以也不太會想要走這麼遠……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過不知為何，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺身體狀況",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特別好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下已經記不起來了，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過似乎從上次做夢的時候開始……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就感覺到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "體內有一股強大的力量在流動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您可能會覺得在下很孩子氣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下現在感覺自己好像能跳著走一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身體很輕盈……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像這樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跳，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跳，跳――",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有台衝很快的",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "馬車……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然從旁邊經過。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下竟疏於注意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "犯了這種錯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您要是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再不放開在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被您這麼用力地抱緊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身體會受傷的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……怎麼回事。",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身體似乎",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得很燙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和主人睡在同一張床上的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不曾有過這種感覺啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是因為身體狀況好，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺也比以往更加敏銳了嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n連心跳速度",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也比平常",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能更清楚地感覺到加快……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很抱歉",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您擔心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下沒事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像這樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深呼吸就好……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吸～",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吐～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n吸～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吐～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心跳速度就恢復正常了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那我們走吧，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了避免發生剛剛那樣的情況，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "握住在下的手……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是怎麼回事。",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛剛",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "碰到主人的手的瞬間，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n心跳速度又加快了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之前明明也",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牽過好幾次手，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼會這樣……？　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是因為……",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "緊張",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的關係嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對主人……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次只不過是被主人拉了一下手，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n心跳卻比",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才更加劇烈……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是怎麼了……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說太危險了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以就這樣牽著手走路",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下沒事！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是小孩子了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一不小心，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就出聲拒絕了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人就要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走掉了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛剛身體明明還熱得發燙，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在卻",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又突然冷卻……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是感到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寂寞嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那、",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想還是……",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您牽著",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的手走吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只牽一隻手指",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也沒關係……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您……",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思了……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心跳得這麼快，",
        "unit_id": 105913,
        "voice": "vo_adv_1059012_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底是為什麼……？",
        "unit_id": 105913
    },
    {
