    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "表演結束後的千歌、與{player}兩人，正沉浸在落幕後的餘韻。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "手還是會發抖。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過這應該是，",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感受到觀眾的熱情……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以喜悅地顫抖了，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒事的喔。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個。",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "表演，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "覺得如何……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很棒的表演，",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是嗎。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "竟然那麼的誇獎我，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然高興，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卻覺得有點害羞呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天的表演，",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比起以往達成目標有更高的成就感而很滿足呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就像能清楚感受到，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自己有所成長的感覺吧……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 108411,
        "voice": "vo_adv_1084004_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　怎麼了呢，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼感覺十分耀眼……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！？",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "歡迎光臨――",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊、{player}！",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　來得正好啊。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n其實有件事情要拜託你……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能看一下，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這張傳單嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是有關於聖歌隊的演唱會，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果可以的話，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聖誕節",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要不要去看這場表演？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是常常在海外公演",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很有名的聖歌隊！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n表演的節目也是跨及現代風，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到流行文化的內容……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在已經期待到快等不及了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "行程沒問題嗎？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　雖然這麼地期待，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但是為什麼",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到目前為止，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都沒去看過嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那是……",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想只要你到了會場",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就會明白了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節當天――"
    },
    {
        "type": "still",
        "still": "108400401"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有看到非常多的情侶吧？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這就是，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都沒來看的原因。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟是這種節日，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n受到情侶們的喜愛",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是沒辦法……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　這種氣氛之中一個人待著",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺會難以忍受的、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我一直都不敢來……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然現在才在問、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會不會造成你的困擾？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒有那回事、",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n反而還很期待是嗎……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣我就放心了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我一開始還在猶豫要不要邀請你、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我很想跟{player}一起來……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　反而，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "選自己當同伴真的好嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那是當然的了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　我對、{player}――",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊！？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　表演好像開始了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什、",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你不要在意我剛剛想說什麼。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比起那個、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是先享受演唱會吧。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是好棒的表演呢。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真是滲透人心的歌聲呢……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "加上聖誕節的燈光，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是相當美麗……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就好像、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在夢中一樣呢。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　該不會是想成為歌手、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總有一天我也想要站上那種舞台。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是……",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當我開始唱歌、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就沒辦法待在{player}的身邊了，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n今天還是當觀眾就好。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天呢，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是我唱歌的日子，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是跟{player}",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n一起享受音樂的日子才對……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的，",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常謝謝你。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n能陪我度過這段美好的時光，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我很高興。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聖誕節快樂……♪",
        "unit_id": 104232,
        "voice": "vo_adv_1084004_028"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1084004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在你看到的，是像夢一樣的東西。",
        "unit_id": 190011,
        "voice": "vo_adv_1084004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想醒來後就會馬上忘記了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n目前就別太在意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "邀請你去情侶間熱門的演唱會，",
        "unit_id": 190011,
        "voice": "vo_adv_1084004_031"
    },
    {
        "type": "dialogue",
