[
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在可可蘿進行完儀式後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人為了療傷兼觀光，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便待在可可蘿的故鄉度過了數日。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿咻，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿咻……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把這個如此這般……",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是不是吵醒您了呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正為了主人",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "製作新鮮的果汁，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這些都是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天早上才採回來的新鮮水果。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "製造了些許噪音呢……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有使用了充滿香氣的水果、",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在堅硬果皮中",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "富含水分的水果等，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n混合了數種水果來製作。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是在研磨充滿營養的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "柔軟果皮。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟若不細心處理，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就有可能會卡在喉嚨中。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不能讓主人",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "受到那種痛苦，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以在下必須",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仔仔細細地處理。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就快要完成了，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請主人再稍等一下。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嘿。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喝！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣應該就足夠了吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接下來",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是充分攪拌……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完成了。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這就是可可蘿特製，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈村的綜合果汁。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來，請。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您慢慢享用。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來有符合您的胃口，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也感到非常開心。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能看到主人用爽朗的笑容說出感想……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的齒縫",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卡了一小片果皮在那。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否因為在下將果皮研磨得細小的關係呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請將您那美妙的笑容",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "轉向在下這邊。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下用小指",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來代替牙籤，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "替您取下果皮吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "戳戳。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……好的，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經取下來了。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的笑容越來越美妙了呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就在下看來，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那如同才剛升起的太陽一樣耀眼。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然已經成功完成儀式了……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了實際感受到這點，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在村子裡的這段時間，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想繼續穿著它。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "穿著這套服裝，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就不可思議地能提起幹勁……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是說讓在下能夠更集中精神。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人現在",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來到在下的故鄉，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n身為這個村子的代表，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下必須更鄭重地接待您才行。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若您願意賞臉……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天是否能讓在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶您參觀村子呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與在下我們平常居住的蘭德索爾，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是冒險過的無數危險場所相比，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並沒有",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼特別稀有的東西，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能多少",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會讓主人感到無聊。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然是難得的機會，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n務必還請主人賞臉，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看看在下出生長大的故鄉。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於這次",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶給了主人許許多多的麻煩，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也為了謝罪……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您意下如何呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常謝謝您。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請放心交給在下導覽吧。",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡是",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引自山中湧泉的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小河。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n生活所需用水",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "取自於這條小河。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才主人享用的",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "水果與蔬菜等，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也都是使用這條小河的水所栽種的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是這乾淨澄澈的水，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "孕育了那些美味的農作物。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而這裡",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是村裡的孩子們良好的遊戲場所。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在年幼的時候，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經常來這條小河戲水。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在夏季的炎熱暑日將腳泡在河中，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就能感到沁入心脾的清涼，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常舒適。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能像這樣與主人",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起走在村子裡，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真令人料想不到。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然是在下提出",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要帶主人參觀村子的……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但就像是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己年幼時的回憶",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都赤裸裸地呈現在主人眼前，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人不禁",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有些許害羞。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也曾心想有朝一日，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想如現在這樣與主人一同回來故鄉，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這確實",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是事實……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許還沒",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做好心理準備……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咳。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就前往下一處吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡是",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "位於村子中心的廣場。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下在村子的那些時日，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經常在這裡",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與年紀相近的小孩們一起玩耍，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接受大人們驅使精靈的特訓。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也並非是相約在此集合，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大家",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都是自然地聚集於此，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "談笑風生、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和樂融融。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要閉上眼，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便能看見那副光景",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有如昨日所發生的事一樣，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼鮮明──",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "啊，",
        "unit_id": 5311,
        "voice": "vo_adv_1155001_035"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是可可蘿姐姐！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哇～！",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_036"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "果然是跑到這裡來了！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們找妳好久了！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦……！",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都過得好嗎？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女們",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1155001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這兩位",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下居住於村子時，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n經常一起遊玩的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "年幼精靈術士同胞。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "主人……？",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_040"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "這個人",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "就是那個主人嗎？",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可可蘿姐姐說的",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "那個重要之人！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是如此。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是的，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所說的重要之人，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非那方面的意思。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n僅是指",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下的職責而言，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是非常重要的……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "姐姐怎麼了？",
        "unit_id": 5311,
        "voice": "vo_adv_1155001_043"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妳的臉",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好紅喔。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是有哪裡還不舒服嗎？",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連主人都……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅是剛好變紅了而已，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下的身體狀況非常良好。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不必擔心。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "啊哈哈，",
        "unit_id": 5311,
        "voice": "vo_adv_1155001_045"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "你們的感情",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "真的很好呢！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……問妳喔，",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_046"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可可蘿姐姐。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我是不是，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "總有一天也能遇見重要之人呢？",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然這麼問是怎麼了嗎？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "就是呀，",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_048"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們兩個人，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n都還沒辦法像可可蘿姐姐一樣",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "聽到愛梅斯大人的聲音，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "父母",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "也只是普通的精靈族而已。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "羨慕獲得職責的",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_049"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可可蘿姐姐",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "什麼的，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我至今雖然從沒這麼想過……",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可是，",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_050"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我現在也想要變得能夠聽到愛梅斯大人的聲音，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n也想要",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "能夠遇到像可可蘿姐姐的主人，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "那樣的重要之人……",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是如此，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是肯定能與其相遇的，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下如此認為。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "真的嗎！？",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下之所以會與主人相遇，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為愛梅斯大人的指示沒錯。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在起初相遇時，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下身為主人的隨從，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅僅",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是為了完成職責",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而照顧主人。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在與主人共同度過的時日中，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下漸漸萌生了更進一步的感情。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非僅是得陪伴在身旁的責任感，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是對在下自己而言，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人成了不可或缺的人。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……沒錯，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實是十分重要的人。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然會產生這種心境轉化，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是愛梅斯大人下達指示時",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從未想像過的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算現在沒有任何特別的力量……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不論契機",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼事物……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法預料的美好相遇，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肯定，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會隨著風兒突然來到您面前的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論是什麼人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要一同度過時間、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "創造回憶，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真正的感情就會萌芽……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這麼認為的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯……",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_064"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "雖然我有點聽不太懂，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "但我好像明白",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可可蘿姐姐的心情了！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總有一天",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肯定能徹底理解的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位說在找在下，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該還有什麼",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其他要事才對？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "對喔！",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_067"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我們想要請姐姐跟以前一樣指導我們，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n所以在找妳！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哪，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "姐姐願意吧？",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "對對！",
        "unit_id": 5311,
        "voice": "vo_adv_1155001_068"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我們想要請變強的姐姐教我們，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "才跑來這個廣場的！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就覺得妳一定會來這邊！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有問題。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就如同過去那樣，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和風一起嬉戲吧。",
        "unit_id": 115511
    },
    {
        "type": "still",
        "still": "115500101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──風之精靈啊，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請起身而舞吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈開心到像輕飄鬆軟的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絨毛一樣呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個村子的風，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然非常特別。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "拜託了，",
        "unit_id": 5411,
        "voice": "vo_adv_1155001_072"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "精靈！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我也",
        "unit_id": 5311,
        "voice": "vo_adv_1155001_073"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不會輸的！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "過來吧，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "精靈！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好一陣子不見，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "你們都變得",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很擅長跟精靈對話了呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "厲害到",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_075"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經沒有東西可以教你們，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n你們已經是獨當一面的精靈術士了。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "哎呀哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1155001_076"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真是令人懷念的光景呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n是在請可可蘿指導嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大人",
        "words": "可可蘿在出村子前，",
        "unit_id": 1,
        "voice": "vo_adv_1155001_077"
    },
    {
        "type": "dialogue",
        "name": "大人",
        "words": "\n大家總是在這裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大人",
        "words": "和精靈玩到日落呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_078"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位……！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好久不見了。",
        "unit_id": 115511
    },
    {
        "type": "still",
        "still": "115500102"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這邊的各位",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下年幼時",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "指導在下讀書、",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n料理等事物的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位村民們。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要說",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位等同於在下的父母",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不為過。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下與各位共同度過了許多時間。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是如此。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「這個村子",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟蘭德索爾相比",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並沒有什麼特色」。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然稍早",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下曾這麼說了，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但那是在下的錯誤發言。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居住此地的人們，",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_083"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其溫情正是這個村子最自傲之物，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n人與人之間的互動景象，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正是在下所愛的故鄉風景。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今從未改變的",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_084"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這道風景，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能夠在這次",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也讓主人見到，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下非常開心。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡",
        "unit_id": 115511,
        "voice": "vo_adv_1155001_085"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是在下出生長大的土地……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是由溫暖的心所培育的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿被故鄉的同胞們圍繞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並露出懷念的微笑。"
    },
    {
        "type": "still",
        "still": "end"
    }
]