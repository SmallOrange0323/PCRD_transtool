[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}送完了貨，走在街上準備回家。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喂～！",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喂～這邊啦！",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥～！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然是老哥的啦！",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下～！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥也要去蘭德索爾嗎？",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛好我也要去，一起走吧！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天大家都出門了",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以牧場休息一天～",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在精靈之森享受姊妹的兩人時光。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "提著伴手禮到咲戀小姐家過夜去了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴也休假",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "回老家了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "然後啊，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛好今天",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在蘭德索爾",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有一場公會管理協會主辦的",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "初學者戰鬥講習，\n我打算去聽看看的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為最近牧場四周變得好危險啊～",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n動不動就會發現魔物的腳印，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我天天都提心吊膽，很怕動物們會被攻擊啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以，為了守護牧場，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我一定要變強！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……老實說，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我是很不想戰鬥啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n比起戰鬥技術，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還比較想加強搞笑能力",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "和酪農知識啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "再怎麼說我也是公會長。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我有責任要保護大家的安全的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了在緊要關頭",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能作為劍與盾而戰，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我必須得先做好準備啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有備無患就是開心！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈哈！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我使出渾身解數的搞笑竟然被無視的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道對老哥來說太難懂了？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且！",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在是關心穿著的時候嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n明明有個非常適合當作閒聊話題的哏",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就在你的眼前耶！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "光是穿上了這套衣服就覺得自己變強了呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我終於懂為什麼搞笑藝人和演員",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會對服裝這麼講究了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但我希望你可以放在心裡想就好不要講出來的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我這空蕩蕩的胸口",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也寫不了幾個大字啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "胸部不大所以胸無大字！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈哈！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得講得不錯，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼講完會這麼空虛的啦……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "再聊下去沒完沒了，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "趕快往鎮上前進吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我要直接去聽講習，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你要去哪？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真、",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的嗎！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我啊，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然嘴上講得很厲害，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但自己一個人去還是有點怕怕的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果老哥也一起的話，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就沒什麼好擔心的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你、",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你在說什麼啊！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種話要向",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你真正重視的人說吧……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的意思應該是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要保護我不受到物理性的攻擊，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n並非帶有什麼羅曼蒂克的含意。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也很",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "令人開心了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我們出發吧老哥──",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呃啊！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很危險耶！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不要突然抓住別人的領子啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的耶。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在變強之前就遇上這種事，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n運氣也太差了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是說，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這隻魔物也太悠閒了吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這不是魔物，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是牛的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看這健壯的體格和",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "漂亮的毛色。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有人養的牛的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "從農場逃出來的嗎？",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是放牧的時候走失了？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好可憐……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……老哥，",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不好意思，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "講習的事就當作我沒說。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我沒辦法",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "放著這孩子不管，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我要去找他的主人。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥……",
        "unit_id": 112811,
        "voice": "vo_adv_1128001_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在我需要你的時候，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你總是在我身邊呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
