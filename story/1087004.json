[
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和日和一同度過了忙碌的一日，\n完全累壞的兩人，正在公會小屋裡休息中。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊～",
        "unit_id": 108711,
        "voice": "vo_adv_1087004_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "終於能夠放鬆了～……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算是我也累壞了呢～",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且天也完全都黑了……",
        "unit_id": 108711,
        "voice": "vo_adv_1087004_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108711,
        "voice": "vo_adv_1087004_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像有點亮耶。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！？",
        "unit_id": 108711,
        "voice": "vo_adv_1087004_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是什麼……！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n明明就很刺眼，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "卻越來越、",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想睡覺……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "了呢……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出門新年參拜的{player}，\n正望著自己在神社抽到的籤詩時，籤卻突然被風給吹走了。"
    },
    {
        "type": "still",
        "still": "108700401"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和服上好像勾到了什麼……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是籤呢。",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是被誰丟掉的嗎？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……唔哇。",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "第一次看到凶的籤耶。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是怎樣的人抽到的呢……？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我看看，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「願望，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "無法實現」。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「等待的人，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不會出現」……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100132
    },
    {
        "type": "still",
        "still": "108700402"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊～！",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長～！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你說籤的話，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正好剛剛撿到了就是……",
        "unit_id": 100132
    },
    {
        "type": "still",
        "still": "108700402"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長！",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "新年快樂！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶吶，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我剛剛在這，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "撿到了一張凶的籤……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是學長你抽到的籤嗎！？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那這個凶，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是新年參拜時被人抽到剛出爐還熱騰騰的呢……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來是這樣呀……",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對不起。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我擅自就讀了它……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是這個籤，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要綁在神社這裡的話，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定就沒事的！",
        "unit_id": 100132
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "108700403"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看你看，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我可是抽到了大吉唷～！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大吉呀，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家都說帶在身上就會有好事發生唷！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿～♪",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很棒吧～！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然在正月就能遇到學長，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還真的馬上就有作用了呢！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也是，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "直到剛剛還和學校的朋友一起來初次參拜的呢。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家一起穿著新年和服來參拜，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "超級開心的呢～！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一起吃了攤販的甜品，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家還一起拍了照……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且呀……",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_017"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "108700404"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……吶，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……就當作你運氣不太好，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n稍微一下下就好，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望你聽我說些話……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以嗎？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你願意聽我說呢……",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真溫柔呢，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那個呢，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在班上有個感情很好的朋友，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她有暗戀的人呢。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n然後呢，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望妳能替我加油",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──她這麼和我說了……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是我社團的朋友中，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也有一個同樣暗戀那個人的女孩子。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我呀，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也一樣被那孩子說了，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望妳能替我加油",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──這樣的話了。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那兩個女生喜歡的那個男生，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天雖然也有一起來，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但氣氛卻有點緊張兮兮的，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想著必須得要做些什麼，結果累壞了呀……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為兩人都是我的朋友，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到底是要只替一個人加油，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n又還是說出兩邊我都不能加油比較好呢，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這讓我一直很煩惱。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "煩惱到最後，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就變得完全不知道",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該怎麼辦才好了。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n學長。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天的參拜呢，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明抽到大吉，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我卻完全開心不起來呀……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管哪邊！？",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但如果這樣做，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不就會有一個人會因為這樣受傷了嗎……？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說、",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說的也是呢……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也可能兩個人都主動出擊，結果都被甩了也說不定……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣的話我到底該要怎麼做才對呢……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要我什麼也不做，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我果然還是辦不到呀……",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長……",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道就沒有什麼事情，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是我能做的嗎？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你是指什麼意思呢……？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有不夠……",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "光是學長你願意聽我說這些話，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就覺得幫大忙了。",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你呢，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長。",
