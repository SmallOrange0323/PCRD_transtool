        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這到底是，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼一回事呢……？",
