        "voice": "vo_adv_1087004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是除了你之外誰也辦不到的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "記好囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
