        "voice": "vo_adv_1087004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也就只有你了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這可是件挺重大的責任唷？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1087004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然你都那樣跟她講了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼在日和她受到了傷害時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你可得要好好地陪伴到她到最後一刻唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只有這件事才真的，",
