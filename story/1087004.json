        "voice": "vo_adv_1087004_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最近呀，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我只要在學長的身邊，",
