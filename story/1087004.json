    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有沒有做一場好夢呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "日和她最後似乎恢復活力了呢，真是太好了。",
        "unit_id": 190011,
        "voice": "vo_adv_1087004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子也還在長大的過程中呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1087004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以就算放著她不管，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n自然也會慢慢長大，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "漸漸產生變化的唷。",
        "unit_id": 190011
    },
    {
