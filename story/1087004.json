        "voice": "vo_adv_1087004_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算只是像這樣陪在身邊而已，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也是能夠成為想加油的人的助力呢！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是能夠幫助到她們的！",
        "unit_id": 100132
    },
