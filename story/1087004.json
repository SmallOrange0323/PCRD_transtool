    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我已經沒事了！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長你的這個籤，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是要去綁起來的對吧？",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果不快點去的話，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是會變得越來越不幸的唷～？",
