    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……吶、學長。",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當我，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想要替自己加油的時候，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n又該怎麼辦才好呢……？",
