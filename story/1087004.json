    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你，學長！",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我啊，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明白了！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果她們遇上了什麼事情的時候，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也想陪在她們的身邊！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就像今天學長你願意這樣陪著我一樣，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也會聽她們說說話的！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不是只有鼓勵她們，",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又或是推人一把，",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才是真的有幫助到了誰呢！",
        "unit_id": 100132
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿～",
        "unit_id": 100132,
        "voice": "vo_adv_1087004_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你唷，",
