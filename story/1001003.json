[
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與日和，\n在一起完成工作後，正準備返回城鎮。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～……！好累唷！可以順利完成實在太好了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "多虧了騎士先生的幫助呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因此有了空閒時間，真想快點回家好好休息呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，可以看見索爾之塔了呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "快到城鎮了唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這麼說來，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n和騎士先生初次相遇時，就是在索爾之塔下面呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為總是無法忘記曾在夢中見面……",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等到一回神，我們三人都已在塔下了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前往索爾之塔塔頂許願的話就能如願的傳言，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一開始還以為是童話故事呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過呀，自從看見夢境之後就不再如此了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然不知道原因，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我也開始相信那些故事都是真的呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我相信，優衣和怜應該也是同一個想法的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以決定要認真的努力一次看看。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了達成想實現的願望……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的願望……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我希望創造大家總是笑容滿面地生活的世界。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這就是我的願望！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然也包含優衣和怜和騎士先生在內……",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望世界上的人都能展露笑容！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我嗎……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……應該吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（……咦？為什麼我剛剛沒說「會」呢……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真奇怪……）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……原來如此。我說了希望「大家」能展露笑容。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，「大家」中不包含我自己……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我明白了……騎士先生，是在替我擔心呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……即便如此，這就是我的夢想！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算我不能展露笑容，只要大家能展露笑容就沒問題了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的笑容……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這是指說騎士先生會設法讓我展露笑容是嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……原來如此。",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要是騎士先生有想這麼做的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就安心了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n謝謝騎士先生呢～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱一下！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "體格意外的健壯呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哎呀，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真不好意思！喘不過氣來嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為我太開心了，不小心就……嘻嘻。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才呀，騎士先生說會保護我，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我非常的高興呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有騎士先生在我身邊的話，",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n單單如此，我就覺得我就能隨時隨地都展露笑容唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（……我為什麼會有這樣的想法呢？）",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（……！怎、怎麼回事？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n為什麼看著騎士先生，我胸口深處就一陣糾結……）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（雖然心頭暖洋洋卻感到難受……",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我並不討厭這種感覺……）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是怎麼了呢，現在的這種心情……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001003_024"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "喃喃自語的日和，\n思考著這個心情的背後真相，\n結果在當天還是無法得出一個答案。"
    }
]