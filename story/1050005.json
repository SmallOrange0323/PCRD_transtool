[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美咲坐在一間露天咖啡座中，看起來一臉苦惱的樣子。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不對……",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這裡應該",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是這樣寫……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "用那個解……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我在寫作業、",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "寫作業啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我一直都是在這間露天咖啡座寫作業的。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "相當優雅吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我稍微被一道難題給困住了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你肯定",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很有空吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了不讓很閒的你沒事幹，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這道題目就交給你來解！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說不能作弊！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才不是呢，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n其實我是要自己解這道題的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我是看你好像沒事做，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以才勉強讓你解的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你居然不懂我的用心良苦，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來你也還只是個小孩子嘛。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比起那個，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你快來解題目。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在你解題的這段期間，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就喝杯焦糖蜂蜜咖啡歐蕾，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n優雅地等你完成♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "題目也差不多該解完了――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼回事呀！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的解題速度",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是慢到令人訝異的程度！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "到底為什麼！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你應該",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "年紀比我大沒錯吧！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊……",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣啊。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總覺得我好像",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對你做了不好的事耶。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "能早點恢復記憶就好了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所、",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以說！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不是說了這不是作弊了嘛！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其實",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你只是因為失去記憶，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以才解不了題目嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這樣的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你就早說嘛！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來……",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖說你是喪失記憶，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n連這種程度的計算都算不出來，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也是蠻不方便的吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是拿你沒辦法。",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖然我只能教你簡單的算術，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過就由我來幫你吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我啊～",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼會這麼有大人成熟的風範呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要感謝我",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一輩子喔？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼，",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你聽好了？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "首先是這裡的公式，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個呢――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃！",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n結果，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我還是靠自己的力量",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "完成全部的作業了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你該不會……",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "從一開始就是這麼打算的吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105011,
        "voice": "vo_adv_1050005_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "大人真的",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好狡猾！！",
        "unit_id": 105011
    }
]