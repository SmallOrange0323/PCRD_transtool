[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}等人\n正在吃拉比林斯達請的可麗餅時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面——"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……豪紳議長？",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關於今天白天送上來的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些下個月的國家預算統整文件。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是的。",
        "unit_id": 191411,
        "voice": "vo_adv_2103008_001"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n儘管資料量稍微有些繁多，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n然而請您在後天以前過目，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "並押上陛下您的印璽……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在第37頁的第五行、",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "54頁的第八行、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有91頁的第三行",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟121頁的第二行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這些地方的數字有矛盾呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……！？",
        "unit_id": 191411,
        "voice": "vo_adv_2103008_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其他還有",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡跟這裡。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡也是。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不好意思，可能得請你",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再重新提交一次文件了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……現在這樣的數據，就算被說私吞也不奇怪了唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有就是，",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於另一件臨時法案，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "審議中的條目，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有對特定部分公會政治分贓的嫌疑。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該案也請你再重新提交。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔……",
        "unit_id": 191411,
        "voice": "vo_adv_2103008_006"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "下臣明白了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n下臣這就",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "立刻去處理此類紕漏。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "然而話說回來……",
        "unit_id": 191411,
        "voice": "vo_adv_2103008_007"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n今日您可還真機靈……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "真不愧是您的慧眼呢，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陛下。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n若平日，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您也能有如此表現那就更好了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "……哎呀。",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "\n看我做了什麼好事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "稍微有些表現過頭了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "討厭啦～豪紳議長，",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "這是偶然的啦～偶然♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "比起這些事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "我因為動頭思考所以肚子餓了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "\n若您能請廚房幫我多準備一點宵夜就幫大忙囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……下臣遵命。",
        "unit_id": 191411,
        "voice": "vo_adv_2103008_010"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n然而請別吃過量，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "以防您的玉體",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "出了什麼閃失啊。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "……\n……",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可？",
        "words": "呼……",
        "unit_id": 105812,
        "voice": "vo_adv_2103008_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "終於能夠一個人獨處了……",
        "unit_id": 107011,
        "voice": "vo_adv_2103008_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點程度的政務……",
        "unit_id": 107011,
        "voice": "vo_adv_2103008_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對我來說簡直易如反掌。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是既然決定要擔任替身，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼就得配合「當今陛下」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的能力值來演繹才行了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……話又說回來。",
        "unit_id": 107011,
        "voice": "vo_adv_2103008_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n起初是為了",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做個人情給貪吃佩可，才開始當她的替身。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過演繹掌權者……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比想像中的還要舒適，倒也令人困擾。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這張王座……",
        "unit_id": 107011,
        "voice": "vo_adv_2103008_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n大概也因為有真那的堅持，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "坐起來特別令人感到愉悅。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n呵呵……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在我真心地",
        "unit_id": 107011,
        "voice": "vo_adv_2103008_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想要奪走這張王座之前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n希望您能夠解決事態呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「陛下」？　",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……\n……",
        "unit_id": 411,
        "voice": "vo_adv_2103008_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊啊啊好煩啊！",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不管怎麼寫，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都完全沒有要結束的樣子啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "豪紳議長也真是強人所難呢。",
        "unit_id": 411,
        "voice": "vo_adv_2103008_021"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n竟然要我們在明早前，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "將這麼厚一疊的預算資料",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "全部修正……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可不覺得",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個看起來傻呼呼的公主殿下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n有辦法將這些會計做帳的伎倆全都看穿……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……或許是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她身邊有誰傳授了她一些知識也說不定。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話又說回來！　",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "把資料彙整工作全丟包給民間，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n甚至還指示說要在預算上偷雞摸狗的——",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不就是那個王八垃圾議長嗎……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 411,
        "voice": "vo_adv_2103008_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那位穢物議長啦……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……那麼。",
        "unit_id": 411,
        "voice": "vo_adv_2103008_026"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我差不多",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要準備下班了呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n畢竟，早就超過正常規定的勤務時間不少了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等，",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳給我稍等一會兒！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們【里士滿工商會】的規定勤務時間，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是和未蓋章的契約書一樣沒有實際效用喔？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……還是說。",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳就連區區地熬夜一天的超時勤務都撐不過，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "甚至連我這公會長的職務命令都聽不進耳裡的話……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說我是不是該",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "把妳給開除了比較好呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "唔呣唔呣……",
        "unit_id": 411,
        "voice": "vo_adv_2103008_029"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真困擾呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n若您真這麼做了……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那這些文件的修正作業，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔小姐您可能就得一個人完成了呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……咕唔～！　",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我知道了啦，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我知道了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做為臨時獎金，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "特別加班費200%！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這樣的話妳多少會有些幹勁想留下來了吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "來吧來吧，克蕾琪塔小姐，",
        "unit_id": 411,
        "voice": "vo_adv_2103008_031"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您還杵在那做些什麼呢？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "讓我們齊心協力，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一同繼續修正這些文件吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n讓我們在日出之前，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "做出完美的資料！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉，",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是夠了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我們的員工，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼都淨是這副德性……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀？",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這份補助金的申請書……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我沒見過呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明明有相當的事業規模，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "申請的額度卻不多……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_2103008_034"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那份呀。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好像是一間新公會所提出的申請。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n是我們當初把資料做完後才送來的，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "想說反正都要進行修正，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就順便處理一下。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼嗯。",
        "unit_id": 118011,
        "voice": "vo_adv_2103008_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……【銀汞貿易】、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗎……？",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……啊呣。",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_036"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n啊呣，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "唔呣……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呼……",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_037"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "果然，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "說到料理還是我侍從所製作的才值得享用。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n在不衛生的廚房，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "用粗糙的食材所做出的料理，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n簡直可以說是對我這舌頭的一種冒犯了……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哈咕，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊呣……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你在那給我大吃特吃什麼啊大豬頭——！！！",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_038"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵～",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_039"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "卡里莎，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "你如此吼叫",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "可得小心血液都衝上腦門唷？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你才是要給腦袋的血都積到胃裡去了吧！",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_040"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "再說，阿澤爾德！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我不是叫你別給我扯後腿了嗎！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哎呀這可真是，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_041"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "絲毫沒有反駁的餘地了呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n豈料，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "大陸最大都市的飲食文化竟僅此程度……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "誠然",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是我的失算呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "只不過，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_042"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如此一來也無任何可惜之處了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n那整座城鎮，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我也能",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "毫無懸念地將其廢棄處分了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……真是的。",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_043"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n現在才有幹勁也太晚了吧。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不過嘛，",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_044"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是叫「即時再生」來著？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這次倒是知道你這豬頭的力量是派得上用場的了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "先不論你的食慾，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這一點倒是能給你點認同。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "能受到您的誇獎，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_045"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是本人畢生的榮幸。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嗯嗯……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "能確實地認同他人優點，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "不為缺點所蒙蔽……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n這可是相當崇高的美德唷，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "卡里莎。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "吵死人了啦！",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_046"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n比起這種事，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我要馬上再去把蘭德索爾掀翻！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "再這樣下去，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我會被他們以為是",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "只會出一張嘴的小癟三啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂！阿澤爾德，",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_047"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你也給我趕快準備好啊！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我明白了。",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_048"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……那麼，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "請你稍待我一會兒。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊呣，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊呣啊呣。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊？",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_049"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你怎麼又給我開始吃起來了啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……喂，你這豬頭。",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_050"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你該不會要跟我說你光是來回跑這樣短短一趟，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n就把魔力全用光了吧？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "怎麼會呢。",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_051"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "但話雖如此……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n為了給予我那被玷汙的舌頭些許的慰藉，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "不享用個百倍來填補缺憾不行啊！　",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "哈呣，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嚼嚼嚼……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "給我吃快點啦，你這個豬頭！！！",
        "unit_id": 191611,
        "voice": "vo_adv_2103008_052"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嚼嚼。",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_053"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊呣……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嗯。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這個法式巧克力蛋糕入口即化般的口感與美味，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n可謂美妙至極啊……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "阿澤爾德。",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_054"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n辛苦了。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵呵。",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_055"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這點小事何足掛齒。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "關照孩子，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "可說是年長者的義務也不為過。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n……對卡里莎來說，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "要挑戰「迷宮女王」為時尚早了點。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "話說儘管有些晚了……",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_056"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n贊恩，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "您是否有意與我一同用餐呢？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n不需要",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "和我客氣喔。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "那，",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_057"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "就吃一些。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "話說回來……",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_058"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "情況如何？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是的，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_059"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "毫無懸念。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n對蘭德索爾宮殿內部構造",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "所進行的觀測幾近完善了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n被幽閉起來的霸瞳皇帝的所在位置，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "可說是",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "再分明也不過了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "真厲害，",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_060"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "阿澤爾德。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……只不過，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_061"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n在宮殿的週遭，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "似乎被施以了某種妨礙移轉魔法的術式。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "暗中潛入宮中先馳得點",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這種做法，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "想必是行不通了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "對方也注意到我們了。",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_062"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n會警戒也是當然的。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "沒有在蘭德索爾全域都設下妨礙移轉的術式，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_063"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n倒也該說是僥倖。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "或許是城鎮範圍廣大，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "導致人手不足以完善防備也說不定。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "同時，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_064"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "多虧了卡里莎所提供的情報，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n又再多掌握了一名七冠",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "大致上的所在處了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n因此——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "如今，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_065"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "在該座城中的七冠共有——",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "３名。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n霸瞳皇帝。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "變貌大妃。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n加上……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……迷宮女王、",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_066"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "嗎。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "如果可以，",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_067"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "能一網打盡最好……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "欲速則不達唷，",
        "unit_id": 191911,
        "voice": "vo_adv_2103008_068"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "贊恩。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n對手是這款遊戲的創造者們。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n我們可不知曉他們是否",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "還藏有任何的一手。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……是啊。",
        "unit_id": 191711,
        "voice": "vo_adv_2103008_069"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n那麼，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我們該先奪下的",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "棋子是——",
        "unit_id": 191711
    }
]