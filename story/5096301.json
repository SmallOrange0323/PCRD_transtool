[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼沙灘上會有魔物……！",
        "unit_id": 122611,
        "voice": "vo_adv_5096301_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "必須要保護好大家才行……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在無法戰鬥的人們去避難之前，",
        "unit_id": 122411,
        "voice": "vo_adv_5096301_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們得好好加油呢！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖說牠是為了炒熱大賽的氣氛才被抓來的，",
        "unit_id": 122511,
        "voice": "vo_adv_5096301_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但牠在這裡作亂的話可就麻煩了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "趕快讓牠離開這裡吧！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯──！",
        "unit_id": 122411,
        "voice": "vo_adv_5096301_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們好不容易，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有機會拚盡全力互相競爭的……",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和……",
        "unit_id": 122511,
        "voice": "vo_adv_5096301_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳在這片大海，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "學會了和夥伴互相競爭的樂趣了呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼……等這場戰鬥結束後，",
        "unit_id": 122611,
        "voice": "vo_adv_5096301_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們再用遊戲來對決吧。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n當然是要等體力恢復之後喔。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "贊成贊成──！",
        "unit_id": 122411,
        "voice": "vo_adv_5096301_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很好！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n打起精神出發囉──！",
        "unit_id": 122411
    }
]