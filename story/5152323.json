[
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對手明明非～常強大，",
        "unit_id": 131911,
        "voice": "vo_adv_5152323_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但是我意外地不覺得會輸呢。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為在這個海邊，",
        "unit_id": 132111,
        "voice": "vo_adv_5152323_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "有跟我們一起戰鬥的夥伴們。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "打擾拉姆休息的你死期到了呢，",
        "unit_id": 109812,
        "voice": "vo_adv_5152323_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "白島鯨。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "莉雅，",
        "unit_id": 2612,
        "voice": "vo_adv_5152323_003"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "妳來發號施令吧！",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克，",
        "unit_id": 131911,
        "voice": "vo_adv_5152323_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那不是要由我來的──",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "──昴。",
        "unit_id": 131911,
        "voice": "vo_adv_5152323_005"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "拜託你了！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "雖然我也沒有做什麼事──",
        "unit_id": 2713,
        "voice": "vo_adv_5152323_006"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但是既然指名我了，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅醬！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "好啦，小子們！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "呃……這群人裡男的也太少了吧！？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "算、",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "算了！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "所有人──",
        "unit_id": 2713,
        "voice": "vo_adv_5152323_007"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "打倒牠吧！",
        "unit_id": 2713
    }
