    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "突然讓她這樣的學生插班過來的人",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n是美里老師吧？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
