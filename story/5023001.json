        "voice": "vo_adv_5023001_075"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不管。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那，那個",
