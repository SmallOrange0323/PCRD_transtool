    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒的特技",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是無論跟誰都能馬上變成好朋友啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這點程度根本不要緊～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對吧，小碧……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……縮。",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_069"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "太遲了……",
        "unit_id": 111011,
        "voice": "vo_adv_5023001_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～啊。",
