        "voice": "vo_adv_5023001_001"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "日安。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "打招呼的尖峰時段，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n四處傳來日安的聲音……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那氣場太過耀眼，眼睛都快瞎了……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看來這裡",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的不是我該來的地方……！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼辦，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼辦……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "『有我在喔好朋友號V3』也忘了帶出來……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我手上有那個……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "本來打算在特別講座時拿來用的",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n曼德拉草……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "曼德拉草",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5023001_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵……",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你好像很有精神真是太好了……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我就如你所見……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說到頭來",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這對於邊緣人的我來說",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "根本就太勉強了。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種充滿青春氣息",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "閃閃發光的地方……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對、",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n曼德拉草先生，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你能不能陪我練習呢？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "至少，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "得、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "得要能夠打招呼才行……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "日、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "日日、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "日日日日……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀啊！？",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "曼德拉草先生！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請你不要丟下我！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔……",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跑掉了……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我不管到哪裡",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "依然都是一個人……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛、",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛剛的聲音！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n原來這不是幻聽。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是{player}！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你怎麼會在這裡……！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是美里老師拜託你",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗎……？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼說起來，{player}你好像說過",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n自己正在聖德蕾莎女學院",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就讀……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太好了……",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的是太好了……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n竟然能在這種地方",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "遇見BB團的團長……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒也在喔，",
        "unit_id": 110911,
        "voice": "vo_adv_5023001_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇呀！？",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等，琪愛兒。",
        "unit_id": 110811,
        "voice": "vo_adv_5023001_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n別這樣，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "才剛見面就那麼誇張地打招呼。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳看，她被妳嚇到了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀！？",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_5023001_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳的動作真特別。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這個真有意思，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是精靈族",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "特有的呼吸法還是什麼嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個反應不曾出現在",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同是精靈族的克蘿依身上。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀！？",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔，",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔唔……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不認識的人……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有好多……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀，",
        "unit_id": 110911,
        "voice": "vo_adv_5023001_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看來是個怕生的女孩。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "{player}學長，請趕快幫我們介紹。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n她因為大量的新角色登場頭都暈了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘿，等一下。",
        "unit_id": 111011,
        "voice": "vo_adv_5023001_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "難道你要剝奪我在這個學園中，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n向插班生自我介紹",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個稀少又珍貴的機會嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不勞麻煩，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這裡就由",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們幾個自己自我介紹吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是優妮。",
        "unit_id": 111011,
        "voice": "vo_adv_5023001_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從我充滿知性的成熟風格",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該就一目了然了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我是這裡面年紀最長，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "最高年級的三年級學姐。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如果妳遇到什麼困難",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "隨時都可以來找我。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "下一位，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？　",
        "unit_id": 110811,
        "voice": "vo_adv_5023001_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊～……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳好",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "初次見面。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我是德蕾女高二年級克蘿依。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我跟妳一樣是精靈族。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請多指教。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有還有",
        "unit_id": 110911,
        "voice": "vo_adv_5023001_031"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可愛度一百分滿分的一年級",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～♪　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種打招呼的方式",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有一天一定會成為蘭德索爾全國的常識，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n所以從現在起就要盡量用喔～♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好、",
        "unit_id": 110711,
        "voice": "vo_adv_5023001_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好刺眼……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個，",
        "unit_id": 110911,
        "voice": "vo_adv_5023001_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼妳都不看向琪愛兒這邊呢……？",
