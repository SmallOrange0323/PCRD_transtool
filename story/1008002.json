[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪倒在道路的正中央……"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呼、呼……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n已、已經不行了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我的生命就到此為止了嗎……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，俗話說紅顏薄命……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這一切，都是我太可愛的錯呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？找我有什麼事嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n難道說是搭訕？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想不到倒在路邊也會被人搭訕，",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌果然是無論如何都藏不住呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，還想說是誰呢，原來是你呀。",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n怎麼了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……咦，看到我倒在這裡才過來？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣呀，你在擔心我呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你真是溫柔呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯？你想要知道為什麼我會倒在這裡？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你就是不能不在意我對吧。",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真拿你沒辦法，不論如何都要我說的話就告訴你吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "其實是……因為肚子非常餓。",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我身上沒錢，從昨天開始就什麼也沒吃。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為呀，要賺錢就得工作才行對吧？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過工作的時候，如果碰到什麼意外，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "傷到我的可愛臉龐的話那怎麼行呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是那樣的話，會讓世界上所有人都很難過不是嗎！",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以呢，我是沒辦法去工作的唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊……不過肚子餓了……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n如果不好好吃飯的話，會讓肌膚乾澀變差的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要是那樣，我美麗的臉就……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚嗚……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我該怎麼辦……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對，對了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……雖然對你有點不好意思，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但你能請我吃飯嗎？我沒有其他能拜託的人了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是這樣嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔～嗯……那該怎麼辦才好呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉呦～我不是說了我不工作嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸？什麼？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n……從問題根源上解決比較好？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，的確也不可能",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n每天讓你請客呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真沒辦法……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我也只能好好工作賺錢了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和普通人一樣，努力賺錢的我……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光是想像就覺得好美唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你知道什麼好工作嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就請你介紹給我囉。",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸，這算什麼？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n道路維修！？工地現場！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全都是些得靠體力賺錢，屬於男人們的職場耶？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不要啦，竟然要在這種充滿男人臭味的地方工作……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n嗚嗚……好討厭的味道……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n都不能呼吸了啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼要介紹這種地方給我啦？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為是算日薪，所以能比較快賺到錢……？",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼說是沒錯啦……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "你們就是新來的啊。",
        "unit_id": 911,
        "voice": "vo_adv_1008002_025"
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "要給我好好工作喔。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇……這個人，全身汗臭味……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然還是不行！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我沒辦法在這種地方工作啦！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇啊！泥水濺起來了！",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是糟到極點……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要是可愛的我沾到泥巴的話怎麼辦啊？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "唉，真是囉嗦的新人啊。",
        "unit_id": 911,
        "voice": "vo_adv_1008002_028"
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "那麼討厭泥巴的話，就幫妳渾身弄髒吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "\n只要全身沾滿泥巴一次後，就會習慣了吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇，你在做什麼呀！",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我的臉上都沾到泥巴了不是嘛！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊……怎麼會這樣……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你竟然做出這種不可饒恕的事！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉……不過，難道說……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然沒錯！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n快看，映照在水窪裡的我！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即使髒兮兮，依然是這麼美麗……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n說不定可愛度反而增加了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管對我做什麼，都只會讓我的美貌更加顯眼呢！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉……真的好美……",
        "unit_id": 100811,
        "voice": "vo_adv_1008002_033"
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "喂！妳一直盯著水窪看，就根本無法工作了啊！",
        "unit_id": 911,
        "voice": "vo_adv_1008002_034"
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "\n真的是一點用處都沒有的新人欸。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "喂，你啊！",
        "unit_id": 911,
        "voice": "vo_adv_1008002_035"
    },
    {
        "type": "dialogue",
        "name": "棟樑",
        "words": "\n因為這傢伙沒啥用處，所以你可要加倍工作喔。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是{player}做了兩人份的沉重勞動而氣喘吁吁……"
    }
]