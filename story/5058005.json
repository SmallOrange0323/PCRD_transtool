[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "遠離蘭德索爾的某個地方。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n少女隻身一人走在險峻的道路上。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這附近",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "休息一下吧……！",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經離蘭德索爾",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很遠了呢。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好久沒自己一個人走這麼遠了。",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自從遇見主人之後，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下幾乎是寸步不離地",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n跟他在一起……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上次和主人分隔兩地",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼時候的事了呢？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有在下叫醒，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人是不是也能自己準時起床呢？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的睡臉實在惹人憐愛，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓在下每天早上都忍不住凝望起來……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等主人起床",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更衣後，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下再替他擦臉……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但主人",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是會一副睡眼惺忪的模樣",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──今天天氣真不錯，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很適合洗衣服。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這時是",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大夥兒的午餐時間嗎？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得主人",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有沒有好好吃飯……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人能不能拿好筷子呢……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘴邊是否吃得髒兮兮呢……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是有挑食呢……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該不要緊吧。",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟有個看似粗魯，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實則很會照顧人的凱留小姐在。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐她……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定會代替在下",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照料主人的。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "另外，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "挑食這件事",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要有貪吃佩可小姐在就沒問題了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她每天",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會為了在下等人",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想出各種菜單。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今後",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也要麻煩您了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──日上三竿了嗎？",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得好好吃頓午餐，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實補充營養。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個時間",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人差不多要出門打工了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……他應該沒有迷路吧？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常在下",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會隨行，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以免主人迷路……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事情不是那樣。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "近來主人",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愈來愈少迷途，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不再需要",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下陪同了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只不過是",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想盡可能",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多陪在主人身邊……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而已。",
        "unit_id": 105914
    },
    {
        "type": "background",
        "background": "500181"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──快要天黑了……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晚餐前",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再多走",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一段吧。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說到晚餐……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一到這個時間，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人總會",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "率先去幫忙",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐下廚。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是會",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以試吃為由，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n親自拿起剛做好的菜餚",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給主人吃。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很期待試吃這件事，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可可蘿可是一清二楚喔。",
        "unit_id": 105914
    },
    {
        "type": "background",
        "background": "500182"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──這個時候……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可不行。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一想到主人，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就忘了時間。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那段對在下而言",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無可取代的時光。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "充滿幸福的",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "短暫片刻。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊──",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好想……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "立刻回去。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到那",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫暖的住處。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到那",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "充滿歡笑的餐桌邊。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到那",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫柔的笑容面前。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這些都已經是、",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法實現的願望了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會把這份如同寶石般",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "璀璨的回憶深藏在心中，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不斷地誠心祈禱。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "祈禱貪吃佩可小姐……",
        "unit_id": 105914,
        "voice": "vo_adv_5058005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
