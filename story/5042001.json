        "voice": "vo_adv_5042001_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "結果我只有顏色跟花紋不一樣啊～！！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為什麼我們會是這種裝扮……",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有，這裡到底是什麼地方呀？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──關於這一點，",
        "unit_id": 1,
        "voice": "vo_adv_5042001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就由我來解釋吧。",
