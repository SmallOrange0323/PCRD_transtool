        "voice": "vo_adv_5042001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你為什麼要戳我的身體呀……？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 1,
        "voice": "vo_adv_5042001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你這個人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是怎麼回事呀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n初次見面就、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
