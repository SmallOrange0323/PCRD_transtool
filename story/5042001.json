    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是從哪裡傳來的……？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃等人",
        "words": "呀啊！？",
        "unit_id": 1,
        "voice": "vo_adv_5042001_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦……",
