    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是不知羞恥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "奇怪……",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "戳了我的衣服",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就有聲音冒出來……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是我身上",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這件洋裝在說話嗎！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳終於發現了呀？",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_015"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n沒錯，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "說話的人就是我，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "愛麗絲！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真、",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的是衣服在說話……！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "總之，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_017"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我先按順序一一解釋，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n你們幾個可要好好聽清楚了。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "首先，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_018"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我想你們應該對這個世界感到很困惑，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n我就先從這一點開始說明吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這裡",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_019"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "和你們原來的世界是不同的世界。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "說是書中的世界",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你們或許比較好理解吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "書、",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "書中的世界……！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n莫非",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是剛才發光的那本書嗎！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "嗯，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_021"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你們會驚訝也是合情合理的。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不、",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我好像稍微可以理解……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "照妳所說的話，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這身裝扮",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "和周圍的景色……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也就說得通了。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要怎麼做才能回到原本的世界呢？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我也不知道。",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_024"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "再加上，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "如果現在才要開始想辦法，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n你們很難有機會回到原本的世界吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 113011,
        "voice": "vo_adv_5042001_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為什麼這麼說呢……？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "現在這個世界",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_026"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n正因為某個存在而面臨危機。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n也就是說，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "在你們離開之前，搞不好這個世界就先消失了呢。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "牠的名字叫做",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_027"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "黑之王。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n牠打算讓這個世界墜入黑暗之中！！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼會……",
        "unit_id": 100113,
        "voice": "vo_adv_5042001_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "居然有這麼可怕的存在……",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個世界也很不容易呢……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳怎麼可以說得這麼事不關己呢。",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_030"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳可是要打倒黑之王的人，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "是這個世界的救世主啊。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼？",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是救世主！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "能夠打倒黑之王的人，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_032"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n就只有穿得上我「愛麗絲」的人……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "也就是妳！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳、",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳突然跟我說這些，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別擔心，別擔心～♪",
        "unit_id": 100113,
        "voice": "vo_adv_5042001_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們會和妳並肩作戰的！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起去懲罰那個叫做黑之王的傢伙吧♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒、",
        "unit_id": 113011,
        "voice": "vo_adv_5042001_035"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒錯！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我也會盡全力",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "支援璃乃妳們的……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦咦！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也要戰鬥嗎！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "是的。",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_036"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n妳們的服裝接收到我的力量產生了變化，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n就表示妳們具有和黑之王戰鬥的力量。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了～～！！",
        "unit_id": 100113,
        "voice": "vo_adv_5042001_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好～",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了幫助那些有困難的人，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要努力囉～～！！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃、",
        "unit_id": 113011,
        "voice": "vo_adv_5042001_038"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也會",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "全力以赴的……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "謝謝！",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_039"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那就拜託妳們了！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……不過，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_040"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那邊那個男的外表看起來",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n好像沒有受到我的影響呢。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "真奇怪，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "怎麼會這樣呢……？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "喔……",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_041"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "嗯，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "很樂觀嘛。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n看起來也滿有幹勁的，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那也拜託你囉。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那、",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我真的能夠",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "勝任救世主這個角色嗎……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "老實說，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一點自信都沒有……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就連設計師養成學校的考試",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我也落榜了……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我連自己的夢想都實現不了，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼可能拯救世界……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "璃乃。",
        "unit_id": 100113,
        "voice": "vo_adv_5042001_044"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個世界的人們",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說不定正因為黑之王而傷透了腦筋。",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果我們的力量可以幫上忙，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我們就去做嘛！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "日和……",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……救世主終究還是妳。",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_046"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n另外兩個人",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "雖然具備和黑之王作戰的力量，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n但能打倒黑之王的還是只有妳一個人。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "──所以，",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_047"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "要不要戰鬥，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "由妳做決定。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "由我……",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我完全搞不懂，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該做什麼才好。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但她說，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為黑之王的緣故，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個世界有可能會消失……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那樣一來，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們就無法回到原本的世界了……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要是再也見不到哥哥了，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐會很難過吧……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "肯定也有人",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在等著日和和步未她們回去……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_052"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也很傷腦筋呢……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "既然這樣，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想要幫她的忙……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我明白了，",
        "unit_id": 112912,
        "voice": "vo_adv_5042001_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會努力看看的。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "說得好。",
        "unit_id": 4611,
        "voice": "vo_adv_5042001_054"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那麼，各位，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我們出發吧！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃等人",
        "words": "好～！！",
        "unit_id": 1,
        "voice": "vo_adv_5042001_055"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了討伐黑之王，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並且找方法回到原本的世界，一行人開始行動。"
    }
]