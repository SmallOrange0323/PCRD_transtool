[
    {
        "type": "background",
        "background": "500091"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉～……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得，一點都不順利啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在當前的目標是監視蒂亞娜……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是貪吃佩可跟那傢伙。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果命令下來的話，我就唆使魔物解決他們。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在還是要繼續監視下去。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是不是不擅長追蹤之類的呢",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不僅輕而易舉地就被察覺到……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不知為何演變成每晚都一起吃飯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不不，這也是作戰計劃的一環。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是因為跟他們變得親密，",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才能站在比以前更能獲得情報的立場上啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正向思考吧，我絕對沒有任何失誤",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是呢……就算我跟陛下這麼說明，",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n搞不好不會被接受呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～我還是先暫時不要向陛下報告吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不知道陛下的地雷在哪啊……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下有時候也會突然生氣。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說的話，跟我有點像呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我覺得我們血脈相連啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可必須多注意點呢……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不要不小心觸犯到陛下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後被陛下說『你已經沒用了』～就被丟掉呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我必須讓陛下認為我很順從地將任務完成了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "若跟那些傢伙感情變好，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n獲得陛下想要的情報的話就好啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，過程就不是問題了！",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管什麼時候，最重要的就是結果了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗯、嗯♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "逃去那邊啦！",
        "unit_id": 711,
        "voice": "vo_adv_1060003_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "趕快抓住他……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n什、什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是什麼事啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "啊、凱留小姐，您辛苦了！",
        "unit_id": 711,
        "voice": "vo_adv_1060003_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n剛剛有沒有人逃到這裡來了呢？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n在王宮周邊，有可疑的傢伙在晃來晃去喔！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊、不好意思……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也是才剛從王宮出來而已，不知道呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他會不會已經通過這裡，不知道跑去哪了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "這樣子啊……我了解了。",
        "unit_id": 711,
        "voice": "vo_adv_1060003_016"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n如果看到像是可疑人物的傢伙的話，請大聲叫出來！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n我們會馬上過來支援的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊、嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我知道了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "工作辛苦了～……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂、你呀？",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那些傢伙走掉囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快給我出來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……果然是你啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我馬上就掩護你了，不過你到底在這種地方幹嘛啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然躲在樹叢裡，真的很可疑喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……就算是散步，你也好好選地點啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡可是這個國家的政治中樞──王宮喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "戒備非常森嚴呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨便在這裡閒晃的話，可是會被剛剛那群傢伙……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "負責王宮警備的武鬥派公會，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n【王宮騎士團】給抓到喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼凱留啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你呀～真是隨便呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，也不是不行。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，算了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在可不是站在這裡聊天的時候，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之我先讓你逃走。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，你就跟我一起走吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡有條不會被任何人看到，能偷偷從王宮離開的路線喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你別在那裡慢吞吞的啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就先裝作是我的隨從吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來呢……王宮的境地內，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只有王侯貴族才能進入的喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "通過這條狹窄小路、從那個門出去的話就是蘭德索爾的街道。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我會陪你一起走到那裡啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要什麼都得讓我這麼費事啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你如果被【王宮騎士團】抓到的話，\n可是會很麻煩的呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過萬一出了狀況，我可以用我的權限釋放你。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖說【王宮騎士團】是直屬於王宮，",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但最近對於王族的忠誠心也變薄弱了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實際上，變得像是流氓們的聚集處一樣。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果被抓到的話，你可是會倒大楣喔。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要小心啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不是在擔心你呢……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是在職場附近發生糾紛的話，會讓我覺得很煩而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我在這個王宮裡效勞。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "姑且～還有個爵位啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，我也能進入王宮的境地內。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我呀，就是所謂的貴族喲。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要尊敬我啊，平民。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之為了要幫陛下跑腿，",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n能自由進出王宮的話會比較好，所以才被授與許可。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這身份要說是虛構的，不如說是可有可無吧",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，這個講了可不行……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～真是的，都是我一直提供情報給你是怎～樣啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n角色顛倒了啊，我怎麼這麼不順啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛啊，不要隨便摸我的頭啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說你雖然不太明白，但要我提起精神……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "安慰個什麼勁啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說，不要太親近我啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我跟你的關係如果變得越來越好，",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來只會很痛苦而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有啦～我在自言自語……",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比起那個……喂，接下來有空嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我幫了你，你總該報答一下，請我吃飯什麼的啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我想吃好吃的東西、吃得飽飽的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是任何事情都不順利，很遺憾的一天。",
        "unit_id": 106012,
        "voice": "vo_adv_1060003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但只要吃到好吃的東西，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n心情好像就會好起來吧 ♪",
        "unit_id": 106012
    }
]