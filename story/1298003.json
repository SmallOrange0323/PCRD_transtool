    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得表情很可怕耶……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "我就開門見山地問了，",
