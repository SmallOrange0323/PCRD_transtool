    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "在我看來，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "他們不只是",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "朋友而已吧！",
        "unit_id": 6511
    },
