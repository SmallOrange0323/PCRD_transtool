        "voice": "vo_adv_1298003_021"
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "幾個小時前，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "朱諾平原那邊",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "\n似乎也有大量魔物出現……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "許多人員",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "\n正忙於應付那邊……！",
        "unit_id": 711
    },
