    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真琴今天依舊對新人施以嚴厲的訓練。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了慰勞那樣的真琴，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}帶著某樣東西造訪了訓練營地。"
    },
