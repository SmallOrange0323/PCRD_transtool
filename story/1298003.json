    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "就是",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "這麼一回事吧……！！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "佐藤",
