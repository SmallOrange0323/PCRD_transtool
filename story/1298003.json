        "type": "dialogue",
        "name": "真琴",
        "words": "什……！？",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才沒有那回事！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我跟這傢伙就只是孽緣而已啦！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "原來如此……",
