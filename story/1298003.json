    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "但我們也想出一份力！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "拜託妳了！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們……",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "變得很會說了嘛。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我明白了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想跟來的傢伙就跟上！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別遲到了啊！",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此……",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "確實就如報告所述，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "密密麻麻的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺光是去數有多少隻都讓人感到厭煩啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "冷靜，",
        "unit_id": 717,
        "voice": "vo_adv_1298003_031"
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "冷靜下來啊我……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n剛剛還說得那麼振振有辭的，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "不要害怕啊……！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "第一次",
        "unit_id": 711,
        "voice": "vo_adv_1298003_032"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "的實戰……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "為了保護大家，我必須加油才行……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n可是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "這麼多的魔物……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "最糟的情況，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "我",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "今天",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "就會在這裡……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我知道啦。",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "新人們",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n都因為恐懼而畏縮了，這點事我很清楚。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽好了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就老實說了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我打從一開始",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就沒有把妳們算進戰力裡。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "怎、",
        "unit_id": 711,
        "voice": "vo_adv_1298003_035"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "怎麼會……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n沒問題的，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "我們",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "能上……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們現在會害怕",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是正常的反應。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們還只是訓練中的實習生啊？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n面對眼前大量的魔物，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "手腳會發抖是理所當然的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "可是，",
        "unit_id": 711,
        "voice": "vo_adv_1298003_037"
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "這樣子",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "我們，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n就只會礙手礙腳而已……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要那樣想。",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n把在安全的地方觀摩戰鬥",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也想成是訓練的一部分。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比那些還要更重要",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_039"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的事情，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是妳們為了保護某人，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而鼓起勇氣來到這裡。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要有那份心，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總有一天",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一定能夠成為獨當一面的騎士。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以今天，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "作為邁向獨當一面的第一步，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就是去習慣實戰的氣氛。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要那樣就行了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就是為此才帶妳們來的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "教官……",
        "unit_id": 711,
        "voice": "vo_adv_1298003_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……那麼。",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接下來，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就好好看著吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n看著教官戰鬥的模樣！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，不行！",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你絕對別使用那個力量！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……你也試著想想看，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "新人們將來出任務時，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n根本不會有人替他們強化。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "然而，作為新人榜樣的我，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_045"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n卻以接受強化的狀態打倒魔物，這樣像話嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算向那些傢伙",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "展現教官那樣子的背影，也沒有意義。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我知道你是在擔心我。",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "拜託了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我在沒有強化的狀態下戰鬥吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──因為，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可是教官啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……唉，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不論哪個傢伙",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都這麼會講。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好啊，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "隨你高興吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要盡情大鬧了喔！",
        "unit_id": 129811
    },
    {
        "type": "still",
        "still": "129800301"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒想到竟然會有這一天，在戰鬥時將後背託付給",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n原本連握劍方式都不知道的{player}……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n過去的我就算聽了也不會相信吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──你變強",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "了呢！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "確實，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟我教了你很多東西啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不管是武器的使用方式，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是戰鬥的方法！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就來測試你能遵循我當時的指導",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n到什麼程度！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可要卯足幹勁啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿……",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_053"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要上囉！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喝啊！",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "──好強。",
        "unit_id": 711,
        "voice": "vo_adv_1298003_054"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "真琴教官她",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n一個人的時候明明就已經強得不像話了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n跟騎士先生聯手的時候卻又更強了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "這",
        "unit_id": 711,
        "voice": "vo_adv_1298003_055"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "也就是說……",
        "unit_id": 711
    },
    {
        "type": "still",
        "still": "129800301"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嘖！",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "數量太多了啊！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然沒有強化的話，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是開始覺得有點吃力了……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話雖如此，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_057"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在開始才要來真的！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你那邊沒問題嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_058"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能那樣子逞強的話，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n看來是還好得很呢！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不能讓新人們看到丟臉的模樣。",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我要全力狂奔了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你能跟上吧？",
