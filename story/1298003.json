        "type": "dialogue",
        "name": "安博",
        "words": "佐藤！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……所以，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主也說她想上傳影片喔。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "那、",
        "unit_id": 413,
        "voice": "vo_adv_1298003_008"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "那",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "個！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "真琴教官、",
        "unit_id": 413
    },
