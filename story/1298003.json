        "name": "真琴",
        "words": "沒有餘力把人派去埃斯特雷拉街道是嗎……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我了解狀況了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳傳達得很好，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝妳啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然這樣，",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就由我出馬！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這是命令，",
        "unit_id": 129811
    },
