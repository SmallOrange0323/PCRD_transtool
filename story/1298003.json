    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "不好意思，",
        "unit_id": 6511,
        "voice": "vo_adv_1298003_024"
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "教官！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n我無法聽從那道命令！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼……？",
