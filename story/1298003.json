        "voice": "vo_adv_1298003_017"
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "真琴教官！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "有急事要報告！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "發生什麼事了嗎！？",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_018"
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "是、",
        "unit_id": 711,
        "voice": "vo_adv_1298003_019"
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "是的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "埃斯特雷拉街道上",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "出現了許多魔物……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "\n再這樣下去，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "有可能會危及到一般市民！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "【王宮騎士團】怎麼樣了！",
