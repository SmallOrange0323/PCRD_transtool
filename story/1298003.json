        "words": "唔……",
        "unit_id": 413,
        "voice": "vo_adv_1298003_004"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "教官她",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "跟騎士先生在一起時總是很開心的樣子。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "那兩個人",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "是什麼樣的關係呢……？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "他們兩個的感情這麼好耶？",
