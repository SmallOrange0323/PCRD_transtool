        "type": "dialogue",
        "name": "真琴",
        "words": "喂──！",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我安靜一下！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽好了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我跟這傢伙",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼也沒有！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明白了吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "真的嗎……？",
