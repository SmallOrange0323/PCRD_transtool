    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "也想要守護蘭德索爾……！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "所以才會加入【王宮騎士團】！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "並不只是因為想見到本命偶像，",
        "unit_id": 6511,
        "voice": "vo_adv_1298003_027"
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n才加入【王宮騎士團】的喔。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "我們也是各自煩惱過後",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "下定了決心，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "現在",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "佐藤",
        "words": "才在這裡的。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "安博",
