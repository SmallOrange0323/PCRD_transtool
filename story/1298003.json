        "voice": "vo_adv_1298003_012"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "也就是說，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "雖然隱約察覺到對彼此互有好感，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "\n但還沒有正式交往的階段……",
