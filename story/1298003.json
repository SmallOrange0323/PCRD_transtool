        "voice": "vo_adv_1298003_015"
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "好可疑……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "安博",
        "words": "盯～",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼要一直盯著我啊……",
        "unit_id": 129811,
        "voice": "vo_adv_1298003_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙是……",
