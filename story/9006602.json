[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出現了呢，",
        "unit_id": 105911,
        "voice": "vo_adv_9006602_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【蠻賊三姊妹】……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "若菜、布武機",
        "words": "「呀哈哈哈☆」\n「……各、各位好……」",
        "unit_id": 1,
        "voice": "vo_adv_9006602_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來了啊，",
        "unit_id": 130013,
        "voice": "vo_adv_9006602_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "貪吃公主一夥人──",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這次絕對",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "要跟你們分出勝負！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "倭小姐！",
        "unit_id": 105811,
        "voice": "vo_adv_9006602_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是不會把皇家裝備",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "交給妳的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘖……",
        "unit_id": 130013,
        "voice": "vo_adv_9006602_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "事到如今也不需要那種東西了。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我要說的是，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n除了擋下你們，還要順便收下你們的性命……！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……璃亞，",
        "unit_id": 125811,
        "voice": "vo_adv_9006602_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "競技場那時候也是，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳不認為……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這樣果然不像倭小姐她們的作風嗎？",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……是的。",
        "unit_id": 126011,
        "voice": "vo_adv_9006602_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "如果她們並沒有被阿剌克涅的絲線控制，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那是為什麼……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "要來了。",
        "unit_id": 126111,
        "voice": "vo_adv_9006602_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得",
        "unit_id": 106011,
        "voice": "vo_adv_9006602_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些傢伙的力量",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比之前戰鬥時提升不少！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們可別鬆懈了啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "莉莉、可璃亞",
        "words": "「……是！」",
        "unit_id": 1,
        "voice": "vo_adv_9006602_009"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "──皇家裝備～？",
        "unit_id": 130213,
        "voice": "vo_adv_9006602_010"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n就算倭姊不需要──",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我也會收下的啦──",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "就拿來當作小鯊鯊的修理費！",
        "unit_id": 130213
    }
]