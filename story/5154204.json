[
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……啊。",
        "unit_id": 132511,
        "voice": "vo_adv_5154204_000"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n感覺氣氛明顯不一樣了。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是啊……",
        "unit_id": 132211,
        "voice": "vo_adv_5154204_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n四處都潛藏著強大魔物……",
        "unit_id": 132211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "散發著一股這樣的味道。",
        "unit_id": 132211
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小望，",
        "unit_id": 132411,
        "voice": "vo_adv_5154204_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "妳用聞的就知道魔物的強度了嗎！？",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好厲害！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好帥氣！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "露易，",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也幫彩羽做一個能成為戀味癖的祕藥～！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不，",
        "unit_id": 132311,
        "voice": "vo_adv_5154204_003"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "那不是什麼能成為戀味癖的祕藥啦。",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "而且剛剛望所說的味道，",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "並不是真的氣味。",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "而是用來表現可疑氣息的譬喻。",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗅嗅……！",
        "unit_id": 132211,
        "voice": "vo_adv_5154204_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家，",
        "unit_id": 132211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有股猙獰野獸的氣味正在接近中！",
        "unit_id": 132211
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊，",
        "unit_id": 132311,
        "voice": "vo_adv_5154204_005"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "原來真的是氣味啊……",
        "unit_id": 132311
    }
]