        "voice": "vo_adv_2115005_080"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "覺醒後的，",
        "unit_id": 129012,
        "voice": "vo_adv_2115005_081"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "龍人族。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……可是……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳應該沒有、",
        "unit_id": 129012,
        "voice": "vo_adv_2115005_082"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能破壞那座城的輸出能力。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不只如此……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳還，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有著餘力。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "到底……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我？",
