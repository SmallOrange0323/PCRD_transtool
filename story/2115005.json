    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2115005_084"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……剛才。",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_085"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n厄莉絲大人呀，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖然說了",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「無論是誰都敵不過我」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這種厲害的話……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯♪",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_086"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就是說呀就是說呀～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n厄莉絲大人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "最強！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也這麼想喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "米奈娃──",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_087"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這個世界的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "管理者的力量，妳竟然完全吸收掉了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那可是比",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "七冠還要厲害的外掛啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "管理者的力量",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_088"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然也有相應的限制。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n迷宮女王好像就想",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "針對那一點……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_089"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那些事就先放一邊。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我是在想，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難道沒有其他攻略路線",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "了嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以我",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_090"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為此做了準備。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n花時間提升等級、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "強化能力值。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "然後……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "給七冠們做個人情。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "借了那「外掛」……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了打贏肯定是最強的、",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_091"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "誰都無法戰勝的厄莉絲大人。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n為了從正面攻略",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不可能攻略的超高難度。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 106711,
        "voice": "vo_adv_2115005_092"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先是──",
        "unit_id": 106711
    }
