        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "竟然會變成彩虹的顏色，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺很可愛，說不定很適合我！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喏喏喏，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今晚就放那個吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不會吧吧吧吧！",
        "unit_id": 110011,
        "voice": "vo_adv_6019109_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n晚上已經一片漆黑了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還放煙霧是要幹嘛？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那樣子看得到嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到底有趣在哪呀，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才你今天晚上放給我看！",
        "unit_id": 110011
