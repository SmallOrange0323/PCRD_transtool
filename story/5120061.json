[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "公會長嗎？",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她美麗的地方啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她身為軍人的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "崇高精神是非常美麗，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是她",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總是在吃糖果……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該說是可愛吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即使現在是偏可愛型的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但莫妮卡小姐成長之後，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定會",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "擁有絕世的美貌吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n只有這點我能確信。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她將來",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "整體的外形都會很棒。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妮諾小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "穿著吸收了東國文化的打扮",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n非常適合她呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能將自己憧憬的裝扮穿得有模有樣，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這也只有美麗可以形容了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "東國文化中流傳的話語裡，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有「侘寂」",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這一個詞，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妮諾小姐",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再多留意這方面如何呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "至少",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得不應該",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在公會小屋中點起狼煙。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "空花小姐美麗的地方？",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "空花小姐美麗的……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咳咳，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽好了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是有很多種的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我想空花小姐一定是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "無法用美麗這個詞來定義的人。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她那獨特的打扮",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一定沒有人可以模仿，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她平時的言行舉止，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是沒有人能夠模仿得來的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "空花小姐一定有",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "專屬她自己的光彩吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "步未小姐……",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "步未小姐？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她是什麼樣的人啊？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我這只是在開玩笑的啦。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "每次",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我只要盯著她看，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n她就會瞬間消失呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "留下殘像的消失方式",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很虛幻而美麗呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要我給她對於美的建議，",
        "unit_id": 126311,
        "voice": "vo_adv_5120061_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是在消失時的殘像中",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "留下像寶石",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n之類的光輝如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想那樣一定會非常漂亮的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……話說回來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我為什麼",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會講到殘像的話題呢？",
        "unit_id": 126311
    }
]