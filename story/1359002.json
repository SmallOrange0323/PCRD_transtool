[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "追循抓走幽靈並從鬼族寶物庫裡\n偷走「返魂靈玉」的犯人足跡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與剎鬼來到了蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這座城市還真大。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n雖然建築結構",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "跟吉歐‧尼布爾黑爾",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有點類似……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但這裡的街道看起來好耀眼。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_001"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒有龜裂的牆壁、",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也沒有掉落的瓦片。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n看來房子真的要有人居住",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "才不會腐朽呢。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……是嗎。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_002"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n貪吃公主她",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也挺能幹的嘛。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然我很想四處逛逛……",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_003"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是追緝比觀光要緊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n沒想到",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "小偷居然會逃到異世界來。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要是不快點抓到人，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "可就沒臉見我家公主跟貪吃公主了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "如果事情",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_004"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "演變成蘭德索爾與吉歐‧尼布爾黑爾間的問題，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就不是我一人的首級能了事的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是啊。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_005"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n多虧騎士公的人脈很廣，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n行動起來方便不少，真是幫大忙了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "問題在於",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "犯人到底跑去哪了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然循著足跡追到了蘭德索爾……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但這裡人多成這樣，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要找人可不容易。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要再來打聽看看幽靈的傳聞嗎？",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_007"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n光是在路上聽到的，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就有關於啜泣女子還有花的事情，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看來被抓的幽靈也沒有乖乖束手就擒。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……又撲空了嗎。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_008"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "白天可能不會有進展呢。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "接著要往哪──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……嗯，",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_009"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n怎麼了嗎。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂喂。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_010"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n都這種時候了還要幫人啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1359002_011"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "謝謝你幫我撐著……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "背著大包行李爬坡果然很吃力呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "人終究還是敵不過年紀啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "給我吧。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我幫妳搬。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n嘿、",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "咻……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……這是什麼？",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_013"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n武器跟防具……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還有捕獸夾？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n喂，老婆婆。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "妳是準備去火拼嗎？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒錯。",
        "unit_id": 611,
        "voice": "vo_adv_1359002_014"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "聽說最近",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "出現了盜墓者。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可不能讓人打擾到死去的老爺子安眠。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n所以我打算親自出手教訓。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然精神可敬，",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_015"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但上了年紀就要服老。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "比起死去的丈夫，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "先擔心自己的腰吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……是啊，",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n想使用「返魂靈玉」的話",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "會需要遺骸。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n搞不好",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那就是犯人也說不定。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這位老婆婆。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "擦肩而過亦是累世之緣。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n盜墓者的事情，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "能不能交給我們來處理呢。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "說不定，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那個盜墓者",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就是我們正在追緝的傢伙。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是這樣嗎？",
        "unit_id": 611,
        "voice": "vo_adv_1359002_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "既然",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳這麼說，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那就拜託兩位了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我這身老骨頭就算去戰鬥，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可能會徒增一座墳墓呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "交給我們。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_019"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n儘管放心吧，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "老婆婆。",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "500532"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……這邊世界的墓地",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_020"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還真是和平啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n連半隻殭屍都沒有。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不用在意。",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_021"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我只是有點意外而已。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "反倒是騎士公，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你才需要放鬆一點──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……不，",
        "unit_id": 135912,
        "voice": "vo_adv_1359002_022"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "等等。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "做好準備吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n看來那傢伙出現了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "終於……",
        "unit_id": 4911,
        "voice": "vo_adv_1359002_023"
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "終於啊……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "好，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "來挖吧……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚……",
        "unit_id": 214,
        "voice": "vo_adv_1359002_024"
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚嗚……",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "用這個「返魂靈玉」，",
        "unit_id": 4911,
        "voice": "vo_adv_1359002_025"
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "將靈魂封進屍體裡……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "哈哈……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "終於……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "\n終於，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "盜墓者",
        "words": "能讓她重生了……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……什麼。",
