[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後……\n智和茉莉前往了蘭德索爾市中心的餐廳街，\n並決定在那邊吃午餐。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來，茉莉",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是菜單。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n儘管點自己喜歡的吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇，",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想吃漢堡排！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只要吃了肉就會變強☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "漢堡排定食是吧，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "收到。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n飲料呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只吃漢堡排定食的話營養不太均衡，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要不要點個果菜汁之類的？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦咦咦，",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不喜歡吃蔬菜啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那個，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不能點",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "冰淇淋汽水之類的嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嘻嘻。",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也不是不行啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你的口味還真孩子氣呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那我就點",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當季的烤魚定食",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和煎茶吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好成熟！",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我從以前就這樣覺得了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你的嗜好都好老氣喔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我家裡比較傳統呀，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為是代代相傳的劍術道場嘛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我的事不重要啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "閒聊結束。",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天的目的是想問",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n茉莉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼最近都沒參加訓練呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "…………",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不是想要說教喲。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我只是很擔心喲，茉莉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望你能敞開心房，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "坦率的和我談談。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你是【王宮騎士團（NIGHTMARE）】之中，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n和我年紀最相仿的人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我一直把你當作妹妹看待呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我總盡量對你好，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "若你有煩惱也希望能好好跟你談談。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不。",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我覺得",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你很可愛喲。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望你能盡量依靠我。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智～姐……",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我很高興。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我也",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把小智姐\n當作自己的親生姊姊的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……那個，",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那我就說實話囉。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣問好像很奇怪，但是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不覺得最近，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純感覺怪怪的嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你也這麼覺得？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我本來還覺得他只有對我態度怪怪的，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n原來茉莉也這麼覺得呀……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純他",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近的行為真的很奇怪對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "作為守衛，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n本應坐鎮在『王宮』的正門前……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但卻在城中看到他，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是在些人煙稀少的區域閒晃。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為很在意而出聲叫他後，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "卻直接無視我。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有一次我覺得很火大，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就半開玩笑的從背後抱緊他",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n並且叫了",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "『純♪』。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你猜，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "發生了什麼事？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純他",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一句話都不說的就直接踢飛我喔？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那時膝蓋的擦傷到現在還沒癒合喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "連心都受傷了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一陣一陣的抽痛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還以為",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純跟我滿契合的說？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純他",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "認真又寡言，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以捉弄他很好玩……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不管我怎麼開玩笑，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n他最後都會笑著原諒我。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我打從心底",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喜歡純喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純作為我們【王宮騎士團（NIGHTMARE）】的團長，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n深受信賴跟愛戴。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近的純真的太不對勁了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡直就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "鎧甲裡換了一個人一樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來純也這樣",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對待小智姐呀……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我也跟你有同樣的感覺，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "應該說",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "更慘。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純他……",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "最近常常",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n出現在我們剛剛去的獸人族居住區喔。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n然後還",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在那邊大鬧一場才離開。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦咦？　",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純會做那種事……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是不是住在居住區的獸人們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n犯了什麼罪，所以才前去討伐？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不可能！",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我們可是一直老老實實",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "悠閒地過生活的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很多獸人都血氣方剛，",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n平常生活中免不了",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會有小吵架……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但才不會去犯罪呢！",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就算真的是犯罪，純他也做得太超過了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n看到什麼建築都肆意破壞，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還任意攻擊路過的行人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再怎麼說都太過分了！",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還好",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還沒出現重傷者或死者，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但再這樣下去我看也只是時間遲早的問題而已～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為如此，居民對\n【王宮騎士團（NIGHTMARE）】的觀感",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "才會變差。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天也是，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是在路上走走卻被瞪。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我原本以為，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只是因為獸人族本來就不喜歡",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團（NIGHTMARE）】而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的、",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確很多人討厭【王宮騎士團（NIGHTMARE）】。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但最近",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為這樣而情況越來越糟，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n甚至還有些人想一起教訓『王宮』呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "媽媽也擔心我如果\n太常進出【王宮騎士團（NIGHTMARE）】的話……",
        "unit_id": 100511,
        "voice": "vo_adv_5006002_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n會很危險，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以完全不讓我出門。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以你才沒來參加訓練吧……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來如此，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我大概知道事情原委了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我還",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真搞不清楚呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n純到底為什麼要做這麼蠢的事情呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一點都不像平常的純……",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺應該",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "向本人問清原委呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "視情況，",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使是純，也必須制裁。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n平白傷害無罪的人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們可不能坐視不管。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我們【王宮騎士團（NIGHTMARE）】可是站在正義的一方呢。",
        "unit_id": 103711,
        "voice": "vo_adv_5006002_040"
    }
]