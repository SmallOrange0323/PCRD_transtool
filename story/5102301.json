[
    {
        "type": "dialogue",
        "name": "智",
        "words": "輝美小姐……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102301_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳這樣不停除掉其他直播主，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n持續踐踏他人的「喜歡」，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對妳究竟有什麼好處？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會是因為",
        "unit_id": 123711,
        "voice": "vo_adv_5102301_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個緣故吧？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n到頭來，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是為了錢",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才開直播之類的？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n然後，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為想要賺到更多錢，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以才要幹掉對手之類的？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "妳說我是為了錢？",
        "unit_id": 16711,
        "voice": "vo_adv_5102301_002"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "呵呵……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "哈哈哈哈哈！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有什麼好笑的？",
        "unit_id": 123511,
        "voice": "vo_adv_5102301_003"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "不……",
        "unit_id": 16711,
        "voice": "vo_adv_5102301_004"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "抱歉。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "因為這個猜測太離譜了，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "讓我忍不住笑出來。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我從來沒有為了錢",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "而開直播。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我只是希望",
        "unit_id": 16711,
        "voice": "vo_adv_5102301_005"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "能有更多人看我的直播，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n想要獲得更多的點讚罷了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的確，",
        "unit_id": 123711,
        "voice": "vo_adv_5102301_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對直播主來說，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n觀看人數和點讚之類的",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都很重要，但是啊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這些難道值得妳不惜踐踏他人重視的事物嗎！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "是啊，",
        "unit_id": 16711,
        "voice": "vo_adv_5102301_007"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "妳說對了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n對我而言，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就是渴望到願意賭上一切！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "誰都別想阻擋我！",
        "unit_id": 16711,
        "voice": "vo_adv_5102301_008"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n我要讓你們",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "就在這裡Game Over！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳想得美！",
        "unit_id": 123611,
        "voice": "vo_adv_5102301_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一定會阻止妳的！",
        "unit_id": 123611
    }
]