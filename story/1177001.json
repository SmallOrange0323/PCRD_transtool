    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "所以",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "你想怎樣？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "\n難不成大哥哥",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "想被我惡作劇嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "不行不行！",
        "unit_id": 1,
        "voice": "vo_adv_1177001_057"
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "就算對大哥哥惡作劇，感覺你也不會嚇到。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "\n還是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "要像那個大叔一樣會大聲尖叫的才好玩！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "\n我先走啦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "掰掰──♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_058"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跑走了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他好像又打算去那家店惡作劇……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們去看看狀況吧～？",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "好──",
        "unit_id": 1,
        "voice": "vo_adv_1177001_059"
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "這次不如在大叔的鞋子裡放口香糖吧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "\n……呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "哇啊啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "為什麼這裡會有獅子！？",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "505034"
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "救、",
        "unit_id": 1,
        "voice": "vo_adv_1177001_060"
    },
    {
        "type": "dialogue",
        "name": "少年幽靈",
        "words": "救命啊～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此～",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_061"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "惡作劇的壞幽靈，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好像會把風獅爺看成獅子呢～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看樣子我們的風獅爺，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_062"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n果然有驅邪的力量～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們快拿出幹勁，努力去送風獅爺吧～！",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼……",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_063"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "花了不少時間，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過總算全都送完了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_064"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你們在這裡啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n兩位，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "辛苦啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我正在找你們喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_065"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大叔。",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n怎麼了嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我要跟你們道謝。",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_066"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不知道是不是那個擺飾的功效，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "今天一天下來都沒有發生惡作劇啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我認識的店家也說，",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_067"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n多虧有你們送的風獅爺，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n每間店",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "都沒有遭到幽靈作亂的樣子。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "風獅爺真是萬聖節的守護神啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_068"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "兩位，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝你們！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_069"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "故鄉的守護神",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "保護了大家，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總覺得讓人驕傲呢～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "以後每年",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_070"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "到了這個時期，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我都會把風獅爺拿出來擺的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那我先走啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不只萬聖節可以擺，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_071"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n每天都可以的呀～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "忘記說明清楚了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_072"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "算了！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n能幫上大家的忙",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就很高興了～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_073"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對了對了……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "趁我還沒忘記，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n趕快把這個給{player}！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_074"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我留了最後兩隻，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要送給{player}當禮物喔～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這兩隻風獅爺，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_075"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n會永遠陪在彼此身邊～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們也要",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_076"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像風獅爺一樣",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一直一直在一起喔～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "香織這麼說著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n緊～緊地一把握住了手。"
    }
