    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "香織在瀰漫著濃厚萬聖節氣氛的街道上散步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看起來很愉快地向前走著。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呵～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你這聲招呼真有活力～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看你一臉好奇的樣子，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼了嗎？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……我為什麼",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "穿著萬聖節拯救隊的制服？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為這件衣服很有萬聖節的風格，也很可愛呀～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也會讓人提起幹勁呢～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然萬聖節期間，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n【哞哞自衛隊】的工作我暫時休假……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但如果",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有人遇到困難",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也不能放著不管～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我為了守護萬聖節，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n才穿著這身制服",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "巡邏呀～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你有空的話",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}也跟我一起巡邏吧～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一邊欣賞萬聖節的裝飾",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一邊散步也滿好玩的……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚、",
        "unit_id": 1,
        "voice": "vo_adv_1177001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚哇啊啊啊啊啊啊啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……剛才的尖叫聲",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是從對面的店裡傳來的──！",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "發生什麼事了嗎──！？",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_008"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "蟲、",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_009"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "蟲……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "有蟲……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蟲？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n……啊，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你說放在桌上的這個嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然做得很像，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是玩具啦～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是玩具……？",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_011"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "呼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "什麼嘛，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嚇我一跳……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還好不是什麼危險的事件～♪",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽到好大聲的尖叫，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚇了我超大一跳呢～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "唉呀唉呀，",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真難為情……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我實在太怕蟲子了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不過是誰搞這種惡作劇呢……",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_014"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……該不會",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真的是幽靈在搗蛋？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "幽靈？",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "最近",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "鎮上到處都有店家",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為被惡作劇而引起騷動……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n被惡作劇的店家老闆",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "都一致這麼認為啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是「幽靈在搗蛋」呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那些老闆都說",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_017"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "他們看到了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n惡作劇的小孩好像在空中飄或穿過了牆壁。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但是",
        "unit_id": 1411,
        "voice": "vo_adv_1177001_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "按常理講，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不可能會有什麼幽靈吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "所以我是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不相信那種事啦……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我猜那些可能，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真的是幽靈搞的鬼喔～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "之前",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "發生一些事的時候",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我有聽他說過……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在萬聖節時",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "現實與",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "靈界會變得比較接近。",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很多幽靈會受到影響而跑出來～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以一定是",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喜歡惡作劇的幽靈們，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在到處",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "惡作劇吧～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "既然這樣",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就該萬聖節拯救隊出場了～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會守護萬聖節的～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你問要怎麼防止幽靈惡作劇？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我現在來想辦法～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯……",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "該怎麼做呢……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……啊，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想到好點子啦──！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "來做風獅爺吧！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對呀，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "風獅爺！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我的故鄉那裡，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "人們為了驅邪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會在家裡擺風獅爺喔～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要有風獅爺在，",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n壞幽靈一定",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就沒辦法再跑進店裡啦～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那樣一來，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "它們就也不能惡作劇了對吧？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為了鎮上的人們",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們來做一大堆風獅爺～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "既然決定好了",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就先來去買黏土！",
        "unit_id": 117711
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "準備齊全！",
        "unit_id": 117711,
        "voice": "vo_adv_1177001_029"
    },
