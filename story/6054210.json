[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃她，",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n願意稱我為",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「勁敵兼摯友」",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實在是讓人很開心呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n……所以",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也要更加努力",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟上她的腳步。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝。",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過呀，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一開始",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她稱我為「勁敵」時，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我其實覺得「秋乃太高估我了」",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而感到有些慌張。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但現在，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這已經無關實力，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是我自己希望「能成為她的勁敵」呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣還不夠吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只要秋乃向我挑戰，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我都不希望自己輸給她，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以我還要再更上一層樓。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得做到能超越秋乃才行！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這我也有同感，",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且也",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很感謝她。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這些感謝，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要等我成為真正的企業家之後再告訴她。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……關於這件事，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可要幫我保密喔。",
        "unit_id": 114511
    }
]