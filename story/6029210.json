        "voice": "vo_adv_6029210_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　你整張臉都紅通通的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "溫泉泡太久了喔。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
