    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘿☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　吃我的雪球攻擊！",
