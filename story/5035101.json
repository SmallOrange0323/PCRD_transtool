[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呼～",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_000"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這次的委託還真不簡單呀～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但報酬的金額也相對地多，",
        "unit_id": 112511,
        "voice": "vo_adv_5035101_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "委託不都是這樣嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "比起這事，卯月，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "剛剛委託人",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是不是給了妳什麼東西？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊，",
        "unit_id": 112411,
        "voice": "vo_adv_5035101_002"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是的。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是這個……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對方說如果有興趣的話就請我們去看看吧。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哦哦──！",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_003"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這個",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不是【慈樂之音】的演唱會門票嗎！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n這是很難拿到的呢！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……那是什麼？",
        "unit_id": 112511,
        "voice": "vo_adv_5035101_004"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦！？",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_005"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "澀凜凜小姐，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "難道妳不知道嗎！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n島村村呢！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我也",
        "unit_id": 112411,
        "voice": "vo_adv_5035101_006"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不是很清楚。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n這是什麼的門票呀？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是現在超人氣偶像團體的活動門票唷！",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_007"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n能看她們",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "又唱又跳的……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "總之是很厲害的東西啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……雖然我也沒看過就是了……！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜、卯月",
        "words": "……「偶像」？",
        "unit_id": 1,
        "voice": "vo_adv_5035101_008"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……「偶像」",
        "unit_id": 112411,
        "voice": "vo_adv_5035101_009"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……是",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "什麼呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "明明是不知道的名詞……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但又好像很熟悉……？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好～！",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_010"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n既然這麼難得，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那我們就一起去看吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦，",
        "unit_id": 112511,
        "voice": "vo_adv_5035101_011"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不用啦，我沒差。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n反正我沒什麼興趣。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦——！",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_012"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n這可是超稀有的門票喔，澀凜凜！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就算妳這麼說——",
        "unit_id": 112511,
        "voice": "vo_adv_5035101_013"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "未央！",
        "unit_id": 112411,
        "voice": "vo_adv_5035101_014"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "很想去看看，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "所謂的「偶像」！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然我不知道為什麼，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但就是感覺不去看不行……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真不愧是島村村──♪",
        "unit_id": 112611,
        "voice": "vo_adv_5035101_015"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "妳看妳看～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "澀凜凜，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "一個人留下來看家可是會很寂寞的唷──？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "一起去一定會很有趣的嘛──",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "哎……",
        "unit_id": 112511,
        "voice": "vo_adv_5035101_016"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真拿妳沒辦法。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "只有妳們兩個的話，總覺得讓人有點擔心，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我會跟著去啦。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜、卯月、未央",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5035101_017"
    },
