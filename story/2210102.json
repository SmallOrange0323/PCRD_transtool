        "type": "dialogue",
        "name": "旁白",
        "words": "遠見空花也一樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "取回了對現實世界的認知與記憶，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了原本的日常，然而──"
