    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從「米奈娃的禁錮」中被解放的一部分人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n逐漸在現實世界取回原本的生活。"
    },
