[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "still",
        "still": "200100301"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呦喂呀～……？",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看來在爆炸規模的調整上，是出了點差錯呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "整輛馬車都被炸飛了耶～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "『被炸飛了耶～』",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說什個鬼風涼話啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "開什麼玩笑！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那輛馬車上，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是還載著毫無關聯的平民百姓喔！？",
        "unit_id": 104311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不不，",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也無法斷言就是毫無關聯的人吧～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "從竊聽魔法所聽聞的內容來看，",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n『小矛依未』她，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n似乎還認識馬車上的其他人唷？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很有可能是為了讓那孩子順利逃亡才準備了這輛馬車～",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n他們極有可能是同一夥的也說不定。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但只要將他們一網打盡，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就能省下不少麻煩了對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但那也就只是『有可能』而已吧！",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n感覺其他人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n根本就不像是認識那個『矛依未』的呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果真要說有沒有可能，",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是『毫無關聯的平民』的可能性還比較高吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我已經受夠你那自私自利的態度了，",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "尾狗刀前輩！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "早知道會這樣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就不幫你這份忙了呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊啊，真不爽！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽著，",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我好好記清楚了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不是什麼殺手啊……！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "冷靜一點～",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n先別這麼生氣嘛，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "小汪汪。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "比起這個……",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n看來那群人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "似乎勉強逃過那場爆炸了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "從現在開始可是要玩真的了唷，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "先專注在眼前的工作上吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不幹了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "誰還能跟你這樣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "繼續玩下去啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎呀，",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "常聽到有人那樣跟我說呢～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我呀，還真是交不到朋友的人呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "到底問題出在哪呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我自認為還算是表現得和藹可親的呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你先摸著你自己的良心想想吧，",
        "unit_id": 104311,
        "voice": "vo_adv_2001003_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "該死的！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n【哞哞自衛隊】的人跟我來，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要火速趕往現場啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n得從被爆破的馬車殘骸中，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "救出生還者才行！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "等一下等一下。",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也一起去喔～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "老實講，",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "小矛依未是生是死，其實一點都不重要呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我只是不得不取回她所偷走的『寶物』罷了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咳，",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咳！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還以為真的要死了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深有同感。",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是千鈞一髮呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您有沒有受傷呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那還真是不幸中的大幸。",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人您沒事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是令人鬆了口氣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有大礙。",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所幸，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是受了點擦傷的程度而已。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明發生了這樣的事，卻還掛念著在下是否有負傷。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下的主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是一位相當溫柔的人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是嘛……",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n僅僅差分毫，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許就得連同馬車一塊葬送於爆炸之中了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是怎麼一回事？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貌似是發生一場大爆炸了？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖、",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然還搞不清楚狀況！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果有傷者，我可以提供治療的唷！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "由於大小姐的擔憂，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以總是會讓我帶著些療傷藥在身上！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我看看，",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "治療符咒在～……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這不是能把人電得酥麻的雷神護符嗎！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還是趕緊用恢復魔法比較快吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想想，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咒語是咒語是……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "噓……",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請安靜，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照這看來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "危機似乎還沒完全解除呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇哇，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "週遭好像冒出了不少人影呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盜、",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盜賊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n難不成就是襲擊了這輛馬車，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "試圖想要奪取財物的壞蛋嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那不是……",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "獸人嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也就是說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是【動物苑】？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼辦？",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n他們和我們家公會上頭所直屬的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n【公主騎士】，最近可是鬧得水火不容呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這麼說來，",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難不成會是【動物苑】想要發動戰爭嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果真是這樣，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那可是比起被盜賊襲擊，這事態更為嚴重呀～！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在也許不是該去管那種事的情況也說不定，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可否麻煩您先試著治療她呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……。",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀！",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "傷得好嚴重！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來是她在情急之下為了避難，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而將在下等人一同拖出了馬車外，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n同時還在爆炸的風波下捨身庇護了大家。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但也因此，",
        "unit_id": 105911,
        "voice": "vo_adv_2001003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法顧及到自己的安危了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是、",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是救命恩人呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好慘啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n明明就還這麼小小年紀的呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳可不能死在這～",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快快恢復元氣吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嘿呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "恢復魔法☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔，咕……？",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "趁現在快逃吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉，",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "把你們也都捲了進來……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那些人的目標是我，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "和你們一點都沒有關係。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "若妳替我治療，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可是會被誤認為是我的夥伴喔？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別在意，",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算獨自一人也沒差。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒問題的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為我早就習慣了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別、",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別再說話了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嘿呀看招，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "回復魔法～☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚～拜託了就這次，別兩光一定要成功呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是在替我加油嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常感謝！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只要有了你的鼓勵，",
        "unit_id": 102511,
        "voice": "vo_adv_2001003_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不知道為什麼就會全身充滿力量呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "給我等等～",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_044"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可不可以別做些多餘的事給人添麻煩呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n難得這麼好運……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "剛好就只讓目標的小矛依未，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n落得這插翅也難飛的處境呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可別還讓人得要再費上什麼額外的工夫呀。",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_045"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別輕舉妄動呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你們已經完全被包圍囉♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "尾狗刀……！",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_046"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別隨便就喊上別人的名字啊～",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_047"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不是會讓別人誤認為我們好像很熟嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "怎麼說我也可算是有著高貴身分背景的人呢，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若被別人認為我和小偷有什麼關係，那可會讓我相當困擾的呢～♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "喂！",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_048"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在那邊的你們幾個！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "雖然不知道你們打哪來的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但可不可以把那孩子交出來呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不太想還要多浪費什麼額外的力氣呢～",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_049"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我想要輕輕鬆鬆的來解決這件事啊♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那孩子，",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_050"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "小矛依未呀～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n從我的宅邸中，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "偷走了寶物唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "瞧，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就是那個王冠造型的胸針呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那個",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_051"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若是不奪回來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我可會挨父親的罵喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對我而言，那可是相當重要的東西呢～。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那是這世上唯一，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "曾經給予過我關愛的祖母，所留下來的遺物。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來是這樣的嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你可從來就沒有，",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對我說過有關於這東西的事呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果真是這麼重要的東西，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那為什麼還要給像這樣的我呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦～？",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_054"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n說什麼『給妳』呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "應該是被妳『偷走』才對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳",
        "unit_id": 106211,
        "voice": "vo_adv_2001003_055"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一直在我的宅邸週遭鬼鬼祟祟的對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就覺得很可疑，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "果然妳就是那個小偷了吧～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才不是我偷的，",
        "unit_id": 106112,
        "voice": "vo_adv_2001003_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是你給我的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
