[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉塔與{player}結束了這天最後的工作，\n回到蘭德索爾的途中──"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就快要到城鎮了，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "稍微休息一下吧。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n今天也已經沒有工作了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "回去之後",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "希望你能陪我進行劍術修行呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "偷瞄。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可以嗎？",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你也變得越來越厲害了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過我可不會輸哦！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "其實呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之前那個像魔法一樣的力量……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我把它叫做轉換職業，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為了要熟練使用那個力量，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想要嘗試各種挑戰。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為了達到那個目的，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就必須變得比現在更加更加強大。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "吶，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然可能是我的錯覺，但是不是有點刺眼？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好像陽光突然變強一樣……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不對……！",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n這個刺眼的光，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之前也有過──！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想想……",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "教職員室的話，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "下這邊的樓梯比較快吧？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……答對了嗎？",
        "unit_id": 105731
    },
    {
        "type": "still",
        "still": "105700801"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了──！",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "怎麼樣？怎麼樣？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我已經很熟悉這所學校了哦！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來到日本也經過一個禮拜了，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n這點小事還不至於搞錯。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "放學後我還跟優衣與真琴一起去買東西，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有去日本的……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有去咖啡店♪",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "然後還有……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "卡拉ＯＫ！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "日本的卡拉ＯＫ很厲害呢……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "非常開心！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "抱歉。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "光顧著說我的事。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n因為之前太開心了，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不小心就……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……那個啊。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才錯過說出口的時機了，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你和我一起搬筆記本。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……你不管在現實，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n還是在阿斯特朗，都沒有改變呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……啊──",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "終於能好好說上話了──！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "每次休息時間和大家聊天都太開心，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不知不覺時間就沒了呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過啊，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "其實我很想找時間和你慢慢聊聊……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "畢竟同時知道阿斯特朗與現實裡，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "兩邊不同的我的人，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n就只有你而已呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過你啊，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n每次一放學就不知道跑去哪了……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "其實啊，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我希望你能多告訴我這個城鎮的事……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "吶，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "放學後能不能帶我去哪呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還是說，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你有事要忙……？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "珍藏的……",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真的嗎？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了──！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好開心……！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就約好了，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "放學後一起走哦！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能不能快點放學呢……♪",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_019"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……咦？",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "教職員室，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要走哪邊……！？",
        "unit_id": 105731
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "放學後──"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "讓你久等了──！",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_021"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就走吧！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "繞路？",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好啊。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要去哪裡呢？",
        "unit_id": 105731
    },
    {
        "type": "background",
        "background": "510121"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……這裡，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是公園對吧？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n上個星期天，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "優衣她們有帶我來過……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你看，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那台紅色的車。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之前沒有出現呢，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你知道那是什麼嗎？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可麗餅……",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "原來，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那台車在賣可麗餅啊！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那口味就交給你選了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我在這裡等！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……總覺得很不可思議呢。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是不是因為平常總是請他跟著我走的呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……他和店員關係似乎很好。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "難道說是常客嗎？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "話說回來，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "感覺我還是第一次一直望著他的背影……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我好像總是和他並肩而行，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "或是把背後交給他守護。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "歡迎回來。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_029"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我看看，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這是巧克力香蕉口味嗎？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那我選這個。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我要開動了──",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊姆……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_030"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好吃。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過呢不算非常好吃，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n但是也不算是不好吃……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n呃……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "普通！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "沒錯，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要說普通！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我原本是想好好誇獎一番的哦？",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_031"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過除了普通之外我也不知道該對這味道說什麼……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "欸？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你為什麼笑了──",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "全部都吃掉了，不過味道果然很普通……",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_032"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這是怎麼回事，這個可麗餅……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "味道非常不可思議……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "時間差不多了？",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_033"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "終於要去你珍藏的地方了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "會是什麼樣的地方呢……？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "令人期待……！",
        "unit_id": 105731
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔哇……！",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_034"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是瞭望台！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "快看，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_035"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "夕陽就快要沉下去了！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好美……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……這裡，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這個景色，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是你所珍藏的美景對吧。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以才會繞路去公園，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_037"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "在那裡吃可麗餅。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就是為了能在恰當的時機來到這裡……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_038"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你帶我來看你珍藏的地方。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……和我在故鄉見到的稍微有點不同，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_039"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不過夕陽的美麗依然沒有改變呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真懷念……",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這個地方非常地棒呢。",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_040"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總有一天，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也想讓你看到，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n在我居住地的珍藏美景呢。",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "既然要去我的故鄉，",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_041"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n那麼途中順便去各式各樣的地方旅行！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n你覺得怎麼樣？",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "沒錯吧！",
        "unit_id": 105731,
        "voice": "vo_adv_1057008_042"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就像阿斯特朗一樣，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總有一天，",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我們要在現實的世界裡，去各種不同的地方冒險！",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105731
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "和你一起冒險！",
        "unit_id": 105731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1057008_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我給你的禮物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你做了個好「夢」對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你珍藏的地方呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1057008_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，還不壞不是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個孩子似乎也很開心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "兩人一起在各種地方冒險不是會很開心嘛。",
        "unit_id": 190011,
        "voice": "vo_adv_1057008_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個願望，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你能夠實現嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好啦，你就好好努力吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1057008_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉～ ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯嗯……",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_047"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "又睡著了嗎……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "早安……",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_048"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "話是這麼說，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "但太陽都快要完全落下來了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_049"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我在夢裡看到了非常美麗的景色。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n就和這個夕陽差不多……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不對，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "比這還要美，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是讓人想珍藏的景色呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果還能見到更多那樣的美景，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_050"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n那麼在夢裡的世界冒險似乎也會很開心呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊哈哈……",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_051"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我在說些什麼呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n明明這個世界就已經廣闊到無法踏遍了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果連在夢裡也要冒險，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可是會非常辛苦呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……不過就算很辛苦，",
        "unit_id": 105711,
        "voice": "vo_adv_1057008_052"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我也想要親眼見識廣大的世界，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "更多各種不同的地方呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "而且要和你一起去……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和夢中的場景相同，\n吉塔望著落下的夕陽，嘴角浮現出笑容。"
    }
