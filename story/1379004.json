        "name": "璃乃",
        "words": "我就想著，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "想把現在的心情",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好好記錄下來。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "留下跟哥哥一起度過",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "特別的一天的、",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "證明。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_057"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "把這裡，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "寫……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我能寫得好嗎……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "完成了……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_058"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不能偷看喔。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是祕密～♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可以告訴你",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一點。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟哥哥一起",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "度過的時間……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n像今天這樣的日子，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "若能一直繼續就好了，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是這麼想的。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "希望能像今天一起在福運會上奔跑那樣…………",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今後也",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "每天都能與你",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "並肩行走……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只是家人、",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妹妹的心情",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已經不夠了……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我想跟你成為更特別的關係……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_063"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我明年、",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "後年，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也想像這樣……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟你一起去新年參拜。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你能……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟我",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "約定嗎？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "璃乃心懷願望，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "輕輕掛上繪馬。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在柔和的陽光照耀下，"
    },
    {
        "type": "dialogue",
