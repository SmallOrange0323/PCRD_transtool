    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在福運會的喧囂散去後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n神社內僅剩舒適的寂靜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "璃乃等人則在神社境內的長椅上休息片刻。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天一整天",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都在全力奔跑……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "腳已經",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都快變成木頭了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥在我身邊，我很努力喔。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能和哥哥一起來，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是太好了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我還是",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直都在依賴你",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呢。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你，",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "光是剛剛的那句話，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "到剛才為止的疲累",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都一下子",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就消失了。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……回頭一看，",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天真的過得很充實。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n福運會的",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "許多課題，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟姐姐的對決……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最終審查，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我心臟還在撲通直跳呢。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天的事情……",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我絕對不會忘記。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為今天對我來說，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已成為特別的一天。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……？",
        "unit_id": 137912,
        "voice": "vo_adv_1379004_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n咦，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "本殿那邊有光……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好刺眼啊……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇……",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好多人……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n氣氛跟平常的神社",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像完全不同。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有這麼多人在等待",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跨年的瞬間啊。",
        "unit_id": 101131
    },
    {
        "type": "still",
        "still": "137900401"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那、",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會不會很難走？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我的和服、",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會不會……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很礙事？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我沒事。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然因為穿不習慣，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有點辛苦，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但今天也好好確認過鞋帶了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "比起這個，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為跟哥哥一起穿和服出門，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我好像有些緊張。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天來真是太好了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次的寒假一～直在念書，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像都快喘不過氣了……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已經決定好要祈求什麼了嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我的話……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "祈求合格",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是不可或缺的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我有跟哥哥說過吧，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我的志願學校……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟哥哥一樣的，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "椿丘高中。",
        "unit_id": 101131
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n準備考哪間高中、",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我沒說過嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯。",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我想和哥哥",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讀同一所高中。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘖～",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明我是打算考上後再告訴哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓哥哥嚇一跳的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以我的學力偏差值來說，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n合格機率是一半一半……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我沒什麼",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "自信能考上。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果我考上的話，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥要給我獎勵的",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「魔法」喔。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們約好了喔，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "非常努力用功喔☆",
        "unit_id": 101131
    },
    {
        "type": "still",
        "still": "137900401"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我無論如何都想跟哥哥念同一所學校，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n自那之後",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就一直拼命努力。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在學習遇到瓶頸時，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥在旁邊教我……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的讓我很安心。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之前我也為了模擬考的成績沮喪，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n差點哭出來過……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是因為哥哥的鼓勵，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我才終於",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "快達到",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "合格線了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……♪",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要是沒有哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我一定會在中途就放棄了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論我多麼用功……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不安也沒有消失。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 101131,
        "voice": "vo_adv_1379004_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能考上嗎……？",
        "unit_id": 101131
    },
    {
