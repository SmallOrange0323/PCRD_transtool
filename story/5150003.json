    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "涅比亞在蘭德索爾的城鎮中到處逃竄。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n除了有愛梅斯、帆稀、{player}在追趕著她外，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再加上──"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "喂，",
        "unit_id": 312,
        "voice": "vo_adv_5150003_000"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "妳聽說了嗎！？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n有小妖精在城鎮裡到處飛耶！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "不是說抓到她的話，",
        "unit_id": 1212,
        "voice": "vo_adv_5150003_001"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "王宮會賜予獎賞嗎？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n聽說是",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "「招待享用王宮晚餐☆」哦！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我",
        "unit_id": 5312,
        "voice": "vo_adv_5150003_002"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "剛才有看到妖精哦～！",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好～",
        "unit_id": 5412,
        "voice": "vo_adv_5150003_003"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們這就呼朋引伴一起去抓她吧！",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n得先準備好",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "捕蟲網才行！",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "變得好像是在舉辦團體活動呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "受不了……",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可竟然把騷動鬧得更大。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣不是舉國都在慶祝狂歡嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "王宮晚餐啊～",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是有貪吃佩可的作風，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "又聰明的好方法呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣子不光是公會，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "又能請城鎮居民他們幫忙，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n況且",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還能讓這個狀況變得很有趣～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能增加人手，我非常歡迎。",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟可以減少涅比亞逃脫的退路。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要抓住她的可是我們哦。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不能搶在任何人前面先唸她個幾句",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就讓我無法氣消啊！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "愛梅斯，",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來妳也會那樣子發飆啊～♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓妳見笑了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不小心就",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "情緒化起來了……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我覺得表現出情緒起伏比較好哦～♪",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對吧，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你也是這麼認為的吧～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦，",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是這樣嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不過，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "事到如今我也沒辦法改變已經扭曲的個性了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "假如你硬是想看的話，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次我就在夢中",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只讓你一個人看吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好心機哦～",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說得我好像平時很聒噪一樣呢。",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該不會",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還隱約記得",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我在夢裡對你嘮叨的模樣？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我就多加注意一下吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這不重要，",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在要緊的是涅比亞啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我們得快點抓到她才行。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子現在在哪裡？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我看看哦～",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她人在鬧區。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "竟然會在這麼空曠的地方……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n奇怪？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且只有這裡景觀沒改變耶～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這很明顯是在引誘我們。",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她肯定弄了一堆惡作劇，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "準備就緒了吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟靠龍眼沒辦法連她設了什麼機關也看清啊～",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n啊，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她笑得好開心哦。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n看來她也知道我們在看她呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來她對自己的惡作劇很有信心吧。",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果單純這樣和她玩起你追我跑，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也只是飛蛾撲火，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "落入她設計好的惡作劇之中嗎……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……既然如此。",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳要用什麼方法呢？",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀──",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想請妳去找一個人。",
        "unit_id": 131711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "找到了！",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次妳休想逃，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐，妳可終於來了啊。",
        "unit_id": 190912,
        "voice": "vo_adv_5150003_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳讓我等太久啦。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "害我無聊到設了一堆機關♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就照事前討論的，",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們三個一口氣上～！",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的！",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哼哼！",
        "unit_id": 190912,
        "voice": "vo_adv_5150003_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這就是所謂的",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "夏日妖精撲火！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡就用亂流──",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──嘿",
        "unit_id": 131711,
        "voice": "vo_adv_5150003_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咻。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的猜中了呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什麼？",
        "unit_id": 190912,
        "voice": "vo_adv_5150003_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n避開亂流了！？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還沒結束呢！",
        "unit_id": 190912,
        "voice": "vo_adv_5150003_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "接著是──",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用風拖住我們之後，",
        "unit_id": 131811,
        "voice": "vo_adv_5150003_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再從上面倒水下來對吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真遺憾，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們不會上鉤的～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳說什麼……！？",
        "unit_id": 190912,
        "voice": "vo_adv_5150003_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那",
