[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尋寶結束後，{player}和珠希\n一邊仰望美麗的星空一邊在海灘上談笑風生。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "星星就好像要落下了一樣啊喵……",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從那座恐怖的洞窟到這裡，",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "竟然有如此美麗的景象映在眼前……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "警備員",
        "words": "喂～",
        "unit_id": 511,
        "voice": "vo_adv_1079004_002"
    },
    {
        "type": "dialogue",
        "name": "警備員",
        "words": "那邊的幾位，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "警備員",
        "words": "這種時候待在那邊是很危險的哦！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "欸……",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是來巡視的警備隊先生嗎？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "應該是待在晦暗的地方久了，",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "都被提燈弄得暈頭轉向了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺，",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "提燈的光暈",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是不是變得越來越大了喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "眼睛，",
        "unit_id": 107911,
        "voice": "vo_adv_1079004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "都要睜不開了喵……！",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "和我到海之家一起來幫忙吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然我是被前輩拜託過去支援的，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過取得銷售額最高的海之家",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聽說會得到額外獎勵呢……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是能請{player}來幫忙的話，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n取得銷售額第一名應該就不是夢了吧！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們要把店裡的東西全部銷售一空喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我對這間海之家太過正統的菜單感到相當介意呢喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "必須要為這個菜單添加品項才行喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這邊果然",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是要讓我助攻一波，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "加上一項鯛魚燒才是啊喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "準備OK！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店面開張了喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……太奇怪了。",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒的銷路完全不行啊喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個紅豆餡和皮的黃金比例哪裡不對了喵！？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這邊的海之家，有賣鯛魚燒哦～",
        "unit_id": 1231,
        "voice": "vo_adv_1079004_015"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n真的毫無季節感呢～",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "夏日的海邊還吃鯛魚燒簡直是懲罰吧。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唔唔……",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然很不想承認……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但確實",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在炎炎夏日下賣鯛魚燒似乎有點不太合適呢喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "和其他店面賣一樣的東西感覺也沒有什麼意義啊喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只有在這間海之家才吃的到的味道，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道就沒有那種料理嗎喵！？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喔喔！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聽起來挺有意思的喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "確、",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "確實是呢！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即使是不被常識所限制的料理也無所謂的喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼事不宜遲，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趕緊來開發會令大家驚喜的甜點吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我果然，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是比較想推出和貓相關的甜點呢喵～",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我還是不想把鯛魚燒排除出去啊喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在炎炎夏日吃紅豆餡熱呼呼的鯛魚燒，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n感覺還比較像是懲罰遊戲呢喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這點",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想到辦法了喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n如果是鹹味的話不知道行不行得通！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓它嚐起來像是飯糰那樣輕食般的鯛魚燒！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其名為，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「魚罐頭鯛魚燒」！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣貓一定會很喜歡，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人們也一定會喜歡的喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來吧，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請品嘗喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "欸……",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這味道對人類來說是不是太前衛了一點啊喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就算貓很喜歡但是人可能就不太合適了……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那還是換下一個提案吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然說到夏天就是冰品了！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n提到冰品那就是刨冰了！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "刨冰果然還是以甜品為主吧……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要製作香味更豐富，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "日本人所熟知的味道，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n使用醬油和鰹魚露的",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「貓飯刨冰」！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "依據不同地區，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "調味和配料也會有所變化，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這些部分就讓客人親自嘗試吧喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這可是我的自信之作呀喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "絕對會大賣的喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你嚐過",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肯定會被這美味所嚇到的喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵？",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幹嘛在品嚐之前擺出一副蒼白的臉色啊喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然口味喜好因人而異，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但顏色不怎麼樣……？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "確、",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_036"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "確實是呢！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完全就是不起眼的茶色刨冰了喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想要強調出貓的個性出來啊喵—！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想要做出一個，讓大家對這間海之家印象深刻，",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那樣的美味",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "又能聯想到貓的甜點出來呀喵—！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 104632,
        "voice": "vo_adv_1079004_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那這樣我們回到初心，",
