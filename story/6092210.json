    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "この前の呪文詠唱？　",
        "unit_id": 113311,
        "voice": "vo_adv_6044210_000"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ああ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "トゥインクルチャージ！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "のやつ？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nアレはやっぱ",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "魔法少女らしさを出すためのポイントなんですぞ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "あるとなしじゃ全然違うんだから～。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "君も分かるでしょ？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "うんうん、",
        "unit_id": 113311,
        "voice": "vo_adv_6044210_001"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "魔法少女のパートナーとして理解が深まってきましたな～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "それじゃあ君もそろそろ決め台詞の一つや二つ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "言ってみる？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ナナカちゃんが考えてしんぜよう！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "うん！　",
        "unit_id": 113311,
        "voice": "vo_adv_6044210_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "キャラになりきるための儀式って言えばいいのかな～？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "そういう、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "なりたい私になるための呪文みたいなものなのだよ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nそれこそ魔法少女以外なら……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "アイドルとかやったら面白いかもね！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ほほー、",
        "unit_id": 113311,
        "voice": "vo_adv_6044210_003"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "なるほど。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "確かに女装系魔法少女という枠もありえるね。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ていうか私たちでコンビ組んじゃえば",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "むしろありなんじゃない？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "……よし、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "これはしっかり作戦会議しよう。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "魔法少女タッグ結成だ！",
        "unit_id": 113311
    }
]