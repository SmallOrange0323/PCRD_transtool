    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲持續專心畫著漫畫。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n原先在一旁幫忙的【暮光流星群】成員們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n都外出處理公會的工作了。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一個人畫漫畫",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果然有點寂寞……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不能因此就停下畫筆……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──需要幫忙的人",
        "unit_id": 105311,
        "voice": "vo_adv_9005013_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是妳嗎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n什、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "什麼……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛才流夏……",
        "unit_id": 105311,
        "voice": "vo_adv_9005013_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛才我遇到【暮光流星群】她們，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n流夏說有人需要幫忙，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "叫我們過來這裡一趟！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳是在為那傢伙製作禮物對吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們前來仗義相助是也！",
        "unit_id": 103011,
        "voice": "vo_adv_9005013_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一同製作",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要獻給將軍的進貢品吧～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我知道我該擔當什麼角色。",
        "unit_id": 100811,
        "voice": "vo_adv_9005013_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來吧，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "儘管描繪美麗的我吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511,
        "voice": "vo_adv_9005013_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "畫什麼都可以對吧？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "什麼都可以……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "請包在空花身上～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105511,
        "voice": "vo_adv_9005013_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我應該是",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫不上什麼忙……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只要能讓前輩開心……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會努力的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳們",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "各位……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那就拜託妳們了……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "事不宜遲，",
        "unit_id": 103011,
        "voice": "vo_adv_9005013_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看我用忍法‧",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "千手觀音之術",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來把手變多！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來人呀，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請站到我身後把手伸出來～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那樣反倒浪費一名人力吧……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "…………",
        "unit_id": 100811,
        "voice": "vo_adv_9005013_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "紋風不動……",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "完全進入模特兒狀態了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我真的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "非畫這個人不可嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "像這種感覺……",
        "unit_id": 104511,
        "voice": "vo_adv_9005013_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這裡再粗一點……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊嗚嗚……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "再翹高一點……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流口水～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳在畫什麼！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說妳到底在畫什麼！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哇哇哇……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呀嗚……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不行，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在不是變成小嬰兒的時候……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "步未小姐、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "步未小姐的狀況呢……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105511,
        "voice": "vo_adv_9005013_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這裡的背景……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我都",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫妳塗黑好了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然後還有，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩的髮際線要再更低一點，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n肩寬",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要再更窄一點，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "披風內裡的布料質感要──",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "檢查得真仔細……",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但坦白說，我甚至不知道她人在哪裡……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯！",
        "unit_id": 105311,
        "voice": "vo_adv_9005013_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然有那個意願，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我們果然還是",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不擅長這種工作啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那妳們還來幹什麼啦～！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005013_018"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在雪菲迴盪的哀號聲中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n漫畫的繪製姑且還算有點進度。"
    }
]