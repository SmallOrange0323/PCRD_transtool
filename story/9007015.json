        "words": "錯覺！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "原來如此……",
        "unit_id": 126511,
        "voice": "vo_adv_9007015_030"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那些景色，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就是各位至今累積的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "回憶呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "萊拉耶爾殿下？",
        "unit_id": 126411,
        "voice": "vo_adv_9007015_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "您怎麼了嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒事……",
        "unit_id": 126511,
        "voice": "vo_adv_9007015_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只是他們的表情",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看起來實在好開心……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "讓我",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不禁有點",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嫉妒起來了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果",
        "unit_id": 126511,
        "voice": "vo_adv_9007015_033"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也能像他們那樣一同聊起共同的回憶，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不知有多好……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳放心吧，",
        "unit_id": 105812,
        "voice": "vo_adv_9007015_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萊拉耶爾小姐♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "貪吃佩可公主……",
        "unit_id": 126511,
        "voice": "vo_adv_9007015_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天是5.5周年的紀念日。",
        "unit_id": 105812,
        "voice": "vo_adv_9007015_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而在這之後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像今天這樣值得慶祝的日子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會不斷再次到來的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今後我們就一起",
        "unit_id": 105812,
        "voice": "vo_adv_9007015_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "造訪各式各樣的地方，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n做很多有趣的事情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃很多好吃的東西……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後",
        "unit_id": 105812,
        "voice": "vo_adv_9007015_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到了紀念日的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再來跟大家一起回顧我們創造的這些回憶吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n約好囉♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_9007015_039"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也對。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "總有一天，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也能像各位一樣……",
        "unit_id": 126511
    },
    {
