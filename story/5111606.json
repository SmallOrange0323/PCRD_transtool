[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尾狗刀找諾維姆出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n說想制定下次戰鬥的作戰計畫。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂～",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你在嗎～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n找我說要制定下次的作戰計畫的人不是你嗎～？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "嗨，",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "\n抱歉讓妳久等了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "應該沒生氣吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "希望妳那俏麗的眉間，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "沒有擠出皺紋。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒事，",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我沒等很久……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n等一下，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你在說什麼啊！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "我在說你很俏麗呀。",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "妳的雙眸，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "\n比世上任何寶石都還要美喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……我知道了，",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳是似似花吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀絕對不會說這種話！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "比預想中還要容易露餡呢。",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_005"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我還期待若變身成他，說些肉麻的台詞，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "就能夠看到",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "妳有趣的反應。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "雖然說稍微遲到是我不好。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n但趁本人不在的時候，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "玩這種惡作劇",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也太惡質了吧～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n要是我被當成性騷擾大叔，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳要怎麼賠我？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這次是真的尾狗刀，",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "肯定沒錯！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n有確實感受到那種",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不想跟麻煩扯上關係的氣場！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳這樣講也挺傷人的～",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "算了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟是事實，我也沒辦法否認。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_009"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "看來你們彼此之間，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "有著深厚的信任。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "這次我稍微提高一下難度吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n我再變身成他一次，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "這一次……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "還附帶分身。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "……唔哇！？",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "\n這是怎樣，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？",
        "words": "有好多個我！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？",
        "words": "拜託饒了我吧……",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？",
        "words": "\n眼前所見全都是跟自己長得一樣的人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？",
        "words": "這根本是恐怖片吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "一、",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "一個尾狗刀、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "兩個尾狗刀、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好多尾狗刀！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n而且長得一模一樣，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這變身能力真厲害……！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "先不論長相，",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "原來從旁人來看，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "\n我講話這麼有氣無力嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "我覺得，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "應該再稍微……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "俐落一點啊～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀？？？",
        "words": "算了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "而且，",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_014"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這次連個性也有好好模仿。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n不過，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這種花招，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是騙不了我的眼睛的！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真正的尾狗刀……",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_015"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是他～！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "答對了～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真虧妳認得出來呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "……真令人驚訝。",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_017"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n我還很有自信這次能騙過妳的說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "妳是怎麼知道他是本尊的？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "當然是",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_018"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "靠直覺啦！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我只是選了我覺得最像尾狗刀的尾狗刀！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_019"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還是一樣隨便耶……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果真的跑出會變成我的敵人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n到時候拜託妳選得謹慎一點喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "包在我身上！",
        "unit_id": 106114,
        "voice": "vo_adv_5111606_020"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n最懂尾狗刀的人",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是我！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n不管出現什麼樣的冒牌貨，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我都一定認得出來！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_021"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "相當值得參考。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n如果面對的人與變身對象之間有著深厚情誼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n那我的變身能力有很高的機率會被拆穿。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我倒是完全不懂這道理～",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_022"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我不認為",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我能靠那種不明確的方式，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "來區辨本人跟冒牌貨。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "是這樣嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_5111606_023"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我覺得如果是你，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "就算我變成諾維姆，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n你也能輕易地認出來喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……真是的，",
        "unit_id": 106211,
        "voice": "vo_adv_5111606_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳太看得起我了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，諾維姆他們重新召開了作戰會議。"
    }
]