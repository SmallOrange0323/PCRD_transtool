[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好堅硬的裝甲……！",
        "unit_id": 127511,
        "voice": "vo_adv_5128323_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很討厭呢！",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快看，",
        "unit_id": 127611,
        "voice": "vo_adv_5128323_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對方引以為傲的裝甲也開始產生龜裂了。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還差一點就能粉碎它了……",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "問題在於能否持續攻擊到那時候。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是說在決勝負前，",
        "unit_id": 127511,
        "voice": "vo_adv_5128323_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要謹慎確實地進攻……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種事",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我以前做得可多了。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n穩健的戰術",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是我擅長的領域，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交給我吧。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會讓你們見識",
        "unit_id": 127511,
        "voice": "vo_adv_5128323_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【王宮騎士團】的前副團長，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可不是白當的。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我就放心了。",
        "unit_id": 127611,
        "voice": "vo_adv_5128323_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "各位，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "準備好了嗎？",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來就是傾注全力的戰鬥了。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還差一點就能粉碎對方的裝甲。",
        "unit_id": 127611,
        "voice": "vo_adv_5128323_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就瞄準那個瞬間，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一口氣解決掉它吧！",
        "unit_id": 127611
    }
]