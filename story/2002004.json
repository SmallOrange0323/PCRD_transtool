        "voice": "vo_adv_2002004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卑賤之人都說出口了嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n突然變得強硬了呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小女孩。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和那邊的少年關係相當好呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵呵，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愛的力量還真是偉大呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n愛啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是能將無牙之兔變為獅子的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這才不是愛！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是在下對主人所表現出來的忠心！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別害羞別害羞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人生苦短，戀愛吧少女♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，妳在看哪裡！",
        "unit_id": 104311,
        "voice": "vo_adv_2002004_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳的對手是我們！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "（呿……寡不敵眾嗎，真是可惡。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是要讓包圍公會小屋的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【王宮騎士團】的部下們衝進來呢？）",
        "unit_id": 107111
    },
    {
        "type": "still",
