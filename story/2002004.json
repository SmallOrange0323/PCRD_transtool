    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……果然也是熟人呢。",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經差不多習慣了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "Hello，咲戀大小姐。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，還是我該稱呼妳前副團長呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "克莉絲提娜……",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我剛才趁路過順便",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n向其他的【王宮騎士團】團員\n打聽到了情況。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "團長對妳橫斷專橫的暴行感到相當憤怒的樣子唷？",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今天可以看在我的面子上，就此撤退嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我無所謂。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "老實說，雖然打得還不太過癮……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但至少我已經達成最基本的目的了。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然在這裡打倒包含妳在內的所有人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也挺有意思就是了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別看我這樣，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也很喜歡【王宮騎士團】。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還想保住現在這個位置。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果對妳出手的話，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我在【王宮騎士團】可是會被排擠的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳真是受人愛戴啊，前副團長……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了以後的樂趣……",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我現在就暫時忍耐吧，這也是歌頌人生的秘訣",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好吧，今晚我就撤退。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正好也有些事情想調查。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇……！？",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不要嚇壞小朋友哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這件事不能就這麼過去。",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我會向【公主騎士】的高層報告。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不能一直這樣橫行霸道呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會好好記住的，大小姐。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼我就先告退了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天度過了久違的愉快時光！",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n下次再一起玩吧，各位先生女士們♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "告辭了。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再會……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，站住！",
        "unit_id": 104311,
        "voice": "vo_adv_2002004_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳以為這樣大鬧一場之後，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還能全身而退嗎！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，別再深究了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002004_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n她都說要放過我們了，這樣就好。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比起這個，還是先讓我看看妳受傷的地方。",
        "unit_id": 101011,
        "voice": "vo_adv_2002004_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織也是，來包紮一下傷口吧～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好的～。",
        "unit_id": 101711,
        "voice": "vo_adv_2002004_052"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過我沒受什麼傷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看來那個人有手下留情唷？",
        "unit_id": 101711,
        "voice": "vo_adv_2002004_053"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "她如果拿出真本事的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我和真琴現在都已經上天堂了吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的假的？",
        "unit_id": 104311,
        "voice": "vo_adv_2002004_054"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那樣還叫手下留情嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟敢小看我……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個人的確異常地強大呢……",
        "unit_id": 101011,
        "voice": "vo_adv_2002004_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她只用一隻手來對付真琴跟香織對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～總覺得有些不對勁。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳知道些什麼嗎？那個……",
        "unit_id": 101011,
        "voice": "vo_adv_2002004_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感覺妳和【王宮騎士團】",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有些淵源的樣子。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，我會好好解釋的，請安心",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是，在這之前……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳沒事真是太好了，鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳這孩子，別讓人這麼擔心啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大、大小姐～！",
        "unit_id": 102511,
        "voice": "vo_adv_2002004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好好好、好可怕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "光是今天，",
        "unit_id": 102511,
        "voice": "vo_adv_2002004_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就經歷了好幾次讓人難以置信的生死關頭！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、我都快要瘋了啦～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好乖好乖，真是可憐的孩子……",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起，我來遲了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然不知道發生了什麼事，但是有種討厭的感覺……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明和平了好一陣子，最近卻到處都很不對勁。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "傷腦筋。",
        "unit_id": 102811,
        "voice": "vo_adv_2002004_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我可不希望這不穩的情勢讓孩子們的未來蒙上陰影。",
        "unit_id": 102811
    }
]