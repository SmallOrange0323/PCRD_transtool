        "voice": "vo_adv_2002004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她的動作亂了，現在正是機會！",
        "unit_id": 104311,
        "voice": "vo_adv_2002004_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n給她致命一擊，香織！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好的～！",
        "unit_id": 101711,
        "voice": "vo_adv_2002004_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要結束囉，吃下我這記超強攻擊吧～☆",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呃……",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呿，什麼啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我的『絕對攻擊、絕對防禦』失效了！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒辦法完全避開，只能防禦了！",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真火大，這套衣服可是我很喜歡的耶！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "（怎麼回事？",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n從後面來……是那個小傢伙丟長槍過來嗎？）",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "（平常的話，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該能精準避開這種出奇不意的攻擊呀？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "玩得太超過，所以反應變遲鈍了嗎？）",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "（還是說，妳……",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有些什麼與眾不同的地方嗎？）",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇……？",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那是什麼眼神？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看、看起來不像是有理性的人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是人啊 。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n慾望強烈，不論何時都是臣服在快樂底下的奴隸。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但還真是有趣啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看起來只是個單純的小姑娘……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道說像我或是『陛下』一樣，是個特別的存在嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，還是說只是偶然呢？",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n剛剛會受到那記出奇不意的攻擊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說不定只是我太大意了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯算了，只要調查一下就知道了。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳過來這裡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我克莉絲提娜來好好地檢查一下。",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "切開妳的五臟六腑，看清楚妳的全部♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主，",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您是來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "保護在下的嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可以。",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是幾乎一點戰鬥能力也沒有哦。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被那種危險人物盯上的話，",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就糟糕了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也許會被砍傷、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是被殘忍的對待！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真過分啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2002004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我有點受傷囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "照妳這說法",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不就好像我是壞人一樣嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚哇？",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您強化在下了是嗎……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "託、",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "託您的福總算得救了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n老實說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才差點要站不穩了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已經準備好，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "重新戰鬥了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "放馬過來，",
        "unit_id": 105911,
        "voice": "vo_adv_2002004_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卑賤之人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要有主人的加護在，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿就不會輸！",
