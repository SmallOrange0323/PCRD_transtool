        "voice": "vo_adv_2002004_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n聽說【哞哞自衛隊】保護了妳，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
