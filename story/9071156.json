    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要能覺醒的話",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種對手根本不算什麼！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可不是辦不到哦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是沒這個必要而已！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511,
        "voice": "vo_adv_9071156_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是能那麼簡單就覺醒的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就不用這麼辛苦了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起這個，",
        "unit_id": 106611,
        "voice": "vo_adv_9071156_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大妳那邊如何？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n看妳擺出一副高高在上的樣子，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但妳才是身手退步的那邊吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_9071156_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳說得沒錯。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n跟長老他們借來的力量",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "似乎不能使用了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真的有點退步了呢……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那也就是說……",
        "unit_id": 106611,
        "voice": "vo_adv_9071156_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在正是大好機會！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈──哈哈！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些時候的怨恨，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該來發洩一下了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳這個劣化的混帳老太婆老大，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "納命來……！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊、喂，",
