        "voice": "vo_adv_9071156_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我在剛才的戰鬥中",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經把力量用完了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喂～",
        "unit_id": 106711,
        "voice": "vo_adv_9071156_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別來打擾我們說話呀。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
