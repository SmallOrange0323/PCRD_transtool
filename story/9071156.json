        "voice": "vo_adv_9071156_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫啊啊啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n剛才的魔物！？",
