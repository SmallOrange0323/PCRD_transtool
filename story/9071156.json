        "voice": "vo_adv_9071156_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳後面！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
