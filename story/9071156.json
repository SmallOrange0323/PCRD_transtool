        "voice": "vo_adv_9071156_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是說祈梨，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我剛剛沒有聽得很清楚……",
        "unit_id": 106711
    },
