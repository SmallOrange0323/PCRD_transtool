    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳覺得如果是現在的我，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "即使妳已經用盡了力量，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也還是能贏嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫？",
        "unit_id": 106611,
        "voice": "vo_adv_9071156_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是啦那個……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 106511,
        "voice": "vo_adv_9071156_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒錯沒錯就是這個，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種感覺。",
