        "voice": "vo_adv_5137068_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n回到原本的世界了，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個嚮導小妖精",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有跟你說這件事嗎……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是？",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "道謝……",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n難道說，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是跟我道謝？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不客氣。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也要跟妳道謝……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n非常謝謝妳！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "草野優衣……",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n為什麼，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連妳都進來了……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我想謝謝妳",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幫了我們……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n說不定暫時",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒辦法回來這邊了，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以想在那之前道謝……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不好意思。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣啊……",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "路上小心喔，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n如果有什麼事……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就跟我說一聲。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一路順風。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我們就告辭了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……草野優衣。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是！",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳過來這邊。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n耳朵湊過來。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "抱歉。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你可以稍微",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "離遠一點嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "湊、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "湊過來了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……騎士先生他，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n給妳「那時候」的答覆了嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「那時候」的……？",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳在前往【憤怒‧軍團】據點的船上，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n向騎士先生",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "傳達了某件事吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n難道，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳是指──",
        "unit_id": 100213
    },
    {
        "type": "still",
        "still": "513706801"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "告……",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n告告告",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "告白的……！？",
        "unit_id": 100213
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼厄莉絲",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會知道這件事？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n當時明明沒有任何人在旁邊才對……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這種事情怎樣都好吧。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "快回答我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才不是怎樣都好……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那件事……",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不重要。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為狀況，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和那時候已經完全不同了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在重要的是，",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "去尋找雪菲",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還有",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "消失的人們。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……而且……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我覺得自己沒有資格因為得不到答覆而著急。",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會等他。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這樣啊。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "草野優衣。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n妳接下來要跟騎士先生去冒險，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n跟他之間的回憶一定又會增加吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後……",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一定會更加被他吸引。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………！",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那只是妳的自滿。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就算回憶增加了，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我來說也微不足道。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我比妳更了解騎士先生，",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是妳完全比不上的程度。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "比方說──",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊嗚！？",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……剛、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才的是……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是餞別禮。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然微不足道，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不過妳就拿去吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不。",
        "unit_id": 129011,
        "voice": "vo_adv_5137068_040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼事都沒有。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯、",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我只是有點站不穩而已。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只有一瞬間……",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_042"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然只有一瞬間，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但剛剛……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我「看到了」。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不對，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是「流入我的腦中了」……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這就是……",
        "unit_id": 100213,
        "voice": "vo_adv_5137068_043"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n厄莉絲一直以來看見的……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「記憶」……！？　",
        "unit_id": 100213
    }
]