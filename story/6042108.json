    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ありえない。",
        "unit_id": 110911,
        "voice": "vo_adv_6038108_000"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "メルクリちゃんたち、ありえなくないです？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nうちらのプレゼン悪くなかったのに！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "で、ちなみに先輩的には",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nあの三つの企画案でとりわけどれがきゅんきゅんファイヤー？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あー、",
        "unit_id": 110911,
        "voice": "vo_adv_6038108_001"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "うん、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "自動的に映え散らかすって発想自体は良きですよね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nでも商品化して爆発事故とか起こしたら信用問題じゃないですか。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ま、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あの子「ちゃんズ」の人なんで、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なかよし部とは無関係ですけど。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "わかりみ！　",
        "unit_id": 110911,
        "voice": "vo_adv_6038108_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "クロエ先輩、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "デザイナーとしてのセンス光ってますもんね！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "店員としても、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "お客目線の正直コメとかわりとアリだと思うけどなー。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ってなると、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "足りないのは商才だけ……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いや、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "致命的か。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "駄目ですね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "えっ、",
        "unit_id": 110911,
        "voice": "vo_adv_6038108_003"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "おしゃべりチエルちゃん？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ですよね、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "さすが先輩分かってる！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あの子はうちら三人が総力を結集して生んだ自慢の逸品ですからね！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いやあ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "アレを選んでもらえてプロデューサーとして鼻が高いですよ！",
        "unit_id": 110911
    }
]