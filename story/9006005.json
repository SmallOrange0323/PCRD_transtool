    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}的mimi收到了訊息。"
    },
    {
        "type": "dialogue",
        "name": "mimi",
        "words": "今天是和花凜在阿斯特朗傳奇相遇的日子。",
        "unit_id": 3
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，經由mimi被佳凜約出來的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了某個住宅區。"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "謝謝你來這一趟。",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_000"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你也收到",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那個通知了吧？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒錯，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_001"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就是這麼一回事。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n今天",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是你和我相遇的",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "值得紀念的日子！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你還記得嗎？",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_002"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n我和你",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "初次見面時的情景。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "後來，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_003"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "為了想辦法和你取得聯繫，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n我註冊了阿斯特朗傳奇……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n當天就找到你了呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "呵呵，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "當時滿辛苦的呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "但",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_004"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這對我來說",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是相當重大的事情。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "透過這個遊戲，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我遇見了許多很有意思的人。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "所以，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_005"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我真的很感謝你",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n和這款叫做阿斯特朗傳奇的遊戲喔。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "即便如此，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_006"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "也很難找到",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n像你這樣有趣的人……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "怎麼樣？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你有沒有意願",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "現在就到敝公司來……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣啊……",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_007"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "雖然很遺憾，但也沒辦法呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不過，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "真的好神奇呀。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "無論是在阿斯特朗傳奇裡面還是外面，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_008"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "只要待在你身邊",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就能遇見很有趣的人呢……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這已經",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_009"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "可以稱作是一種天賦了呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你搞不好",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "比我還有",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n獵人頭的天賦呢！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "認識我之後，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_010"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你的人際關係是不是還在不斷拓展呢？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "如果有什麼有趣的人才，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "要介紹",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "給我哦♪",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那麼，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_011"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "工作上的事就先聊到這裡吧……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "如果像我一樣從事挖掘人才這種工作，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n就會知道緣分是很不可思議的。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "意志堅強的人、",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_012"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "溫柔體貼的人……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "擁有這些特質的人",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "好像會",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "互相吸引。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "而",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_013"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣交織而成的羈絆",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "會昇華周圍的人的心，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "並吸引著他們……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我認為你很特別，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "足以成為這個起點。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "今後",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_014"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "遇見更多的人",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "並互相影響的話，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "世界就會",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "朝著快樂有朝氣的方向發展。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我是不是",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_015"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "說得有點誇張了呢？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "呵呵，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不好意思，說了奇怪的話。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就是這樣……",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_016"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n這裡即將要舉辦",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "志工撿垃圾的活動。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你願意一起參加",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "讓世界變得更好的活動嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "呵呵，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_017"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我就知道你會這麼說。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我已經準備好手套和垃圾袋了，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "請收下♪",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那麼，",
        "unit_id": 118531,
        "voice": "vo_adv_9006005_018"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "從今以後……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我們也一起努力讓這個世界",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "變得更快樂有朝氣吧！",
        "unit_id": 118531
    }
]