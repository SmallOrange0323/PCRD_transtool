[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在和怜一對一對決的幾天後，\n{player}被怜叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這邊這邊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不好意思突然叫你出來。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想要快點完成那個約定。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說什麼事情……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你竟然忘記了這麼重要的事？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真是的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我和你之前不是對決了嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我說如果你贏了我，你說什麼我都聽你的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我還沒聽到你的願望，才利用機會把你叫出來。",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，快點決定是什麼願望――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好刺眼！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n怎麼回事，這道光……！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是……之前的！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯！ 難道……！",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦……？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我才在想這個背影好像在哪見過，果然是你啊。",
        "unit_id": 100332
    },
    {
        "type": "still",
        "still": "100300801"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你好啊。來散步的嗎？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也是喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……看你那麼驚訝，怎麼了嗎？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n有什麼看不習慣的東西……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊，原來如此。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是我的愛馬，馬倫哥喔。請多指教。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想說今天帶這些孩子來散步，",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以就來公園了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然看到附近的公園出現馬，還是會嚇一跳呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過讓牠們在外頭走走，並沒有什麼問題喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也可以騎馬在大道上奔跑喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道說，你對馬感興趣？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "機會難得，你要不要騎看看？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這孩子特別安分乖巧，很容易騎喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當然，不會突然說放你一個人騎。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你只是兩腳跨上去。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我來牽著馬倫哥走。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來騎看看吧。我也會在後面推你上去，",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n將那邊的段差做為踏台。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要推了喔……嘿咻！",
        "unit_id": 100332
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實騎上去了呢。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如何？ 騎上去的感想？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，那是當然。你騎在馬上啊。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但只要你能高興的話，我也很開心喔。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒事的。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我有好好地拉著韁繩。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哇！ 馬倫哥！",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不要亂動！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抓緊了喔！",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從馬上摔下來的話會受重傷的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n馬倫哥很快就會安分下來的。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "馬倫哥，你是好孩子所以請你安分一點喔！",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼……？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n平常明明是相當乖巧的孩子……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好了！ 這樣會掉下去的！？",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……馬倫哥。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你是要傷害我重要的人嗎？",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "終於安分下來了。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你能夠明白就好了。謝謝你，馬倫哥。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你似乎也沒事。",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了。",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是你發生什麼事的話……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊！ ",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，不是，剛才說的不是這個意思！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我說你是我重要的人是指……！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你確，確實是我重要的人，",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n該說是朋友，還是……",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是為了讓馬倫哥能夠明白，",
        "unit_id": 100332,
        "voice": "vo_adv_1003008_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我才突然這麼說的！",
        "unit_id": 100332
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我沒，沒別的意思！",
        "unit_id": 100332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "騎馬呀，感覺她完全就是大小姐呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然在「這邊（的世界）」似乎是對那種生活，",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n討厭到要離家出走，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過在「那邊（的世界）」並沒有到那種程度呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為她是有強烈責任感的孩子，就算討厭，",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也有能確實地了解自己立場，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n完成自己該做的事的一面就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從這方面來看，",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在你今後要設法處理這種情況時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她應該會成為你的助力吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，「能做到」這種說法，並不代表她沒有勉強自己唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望你不要弄錯這點。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但有你在她身邊的話，就沒問題了吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也許是我過度操心了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼這次就先聊到這裡，",
        "unit_id": 190011,
        "voice": "vo_adv_1003008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜～拜，下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我又睡著了嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你也正好睡醒……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明在說重要的事，兩人竟然都睡著了……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之前好像也發生過這種事……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，是什麼事呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，是願望的事情啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我會聽從你任何一件要求。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你已經想好要拜託我什麼事了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎麼回事？",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你是希望我教你騎馬嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是剛才我已經教你了……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道我又跟你做了同樣的夢！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……就是說願望已經實現了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼會……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明明做好了無論被要求什麼都可以的覺悟才來的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且反正都要教你騎馬，",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想好好地在現實中教你，而不是夢中。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但如果你對騎馬有興趣，",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那就跟願望沒關係，只要製造一起騎馬的機會就好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比如說這樣……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n兩人一起到哪裡出遊之類的，如何？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "決定了喔！",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n下次我們把行程安排在一起，來騎馬吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好期待啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003008_047"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如此喃喃自語的怜，\n不自覺地微笑著。"
    }
]