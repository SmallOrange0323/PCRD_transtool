        "words": "\n絕對",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不能讓魔物搞砸！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "魔物植物",
        "words": "──嘎喔喔喔喔喔！！",
        "unit_id": 12012
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "擺好架式吧，",
        "unit_id": 130811,
        "voice": "vo_adv_5144323_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
