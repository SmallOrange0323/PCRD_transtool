        "name": "鏡華",
        "words": "包在我身上！",
        "unit_id": 130711,
        "voice": "vo_adv_5144323_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n現在的話和鈴莓小姐的默契，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也是完美無缺！",
        "unit_id": 130711
    }
