        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n《阿斯特朗傳奇》的主要贊助者阿斯特賴亞王國，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n近來抗議事件頻傳，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "不穩定的局勢",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "持續惡化──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──激進抗議分子闖入王宮，",
