        "words": "懷念。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，謝謝！",
        "unit_id": 105811,
        "voice": "vo_adv_1383004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n靠著超棒的白飯和強化之力，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的力量",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "增強了！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個，{player}。",
        "unit_id": 105811,
        "voice": "vo_adv_1383004_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然還是想要一個人去旅行。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然像這樣待在一起真的很開心，",
        "unit_id": 105811,
        "voice": "vo_adv_1383004_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是和我一起行動的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會給{player}添麻煩。",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊。",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我開動了！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……哈姆。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "柔軟。",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又溫暖。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甜甜的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鹹鹹的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好懷念。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──「美味」這件事，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會這麼讓人感動呢……",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "138300402"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "由女神「阿斯特賴亞」所建立，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們這些皇族應當守護的王國。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如今，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然要消失了……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我既無知，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又無力。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒能為王國",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做任何事。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至還逃了出來，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在只能向他撒嬌。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像小孩子一樣哭泣。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使如此，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你──",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個，{player}。",
        "unit_id": 105812,
        "voice": "vo_adv_1383004_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼你明明知道很危險，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還願意和我扯上關係呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……？",
        "unit_id": 105812,
        "voice": "vo_adv_1383004_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為佩可",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快要哭了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105812,
        "voice": "vo_adv_1383004_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒有快要哭！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼可能有那種事呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我只是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子餓得咕嚕咕嚕叫的貪吃佩可啦！",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "138300402"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──一直以來，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你都是這樣。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n待在我身旁，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "率直地向我傳達心意。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的心意與我連結，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把力量分給了我。",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "138300403"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……討厭。",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還真是敗給你了呢，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不想就這樣放棄。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了某天，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能再次──",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和重要的人們",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起同桌吃飯。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我的騎士。",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n等肚子和內心都填滿後，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你會願意聽我說嗎。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關於母國的事，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家的事，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今後的事。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃☆",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……還有，",
        "unit_id": 105831,
        "voice": "vo_adv_1383004_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠告訴你嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說我",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「一直很想見你」。",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還潛藏著對梅莉莎小姐懷恨在心的魔蜂呢。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n護送的馬車",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經先往前面的「門」那裡去了！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "一大群魔蜂",
        "words": "────",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "梅莉莎小姐她們會在適切的地方贖罪。",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n即使如此也打算追上去的話，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就由我來當你們的對手！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也許對她來說，",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在也還是敵人。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是……",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}捏的兩人份飯糰，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被吃光了。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一粒米都沒有剩下。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……梅莉莎小姐。",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對妳來說，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "餐桌是要和哈尼哈尼一起圍聚的呢。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是這樣，",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就足以成為我站在這裡的理由。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為──",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論我所珍愛的人們，",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是幸福的餐桌……",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都由我來守護。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是",
        "unit_id": 138312,
        "voice": "vo_adv_1383004_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜‧F‧阿斯特賴亞。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是繼承了星之女神之名的",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主！",
        "unit_id": 138312
    }
]