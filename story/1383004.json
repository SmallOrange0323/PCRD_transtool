        "voice": "vo_adv_1383004_000"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n《阿斯特朗傳奇》",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "相關的最新消息──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──數天前，「米奈娃的禁錮」忽然解除，",
        "unit_id": 1,
        "voice": "vo_adv_1383004_001"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n原本被困在遊戲中的人們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "陸續甦醒。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n如同前面所報導，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "全世界都為此歡欣鼓舞──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──然而，",
        "unit_id": 1,
        "voice": "vo_adv_1383004_002"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "「禁錮」所造成的經濟損失無可估計，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n聯合國",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "以及國際刑警",
        "unit_id": 1
    },
