[
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "很好！",
        "unit_id": 125511,
        "voice": "vo_adv_5118203_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n攻擊感覺很有效！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "呵呵呵……",
        "unit_id": 17512,
        "voice": "vo_adv_5118203_001"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n真是精采呢。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n就如情報──",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "不，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "實際上對峙後，各位的實力都比已知情報還強大。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "只不過，",
        "unit_id": 17512,
        "voice": "vo_adv_5118203_002"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "我也不是都在隨便揮拳出招。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n你們的行動模式已被我學習起來了。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "誠心感謝幾位提供資料。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "唔～嗯，",
        "unit_id": 125611,
        "voice": "vo_adv_5118203_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "這態度恭敬到有點諷刺呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "看來沒那麼容易解決對手……",
        "unit_id": 125711,
        "voice": "vo_adv_5118203_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "接下來",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "恐怕會發展成更棘手的狀況。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就算那樣，",
        "unit_id": 125511,
        "voice": "vo_adv_5118203_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也只能上了！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "沒問題的，",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "只要我們比剛才再更加努力就好了！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118203_006"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n簡單易懂，很不錯呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我也贊同吉塔的意見喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵，",
        "unit_id": 125711,
        "voice": "vo_adv_5118203_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "說得也是。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就讓我們拚命努力吧。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n努力到讓莫夫再怎麼分析也追不上的地步。",
        "unit_id": 125711
    }
]