[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "～……♪",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚哇，好癢啊！",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "放過我吧～公主？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，不要亂動。",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再忍耐一下吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳的頭髮總是亂糟糟的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家看了～總覺得有點手癢癢的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至少讓人家幫妳順順頭髮。",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟是女孩子呀，不弄整齊一點不行。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚嗚～？",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就算我弄得整齊漂亮也沒用，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "又沒有會多看我兩眼的對象啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "反正",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我一暴走頭髮又會東翹西翹了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算整理好也沒有意義！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳有暴走的計劃嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行唷，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要是做一些太危險的事……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哼。",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n沒關係的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為那是我們【哞哞自衛隊】的工作。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "保護獸人的……夥伴們的安全，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是非常榮耀的工作不是嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是毫無理由地暴走，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也不會為公主帶來麻煩的啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說什麼麻煩……",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n才不是呢，人家是擔心妳唷～？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行呢，",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這麼愛和別人吵架可不好呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是在這雪白的肌膚留下疤痕就不好了。",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不管做什麼都要小心點，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳可不要早死喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是的。",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我們家的孩子們為何",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都這麼血氣方剛呢？還是該說忠於本能呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈！",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那也是優點吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不用在那裡虛情假意的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們這裡沒有人會把真心話",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n憋在心裡不說出來。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n本能萬歲獸人萬歲，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呵呵♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是呀，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但該乖乖安靜了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚哇？",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n喂，怎～麼了霞……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對我有什麼怨言嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哼……",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n少自作多情了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我才不管妳呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想抱怨的是",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不管上午下午晚上都一直在那裡跳舞的蠢蛋！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～……",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n或許跟霞相比，我的確是個笨蛋吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "現在是傍晚了～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不只是早上、下午、晚上，",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也要跳舞跳整個傍晚～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "霞也要來做飯後運動嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跳舞的話，壓力跟煩惱就會全部被拋到九霄雲外了喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，可惡！",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n至少不要再彈奏那個音色過分歡樂的樂器了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我沒辦法專心思考！",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼我們的辦公室",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總是這麼吵鬧！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～不是辦公室，是公會小屋啦～？",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且這裡不是霞一個人的地盤，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n對別人做的事情有意見是很沒規矩的喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "笑著原諒之後，就是好朋友囉～",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好不好～這樣就天下太平了喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳有資格談什麼禮貌嗎！？",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n唯一就不想被妳說而已，在那裡半裸狂跳舞的人！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓、讓人懷疑妳的品行……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～☆",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n其實我比較想穿泳衣耶～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是在這裡會有點冷呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對話根本牛頭不對馬嘴！",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊真是火大，講話有邏輯一點！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好啦、好啦……",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們不要吵架啦～。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對呀。",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要好好相處才行呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哼……",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n既然公會長這麼說就無可奈何了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也很清楚自己的立場。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然是被收留的身分，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才不會白目到在公會內部製造紛爭。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我沒有吵架啊～",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是霞來攻擊我的喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為了和好一起來跳舞吧，",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "看吧，書也丟掉囉～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，我還在看耶！",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才、才剛買的！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣不行，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n根本沒完沒了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這就是【哞哞自衛隊】的風氣。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家得更『拼』才行……",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟在書面上",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家是公會長。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有什麼關係，就這樣吧。",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "又熱鬧又自由又歡樂……♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是……",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然我們的公會小屋很寬廣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是人數也變多了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果擠得像沙丁魚一樣的話，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n大家也會累積壓力的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以呢，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們就去散步吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n順便巡邏一下城鎮吧～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要只是跳舞或是讀書，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_045"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "偶爾也要工作！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對，",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在屋裏跑來跑去的確有點不太好。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "走吧～霞♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇，不要隨便把我抱起來！？",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳不覺得有點裝太熟了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我常被這樣說呢～",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_048"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過獸人不就四海『一家』嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不對，獸人族、人族、魔族跟精靈族……",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n如果大～家都和諧共處的話",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就世界和平啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才不是那麼簡單的事情吧。",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳偶爾也該念念書。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "打開書本的話，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就可以知道這世上人心險惡。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，我看我看！",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_052"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "之前就覺得霞一直都看書看得津津有味呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n拜託告訴我妳推薦的書吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒問題，就借妳傑作吧。",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但或許對妳來說",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "內容有點難懂呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會努力看的～",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_054"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "作為回報，可以偶爾一起跳舞喔？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果我心血來潮的話……",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然妳讓步了，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_056"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果我還繼續固執的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n反而可能換成我被批評沒有常識。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "停止爭吵吧。",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_057"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我有些說得太過分了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不，霞對不起。",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_058"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n被這樣吵鬧，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n妳當然會不耐煩呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳不需要道歉。",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_059"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只因為那一點噪音就無法原諒，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是我的心胸太狹窄了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要聽習慣的話，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我一定會覺得那是很悅耳的伴奏。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也會努力早點習慣【哞哞自衛隊】的。",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_061"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是破壞和諧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n從這裡被趕出去的話我會受不了的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這裡的時間有點長了，",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_062"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很難回到在小巷子中當流浪狗的日子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，我實在懶得動……",
        "unit_id": 101411,
        "voice": "vo_adv_3004001_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們去散步就好了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我回去繼續看書。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不要這樣說嘛～大家一起去啦～",
        "unit_id": 101711,
        "voice": "vo_adv_3004001_064"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天吹的是南南西風，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是從我故鄉吹來的風喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_065"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就這樣和好了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一直擔心妳們的我簡直就像蠢蛋一樣呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過也好，",
        "unit_id": 104311,
        "voice": "vo_adv_3004001_066"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "和平萬歲♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀是呀，",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_067"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n和平『第一』呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好啦走吧～",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_068"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n大家一起去散步。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要手牽手喔，",
        "unit_id": 101011,
        "voice": "vo_adv_3004001_069"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不要走丟了……♪",
        "unit_id": 101011
    }
]