        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家還能動嗎？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有誰卡在異空間的縫隙嗎？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸可以不要說那麼恐怖的事嗎！？",
        "unit_id": 121111,
        "voice": "vo_adv_5085204_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會變怎樣！？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那到底會變怎樣！？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看上去",
        "unit_id": 121011,
        "voice": "vo_adv_5085204_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在場所有人似乎都沒有問題……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就好。",
        "unit_id": 121211,
        "voice": "vo_adv_5085204_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n剛剛那簡直是毫無準備直接上陣呢～",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "干涉無法控制的空間，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我很久沒挑戰過像這樣的難題了。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……雖然如此，妳不是很開心嗎？",
        "unit_id": 121111,
        "voice": "vo_adv_5085204_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦哦，",
        "unit_id": 121211,
        "voice": "vo_adv_5085204_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "空間竟然還有殘留的裂縫。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "凱留，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "小心不要掉進去了。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噫噫！？",
