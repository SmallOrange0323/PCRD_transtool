        "voice": "vo_adv_1285002_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是可是……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是喝了像是麥酒或是讓人心情變好的水，",
