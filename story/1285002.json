    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "結果又是助手先生啊！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你怎麼會在這裡！？",
