    {
        "type": "dialogue",
        "name": "日和",
        "words": "對不起呢！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嚇到你了吧！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為和我預想的時機點不同，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不小心就叫出聲音了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚—……",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定覺得我很奇怪吧……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大會優勝後，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要在騎士先生身邊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "內心深處",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就會雀躍不已呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒事！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我和魔物對戰完",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是很有精神！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……很有精神倒是真的。",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要內心雀躍，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "同時我的體內就會湧現一股力量。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "多虧了這件事，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幾乎不需依靠騎士先生的那力量。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n話說今天，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒靠騎士先生的力量，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是成功打倒了強大的魔物。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這樣子說，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是因為我內心深處雀躍不已，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以才變強嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n還是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實是相反的呢……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該如何確認這個理論，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也不太清楚……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是想要確認一下呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個呢～，",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的內心……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然還是當我沒說！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n抱歉，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼事都沒有！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你問",
        "unit_id": 100111,
        "voice": "vo_adv_1001009_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼事……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是什麼呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好險好險……",
        "unit_id": 100111
    },
