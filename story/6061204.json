[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪她",
        "unit_id": 116011,
        "voice": "vo_adv_6061204_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是個很奇妙的女孩子呢～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n她跟人家的朋友",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "同樣名字，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "給人的感覺也很相似。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您知道些什麼嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "既然王子先生都這麼說了，",
        "unit_id": 116011,
        "voice": "vo_adv_6061204_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那人家就不多問了。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再說，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "少女",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "本來就會有",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一、兩個祕密嘛～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是很棒的情報呢。",
        "unit_id": 116011,
        "voice": "vo_adv_6061204_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不止是外表可愛，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "連內在也很可愛呢～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對了，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次人家就來做些",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "蘋果的點心",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "或布偶吧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "希望她會喜歡～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣啊～",
        "unit_id": 116011,
        "voice": "vo_adv_6061204_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她就跟身為真步真步王國的公主，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n以及【哞哞自衛隊】公會長的",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是一樣的。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "希望可以和她當永遠的",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好朋友～",
        "unit_id": 116011
    }
]