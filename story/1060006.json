[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼哼……♪",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多虧我踏實地練習，",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我覺得我大概能靈活運用",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n『公主騎士』的權能啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只要肯做就一定能做到呢 ♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我現在的極限只能完全控制幾隻較弱的魔物……",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照這樣的話，之後一定能",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n支配更大量的強大魔物。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對～嘛，任何事情都有分階段性的嘛。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然要操控許多強大的魔物",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是不可能的啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣魔物會完全不聽話，還會暴走之類的。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果想要長時間控制強大的魔物，",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魔力跟生命力反而會被用光，最後還會失神之類的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該要慢慢習慣，這可是舉重的要領呢～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果習慣的話，一定更能有效率的操控魔物！",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不讓魔物暴走或讓自己失神失誤，完全支配牠們！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我能成為魔物們的女王……☆",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下也一定會誇獎我的……",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我為此持續練習，非要好好展現出成果不可呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果沒有成果，誰也不會去追溯我的努力過程呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你啊～我跟你說過叫你不要來這裡吧？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛啊，你不會又在找食材了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……你說有傳聞這個森林有可疑的魔物出沒，",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以才來調查的？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在做那種工作呢，嗯，辛苦啦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（嗯～可疑的魔物？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會是在說我在操控的魔物？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（因為被我操控了，所以做出了非常不自然的動作呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "路過的人看到並嚇了一跳之類的？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（這下變成了流言，不更換練習場所不行呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然這個神秘森林有著剛剛好的強弱交集情況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也有魔物分佈在這裡，最適合用來練習啦？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "嘰歐歐歐歐……！",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噫……",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇呀啊啊啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦、咦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魔、魔物……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想事情想得出神，反應就太慢啦！",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙是怎樣，沒看過的造型呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新、新類型？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙就是你剛說的『可疑的魔物』嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦咦！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你打算要戰鬥嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要亂來，你可是個弱雞！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這樣拿著劍……",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會是要保護我吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是笨蛋嗎，這樣子一點都不帥氣啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸……喂～你不要只顧著自己逃跑啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、我嚇到腿軟了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇呀……？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛啊，不要隨便抱我啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你還出乎意料地挺有臂力的呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，就是在這種時刻才需要活用我的能力啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種程度的魔物……看我輕易就能操縱牠！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n哎呀，也就是我……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個魔法？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我能使用類似魔法的東西啊，很厲害吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，你要替我保密喔？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吧，受我支配吧！",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n成為我的奴隸吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "叫我女王大人……☆",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "女王大人……！",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "講話了啊啊啊啊啊！",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，所以這是能理解語言的高階魔物？",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "糟糕，我還沒辦法操縱那麼強大的魔物啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦，還是我應該就用攻擊魔法之類的一刀宰了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "請、請等一下！",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_030"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n我不是魔物，是人類啊！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？啊……",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "仔細一看，好像是玩偶裝？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為森林裡面有點暗，看不清楚，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n害我以為是真的魔物啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你啊～不要那樣嚇人啊？",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底要幹嘛，你是笨蛋嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗄？",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n假裝是魔物嚇路過的人……然後搶走他們掉的行李之類的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新類型的強盜！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "才不是呢，請不要把我跟強盜相提並論！",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_034"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n我只是……看到對魔物感到害怕而哭泣，",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n或發出慘叫聲的女生會感到異常興奮而已！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你只是新類型的變態啊啊啊啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比盜賊還惡劣啊，這個變態！",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "犯罪者！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "請妳再多說一點！",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_037"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n雖然慘叫聲也不錯，但責罵聲更棒……",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "☆",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噁，雖然我不是很了解，但真恐怖！",
        "unit_id": 106011,
        "voice": "vo_adv_1060006_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n比魔物或強盜更恐怖、更噁心！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就用我的魔法讓你飛到宇宙去吧，笨～蛋！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "謝～謝～您～……☆",
        "unit_id": 1614,
        "voice": "vo_adv_1060006_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、呼……！",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到、到底在幹嘛啊，真是？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我完全不懂啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的真是的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果有那樣的變態出沒的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我搞不好真的應該要換練習場所？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，喂……",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不覺得你的工作，好像也順便完成了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "新品種魔物的真實身份，只不過是心理變態啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就這樣跟雇主報告這個事實吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是多虧了我呢，記得感謝我啊！",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊真是的……到底是為什麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不管什麼時候結局都會對你有利呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是不得已啊，真是的。",
        "unit_id": 106012,
        "voice": "vo_adv_1060006_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我又不是特別想要幫你……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可一點都不喜歡你喔？",
        "unit_id": 106012
    }
