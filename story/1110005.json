[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依照慣例，{player}在收到優妮的信後，\n他被叫到了「象牙之塔」來。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，朋友，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "歡迎到我家來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天找你來不為別的。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n首先你就先過目一下這個吧。",
        "unit_id": 111011
    },
    {
        "type": "background",
        "background": "500134"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「那一天，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_002"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "筆者遇難了。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「為了至碧之深淵進行田野調查，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_003"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　我不顧危險，投身冒險——」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「然而前去之路險峻，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_004"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "狂風亂舞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　黑暗的天空中",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "響徹著魔龍的咆哮聲。」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「……的樣子。」",
        "unit_id": 1,
        "voice": "vo_adv_1110005_005"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「畢竟那是好久以前的事了，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_006"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　記憶中有些不鮮明之處。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　然而筆者是位不拘泥過往的女性。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你忘了啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這是第一次遇見你那天的備忘錄喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為我是筆記狂嘛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以會把所有事實原封不動記錄下來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "多少有點加油添醋也是無可奈何的嘛。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要是寫得像去野餐那樣平靜，讀者會膩的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "筆者是重視娛樂效果的女性。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "細節就別在意了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你快點讀下去。",
        "unit_id": 111011
    },
    {
        "type": "still",
        "still": "111000501"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「在拚命地勇猛行軍後，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_010"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "柔弱的我耗盡了全力。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「在威猛的大自然眼前，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_011"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "人類的生命簡直虛無飄渺。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「閉上雙眼，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_012"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "筆者那靜靜地蒙主寵召的身姿，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　猶如聖女般美麗。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「猶如聖女般美麗。」",
        "unit_id": 1,
        "voice": "vo_adv_1110005_013"
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "做什麼。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你不要一言不發就從書面上抬起頭看著我啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不要交互看著文章和我作比較，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n聽話，你快點往下讀。",
        "unit_id": 111011
    },
    {
        "type": "still",
        "still": "111000501"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「筆者的身姿，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_016"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "猶如聖女般美麗。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　不久，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "大概是受她的美貌吸引吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　有位男性像是被她誘惑一般，漫不經心地走了過來。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「種族是人類。",
        "unit_id": 1,
        "voice": "vo_adv_1110005_017"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　雖然沒有騎著白馬，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　不過打扮得還算像個騎士。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「不管怎麼說，他帶來的神祕奇蹟，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_018"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　讓我得以九死一生。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　講白一點，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "就是受他照顧。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "「於是，",
        "unit_id": 1,
        "voice": "vo_adv_1110005_019"
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "這名青年",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　在往後便是與筆者聯名的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮的筆記",
        "words": "\n　那位共同研究者{player}。」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎樣？",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你不要那麼嚴肅地慢慢歪頭啦，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "共同研究者。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "算了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我想你大概懂得差不多了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是時候進入正題了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我弄丟那本筆記了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你現在手上拿的那本",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是我事前用魔法複製的備份，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但原來的那本筆記本，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我怎樣都找不到。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "手邊因為還有一本備份，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以目前是不會對作業造成影響。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話雖如此。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n既喜歡又想要永遠使用下去的東西不見的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有種例行工作會走樣的感覺，實在很不舒服。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽到你先提出這個意見，實在太感激了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "其實我剛剛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一直在想著要如何自然又若無其事地，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n半拐半騙把你捲進我這場搜索活動呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "噗哈哈哈哈哈！",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊～超有趣的。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "先不管我臨時起意的玩笑話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n讓我們馬上開始這場搜索活動吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "放心吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我還是有一些頭緒的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我今天有點事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "午休時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "去了一趟新校舍。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "當時因為一些奇妙的事，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n得知了教務主任修女希爾達是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n接吻時不閉眼的人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我便打開那本筆記本記下了筆記。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "後來，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "當我回到這間房間時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就發現筆記本不見了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是在這段時間的某處遺失的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，出發尋找吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟我來，同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乍聽之下確實是挺有效率的提案。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而你先聽我解釋一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然我尚未得到生物學上的證據，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不過就現狀我主觀推斷，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你是——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "男孩子……",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，不，不必了。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不必給我看實質證據，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "給我繫好你的皮帶。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果有「特例」的我陪在你身邊，就能主張例外了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟本來我們學院",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原則上是禁止",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n叫做男性的生物進來的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管已經是放學時間，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但想必校內還是有些學生吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從道德觀點上看，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不能讓你一個人四處徘徊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是你會被報警處理。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反過來嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n原來如此，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只要我一個人去找就行了？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦～",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我才不要，那多無聊。",
        "unit_id": 111011
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "找不到呢……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可頭大了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在我有頭緒的地方全都沒找到。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這裡為止的路途，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我應該都是沿著午休時走的同一條路沒錯啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……這樣子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "理論上應該沒有其他該找的地方了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這情況的話……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n先猜想是被第三者撿走了，會比較有建設性吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "詢問總務後，那邊好像沒有收到撿到遺失物的消息。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話是這麼說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我也不覺得有人怪到會偷那個。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那麼破爛的筆記本，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算拿去古董店賣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也連一枚盧幣都不值。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "束手無策了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不過，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算唉聲嘆氣，找不到還是找不到。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們就先回「塔」裡，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "改用魔法的搜索手段——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那是……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個班級的學生嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n她們不進教室，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在竊竊私語什麼……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊！　",
        "unit_id": 2911,
        "voice": "vo_adv_1110005_047"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "是前些日子的那位男性！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "啊！　",
        "unit_id": 3111,
        "voice": "vo_adv_1110005_048"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "在他身旁的是優妮博士！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "那兩個人",
        "unit_id": 2911,
        "voice": "vo_adv_1110005_049"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "看起來好像很親密……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "呵呵，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "難不成他們，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "有著更加深入的關係嗎？",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "是啊，",
        "unit_id": 3111,
        "voice": "vo_adv_1110005_050"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "一定是這樣子。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n呵呵，",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "會不會已經求婚了……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "呀，好棒！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從偷聽到的內容推測……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看來她們",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n似乎對於你和我的關係性，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感受到了某種特定的意義。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管那推測和實際差了十萬八千里，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不用去怪她們。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若考量到她們出生後的年數，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n做為生物，她們已經開始準備要繁衍後代了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "思考時會戴上桃色濾鏡也是自然的法則。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在學會裡把那個稱作是青春期。",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像也稱作是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嚮往談戀愛的年紀。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不知是幸或不幸？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我至今似乎尚未出現那樣子的徵兆。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話說回來學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那你呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你談過戀愛嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不清楚。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n說實話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "戀愛——",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_057"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很常聽到這個詞，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "當然",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也知道它的意思。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是想繁衍子嗣的這種絕對欲望的前一個階段，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只會出現在具有智慧的生物身上的高度複合感情群。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是甜蜜、悲傷，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "又有點苦澀的心情。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我只能理解這個詞。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n並沒有伴隨真實的感受。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所謂的知識",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會進入人體內兩次。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n一次是知道意思時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "另一次則是知道了本質後。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果那樣的定義為真，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那便表示我還尚未理解戀愛的本質呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "據我聽聞，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雌性雄性的身體接觸後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n會讓血壓急速上昇，還會讓人精神亢奮。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是碰觸彼此時會心跳加速。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n似乎是這個樣子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎是哦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎是呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你要怎麼做？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以說……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的意思是……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要試試看嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼哇！？",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_065"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦、",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_066"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還真是突然啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我嚇到了啦……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再加上，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_067"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你這個距離感……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不會靠得太近了一點嗎……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不……",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_068"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我並沒有",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "覺得討厭。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n雖然不討厭，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "莫名有種無法冷靜的感覺……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "呀啊啊啊他們黏在一起了！　",
        "unit_id": 2911,
        "voice": "vo_adv_1110005_069"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "是不純異性交往呀！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "討厭啦啊啊啊，又是雙眼凝視又是互咬耳朵的！　",
        "unit_id": 3111,
        "voice": "vo_adv_1110005_070"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "婚前性行為呀！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊、",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_071"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊哇哇哇……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n圍觀的人怎麼好像突然興奮起來了……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎、",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_072"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼回事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這股心癢難耐的衝動……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n神祕的煩躁感填滿了我的思緒……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚嗚嗚……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟住手吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "實驗中止，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "結合解除！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼……",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_073"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這狀況是怎樣？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這不是從找筆記這件事上大大地偏題了嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唉呀唉呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_074"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因為沒來由的驚慌失惜，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感覺肌膚發燙了起來——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_075"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n血壓上昇……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "精神亢奮……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_1110005_076"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "怎麼可能……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不可能啦，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為莫名的羞恥情感而不知所惜，\n甚至不自覺地皺緊了眉頭，\n看來優妮的青春期似乎尚未到來呢。"
    }
]