[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣、",
        "unit_id": 100311,
        "voice": "vo_adv_5096411_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "回去的船馬上就要開了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳們回程的行李都準備好了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 100211,
        "voice": "vo_adv_5096411_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我已經準備好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和？",
        "unit_id": 100311,
        "voice": "vo_adv_5096411_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我完全還沒玩夠呀──！",
        "unit_id": 100111,
        "voice": "vo_adv_5096411_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n明明就還有很多想做的事情",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和想吃的東西──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n時間根本不夠啦──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈……",
        "unit_id": 100211,
        "voice": "vo_adv_5096411_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從剛剛就一直是這樣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 100311,
        "voice": "vo_adv_5096411_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不可以任性。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呵呵，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然我也覺得快樂的時光",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "過得特別快。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧對吧！？",
        "unit_id": 100111,
        "voice": "vo_adv_5096411_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然這樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們也只能出發了對吧！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我們一起在夏天的大海盡情地玩耍，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "直到最後一刻吧──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就這麼決定了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很好，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "Let's Go──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行，",
        "unit_id": 100311,
        "voice": "vo_adv_5096411_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們必須得留下充裕的時間來行動才行，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不然之後可是會陷入慌慌張張的窘境喔？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒在聽嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真傷腦筋呢，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳為什麼在把泳圈充氣呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_5096411_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為日和",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "已經出發了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我也是",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不得已的嘛……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嘿嘿……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣，",
        "unit_id": 100311,
        "voice": "vo_adv_5096411_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "居然連妳也這樣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "算、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "算了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "反正我也不是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有遺憾。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜……",
        "unit_id": 100211,
        "voice": "vo_adv_5096411_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然是這樣呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也一起來吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "直到最後一刻，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都和我們一起……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "享受大海吧！",
        "unit_id": 100211
    }
]