        "voice": "vo_adv_1099003_009"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "非～常難受的樣子。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n而且還有發燒，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "她應該很難過……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "體內的瑪那似乎沒有不穩。",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_010"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一定是累積的疲勞爆發出來了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為可可蘿",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n是個非～常努力的人啊。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "喂～",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_012"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我知道你很擔心她，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n但是你可不能那樣慌慌張張的呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你冷靜下來，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_013"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n從育幼院裡",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "找出退燒的藥。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這裡",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也有很多小孩子，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想一定會備有藥品的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我趁這段時間",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_015"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n把可可蘿",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "背到房間去。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嘿咻……！",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_016"
