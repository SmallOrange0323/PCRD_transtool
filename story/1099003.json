        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "再讓她繼續勉強的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "快點把身體養好，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_019"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n等妳恢復精神了，",
        "unit_id": 109911
