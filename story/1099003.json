        "voice": "vo_adv_1099003_029"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有好好把藥保護住了",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你啊，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的不管做什麼都會變成大冒險呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_030"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n那麼，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "再來",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "得把這個藥餵給可可蘿吃才行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想想……",
