        "voice": "vo_adv_1099003_018"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我不接受異議。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對於努力過頭而倒下去的人，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我是不會",
        "unit_id": 109911
    },
