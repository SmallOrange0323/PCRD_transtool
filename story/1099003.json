        "words": "因為你",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "光是可可蘿的事",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就這麼慌慌張張的了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "看到你那個樣子，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_065"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n一點都沒有像哥哥的感覺呀。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_066"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你是我的",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "弟弟唷。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "今後如果",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_067"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n有遇到什麼不安的事情，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要來依靠我喔。",
        "unit_id": 109911
    },
    {
        "type": "still",
        "still": "109900301"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯、",
        "unit_id": 105912,
        "voice": "vo_adv_1099003_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好乖好乖，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好可愛好可愛。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要好好休息，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "讓我再看到妳有精神的樣子喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在那之前，",
        "unit_id": 109911,
        "voice": "vo_adv_1099003_070"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "請好好",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
