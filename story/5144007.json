    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "我還以為妳不管再怎麼冒失，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "都不會氣餒的。",
