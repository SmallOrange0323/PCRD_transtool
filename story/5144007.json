        "voice": "vo_adv_5144007_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也曾經有過和你一樣的心情。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "鈴莓小姑娘也有嗎？",
