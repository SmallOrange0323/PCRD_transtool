    {
        "type": "dialogue",
        "name": "依里",
        "words": "進入茜里的身體，",
        "unit_id": 102211,
        "voice": "vo_adv_6048109_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓我又重新",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "思考了很多",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n關於那個孩子的事呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這還用說嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_6048109_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "當然是不管誰說什麼，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那孩子都是我最棒的妹妹。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我只是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "更清楚明白了這一點而已。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是……",
        "unit_id": 102211,
        "voice": "vo_adv_6048109_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒有因為我的身體",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "留下什麼不好的回憶嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果過得開心的話就好了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是個好機會，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "去好好和茜里聊一聊吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唔，",
        "unit_id": 102211,
        "voice": "vo_adv_6048109_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個豐滿感",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的確讓我",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有點羨慕呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我和那孩子可是姊妹喔？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "將來我一定也能……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等等，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你想讓我說什麼啊笨蛋！",
        "unit_id": 102211
    }
]