    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "匆匆忙忙從深山小屋跑出去，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n去調解【哞哞自衛隊】和【王宮騎士團】的，\n小衝突呢～？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在這之後，還要接受調查。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來要熬通宵了…………",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "皮膚肯定會變差，會變老的啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_2003002_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "辛苦了，大小姐。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說回來，",
        "unit_id": 102511,
        "voice": "vo_adv_2003002_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n若要接受調查，我們也應該一起嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟比起大小姐，我們感覺還更像是當事人？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用了。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就只是公會長們簡單聊一下而已。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【咲戀育幼院】的我和，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【王宮騎士團】的純和……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【哞哞自衛隊】的真步？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就這三個人開會。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經很晚了，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該明天才會問你們的情報啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然暫時有點麻煩，到時要佔用一下你們的時間囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這段期間，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}你們就借住在【咲戀育幼院】這裡吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是飲食跟住宿的話，我們可以免費提供。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果沒有其他可去的地方，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也可以一直在這裡住下去。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "想自己賺取伙食費的話，\n",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們也會幫忙介紹工作。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話先說在前頭，可別逃跑唷。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把你們留下的其中一個理由也是為了監視你們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n直到把事情經過詢問清楚為止。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，也就是所謂的保護觀察的處分呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【哞哞自衛隊】的公會小屋",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因為遭到襲擊而毀了一半……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而【王宮騎士團】的根據地又在王宮，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因此除了相關人員以外的人都禁止進入。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以呢，就只能由我把你們帶回來了。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們在這次爭執的立場算是第三方，某方面來說也是最合適的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我們是隸屬於【公主騎士】下的公會，",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n姑且算是【王宮騎士團】那方的人……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以也不能說是完全地公平中立就是了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總覺得很複雜呢。",
        "unit_id": 102511,
        "voice": "vo_adv_2003002_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真傷腦筋。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像我們這麼和平的公會，竟然捲入了紛爭。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果、果然還是我的錯吧？",
        "unit_id": 102511,
        "voice": "vo_adv_2003002_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對不起！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎會是妳的錯呢，鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們只是被無端捲入麻煩的受害者呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們要抬頭挺胸。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果示弱的話，會被有機可乘的唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊。",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}你才剛來蘭德索爾沒多久，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該不清楚公會之間的關係吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看你一臉搞不清楚狀況的樣子……",
        "unit_id": 102811,
        "voice": "vo_adv_2003002_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好吧，跟你們簡單說明一下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你們就邊吃邊隨便聽聽吧。",
        "unit_id": 102811
    }
]