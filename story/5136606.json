[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "晶のことが気になっているノウェムは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n同じ七冠である誓約女君に、どんな人物か尋ねてみることにした。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そういえば、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "前々から気になってたんだけど……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n晶って、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "本当はどんなヤツなんだ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "なんだ、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_001"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "その曖昧な質問は。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nどんなヤツも何も、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "見たままだろう？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ワタシたちの野望を阻もうとする敵だ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そういうことじゃなくてさ～、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "現実でも会ったことあるんだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アイツ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いつもあんな感じだから、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "人柄とか分かんないんだよ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "その辺、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "クリスティーナだったら",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "知ってるんじゃないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ものすごく正義感が強いとか、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_003"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "逆に現実だとすごく悪いヤツだとかさ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "他にもぬいぐるみを抱いて寝てるとか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おやつはマカロンとか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそういう感じの情報でもいいぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "おかしな想像をさせるな！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_004"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n断じて、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "そんなフワフワキラキラした趣味などヤツにはない……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "と思う。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "しかしクレープ屋とかもやっていたな、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "もしや裏では……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_005"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そこまで真剣に悩まなくていいぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "プライベートなことが分からないなら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "職場での話でもいいし。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nなにか思いついたりしないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "開発現場でも、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_006"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ずっとあの調子だったな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "言われたことはそつなくこなすが、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "気に入らないことには",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nはっきり気に入らないと言い放つ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "それでいて",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_007"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "普段は率先して周りを手助けしていたから、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nプロジェクトメンバーからの人望は厚かった。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我々とは",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "袂を分かつことになったがな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "わ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_008"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分かったような分からないような……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんていうか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いいヤツそうだっていうのは分かったけど、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "イマイチこう……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "掴みどころがない",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "って感じだぞ……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "実際、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_009"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "そういう女だ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nいつもヘラヘラして、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "心の奥底に抱え込んでいるものは、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n決して他人に見せようとしない。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "それなりに付き合いはあったはずなのだが……",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_010"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ワタシは晶の本心というものを、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "心から確信できた覚えがない。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そっか。",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "じゃあクリスティーナにとって、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n晶はそんなに大事な友達だったんだな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "人の話を聞いていたのか？",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_012"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nワタシは今、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ヤツの心が分からないと言ったんだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "なぜ、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "大事な友達ということになる？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "大切って思ってないヤツのことで、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそんな真剣に考え込むことないだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシも、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "どうでもいいことはすぐ忘れるしな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "子どものくせに、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_014"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ませたことを言う。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "だが……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "そうだな、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "認めよう。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n間違いなく、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "数少ない友人のうちの一人だとは思う。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "やっぱりそうか！",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_015"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nでも、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "クリスティーナがそこまで認めるなんてな。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nもしかして",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アストルムの強さでも",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "向こうが上なのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "断じて違う！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うわぁ！？",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_017"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nな、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんだよ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "急に大声を出すな！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "びっくりするだろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "キサマがふざけたことを言うからだ！",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nこのワタシが",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "晶より弱いなどということはありえん！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nレジェンドオブアストルムに限らずだ！！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "レースゲームでは87戦44勝で勝ち越しているし、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n格闘ゲームでは123戦61勝で……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "む、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "これは負け越しているな。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "他には腕相撲なんかだと……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "わ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110606_020"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分かった！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "分かったって！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nけど、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "よくそんなに何回も勝負できるな〜",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシだったら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "途中で飽きちゃいそうだ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "晶との戦いに、",
        "unit_id": 107111,
        "voice": "vo_adv_5110606_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "飽きる日など来るはずがない。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ワタシと渡り合うだけの実力を持った、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n数少ない優秀なプレイヤーなのだからな……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "う〜ん……",
        "unit_id": 106114,
