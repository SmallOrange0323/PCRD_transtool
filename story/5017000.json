        "type": "dialogue",
        "name": "拉姆",
        "words": "而是跟",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "某個其他的地方相連……！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不好！",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_061"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "快放開那本書！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n再這樣下去的話會……！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "快、",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_062"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "快被門吸進去了！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呀啊啊啊啊啊――！！",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_063"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "白色的光照亮了整個房間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當光消失的時候――"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "房間裡已是空無一人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這個被寂靜支配的房間裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一本書"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "掉落在地上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "只聽見"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "書本翻頁的聲音，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在原本毫無內容、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "空白的頁面上浮現了文字。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n上面只有一句話，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這麼寫道。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「――身處不同世界之人，將於異邦相逢」"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "。"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯、",
        "unit_id": 190011,
        "voice": "vo_adv_5017000_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "奇怪，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像感覺到有什麼奇怪的干涉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "錯覺嗎，",
        "unit_id": 190011,
        "voice": "vo_adv_5017000_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該不是吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像在我不知道的地方",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生了什麼事……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真糟糕……",
        "unit_id": 190011,
        "voice": "vo_adv_5017000_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望那傢伙",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒遇到什麼事就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底是",
        "unit_id": 190011,
        "voice": "vo_adv_5017000_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼人做的好事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的……",
        "unit_id": 190011
    }
]