[
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這裡是親龍王國露格尼卡梅札斯邊境伯的宅邸。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這座宅邸的見習執事菜月昴，今天也和平時一樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n跟兩位前輩女僕拉姆和雷姆"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一起辛勤地工作著。"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "啊～",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_000"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "拖著剛康復的身體整理倉庫好累～",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n整個身體隱隱作痛，腰和腿嘎搭嘎搭作響，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "手臂抖個不停又呼吸急促。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你沒事吧？",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "今天是難得的假日，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n你可以把這些交給我們，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好好休息就好了……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_002"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我很感謝雷姆妳的心意，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真的。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n可是，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "一直被當作傷患照顧根本不符合我的個性，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n說真的身體明明能動",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "卻得一直躺著，對我來說才是痛苦。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可是……",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "沒關係啦，雷姆。",
        "unit_id": 109811,
        "voice": "vo_adv_5017000_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n讓巴魯斯做他想做的吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "怎麼連姊姊都這麼說。",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "他想工作的話就讓他工作就好。",
        "unit_id": 109811,
        "voice": "vo_adv_5017000_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n反正，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "他只是想被人稱讚說，這麼不舒服還那麼努力。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是低級的心機。",
        "unit_id": 109811,
        "voice": "vo_adv_5017000_007"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳真是一針見血呢，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_008"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "姊姊！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這個嘛，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "雖然我不能說自己完全沒有這種想法！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但、",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_009"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但可不是因為",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n想表現給你們或愛蜜莉雅碳看",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "而已喔！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "――剛才",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_010"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有誰提到我嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "唔喔喔喔喔喔喔――！！",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "哇，",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_012"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嚇我一跳……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴你竟然能",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "跳這麼高。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛、",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_013"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛、",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛、",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅碳……！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳怎麼會突然跑來這裡！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這裡屋塵滿天飛耶！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "屋塵……",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是什麼？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我不是很懂，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n不過我感覺好像聽到有人提到我的名字，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有點在意。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "沒有沒有沒有，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_015"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "關於愛蜜莉雅碳的話題嗎？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "完全沒有喔。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真的完全",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不是真的，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我沒有騙妳也沒有瞞著妳喔。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――哎呀哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_5017000_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這蒙混的手法也太粗糙又隨便了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "唔，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_017"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那個聲音是……",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "帕克！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "說謊可不行唷，",
        "unit_id": 2611,
        "voice": "vo_adv_5017000_018"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "昴。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n你這麼拼命地隱瞞，感覺事有蹊蹺。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n照我的直覺，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這應該是件不能讓莉雅聽見的糟糕事吧。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴，",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_019"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是真的嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的像帕克說的一樣，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是不能讓我",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "聽到的內容嗎……？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我真的拿愛蜜莉雅碳這種寂寞的眼神沒轍！",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_020"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不是啦，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "完全不是那樣，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不是在講那種事情……",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "只是，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_021"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "對於看到我病剛痊癒還認真工作的樣子，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅碳是否會溫柔地",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "可愛地誇獎我，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "而有點期待……",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "話說回來，",
        "unit_id": 109811,
        "voice": "vo_adv_5017000_022"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "愛蜜莉雅大人",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是不是有事情要囑咐我們？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊，",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_023"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒錯。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我有事想請昴幫忙……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我被無視了嗎！？",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_024"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我可是會鬧彆扭喔！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "可能會離家出走喔！？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "沒事的。",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_025"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴的努力雷姆都看在眼裡！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我會用這雙眼睛，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "從早到晚一點不漏地仔細看清楚！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這說法還真有點恐怖，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_026"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過謝啦。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n果然，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "只有雷姆站在我這邊……",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "怎麼會……",
        "unit_id": 109711,
        "voice": "vo_adv_5017000_027"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "竟然說我可愛到想娶回家，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "人家會害羞啦……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我才沒說成那樣好嗎！？",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_028"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "話說回來，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅碳難得有事會找我耶。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是嗎？",
        "unit_id": 109911,
        "voice": "vo_adv_5017000_029"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "或許是那樣。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "如果你在忙的話，不用急著現在也沒關係。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我暫時",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "會跟帕克兩個人一起喵喵喵喵……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "抱歉，",
        "unit_id": 2711,
        "voice": "vo_adv_5017000_030"
    },
