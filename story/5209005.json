    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員２",
        "words": "\n至於公主候補，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員２",
        "words": "要重新提名人選才合理。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂、",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_063"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "反對……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂認為",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "應該要用盡一切辦法……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "為、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "為了讓剎鬼醒過來，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "大家一起……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員３",
        "words": "那具體的方法是？",
        "unit_id": 1,
        "voice": "vo_adv_5209005_064"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那、",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_065"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那個……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n讓宮子",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "吃下布丁的話，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就可以讓她離開剎鬼的身體……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n……應、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "應該……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "只、",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_066"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "只要集齊了剎鬼的靈體",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "和身體，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "應該會更清楚情況……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "……而、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "而且，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "還有其他沒試過的復活術……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "剎鬼的靈體……",
        "unit_id": 1,
        "voice": "vo_adv_5209005_067"
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "是異界騎士那件事嗎。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "已經夠了吧。",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_068"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "雪野是被異界人唆使了。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "咦？",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_069"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "各位，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_070"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "對於之前的事件還記憶猶新吧。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "那些傢伙踏入黑曜宮，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "招來了【術士】這件事。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "黎薩殺害剎鬼這件事，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_071"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "也是在名為阿斯特朗的異世界──",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n也就是那些傢伙的世界裡發生的。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "要說這些事是巧合，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "未免也太剛好了吧？",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "雖然薇歐莉特公主",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_072"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "以友善的立場對待異界人，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "但我們",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "應該要更慎重一點才對。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "因為異界人，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_073"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "有可能打算讓這個國家陷入混亂。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "當然，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "這次的事件也一樣。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員２",
        "words": "果然，",
        "unit_id": 1,
        "voice": "vo_adv_5209005_074"
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員２",
        "words": "不應該再留下混亂的根源呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "怎、",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_075"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "怎麼會這樣……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n這樣",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "太奇怪了……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "可是伯爵。",
        "unit_id": 1,
        "voice": "vo_adv_5209005_076"
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "鬼族族長和公主都不在場的情況下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "\n你不覺得處置太極端了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "再怎麼說",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員４",
        "words": "那也是剎鬼的身體。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "的確，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_077"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "還是有復活過來的可能性。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "這樣的話，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "先把這次復活的剎鬼",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "監禁起來怎麼樣？",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n只要交給鬼族管理的話，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "他們也不會有怨言吧。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "但是，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_078"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "在找到確切且安全的方法之前，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "不可以解除監禁。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "要是找到方法的話，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "就在黃泉的餐桌會議上提出。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "獲得認可之後，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "再執行就可以了。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員１",
        "words": "……好吧，",
        "unit_id": 1,
        "voice": "vo_adv_5209005_079"
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員１",
        "words": "這樣比較實際。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不、",
        "unit_id": 135812,
        "voice": "vo_adv_5209005_080"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不行……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n那、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那樣的話，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就太慢了……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼會消失的……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "大、",
        "unit_id": 195512,
        "voice": "vo_adv_5209005_081"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "大家",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "都被伯爵大人的意見牽著走……",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員１",
        "words": "唔，",
        "unit_id": 1,
        "voice": "vo_adv_5209005_082"
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員１",
        "words": "為什麼烏賊女會在這裡？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黃泉的餐桌成員１",
        "words": "\n妳這傢伙在黃泉的餐桌並沒有席位吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "嗚啾……！？",
        "unit_id": 195512,
        "voice": "vo_adv_5209005_083"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "璐璐伊，",
        "unit_id": 2516,
        "voice": "vo_adv_5209005_084"
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "原來妳躲在那裡啊。",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "反正都是要躲，",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "\n就把妳關在",
        "unit_id": 2516
    },
    {
        "type": "dialogue",
        "name": "奧洛克伯爵",
        "words": "妳最喜歡的章魚壺裡吧。",
        "unit_id": 2516
    },
    {
        "type": "background",
        "background": "502430"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "──在那之後，",
        "unit_id": 195512,
        "voice": "vo_adv_5209005_085"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "偶就不知道了……",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "雪野姐接她，",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "沒有問題吧……",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這樣啊……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_086"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "說起來，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "妳還有帶著剩下的布丁嗎？",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "啊，",
        "unit_id": 195512,
        "voice": "vo_adv_5209005_087"
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "素的……",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "\n雖然",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "璐璐伊",
        "words": "幾乎都塌掉了……",
        "unit_id": 195512
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "妳拿著這個",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_088"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "在這裡等。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我去看看雪野的情況。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那些傢伙",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_089"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看不到現在的我。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n可以直接進去。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "舔刀子氏",
        "words": "大家從剛才開始，",
        "unit_id": 816,
        "voice": "vo_adv_5209005_090"
    },
    {
