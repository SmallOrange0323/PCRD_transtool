[
    {
        "type": "background",
        "background": "502420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪野和璐璐伊前往巨鯨城。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}留在了久遠冰河，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在他面前是欲言又止的剎鬼靈體。"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "到此為止了……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……沒時間了。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_001"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "抱歉，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "替我跟雪野打聲招呼。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "受你關照了。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_002"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有很多事情要謝謝你。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "唔……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_003"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這樣耍不了帥啊。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我都已經準備好消失了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不穩定的週期愈來愈短了。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_004"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n頂多只能再撐幾小時。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我欣賞你的毅力。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_005"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那份力量也不是無限的吧。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "重點是沒有復活的線索。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "都準備好布丁了，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "卻連身體也被搶走……",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……對了，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_007"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "布丁。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n為什麼我沒有注意到──",
        "unit_id": 135915
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚唔……",
        "unit_id": 106012,
        "voice": "vo_adv_5209005_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好不舒服……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_5209005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n彷彿是身體",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在拒絕食物一般……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n十分抗拒的感覺……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "──真是對不起呢？",
        "unit_id": 195212,
        "voice": "vo_adv_5209005_010"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "該說是內臟變得衰弱嗎……",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n因為黑暗精靈族祕傳的咒術，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "讓生命力減弱了。",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "更加接近死亡，",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "這樣說可能比較貼切吧。",
        "unit_id": 195212
    },
    {
        "type": "background",
        "background": "502420"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──身體因為咒術而接近死亡的話，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "會接受不了食物。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "宮子卻用我的身體吃下了布丁。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還吃得津津有味。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也就是說，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "被宮子附身的身體，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還沒有死。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "黎薩公用的應該不是對身體，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_013"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n而是對靈魂產生作用的詛咒。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "本來，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_014"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "作為目標的公主是殭屍。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "即使普通地殺掉，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也死不了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "因為本來就已經死了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所以，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_015"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "才會使用對靈魂產生作用的咒術。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "而不是平時所用的咒災之箭。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n這樣的話，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就能解釋為什麼宮子吃布丁吃得津津有味了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……既然我",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "現在像這樣存在。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n黎薩公那傢伙，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "可能也不是真的要置公主於死地。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "應該是打算",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓她處於假死狀態吧。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是因為宮子的關係，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_018"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我被彈出體外，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就醒過來了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_019"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這下欠了宮子一個人情呢。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那傢伙應該只是想吃布丁而已吧。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "她說不能順利離開身體，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_020"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "搞不好是真的。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒有靈魂的身體",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "可能正好適合她呢。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……至於吃了布丁是不是就能離開身體倒是很可疑。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_021"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就當作是魔法之類的吧。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒錯。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_022"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "只要能回到身體裡，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就可以活過來……",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "可以活過來嗎……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_023"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "…………",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_024"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_025"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看在你陪我走到這裡的分上，才跟你說。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我果然──",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不想死啊。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "和你們",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_026"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "在吉歐‧尼布爾黑爾東奔西跑後。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我開始搞不清楚自己的優先順序了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我曾經覺得如何死去",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_027"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "才是人的價值所在。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒有人能夠逃過死亡，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但至少可以選擇怎麼死。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所謂的",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_028"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "勇氣還有覺悟。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我一直相信，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那些才是有價值的。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所以，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_029"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那時候我的身體也立刻動了起來。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "因為一直以來，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我都是懷著那樣的想法而活。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "會這麼做是很自然的。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是我看到的跑馬燈，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_030"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "和那些價值什麼的沒有關係。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "都是和雪野一起玩之類的",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "瑣碎小事。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還有就是……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_031"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我的妹妹。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是個跟雪野很像，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "溫柔又可愛的傢伙。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "為什麼死的不是我，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_032"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "而是妹妹。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我心裡一直這麼想著。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "自從妹妹死了之後，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_033"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我似乎就放棄了自己的生命。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "而我也對此有所自覺。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "…………",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_034"
    },
    {
        "type": "still",
        "still": "520900202"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "…………但是，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_035"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看到雪野和你很高興地表演。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n看到你們笑著的樣子，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "觸動了我的心。",
        "unit_id": 135915
    },
    {
        "type": "still",
        "still": "520900403"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "同時，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_036"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "體認到自己已經不會再有這樣的時間。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也不能和雪野一起把埋起來的時間膠囊挖出來。",
        "unit_id": 135915
    },
    {
        "type": "background",
        "background": "502420"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我察覺到自己的寂寞。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_037"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n所以，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "覺得不想死……",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "拜託了。",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_038"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n請你",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "再幫我一次吧……",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "呼……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_039"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我竟然說了這樣的話。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n騎士公，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "感激不盡。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "剛才說的話",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_040"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要保密。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我可是相信你才說的。",
        "unit_id": 135915
    },
    {
        "type": "background",
        "background": "502430"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "穿過這裡之後就是巨鯨城了……",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_041"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是入口",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有那些無頭們在。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "用騎士公的力量，",
        "unit_id": 135915,
        "voice": "vo_adv_5209005_042"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓他們看到我也是一種辦法。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不知道有誰和伯爵是一伙的。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n如果選錯人",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就完了。",
        "unit_id": 135915
    },
