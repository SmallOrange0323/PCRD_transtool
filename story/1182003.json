    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "和騎士同學合作",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_049"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "克服某個很厲害的危機之類的？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "像吊橋效應那樣的？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……但是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大部分的危機",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大概都能用超能力解決……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯……",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n其他還有……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……譬如說",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_051"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在世界毀滅的前一刻之類的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果騎士同學到這種時候",
