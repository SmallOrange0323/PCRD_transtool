[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──數天後。"
    },
    {
        "type": "background",
        "background": "500091"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美空正一個人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n坐上蘭德索爾的城牆外側，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眺望著逐漸昏暗的天空。"
    },
    {
        "type": "still",
        "still": "118200301"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_000"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……唉。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_001"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……我真是",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "無藥可救呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "難得",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學說要跟我一起約會的……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我還鬧起脾氣，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "把他一個人丟在那裡。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "受夠了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……可是可是。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_005"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n雖然",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我可能真的有點固執……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n但那時候的騎士同學",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也沒有多好啊。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在我們爭執途中，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_006"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那些綁架犯如果逃走之類的話。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n之後肯定又會在",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "某個地方做壞事。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說到這。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n又覺得",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "生氣起來了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果沒有那些綁架犯，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我現在就在跟騎士同學約會……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "感情變得更好。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n說不定就可以理解",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為戀愛而心跳加速的感覺了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……不。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n仔細想想，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說到底。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我一直",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都沒有從正面",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "出現在騎士同學面前呢……",
        "unit_id": 192011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "幾天前的美空",
        "words": "「呵呵★",
        "unit_id": 1,
        "voice": "vo_adv_1182003_010"
    },
    {
        "type": "dialogue",
        "name": "幾天前的美空",
        "words": "\n猜～猜我是誰？」",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "118200301"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總是",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "從他後方。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就像是偷襲一樣。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……希望這麼做，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_013"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n事情就能順著自己的步調進展，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的？　",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還是說。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_014"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果騎士同學注意到我正朝他走過去，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n卻擺出厭惡的表情的話該怎麼辦，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或是說……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我在害怕……",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_015"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的……？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然我不覺得",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_016"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學會喜歡上我。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n雖然我也非常清楚",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學完全是個濫好人。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然騎士同學可能會說，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_017"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不想再見到我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也可能會被騎士同學避而不見。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "即使如此，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_018"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我啊。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n能不能為了讓騎士同學中意我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而不再繼續固執下去",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呢……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_019"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "明明",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_020"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還沒有愛上他。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就覺得……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經很挫折了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n果然我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "辦不到呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我又",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_021"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "變得想要放棄了呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n…………",
        "unit_id": 192011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "118200302"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……咦？",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_022"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦、",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_023"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦……？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學……？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你在",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_024"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "找我嗎？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n為什麼……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_025"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "118200303"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……啊哈★",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_026"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之前",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_027"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我有好好說過了呀？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我對騎士同學的感情，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "並不想要停在「喜歡」，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而是想要好好愛上你的這個話題。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果真的變成那樣。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_028"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我也能從現在的人生放棄模式，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n轉變成普通的女孩子吧──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這樣。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這些，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_029"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "完全就是我的真心話喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學你該不會，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不相信我吧？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果是這樣的話，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我好傷心──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呢。",
        "unit_id": 192011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "118200304"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_030"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也沒有那麼受傷，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以不用感到抱歉。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n畢竟要相信一個至今為止都還是敵人的我所說的話",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是很困難的呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還有還有。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_031"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n有件事",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我那時候沒有說──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_032"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真的愛上騎士同學的話。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n一定會",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "非常非常開心的～♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我是這麼想的──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而且啊。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這段戀情",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "肯定不會有結果。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_034"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "以騎士同學的角度來說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n完全沒有任何半點",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會喜歡上我的理由呢♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "深陷足以改變以往的我的戀愛。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_035"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n讓其他所有事情都變得無所謂的那種戀愛。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n然後──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "徹底被甩掉的話……",
        "unit_id": 192011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
