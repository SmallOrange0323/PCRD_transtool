    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊啊──",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_053"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n好難啊──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要愛上別人這件事。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_054"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過不過♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "找我找到這裡來，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我非常開心喔★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "剛才太驚訝了，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_055"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以一時沒有注意到。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "仔細想想，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這說不定",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "蠻接近「心動★」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "的感覺……？",
        "unit_id": 192011
    },
