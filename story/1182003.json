    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "受傷呢★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵♪",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_037"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n真棒……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n無論多麼波折，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "最後肯定會很開心對吧？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這種事情。",
        "unit_id": 192011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "118200304"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯～",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_038"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n……看你這種表情。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n果然我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很奇怪呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之前",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_039"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也有跟蘭法姐說過。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "曾有段時期非常煩惱──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n已經開始的事情該如何讓它結束。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果是騎士同學、",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_040"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或是蘭法姐。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n由我喜歡的人來了結我的話，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那麼",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就太好了呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……結果，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_041"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大家都善良過頭了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n完全不會",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "討厭我、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "憎恨我。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n事情就沒有我想的順利……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是的★",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_042"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "並不討厭被憎恨。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我會覺得我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有在被合理對待。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我並不像矛依未",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_043"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "只有表面上是壞蛋。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n本質上就是壞孩子的我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是不能被原諒的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我應該受到更多憎恨，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "受到更多傷害，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "然後遭遇悽慘的下場。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊哈。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_044"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果是身為超能力實驗品，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "做了各種壞事之前的我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n也許就會是你說的那樣呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……是呢。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_045"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我不是超能力少女的話。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果我沒有被綁架，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "只是個非常普通的女孩子的話。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也會像其他孩子們一樣，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_046"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "以普通的方式認識騎士同學。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n然後很普通地",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "愛上騎士同學吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但就算說這些假設，也無濟於事呢──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "比起這個。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_047"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對我而言──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我還想知道該怎麼做",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "才能更愛上騎士同學～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被魔物襲擊的時候，",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_048"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學突然現身保護我之類的？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……但是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "面對大部分的魔物我也不會輸……",
