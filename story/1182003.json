        "voice": "vo_adv_1182003_057"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n今天的夕陽，",
