    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還會來關心我之類的──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也許",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我就會感覺到「心動★」──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……可是可是。",
        "unit_id": 192011,
        "voice": "vo_adv_1182003_052"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這就是",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不會發生的「如果」呢。",
