[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您呀，",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我在這裡哦……♪",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天受到您的邀約，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "心臟",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "跳得非常快呢……♪",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……♪",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真是太棒了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "居然能讓您幫我慶祝生日……！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……當然，",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我早就知道了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n因為從前陣子開始，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就見您造訪各式各樣的店家，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n看著女性用的雜貨。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還會若無其事地",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "詢問我，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有沒有想要的東西……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n要沒發現反而還比較難呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "──請您",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "稍等一下。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡人有點多，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不能清楚聽到您那美妙的聲音。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不如我們來去……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更安靜點的地方吧？",
        "unit_id": 102731
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡是充滿花香的",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好地方。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請您",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再重新來一次。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "非常",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "感謝您。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我作為您命中注定要結合的未來伴侶，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n今天這個日子",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "永遠記得的……♪",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………話說回來，",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您現在的身體狀況如何呢？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "個，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會不會覺得臉燙到不行，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "或是",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "心臟噗通噗通地跳，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "之類的。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又或者是想要擁抱眼前的女孩子",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想要得受不了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……沒有？",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是嗎。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼事都沒有。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您別在意……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在您準備來慶祝我生日的期間，",
        "unit_id": 102731,
        "voice": "vo_adv_4010189_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我也",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "準備了「能讓男女關係急遽升溫的環境」……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n看來計畫無法順利進行呢……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就留到下一次的機會吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻♪　",
        "unit_id": 102731
    }
]