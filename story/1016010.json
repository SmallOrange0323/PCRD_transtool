[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拍攝結束沒多久，某一天的【月光學院】。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在宣布放學的鐘聲響起的同時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴奈從書包裡拿出刊登著前幾天的特輯的雜誌。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呼！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "終於下課了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天也超級不知所云……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才──！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看你看！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "刊登之前約會的照片的雜誌！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也還沒有看過，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們一起看吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我看看……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "變成什麼樣子了呢──？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在這裡！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才在幫人家戴首飾的時候！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那時候真的好開心呀──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這張照片是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "餵聖代的……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才約會的時候",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是這種表情的嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總覺得超級害羞的啦──！！　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "途中還忘了還在拍攝，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n完全沉浸在",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才的約會裡了呢……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對、",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吧──？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這就是",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我的模特兒能力喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小、",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "小菜一碟啦。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是、",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒那回事吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是的──秀才你呀！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n要是不認真關注",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的照片的話，人家可是會氣呼呼的喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "鈴奈。",
        "unit_id": 1,
        "voice": "vo_adv_1016010_012"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n有人想和妳聊聊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "方便佔用妳一點時間嗎──？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼事──？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "鈴奈小姐，",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_014"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "初次見面，妳好。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不好意思，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "冒昧造訪妳就讀的學校。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n有一件事想委託鈴奈小姐妳……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_015"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "來自一個專為年輕貴族打造的時裝品牌，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n我負責的是活動企劃……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "本公司將舉辦品牌時裝秀，",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_016"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n這次前來造訪，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "是想詢問妳是否願意參與演出。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "哦？",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_017"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳手上的雜誌……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我正是看了這個特輯，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n認為最佳人選非鈴奈小姐莫屬才前來拜訪的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是工作邀約呀！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好呀──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "貴族階級……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那是……",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "指什麼大人物嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼會找上",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "身為普通人的人家？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這是因為……",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_020"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "不論好壞，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n貴族階級的時裝業界長年以來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "一直受到老舊傳統的束縛。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "但是，",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_021"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "現在這個時代的時尚",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n不應該受這些傳統和規則的束縛，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n無論是穿戴的人",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "還是製作的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "都該更自由地享受其中。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說得對！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "穿自己覺得可愛的衣服，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n戴自己喜歡的時髦飾品是很重要的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沒有錯。",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_023"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "因此，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我決定改變這種傳統，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n創立了一個全新品牌，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n融合了鈴奈小姐平時活躍領域的精髓。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我想向年輕貴族呼籲，",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_024"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n時尚是一種可以自由享受的東西……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很好呀！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像很有趣──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不是很了解貴族階級的時裝，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n原來有這樣的品牌呀！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "年輕人的反應怎麼樣呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這個嘛……",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_028"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雖然我舉辦過很多場時裝秀和活動……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "採用的模特兒和以往一樣，",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_029"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n都是本來就活躍於貴族階級的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n結果比預期中還要欠缺刺激性和話題性……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "那些模特兒",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_030"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "本身並沒有任何不足。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "只不過，如果要改變老舊傳統，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n那就得更加大膽地突破現況才行。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "於是！",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_031"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n我就想到，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "若可以採用現在年輕人間最受歡迎的超級名模鈴奈小姐，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n或許能成為一記震撼彈。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "我在",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_032"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "今天這份工作邀約上，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n賭上了貴族階級",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "時裝業界的未來！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來是那麼嚴肅的工作邀約啊……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "鈴奈小姐！",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_034"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳意下如何呢？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "妳願意助我一臂之力嗎！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃、",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該怎麼辦……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對人家抱有期待，還發給人家工作邀約，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家超級高興的，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但人家對貴族階級的時裝",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一無所知呀……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會開始當模特兒，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_037"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是在路上被星探發掘，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "覺得好像很有意思就嘗試看看而已。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後可以穿各式各樣的衣服拍照，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n或是可以登上時裝秀，這些事都很有趣，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家才持續到現在。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然現在",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也已經不是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n只顧著自己開心而已……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也想努力讓粉絲們開心。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過……",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "時裝業界的",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "未來，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家完全沒有辦法想像……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "況且，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_041"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "貴族階級還有禮儀？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那些人家也完全不懂。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_042"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這種半吊子的人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真的可以答應這個邀約嗎……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "主辦人這麼絞盡腦汁想出來的活動，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_043"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家卻沒有自信",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "自己出場能夠保證成功……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這樣、",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_044"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "啊……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "雖然鈴奈小姐已經是我最後的希望了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "但這種事也強求不來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "既然如此，這次就先這樣吧……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_045"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很抱歉……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n可以收到工作邀約，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家真的超級開心的，但是……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_046"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "從來沒有拒絕過任何工作邀約，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的好難受呀。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_047"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "常常興致一來就答應了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "或許是因為",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家喜歡看到自己答應後，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "委託人高興的樣子。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_048"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想透過模特兒活動讓對方開心的對象中，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n或許也包含工作上對這樣的人家有所期待的人吧……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_049"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "隱隱約約意識到了這一點，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n在婉拒工作邀約的時候反而會感到有些歉疚……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶吶，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_050"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家想問一件事，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可以嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "假設",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_051"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "鈴奈答應了這個工作邀約出席活動，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n有可能不小心搞砸一切，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "出大糗也說不定。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……即便如此，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也願意像平時一樣為鈴奈加油打氣嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只有這一次，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "似乎有點難約定……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定會讓你玩得盡興。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_053"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家就知道",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才會這麼回答！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個呀，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_054"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "其實人家是在遇見了秀才以後",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n更覺得當模特兒很好玩、很有意思喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看見粉絲高興的模樣確實令人家很開心，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_055"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但秀才的笑容讓人家更開心，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的為此受到了很大的鼓舞。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "每次人家在舞台上都想找到秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_056"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要是看見你很開心的模樣，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就會冒出一股自信，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "覺得今天活動也很成功呢。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_057"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然貴族階級的時裝秀",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n有很多不知所云的地方，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只要秀才在觀眾席裡，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家就有幹勁好好努力！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_058"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一直以來都很謝謝你呀，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_059"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就這麼決定了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要答應這個工作邀約！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "真、",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_060"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "真的嗎！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "謝謝妳！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然不知道可以做到什麼程度，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_061"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但只要人家可以試，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "都會去試試看的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想讓信賴著自己的主辦人感到高興，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_062"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也對貴族階級的年輕族群充滿好奇！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會把所有人",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_063"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "變得超可愛的！！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "光是鈴奈小姐的這番話就讓我很欣慰了……！",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_064"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "事前還有個",
        "unit_id": 2511,
        "voice": "vo_adv_1016010_065"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "決定伸展台出場順序的甄選會，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n之後我會再將詳細內容通知妳。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "還請多多指教！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呼──",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_066"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家答應工作邀約了──！！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_067"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家一點也不後悔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "下次人家也會讓秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n超級亢奮又興致高昂，說好了喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定會做到的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總而言之，",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_068"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為了到時候能夠盡情享受，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家應該趁現在",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學習貴族階級的禮儀？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之類的吧……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然感覺就超級難的！",
        "unit_id": 101611,
        "voice": "vo_adv_1016010_069"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以秀才……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你要陪人家一起學習喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈下定決心挑戰新事物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對於一如往常鼓舞自己的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又加深了信賴。"
    }
