        "type": "dialogue",
        "name": "帆稀",
        "words": "太可愛了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……看來你",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對他人",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有著很敏銳的感受力呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你想想看，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "幫派的老大",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果太過招搖，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就會被王國盯上，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "認為是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "危險分子不是嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，我只會在出席集會等這類重要的工作場合上露臉，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_061"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n至於其他工作，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在給予成員們的指示時，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n都會盡可能不要口頭傳達",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或是當面告知。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你很好奇我是如何給成員們下達指示嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_062"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是使用你現在正在幫忙繪製的東西喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是這樣～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_063"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我會在漫畫、插畫，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以及",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "信件當中留下暗號。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為必須事先讓成員們",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_064"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "記住解讀暗號的方式，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n剛開始的時候真的很辛苦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過等他們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都記住後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來就輕鬆多了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……不用擔心。",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_065"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我在你來幫忙繪製的原稿當中，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n並沒有留下記號喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是難得的回禮，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我不會讓你去做既危險又骯髒的幫派工作～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也希望你收下的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_066"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是我純真的感謝之意呢～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……雖說我也很想為你，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_067"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好～好準備墮落的那一刻♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_068"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是在開玩笑，開玩笑的☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好啦，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該動動停下來的手囉～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n今天工作結束後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一起去吃",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "美味的大餐吧～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，兩人又再度投入工作。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，{player}卻從帆稀對他投來的微笑當中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n感受到了深不可測的某種東西。"
    },
    {
        "type": "still",
        "still": "end"
    }
]