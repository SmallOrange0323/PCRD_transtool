    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}因為沒有預定行程，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在公會小屋享受著悠閒時光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時，從大門的另一側傳來了帆稀的聲音。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "午安～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請問{player}在嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊！",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來你在啊～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n精神看起來不錯，真是太好了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯！",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好久不見～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天我是來感謝你上次的幫忙。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n總之，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "方便請你隨我走一趟嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別擔心。",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "待會要去的地方，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n絕不會是像上次那樣可怕的地方♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且你也不需要特別做什麼準備，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果你可以來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們現在就出發吧～☆",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你看看～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡就是我們的據點♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "才沒這回事呢～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這棟建築能夠完全抵擋大部分的攻擊魔法喔！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開玩笑的啦♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就算不是這樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡一點也不危險。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "歡迎回來，老大！",
        "unit_id": 811,
        "voice": "vo_adv_1067002_007"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "咦，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "這不是上次的那位小哥嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天我請他來",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "協助我的工作～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "原來是這樣。",
        "unit_id": 811,
        "voice": "vo_adv_1067002_009"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "小哥，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "請隨意。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "待會我們會再",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "派誰端個茶進去。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～的。",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就麻煩你們了～☆",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，請～進。",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "快進來快進來♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這裡是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我房間喔～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為資料很多，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "空間可能有點擁擠……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，對工作完全不受影響。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼～",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我要公布囉～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "等一下我想請你……",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……協助我",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畫漫畫的原稿～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你以為是幫派的工作嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請放心。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我不會讓你去做那麼危險的事♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該說",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "幫派老大是我的另外一面吧，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n比較像是副業，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而這才是我的本業。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的本業是為在蘭德索爾出刊的報紙畫插畫，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或是畫些漫畫。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如何，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你嚇到了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "平時我都是請住在這附近，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n手比較巧的孩子來幫忙。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這次是為了向你答謝，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以才請你來幫我這個忙～☆",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "106700201"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就請你坐在這邊♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n幫我在畫好線條的原稿上",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗黑底、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或是貼網點，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就拜託你了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "做法",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會一步步說明，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n教你怎麼做，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你要牢牢記住喔♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先是",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗黑底～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是我畫好線條的原稿，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "上頭有畫×的記號對吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你試著用筆",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "將有畫×的地方塗黑……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對，就是這樣！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗得很漂亮～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全部都塗完了吧。",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣一來……？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "太～驚人了！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗黑的地方化成了陰影～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有了陰影，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就算只是畫在紙張上的黑白畫，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也可以看出遠近感，對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你做出這麼好的反應～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就像這樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "繼續把陰影塗黑吧～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n等全部塗完後",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再告訴我一聲～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我看看～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "確實全部都塗完了！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你做得很好～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這張原稿這樣就完成了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你塗得很仔細，",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來你也很有",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畫漫畫的素質呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就教你貼網點的方式～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔喔～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067002_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "貼網點的部分也全部過關～！",
        "unit_id": 106711
