[
    {
        "type": "background",
        "background": "500740"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "先日、",
        "unit_id": 111011,
        "voice": "vo_adv_6023308_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ギルド活動の一環で",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ルーセント学院へ赴いた折、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n男子生徒らが遠巻きに",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "「テレ女のやべーやつ」などと囁いていたが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれはチエル君とクロエ君、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "果たしてどちらのことだったのだろう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やはりチエル君か。",
        "unit_id": 111011,
        "voice": "vo_adv_6023308_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくが言うのもなんだが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "客観的に考えればあの歳で",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ちぇるーん♪　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "などと騒ぎたてるのは狂気の沙汰だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さもありなん。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やはりクロエ君か。",
        "unit_id": 111011,
        "voice": "vo_adv_6023308_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "酷いことを言う……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼女の内面はとても愛らしいというのに、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "顔と声と",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんか全体的に色々やべーぐらい",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何だと言うのだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんと。",
        "unit_id": 111011,
        "voice": "vo_adv_6023308_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "たしかに「やばい」という語の用法は",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "広範に渡ると聞く。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あのお下げのナオン最高にイカすぜやべー",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "的な意味と捉えれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なるほど合点がいくな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "然り、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくこそテレ女のやべーやつだ。",
        "unit_id": 111011
    }
]