    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！？",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_044"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與薇歐莉特\n從幽靈們的狀態感覺到危險。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人理應走出了墓地，然而──"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這個……",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_045"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "看來是方才的幽靈們",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n為了讓我們迷路所做的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n……要說",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "根本的原因，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也是我──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_046"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "唔……",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_047"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還請……",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_048"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還請您別道歉。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n您沒有做任何",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "需要道歉的事。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "當務之急，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_049"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還是盡早",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "找到出口吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n只要我們同心協力，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一定沒有問題的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……沒錯，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一定可以……",
        "unit_id": 133111
    },
    {
        "type": "background",
        "background": "501570"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這裡是……？",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_050"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也就是說，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_051"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這代表我們",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "從墓地出來了是嗎。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "太好了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……看來，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_052"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒有其他辦法呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n騎士先生您",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也需要休息。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生他，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_053"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "看起來也很熟悉野外露宿的樣子。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "多麼可靠的人啊……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就算我想要幫忙，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "反而",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會妨礙到他吧……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不、",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_054"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我這副身體",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "很耐寒。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n非常感謝",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "您的關心。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……都這時候了，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_055"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "他竟然還在關心我。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "明明騎士先生他",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也很疲累才對……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "相較之下，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_056"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我卻……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "連自己的身體狀況都沒管控好，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "給人添了這麼多麻煩……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……縱然如此。",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_057"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n現在的我，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "卻只想依賴他的溫柔。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不去思考公主的身分",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "或是其他事情。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不對，",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_058"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不止現在。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "只要跟他在一起，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我總是會",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不禁放鬆下來。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n不再是公主，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而是變成一個普通的人類。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──啊……",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_059"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "對騎士先生──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "…………",
        "unit_id": 133111,
        "voice": "vo_adv_1331002_060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "薇歐莉特對自己心中萌生的心意有了自覺。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她感受著{player}的溫柔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n獨自安靜地入睡。"
    }
]