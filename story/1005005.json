[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼～哼♪",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "前進吧～虎虎！",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了守護世界的和平～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼哼♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……咦？\n{player}！\n",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是巧遇呢～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你在這種森林裡做什麼啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又在找食材了嗎～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我很想幫你，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我現在正在任務中！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呵呵。",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我雖然在",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n【王宮騎士團】中還只是見習生而已。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但因為人手不足的關係，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被派出來了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "最近",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在一些簡單的事情上被分派了工作。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然還是有種像打雜的感覺，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但比起一～直訓練要好得多了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總而言之，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n現在因為某個任務，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n正在前往在山上的某個牧場。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}也是同一個目的地嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n哦……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你在做送包裹到牧場的打工是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以才會走在前往牧場的道路上啊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我理解了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "既然要去的地方相同，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就一起去吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "機會難得！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們就牽著手走吧～",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼哼♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的任務，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是要去巡視牧場哦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "想必{player}你也知道，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那裡",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是曾經變成一片非常狼狽的樣子嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了復興……",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們【王宮騎士團】，\n也進行了資金，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還有人手上的援助。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在那之後，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "牧場的復興，似乎進行得很順利。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但光只看書面報告，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也無法了解真正的情況，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以我要實際去現場，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "確認各種事情。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "像是我們提供的資金，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是否有好好地被利用在如報告書上所寫的地方之類的……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果遇上什麼麻煩事的話，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n追加的融資等等，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為了支援，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也必須進行很多的準備。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「牧場的人們也信得過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以不要做多餘的事情……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只要先打個招呼，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再大概檢查一下，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n喝個茶以後",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就馬上回來。」雖然我還被這麼說了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣一點也不有趣，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還想著「會不會有什麼事件發生呢～」！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……不對不對，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n對那種事情抱有期待是不好的對吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我知道的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "剛才的是說錯話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請你忘掉～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "實際上，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和平就是最好的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "竟然期待發生事件，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我真是英雄失格。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "深刻的反省了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是幹勁十足！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "自己終於也能夠，\n為【王宮騎士團】盡一份心力了！",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是能夠為世界和平而戰了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是令人情緒激昂～☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇？",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請不要一邊說「好乖、好乖」，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一邊摸我的頭啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然很開心，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但是帽子要掉下來了～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗯呀？",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n剛才，臉頰被水滴打到了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難道說，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要下雨了嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真糟糕。",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n牧場在山上，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n在大雨中登山太過危險了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "地面變得很容易滑倒，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不小心跌倒摔下懸崖的話說不定還會死掉。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這座精靈之森……",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好像是由某個公會在守護著的樣子，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n似乎會比其他森林要來得安全。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過也不可能沒有魔物存在，",
        "unit_id": 100511,
        "voice": "vo_adv_1005005_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要是到處亂晃，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會被當成飼料的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
