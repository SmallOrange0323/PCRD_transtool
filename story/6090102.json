    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然我是像這樣成為怪盜了……",
        "unit_id": 121511,
        "voice": "vo_adv_6090102_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但老實說，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我沒什麼自信……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對怪盜而言，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "重要的是什麼事呢……？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 121511,
        "voice": "vo_adv_6090102_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是這樣嗎？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "像是鋼索槍",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "或煙霧彈，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n帆稀小姐她有幫我準備了各式各樣的道具……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但我不覺得自己能熟練使用那些道具……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "能夠做得下去嗎……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就是說呢……",
        "unit_id": 121511,
        "voice": "vo_adv_6090102_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果被人發現自己潛入，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要偷寶物就會變得非常困難了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "希、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "希望能夠在這裡好好發揮……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我不引人注目的能力……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘉夜小姐、",
        "unit_id": 121511,
        "voice": "vo_adv_6090102_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "帆稀小姐、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "祈梨……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我有這些",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "非常值得信任的夥伴……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我雖然很沒用……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但如果和夥伴一起……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "或許總會有辦法的……！",
        "unit_id": 121511
    }
]