[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被雪叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓你久等了。",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼我們就去約會吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？我沒有說過是約會嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n好啦，既然能夠和我約會，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這些小事都不重要對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼接下來，要先去哪裡──",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇，好刺眼……！？",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這是，之前的那個！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇～",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "！",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}，難得和我一起出門，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "多仔細看我一點也沒關係唷？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你看，因為我這麼可愛呢，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以可以多多欣賞我一點唷？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，原來如此！",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是因為我太耀眼了，無法直視我對吧？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "僅僅是存在於世上，就會傷害到人……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，我是多麼罪孽深重啊。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？為什麼要嘆氣呢？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……總覺得你啊，從剛才開始就有點冷淡呢？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是繼續擺著那種態度，我就要另尋新歡了唷？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要我使出真本事，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n馬上就會被人搭訕的！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "欸，妳真可愛啊！",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，已經來了嗎……？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我明明就還沒表現我自己……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真不愧是我呢！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是像我這麼可愛的話，也就沒有必要表現了唷。",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也這麼想對吧？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "嗯？什麼啊，原來有男人跟著喔……",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_014"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n比起那種不起眼的傢伙，還是跟我玩比較好吧？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸～該怎麼做呢。",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我和這個人有很深的羈絆呢。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為呀，我們是赤裸裸坦誠相見的夥伴呢……嘻嘻。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}也真是的，\n害羞起來真是可愛！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "喂喂喂！",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_017"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n不要無視我在那邊恩恩愛愛的！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "既然這樣我也脫光和妳親密接觸吧！",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_018"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n過來我這裡！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不要啦～",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n{player}，救我呀～",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "怎樣，你要妨礙我嗎？",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_020"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "只顧著自己快活！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n絕對饒不了你！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拜託，不要吵架！",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不要為了我爭執！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，聽到我美麗的聲音耳朵都快融化了對吧？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，既然是為了我吵架我就不能不出聲唷！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣啊……都是我太美的錯……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是想這麼說對吧？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯！就是因為我這麼可愛，所以才有錯的！",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，我多麼地罪孽深重……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "你們兩個，囉哩八唆的吵死了！",
        "unit_id": 1331,
        "voice": "vo_adv_1008008_025"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n既然這樣，用盡全力也要讓妳聽話！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇，生氣了耶……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看起來不像是能和平對話解決的呢。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我不想讓這個人受傷呢……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸？等等，怎麼了？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n為什麼要抓住我的手？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣啊，是為了逃走……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……唔，嗯。我知道了。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "絕對不要放開我的手唷？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_029"
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呼，呼，呼……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總算是逃掉了呢。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n長的太過可愛就會發生這種事，真累人呢。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，這就是上天施加在太美麗的我身上，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n類似天罰般的東西呀。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是沒辦法……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟比我還要有魅力的事物，",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n在這個世上是不存在的呢！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，但是……",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你拉住我的手的時候……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有一點點帥唷。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從今以後，也絕對不要放開我的手唷？",
        "unit_id": 100832,
        "voice": "vo_adv_1008008_034"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過雪不管在「那邊」還是「這邊」，",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n完全都沒有改變呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他覺得自己比誰都可愛。",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為是最可愛的，所以認為就算弄得大家團團轉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n造成其他人的困擾也不會有問題，大概是這樣吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對這樣的想法毫無疑慮地深信不疑還挺可怕的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，不過這種厚臉皮的地方也是他的優點，",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說實在真的有點羨慕呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，說太多閒談也沒用，",
        "unit_id": 190011,
        "voice": "vo_adv_1008008_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次就先這樣吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "終於醒來了呢？",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我們好像又睡著了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後呀，我做了一個不可思議的夢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008008_043"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我夢到，你幫我逃離一個搭訕的男人……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
