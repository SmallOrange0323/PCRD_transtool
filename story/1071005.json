[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克莉絲提娜無意間聽到幾位看似已婚女性之間的閒聊內容。"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "到頭來，結婚這件事，",
        "unit_id": 413,
        "voice": "vo_adv_1071005_000"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "說白點還是「繼續走」呢。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "說得對極了。",
        "unit_id": 411,
        "voice": "vo_adv_1071005_001"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "結婚並不是終點。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n真想回去警告以前的自己哪。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "意思是說，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算已經立下婚約，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但若沒有繼續進行結婚生活，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就不算有完成「誓約」嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼說來……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽說咲戀育幼院的成員",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "目前正在員工旅遊中呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n記得沒錯的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只有需要去打工的小子一個人留下來看家……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唔姆♪",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_007"
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事情就是這樣。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從今天起，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n小子你和我要在此處開始進行",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「結婚生活模擬演習」。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你沒有異議吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哪裡聽不懂？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，你聽好了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n萬一屆時要實現誓約時手忙腳亂，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可謂欠缺戰略性的表現。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了防止此狀況發生，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我才來提議事先進行演習。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用不著擔心。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我已經有取得咲戀大小姐的同意了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖說我算不請自來的老婆，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我可不會去做些與親戚產生衝突的事哪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如何啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經開始有我是個能幹妻子的預感了吧♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你消化事情的能力還是老樣子呢。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過──也罷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽不懂也無妨！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種情況，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論是不請自來的人或該對象，都得順著氣勢走。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "論一般世間認知，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種事通常都是在半推半就的狀態下開始的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事情就是這樣。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你和我的結婚生活……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是特地改個說法吧──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你和我的",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「新婚生活」！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n已經",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在順水推舟下",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "揭開序幕囉♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小女子不成材，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "未來請多指教☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………雖然",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "強硬地把自己送上門了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但其實，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次我並非很有自信。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟克莉絲提娜我，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "個性可是自己與他人都公認的旁若無人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對身旁的人視若無睹，行為毫無顧忌，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的我要和他人持續進行共同生活，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟是否有可能達成？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使是我本人……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也對此感到無比疑惑。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我聽到「結婚就是繼續走」",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那句話後感到很在意，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n老實說沒多想就直接衝來這裡了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，誓約確實是必須絕對遵守的沒錯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為了讓絕對能繼續維持住絕對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我無論如何都得實行這個模擬演習。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結婚生活……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這或許會是近年來少見的強敵呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟它會多難對付呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我好期待哪♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_026"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天早上──"
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "{player}，早啊☆",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "終於醒啦？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還真的是不擅長早起呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我已經",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做好早餐囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我只是把現有食材湊合一下，隨便做做而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……有很多道菜色？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "噢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟早餐可是一整天的活力泉源。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要確實把五菜一湯都吃完再上戰場。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可是基礎戰術。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那當然。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "除非是敵對關係，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人與人之間就該互相配合時間一起用餐。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n此乃人際關係之基本。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了，快吃吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雙手合十──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要開動了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……有那麼好吃嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那太好了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……是啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底是怎樣工作才會把鞋子弄得那麼髒？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是跑去沼澤送貨嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "昨天晚上我就把鞋子拿去洗並晾乾，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在應該已經可以穿了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──對了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "另外，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還做了便當。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟你的工作是體力活，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在便當裡幫你放了兩層份量較多的肉跟飯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至於蔬菜你應該有喜歡和不喜歡吃的吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是我目前還沒有完全掌握。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以，第三層放的是水果。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果你不介意，就帶這便當出門吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，一臉驚呆的表情？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……沒想到克莉絲提娜竟會願意做到這種地步……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──哈哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n全都是我等你起床時，打發時間做的而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人生可是先搶先贏。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果不想要家務事全被我搶去做，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你可得更早起哪♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啦，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你吃完了吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n差不多得出門了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "否則會遲到喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好～",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你來站在這邊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "臉色OK。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便當OK。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "披風OK。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽好了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果有人敢欺負你，就立刻跟我報告。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n身為你妻子的我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「絕對」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會替你報仇的☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，小子──",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "噢……先等等。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……有亂翹的頭髮……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣就行了♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，重新來一次。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "{player}，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "路上小心☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本還以為會經歷一番波折，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但意外地還挺順遂的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "夫婦間合得來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是這種感覺嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔姆♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天晚上──"
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "歡迎回家，小子☆",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n今天一整天辛苦了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你沒想到我已經回來了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的工作？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然已經都處理好才回來的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "去監督慈樂之音演唱會的會場佈置、",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "商量新曲的主題理念、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "開會討論牧場下一季的活動企畫、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "處理幾件新的企業諮詢案。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再來就是以【王宮騎士團】身分去幫忙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大概就這樣吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不，還好啊？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這點工作量，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "稱不上什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實際上，下面的人在我命令之前就已經做好判斷了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n除了非得親自來的部分，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相關作業也都交給可信賴的人處理，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我只要聽狀況回報就好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我做這些工作，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "基本上不需要花時間。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n更何況，這些事原本算是興趣的延伸。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此，你無須擔心。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是不會把工作給帶回家的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我今天也下午就回到家了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是已經洗好澡囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晚餐也已經煮好了……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你想要選哪個？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先洗澡、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先吃飯、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是先──！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "開玩笑的啦☆",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我逗你玩的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……果然狀況一切順利♪　",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "兩人一起生活，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "家務事自然會增加，因為多了這些事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不用再拚命躲避無聊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我賺來那些閒錢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也多了可以花的地方。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼哼。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來結婚生活，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n意外地是很好對付的敵人嘛♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──小子，你怎麼了？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟露出那麼悲傷的表情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──喂。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你擺那什麼臉，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡直就像頭上被放了一顆壓醃漬物的石頭般陰沉哪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所有大小事都讓我做了，覺得很不好意思？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原本打算至少幫忙做晚餐，所以才趕回家，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結果發現連晚餐都做好了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你覺得明明克莉絲提娜不管是家事還是工作都完美處理好了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n自己卻什麼事都沒能",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幫到忙……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來有那種想法嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……的確……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們之間的家務事分配，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有著很大的偏頗……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "分工內容本來就會因雙方能力值不同而異。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我只是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "依照自己的步調，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "完成自己能做到的事情罷了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n小子肯定也是相同的吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這便是我們之間的自然平衡……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若硬是平均分配家務事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "則很不合理。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "倒不如說是，不自然。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但──",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_075"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若是這個自然而然產生的狀態，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n反而傷害到了小子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_076"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……果然，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_077"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像我這樣的人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不適合結婚生活──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……頭髮？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_078"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n意思是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你要幫我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "弄乾頭髮？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "髮尾看起來有點毛躁……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "噢，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說的是這件事啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為我覺得每次都要把頭髮弄乾很麻煩，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n常常放著讓它自然乾燥，就變成這樣了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在也是自然乾……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……要幫我弄乾頭髮，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是可以啦……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點小事真的就可以了嗎……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不認為只是幫忙弄乾頭髮，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_083"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n夫婦間家務事分配不平均的問題，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就能獲得解──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_084"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要我願意依賴你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論是什麼樣的事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都很開心……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………！",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_085"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_086"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來如此……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "重要的並非事務的大小或公平與否，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_087"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而是彼此",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相互託付，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是想表達這個意思吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唔姆！",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_088"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_089"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是好險……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來我堂堂克莉絲提娜，",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_090"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎差點不小心就要在結婚這座",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n魔宮的入口處掉進陷阱裡了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過──小子。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_091"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n多虧有你，我得救了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要向你道謝！",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_092"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好～♪",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_093"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼就依照你的希望，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓你幫忙弄乾我的頭髮吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_094"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "麻煩了☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_095"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "託付……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_096"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n此事看似簡單，實際上卻很難。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子這傢伙……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本以為無法輕易攻破的這座魔宮……",
        "unit_id": 107111,
        "voice": "vo_adv_1071005_097"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "照這樣看來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "搞不好出乎預料地有辦法攻下呢♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜把頭靠在{player}身上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n開心地露出了微笑。"
    }
]