[
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……唉……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在打西瓜的過程中出了意外，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n使得莉莉撞上了{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於事情發生得太突然，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n陷入慌張的莉莉"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是逃離了現場──"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……太陽",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "終於下山了呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我居然會過於沉浸在聆聽兄長大人的聲音……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n導致自己",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "與他相撞……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還穿著這樣……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "單薄的衣服。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊啊，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "光是回想起來，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我的臉就快要燒起來了……！　",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……再者，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我做出的無禮舉止，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不只是撞到兄長大人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在兄長大人告知我之前──",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一直都拿著武器對準他。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "無庸置疑的事……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我居然用過度裸露肌膚的身姿",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "碰到了兄長大人，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n甚至還把劍尖對準了他……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "自我了結……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "吧。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "果然",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "應該要這樣才恰當……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原本是該穿上素服的，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但我這個罪人又怎能奢求。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至少，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這白色沙灘的沙子正好適合──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是我的錯覺嗎，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好像……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有像是叫聲的……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "細微聲音……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……如果是魔物，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也可能會危及在海邊的人們呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n在自我了結之前，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "必須去確認一下……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啾……",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n啾啾……",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "哎呀？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n在那裡的是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "海龜──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "仔細一看，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這應該是魔物的孩子……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "魔物的孩子們",
        "words": "啾～！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "哎呀，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這是怎麼了……！？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "冷靜下來……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看來果然是魔物呢……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n而且",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "似乎才剛出生不久的樣子。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即便是魔物，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要對這樣的孩子下手，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還是會於心不忍……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……話說回來。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n雖然我的體質",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是會讓動物對我有好感，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但牠們一下子就往我這邊靠了過來……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是牠們碰上了什麼麻煩事嗎？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n魔物的孩子們，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "能告訴我",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "究竟發生了什麼事嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "魔物的孩子們",
        "words": "…………",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要和牠們溝通……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "果然很難呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "牠們的樣子看起來很不尋常，我有些擔心……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "中型魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "什麼！？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "海中",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也出現了魔物……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "魔物的孩子們",
        "words": "（抖抖抖……）",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……原來如此，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這些孩子是從那隻魔物的手中逃出來的。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "居然想對年紀尚小的孩子下手……！　",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "中型魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我並不打算否定自然界的弱肉強食。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可是……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這樣未免太過欺負弱者了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我可不能裝作沒有看到。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好了，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_020"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "放馬過來！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n就由我",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "作為你的對手──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n來吧！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "十幾分鐘後……"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "喝啊！！！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_021"
    },
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "中型魔物",
        "words": "──嗚喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "唔！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_022"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "攻擊完全無效……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然兄長大人指導過我，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_023"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但我的劍術",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還不到家……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在實戰中使用太勉強了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "然而現在，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_024"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就算哀嘆自己的不成氣候也無濟於事。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n得趁還有體力的時候，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "使出能改變戰況的招式……！　",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然如此──",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_025"
    },
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_026"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我還真是",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_027"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "膚淺呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "鍛鍊自身的實力，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_028"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n讓自己不去仰賴「黑天使之力」，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就是我行腳遊歷的主要目的。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然如此，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個狀況",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可謂是大好機會。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "敵人是一隻小型──",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_029"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是中型魔物。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我方只有一人，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "武器只有仿照劍身外型製成的一根木棒。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我很清楚這是場苦戰。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_030"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對於像我這樣的罪人──",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_031"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n艱難困苦的道路",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正好適合。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "中型魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我要迎擊了……！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_032"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n喝！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_033"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這個感覺──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道是！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_034"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我明白了！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_035"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n獲得{player}強化的莉莉大展身手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n擊敗了想對魔物的孩子們下手的魔物……"
    },
    {
        "type": "dialogue",
        "name": "魔物的孩子們",
        "words": "啾～！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "各位，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_036"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請多加小心……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n還請大家要成長為心地善良的魔物喔……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……牠們離開了呢。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_037"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_038"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……兄長大人。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_039"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n感謝您",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "助我一臂之力。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "憑我一個人的力量……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_040"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是絕對",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "沒有辦法打倒那隻魔物的。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "之所以能打敗它，都是因為有兄長大人的幫忙。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這樣的稱讚，我真是受之有愧……！",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_041"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "光靠我的劍技，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "完全沒辦法對抗魔物……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "實在是太羞愧了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那是……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_042"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_043"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果要說",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_044"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我沒有那樣的感受……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n就是在騙人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "和以前相比，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_045"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我認為自己",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n能更完整地承接住兄長大人的力量了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……然而。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_046"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這只是我自以為是。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我太依賴兄長大人的溫柔，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_047"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "把自己當成一回事的下場……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n便是誤判距離，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "導致了碰觸到兄長大人貴體",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這般有失禮數之事態。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "──兄長大人。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_048"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我剛才逃離了現場，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真的非常抱歉。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我得到了一些時間，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_049"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "做好心理準備了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n請狠狠地",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "責罵我吧。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……不管是什麼樣的懲罰，我都願意承受。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………唔。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_050"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………咦？",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_051"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，兩人在夜晚的海邊散起了步。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n莉莉走在{player}的身邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n偷偷觀察著他……"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_052"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n什麼話都沒有說呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "他是……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_053"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在生氣嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還是說……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "他果然",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "認為我是個放蕩的女孩，而鄙視我……？　",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至少",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_054"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要做點什麼──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要是能洞悉",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人的部分想法……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是、",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_055"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大海，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_056"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是嗎……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_057"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……現在想起來才發現，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_058"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我不曾有過片刻閒暇，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在悠然地欣賞大海……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "和做好事社團的大家一起行動時，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_059"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當然是沒有什麼空閒。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是在那之後，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也並沒有把心思放在大海之上……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我甚至不覺得自己",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有聽見海浪的聲音。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……真的",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_060"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "很美呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n即使是在暗夜之中，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "它依然映照著月光，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "清澈透亮。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n而且，不管到哪裡",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都是這麼廣闊。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……簡直就如同兄長大人的心胸一般。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_061"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不論是罪孽或汙穢，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_062"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "甚至是懊悔。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n都會用廣闊而美麗的心胸來接納。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人就是這樣的人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正因如此……",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_063"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我才會",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "感到害怕。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "被溫柔的兄長大人接納、",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_064"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "包容之下──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n感覺甚至會遺忘掉自己的罪惡。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我害怕這種事會成真。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我是個意志薄弱的人。",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_065"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n甚至可以說是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "貪圖安逸……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n很容易便會選擇輕鬆的做法。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要說如今這樣的我，",
        "unit_id": 131611,
        "voice": "vo_adv_1316003_066"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至少還能做到什麼事……",
        "unit_id": 131611
    },
