[
    {
        "type": "background",
        "background": "501670"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧提格尼亞某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可麗餅的攤販前。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我呀，",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這6.5年來",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一直都在思考。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要怎麼用可麗餅，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來表達我至今傾注在弟弟身上的",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這份愛呢。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "於是我幫忙完成了",
        "unit_id": 101112,
        "voice": "vo_adv_9009003_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個等比例的哥哥可麗餅！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以吉歐‧提格尼亞產的奶油、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "水果和可麗餅皮，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n完美地重現出了哥哥的模樣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "多麼精緻的可麗餅呀……",
        "unit_id": 1,
        "voice": "vo_adv_9009003_002"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n能夠真切地",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "感受出製作者的愛呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "以可麗餅來呈現真的很厲害呢！",
        "unit_id": 1,
        "voice": "vo_adv_9009003_003"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n不是用糖雕……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "而是選擇了難度更高的可麗餅，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n感覺真不愧是異文化！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然",
        "unit_id": 101112,
        "voice": "vo_adv_9009003_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "每一根頭髮都是完美的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "俗話都說",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "頭髮藏在細胞裡嘛♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對弟弟的愛固然重要，",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但也需要技術。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是只有兩者兼具，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才能做出的可麗餅唷♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這就是",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐之力！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以及妹妹之力的",
        "unit_id": 101112,
        "voice": "vo_adv_9009003_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "共同合作呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該跟哥哥擺在一起拍照嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是等做了更多更多的可麗餅以後再拍照呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個等比例的哥哥可麗餅",
        "unit_id": 101112,
        "voice": "vo_adv_9009003_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是愛情和技術的結晶。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n等到可以大量生產的那一天，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "肯定會對可麗餅產業帶來震撼！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你說，",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是這樣沒錯吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "不好意思！",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_009"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n請問也可以幫我做一個",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我達令的可麗餅嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我也要！",
        "unit_id": 1,
        "voice": "vo_adv_9009003_010"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "這樣的話",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "就算分隔兩地也能在一起了♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然沒有問題♪",
        "unit_id": 101112,
        "voice": "vo_adv_9009003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就用妳喜歡的水果和奶油來做吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家只要有珍視之人的等比例可麗餅，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就能夠變得幸福喔！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "希望弟弟",
        "unit_id": 104914,
        "voice": "vo_adv_9009003_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也能盡情品嚐",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個等比例的弟弟可麗餅喔♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我們還打算",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要做很多很多個呢♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜流和璃乃的心血之作──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n創新的可麗餅於吉歐‧提格尼亞蔚為話題，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n之後在廣場上展示了一段時間，成為了一處旅遊景點。"
    }
]