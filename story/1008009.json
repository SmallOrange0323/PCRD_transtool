        "type": "dialogue",
        "name": "雪",
        "words": "只要用我美麗的心眼去看，輕而易舉就能解決。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你自己有沒有發現？",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_061"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你即使身處艱難的情況，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也會隨時保持抬頭挺胸，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "望向前方。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這一點，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算你變成魔物也仍未改變。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更何況，",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_062"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你這個人整體散發出一種和煦的氣息，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n再來就是笑起來時眼角會往下垂、",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟小狗一樣微微歪頭的舉動等等……",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n其實許多動作都還挺好辨認的。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算外表改變了，",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_063"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種行為舉止的細節是不會變的。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這正是",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_064"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你與魔物的關鍵差別。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n畢竟若只是當場有樣學樣，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可無法連這種小細節都重現呢。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明白這點後，就只需要仔～細觀察囉。",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_065"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很簡單吧♪",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……咦，",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_066"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了？",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你看起來好像很開心，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是發生了什麼好事嗎？",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這不是當然的嗎。",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_067"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是和我相處時間最多的人，",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_068"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "除了我自己以外，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你是",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最常映照在我眼裡的存在。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可要好好地",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_069"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "打從心底感到光榮哪。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇呀！",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_070"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "討厭，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這次又是發生什麼……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n恢復了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "變回人類的模樣了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太好了……",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_071"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我原本還一直都很忐忑不安，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n想說該不會要永遠維持魔物的樣貌吧……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怪了……",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_072"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總覺得前面那邊",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是不是有個像出口的東西呀？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n空中還浮現出了文字……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「通過測驗」？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇～！",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_073"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "通過測驗了耶！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太棒了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……不過，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "到頭來這測驗，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是在測試我們什麼呀？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_074"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "多想也無益。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "反正只要成功通過就好了對吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在繼續出發前──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再讓我",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_075"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好好享受一下恢復成原本模樣的自己！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我好想見你呀！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然變成魔物時的樣子也很有魅力，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_076"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但果然",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還是這模樣最棒了呢！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵呵呵♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從雪的眼眸中被趕出去的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n默默地望向了遠方心想："
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看來，得繼續在這裡待上一段時間啊……"
    }
]