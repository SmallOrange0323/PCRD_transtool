[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的一個下午，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被雪叫到餐廳見面。只不過──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊……",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是太驚人了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n沒想到呀，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真沒想到",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就連映照在湯匙上的臉都如此美麗……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即便扭曲、",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "甚至倒過來，都能夠這麼地美，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這恐怕是跨世紀的大發現吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "學會一定不會放過這資訊的！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "抱歉抱歉，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你能稍微安靜一下嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我現在",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "正見證著奇蹟的一瞬間……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想喔，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你就再等個五小時左右吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼事……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等等，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這不是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "鏡子嗎！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然處於特異狀態的我很美，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "映照在一般鏡子裡的我果然才是究極的美呀！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "乾脆輪流看",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "湯匙和鏡中倒影來進行比對如何呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能見識到有如萬花筒般的幻想美麗世界──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊！",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不見了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你為什麼要做如此過分的事呀……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……對耶，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是有事才會找你來的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n由於有了意想不到的發現，讓我有些忘乎所以，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對不起唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "其實是呀，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我希望",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你能陪我去一個地方。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是一座有著「美之聖域」稱呼的神殿……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該知道愛梅斯神吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽說她",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也有著美之女神的另一面，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要前往那座神殿，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就能獲得美的祝福喔！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "已經是美麗化身的我不需要祝福吧──",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你看起來似乎是想這麼說呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過呢，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果現在外表已經十分完美的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n有機會",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "升級到神一般的美貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就還是很有過去一試的價值對吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只不過有一個問題，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是那座神殿",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎在很遙遠的邊境之地。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "像我這般柔弱可人的存在，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要獨自前往那種地方，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n會令人不禁",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在各方面都感到憂心吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因此，想麻煩你",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以貼身護衛和負責拿行李的身分，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "陪同我一起去旅行。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不會讓你做白工的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我就賜予你有幸第一個見識",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "變得更加美麗的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "的權利吧♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和我來趟雙人旅行，",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再加上這至高的獎勵，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "根本沒有理由拒絕對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "事情就是這樣，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明天就要出發了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "多指教囉♪",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "500403"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}就在雪的強硬態度下半推半就地一起同行了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自蘭德索爾出發後，便陪著雪四處繞道，走走停停了好幾天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n最後兩人終於抵達了目的地「美之聖域」的入口。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哦～",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡就是「美之聖域」嗎。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "確實不愧對那宏偉氣派的名字，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有著相當不得了的氛圍呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這下似乎也能期待祝福的效果呢！",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就立刻過去吧──",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "500414"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……咦？",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦咦咦咦～！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼回事，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "發生什麼事了！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n剛才為止的神聖氛圍怎麼不見了？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看上去就挺陰森的呀……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種地方",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真的是「美之聖域」嗎……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你怎麼看，{player}……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼？",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你在說什麼奇怪的話──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚哇啊啊！",
        "unit_id": 100811,
        "voice": "vo_adv_1008009_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "魔物……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等等，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "該不會是{player}吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這也代表……",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊、",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊……",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也變成魔物了～！",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這、",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是怎麼一回事……",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼會變成這種狀況？",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n儘管變成魔物的我十之八九也很可愛，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但即使如此也太過分啦！",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這、",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼說也有道理，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想要",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "獲得女神的祝福，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就必須先通過一兩個測驗，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種事確實也不足為奇呢。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 1615,
        "voice": "vo_adv_1008009_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算是測驗，",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓人變成魔物果然還是太過分了。",
        "unit_id": 1615
    },
    {
        "type": "dialogue",
