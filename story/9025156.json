[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "乖乖、乖乖～",
        "unit_id": 105811,
        "voice": "vo_adv_9025156_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家沒事吧～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大姐姐們來救大家了～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來",
        "unit_id": 105911,
        "voice": "vo_adv_9025156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有生病也沒有受傷。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "二、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "三……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "失蹤的孩子們應該都在這裡了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚哇～",
        "unit_id": 211,
        "voice": "vo_adv_9025156_002"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "對不起～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事真是太好了♪",
        "unit_id": 106011,
        "voice": "vo_adv_9025156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些魔物",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有沒有",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "傷害你們？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "傷害？　",
        "unit_id": 211,
        "voice": "vo_adv_9025156_004"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "沒有啊，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們玩得很開心喲！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "在附近森林玩耍時，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "聽見了太鼓的聲音……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們往鼓聲傳來的方向走過去，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "然後就回不了家了。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "雖然遇見魔物時覺得很可怕，",
        "unit_id": 111,
        "voice": "vo_adv_9025156_005"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "但是跳舞很有趣，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "所以後來就不會感到害怕了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我們一起跳舞，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "變成了朋友！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸、",
        "unit_id": 106011,
        "voice": "vo_adv_9025156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那真是太好了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來還發生了這種事……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過呢，",
        "unit_id": 106011,
        "voice": "vo_adv_9025156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽好囉？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物不全然是善良的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n很恐怖、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很～危險的魔物也不在少數喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這座島嶼",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n充滿了各種未知的事物。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們絕對不能再隨便亂跑囉？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了好了，",
        "unit_id": 105811,
        "voice": "vo_adv_9025156_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這些孩子有在反省了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們趕緊回村吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡有肉乾，要不要吃吃看啊♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有，",
        "unit_id": 106011,
        "voice": "vo_adv_9025156_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不能相信這個大姐姐。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為她會拿奇怪的東西給你們吃。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快走快走！",
        "unit_id": 106011
    }
]