[
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔？",
        "unit_id": 106811,
        "voice": "vo_adv_5212322_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "確認到敵人周圍有遠古遺物！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n大家，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "比起目標的BOSS，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先瞄準那些傢伙！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "遠古遺物？",
        "unit_id": 136511,
        "voice": "vo_adv_5212322_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在說",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個小型魔物？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊啊，",
        "unit_id": 106811,
        "voice": "vo_adv_5212322_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是很久以前的測試資料。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那些魔物裝有BOSS戰用的機關，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n打倒後，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就能發動對我們有利的附帶效果。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來如此，",
        "unit_id": 137911,
        "voice": "vo_adv_5212322_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼就是要先來",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「大頭針」對吧！",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當作是順便年末大掃除，",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "用我的箭收拾得一乾二淨吧！",
        "unit_id": 137911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說得對，",
        "unit_id": 106811,
        "voice": "vo_adv_5212322_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "交給妳「打頭陣」了！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "璃乃！",
        "unit_id": 106811
    }
]