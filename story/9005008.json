[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽了伊莉亞的建議，雪菲重新調整尋找禮物的方向。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時有個聲音叫住了她。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "找到妳啦！",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n龍人族小妹妹！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_9005008_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n呃、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳好，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我都聽說了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳正在煩惱紀念日要送什麼禮物是吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃、",
        "unit_id": 106412,
        "voice": "vo_adv_9005008_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這件事",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳是從哪裡得知的啊？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無須在意！",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那些瑣事無須在意！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "關於禮物的事，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會在百忙之中撥冗，\n為妳提供全方位的協助！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "儘管感謝我吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不用了。",
        "unit_id": 106412,
        "voice": "vo_adv_9005008_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當機立斷！？",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳竟然當機立斷拒絕我！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼？",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我只不過是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n想要打造一座尤絲蒂亞娜陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "的黃金雕像來作為紀念日禮物……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然會動用到一點國家經費，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但肯定會皆大歡喜的吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_9005008_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我覺得【美食殿堂】的成員裡，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n沒有人看到自己的雕像會覺得歡喜的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再說，",
        "unit_id": 104711,
        "voice": "vo_adv_9005008_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼能讓妳那樣任意妄為呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哇！？",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是【王宮騎士團】……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……哦呵呵呵，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "日安呀妳們好啊～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉、",
        "unit_id": 104711,
        "voice": "vo_adv_9005008_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n幫我把她帶回王宮。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "了解！",
        "unit_id": 100512,
        "voice": "vo_adv_9005008_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來來，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳給我乖乖配合～！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103712,
        "voice": "vo_adv_9005008_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要掙扎好嗎？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都該是個成熟的大人了，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在搞什麼啊……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n工作堆積如山了喔……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "放開我！",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳們放開我！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "尤絲蒂亞娜陛下欽點的內政大臣啊～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然如此，就請妳不要把國家經費挪為私用好嗎……",
        "unit_id": 103712,
        "voice": "vo_adv_9005008_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉，真是的，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳幫我",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抓住她的腳。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好的！",
        "unit_id": 100512,
        "voice": "vo_adv_9005008_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n克蕾琪塔阿姨，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有什麼話待會再說吧。",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可惡────！",
        "unit_id": 118011,
        "voice": "vo_adv_9005008_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是不會放棄的────！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我一定會留下對陛下忠心耿耿的證明──────！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……抱歉，",
        "unit_id": 104711,
        "voice": "vo_adv_9005008_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "給妳添麻煩了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不會……",
        "unit_id": 106412,
        "voice": "vo_adv_9005008_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n純小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也辛苦了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽著克蕾琪塔的喊叫聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲和純輕輕嘆了口氣。"
    }
]