        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算是像那樣子的人，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果不在身邊也會讓人很困擾呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不管什麼時候，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算是陷入了危機",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "他也都會很冷靜……",
