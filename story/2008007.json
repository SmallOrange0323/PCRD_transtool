    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要有那個人在，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該說是",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就能夠安心嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嘻嘻。",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n鏡華也一樣，",
