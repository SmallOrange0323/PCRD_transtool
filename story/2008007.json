    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "妳真厲害呢，鏡華！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n好棒棒，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "摸頭頭♪",
