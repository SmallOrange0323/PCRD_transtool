        "name": "美美",
        "words": "\n鏡華和禊就會肚子餓了呢。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n所以三個人分著一起吃吧♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！",
        "unit_id": 100411,
        "voice": "vo_adv_2008007_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我嚼我嚼……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "超好吃～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "吃了甜的東西後精神都來了☆",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊的話隨時是精力充沛的吧……？",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是。",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n雖然偶爾會惹人生氣，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但兩人能夠陪著我，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "實在太好了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "若只有我一個人，絕對會嚇到不知道該怎麼辦呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是到底，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼我們會跑到這個地方來呢……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "記得沒錯，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們幾個，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是一起出來玩的吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我們三人，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就像平時一樣，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "假裝是大人的公會在玩扮家家酒。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒記錯，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好像是發現了停住的馬車，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n假裝是探索城堡或是地下城的冒險者公會一樣……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "偷偷的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "潛入了馬車的車箱裡面來著？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "發現寶箱！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": " 在這麼講完後，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊就擅自把車箱裡載著的箱子給打了開來……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "接著，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "飄飄然的～煙霧就瀰漫了起來呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "自然而然就不小心吸了進去，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n然後就突然變得很睏了呀。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……最後，可能就那樣睡著了呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個箱子裡大概裝著，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n會讓人想睡覺的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔法所做出來的東西吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那樣的東西，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也有聽說過有些社會人士很需要呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後三個人就那樣睡著了，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而駕馬車的人也沒發現就出發了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n之後就被帶到了距離蘭德索爾，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n稍微有一點遠的這個地方。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後駕馬車的人，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "發現了坐霸王車的我們幾個，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n一氣之下就把我們扔了下來嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還是說，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "馬車晃呀晃，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就把我們從車廂上晃了下來呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不管怎樣，",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_039"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼想都是自作自受……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n哎～",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是嘛，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "看起來是可以安全的回到蘭德索爾也就算了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但下一次，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不再小心一點行動不行呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華，",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_040"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好像又在想什麼了……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這時候如果跟她講話又會生氣了，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "還是等一下吧。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_041"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗯嗯？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這個是……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "什麼東西呀？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "怎麼了嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_2008007_042"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "美美？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n妳在看什麼呢？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯嗯～？",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_043"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n那個，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好像有什麼東西動來動去的……？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……！？\n美美，不行！",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_044"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那個，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是魔物的尾巴嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_045"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦！？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！",
        "unit_id": 100411,
        "voice": "vo_adv_2008007_046"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真的耶！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n有隻超大的魔物！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "話又說回來……",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_047"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀啊啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "草叢的附近，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不知不覺冒出了一大堆魔物！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎怎怎、怎麼辦？",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n該怎麼辦才好！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": " 好可怕～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "冷靜一點，鏡華……",
        "unit_id": 102011,
        "voice": "vo_adv_2008007_049"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n魔物先生牠們，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好像還沒有發現我們在這裡唷。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n『噓～』不要說話，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "再躲好一點應該就沒問題了唷？",
        "unit_id": 102011
    }
]