        "name": "禊",
        "words": "嗯！",
        "unit_id": 100411,
        "voice": "vo_adv_2008007_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n鏡華也這麼加油了，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以讓禊幫妳按摩肩膀吧！",
