    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才、",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才不是喜歡他！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才不是啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊喜歡哥哥唷～！",
        "unit_id": 100411,
        "voice": "vo_adv_2008007_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好想他呢，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不知道他現在在哪裡，做些什麼事呢？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不知道耶……",
        "unit_id": 103611,
        "voice": "vo_adv_2008007_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但這時間的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說不定剛起床，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才正在吃早餐呢。",
