    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "就算是迷路了也有好事情呢♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要那麼悠哉呀……",
