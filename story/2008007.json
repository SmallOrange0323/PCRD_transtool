        "voice": "vo_adv_2008007_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊這裡有零食唷！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n先吃這個吧，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "美美♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "謝謝妳～♪",
