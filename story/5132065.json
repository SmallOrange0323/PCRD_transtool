[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "進行著聖誕節準備的貪吃佩可，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在街上偶然地發現了熟人的身影。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀？",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那道可愛的背影是……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡希──！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯？",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "貪吃佩、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡希？",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳怎麼了嗎？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是什麼，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這到底是怎麼回事啊──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡希冷靜點……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳在說什麼，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這要人怎麼冷靜得下來！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "貪吃佩可，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳這身衣服到底是什麼啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想想……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這件衣服，\n是克蕾琪塔小姐說要做為聖誕節活動用",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為我訂製的……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來著……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有哪邊不對勁",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是嗎？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不對勁？",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請別說這種蠢話！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件衣服是已達極致的最高級藝術品哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "乍看之下很豪華，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卻也沒有因為是皇族，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就一味地",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "賣弄高級感，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而是均衡地呈現出了高雅與惹人憐愛的感覺。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可說是為貪吃佩可量身打造的設計！",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且這塊布料……",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是極為罕見的最高級品哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "居然能夠用這種布料製作禮服，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼有這麼幸福的裁縫師啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "令人羨慕！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然了，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "製作上也很細膩而完美。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在的我還無法達到這種境界……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "敬佩和不甘心快讓我瘋掉了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡、",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡希！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冷靜點，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳冷靜下來啊！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓妳看到那麼丟臉的模樣。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妳真是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "穿上了一套不得了的服裝呢，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "貪吃佩可。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "它可是一套能夠征服所有裁縫師的魔性服裝哦！",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎呀──",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "出門轉換心情果然是正確的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為我這陣子一直被工作逼得身心俱疲……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然說是我自願做的工作",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以不會感到厭惡，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n可是睡眠不足與疲勞使得表現變差，讓人蠻難受的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有幸見到這件衣服讓我的疲勞感一口氣全都飛到九霄雲外了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵呵，",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幹勁和想法源源不絕地冒了出來！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我要快點趕回去繼續工作！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "儘管不能像小望她們那樣",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幫忙活動，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到了當天我也會好好享受的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天非常謝謝妳。",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼我先失陪了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紡希。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走掉了呢……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得有種來去匆匆的感覺。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我原本沒有注意到，",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是居然能夠",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如此撼動人心……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "衣服真的很厲害呢☆",
        "unit_id": 127911
    }
]