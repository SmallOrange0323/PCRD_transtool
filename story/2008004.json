[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "still",
        "still": "200800401"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 106812,
        "voice": "vo_adv_2008004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位就是……",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n祕密社團【拉比林斯】的首領，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一位擁有著異樣存在感的人物呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n彷彿像是窺視著休眠火山口般的感覺，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不禁打了個冷顫。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是為何呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "包含著那股威壓感，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻也能感到種不可思議的親近感。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有在何處和這人物",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "曾經見過面的感覺……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有種和小時候見過幾次的親戚，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於某處又再會一樣的情感。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那個",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "伊莉亞小姐的古文書中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和長老的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和在下的父親之名，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被記載為『七冠』之一人的這件事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否又有所關連呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位人物，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定是一位與在下有著匪淺因緣的存在呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管有著不少疑問想要探個究竟。",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這是福是禍呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她似乎沒有要醒來的跡象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有點遺憾，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻又有點鬆了口氣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此這般複雜的心境。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哈嗚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您為什麼要摸摸在下的頭呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然會流露出這種情感，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下果然還完全不夠成熟呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是。",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能得到主人您的關心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使在下無比的欣喜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是個幸福之人呢……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～。",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然我也很抱歉在正火熱的時候打擾到你們，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但拉比林斯達的人妳們也見到了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來就去餐廳吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才、",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才沒有什麼火不火熱呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與平時並無兩樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是這樣見見她的樣貌而已嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n倘若能夠說上幾句話可就幫了大忙了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉比林斯達小姐她，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直都像這樣沉睡著嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那一次，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了要抵擋住大規模破壞魔法，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n拉比林斯達",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似乎拚盡了老命呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而因此汽油也燒光了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以就一直像這樣昏睡著。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汽油？",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是在指魔力耗盡見底，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像那樣的意思嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "除了讓她靜養之外沒有其他的方法了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也是呢～",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "姑且是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給她吊吊看了點滴，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或是嘗試了各式各樣補給魔力的方法就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但到現在都沒有什麼成果，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來除了等她自然恢復以外沒別的辦法了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "試著調查過發現，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉比林斯達是真那的……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊、不是，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在自稱叫什麼來著？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對對，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "叫尤絲蒂亞娜。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真是個難記的名字呀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別鬧別鬧，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽都沒聽過喔那種名字。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別就只是隨便說說啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "記得沒錯，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是叫尤絲蒂亞娜來著嘛……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了要壓制住那個邪魔歪道，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n拉比林斯達在那精神世界之類的……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反正",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是那方面的地方，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "正在和那個傢伙戰鬥的樣子。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若不小心把拉比林斯達給吵醒，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個戰鬥可能就會被中斷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而就連那個想要把我們一口氣全部滅掉的尤絲蒂亞娜，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也很有那個可能，會因此一起復活。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以說",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可能的話就維持現狀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "尤絲蒂亞娜……",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是那個奪走了貪吃佩可小姐立場的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "極惡之人呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那人是當下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可說是在下等人最大的敵人也不為過吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐她，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若正親手壓制著那邪惡的存在的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n趁這個好機會……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不得不盡力來做準備，好應付接下來的展開呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這麼一回事。",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們也一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "正為了這件事忙得團團轉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然不想讓你們也得跟著我們一起來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但若能幫點忙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就會讓人很高興了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是。",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必定竭盡所能。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟對矛依未小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有著救命之恩未償呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在說哪件事？",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n啊～……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是從被爆破的馬車上，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n把你們都給救下來的那件事嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也讓你們治療燒傷了嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n一來一往，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "誰不欠誰的感覺就是。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨天也是，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從要自爆的研究設施中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n親自帶領著在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "逃離了危險來到安全的場所避難。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管矛依未小姐的",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身分依舊還是個謎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下認為您是位值得信賴之人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟若真對在下等人有不利的想法，",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要在哪一個關鍵點上，對在下等人見死不救即可。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是剛好那麼做了而已啦。",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果肯把我當成同伴那最好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘻嘻。",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能和{player}你們同一陣線，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對我來說，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以說是像做夢一樣的發展呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總是看起來都很歡樂，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓人家對你們幾個……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很羨慕嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當然，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和尾狗刀兩人一塊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n當個壞人到處去搗亂也超開心的就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說真的，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那時不管做了些什麼都很精采啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n安穩的和平之中，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "偶爾吵吵鬧鬧的",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一段幸福的時光。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當然，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然也經歷過了可怕又傷心的事情。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但若現在看來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那些，全都很美好呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？ ",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是指什麼事呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來是聽不懂呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n包含這件事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晚一點再說明給你們聽吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "早餐應該快準備好了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們也去餐廳吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遵命。",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呆呆的",
        "unit_id": 105913,
        "voice": "vo_adv_2008004_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盯著拉比林斯達小姐看著呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n別人的睡姿，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是該讓他人觀察之物呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像這樣凝視並非是件好事唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是沒差啦～",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想她應該不會在意這點小事。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n拉比林斯達，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "她的個性挺隨性的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似乎也把{player}你，",
        "unit_id": 106112,
        "voice": "vo_adv_2008004_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當成弟弟或是孩子一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n特別愛把你逗著玩就是了呢。",
        "unit_id": 106112
    }
]