        "unit_id": 111411,
        "voice": "vo_adv_1114008_001"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "剛才跟老婆婆在一起唷！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是在一起玩娃娃唷！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_002"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也喜歡娃娃嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜最喜歡了！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……啊！",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_003"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n那個，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還有還有……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_004"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……那個。",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……果、",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "果然還是不行！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "就是不好吃呀……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……露娜，",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是不是沒辦法像媽媽一樣呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "啊！？",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_009"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好耀眼呀……！？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "哇啊啊！？",
        "unit_id": 111411,
        "voice": "vo_adv_1114008_010"
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……哥～！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_011"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥～！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_012"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "真是的，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_013"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我說大哥哥！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n你要睡到什麼時候啊―！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不快點的話會涼掉的！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你問什麼，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_014"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "真是的！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n大哥哥很愛睡過頭呢！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "早餐唷！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_015"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是露娜做的唷！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "快一點！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_016"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n快過來這裡！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "知道了講一次就好！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_017"
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "快點，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_018"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "快看！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "　好吃吧！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我是說看起來很好吃吧！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_019"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "呵呵，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那我開動了―！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……嚼嚼。",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_020"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n如何？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "　大哥哥。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "有好吃嗎？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那個，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_021"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "魚的部分呢，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我是努力烤的唷。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "米飯也是很用心煮的！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_022"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為菜刀還很危險……",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n所以能做的料理沒有很多……",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_023"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "這次可能做得不錯！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "真的嗎！？",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "太好了。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……其實，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_025"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我有失敗很多次呢。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n魚也是，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也有燒焦的呢……",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_026"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為大哥哥會稱讚好吃，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我一想到會被稱讚，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n就努力了下來。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嘿嘿……",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_027"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嗯！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_028"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_029"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "只會做飯是不行的。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥還會睡過頭，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不好好把你叫起床的話不行。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還有，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_030"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥常常忘東忘西，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜必須要更可靠才行。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "要成為太太的話，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "要等露娜更大才行！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嗯！",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_031"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "如果變成更乖的好孩子，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_032"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是不是就能更快長大呢？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "這樣，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜就可以一直照顧你呢。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "現在還沒有辦法，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_033"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜雖然還很小……",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但等我長大，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜要跟大哥哥",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一直永遠在一起。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……等我長大唷，",
        "unit_id": 111431,
        "voice": "vo_adv_1114008_034"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥。",
        "unit_id": 111431
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1114008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是個好夢吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她很值得讚許呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說起露娜。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "女孩子做飯，",
        "unit_id": 190011,
        "voice": "vo_adv_1114008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這可是一件大事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "更何況是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "作給喜歡的人吃。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那一點，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可要明白啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_1114008_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你是吃什麼都好吃的類型，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該是沒問題啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是要真心誠意說出好吃唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……總之，",
        "unit_id": 190011,
        "voice": "vo_adv_1114008_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差不多該醒來了。",
        "unit_id": 190011
    },
