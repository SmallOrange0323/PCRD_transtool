[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100211,
        "voice": "vo_adv_5096402_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "結、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "結束了嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那隻魔物，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這次真的回去了，對吧……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……好像是呢。",
        "unit_id": 100311,
        "voice": "vo_adv_5096402_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該是理解到我們的強大才撤退的吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……又或者是，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說不定牠也想參加比賽。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難不成，",
        "unit_id": 100111,
        "voice": "vo_adv_5096402_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "牠一直在看著我們的比賽……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才會那麼的想戰鬥……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果是那樣的話，早點跟我們說就好了啊──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈……",
        "unit_id": 100211,
        "voice": "vo_adv_5096402_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過被妳們這麼一說，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我覺得牠們回到海裡的身影，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n看起來好像有點滿足呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是讓人困擾。",
        "unit_id": 100311,
        "voice": "vo_adv_5096402_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果硬要說的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感到困擾的應該是牠們吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過這麼一來，",
        "unit_id": 100111,
        "voice": "vo_adv_5096402_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沙灘總算恢復和平了呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n既然如此，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我將宣布在這場戰鬥中",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "堅持努力的比賽冠軍！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n冠軍就是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和……",
        "unit_id": 100311,
        "voice": "vo_adv_5096402_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那種比賽",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是什麼時候開始的？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為",
        "unit_id": 100111,
        "voice": "vo_adv_5096402_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在剛才的戰鬥中，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我覺得最努力的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是騎士先生呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生直到最後，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都一直在後方支援著我們對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而且在這個島上，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也一直在幫助我們……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和，",
        "unit_id": 100311,
        "voice": "vo_adv_5096402_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來妳早在戰鬥前就決定好要那麼說了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……這樣啊。",
        "unit_id": 100211,
        "voice": "vo_adv_5096402_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來日和",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是想跟騎士先生道謝呀。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸、",
        "unit_id": 100111,
        "voice": "vo_adv_5096402_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿嘿嘿……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不可以、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我怎麼可能會有意見。",
        "unit_id": 100311,
        "voice": "vo_adv_5096402_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為我也有一樣的想法啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣也是這樣想的吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當然呀。",
        "unit_id": 100211,
        "voice": "vo_adv_5096402_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們三個人就一起為騎士先生頒獎吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "恭喜你奪下冠軍！",
        "unit_id": 1,
        "voice": "vo_adv_5096402_013"
    }
]