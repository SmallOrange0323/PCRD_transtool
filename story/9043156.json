[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就剩最後一擊！",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然是這樣沒錯……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變成剛才的汪汪擋在我們前面了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠們果然是一家人……",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大人為了保護小孩拼命戰鬥，",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "換成小孩為了保護大人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而打算戰鬥……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不覺得",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種情況，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞得我們變成壞人了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這時候……",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就只能這樣了呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳拿烹飪器具出來幹嘛……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳該不會……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是想要吃掉牠們吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再怎麼說也是在下等人闖進牠們的地盤在先……",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討厭啦，",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、小可蘿！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看到這種景象還怎麼吃得下去嘛～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以！",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想要煮頓飯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "分給同樣餓著肚子的狼群吃，順帶表達歉意！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吵架之後",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是要一起吃飯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後再言歸於好，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是我們",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】唷☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太、",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還以為",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳要把牠們一家都吃了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐很溫柔呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才、",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是覺得這樣會讓我晚上睡不好覺而已！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐的心意",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像也傳達給了汪汪牠們。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠們平靜下來了呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是太好了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了好了～",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就準備開始做飯了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n兩位也請來幫忙吧～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "機會難得，",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就做得豐盛一點吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下來一展身手吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n汪汪你們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請稍等一下唷。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "慢慢燉煮至完全入味～",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肉也要烤到滋滋作響～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "弄得太燙可不好喔。",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會被燙傷的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題的～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會讓貓舌頭小凱留也能吃得下去的呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不是什麼貓舌頭！",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓大家久等囉，",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經煮好了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來料理得挺好吃的嘛。",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了不讓",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪們燙傷，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以請您吹一吹再拿給牠們吃嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留果然會怕狗狗嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能會害怕啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "況且牠們也不是狗吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果不行的話",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下來吹涼吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要餵牠就好了吧，餵就餵嘛！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這點小事我也做得到啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點吃吧……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊啊啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們要做什麼！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到……",
        "unit_id": 105911,
        "voice": "vo_adv_9043156_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪們竟然",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在舔凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我能夠理解～！",
        "unit_id": 105811,
        "voice": "vo_adv_9043156_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留呢，看起來很美味，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "確實會讓人很想舔一舔嘛！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是在說什麼傻話……",
        "unit_id": 106011,
        "voice": "vo_adv_9043156_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住手……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好癢……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說妳們別光站著看，快來救我啊～！！",
        "unit_id": 106011
    }
]