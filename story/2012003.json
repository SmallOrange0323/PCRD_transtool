[
    {
        "type": "background",
        "background": "500584"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝～！",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "蘭德索爾的大家，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的非常感謝你們",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "願意來看我們！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這感覺太棒了！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就是這個瞬間讓人無法自拔呢，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能當偶像真是太好了～！",
        "unit_id": 102912
    },
    {
        "type": "background",
        "background": "500584"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當然，就是盡力而為而已！",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n拜託大家讓所有人能夠冷靜的行動，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以便進行避難疏導！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "上一次因為試圖想要打倒魔物所以做了傻事，",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也導致有人因此受了傷……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得記取那教訓，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次一定得更努力地不讓任何人因此受傷唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位～！　",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請靜下心來！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好好聽我們說的話，",
        "unit_id": 105412,
        "voice": "vo_adv_2012003_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後冷靜地行動！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "萬一",
        "unit_id": 104212,
        "voice": "vo_adv_2012003_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真有出現傷者的話，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請到我這邊來！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我會使用唱喚術治療的，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但還請",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "別慌別著急！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幹得好！",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是不錯的處置呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "迅速且確實！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不用如此地急迫也無妨唷，",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們幾個……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來那些黑色的『闇影』們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n完全沒有打算鬧事的樣子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就只是緩緩地",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "朝著『王宮』的方向前去而已呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔呣……",
        "unit_id": 104212,
        "voice": "vo_adv_2012003_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的確，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果從站在舞台上的角度來看的話，相當顯而易見呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n正如同製作人所講的，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n『闇影』們",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "正一同朝著『王宮』前進呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 105412,
        "voice": "vo_adv_2012003_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼是往『王宮』呢？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該不會那裡有什麼東西在牽引『闇影』嗎？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又或是說，在『王宮』的某人，",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n正在呼喚且招集著『闇影』……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是糟糕的時間點呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在於『王宮』那，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【拉比林斯】的那群人應該還正在實行作戰才是……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "發生了什麼我們預料之外的事呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼說來『陛下』",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……尤絲蒂亞娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他以前曾說過呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『闇影』是便利的備用食品，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是為以防萬一所準備的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那句話，究竟是什麼意思呢？",
        "unit_id": 107111,
        "voice": "vo_adv_2012003_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管毫無頭緒，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻很忐忑不安！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "――吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚欸，",
        "unit_id": 105412,
        "voice": "vo_adv_2012003_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是怎麼回事呀？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n『闇影』一個接著一個撞在一起，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n然後一點一滴溶解掉了唷！？　",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好噁心……！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是呢。",
        "unit_id": 104212,
        "voice": "vo_adv_2012003_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "溶解掉的『闇影』，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n則像是黑色的爛泥灘一樣流走了……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎是往『王宮』方向那邊去的樣子呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104212,
        "voice": "vo_adv_2012003_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我剛才仔細聽了一下，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n似乎城裡的各地，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也正發生著相同的異常事件的樣子。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n四面八方，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎都有「是『闇影』呀～」",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的聲音傳來。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且精靈們似乎也相當的懼怕……",
        "unit_id": 104212,
        "voice": "vo_adv_2012003_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "究竟是怎麼一回事呢，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是恐怖呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也不曉得！",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但再怎麼說我們也唱完最後一首歌，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "做為偶像的工作告一段落了。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n從現在開始",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "則是以一般人的身分，盡力而為！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要這麼做，",
        "unit_id": 102912,
        "voice": "vo_adv_2012003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管是有什麼事都一定有辦法解決的……！",
        "unit_id": 102912
    }
]