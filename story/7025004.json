[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜持續登塔，仍對先前與香織過招一事無法釋懷。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的焦躁開始轉向針對魔物。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊！",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_000"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管打敗幾隻魔物還是完全搞不懂……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我跟香織到底是哪裡差那麼多啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是說……",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "單純只是我比香織弱太多了？　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……我說，嘉夜。",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可以聽我說一下嗎──",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔！",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳有注意到嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我知道。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那些魔物",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "非常厲害～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些傢伙",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "出於本能盯上容易對付的人嗎！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好的喔～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一人解決一隻吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔喔，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是什麼力量啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且這傢伙",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一看就很強壯。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……靠我的拳頭",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打得贏牠嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇哇哇～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這魔物動作好快呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不只是這點。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n牠的動作沒有規則，就像野獸一樣，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這下很難預判呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔啊",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好痛～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "敵人相當棘手耶～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣下去不妙……",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們暫時撤退，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "重整態勢吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "了解～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼、",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些傢伙真難纏。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n繼續跑下去會被牠們追上的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，香織，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳帶著他逃。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我來殿後。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我不同意～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我們",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會戰勝那些魔物～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別說傻話！",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我跟妳都不是對手啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算香織打得贏，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我剛才就想告訴嘉夜了，",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳很強的喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "假如認真較量的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "勝負還很難說呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼啊，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種時候不用說客套話啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不是客套話喔～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n過招時的事，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有我能打敗讓嘉夜陷入苦戰的魔物，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n單純只是契合度的問題呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳說",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "契合度……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對呀～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我擁有嘉夜沒有的技能～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才能躲開嘉夜的攻擊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有一招打敗魔物～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也僅只如此罷了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那不代表我比嘉夜強喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以嘉夜",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要相信自己的實力去戰鬥，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就絕對不會輸的～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……或許是吧。",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可是，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並不像香織一樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n有想守護的地方或家人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個差距很大吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳說的話好奇怪呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳想守護的人",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一～直都在身邊呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……啊。",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我到底是來這裡幹嘛的啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我一心只顧著打架，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "完全忽略周遭了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我確實",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不像香織那樣會武術。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我在無數生死關頭鍛鍊出來的拳頭",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "絕對不算軟弱。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是不相信自己的拳頭，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原本能贏的都會被搞輸了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啦，香織。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳替我守住了我的心靈和拳頭。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然這麼做算不上道謝，",
        "unit_id": 106511,
        "voice": "vo_adv_7025004_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但香織所認同的這份實力，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會好好證明給你們看！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，",
        "unit_id": 101711,
        "voice": "vo_adv_7025004_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就該拿出這種氣勢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "非常欣賞嘉夜直率又熾熱的拳頭～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
