[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}結束了一天的工作，在街上散步。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n路過那裡的日和，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "向他搭話。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是騎士先生──！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能在這裡碰到你，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺好開心呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在有空嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我又想挑戰一下新事物，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不曉得你要不要一起來……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然是要騎士先生有空的話喔？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最好是閒到不能再閒，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再不做點什麼就快無聊到死掉了──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的程度再陪我就好！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……最近，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像是用不會沉下去的速度在水上走……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或是在垂直的牆壁上行走",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之類的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我已經讓你陪著我挑戰很多事了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果你還不覺得困擾的話……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎！？",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n感覺今天的挑戰也會很愉快呢♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總之我們先到郊外去吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今天要挑戰什麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去那邊再決定！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──我們到了～！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "馬上就來進行新的挑戰吧──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話雖如此，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該做什麼才好呢……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我和騎士先生一起想出來的挑戰幾乎都嘗試過了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我總覺得最近，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n挑戰的方向好像有點不太對勁……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "漸漸變得像在玩樂一樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我玩得越來越開心了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所謂的找回初衷是嗎！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說得也是！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一起思考吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "回歸初衷……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原本的目標，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是要讓我的公主型態變得更強。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n為了這點，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我猜想只要能做到至今為止辦不到的事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n說不定就能變強，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以嘗試了各式各樣的挑戰。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……不過，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我現在，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n還是沒有變強的感覺。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然是很想相信這個想法不會有錯……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗯…………",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗯………………！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯喵──！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我自己也搞不清楚了啦──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒事沒事……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這應該……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只是那個、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "叫做用腦過度的現象！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大概！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該怎麼辦才好呢……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n公主型態，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是和騎士先生齊心協力變身的能力，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n該怎麼樣才能兩個人一起變強……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是這個，騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "公主型態是兩個人的力量……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要和騎士先生更加心靈相通，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n更有默契才行！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以說騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們今天就一邊特訓，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一邊盡情地玩吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要讓兩個人心靈相通，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n培養默契，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起玩就是最好的方法了嘛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "需要默契的遊戲，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有什麼呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或是玩不能太有默契的遊戲，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後故意互相配合，說不定也很有趣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……對了！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來玩猜拳怎麼樣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我說的可不是普通的猜拳喔？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要用對我們來說",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能成為特訓的方法玩！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們接下來要玩的猜拳，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是要連續不斷地平手！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要能辦到這一點，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就表示能感受到對方的想法，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n和對方心意相通，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該就也能提升默契了吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哼哼哼……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不可以著急喔，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果是我們，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "肯定能以更高的境界為目標！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以除此之外，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們還只能連續出一次一樣的拳！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果也能克服這點就完美了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼要開始囉──！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剪刀石頭……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剪刀！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我贏了──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n哼哼哼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你還不夠看呢騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦不對！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
