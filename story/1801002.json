        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "猜猜看！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而我就來猜騎士先生想吃的甜點！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_049"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "準備好就一起說喔──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n預備……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果凍！！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……騎士先生也選果凍！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也是──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n欸嘿嘿，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正好想吃點清爽的東西呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "居然又猜對了……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_051"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這下我們，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n可以說是完完全全心有靈犀了吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_052"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要點餐才行。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不好意思──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請給我兩份果凍──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好的──！",
        "unit_id": 1211,
        "voice": "vo_adv_1801002_053"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "──讓您久等了～！",
        "unit_id": 1211,
        "voice": "vo_adv_1801002_054"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n為您送上兩份果凍──！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇～",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_055"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看起來好好吃喔──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我開動了──♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……嗯──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好吃──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "口味和軟嫩嫩的口感都好好吃──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "軟軟嫩嫩的♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哦哦，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_056"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生的果凍也軟嫩嫩的呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這間店的果凍這種軟嫩嫩的感覺……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你的果凍，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_057"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看起來有點不一樣呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟是手工製作的，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也不可能全都一樣吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是說……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_058"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明點了同一份甜點，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "端上來的卻是不同的果凍！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呵呵，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我開玩笑的啦……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……？",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為什麼要把",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n舀了果凍的湯匙靠近我嘴邊呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我……？",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_060"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生吃過的果凍，",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_061"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓我也……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這該不會……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "間、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "間接接吻、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯吧……！？　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以吃嗎！？",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_062"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n可以嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎怎怎、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦……！！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_063"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……果、",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_064"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然還是不必了！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不用吃也沒關係！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒關係啦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我剛剛是開玩笑的！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_065"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "點了同一份果凍，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n怎麼可能端了不一樣的來呢，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈哈……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我……",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n剛剛那樣順勢下去就會和騎士先生……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……快忘了剛才的事吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊──好好吃啊──！",
        "unit_id": 100111,
        "voice": "vo_adv_1801002_068"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就算只是為了吃果凍，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這間店也值得再來幾次呢──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n哈哈、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和一邊吃果凍一邊用明快的語氣說著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但總看起來有些坐立不安的樣子。"
    }
]