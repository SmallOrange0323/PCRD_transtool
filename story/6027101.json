[
    {
        "type": "background",
        "background": "500833"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611,
        "voice": "vo_adv_6027101_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜很讓人傷腦筋呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼血氣方剛的個性，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n真虧她能平安無事的活到今天啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我和嘉夜夜",
        "unit_id": 106611,
        "voice": "vo_adv_6027101_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是差不多時間加入公會的。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們認識的時間可是比這條尾巴還長呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她跟我一樣是龍人族，是很重要的同胞。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "綜、",
        "unit_id": 106611,
        "voice": "vo_adv_6027101_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "綜合各方面的能力來說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們應該算是勢均力敵吧……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "除了互毆以外喔！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰打得贏她那種人啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總有一天",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也能變成那樣……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才對……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼～",
        "unit_id": 106611,
        "voice": "vo_adv_6027101_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那是因為嘉夜夜是個笨蛋打架狂！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n如果我不在的話不知道她會搞出什麼事情來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以我才一直待在她身邊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然很可靠，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但我希望她可以稍微有點分寸。",
        "unit_id": 106611
    }
]