[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟敢讓小織女那樣的美少女哭泣，",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我絕──對不放過他！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n身為最可愛最強的正義魔法少女七七香，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "絕對會解決這個問題呦☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那還用說嗎！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然我們的目的是為了得到「祈願竹」，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但幫助有困難的人",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也是魔法少女的生存之道、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的說──！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯～",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這就是明明有主推的本命，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還去推別的角色。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n或許這是別人的家務事啦，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是做出傷害別人的事",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就是不好呢。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "身為相信愛的魔法少女，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我無法置之不理！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔，",
        "unit_id": 113311,
        "voice": "vo_adv_6044205_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "關於那點，七七香也沒辦法好好解釋，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一旦喜歡上了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就沒這麼容易會討厭對方。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不小心變得有點正經了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香好害羞喔！",
        "unit_id": 113311
    }
]