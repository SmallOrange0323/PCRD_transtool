[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011,
        "voice": "vo_adv_5058204_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是走到太深處了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n氣氛好像都變得不一樣了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對耶……",
        "unit_id": 105811,
        "voice": "vo_adv_5058204_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有種被緊緊盯著的感覺。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定是我們",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被當成餐點了呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不好笑呢！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058204_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來獵食材的卻被當成食材是在搞什麼啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是",
        "unit_id": 105911,
        "voice": "vo_adv_5058204_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "適得其反吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105911,
        "voice": "vo_adv_5058204_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不必擔心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n迄今為止",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們無論遭遇到何等困難，都成功跨越了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正是如此！",
        "unit_id": 105811,
        "voice": "vo_adv_5058204_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【美食殿堂】只要同心協力，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼事都能做到♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又在說毫無根據的事情了。",
        "unit_id": 106011,
        "voice": "vo_adv_5058204_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有自信雖然很好，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但因此疏忽大意就沒有意義了啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且妳本來就很粗心了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過會幫妳補足這些缺點的，",
        "unit_id": 106011,
        "voice": "vo_adv_5058204_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是所謂的夥伴啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_5058204_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳剛剛說了什麼嗎小凱留？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是說了什麼讓我想要緊緊抱住妳的話啊小凱留？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以用力抱緊妳嗎小凱留！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！",
        "unit_id": 106011,
        "voice": "vo_adv_5058204_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了吵死了，不要靠過來啦～～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快走了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……擁有",
        "unit_id": 105911,
        "voice": "vo_adv_5058204_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可靠的夥伴在確實很幸福呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是呀♪",
        "unit_id": 105811,
        "voice": "vo_adv_5058204_011"
    }
]