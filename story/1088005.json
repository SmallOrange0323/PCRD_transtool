[
    {
        "type": "background",
        "background": "501490"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾即將迎接年末的某個冬日。\n優衣今晚要代替雙親準備晚餐，在買好食材後，她正走在回家的路上。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "晚餐的",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "湯",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該煮什麼呢……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這麼說來，",
        "unit_id": 1,
        "voice": "vo_adv_1088005_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這次要回哪邊的老家跨年？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我爸說",
        "unit_id": 1,
        "voice": "vo_adv_1088005_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "想和你一起喝一杯。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n說也歡迎公公婆婆他們一起來喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……跟家人",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一起啊。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果能夠",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟之前一樣",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和騎士先生一起的話……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他一定會",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很忙吧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唉……",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那回事。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我只是邊走路",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "邊想事情。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生你除夕那天，",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有什麼計畫嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是，",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以的話……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n要不要跟我",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一起過呢……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個，",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才的邀請是要看你方便！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但你應該",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "已經排好",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "計畫了吧……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以嗎……？",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想想，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那除夕的早上，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們在街道的入口",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "碰頭好嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒問題？",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那就",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "除夕見。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拜拜。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……咦咦咦！？",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我和騎士先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就這樣約好了！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n怎、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼辦～！！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "明明是自己主動邀請的，",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n卻還是有點",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不可置信……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "除夕那天，",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該怎麼辦呢……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要做什麼才好？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……好，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先從今天的晚餐開始想吧！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和騎士先生",
        "unit_id": 100213,
        "voice": "vo_adv_1088005_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩人一起跨年，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真讓人期待……",
        "unit_id": 100213
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了幾天，終於到了除夕當天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣穿上新年和服，正要從老家的小吃店\n前往會合的地點。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "隨身物品準備好了。",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和服也",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有哪裡……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怪怪的吧？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒問題。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我出門了～！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "優衣～！",
        "unit_id": 1,
        "voice": "vo_adv_1088005_017"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "等一下～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽媽？",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "爸爸也……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼那麼慌忙？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n發生什麼事了嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "其實……",
        "unit_id": 1,
        "voice": "vo_adv_1088005_019"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "我們之前說過",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "除夕夜要去",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "神殿擺攤對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你們說過",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "第一次抽中",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以擺攤的資格呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "然後啊，",
        "unit_id": 1,
        "voice": "vo_adv_1088005_021"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "我們就去公會管理協會",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "張貼了打工的委託。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n結果原本要去幫忙擺攤的工讀生，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n竟然在其他工作中受傷了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "所以說，",
        "unit_id": 1,
        "voice": "vo_adv_1088005_022"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "優衣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "妳能代替他去幫忙擺攤嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦咦！？",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我嗎！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "好不容易中籤了，",
        "unit_id": 1,
        "voice": "vo_adv_1088005_024"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "所以我們不想放棄擺攤的機會。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n但也不能因此放著家裡的店不管……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n拜託妳了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "會給妳更多壓歲錢的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "好嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……對不起，媽媽。",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我今天，那個，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有約了……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……能和騎士先生一起度過的",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "珍貴時光正在等著我。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是這種時候，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果是騎士先生……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……雖然有約了，",
        "unit_id": 108811,
        "voice": "vo_adv_1088005_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但我就去幫忙擺攤吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要做些什麼呢？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "謝謝～！",
        "unit_id": 1,
        "voice": "vo_adv_1088005_028"
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "有優衣這個女兒",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "真是讓媽媽自豪～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n菜單和重要事項",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "我都寫在這張紙上了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "\n那就拜託妳了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣的母親",
        "words": "得快點跟公會管理協會聯絡才行！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道了，",
