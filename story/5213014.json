[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "…………",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_000"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n……",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "嗯……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_001"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "嗯。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "梅莉莎大人……",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_002"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "一直在沉睡著……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n真希望她能醒過來哈尼……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "騎士大人！",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_003"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "你、",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "你是來做什麼的？",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "咦……？",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_004"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "飯糰……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "哈尼？",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "…",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_005"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "…嗚嗚。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n竟然連我們這樣的人，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "你都願意送來慰勞品……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n騎士大人，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "真的很對不起哈尼……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "還有……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "謝謝你們讓梅莉莎大人活了下來。",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_006"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n真的",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "很感謝你們哈尼。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "那個啊……",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_007"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "雖然你可能不會相信。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n真正的梅莉莎",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "其實沒有這麼誇張哈尼。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "啊……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "不過她本來也是有點誇張啦哈尼……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "但是，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_008"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "她其實也有溫柔的一面，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n是個很重視朋友的女孩……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "她曾經是我",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "最喜歡的朋友。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "她總是說，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_009"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "必須成為出色的女王蜂。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n一直都很努力。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "就在那個時候……",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_010"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "從天空傳來聲音。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "大概……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n是從非常遙遠的地方傳來的。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "我們，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_011"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "聽見了那個聲音。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "然後呢，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_012"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "從聽到那個聲音的隔天開始，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "我和梅莉莎大人，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n好像莫名其妙得到了亂七八糟的力量……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "梅莉莎大人想著，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_013"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "甚至能夠取得超越吉歐‧格黑納，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n不同世界的一切力量哈尼。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n她想建立一個更加龐大的蜂群……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "總之……",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_014"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "獲得那股力量之後的梅莉莎大人，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n認為自己必須變得冷酷無情才能統治國家。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "但是呢，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "她卻始終無法真正變得無情。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "所以梅莉莎大人，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_015"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n自己喝下了「蜜糖陷阱」哈尼。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "嗯，",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_016"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "一直都是哈尼。",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n只是用毒來欺騙自己，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "假裝成一個可怕的自己……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "其實她本質上是非常溫柔的，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "是我唯一的朋──",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "朋──",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_017"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "什麼？",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "哇呀啊！！",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_018"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n對不起梅莉莎大人，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "我要接受懲罰哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "請踩我！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "拜託踩我～！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "唉……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_019"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "別相信這傢伙說的話。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "話說你這人，",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "到底是來做什麼的？",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "是來看我狼狽的樣子，特地跑來嘲笑我的嗎？",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_020"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "呀哈哈，",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "品味真差～",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_021"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n沒什麼，",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我沒事。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕嚕嚕嚕……！"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "……唔！？",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_022"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "剛、",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_023"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "剛剛那個",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "才不是我呢。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n對吧，",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "哈尼哈尼。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "是、",
        "unit_id": 20111,
        "voice": "vo_adv_5213014_024"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "是啊哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "剛剛那是我肚子叫了哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "……咦。",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_025"
    },
    {
        "type": "still",
        "still": "521301401"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "這……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_026"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "這是什麼啊。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n看起來真寒酸。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_027"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我才不需要呢──",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我早上是吐司派的。",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_028"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n米飯這種東西，跟蜂蜜也不搭啦──",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "而且……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_029"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "要是被下了毒，",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n那可不是開玩笑的──",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "你、",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_030"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "你很囉嗦耶。",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕嚕嚕嚕……"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "唔……",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_031"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "啊～",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "好啦我知道了啦！",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n我吃就是了！",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "雖然是超級不情願！！",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "…………",
        "unit_id": 20011,
        "voice": "vo_adv_5213014_032"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我要、",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "開動了……",
        "unit_id": 20011
    },
    {
        "type": "dialogue",
