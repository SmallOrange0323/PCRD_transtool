    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有感覺到過吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個世界",
