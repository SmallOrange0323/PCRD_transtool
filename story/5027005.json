    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜她們所在的公會──【龍族巢穴】和茉莉一行人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了尋找智以及龍，在茂密的樹林中前進著。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這個方向對嗎？",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒問題，",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "方向正確～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n以我剛剛",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "『看到』的內容的話☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大這種時候特別可靠，讓人很放心。",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳那邊有沒有發現什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個，",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是那個石板吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "會掉在這裡就表示……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "樹在搖晃！？",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在那裡！",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_005"
    },
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐！！",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦！？",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　為什麼茉莉妳會在這裡？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳這樣問就不對了。",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且說起來，那是我們要問妳的才對。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一個人跑出去還被逼到絕境，",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是不像話！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳說得沒錯。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n光靠我一個人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒辦法像你們這樣",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把事情處理好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣一來任務也失敗了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒有臉見茉莉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你這個人……",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "敗給你了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚哇～！！",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n竟然丟下我跑掉，太過分了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來妳也很受愛戴嘛。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n與其說什麼沒臉見她，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不如別做這種讓夥伴擔心的事情啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且，所謂的夥伴",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒什麼幫不幫得上的分別吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對嘉夜夜來說也是嗎……？",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那當然？",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……欸嘿嘿，",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哈哈……",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真傷腦筋。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n竟然被監視的對象說教。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳說得沒錯。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我讓各位擔心了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是個需要讓妳這麼拼命的任務嗎～？",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "【王宮騎士團（NIGHTMARE）】的小姐☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到妳連這個都知道了啊……",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我投降了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "完全逃不出妳的手掌心呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "撇下我們偷跑的人",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還真敢講耶。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為焦急和競爭意識",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而失去冷靜，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我果然",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還不夠成熟呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我要再次",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正式跟妳道謝，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝妳來救我，我真的很高興。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐！！",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喔？",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一開始就這麼坦率的話就可愛多了嘛",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之後要好好感謝我祈梨大人，然後成為我的手下……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "各位～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不好意思在大家聊得開心的時候打擾～……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "昨晚",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "『那個』",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是牠沒錯吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "龍？",
        "words": "……",
        "unit_id": 12311,
        "voice": "vo_adv_5027005_026"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "所有人的視線都集中到帆稀的手所指向的地方。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那隻巨大生物，就像是在打量般地盯著眾人看。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說，",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們在找的龍……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是這傢伙沒錯嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨妳之前直接遇到過牠吧，",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳怎麼看？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_5027005_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有這麼醜嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "龍？",
        "words": "咕喔！？",
        "unit_id": 12311,
        "voice": "vo_adv_5027005_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "拉格，",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你能和牠對話嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔！",
        "unit_id": 1,
        "voice": "vo_adv_5027005_032"
    },
    {
        "type": "dialogue",
        "name": "龍？",
        "words": "咕喔喔喔……",
        "unit_id": 12311,
        "voice": "vo_adv_5027005_033"
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎嘎嘎。",
        "unit_id": 1,
        "voice": "vo_adv_5027005_034"
    },
    {
        "type": "dialogue",
        "name": "龍？",
        "words": "咕喔……",
        "unit_id": 12311,
        "voice": "vo_adv_5027005_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……總覺得，",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像語言不通的樣子。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難不成，",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這傢伙",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是龍嗎！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "龍？",
        "words": "咕喔！",
        "unit_id": 12311,
        "voice": "vo_adv_5027005_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我原本是這麼認為的……",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不再仔細一點確認的話，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒辦法確定是不是我們在找的目標呢☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "難不成，",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳們的公會",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【龍族巢穴】",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是在尋找",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "龍以及與龍有關的遺跡……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算是啦。",
        "unit_id": 106511,
        "voice": "vo_adv_5027005_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖說是龍人族，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但就連我們自己",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也搞不清楚龍人族的起源是什麼。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以才要進行調查。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你沒跟她們講嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦！？",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　你早就知道",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這次來的目的了嗎！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼嘛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "早知道一開始問你就好了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還以為",
        "unit_id": 100511,
        "voice": "vo_adv_5027005_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你是要加入幫派去做壞事哩……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒想到妳們是這樣看待我們的，真讓人遺憾啊～……",
        "unit_id": 106711,
        "voice": "vo_adv_5027005_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看起來真的那麼像壞人嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不想被罵所以不想回答……",
