        "voice": "vo_adv_5027005_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳們打算利用龍",
        "unit_id": 103711,
        "voice": "vo_adv_5027005_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來做什麼？",
