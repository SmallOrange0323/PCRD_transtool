    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "錯誤的世界",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "指的是在皇家統治下的國家嗎？",
        "unit_id": 103711
