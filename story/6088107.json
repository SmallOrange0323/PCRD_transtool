    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這套服裝",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼樣啊？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不過呢，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我這個人怎麼穿都好看就是了！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幹、",
        "unit_id": 121411,
        "voice": "vo_adv_6088107_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幹嘛？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別不吭聲，你倒是說句話啊。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很適合嗎？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是喔。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為太適合，所以你看得出神了吧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那我原諒你。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對吧？",
        "unit_id": 121411,
        "voice": "vo_adv_6088107_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟物產展的歡快氛圍很搭吧！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "根據場合製作適切的服裝……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不愧是秋乃小姐。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果真是一流的商人。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你用「漂亮」",
        "unit_id": 121411,
        "voice": "vo_adv_6088107_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這個詞不太對吧？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不細細斟酌適當的詞彙來讚美服裝，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是無法討淑女歡心的喔。",
        "unit_id": 121411
    }
]