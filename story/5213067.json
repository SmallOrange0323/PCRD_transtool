    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哈呼……",
        "unit_id": 101011,
        "voice": "vo_adv_5213067_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總覺得像在做夢一樣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還看見幻覺了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那溫柔的甜味，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓身體都變得",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "輕飄飄的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "直到現在，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "心還是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怦怦跳個不停……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明只是一瞬間的事，",
        "unit_id": 101011,
        "voice": "vo_adv_5213067_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n卻好像讓身心都",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "去了一趟",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "童話世界旅行一樣哪。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不愧是萊拉耶爾小姐，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的是既夢幻、",
