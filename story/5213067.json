        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家覺得妳一定也會",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喜歡上真步真步王國的♪",
