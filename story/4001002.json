[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從{player}一行人開始使用公會之家後，\n又經過了一段時間。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然，很令人在意呢。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我我我、我可沒有在想什麼詭計之類的喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我跟你們是同一個公會的夥伴呢，對吧可蘿仔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐不好意思，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已經說過很多次了，請不要稱呼在下為可蘿仔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最近連主人也開始仿效，",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n稱呼在下為可蘿仔了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請好好地用充滿感情的口吻，",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稱呼在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們是不是離題了呀？",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳注意到什麼地方了嗎～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等精靈族，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是聽力優越的種族。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是覺得樓上，",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像有些可疑的聲音。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有點像是怪物的呻吟……",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是在下的錯覺呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在意的話，要不要去看看？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，小凱留不可以啦！",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "樓上是禁止使用的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【公會管理協會】的花凜小姐不是才交代過嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙似乎也在微妙地隱瞞些什麼事情，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得怪怪的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明其他的事情都很親切地應對，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不知怎的就硬是不想讓我們到樓上去。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我感覺這肯定有什麼，就在樓上。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去調查一下吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是什麼問題都沒有的話，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n二樓也可以作為我們的聚會地點。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一樓已經變得非常侷促，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是上面的樓層能用的話不是很方便嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然妳說的也沒錯啦～",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過得先取得花凜小姐的許可才行啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是我們違反規定的話，",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有可能會被趕出這個公會之家耶？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是稍微看一眼而已啦。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之後只要道個歉就會原諒我們了不是嗎，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且花凜看起來像個大好人。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就因為她是個好人，",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才不能造成人家的困擾呀～……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係啦，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "責任就由我來承擔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜那傢伙，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛好出去買東西不在家呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趁現在把所有疑點都追根究底弄個明白吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "事實上確實，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我感受到樓上傳來了不安定的魔力……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "叫人坐立難安，感到憂心呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在我的地盤裡，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有自己未能掌握的部分存在，真叫人無法忍受啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……？",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "通往二樓的樓梯，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被相當強大的力量封鎖住了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但只要我出手的話，這種程度的封印，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n輕而易舉就可以突破了喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就說不行了嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不要緊的吧。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟在主人周圍，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像也環繞著異常恐怖的陰謀呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來這或許，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是主人所背負的命運。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因此。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不安的種子，應該要盡快去除才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為，",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為一些理由被綁手綁腳，進而失去了重要的事物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之後再來後悔的話就太遲了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，在下來幫助您解除封印。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n即便是在下，也是有兩把刷子的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎唷～連小可蘿都這麼說……",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣如果只有我在這邊假正經、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不一起同流合汙的話就太沒人情味了對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家都是同一個公會的夥伴，是牽一髮而動全身的～",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該、該怎麼辦呢……{player}？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的確也很在意樓上有什麼東西，",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們也一起協助小凱留……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呀！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位？",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_035"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是在做什麼呢？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦咦，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "花凜！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳回來了呀！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不不不、",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是那樣喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為上面的樓層傳來了奇怪的聲音，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓人在意……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_038"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "會有疑問是理所當然的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不過各位擅自行動的話會讓我很困擾。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "至少請與我商量一下，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_039"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我又不會生氣………",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因為我能理解各位的心情。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然我也被上司嚴格警告，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_040"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n而不能詳細說明……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為上面的樓層，有點危險。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "話說回來。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_041"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這棟建築，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n本來就是不屬於任何人的空屋。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以，有幸被國家接收……",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_042"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n並且賜給了我們【公會管理協會】。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "另外就是。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_043"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "前往上層階梯的封印，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是在我們管理這棟建築物的一開始就存在了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是為了封印什麼，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_044"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n樓上到底藏著什麼………",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n老實說，我們也不清楚。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但只要不觸摸到封印，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_045"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是不會有什麼問題的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因為是這樣有點可疑的房子，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以才會租給像各位這樣來歷不明的公會。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔～我就想說這麼豪華的建築物怎麼會借給我們……",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然～這就是所謂的有問題的房子吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "天下真的沒有白吃的午餐呢～我就知道～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "很抱歉一直瞞著各位，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我在一開始說明清楚的話就好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只是因為，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_049"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n還不知道各位是不是能信任的對象。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是打算，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n找時機擇日再說明的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也沒辦法嘛～",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟花凜小姐是公務員！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳也無法違抗上司跟國家的命令吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳現在能夠好好地跟我們說明，",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們就感激不盡了喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "很感謝各位能理解～。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_053"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以說呢……非常抱歉，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請千萬別觸碰封印。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "被封印的有可能，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是兇狠的魔物之類的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊不好意思，已經太晚了。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為封印，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "早就被我輕鬆解除了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～偏偏這時候手腳那麼快……！？",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳要小心喔！",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n搞不好會有危險的魔物衝出來！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～？",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_058"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可是乍看之下根本沒有什麼魔物存在啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n二樓完全沒有任何顯眼的東西耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就是空無一物的感覺。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦，不該是這樣的……？",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_060"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "很抱歉，請讓我也看一下！",
        "unit_id": 190811
    },
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是真的呢……",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_061"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n雖然隨著時間變的老舊又有點髒亂，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但看起來只是個普通的房間。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然也沒有封印著，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_062"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n什麼凶狠魔物的樣子。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話～為什麼這裡會被封印住呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位請看，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牆壁上畫著魔法陣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是空間轉移的魔法陣呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n它能一瞬間就把對象轉移到遠方去……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是被用在軍事用途上的話會十分危險，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以這是被國際條約列為禁止使用的魔法喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行呢，這好像是用過一次就會失效的魔法陣。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n發動過一次之後，魔法迴路就會溶解。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "即使注入魔力還是無法啟動呀，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也不知道這到底是跟哪裡聯繫著……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這已經單純是一幅牆上的塗鴉了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以可以推測，被封印在這裡的魔物還是什麼的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n利用了空間轉移魔法之類的逃出去了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡有生活過的跡象。",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n確實是有「什麼」曾經在這裡生活過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可能在很久以前就已經離開了吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，真讓人泄氣呢。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【公會管理協會】也不覺得丟人現眼嗎，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一直為了空盪盪的箱子而戰戰兢兢的過度警戒呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_072"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只要沒有危險的魔物的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n什麼都沒關係囉。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "看起來只要四處整修一下，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_073"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n似乎就可以當作普通的房間使用……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我去請業者來施工，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_074"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n讓他們整修成像一樓般可以便利地使用。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "由於造成各位的不安，",
        "unit_id": 190811,
        "voice": "vo_adv_4001002_075"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n作為補償就由【公會管理協會】來支付工程費用。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，真是慷慨呢。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_076"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯，憂慮也一掃而空，二樓也開放了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果是皆大歡喜呢，可喜可賀～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～我突然想到一個問題……",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然二樓是沒有任何東西的空房間，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那為什麼剛剛樓上會傳來奇怪的聲音呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是三樓吧～",
        "unit_id": 105812,
        "voice": "vo_adv_4001002_078"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n通往三樓的樓梯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也被下了封印呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且有聲響的話，",
        "unit_id": 105913,
        "voice": "vo_adv_4001002_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n表示三樓恐怕不是空房間吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說，跟被封印在二樓的一樣，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在三樓很有可能也有著「什麼」……是吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。被封印在三樓的東西，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_082"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟曾經被封印在二樓的「什麼」究竟是同等級的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是更加高等級的存在……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這有點不妙呢。",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_083"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n空間轉移是禁術，而且是高等魔法喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能畫出魔法陣，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_084"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n代表可能是高等智力的強大魔物或者其他什麼的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不小心惹牠發怒的話，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_085"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n大概會造成一個小村子被毀滅之類的吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對於通往三樓樓梯的封印，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_086"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是別輕率出手比較好吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是又很叫人在意呢～……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_087"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被封印在這公會之家裡的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底是什麼呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有些來路不明的東西潛伏在上頭，",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_088"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本沒辦法安穩的生活呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_089"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "三樓，我想另外擇日好好調查一下。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n當然，到時候我會徵求花凜的同意的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這棟公會之家待起來蠻舒適的……",
        "unit_id": 106012,
        "voice": "vo_adv_4001002_090"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不想因為違反規定而被人趕出去。",
        "unit_id": 106012
    }
]