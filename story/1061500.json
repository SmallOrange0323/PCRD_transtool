[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿！　",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最近還好嗎？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我最近很好喔！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以呢？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "找我有什麼事嗎？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔，",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的生日啊！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……加那個「小」是多餘的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我叫諾維姆啦！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別再忘記了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n算了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝你的祝福！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原本我就不知道是什麼時候生日的，",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像這樣被別人親口祝福\n雖然很開心，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但有點害羞呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿嘿……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說慶祝，",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是指什麼？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "身高又沒有長高……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的生日？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "難不成，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你是要幫我慶祝嗎！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的生日啊，",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有除了我以外的傢伙重視著我的生日呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底是為什麼呢？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是你能幫我慶祝很讓人開心呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "禮物？　",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是什麼的？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我什麼都沒做啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想送什麼我都收下吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，這樣啊！　",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為今天是我的生日啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "早說嘛！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝呀！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n竟然會有那麼一天能被你祝福，真是讓人吃驚呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被你慶祝那就代表著",
        "unit_id": 106112,
        "voice": "vo_adv_1061500_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我出生在這個世界上",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也就具有意義了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那就想成是那樣",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來盛大地慶祝吧！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "盡情地！",
        "unit_id": 106112
    }
]