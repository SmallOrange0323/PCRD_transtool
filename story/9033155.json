[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了，",
        "unit_id": 105811,
        "voice": "vo_adv_9033155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經無路可逃囉你這個小偷鱉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n飯糰被偷走的怨恨，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在這裡做個了斷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "飯糰什麼的都無所謂了啦，",
        "unit_id": 106011,
        "voice": "vo_adv_9033155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在到處是蟲子的森林裡跑來跑去，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "整個人都火大起來了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快把那隻大眼怪解決掉，",
        "unit_id": 106011,
        "voice": "vo_adv_9033155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把懸賞金拿去悠閒地渡假……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跑、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跑到哪去了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎",
        "unit_id": 105911,
        "voice": "vo_adv_9033155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比之前更加謹慎了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "書裡有寫到，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來想找到變色龍便十分困難。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在就",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "姑且靜待良機吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105811,
        "voice": "vo_adv_9033155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那也沒辦法呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就休息一下邊吃飯邊等吧――",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊！　",
        "unit_id": 105811,
        "voice": "vo_adv_9033155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飯糰又被偷走了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可饒恕，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們馬上追上去吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……等等，",
        "unit_id": 106011,
        "voice": "vo_adv_9033155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳就留在這裡繼續吃！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠又要來偷了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自投羅網的變色龍！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我把那附近",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部轟炸一遍！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈啊啊啊——！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105811,
        "voice": "vo_adv_9033155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鱉先生被燻出來了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一口氣解決牠吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是、",
        "unit_id": 105911,
        "voice": "vo_adv_9033155_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的！",
        "unit_id": 105911
    }
]