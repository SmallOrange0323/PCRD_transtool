[
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呵呵，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好笑吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這就是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我和『陛下』唯一一個幸福的記憶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是一起吃飯糰，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聊著無關緊要的事情……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "除此之外",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直都被無視著，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被辱罵，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "失敗了就會被教訓。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就只有這樣……",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算只有一瞬間，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算只有一次",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻也曾度過幸福的時光了唷。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也足夠當成我對『陛下』盡心盡力的理由了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "打從出生以來就從來沒有遇過任何一件好事啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "父母沉迷在奇怪的宗教中，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還會因為一些讓人完全搞不懂的理由來兇我。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是在學校還是補習班也都交不到朋友，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也沒有嗜好，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是念書或打工就是做家事的每一天……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "漸漸的就支離破碎了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後變得什麼都討厭了起來啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就在那時候，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了有關『陛下』的事情。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n說有可能是我的親戚，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且是個偉大的人……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "存在著一個跟我很像，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但卻很有成就，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "並且備受尊敬的人……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而這件事，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也變成了我的驕傲。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓我湧現了活下去的力量，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "變成了我的希望啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對於這個人，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我下定決心和他見了面……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他絕對說不上是一個會溫柔對待我的人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但卻認同了我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "並且給予了我特別的力量。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我真的很高興……！",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n『啊啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是為了這件事才誕生的。』",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我忍不住這麼想了啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼不論多麼痛苦",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "甚至沒有任何回報，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就只能拼了命不是嗎！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是我所有的幸福啊……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我甚至想著能夠親近那個和我一樣孤獨的人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n能夠去愛著他的人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也許就只有我也說不定。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算這個世界上每個人都憎恨著他，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把他當成是一個壞人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也會站在他的那一邊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算只有我一個人，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也下定決心要去愛著他了啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我錯了嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果真的是這樣，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我究竟又該要怎麼做才好啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既悽慘",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又笨的小女生，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就只能落在谷底，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後死在哪個荒涼的路邊才對嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "告訴我啊，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底該怎麼做才對啊……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105831,
        "voice": "vo_adv_2012013_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是小凱留對吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒有被洗腦，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不是過去的回憶，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳就是那個我們所認識的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像是一直",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都在做夢的感覺……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對妳們做的那些事全都還記得。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算說是被洗腦了，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不足以當成理由。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "依我自己的意志，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去遵守了『陛下』的命令。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對。",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是因為真的想那麼做，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以才執行了命令唷。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我是真的想要殺了妳啊……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n打從一開始，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就知道自己總有一天會",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "背叛妳們的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是妳的愛情、",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "信賴，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部都視而不見的殺了妳！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我明明知道",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總有一天會變成這樣的！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但我還是",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "利用了妳們的好意，繼續待在妳們的身邊啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對妳們做出了殘忍的事情啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直都是妳們的敵人唷！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明妳們",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就把我當成了同伴，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還說著什麼最喜歡我了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是個像這樣，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無可救藥的傢伙！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本沒有被妳們拯救的價值啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是這麼一個讓人反胃的壞蛋，",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們就該嘲笑我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我吐口水，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後殺了我踐踏我的屍體就好了啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我本來就該被這樣對待的！　",
        "unit_id": 106031,
        "voice": "vo_adv_2012013_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在更早之前！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在我傷害妳們之前……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別如此責備自己。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是誰皆會犯錯。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟我們",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都並非是全知全能的神明大人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就只是一般人。",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會迷惘、",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "困惑，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會失敗，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是如此不完全的生命。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因此才會",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此地令人憐愛，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少在下是這麼認為的。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不。",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是經常遇上問題，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有過數也數不清的失敗，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一日又一日",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慌慌張張地引起騷動的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的各位……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "教會了",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這些事情。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是令人憐愛不已的人們啊……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每一天，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都讓人打從心底",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "期待著那聚在餐桌前的時刻。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想著今日，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又會",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被捲入何等令人開心的事情當中呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是在安穩，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然而",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也未曾有任何變化的故鄉中，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所無法品嘗到的感慨。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是份美食，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一段至高無上的幸福時光。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是各位，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有凱留小姐一同給予了在下的唷。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您把自己",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "述說成了一位應當被唾棄的惡人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實您",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有不少無法",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使人尊敬的部分。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對任何事都有意見，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且易怒，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還不坦率",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又愛逞強。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您絕非是如同魔物一般的邪惡化身。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為您對在下，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是相當的溫柔。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您總是將用餐與步行都相較緩慢的在下放在心頭上。",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並且默默關心著在下對吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可蘿仔，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還這樣稱呼著在下……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還替無法妥善使用筷子的在下，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特地去取了湯匙。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n當差點摔跤時執起了在下的手。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『沒事吧？』　",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此地詢問。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這全部，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都記憶猶新。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下最喜歡",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此溫柔的凱留小姐了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是如此地，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反省對於自己的所作所為，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後懊悔",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且落下眼淚的您……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才會如此愛著您。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並且冀望您活下來，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後再次",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與大家一同聚在餐桌之前。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望能再讓凱留小姐您，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可蘿仔～",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此喚著在下",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後遞出那把湯匙。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若嘴角沾上了汙漬，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還想讓您若無其事地替在下擦拭。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想讓您嘴邊念著妳還是個臭小鬼呢，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻又無可奈何。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想如同以往一樣，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和您再一同度過那相同的時光。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此凱留小姐，",
        "unit_id": 105931,
        "voice": "vo_adv_2012013_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管盡是些孩子般的任性……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您回來吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到【美食殿堂】的各位所環繞著的，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個幸福的餐桌前。",
        "unit_id": 105931
    }
]