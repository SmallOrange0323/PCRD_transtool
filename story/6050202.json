    {
        "type": "dialogue",
        "name": "怜",
        "words": "她的身型嬌小卻是【王宮騎士團】的一員，",
        "unit_id": 114011,
        "voice": "vo_adv_6050202_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該非常努力吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真想和她較量一次看看。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那我也得要展示出",
        "unit_id": 114011,
        "voice": "vo_adv_6050202_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能讓她開心的本領了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她應該總是和很強的人一起練習吧，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能掉以輕心啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也必須重新鍛鍊才行。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你那樣說",
        "unit_id": 114011,
        "voice": "vo_adv_6050202_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對茉莉很失禮呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n心懷敬意就要使出全力……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，不，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "僅僅是在練習的範疇內喔？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不用露出一臉不安的表情……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不如說是我",
        "unit_id": 114011,
        "voice": "vo_adv_6050202_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想從茉莉那裡學到什麼呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼嬌小的身體是怎麼戰鬥的呢？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想一定有很多值得參考的地方。",
        "unit_id": 114011
    }
]