[
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好了，",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們到了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n在放學回家路上",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟閣下一起到懷舊點心店來，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n已經",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "變成每天的習慣了呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "每次都會聚在這裡小孩子們，",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天難得不在呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n只有我跟閣下兩個人。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯嗯，",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這下麻煩了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n以往都是跟小孩子們一起，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n才能毫無顧慮地",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "吃著懷舊點心……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說……",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼……！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下到底有什麼打算！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n居然做這種讓人羨慕，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種奢侈的行為……！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難、",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難道說閣下，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是為了我才買了",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼多的懷舊點心……！？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……沒想到你居然記得我的生日。",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n明明就連我自己本身，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都沒特別去在意了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下送的禮物，",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我確實收到了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然我，那個，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對懷舊點心，並沒有特別喜歡",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哦？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但還是心懷感激地",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "全部收下了！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為這可是",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下送的禮物啊！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以我只好勉為其難，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把這兩隻手抱滿滿的懷舊點心給吃掉囉！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵、",
        "unit_id": 105331,
        "voice": "vo_adv_4010188_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵呵……！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n簡直就像在做夢一樣……！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "謝謝你，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下……♪",
        "unit_id": 105331
    }
]