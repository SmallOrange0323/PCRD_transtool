[
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "510181"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗨，",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你放學後約我出來是怎麼了？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難道想跟我一對一決鬥嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "開玩笑的啦♪",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n現在怎麼可能還有人",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會在屋頂上做這種事。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊哈哈哈……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不對，",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是在笑什麼。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就算是這樣又如何。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是選在午休，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而是等到放學後，才特地約我出來的理由……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果是要一起回家",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的話，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒必要約在這裡。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n難道是有事商量嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "午休時明明一起在這吃過飯了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n居然像這樣正經地約我出來，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難道說……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦、",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等、",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等一下，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我還沒心理準備──",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──啊？",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊──！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不，什麼事都沒有，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你別在意！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n謝啦！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我都忘了！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉～",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "做了些奇怪的聯想。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還讓你準備禮物給我。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我能打開看看嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "已經打開了就是了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "玩偶……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好可愛……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃、",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咳咳。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然對我來說，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有點太過可愛了……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過很有你的風格。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我會好好珍惜它的，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個──",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──熊玩偶。",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "熊……？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼選了熊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂你，",
        "unit_id": 104331,
        "voice": "vo_adv_4010192_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我的內……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你沒回想起什麼多餘的記憶吧！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，等等！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼要逃跑！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我等一下！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管你跑到哪，我都會追到底的──！",
        "unit_id": 104331
    }
]