[
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "橡子遊俠‧鈴雖然在與強敵的激戰中勝出，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但在那之後她便開始歇業，使人們大受打擊。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n即使如此，期盼她復出的聲音卻不曾停止，並且日漸增強。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所～",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的使命已經完成了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今後我要每天吃飽睡睡飽吃了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可別來打擾我哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我、",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才不管呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管是【哞哞自衛隊】還是【慈樂之音】",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都有其他很強的人吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "委託他們不就好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "鎧甲不是重點。",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而是我完全沒有勞動的意願！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以說，",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我以後絕對不會再工作了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就這樣啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "永別了永別了。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "每天都這樣真的很纏人耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "逃跑也是需要體力的喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的很認真耶。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管你說什麼，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我都已經不打算工作了啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想要讓我工作",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就先抓到我吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我話說在前頭，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "像之前那樣哄騙我是沒用的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "紅豆麵包？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在哪裡，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在哪裡飛啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太陽好刺眼我看不清楚～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……不對，",
        "unit_id": 102611,
        "voice": "vo_adv_1127004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這道光不是陽光！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇～！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "快點快點，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別拖拖拉拉的。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太大意的話，你會死掉的喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為現在",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "街上到處都是殭屍啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒錯，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天正是超人氣遊戲",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "《小鎮 of The Dead》舉辦活動的日子！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實我根本不想踏出家門一步，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是只有今天，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只有今天我必須努力。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "畢竟",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "除了會出現大量殭屍以外，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "道具掉落率也加倍了！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且在特定地點",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還會出現活動限定的黃金殭屍！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只要打倒那傢伙，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就能獲得可以轉職成EX階級的道具。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣就算是家裡蹲也會衝出家門啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……會說這種話的人",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就去給殭屍吃吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "馬上就有敵人出現了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我暫時會在這邊打怪，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "待會見囉。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "打倒了好多隻殭屍喔。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也拿到了很多道具，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只剩下最主要的目標了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦哦！",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才剛說，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "黃金殭屍就出現了！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趕快掉限定道具吧，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "接招，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "接招！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太棒了～",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我贏了！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "得到了黃金內臟燒烤！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿嘿，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "特地出門總算有回報了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你那邊如何？",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "打倒黃金殭屍了嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……哇，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你還在跟雜魚殭屍糾纏不休啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是地獄般的場面。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你好遜喔。",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "借我看一下。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你這裝備",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎麼回事啊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼你要裝備著木材？",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n屬性也亂七八糟的，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再有幹勁一點啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總之先把武器換掉，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "火力不夠就靠攻擊次數來決勝負。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿呀嘿呀嘿呀嘿呀～",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "112700401"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你試試看。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎喲真是的，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你動作好慢喔。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你在被咬了你在被咬了！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "趕快喝回復藥！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "死掉了～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你真的是遜到不行耶。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你在傻笑什麼啊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔唔，",
        "unit_id": 102631,
        "voice": "vo_adv_1127004_024"
    },
    {
