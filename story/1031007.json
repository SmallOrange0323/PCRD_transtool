[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和忍見面時，\n在突然一陣強烈的暈眩襲來之後倒了下去。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀！",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}，你怎麼了！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你還好嗎！？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊……{player}的身體跑出瘴氣……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來不是一般的疾病。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我現在用通靈眼來看看。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "天啊……這、這個……！",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，\n雖然很難以啟齒，\n你……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你就快要死掉了。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你身上有很強的詛咒。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這樣下去的話，頂多只能撐半天吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得趕快解除詛咒才行……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不……這是相當高階的詛咒。",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n下這個詛咒的人，恐怕是功力強大的靈媒。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n絕不是半天就可以解除的詛咒。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎、怎麼會……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……………………",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯？",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n怎麼了，忍？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，沒事，爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，雖然會有點痛苦，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但請你稍微忍耐一下。",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，久等了。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n接下來我要進行解除詛咒的儀式。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是除魔之舞。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n具有解除詛咒的效果，請放心。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如何呢，{player}？",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是不是比較不痛苦了？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，你的臉色變好了呢。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n詛咒好像慢慢和緩下來了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n太好了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我、我也不知道有這種舞……",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_015"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍，妳什麼時候學會的？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵呵，我是最近學會的唷。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我想或許哪天會派上用場，所以保險起見就學了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n真是太好了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "哪會……但是謝謝你。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n被{player}這麼誇獎，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然覺得害羞……但是我很開心。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請不用客氣。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我總是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "受到你的幫助啊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……記得嗎？以前，",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我曾經跟{player}約定過，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n「下次換我來守護你」。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在可以幫上你的忙，",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我覺得有些欣慰。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我一直很想報答你……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但這麼想是有點輕率呢。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為{player}剛剛那麼痛苦……真是抱歉。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那我繼續進行儀式喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔唔唔……",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_022"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍和小伙子在打情罵俏…我饒不了他！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "吁、呼、呼…………",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼、",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼啊…………",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "怎、怎麼了，忍！？",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_025"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你臉色鐵青啊！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼啊…………",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、我不要緊喔……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別管這個，我得繼續跳舞才行……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你……難不成這個除魔之舞，",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_027"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n是把小伙子身上的詛咒轉移到忍身上的魔術！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "蠢蛋！",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_028"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這可是能致人於死地的強力詛咒！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n忍怎麼能為了這種混蛋小伙子葬送性命呢！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可以為{player}而死的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我一點都不介意……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為如果沒有{player}，",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那時候我或許早就被闇影給殺了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且我，",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對{player}……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。不過請讓我繼續跳下去。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果{player}就這樣因為詛咒而死掉的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "啊────！我知道了、我知道了！",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_033"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我來解除詛咒！！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你能解除詛咒嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你剛剛也說了，這是功力強大的靈媒下的強力詛咒……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎噗！",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_035"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子！我用盡全部的靈力一口咬住你了。",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_036"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這樣應該可以祛除邪氣才對。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你感覺如何啊？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你、你還好嗎，{player}？",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……太好了……詛咒解除了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你，爸爸！真不愧是爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n竟然可以解除功力強大的靈媒",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所下的強力詛咒。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔！可以解除如此強力詛咒的人，",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_039"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n大概也只有我這種功力強大的靈媒了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n哇哈哈哈哈！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "強力的詛咒……功力強大的靈媒……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大概只有我……？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n該不會對{player}下詛咒的是……！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不妙！",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "果然是這樣……",
        "unit_id": 103111,
        "voice": "vo_adv_1031007_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸！！！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咿！忍好恐怖！！",
        "unit_id": 2411,
        "voice": "vo_adv_1031007_044"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後骷髏老爸就被忍長篇大論地訓了一頓。"
    }
]