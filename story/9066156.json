        "words": "\n",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……呼。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "總算是打倒了……",
        "unit_id": 125813,
        "voice": "vo_adv_9066156_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還真是",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "千鈞一髮呢。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "再次感受到",
        "unit_id": 126013,
        "voice": "vo_adv_9066156_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們跟【美食殿堂】的差距了呢。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我們",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還得更加努力才行。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是啊……",
        "unit_id": 125813,
        "voice": "vo_adv_9066156_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n發現了一個",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "【美食殿堂】跟【幻變少女】的",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "共通點呢。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們也是一樣，",
        "unit_id": 125813,
        "voice": "vo_adv_9066156_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有著「能共同跨越困難的夥伴」。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我再次切身體會到這件事了。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那也是多虧了",
        "unit_id": 125813,
        "voice": "vo_adv_9066156_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有兩位一同煩惱、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一同努力。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n所以說，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們之後也一起加油吧。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……為了總有一天",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "能夠成為一流的冒險者。",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126113,
        "voice": "vo_adv_9066156_006"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n會加油。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉、",
        "unit_id": 126013,
        "voice": "vo_adv_9066156_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就是說呀♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126013,
        "voice": "vo_adv_9066156_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但是請等一下。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "【幻變少女】也一樣，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "有著互動……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n有著「肢體接觸」喔。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不對，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "抱。",
        "unit_id": 126113,
        "voice": "vo_adv_9066156_009"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n抱緊──",
