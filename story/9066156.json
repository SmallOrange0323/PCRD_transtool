        "voice": "vo_adv_9066156_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n各位、",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "太近了……",
        "unit_id": 125813
