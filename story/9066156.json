        "words": "哇哇……！",
        "unit_id": 125813,
        "voice": "vo_adv_9066156_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兩位，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "抱我抱得那麼緊的話……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105911,
        "voice": "vo_adv_9066156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您們不要緊嗎！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像發生了戰鬥……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物在──",
        "unit_id": 106011,
        "voice": "vo_adv_9066156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼狀況！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們黏在一起是怎樣啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "啊。",
        "unit_id": 126113,
        "voice": "vo_adv_9066156_013"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n傲嬌。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說誰是傲嬌啦！？",
        "unit_id": 106011,
        "voice": "vo_adv_9066156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105811,
        "voice": "vo_adv_9066156_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來是正在肢體接觸呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也請讓我們加入～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9066156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要把我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也牽扯進去──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "哇啊啊……",
