[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呀啊啊啊啊！",
        "unit_id": 124111,
        "voice": "vo_adv_5106323_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那個刺刺的外型",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很可怕耶……！",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "發狂的聖誕樹",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比想像中還要棘手……！",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "對不起！",
        "unit_id": 8912,
        "voice": "vo_adv_5106323_001"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "都是我的錯……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "還是讓我自己想辦法吧！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n各位請退後一點！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我自己來──！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "唉～",
        "unit_id": 5512,
        "voice": "vo_adv_5106323_002"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "唉。",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n艾米根本是嘴上說一套，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "實際上做一套啊。",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……咦？",
        "unit_id": 8912,
        "voice": "vo_adv_5106323_003"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我之前不依賴妳，",
        "unit_id": 5512,
        "voice": "vo_adv_5106323_004"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳不是還不高興，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "要我多依賴妳一點？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "為此訓了我一頓的",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不就是艾米妳嗎？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……！！",
        "unit_id": 8912,
        "voice": "vo_adv_5106323_005"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n姊姊……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "對不起……",
        "unit_id": 8912,
        "voice": "vo_adv_5106323_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 124011,
        "voice": "vo_adv_5106323_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看來我們",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也可以幫忙吧？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "──那麼",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "進行最後的攻擊吧！",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 124213,
        "voice": "vo_adv_5106323_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了苦苦等待幸福聖誕節的人們……",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "為了全世界的",
        "unit_id": 1,
        "voice": "vo_adv_5106323_009"
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "可愛姊妹檔……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "要上囉！",
        "unit_id": 1,
        "voice": "vo_adv_5106323_010"
    }
]