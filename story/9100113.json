    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我來讓牠",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "見識一下我的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "大海驚喜箱……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "…………啊啊啊～！？",
        "unit_id": 6411,
        "voice": "vo_adv_9100113_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106011,
        "voice": "vo_adv_9100113_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次又是怎麼了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你應該不會說你忘了帶大海驚喜箱吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不是，",
        "unit_id": 6411,
        "voice": "vo_adv_9100113_032"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我有帶大海驚喜箱……！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "但問題是……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n都怪那傢伙的滑溜溜，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "箱子被弄濕了～！！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇、",
        "unit_id": 105811,
        "voice": "vo_adv_9100113_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就不能用了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果有會讓人放心多就是了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不用擔心！",
        "unit_id": 6411,
        "voice": "vo_adv_9100113_034"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n我現在就吹乾它，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "你們先稍微撐一下場面！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n呼──",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "呼──！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他、",
        "unit_id": 106411,
        "voice": "vo_adv_9100113_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他打算用吹的把箱子吹乾……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這需要花多少時間呀？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺想別的作戰比較快……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲……",
        "unit_id": 106011,
        "voice": "vo_adv_9100113_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個還是別抱期待地等比較剛好。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不重要！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趁雨吉下下來的雨還沒停，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n先狠狠修理那傢伙吧！！",
        "unit_id": 106011
    }
]