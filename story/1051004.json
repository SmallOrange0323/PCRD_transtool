[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}伴隨著深月前往出診。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不好意思呢，",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明不是做實驗卻讓你跟著來。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，你真無情。",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不也挺好的嗎，什麼事都是人生經驗唷？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天的病人是在這一帶從事採礦的人哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然以難以伺候聞名，我可是完全不在意的。",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大概是在醫生面前的關係，所以是位話有點多的大叔呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有還是有的唷？",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過不太想讓人知道呢，我不擅長的東西。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……哎呀？",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這道光是怎麼回事？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不知道怎的……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "突然、好睏……",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為什麼我會在動物園……",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n呼……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺提不起勁。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我的確是說過為了實驗想要動物的數據，",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過這樣不就沒了找你幫忙的意義了嗎。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……自己來收集是最好的？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個……的確是這樣沒錯。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "算了，既然都變成這樣就沒辦法了呢。",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只好硬著頭皮去了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵……原來還挺抗拒的，不過這裡出乎意外地有趣呢。",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "尤其是熊啊大象啊之類的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還有老虎也是，真棒。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看著大型的動物真有意思。",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n想像戰鬥時要如何攻擊才能打倒牠們之類的也很有趣呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "接著要去哪裡？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "欸……可愛動物接觸區！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這、這、這樣的話我可不去！太危險了！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊啊，不過還需要收集數據……",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n嗚嗚……明白了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我去就好了是吧，去就去！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嘿，動物的種類還挺多的呢。",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了……兔子之類的我一直都覺得很可愛呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n如果只是看的話……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "碰、碰碰看……！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一來就接觸太高難度了啦！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "餵食！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不、不過我餵的話可能會堵住牠的喉嚨……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就、",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算你這樣說……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不知道該怎樣拿捏力氣，說不定會惹怒牠……",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "105100401"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n猴、猴子爬到我的肩膀上！？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "快點，幫我拿開！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個……說實話我不太擅長親近動物……！",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不是討厭或是害怕牠們喔！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只不過……不知道要怎麼樣跟牠們相處……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "從遠處看的話還好……",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過要在這種近距離，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還要接觸牠們……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……已、已經是極限了！",
        "unit_id": 105131,
        "voice": "vo_adv_1051004_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們快點回去吧！",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看見的，是如同夢境一般的情景唷。 ",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你醒來以後幾乎都會忘記的， ",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "深月原來不擅長親近動物呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我稍微有點意外哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要靠近動物就會慌張起來，",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "深月也有可愛之處呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看，她平時總是一直做實驗，",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不會展現這種像女孩子的一面吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "成熟女人示弱的場面，很棒對吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n然後你就會想保護她之類的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，怎麼說些無關緊要的事了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1051004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先聊到這裡吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯嗯……？",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……難道，我睡著了……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n竟然在這種地方睡著，看來我也累了呢……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，還真是討厭的夢呢……",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n居然做了要和動物接觸的夢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "欸？嗯，",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對唷。小隻的那種……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "該不會你也做了同一個夢……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嘿，竟然有這種不可思議的事情呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n真有意思呀。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真想確認一下，",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還會不會發生同樣的現象呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喂，你呀。一會兒要不要來我家？",
        "unit_id": 105111,
        "voice": "vo_adv_1051004_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我有很多想嘗試的事呢……♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "感到不妙的{player}，\n全力從那裡逃了出來。"
    }
]