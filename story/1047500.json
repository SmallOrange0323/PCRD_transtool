[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "突然叫我過來做什麼，",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你有什麼煩惱嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對耶，",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來今天是我的生日啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n長大後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對那種事就變得不太在意了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你的祝福。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我真的很開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為鎧甲的關係，",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可能很難把我的喜悅傳達出去，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過我真的很開……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年你",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很明確的感受到了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那還真是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓人害羞啊……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟保護市民",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可是【王宮騎士團】的義務呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n話雖如此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "受人感激",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還是很開心哦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不是那樣嗎？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那到底是什麼事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的生日?　",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼說來的確是今天呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n哎呀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真不好意思。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我沒想到",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會有人幫我慶生。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n容我再說一次……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？　",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是什麼？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是少年你發現的失物嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n包裝得好可愛呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我就收著了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是送我的生日禮物嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是、",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "竟然把少年你特地準備的東西",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n當成了失物，這還真是抱歉……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我對於",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n收到別人的禮物不太習慣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我真的很開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會珍惜它的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你問我待會有沒有空，",
        "unit_id": 104711,
        "voice": "vo_adv_1047500_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是工作完才過來的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過你還準備了什麼嗎？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你真的很溫柔呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那今天",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就不客氣的收下你的溫柔囉。",
        "unit_id": 104711
    }
]