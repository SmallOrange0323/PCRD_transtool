[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "にゃっ、",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_000"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "いいこと思いついたにゃ！　",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お店で猫のグッズを",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n売るっていうのはどうかにゃ？　",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "副収入があればカフェも儲かって",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nモニカも大喜びにゃ。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミ、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "なにかいいアイデアはないかにゃ？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "なるほどにゃ！　",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "推しの猫に肉球でスタンプしてもらうんだにゃ？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "おうちに飾ってもらえば、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "見るたびに推しの猫が恋しくなって",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nついついお店に通ってしまう……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "何人も猫の魅力には抗えないのにゃ！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "──す、",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "素晴らしいアイデアなのにゃ！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お店の集客だけでなく、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫派の勢力を誇示することもできちゃうにゃ！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nそしてゆくゆくはランドソル全土を、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫が支配するのにゃ～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "うにゃっ！？　",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "い、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "いくら同じ猫だからって……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nあたしはモフるのもお触りも禁止だにゃ！　",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "非売品なのにゃ！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "……ま、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "まあ、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミにだけなら売ってあげてもいいけどにゃ……？",
        "unit_id": 125111
    }
]