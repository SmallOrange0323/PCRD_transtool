[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的假的。",
        "unit_id": 110811,
        "voice": "vo_adv_5038302_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那個臭遜廢鐵丸又復活了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，那這要怎麼辦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而且它的火力和輸出似乎也受到了大幅的強化。",
        "unit_id": 111011,
        "voice": "vo_adv_5038302_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀呀～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "自我修復再加上反覆的自我學習真是令人敬畏。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這應該是墨團",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "驚人的技術吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，根本是困擾至極好嗎！？",
        "unit_id": 110911,
        "voice": "vo_adv_5038302_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "浪費技術力好歹也要有個限度啊！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切嚕～☆",
        "unit_id": 13211,
        "voice": "vo_adv_5038302_003"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n切啪哩扣‧切啦哩噗‧切嗶啦啪～～～～～～！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 110811,
        "voice": "vo_adv_5038302_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這傢伙突然間怎麼搞的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全聽不懂到底在講什麼——",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你……",
        "unit_id": 110911,
        "voice": "vo_adv_5038302_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你怎麼會講出這麼恐怖的話，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好朋友X！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我絕對不會讓你得逞的！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖德蕾莎女子學院",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就由琪愛兒等人來保護！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_5038302_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "它剛剛講了啥？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為什麼琪愛兒突然進入戲劇化模式？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n它說了那麼惡劣的話嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀呀，",
        "unit_id": 111011,
        "voice": "vo_adv_5038302_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來切嚕語的功能也強化了的樣子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在它繼續強化之前粉碎它吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力上吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
