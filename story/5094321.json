[
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "給我等一下，",
        "unit_id": 122211,
        "voice": "vo_adv_5094321_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在究竟是怎麼回事！？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們不是已經把冒牌阿斯特賴亞菇的魔物打倒了嗎？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……很遺憾，",
        "unit_id": 104715,
        "voice": "vo_adv_5094321_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對方似乎還沒學到教訓呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不愧是有辦法當上老大的傢伙，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其自尊心看來相當高哪。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哇哇哇……！",
        "unit_id": 122111,
        "voice": "vo_adv_5094321_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而且",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在牠還不斷地在增加蘑菇手下的數量……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若對手打算以量取勝，",
        "unit_id": 104715,
        "voice": "vo_adv_5094321_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們也互相配合，聯手應戰吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "互相配合……",
        "unit_id": 122111,
        "voice": "vo_adv_5094321_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要比孤伶伶一個人",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還來得多人數的團隊合作吧，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我明白了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我覺得到目前為止我們也都有在團隊合作啊……",
        "unit_id": 122211,
        "voice": "vo_adv_5094321_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "算了，不計較那麼多。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n總而言之，先把手下們給解決掉吧！",
        "unit_id": 122211
    }
]