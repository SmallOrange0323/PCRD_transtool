    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不覺得純最近很奇怪嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_5006101_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也這麼覺得。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n跟以往的純不太一樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "偶爾會來獸人居住區這邊，",
        "unit_id": 100511,
        "voice": "vo_adv_5006101_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n對大家做些過份的事！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼要做那些事呢！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡直就像",
        "unit_id": 103711,
        "voice": "vo_adv_5006101_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在鎧甲裡裝了另一個人一樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "去向本人問個清楚吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "視情況……",
        "unit_id": 103711,
        "voice": "vo_adv_5006101_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使是純，也必須制裁。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉・智",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5006101_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉・智",
        "words": "「黑鐵的亡靈（nightmare）」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……怎麼了，",
        "unit_id": 104711,
        "voice": "vo_adv_5006101_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "王宮內部真吵呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該不會王宮內有敵人？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 107111,
        "voice": "vo_adv_5006101_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且對方可不是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一般的敵人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　這可是極度異常的事態！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "到底發生了什麼事呢……！？",
        "unit_id": 104711,
        "voice": "vo_adv_5006101_008"
    }
