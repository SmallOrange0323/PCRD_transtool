[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀……",
        "unit_id": 105911,
        "voice": "vo_adv_9017155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為淋濕使得腳邊變得更滑了呢。\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心不要跌倒。\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是掉到嚴寒的海裡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很有可能會沒命的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙啊～",
        "unit_id": 106011,
        "voice": "vo_adv_9017155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是最近在北之海猖獗的魔物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為會把碰到的冰都碰碰碰地打碎，\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無論是人類還是動物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說都出現了很多受害者。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9017155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於是被奪走居所的冰上魔物們，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也變得無處可去而四處遊蕩呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是為了生態系的安定也好，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得讓牠安份一點才行……",
        "unit_id": 105911
    }
]