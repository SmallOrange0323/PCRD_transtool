        "voice": "vo_adv_3013001_002"
    },
    {
        "type": "dialogue",
        "name": "美美的母親",
        "words": "\n這個是購物清單和地址。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美美的母親",
        "words": "\n今天有商隊來到蘭德索爾附近喔。",
