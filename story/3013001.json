    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "噗滋噗滋咕嘟咕嘟，火鍋在唱歌喔～♪",
        "unit_id": 102011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "噗滋噗滋……",
