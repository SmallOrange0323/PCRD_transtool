    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我、我不知道路了啦～！",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "媽媽～！爸爸～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗚哇～～～嗯！！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個……妳沒事吧？",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_011"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚？",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_012"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那、那個……妳是誰啊？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我叫鏡華，是精靈族。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我在遠處就聽到哭聲，所以擔心地過來看看。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳是迷路了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是的……美美是從蘭德索爾到這裡來買東西，",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n但卻不知道路要怎麼走了……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚嗚～～～哇！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、請別哭呀！妳、妳真奇怪耶。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "獸人族是充滿野性又強勢的種族，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n學校是這麼教的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請問有前往目的地的地圖嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……還有請告訴我妳的名字。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚嗚、嗚嗚……",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我是美美。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這是要去目的地的便條紙喔……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請讓我看一下。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……妳完全走錯方向了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再走回蘭德索爾一趟似乎會比較快。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "美美，我會看著地圖指引妳，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以請跟我來。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華也要陪我一起去嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "謝謝～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n欸嘿嘿～最喜歡鏡華了！",
        "unit_id": 102011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啦嚕嚕，啦嚕嚕～♪",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_021"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n兩人一起散步～♪散步～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "太陽公公，閃閃發亮～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……妳明明迷路了卻還很悠閒呢。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_022"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "因為雖然剛才美美都是自己一個人，",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n但現在有鏡華陪著我一起走啊！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "所以覺得非常放心喔～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（……真是個天真的孩子。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n雖然學過獸人族是更野性的種族……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但或許美美是比較特殊的獸人族？）",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（哈！說不定美美也會",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n變身成可怕的獸人！？）",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "唔唔唔－－－－！",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_026"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗷嗷嗷嗷嗷－－－－－－！！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（……嗯～～。感、感覺應該不太可能）",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！是叉路。",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯～路標寫說……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這邊是蘭德索爾。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後……",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "………",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_029"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、我們迷路了！！！",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_030"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦！？",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好、好奇怪！我應該沒有走錯路啊！",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳看，路標也寫著這邊是蘭德索爾……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗯？",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個路標……不太對呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "照我的印象，蘭德索爾應該是右邊的道路……",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是現在路標卻變成左邊是蘭德索爾。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n路標是錯的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應該說，是有人對調了兩邊的路標。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是、是嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_035"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "對調……是誰做出這種事～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……啊！",
        "unit_id": 103611,
        "voice": "vo_adv_3013001_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說、說不定是！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其、其實最近在我們精靈族之間",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n一直不斷地發生類似的事件。",
        "unit_id": 103611
    },
    {
