    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇啊～！",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n那麼是要去蘭德索爾外面買東西嗎？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美還是第一次自己去蘭德索爾外面呢～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美的母親",
        "words": "那麼就拜託妳了。",
        "unit_id": 1,
        "voice": "vo_adv_3013001_004"
    },
    {
        "type": "dialogue",
        "name": "美美的母親",
        "words": "\n要沿著街道走，絕對不要走偏了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美美的母親",
        "words": "\n路上小心喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯，美美知道了～",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美出門了～！",
        "unit_id": 102011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "買東西～♪買東西～♪",
