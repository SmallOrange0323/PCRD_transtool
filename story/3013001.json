    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "馬鈴薯先生、紅蘿蔔先生、磨菇先生～♪",
        "unit_id": 102011,
        "voice": "vo_adv_3013001_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n和肉先生一起慢慢地燉煮～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
