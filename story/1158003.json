        "name": "莉瑪",
        "words": "對耶！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "老婆婆，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
