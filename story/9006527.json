[
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "唔……！？",
        "unit_id": 192613,
        "voice": "vo_adv_9006527_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太好了！",
        "unit_id": 106011,
        "voice": "vo_adv_9006527_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n破壞掉",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "演算無效化了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "發生奇蹟",
        "unit_id": 192613,
        "voice": "vo_adv_9006527_002"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "到這種程度……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "也真讓人笑不出來啊。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "……但是。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔、",
        "unit_id": 106411,
        "voice": "vo_adv_9006527_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔唔……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、可可蘿",
        "words": "「雪菲小姐！」\n「小雪菲！？」",
        "unit_id": 1,
        "voice": "vo_adv_9006527_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 106411,
        "voice": "vo_adv_9006527_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我沒事……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n畢竟",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就差一點了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我可不能",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在這裡倒下……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們方的況狀",
        "unit_id": 100311,
        "voice": "vo_adv_9006527_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是滿身瘡痍。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不能再繼續拖下去……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣的話……",
        "unit_id": 100211,
        "voice": "vo_adv_9006527_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n拜託你了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "……好啊。",
        "unit_id": 192613,
        "voice": "vo_adv_9006527_008"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "既然如此……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "既然如此，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我現在就將此身捕獲的眾多靈魂作為階梯，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n來引發所謂的奇蹟吧……！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔！",
        "unit_id": 180111,
        "voice": "vo_adv_9006527_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 180111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對方似乎",
        "unit_id": 180111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也要徹底使出真本事了……！",
        "unit_id": 180111
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "啊啊──",
        "unit_id": 192613,
        "voice": "vo_adv_9006527_010"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "神啊神啊神啊！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n奇蹟的根源啊！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n人智不可觸及的理外之混沌啊！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "人類史上獨一無二的",
        "unit_id": 192613,
        "voice": "vo_adv_9006527_011"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "奇蹟與神祕的聚集地──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n在此化為靈魂坩堝的",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "阿斯特朗傳奇！",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n在我面前",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "顯現其身姿吧！",
        "unit_id": 192613
    }
]