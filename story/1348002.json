    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要啊啊啊！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然很感謝你，",
