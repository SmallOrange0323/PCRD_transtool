    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是之後",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也請來救救我～～！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然、",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果可以盡量不要看向這邊我會很感激的！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只要某個東西稍微移動位置，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "重要的部分就會……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喝啊，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "青蛙魔物們",
        "words": "──呱呱呱！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感、",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺之前",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好像也發生過類似的事？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難道遭遇這種事就是我的宿命嗎──？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這青蛙，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼會想吃我的衣服啊！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這好吃嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是牠愛吃的嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊！",
        "unit_id": 134812
    },
    {
        "type": "background",
        "background": "502210"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來這件衣服的原料，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是在鬼岩城塞溫泉附近採集的，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n被當地人",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "稱為「青蛙皮」。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就想說明明是植物卻叫皮",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還真奇怪……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來不是指皮膚，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而是指調皮的青蛙愛吃這個！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n居然還有這種陷阱嗎！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吉歐‧格黑納真讓人受不了──！！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "青蛙魔物們",
        "words": "──呱啊啊啊啊啊！！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺越來越火大了……",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n才這種程度，",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可不會認輸！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算我自己的衣服破了，",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也要為了他人製作衣服！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這就是作為裁縫師的決心，",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "負責慈樂之音服裝製作的自尊！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到底吃衣服這種行為，",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "根本是裁縫師之敵！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也是女性之敵！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼可能敗給這種傢伙啊啊啊！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "全身",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "充滿了力量……！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這傢伙～～～～～！",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吉歐‧格黑納色青蛙！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n讓你們嚐嚐",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "蘭德索爾裁縫師編織的絲線力量────！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n看招──────！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "青蛙魔物們",
        "words": "──呱啊啊啊啊啊啊啊啊啊啊啊啊啊！？",
        "unit_id": 3
    },
    {
        "type": "background",
        "background": "502111"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一時之間還想說該怎麼辦呢，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n總算是回來了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "衣服能馬上修補好真是太好了……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒受傷！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多虧有騎士先生幫忙！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n成功把素材帶回來了！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣感覺就能",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "兼顧耐用性和易加工性！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛被強化的時候……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我感覺比平時獲得了",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "更多的力量，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也因此將那些青蛙魔物一網打盡了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有做什麼",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "特別的事嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是這樣啊……",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為我",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要遇到衣服的事情就會變得忘我……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很好～！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "材料和道具都齊全了！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n馬上來做準備吧！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一定會在",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吉歐‧格黑納",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "掀起「時尚革命」！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希距離兼顧時尚與狂野又更進一步。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n吉歐‧格黑納正要迎向黎明──"
    }
