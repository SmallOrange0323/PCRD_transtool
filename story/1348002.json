    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你騎士先生！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒錯，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在比起我，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請絕對要保護好那些素材！",
