    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些青蛙是怎樣啊！？",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼一直攻擊我的衣服……",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊──！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要拉扯那邊──！",
        "unit_id": 134811
    },
    {
        "type": "background",
        "background": "502070"
    },
    {
        "type": "dialogue",
        "name": "青蛙魔物們",
        "words": "──呱啊啊啊啊啊！！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你！",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我要把這個素材帶回去，",
        "unit_id": 134811,
        "voice": "vo_adv_1348002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在吉歐‧格黑納",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "掀起「時尚革命」！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和紡希在叢林深處與魔物戰鬥。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為什麼"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要來到吉歐‧格黑納數一數二的危險地帶？"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n事情要回溯至昨天──"
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯……",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼樣都找不到呢……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n能夠做成堅韌布料的素材……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種葉子感覺比看起來還脆弱，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這邊的藤蔓又太硬了不適合加工……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我在找能當作衣服素材的植物。",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "衣服的素材有不可或缺的重要元素，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要舉兩個的話，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你覺得是什麼？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有毅力嗎！？",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "思考方式是不是被吉歐‧格黑納感染了？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "毅力雖然是裁縫師很重要的元素，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但不是正確答案。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "答案是，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "耐用性和",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "易加工性。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "耐用性你能懂吧，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為容易破掉損壞的衣服",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "並不實用。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這在吉歐‧格黑納中，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是尤其重要的元素。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再來是易加工性，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也很重要。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果素材不易加工，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就無法做出設計複雜的衣服！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了做出色彩鮮艷的布料，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也不能無視好不好染色這點。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "耐用性和易加工性",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是很難兼顧的。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "堅韌的素材很難加工，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n好加工的素材又缺乏耐久力，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是這種感覺。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是當然……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也是為了時尚拼命的人啊。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不管什麼事要兼顧都很困難呢。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該怎麼辦呢……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個～",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你是上次",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和那位衝鋒迅豹女性",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聊天的人對吧？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "嗯？",
        "unit_id": 50711,
        "voice": "vo_adv_1348002_014"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "妳是誰？",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "生面孔呢。",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是在蘭德索爾經營裁縫店的紡希。",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正在尋找衣服的素材。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "衣服的素材？",
        "unit_id": 50711,
        "voice": "vo_adv_1348002_016"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "這附近的素材",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "普遍是野獸或魔物的皮革。",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "雖然也有植物素材，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "但不太精緻啊。",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "蘭德索爾那邊",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "會組合各種素材",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "做裝飾對吧？",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "蘭德索爾的素材有很多種類和顏色。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吉歐‧格黑納",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定也會有好的素材！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果有實用又可愛的衣服，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那不是超棒的嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n上次和你吵架的",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那位女性也能夠……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "讓、",
        "unit_id": 50711,
        "voice": "vo_adv_1348002_019"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "讓那傢伙打扮得可愛？",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "我、",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "那個，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "那傢伙穿什麼",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "我都沒差……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在這邊嘴硬幹嘛啊，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總覺得像在看自己一樣真令人火大……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有想到什麼堅韌又好加工的素材嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "這個嘛。",
        "unit_id": 50711,
        "voice": "vo_adv_1348002_021"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "叢林深處",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "有藤蔓的群生地，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n那個如何？",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "雖然不知道是不是妳說的好素材，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n但捕獲魔物的時候都會用那個。",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "我可以保證它很堅韌也易用，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "只是……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就是想聽這種情報！",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那麼我們馬上出發！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為了時尚，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了可愛的衣服，不管是哪裡都要去！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "啊，",
        "unit_id": 50711,
        "voice": "vo_adv_1348002_023"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "喂！",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "等一下等一下！",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n那邊住著難纏的魔物……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "啊，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "跑走了……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "\n",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "那個傢伙也是、那個女生也是，",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男性",
        "words": "怎麼都不聽人說話啊……？",
        "unit_id": 50711
    },
    {
        "type": "background",
        "background": "502070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是悶熱。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然吉歐‧格黑納感覺只有樹木、草和石頭，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但這裡又更加充滿野性了呢。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然的確是狂野過頭了，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我不討厭。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n經歷了一些事之後，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在也很習慣了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且現在，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我有要用時尚帶給吉歐‧格黑納幸福",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個重要的目標！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想找到在蘭德索爾沒有，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "屬於吉歐‧格黑納的時尚。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "活動自如和狂野，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有設計感！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定能夠兼顧的。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然有些人",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對時尚會有「裝模作樣～」",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "的印象，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但換個想法，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "心態也會跟著改變。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "打聽到的地方應該就是這裡了……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n有看到類似的素材嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "腳下！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……真的耶。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "專注在聊天都沒發現！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個一定能拿來用，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺可以做出很好的布料！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼，",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有這麼多就夠了吧！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "趕快回去吧！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n借個小屋",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當成簡易工作室的話馬上就能動工…………",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "青蛙魔物們",
        "words": "──呱呱呱！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些東西是什麼？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "青蛙魔物？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有超多隻的！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不、",
        "unit_id": 134812,
        "voice": "vo_adv_1348002_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不要過來！",
