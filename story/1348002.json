    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "走開！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這傢伙……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊啊啊啊！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的──！",
