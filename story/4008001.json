        "voice": "vo_adv_4008001_010"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我也要去委託其他公會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以差不多該告辭了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請你們務必積極地考慮看看♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼",
        "unit_id": 106012,
        "voice": "vo_adv_4008001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳打算怎麼辦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "條件這麼有利的委託，",
