    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要去正常的高級餐廳點一套全餐！！",
        "unit_id": 106012
