    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "你們在嗎！？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我有事想商量……！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_4008001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看妳這麼著急，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是怎麼了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "其實，",
        "unit_id": 190811,
        "voice": "vo_adv_4008001_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們在蘭德索爾的各地",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "發現了大量的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n新冒險地點喔！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "且還是",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "完全未開發的狀態！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說，",
        "unit_id": 106012,
        "voice": "vo_adv_4008001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寶物可以隨便拿的！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這不是一夜致富的大好機會嗎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了好了，",
        "unit_id": 105913,
        "voice": "vo_adv_4008001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們先",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽花凜小姐講完吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您找我們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼事呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們正在向蘭德索爾的公會們",
        "unit_id": 190811,
        "voice": "vo_adv_4008001_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n委託去遠征本次找到的冒險目的地。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因此也來拜訪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "由公會管理協會來",
        "unit_id": 106012,
        "voice": "vo_adv_4008001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "指揮未開發之地的冒險委託……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "找到的寶物，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最後還是會被沒收？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不會。",
        "unit_id": 190811,
        "voice": "vo_adv_4008001_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "協會的目的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只是要把握未開發之地的狀況，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所發現的物品，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各公會可當作獎勵拿回去喔♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的嗎！？",
        "unit_id": 106412,
        "voice": "vo_adv_4008001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106412
    },
