[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了完成被派遣的任務而到訪了月光學院，\n並在某間教室裡發現了熟悉的人影。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "居然能在這種地方碰見你，好巧哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在工作嗎？我也是因為工作在這裡哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "偶爾我會給這裡的學生上課。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n相對地，我做實驗時就可以借用這裡的教室。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我現在也正好在為實驗做準備……",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了！要不你現在就來當我的實驗品？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之前不是約好了的嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放心吧。這次並不是什麼危險的實驗。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……大概。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你已經要回去了嗎？……真可惜。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……怎麼了？難道門開不了嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "其實呢，我在教室裡施展了結界魔法。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不解除的話，無論是誰也無法進出。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嚇到你了？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "平時是為了不讓實驗動物逃走而用的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有備無患嘛♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "反正你無路可逃了，",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "快點死心過來幫忙吧。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "105100201"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我最近在為這種會產生特殊香氣的薔薇做品種改良哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就是這個……你看。這種花的色調很棒對吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來聞一下這種花的香氣……",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣一來你就會對我言聽計從了哦……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵……看你能忍到什麼時候？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……快忍不住了吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "牙一咬吸氣吧。\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來……請放輕鬆……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，你以為走遠點就可以了？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很可惜，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為有結界所以教室裡會充滿香氣哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我已經喝了解藥，能對香氣的效果免疫，",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但你呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你看，香氣越來越濃了唷。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "105100202"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵……你剛剛吸進去了吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "馬上就會有效果了唷。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你越來越想睡了吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n來，過來在這裡坐下。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，我要確認一下催眠術的效果唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你的名字是？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵，真是乖孩子。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n催眠已經開始有效果了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼就來下一個問題了唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n告訴我，對你來說最丟臉的往事是什麼？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……咦？沒有？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n怎麼可能……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "丟臉的回憶應該是最深刻的啊……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你能告訴我為什麼沒有丟臉的回憶嗎？",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "105100202"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喪失記憶……",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來如此。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n憑這簡單的技法可能無法幫你恢復記憶……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼把你現在對自己所認知的一切統統告訴我？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……欸，還發生了這種事情……然後呢？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n嗯……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這還挺有意思的呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……公主騎士？能使女孩子變強的特殊能力？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這種事情也做得到嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……真有趣呢。關於特殊能力，能說得再詳細點嗎……！",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我現在開始數到三，你就會醒過來哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n一……二……三！",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……早安。感覺怎樣？",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n剛剛我聽了不少關於你的事哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "記憶喪失還有特殊能力……",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你的背景真是精彩，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不只把你當作實驗品，我對你整個人都產生興趣了！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣一來就得對你進行更仔細的身體檢查了呢！",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n呵呵呵……有意義的調查真令人興奮！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，你要去哪裡？ 雖然我已經解開了結界魔法……",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你不陪我做檢查了嗎？ ",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不會弄疼你的唷…… 好嘛？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為以後也要讓你參與各種不同的實驗，",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我必須要對你全身上下的每個部位都完全掌握哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是服用了不適當的藥物，後果不堪設想哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為了不讓這種事情發生，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我必須由頭到尾地把你的身體調查清楚。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……你要乖乖的。",
        "unit_id": 105111,
        "voice": "vo_adv_1051002_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有不少地方要確認呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，要開始了唷！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "無法抵抗的{player}，\n除了重要部位以外，都被徹底調查了一遍……"
    }
]