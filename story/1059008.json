[
    {
        "type": "background",
        "background": "500182"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚕～……♪　",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n嚕嚕～嚕～……♪　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……喔呀，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這麼晚了，有什麼事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，在下這次有留下訊息，所以想必您應該知道了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下放回故鄉的傳信鴉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也差不多該回來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正要到這座森林裡迎接牠們。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們比預定的時間還要晚回來，所以在下有點擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n希望牠們不是被魔物襲擊就好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了讓傳信鴉能夠輕易地找到回來的地方，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下剛剛用容易被牠們聽見的音域唱歌。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈族的歌聲",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘊藏著特別的力量。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過跟職業的吟遊詩人相比，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不過是個外行人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人要不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟在下一起唱啊？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽到主人的聲音，在下總覺得很安心……",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然一不小心就會睡著♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……？　",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n汪汪主人也跟您在一起喔？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可以突然飛奔過來喔，在下會嚇到的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不可以這樣舔來舔去的……",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真是愛撒嬌呢，主人♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下不在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n汪汪主人感到寂寞所以放聲狂吠。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此造成鄰居們的困擾，就害您被教訓了一頓是嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正因如此。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您才把汪汪主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n帶到在下的身邊來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是這樣，",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是抱歉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是在下思慮不周。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是因為在下把汪汪主人扔下不管，",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以讓牠感到不安呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用擔心喔，",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n即使總有一天我們會找到您的飼主而終將分離。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n此刻在下會陪在您身旁的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇……",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，您又在發光了唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是什麼事？",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯小姐是不是有什麼事情想告訴主人？",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "510141"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……哎呀。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這不是主人嗎。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "別來無恙。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人忘記在下了嗎？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "沒錯，在下正是您忠誠的僕人……棗 可蘿。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "很榮幸能夠再次見到您，主人……♪",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗚……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n為什麼要摀住在下的嘴，主人？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦，不能太大聲稱呼您為主人嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我們會被周圍的人投以異樣的眼光？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下並不在意這種事。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因為主人就是在下的主人……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您說至少在他人面前不要這麼稱呼？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如果這是主人的命令，在下必會遵從。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "因為在下對主人唯命是從。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "話說回來，主……那個，應該要換別的稱呼呢。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_023"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您在動物園裡做什麼呢？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "難道這就是所謂的約會嗎？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "俗話說「英雄難過美人關」……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_025"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您跟一起出來玩的同性友人走散了？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯，這個動物園還蠻複雜的呢。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今天又剛好是假日，人山人海的。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不小心迷路也沒辦法。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_027"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……您說手機也很不湊巧地沒電了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n好像沒辦法跟朋友會合？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "原來如此。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_028"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下剛好有帶充電器，借給您吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在充好電之前，您就跟在下約會吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下可以牽您的手嗎……♪",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_029"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "喔耶……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_030"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那在下就恭敬不如從命囉。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您的手好大喔……♪",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_031"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇哇……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_032"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n好大的福利呢，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下深感榮幸♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_033"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您果然和在下想的一樣，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是個溫柔的人……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_034"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您問在下在動物園做什麼嗎……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下住在這裡喔。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_035"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，剛剛那句話有點語病……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下可不是那種動物狂喔。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "正確來說，在下是生活在動物園附設的研究所裡。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_036"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n父親是那邊的高層……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真正的住處是在國外，日本這邊的只是暫住的地方喔。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有了這層關係，在下靠臉就能免費進入動物園……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_037"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n小學放學後，在下多半在這裡到處亂晃。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下一直無法融入小學生活……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_038"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n大概是在下的言行舉止總是冒冒失失的關係吧，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "所以放學後也沒有一起玩的朋友。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下果然還是有點寂寞……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_039"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "能和您相遇，在下真的很開心喔。",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "105900801"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "哇哇？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_040"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您怎麼了嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣突然跑起來，在下會很困擾的……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "咦？",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_041"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您說到今天日落為止，您都會跟在下一起玩嗎……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然很開心您能這麼說，",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_042"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但您不是跟朋友一起來的嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您不用管在下，快去跟朋友會合吧……",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_043"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然在下並不是很明白，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但所謂朋友，應該是很重要的人吧？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您真的很溫柔呢。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_044"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是看到在下很寂寞的樣子，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n所以才安慰在下的吧。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "非常感謝您。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_045"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n像您這樣的人，能成為在下的主人……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n真的是太好了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嘻嘻。",
        "unit_id": 105931,
        "voice": "vo_adv_1059008_046"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下真是幸福的人呢♪",
        "unit_id": 105931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿……",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，多麼討人喜歡啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對可可蘿這麼溫柔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子真的一直都是孤單一人，",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也很少看到她笑呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在動物園一起玩樂的那天，還有和你見面的時候……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她都露出了符合年紀的可愛笑容呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那孩子的改變應該是『從現在開始』的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下你們和你的朋友會合之後，就會一起玩樂吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那些朋友當中，",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有個人的妹妹正好在可可蘿的那所學校就讀……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把那個人的妹妹介紹給她，讓她們成為朋友。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來可可蘿應該就會得到幸福了。",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如同普通的小學生一般，好好享受她的人生喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "獨自一人在動物園裡遊蕩的生活也會結束才是。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是，",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就在那之前，她將要得到那平凡的幸福之前……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子的人生迎來了不平凡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在那個當下勉強迎合她也好，怎樣都好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然成為了那孩子的『主人』，就帶給她幸福吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將她從這個地獄拯救出來吧……",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然跟現在的你說這些也沒用，但我誠心地祈禱你能做到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "麻煩你囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那今天就先這樣……",
        "unit_id": 190011,
        "voice": "vo_adv_1059008_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰，可可蘿就拜託你囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500182"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊太好了，您終於醒了……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您見到愛梅斯小姐了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她說了什麼嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……您說不太記得了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟愛梅斯小姐的對話，",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以說就像是做夢一樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記憶模糊也沒辦法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下雖然也能在神殿接受天啟，",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但只能聽見聲音而已……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對方究竟長什麼樣子，在下相當感興趣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇哇？",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，為什麼要摸在下的頭？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說總覺得應該這麼做……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，主人真奇怪呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被您這樣摸摸頭，雖然很開心……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是會令在下想睡覺，現在就請您放過在下吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在迎接傳信鴉之前。",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下必須保持清醒，在這裡待命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以主人的摸摸頭獎勵……就留到待會再給吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等到辦完正事回家後……",
        "unit_id": 105913,
        "voice": "vo_adv_1059008_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請讓在下盡情地撒嬌♪",
        "unit_id": 105913
    }
]