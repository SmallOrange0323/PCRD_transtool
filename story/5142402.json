    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "やった、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "やってやりましたわー！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nバジリスク、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "討伐完りょ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "う……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ららら……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさん！？　",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_001"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "どこか",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ケガでもされたんですか！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "ご安心を。",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "体力が尽きかけたところに大声で勝ち名乗りを上げたせいで",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nいよいよ限界がきただけですから。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n特製の栄養剤で",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "体力を前借りすれば、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "すぐ復活します。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そう、",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_003"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ですか……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "よかった……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさんには",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "だいぶ無理をさせてしまいました。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わたしのために、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ありがとうございます……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ふっ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_004"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下の頼みとあらば、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "化け物の一匹や二匹くらい",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n倒してみせるのが真の忠臣、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ですわ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "まあ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "実際倒したのは",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下なのですが。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_006"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "細かいことはいいんですわよ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "とにかくわたくしは",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下のためなら何でもする、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nそのことは示せたし、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これからも努めてまいりますわ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさん……",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_007"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それでは",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "お疲れのところ申し訳ないのですが、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "このバジリスクの下処理を手伝ってください！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "え……？　",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_008"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "このデカすぎバジリスクを、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ここで……？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "はい！　",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_009"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "すぐにやらないとどんどん味が落ちてしまうので、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "最高のごちそうにするためにも",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ぜひ、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "お願いします。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "頑張ってくださいね、",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真の忠臣。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ちょっと！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n貴女も手伝うんですからね秘書１号！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "あ。",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_012"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "もう定時を過ぎていますので。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "きいいいーーーーっ！！",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_013"
    }
]