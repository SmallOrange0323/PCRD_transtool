[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到了舞台劇當天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n紡希終於要正式上場了。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天終於、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就要站上舞台了……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "角色的揣摩很完美，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "特效的部分",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也沒有鬆懈……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們應該有把所有能做到的事情",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都做好了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這股坐立難安的感覺",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是怎麼一回事呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……居然被騎士先生擔心了，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這真是我的恥辱。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但你不必擔心喔。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生你該不會是覺得",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒精神的人",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都是因為沒吃飽……？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我覺得這很像騎士先生的作風……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你放心吧。",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你以為我至今站上過幾次慈樂之音的舞台了？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n事到如今……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……對不起，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是在逞強。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n坦白說，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我很緊張。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "挑戰新事物原來",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是會讓人這麼緊張的事情啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在我第一次站上慈樂之音的舞台時，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一定跟現在有著同樣的感覺。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我現在又再次有了",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那時候的感受。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然那時候是受到了小望強硬的邀請，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就忘我地上台表演了……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但這次",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有我一個人。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒有人會在前頭拉我一把。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這讓人有一點……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不放心呢。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "噗，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊哈哈！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你在講什麼啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "區區的騎士先生，你的口氣太大了喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算有騎士先生在，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也完全不覺得放心就是了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過嘛……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你在最近的地方",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好好看著吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看著我……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是看著我",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和騎士先生一起打造出的舞台劇。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那我差不多",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該去就準備位置了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我先走囉！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會在舞台上",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "確認你是不是真的有在看喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是你敢打瞌睡，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我之後可是會訓你一頓的！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "待會見！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛那股坐立難安的感覺",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "已經消失了……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣就沒有問題了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我一定要讓這場表演成功──！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼哼。",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是人類的城鎮嗎……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多麼地熱鬧呀。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "觀眾席",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都坐滿了呢……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也要感謝主辦人",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "努力地宣傳啊……！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今晚",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就由身為吸血鬼的妾身，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n以恐懼和絕望",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "籠罩這座城鎮吧！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──嘿！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在這時候生起煙霧，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "同時用事前暗藏的鋼絲飛起來！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "喔喔────！",
        "unit_id": 1,
        "voice": "vo_adv_1139003_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "很好很好，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一如我的目的，觀眾也很驚訝呢！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我的特效",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可不是只有這樣而已喔……！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──萬聖節還真是個愉快的東西呀。",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哈哈哈！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妾身很是中意！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "差不多要到劇情高潮了……！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在這之前都很完美，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就這樣繼續演到最後吧……！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "觀眾的反應很不錯，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n特效也和舞台劇配合得很順利！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要能保持這樣，沒有發生任何問題的話……！　",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話又說回來……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妾身不打算用恐懼和絕望來籠罩城鎮了！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但相對地，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妾身明年還會再來的！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生在哪裡呢？",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他不在觀眾席上，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也沒在舞台兩翼看到他……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難不成那個人……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我明明要他在最近的地方看著，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他該不會是又迷路到哪裡去了吧！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我難得完美地……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼我非得覺得這麼遺憾不可啊！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊，受不了！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然都這樣了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我待會一定要跟他問個水落石出！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不可以心浮氣躁。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比起這件事，接下來就是最後的場景，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也就是身為主角的女吸血鬼",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "向人類男子告白的場景……！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和我演對手戲的男人",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會從舞台側翼走過來，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在我面前跪下，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "奇怪？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從舞台側翼走過來的人……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼是……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──騎……！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_040"
    },
    {
        "type": "still",
        "still": "113900301"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？　",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好險，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我差點就要喊出來了！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你在做什麼啊？騎士先生！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n現在可是正式表演耶！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊對耶！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……才不是這樣啦！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來是很重要的最後場景！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n現在可是和我演對手戲的演員登場的時候耶……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊？",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是在最後場景中",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和我演對手戲的人？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼！？",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是騙人的吧！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我可沒聽說過這件事情喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說為什麼都沒人阻止你啊！",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n主辦人呢！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "……呵呵，",
        "unit_id": 2511,
        "voice": "vo_adv_1139003_050"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n這就叫",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "別出心裁的驚喜喔。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──一臉好像在這麼說的微笑，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是這樣的話……！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "演對手戲的角色台詞很少，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我想就算是騎士先生，應該也沒問題……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "……窸窸窣窣。",
        "unit_id": 1,
        "voice": "vo_adv_1139003_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟糕，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我忘記把台詞繼續說下去了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n總而言之，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我得繼續演戲……！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但這個場景",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是女吸血鬼",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "向人類男子告白的場景……",
        "unit_id": 113911
    },
    {
        "type": "still",
        "still": "113900302"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我……",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要對騎士先生……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "告白！？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒有。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒什麼。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有好好記住台詞呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明被我使喚成那樣，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卻連演技也有好好地在練習……？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……人類啊。",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妾身很中意你。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請你──",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……真是的。",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣一來，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我不就絕對不能失敗了嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──和我永遠",
        "unit_id": 113911,
        "voice": "vo_adv_1139003_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在一起吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不久後，布幕拉下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n熱烈的喝采聲向著舞台排山倒海而來。"
    },
    {
        "type": "still",
        "still": "end"
    }
]