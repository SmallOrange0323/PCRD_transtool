    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然一路上發生了不少事……",
        "unit_id": 101711,
        "voice": "vo_adv_5076411_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但能夠讓小棉花糖",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "恢復原本的乖巧模樣，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "送牠回靈界去……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可說是萬聖節拯救隊的",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大獲全勝～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，說真的……",
        "unit_id": 101711,
        "voice": "vo_adv_5076411_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n和小棉花糖分開，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不禁讓人感到有點寂寞……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是說啊……",
        "unit_id": 101611,
        "voice": "vo_adv_5076411_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "反正",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "以後還有機會再見到面吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不然，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們找個機會去靈界",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "遊玩也不錯啊！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖說不清楚前往的方式，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但只要有秀才在，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "肯定會有辦法的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很好！",
        "unit_id": 103011,
        "voice": "vo_adv_5076411_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我舉雙手贊成",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "去找小棉花糖！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再說，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "靈界或許也是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "該由將軍來統治之地。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "身為侍奉將軍的家臣，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果有機會，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我很想",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "去一次看看！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳們兩位",
        "unit_id": 101711,
        "voice": "vo_adv_5076411_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還真大膽呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這也不失為好主意～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果真有要去遊玩，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會為小棉花糖和靈界之王陛下，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n準備許多開口笑帶去的～♪",
        "unit_id": 101711
    }
