    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "美咲所說的",
        "unit_id": 102111,
        "voice": "vo_adv_6088201_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "成熟的淑女",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是怎麼樣的人呢？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得不只是像咲戀媽媽那樣的感覺……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一想到各種做生意的點子",
        "unit_id": 102111,
        "voice": "vo_adv_6088201_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就會立刻去執行，\n這一點很帥氣呢。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "美咲長大後",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也會充滿工作熱忱嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真厲害……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……哇！？",
        "unit_id": 102111,
        "voice": "vo_adv_6088201_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說得也是。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真陽小姐也是個大人呢。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "從事牧場工作的真陽小姐",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "無疑是個大人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我怎麼老是忘記這點呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦！？",
        "unit_id": 102111,
        "voice": "vo_adv_6088201_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你說我嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是指演戲時候的我吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得還是有點不好意思。",
        "unit_id": 102111
    }
]