[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}散著步，\n遇見了站在店門前的紡希。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，騎士先生……早安啊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我埋頭在設計上覺都沒睡，請別看我的臉了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天上午就會打烊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……今天的陽光還真是刺眼呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是陽光？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那這道光是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "已經、不行了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "睏死了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼都沒辦法思考……",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然時間很短，但能見到你真是太好了。",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼晚上，阿斯特朗再見了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我等一下！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那邊的那位！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那邊的那位，就是你！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請你別再接近怜大人了！你這個跟蹤狂！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯沒錯！就是在說你！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼誤會！？從剛才就一副居心不良，",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n想和怜大人攀談的樣子！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一整天都在盯著怜大人！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我的眼睛是不會弄錯的！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才、才沒有那回事呢！？",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這人真是沒禮貌啊！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可是遠～比你，",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還要了解怜大人的一切哦！？",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "即使如此，要我信任你這個毫無品味的人我哪做得到啊……",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人也真是的，這種關鍵的地方卻這麼沒有戒心呢。",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n最近在阿斯特朗也是和騎士先生這麼要好…………",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我話還沒有說完欸！別想逃跑啊！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n必殺皮尺束縛！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼樣？掙脫不了了吧？",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你別再想著要逃跑了！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯沒錯！我勤練許久，掌握了阿斯特朗的技能！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？難、難不成，你……！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊？你給我等一下！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n話說，難道你……！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你就是，阿斯特朗的「騎士先生」……！？",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生和怜大人，不僅是在阿斯特朗就連現實中也是――！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──你們兩位。到底在做什麼？",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜、怜大人！？不，是士條前輩！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "您、您好……您剛才不是先行回去了嗎……？",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想到還有其他事情要找{player}，",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就回來看看，結果……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳為什麼要在公眾面前，",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大聲疾呼我的名字呢……？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂，那不是……",
        "unit_id": 1031,
        "voice": "vo_adv_1054004_023"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "噓！",
        "unit_id": 1231,
        "voice": "vo_adv_1054004_024"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "看起來很不妙還是不要看比較好啦！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼時候多了這麼多看熱鬧的人……！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_025"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "剛才我聽見了說是跟蹤狂哦。跟蹤狂說的是那個男的嗎？",
        "voice": "vo_adv_1054004_026"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n咦？不過那孩子也變得安分起來了。"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那男生劈腿了嗎……",
        "voice": "vo_adv_1054004_027"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "啊啊看來好像不是。"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n還是說兩邊都是跟蹤狂，"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "在互相搶奪那個女孩子啊？"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人，這是誤會！我只是想要修理這個跟蹤狂而已！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也不知道他居然就是那個騎士先生啊――！",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不要找藉口！",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}你也是！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是──！萬分抱歉──！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……騎士先生也反省一下啦？",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生不也一起被怜大人罵了嗎！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且竟然還是用拘束方式把我給認出來的──",
        "unit_id": 105432
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──給我適可而止！你們兩個都給我跪坐！快點！",
        "unit_id": 100331,
        "voice": "vo_adv_1054004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……要是在阿斯特朗你們早就被我切成兩半了！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼會～！怜大人對不起啊――！",
        "unit_id": 105432,
        "voice": "vo_adv_1054004_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請原諒我吧～！！",
        "unit_id": 105432
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦你了♪",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來過後大概就會忘掉了吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在就請你不用太在意了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來紡希還真是個有趣的孩子呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n尤其是那個技能，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底是為了什麼才學會的呢……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她很努力，",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但有時好像也會朝著奇怪的方向前進呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可以的話還請你好好導正她一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次再做些怪事，小心可別又被綁起來了哦？",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……該不會，養成癖好了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的。那就下次再見囉。掰掰～",
        "unit_id": 190011,
        "voice": "vo_adv_1054004_039"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？難道，我睡著了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也睡著了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明沒有通宵，真是個悠閒的傢伙。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……怎麼會這樣。騎士先生這呆滯的臉，",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我似乎也在夢境中見到過的樣子。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "記得我們是在為怜大人的事吵架的樣子……",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會、會做那樣的夢也是因為，",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生和怜大人的關係太好的緣故！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……也不是說你們的關係不可以這麼好，",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只是稍微，那個，也應該要看一下場合才對嘛……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是因為夢境的緣故嗎……？",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼覺得現在，自己必需要向騎士先生道歉的感覺……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？騎、騎士先生！你的衣服都脫線了！看，在這裡！",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真拿你沒辦法，我來幫你補好吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "事先說好，我所使用的線……",
        "unit_id": 105411,
        "voice": "vo_adv_1054004_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n其實才不是為了拿來綁人的道具喔！",
        "unit_id": 105411
    },
