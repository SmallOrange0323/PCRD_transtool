    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節當天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊緒為了表達對{player}平日的感謝之情"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在市集大道上尋找禮物。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯……",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一直在找禮物",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知不覺就到這個時間了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "結果，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}到底會想要什麼呢……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作為教師贈送禮物的話，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "果然還是參考書？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，不過",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他最近正在認真研讀自己買的書呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然我猜不管送什麼禮物",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他一定都會很高興，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但這樣反而沒辦法鎖定範圍……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到底該怎麼辦才好？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要送物品，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而是送體驗呢……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "接下來一起去吃晚餐的話……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "以師生關係來說也很奇怪……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "乾脆，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "把我自己當成禮物……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不對，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我到底在想些什麼啊。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是的真是的！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "體驗的話，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是有很適合的嗎♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知道他",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會不會高興？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n呵呵呵♪",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "502270"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "驚喜禮物～☆",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有嚇到你嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今晚呢，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想讓你體驗特別的校外教學，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以就來夢中打擾了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}一路上也學了很多，不停的在成長，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為了讓你考慮將來的事情，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我想讓你看看大家都是怎麼工作的。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "首先是這裡！",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒錯，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大夢想樂園♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是萊拉耶爾告訴我的。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼樣？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有沒有感到很興奮？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼我們就馬上，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一邊遊玩，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一邊觀察工作人員們工作的模樣吧！",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "502280"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和某人一起去遊樂園玩一直都是我的夢想！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在夢中實現了一個夢呢♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊～",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該先從哪裡開始，真令人猶豫！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}有想要去的遊樂設施嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "推薦？",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n難道你",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前來過嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……咦，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你之前在這裡幫忙過！？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來是這樣！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你在這裡經歷了美好的體驗呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就拜託你主導囉。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "超開心的～♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n彷彿是到了阿斯特朗各地進行旅遊，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n全程都讓人心跳加速、充滿期待！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "當然了♪",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跑出熟識的人型看板時候很令人驚訝，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且產生了",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也想去冒險的憧憬♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……話說，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊！？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不起，我真是的，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "完全忘記校外教學的事，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n沉迷在遊樂設施了……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作為老師得認真一點才行！",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "接下來",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就去能夠獲得珍貴體驗的地方吧！",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了保護我們，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "【王宮騎士團】的各位\n每天都在進行訓練，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這我想你也知道。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天就稍微",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "觀察一下訓練的模樣吧♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "練腹肌！",
        "unit_id": 717,
        "voice": "vo_adv_1329003_022"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "練背肌！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "伏地挺身！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "長跑！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n再來練腹肌！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "練背肌！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "深蹲！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "然後是長跑！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "基礎訓練不做好，",
        "unit_id": 711,
        "voice": "vo_adv_1329003_023"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "可就沒辦法守護任何人了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "\n要訓練到即使劍折斷了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "赤手空拳也能壓制對方！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難道你知道這裡的訓練？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……別說知道，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前還幫忙過訓練？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是、",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是這樣嗎！？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我還以為這裡的話就可以教導你未知的事了呢……",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n嗯～",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "參觀工作也不簡單呢……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "唔，",
        "unit_id": 717,
        "voice": "vo_adv_1329003_026"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "那邊的女士……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "\n難道是",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員1",
        "words": "新任的教官！？",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_027"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "教官，",
        "unit_id": 711,
        "voice": "vo_adv_1329003_028"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員2",
        "words": "請指導我們吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦咦──！？",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我不是教官，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是老師啦～！",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總算是逃出來了……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n總覺得比普通的參觀工作還要累人……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我明明想要教導{player}更多",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你不知道的事情，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "卻什麼都沒能教你……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是不是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "失格的老師啊……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你一直都對我很溫柔呢。",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像是我對你有誤解。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "至今為止一直都",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "把你當成一名學生，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但你不知不覺間，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "已經成長為能獨當一面的人了呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明一般來說學生的成長都會令人高興的……",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為什麼呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在喜悅中，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還帶了一點寂寞。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真不可思議。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也許我這個老師，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n比自己想像中的",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還要離不開學生呢……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……這麼一說，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我最近迷上的漫畫裡，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n也有師傅對",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "成長的徒弟感到心動的場景呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像現在的我們一樣──",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不行不行！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n當我沒說！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不可以！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "純潔的師生關係～！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒、",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼事都沒有！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "比起那個，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "最後來體驗天文學家的工作吧♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我有準備天文望遠鏡，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "用這個看看夜空吧！",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼樣？",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看得清楚嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "抬頭時能看到的那些在空中閃耀的星星，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n看起來和平時不一樣對吧♪",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_040"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "完全沉迷於其中了呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "了，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們再更靠近一點去看吧！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡可是夢中世界。",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只要許願想飛起來，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就能飛到任何想去的地方♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們走吧！",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "background",
        "background": "501080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真漂亮……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "空中原來有著這樣的景色啊……♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然因為是夢中世界，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "應該都只是我們的想像……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你說的對。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n更重要的是，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在在眼前的事物呢！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們再前進吧。",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_045"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n抱著對前方景色的期待，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "兩人一起♪",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "500980"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……景色開始不一樣了呢。",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "星星們看起來好小。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在那些光芒的某處，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是我們居住的地方呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和{player}度過的時間實在太有趣，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我似乎不小心就沉迷其中了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的非常開心♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都已經來到這麼遠的地方了，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n也差不多該回去了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到夢醒來為止",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "惡魔老師的校外教學都不算結束喔♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在夢中睡著的話，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_049"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就能夠回到現實世界了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了讓你安然入睡，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師會陪你一起睡的。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來吧，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "躺上雲朵床鋪。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n把星星窗簾拉上的話，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定馬上就能入睡。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一邊回憶",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_051"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天發生的愉快的事情……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "晚安。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_052"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "已經睡著了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n雖然有感受到成長許多，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但睡臉卻還是像小嬰兒一樣♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣的反差好像又讓人感到心動了……♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然已經沒有像那時一樣親吻你的勇氣了，",
        "unit_id": 132912,
        "voice": "vo_adv_1329003_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但為了讓你能夠覺得這是一場好夢，",
        "unit_id": 132912
    },
    {
