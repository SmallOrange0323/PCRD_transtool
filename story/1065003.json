        "voice": "vo_adv_1065003_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一人、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "兩人、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "三人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n哦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在跑過來的一群孩子也算進去的話，就有",
        "unit_id": 106511
