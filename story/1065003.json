    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿嘿，",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個很適合鍛鍊動態視力！",
