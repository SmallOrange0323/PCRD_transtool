    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了打倒在餐廳林立街道上阻礙通行的小混混，\n{player}委託工作給嘉夜。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這拳就是致命一擊！",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊！！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哇啊啊啊！！",
        "unit_id": 811,
        "voice": "vo_adv_1065003_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂你這傢伙！",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別說些通行費之類無聊的話！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n鎮上大家都覺得很困擾呢！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "嗚嗚嗚！",
        "unit_id": 811,
        "voice": "vo_adv_1065003_003"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "對、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "對不起！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n我不會再犯了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "原、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "原諒我……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不要讓我在這條街上再看到你！",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n聽懂的話就把倒地的傢伙帶走，快消失在我眼前！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "好、",
        "unit_id": 811,
        "voice": "vo_adv_1065003_005"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "好的！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "對不起！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嘖，",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該已經沒事了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "連勝記錄又更新了呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你也是。",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近你有好好把打架的工作帶來呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幫了大忙。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼……",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n今天既然沒有公會也沒有幫派的工作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有點閒呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之後要做什麼呢……",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你要打工，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也不能拉你去晃晃……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……對了！",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓我來幫忙吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的打工。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別客氣啦！",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "單方面只讓你一直介紹工作給我，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是很奇怪嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點，",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一直發呆下去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打工可要遲到了哦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快出發吧！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這裡，",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你打工的地方嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n什麼都沒有，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就只有一般的路邊而已……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "你好。",
        "unit_id": 1211,
        "voice": "vo_adv_1065003_014"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "今天也請多指教。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "這個人是……？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳好，",
