    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不會厭煩嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "騙人的吧。",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到底多有耐心啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我已經極限了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你超厲害的啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的嗎……",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "太有耐力了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n超佩服你的……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果要我每天都做這件事情，",
