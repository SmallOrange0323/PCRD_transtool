        "voice": "vo_adv_1065003_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我有沒有算對呀！？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n像這樣連續算好幾個小時，都要搞亂了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不行了不行了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說回來，",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你從剛才開始就默默地數著，",
