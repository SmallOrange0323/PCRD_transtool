    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然今天",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟著你來是正確的。",
