        "voice": "vo_adv_1065003_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是他的朋友。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這份工作",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也能做嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "當然！",
        "unit_id": 1211,
        "voice": "vo_adv_1065003_016"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "而且今天剛好缺人正煩惱著呢，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "\n妳來的正好。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "這個給妳。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個是……？",
        "unit_id": 106511,
        "voice": "vo_adv_1065003_017"
    },
    {
        "type": "dialogue",
        "name": "職員",
        "words": "這個工作",
