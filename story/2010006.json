        "voice": "vo_adv_2010006_031"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n但如果是移動到近處的話",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "也只需要一瞬間的功夫。",
        "unit_id": 107311
