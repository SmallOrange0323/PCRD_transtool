        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "在事前的調查下，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "能夠安全使用空間移動的路徑",
        "unit_id": 107311
    },
