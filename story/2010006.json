[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您的購買。",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是找您的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "50盧幣♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您的惠顧，",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "歡迎再來……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在攤販和主人一起工作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是挺愉快的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要持續這樣到何時呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經完全快要按捺不住了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一想到在這段時間裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐可能正在承受著難以想像的苦痛，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這份過剩的焦躁使得在下坐立難安。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我懂妳的感受，但還是冷靜點唷～",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這種事就是誰先急了誰就輸囉。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "放心吧，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也差不多是暗號快要來的時候了。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你們看！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你們倆快抬頭看，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個就是暗號！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦？　",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天空中",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "閃過了一陣不可思議的光芒？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正如同祭典中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是煙火一樣的東西嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是現在還日正當中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是煙火，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可不會像那樣閃耀了整個天際才對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵。",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那是諾維姆她，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "揮舞她的主力武器『天樓霸斷劍』所轟出來的唷。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那把劍，",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像會",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "放出一種像是能量波一樣的東西出來？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "諾維姆小姐那把和她的體型有著顯著對比的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大劍對吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "曾經見她揮舞過一次，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此仍有些印象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是諾維姆小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在哪裡進行戰鬥……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的意思嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是唷～",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就只是送暗號給我們而已。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這種人潮中可沒辦法和別人戰鬥啦，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會鬧出大事的唷……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "若把無關的一般市民或觀光客給捲入，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "害得人家受傷可就不好了呢。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們【拉比林斯】",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然被當成恐怖份子來看待，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但可不是",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "『管他三七二十一全部宰了吧～』",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "的那種大壞蛋嘛。",
        "unit_id": 104912
    },
    {
        "type": "still",
        "still": "201000601"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位在遠處引起騷動的，",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該就是諾維姆小姐對吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她似乎相當自然的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "扮起了壞蛋呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那孩子，",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不知道為什麼總是自稱是個壞蛋呢……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "似乎，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從前好像真的挺淘氣的樣子？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是現在，",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是刻意去模仿而已。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n畢竟諾維姆她被",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【王宮騎士團】的副團長，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那個叫尾狗刀的人",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "給盯上了嘛。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "若那孩子大鬧起來",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【王宮騎士團】也不可能坐視不管，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n肯定會卯足全力去追她吧。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "簡單來說",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是誘敵作戰呢～",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是諾維姆她自願提議要來當誘餌的喔。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "盡可能的",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓會場中擔任警備的\n【王宮騎士團】等人",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "遠離『王宮』，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就是那孩子的任務唷。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而我們就趁這空檔，",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "悄悄地入侵『王宮』。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣的作戰啊。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡離『王宮』還有一段距離呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果以徒步移動，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不太容易呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "別擔心。",
        "unit_id": 104912,
        "voice": "vo_adv_2010006_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳忘了嗎？　",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們還有一個最可靠的伙伴在呢。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "讓各位久等了。",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔哇？",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊讓人嚇了一跳，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是冷不防地就現身了呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉基拉基先生？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "失禮了。",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_025"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我的存在感似乎稍稍低了些，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "經常受到大家這樣子責備。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "總之。",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_026"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "讓我們加緊腳步吧，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "現在開始就是",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "與時間的戰鬥了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "終究是寡不敵眾。",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_027"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "憑諾維姆一人，能夠吸引【王宮騎士團】\n的注意多久仍是未知數。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我們還是趕緊前往『王宮』吧，",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_028"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我會用空間跳躍來移動大家。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2010006_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉基拉基先生，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實是會使用瞬間移動的呢。",
