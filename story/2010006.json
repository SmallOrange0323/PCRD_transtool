    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用這個不可思議的能力",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "移動到『王宮』就是入侵的計劃嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是的。",
        "unit_id": 107311,
        "voice": "vo_adv_2010006_030"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "儘管敵人應該也有對策……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n不過各國的重要賓客",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "造訪祭典的期間，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n蘭德索爾裡",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不會設置任何過於險惡的結界或陷阱。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "雖說以防萬一還是避免直接闖入『王宮』的內部，",
