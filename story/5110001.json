    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "所以多吃一點啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚哇，",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們從哪裡冒出來的啊！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別擋路！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我等一下──！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可、",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡──！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都是因為路上這些傢伙害我完全跟丟了……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然那些人笑咪咪又輕飄飄的樣子讓人很不舒服，",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是又跟魔物和小混混不一樣，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不能直接打倒他們……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的很麻煩啊！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那邊又有人被襲擊了……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n咦，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "啊叭叭噗──",
        "unit_id": 511,
        "voice": "vo_adv_5110001_054"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我是爺爺唷～",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n嗯～",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "好可愛耶～",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n……第一個孫子出生了好幸福啊～！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好開心……",
        "unit_id": 411,
        "voice": "vo_adv_5110001_055"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這麼棒的求婚，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "就像在做夢一樣……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣下去那傢伙",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會被抓到的……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，{player}！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這邊！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來這邊！",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好了快點！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……走掉了。",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_058"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒事吧？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有被怎麼樣嗎？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……很好，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟平常一樣傻楞楞的樣子就代表沒事！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他們好像是",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "永遠沉浸在幸福的回憶裡……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n之類的",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事情。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "其實啊──",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──好像就是這麼一回事。",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我覺得這肯定是",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我遇到的那個女的幹得好事。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你問為什麼對我無效？",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事我怎麼會知道！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總而言之你先",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "找個地方躲起來！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不然很危險！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "貪吃佩可發生什麼事了嗎！？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……原來如此。",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n聽了團員們說的事情後，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就跟你兩個人一起開始上街調查了啊。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後被城鎮的人們追著跑，",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不知何時",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就走散了啊。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不要太在意！",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_065"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "面對城鎮的人們",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你無法出手反抗對吧？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為你們很溫柔嘛！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "連貪吃佩可都不見了，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n事情變得很不妙啊……！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡！",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_067"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我得拿回胸針才行，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是這個狀況想動也動不了……！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟平安無事的傢伙一起行動也許比較好。",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_068"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現在這種情況",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
