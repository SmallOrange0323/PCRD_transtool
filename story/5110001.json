[
    {
        "type": "background",
        "background": "500035"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從熱鬧的白天進入平靜夜晚的蘭德索爾街頭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未正在一個人遊蕩。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎呀──",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天都黑了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真不像我呢，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然跟普通人一樣在慶典上玩樂……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒關係！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "慶典也才剛開始！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n把壞蛋的實力",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "留到明天再來大展身手！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 1411,
        "voice": "vo_adv_5110001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你幹什麼……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說些莫名其妙的話……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你打算幹嘛，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "住手，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚哇──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼？",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才的聲音……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有人被襲擊了嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然不知道是什麼惡劣的壞蛋，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "選在有我的地方做壞事，算他倒楣！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好──！",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當作是慶典的延續，上吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈──哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大壞蛋諾維姆登場！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n想變成天樓霸斷劍上鏽斑的人，儘管來吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "女的？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有點意外啊……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過也是，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這城鎮裡也是有幾個很扯的女生嘛。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放開那個男的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n選在慶典的日子襲擊別人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是三流壞蛋才會做的事喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……襲擊？",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還以為妳突然冒出來是要說些什麼，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "誤會也該有個限度吧。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──這是救濟喔。",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊？",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "救濟？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n一個勁地抓著他的臉還說是救濟──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太好了……",
        "unit_id": 1411,
        "voice": "vo_adv_5110001_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哈哈，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太好了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太好了──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚喔，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙怎麼一回事……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n明明被襲擊了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼還一臉開心的樣子啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "振作一點！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗚喔──！",
        "unit_id": 1411,
        "voice": "vo_adv_5110001_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "打進沙灘棒球全國大賽啦──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗚嗚……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我現在，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "超級感動的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂喂，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完全無法溝通啊……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那當然。",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為他現在已經是「樂園的居民」，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "身處在幸福當中。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "他已經完全",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看不到現實了。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊、",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳在說什麼……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不要說這麼難懂的話啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊不管了！",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之就先把妳打飛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要怪就怪妳運氣不好，遇到了大壞蛋！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……仔細一看，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳的臉看起來很不幸呢。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什……",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳曾遭逢天大的悲劇，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在緊抓著過去的回憶生活著。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不是嗎？",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳……！",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來說對了呢。",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但我沒有揶揄妳的意思。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "倒不如說，妳是正確的。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "即使心中懷抱夢想和希望，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也很容易被現實否定。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等待我們的是絕望的未來喔。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "既然如此，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "乾脆永遠",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沉浸在幸福的回憶裡，不是比較好嗎？",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事，",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼可能──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "辦得到喔，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我們辦得到。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我們就是為此而來的。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看到剛剛那位男子了吧？",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看起來非常幸福的樣子……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這就是最完美的證據喔。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙……",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟單純腦袋有問題的傢伙不一樣耶？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙抱著強大的信念，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "並擁有能實現這個信念的力量……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也讓妳成為樂園的居民吧。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃！",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "動作好快……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抓到妳了。",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳、",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳要幹嘛……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放開我妳這混帳！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不會讓妳逃走的。",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好了，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一起前往樂園吧。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔",
        "unit_id": 106113,
        "voice": "vo_adv_5110001_036"
    },
    {
        "type": "dialogue",
