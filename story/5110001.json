        "voice": "vo_adv_5110001_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是胸針守護了我嗎……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而且，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼會想起跟尾狗刀的回憶……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛才的，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是這女孩的回憶、",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗎……？　",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳很有趣呢。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我稍微有點感興趣了。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以這個，",
        "unit_id": 9011,
        "voice": "vo_adv_5110001_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "借我一下。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼時候……！？",
        "unit_id": 106116,
        "voice": "vo_adv_5110001_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等等！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是我的胸針！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還給我，妳這混帳──",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "爸爸你看！",
        "unit_id": 111,
        "voice": "vo_adv_5110001_048"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我又拿到100分了喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "啊哈哈，",
        "unit_id": 1511,
        "voice": "vo_adv_5110001_049"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "吃相很棒呢！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n光是這樣看著你吃就感到很幸福呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n我免費招待，",
