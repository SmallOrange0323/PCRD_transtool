        "voice": "vo_adv_5110001_042"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "仔細一看很帥欸……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n長度",
