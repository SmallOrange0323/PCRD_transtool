[
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼回事？",
        "unit_id": 111711,
        "voice": "vo_adv_5029321_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這些馴鹿，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從袋子裡拿出什麼來了！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n和咱們長得一模一樣的人……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠們到底做何打算？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔？",
        "unit_id": 111511,
        "voice": "vo_adv_5029321_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有意思！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這裡竟然同時存在著兩個克莉絲提娜……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來會是一場愉快的盛宴了♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳可別讓我失望啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "　另一個我啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不論外表再怎麼相似，",
        "unit_id": 111611,
        "voice": "vo_adv_5029321_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳都不可能模仿得了我的唷？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要讓妳看看，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真正的偶像才有的光芒！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜之人，有妾身一個人就夠了。",
        "unit_id": 111711,
        "voice": "vo_adv_5029321_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妳見識一下妾身與你之間的差距吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧！",
        "unit_id": 111511,
        "voice": "vo_adv_5029321_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "贗品們！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有本事就打倒我們、",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "進而取代吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真正的克莉絲提娜可不好對付喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人！",
        "unit_id": 111611,
        "voice": "vo_adv_5029321_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳這樣變得好像壞人一樣了！",
        "unit_id": 111611
    }
]