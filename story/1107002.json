        "voice": "vo_adv_1107002_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對我來說簡直是夢想中的夢想……",
        "unit_id": 110711
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "碧",
