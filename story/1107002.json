    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖德蕾莎女學院的學校生活剛開始不久，\n碧來到了{player}的身旁。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「校園種姓制度」，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你知道這個詞彙嗎……？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看來你好像不知道呢。",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那麼，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我來說明一下。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所謂校園種姓制度，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總而言之",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是學校內的排序。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n每間學校都存在著",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n像這樣的階級制度……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在聖德蕾莎女學院內，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也有彼此心照不宣的階級制度，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n據說位於下層的人",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是不可以隨意先跟上層階級的人說話的。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "反過來，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "周圍的人會對",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "上層階級的學生投射羨慕的目光，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是十分醒目的存在……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是，怎麼可能，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我怎麼可能想變成那樣的上層階級，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n簡直是不自量力的小孬孬！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果能成為上層的話，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n結交朋友應該是件簡單的事吧，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自從插班過來後，",
        "unit_id": 110711,
        "voice": "vo_adv_1107002_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "連、",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "連一個",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "朋友都還沒交到……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以就開始在想……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這些事了。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
