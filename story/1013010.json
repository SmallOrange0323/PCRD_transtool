[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七七香得到「黑暗魔導書」後又過了幾天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天{player}被七七香約出來見面。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "之前真是謝謝你啦～",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天就當作是答謝，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想吃什麼都由我請客！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n儘管吃不必客氣！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你是指「黑暗魔導書」嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那東西除了丟不掉，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其他方面沒什麼問題。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那並不是什麼",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真正受詛咒的道具，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以你可以儘管放心。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "根據我的調查，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那似乎是某種目的達成後才能解除……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n類似防護措施的東西。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我猜",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從「黑暗魔導書」衍生出來的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "某種魔法吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當天不該隨口撒謊接下那本書的關係。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大概因為這樣",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才不小心觸發了它內建的效果吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n至於",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "解除的方法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "似乎就只能趕快從它那兒收下魔法。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想說既然有這機會，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不如就積極地想要拿什麼新魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n才會找你來討論這件事情！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然被問到想要什麼魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真叫人傷腦筋呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n再說碰上七七香我這種最強魔法少女，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n能選的候補也多到叫人不知從何挑起。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣就對了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n多謝你了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "事不宜遲，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你覺得我應該",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "收下什麼魔法比較好？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是不是那種",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "浮誇又炫目的魔法比較好？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 好比說",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女鈴鈴噹那種可愛的花俏特效！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或者",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像杏奈美眉那種",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "耽美的世界觀也不錯呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好比說",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有龍跟玫瑰花",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "漫天飛舞之類的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或者乾脆學個",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓我自己變身的魔法……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "例如變成魔法少女這樣？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎唷像這種時候",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你要用力吐嘈說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳明明早就是魔法少女了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是能學個變裝魔法好像也不錯，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不過現在的服裝",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實我就已經很滿意了～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚呃、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒、",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒事呀？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n什什什、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼事都沒有！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛剛我和他的臉",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "湊得超近把我給嚇到了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聊得太起勁完全沒注意到……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他特地來陪我討論正事，我這樣太失禮了，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但我好像是頭一次，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n近距離見到{player}這麼認真的表情……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且仔細想想，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像這樣就我們兩人一起吃飯的狀況，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n豈不就像約會一樣嗎……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對啦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不是這樣的七七香！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這頓飯是答謝！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是答謝所以沒有犯規！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所謂的御宅之道，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "必須時時與異性保持距離！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "御宅談戀愛更是不被允許的事！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我沒事我沒事。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "倒是話說",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "料理再不吃就要涼了，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們趕緊開動吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當當當、",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然不要緊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈哈哈，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這間店",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "連料理也很不錯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以才會這麼期待啦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是吧～",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種事真的很難下決定吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真叫人傷腦筋呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是的真是的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈……",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來還真是瞞不過你呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "關於該得到什麼魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的確是早就有想法了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想你也知道",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香我是個",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有資歷的玩家吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n所以總喜歡照著攻略走，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或者說想法總是效率至上吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "自然而然就會有些念頭呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡而言之！",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "以效率觀點來看，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香我應該弄到手的魔法是……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也就是前往「暮光之都」的魔法～！",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或者與其說是前往，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算能夠知道位置，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就已經是賺到了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若要問行不行，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然是行得通。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一般常見的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "主要都是那種通用性較高的為主流，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n因此這類魔法平常幾乎是看不到的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而這種類似單招絕活，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其他地方派不上用場的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n效果品質也會特別高呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這就是所謂單點突破特化型的浪漫吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好比說，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想要最強魔法！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算許了這種願，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n得到的東西到時還是會",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "端看當事人的實力水準。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法這東西看似方便，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但絕大多數換個場合就派不上用場。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有這招魔法就永遠天下無敵！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種彷彿",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "開外掛般的魔法是不存在的～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也因為這樣，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我認為我",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要求這種針對一件事的強效魔法才是最佳解～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「黑暗收藏家」肯定也是這麼想的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然而",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他最後還是沒弄到想要的魔法。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才會千方百計地想要利用我吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當初只是覺得怎麼能讓他稱心如意呢～",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有部分是這麼想的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但真要說的話，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也許我只是覺得可惜，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "吧……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我指的不是獲得前往「暮光之都」的魔法",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這件事喔？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我指的是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抵達「暮光之都」這件事……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈。",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看你一副一頭霧水的表情。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你想想，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們【暮光流星群】，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n當初是以尋找「暮光之都」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為目標而成立的公會不是嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你至今也幫了我們不少的忙。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我很享受這些日子以來的冒險～",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "以為今後也能永遠這樣繼續下去……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是一旦找到「暮光之都」，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "至今的冒險也就等於抵達終點，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n正式劃下句點～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而說來說去，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我覺得大家一同冒險的過程",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才是最快樂的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "加上你也是其中一員……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是抵達終點，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我怕像這樣和你一起聊天的時光，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n會不會也跟著消失……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我一個在人胡說些什麼啦，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈哈！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那句話",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有特殊含意喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是說以夥伴身分在一起很快樂！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最重要的是，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣子",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是很沒成就感嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然就",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咻的一聲傳送到終點破關了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這又不像地下城那樣破關後能繼續刷第二輪！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在下",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_041"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好歹也是硬派的深度玩家！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n冒險要是少了難度",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那不就失去意義了嗎！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "另外",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最重要的問題是，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是真的輕易找到那裡，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "【暮光流星群】到時就得宣布解散！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……這樣一連串思考下來，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_043"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我心想前往「暮光之都」的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也許並不是我真正想要的魔法吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "何況不說別的，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這本「黑暗魔導書」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是不是真能給我這樣的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也還是個問題就是了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱歉啊～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當初為了那件事找你陪我一起去，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "結果我還這樣煩惱東煩惱西的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "耶嘿嘿，",
        "unit_id": 101311,
        "voice": "vo_adv_1013010_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝謝你。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等我決定好要什麼魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "到時會一併通知你的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
