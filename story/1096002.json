        "name": "妮諾",
        "words": "你們還會再來玩吧！？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　還請",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "保重身體！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "閻魔大人也",
        "unit_id": 109611,
        "voice": "vo_adv_1096002_052"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再會了忍忍是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "隱身是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著在水上跑著的妮諾的背影，\n觀眾們響起了今天最大的歡呼聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是因為妮諾跑的那個池塘水很淺，\n其實她只是看起來像是在水上跑。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "腳",
        "unit_id": 109611,
        "voice": "vo_adv_1096002_053"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都濕透了是也。",
        "unit_id": 109611
    },
