    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了尋找玩偶們而分散行動的{player}等人，\n回到了集合地點的沙灘上。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}、",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "歡迎回來～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔！",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們回來了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們那邊狀況如何？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們這裡沒看到呀～",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊……",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們奪回兩隻，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但看來路途還很漫長。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "天色要變暗了，",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天就在這附近",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "過一晚吧～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我剛才順便",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "把一些柴火之類的東西帶回來了～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想得很周到嘛，香織。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是說，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們怎麼不在那個漁村找地方借住啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是真步的決定～",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為說不定",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "玩偶們隨時會跑回來呀～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……原來如此。",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "海邊露營也滿有夏日的感覺，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "挺好的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主現在人呢？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　沒看到她在啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "她說想去看看大海～",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "抱著亞瑟就",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "往那邊走去了～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n希望她不會感到太沮喪……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}{player}～",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n可以拜託你一件事嗎～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "能請你",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "去鼓勵真步嗎～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "她現在失去重要的東西",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一定很難過～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}一定有辦法",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "平撫她失落的心情～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就像你對我那樣～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不愧是{player}～♪",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "什麼都不用說就知道我想講什麼，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n充滿男子氣概～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好迷人呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼",
        "unit_id": 110511,
        "voice": "vo_adv_5021005_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步的事就交給你了～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們就在這裡做好露營的準備。",
        "unit_id": 110411,
        "voice": "vo_adv_5021005_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n天色馬上就要變暗了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "記得在那之前回來啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你是來叫我回去的嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對不起，",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "居然把您",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "捲入麻煩的事情裡了。",
        "unit_id": 110611
    },
    {
        "type": "still",
        "still": "502100501"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……蘭斯洛特和高文！",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您把它們帶回來了。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實人家",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒有感到沮喪唷。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只是在稍微",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "思考一些事。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織不是說過嗎？",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要是被珍惜的事物，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就會有善良的靈魂寄宿其中。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣是不是表示，",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家給予它們的愛",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是不夠呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "每天和它們說話、",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "照顧它們，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還以為這樣已經注入許多愛了……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這些",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所做的一切",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該不會完全沒傳達給它們吧。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "難道不是嗎？",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "　如果它們體內寄宿著善良的靈魂，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就不會被壞心的惡靈……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "奄美魔物給",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "附身了不是嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家從以前到現在",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "做的這一切",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "全都……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生……？",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_030"
    },
    {
        "type": "still",
        "still": "502100502"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好神奇。",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "直到剛剛都還在想很多事，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感到那麼不安。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被王子先生",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "摸頭後，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n腦中",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "混亂的思緒",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "彷彿受到舒服的微風吹拂。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就連胸口",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "揪心刺痛的那種感覺，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也跟著淡化去了，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "心中充滿溫暖。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您。",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然，",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生是……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "非常重要的",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子大人。",
        "unit_id": 110611
    },
    {
        "type": "background",
        "background": "500711"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "夕陽真是美麗。",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然太陽西沉大海",
        "unit_id": 110611,
        "voice": "vo_adv_5021005_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "令人感傷，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但只要王子先生陪在身邊",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就不會感到寂寞……♪",
        "unit_id": 110611
    },
    {
        "type": "still",
        "still": "502100006"
    },
    {
        "type": "dialogue",
        "name": "布偶們",
        "words": "……"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
