[
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "闖入了不可思議世界中的可可蘿，\n正跟著神秘的人物模索路晶一起散步聊天。"
    },
    {
        "type": "still",
        "still": "201000101"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣說明妳聽得懂嗎……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "現在的妳啊，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是把心靈從原本的肉體中抽離出來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "然後放進其他東西裡的狀態。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而妳原本的肉體，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "則是躺在醫院裡的病床上呼呼大睡唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其他東西？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的意思是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乍看之下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的身體與平時看起來似乎沒有什麼兩樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n倘若真要說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅僅是痣的位置有些許的差異而已？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～。",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果說這是採用生物材料所製成的機器人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你大概也聽不懂吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就像是用精密的方法製作出來的人偶吧，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳現在的這個身體呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "再怎麼說也擷取了所有的數據，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應該會分毫不差地重現才對。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但在實際生活上非屬必要的部分，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n例如像痣這種事可能就很隨便～",
        "unit_id": 106831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "201000102"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個身體",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是人偶……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有什麼真實感呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅有體溫，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而用力一捏也能感到疼痛。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟從神經系統甚至到微血管，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "都幾乎將人體完全重現出來了嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應用義軀幹……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "義肢的手腳、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到義眼的專業技術，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是比擬科幻等級的超高技術產物喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "光是這一個玩意兒，就足以將一間大型企業整年度的預算燒光了，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所以盡量別弄壞它喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "付這筆錢的人不是我，其實也沒差就是了。",
        "unit_id": 106831
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總之，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在就先把在下身體的事",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擱置一旁吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管您如此詳盡地說明，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也仍舊無法理解。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起這件事。",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更讓人疑惑的… …",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是為什麼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會處於這樣的狀態呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": " 我其實是一個",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不怎麼擅長說明的人呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這也是所有天才的通病嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也因為這個緣故，從與{player}相遇以來，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "讓他費了不少苦思啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是說，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也不過就是個嚮導",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "負責來",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "帶妳而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n詳細的事情，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就去問接下來應該會跟妳見上一面的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "父親吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是說長老、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與在下一樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來到『這邊』的世界了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊哈哈。",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_014"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n對對，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老大人。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那人在『七冠』中也是最年長的嘛，",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在『這邊』的綽號也是長老沒錯啦～",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "知道他在『那邊』也一樣被這樣叫的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我笑到差點翻過去了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總而言之。",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正確來說，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳的父親打從一開始",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就沒有到過『那邊』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟也一把年紀了嘛～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他不是那種會放開心胸好好享受遊戲的個性。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而在『那邊』的那個人，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n單純的就只是重現了妳父親人格的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "NPC。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n只是個會按照程式做出行動，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "卻沒有靈魂的人偶唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而妳，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_018"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "則是代替對遊戲沒有興趣的父親……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n為了負起身為『七冠』的責任，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n才會開始玩阿斯特朗傳奇這款遊戲的喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『七冠』……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不好意思，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從方才開始就有聽聞到不少無法理解的單字……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n阿斯特朗傳奇",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這種Game可是超流行的唷，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在『這邊』的世界。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說起來在『那邊』會用Game這個詞嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總之就是一種娛樂、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "遊戲的意思啦。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "話說呢。",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_022"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可可蘿妳呀，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對現況了解的程度又有多少呢？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "關於{player}少年他們，\n現在所生活的『那邊』那個世界中，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被隱藏的真相。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從諾維姆小姐那邊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n曾有聽聞過關於世界之謎",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的說明與推測。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人似乎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直以來都是處於夢境之中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，原本",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該生存的真正的現實，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是存在於別處……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下等人並未知悉此事，",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至將其遺忘，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n反倒將夢境當作現實一路生活至今。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『那邊』為夢境，",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『這邊』則為現實。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而在下現在卻",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不明就裡地來到了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『這邊』……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n穿越到了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個原本的世界。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哦～",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_027"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那孩子是這樣和妳們說明的嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n還以為她是個不太動頭腦又直腸子的孩子呢，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n果然是不經一事，不長一智嘛？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不對，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_028"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說不定她本來就是個聰明的孩子呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也算是做了個挺淺顯易懂的說明。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "簡單來講，",
        "unit_id": 105913,
        "voice": "vo_adv_2010001_029"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那樣的理解大致上沒有什麼錯誤唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳們被從這個原本的現實中抽離，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n甚至忘記了其存在，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被囚禁在夢境之中了喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而那個所謂的夢境……",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在這邊的世界，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "則是被稱做『阿斯特朗傳奇』",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n的一款遊戲呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果照著矛依未她的說法來講，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這就等同於強制讓人作夢的商品唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是既有趣，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "又歡樂、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "一個幸福的夢呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而這麼一個令人著迷的新娛樂，",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也讓不少人沉溺在上頭。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "直到了半年前……",
        "unit_id": 106831,
        "voice": "vo_adv_2010001_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n發生了一件被稱為『米奈娃的禁錮』",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "的異變為止。",
        "unit_id": 106831
    }
]