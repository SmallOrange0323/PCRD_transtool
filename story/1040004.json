[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "午安！",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n今天我們BB團也要好好加油喔……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，我們先做熱身運動吧。",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我覺得交朋友的資本就是體力……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一、",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "二、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "三、四……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……為了交朋友而努力所流出的汗水，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n看起來好像閃閃發亮呢……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "汗水的確在發亮……",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？不、不對，汗水真的在發亮嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而且，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "光線越來越強烈了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀、",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀啊啊啊啊啊啊！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在公園\n看到碧和小鳥說話。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，午安……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個嘛，我是在和小鳥說話。",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這是為了某天交到朋友時先做的練習……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……請你什麼都不要說……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道……我這樣子做……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n很明顯是個怪人。",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是因為奇怪所以才沒有朋友嗎……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……為什麼……？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你不覺得跟小鳥說話的我有點奇怪嗎……？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……蛤？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，呃，",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你不可以對著郵筒的投遞口說話……！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大家在用奇怪的眼光看你呢……！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊，就算不用大叫",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「現充滾開吧」，",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n大家也會走開的……！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我知道了，你比我奇怪……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，個性奇怪和有沒有朋友是兩回事。",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我才是沒有朋友的人。這一點就算是軟弱的我，",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也不會退讓的！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在沒有朋友這一點上我絕不讓步！",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒、沒有朋友到哪種程度？我、我啊！",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有朋友到……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n買了兩台電動遊戲機一個人玩對戰遊戲！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎、怎麼樣啊……！？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、這個……！",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這完全沒有任何策略，只不過是圖案配對遊戲吧……！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣怎麼可能會有趣！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、那樣……！",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不就會知道是誰拿到鬼牌，",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n超級浪費時間的不是嗎……！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我輸了……就連沒有朋友這點，",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也贏不過你……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不愧是BB團的團長……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我已經……失去自信了……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不單是朋友，我什麼都沒有了……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……我還有什麼……？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我有我的生存之道……？",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣的我……",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也能充滿自信地活下去……",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n帶著沒有朋友的寂寞心情",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "繼續生活嗎……！？",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}……我……我，",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n非常地很高興！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能加入BB團真是太好了！",
        "unit_id": 104031
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明天起，BB團也要繼續加油……！",
        "unit_id": 104031,
        "voice": "vo_adv_1040004_028"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此……以前的你，",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像太激進了吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你仇視現充嗎……？",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我覺得那樣有點太過頭了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像現在這樣冷靜的反應比較好呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，收集更多的記憶碎片……",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n去挖掘這個世界的謎底吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1040004_034"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃，這裡是哪裡啊……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈之森……",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n咦，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你也做了同樣的夢嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真是不可思議呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但話說回來，",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你竟然這麼執著於和我競爭誰才是沒朋友的人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n總覺得很有趣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個有趣是好的意思，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請不要生氣喔……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總之，我覺得很有趣、很開心，",
        "unit_id": 104011,
        "voice": "vo_adv_1040004_039"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我覺得和你越來越親近了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也覺得BB團要更努力才行！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從那天之後，\n碧就越來越信任{player}了……"
    }
]