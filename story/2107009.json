[
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和日和分別後的矛依未"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了【王宮騎士團】的據點……"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……尾狗刀他，",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也沒有回【王宮騎士團】呀。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "照這個樣子看來，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}他們應該也不曉得尾狗刀的行蹤吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然如此……",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剩下的還有……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對了！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果是那傢伙，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "或許會知道些什麼！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呼，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今天差不多",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以打烊了吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我該開始做旅行的準備了……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶─────！！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "諾維姆！？",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳怎麼突然來了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了～！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n晶，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳今天在開可麗餅店呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我有一點事想問妳！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔～",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉諾維姆。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在問問題前……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在這邊的時候，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳可以叫我「拉比林斯達」嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不小心就叫太習慣了～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n晶……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比林斯達！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "尾狗刀是嗎……",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉喔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也不知道欸。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……這樣啊～",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真傷腦筋……",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我已經沒有頭緒了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然如此，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就只好在整個蘭德索爾裡到處問人……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我跟妳說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "諾維姆。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我接下來",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要離開蘭德索爾一陣子。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果諾維姆願意聽我的請求，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我可以幫忙蒐集尾狗刀的情報。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "怎麼樣啊？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的嗎！？",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那真是幫了我一個大忙！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳的請求是什麼！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個嘛──",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是我的公主騎士，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那個少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和他的夥伴們遭遇到危險，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我希望妳可以幫助他們。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幫助那些傢伙？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我是無所謂啦……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但妳只有這項請求嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該說，",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶妳不能自己保護他們嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再說那些傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是滿強的嗎，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說保護，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是要從何方神聖的手中保護他們？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我按照順序回答妳。",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n首先",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「敵人」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是名叫【憤怒‧軍團】的公會。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他們盯上的目標",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是我，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而少年他們是受我牽連才會一起被盯上的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是我直接去幫助他們，就本末倒置了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……前陣子",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是因為真那快要被搶走了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我別無他法，才只好出了手……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且我",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "得去辦有點重要的事，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖然我還打算再多請幾個人幫忙他們……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但要是諾維姆願意伸出援手，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我真的會非常感激妳。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好啊！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "交給我吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管對手是誰，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都會好好保護住他們的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為我還有其他要找的東西，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以尾狗刀我只能順帶地找一下，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣也無所謂嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒關係啦沒關係！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟光憑我一個人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺也已經到了極限了～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是晶……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉比林斯達願意幫忙我，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就太感激不盡了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……我說啊，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "諾維姆。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖然妳聽到這種話，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可能會不太開心……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然諾維姆妳想和尾狗刀重逢，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那妳所使用的方法或許是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在繞遠路……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是這麼想的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n什麼意思？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n諾維姆",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳不是把「那一邊」的事",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "記得很清楚嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呃、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然如此……",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳不是應該去尋找回到「那一邊」的方法嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是順利成功，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳就可以在「那一邊」和尾狗刀重逢了呀。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……！",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n嗚、嗚嗚……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我當然……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也是有",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "考慮過……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這些事呀。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟我認為現在的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界是不對的……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "必須要",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "回去「現實」才行。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "回去以後，我就能見到尾狗刀……",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "見到尾狗刀詠斗",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "了吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……畢竟只要我的超能力全部都能使用，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要找到那傢伙也很簡單……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是……",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那我要怎麼做才好！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我問妳，晶！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n該怎麼做，才能夠讓大家一起回到「現實」啊！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……關於這點，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我現在也還",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正在「尋找答案」。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我還說不出",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有什麼絕對的方法，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只不過……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實諾維姆，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳反而比我",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還要接近「答案」……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是這麼想的～♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……咦？",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯♪",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～～～～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該不會是！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "持有天樓霸斷劍嗎！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟這傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "確實是很厲害的武器嘛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此呀〜",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對不對不對。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在的天樓霸斷劍是我做的仿造品吧！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳忘了嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才沒有忘記呢！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……而且……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我跟日和說話的時候，",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有若無其事地問她",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「真正天樓霸斷劍」的去向，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是那傢伙好像也不清楚……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……果然",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "本尊是在「再構築」時",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n消失了吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……有這個可能，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟那時大家都人仰馬翻，一片混戰的慘狀，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n根本沒空管這些──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……要是問米奈娃，\n不曉得能不能得知",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「真正的天樓霸斷劍」的所在地呢？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然說",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不知道米奈娃在哪裡……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不過，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "米奈娃確實存在於",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個世界的某處。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原因是就算現在發生過「再構築」，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n米奈娃是負責經營這個世界的存在，這點仍然沒有改變。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我之所以覺得諾維姆比我還要靠近「答案」，就是因為這點。",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為妳",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在「之前的世界」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是和米奈娃定下了契約的人。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是諾維姆可以和米奈娃取得聯繫，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n事情就會變得",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "非常簡單了說～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "確實",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在「之前的阿斯特朗」裡，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我和尾狗刀",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "受到米奈娃委託，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n做過很多事……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n米奈娃",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都是單方面朝我們搭話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這裡的話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也沒有工具能傳訊息給她……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聯繫她的方法是吧……",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我完全不知道有什麼方法！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……如果不是我，",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而是尾狗刀的話，或許就會想出什麼方法了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為那傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "甚至在米奈娃還在開發途中時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就有接觸過她……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但畢竟尾狗刀現在不在，",
        "unit_id": 106812,
        "voice": "vo_adv_2107009_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只好靠諾維姆",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盡量思考一下辦法了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……唔、",
        "unit_id": 106113,
        "voice": "vo_adv_2107009_059"
    },
    {
