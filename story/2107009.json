        "voice": "vo_adv_2107009_073"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……什麼嘛，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_074"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是你啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這樣對心臟不好，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不要突然冒出來搭話啦～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_075"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "失禮了。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我並沒有打算要嚇你的。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "算了，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_076"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是也沒差──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你找我有事嗎──？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我並不是特別有事要找你，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_077"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只不過是",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "稍微有一點在意。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛才在那邊的廣場大聲喊叫的少女……",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_078"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n原本是妳的搭檔對吧。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我記得──",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "她是園上矛依未小姐，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒錯吧。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "…………",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_079"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "什麼嘛，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_080"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "原來你有看到嗎～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n你這個人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "興趣真是",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "很差勁欸。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_081"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n先別說我了……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣好嗎？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你不去向她搭話嗎？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我為什麼要？",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_082"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "她只是個外人呀～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_083"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對人來說，除了自己以外，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不管是誰都是外人、",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呢。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我就當作你這話是這個意思吧。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過……",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_084"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這還真是",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有點奇妙的狀況呢。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯……？",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_085"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "回想一下「這個世界」的由來，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_086"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n園上矛依未小姐",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是能和七冠相比擬的",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就不同角度來看，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "她應該可說是比七冠還重要的人物。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然而她卻",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_087"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼大搖大擺地走在路上……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這還真是",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "吸引人注意呢。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哦哦，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_088"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對了……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我姑且還是說一下──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……要是敢對她出手，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_089"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就算是你，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也不會輕易放過喔……？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦？",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_090"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你剛才不是說",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "她只不過是外人而已嗎？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_091"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "已經是外人囉～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算你充其量",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_092"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只做到復仇不成反被害而已？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這不試試看，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_093"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就不會知道吧～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_094"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這是愛呢……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "尾狗刀先生。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "…………真是的。",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_095"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n真的是個討人厭的傢伙欸～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你這個人。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "彼此彼此，",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_096"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是吧？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n好了……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我們差不多該出發了。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "畢竟我們",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_097"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還有很多必須做的事呀，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我很期待",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的本事喔。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好啦好啦，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_098"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "知道了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼走吧──",
        "unit_id": 192612,
        "voice": "vo_adv_2107009_099"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這是為了",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "迎接我們的「神」。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "…………",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_100"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……再見了，",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_101"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我會",
        "unit_id": 106211,
        "voice": "vo_adv_2107009_102"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "自己獨自，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
