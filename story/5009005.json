[
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大概唱了一小時後，望他們才稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈啊，",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "突然覺得累了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "辛、辛苦了～",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不介意的話，請喝茶吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝妳～♪",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n天氣一冷，喉嚨就很容易痛呢，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正好想攝取水分真是幫了大忙！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，奇怪？",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "綾音，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳打扮得好可愛呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿，",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可愛吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我想說要是聖誕節過了，這衣服就不能穿了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在育幼院時，就儘量穿著這件吧～！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "剛好有點時間，就去換上了。",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為只有我一個人穿會很怪，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就讓胡桃也一起穿上了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很適合吧～？",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這衣服是鈴莓為了聖誕派對而製作的！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓雖然冒冒失失的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但除了煮飯以外都很厲害喔！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉要是破掉了，",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還會幫我縫好♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊～",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "【慈樂之音】裡也有很會縫紉的夥伴喔，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她叫做紡希。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n老是在縫衣服或是別的東西。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "紡希？　",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個名字，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是不是就是剛才寄東西來育幼院的人呢？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "裡面放著那位叫千歌的人的換洗衣物！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那位叫千歌的人的衣服都又髒又破了呢……",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "剛才胡桃很高興的讓她換上了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個也是聖誕節的衣服吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不愧是紡希，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還真是細心呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作都交給她一個人應付，明明很辛苦，",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一有空閒時間，還能照顧到我們啊？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連我都慌慌張張地，",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n沒辦法用通訊魔法好好說明事情經過……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真厲害啊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算不當偶像，改做經紀人也能有一番成就也說不定。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n小望……姐姐，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好像很開心。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳很珍惜夥伴呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那當然。",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我們是同一個團體啊",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是命運共同體呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是重要的夥伴，也是家人。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大概就像綾音的噗吉一樣吧……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才對妳說了很過分的話，對不起喔，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說它是玩偶什麼的。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒關係。",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳會那樣想也是正常的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我也不是小孩子了，可以了解。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大概，奇怪的人是我才對。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會和玩偶說話的我才是怪人……",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是我可以聽到噗吉的聲音，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是真的喔。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然現在",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "變得無法和噗吉說話了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "究竟是為什麼呢……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這個時間點也不能說完全沒關聯，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是說那也是「記憶的大精靈霧奇」搞的鬼？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到底是何方神聖呢，",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個叫霧奇的？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我不知道……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果千歌精神狀態正常的話應該能說明，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是她現在退化成幼兒了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好，",
        "unit_id": 108511,
        "voice": "vo_adv_5009005_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "接下來輪到千歌了……♪",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯嗯～？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是哪一張呢？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哪一張不是鬼牌呢～？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿，",
        "unit_id": 108511,
        "voice": "vo_adv_5009005_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是哪一張啊？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這張！",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇，",
        "unit_id": 108511,
        "voice": "vo_adv_5009005_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "千歌妳好厲害！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好會玩抽鬼牌，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "漂亮地避開了鬼牌……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "欸嘿嘿♪",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很厲害吧～？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯♪",
        "unit_id": 108511,
        "voice": "vo_adv_5009005_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那接下來，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "用接龍決勝負吧……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "千歌才不會輸呢……",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "欸嘿嘿♪",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個～……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小胡桃對不起，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓妳幫忙照顧千歌。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 108511,
        "voice": "vo_adv_5009005_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要緊的……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我很習慣陪小孩子遊玩，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就像玩扮家家酒一樣很開心喔……♪",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呵呵。",
        "unit_id": 108611,
        "voice": "vo_adv_5009005_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n育幼院除了我們以外還有很多小小孩，",
