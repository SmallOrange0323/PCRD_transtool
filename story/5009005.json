        "type": "dialogue",
        "name": "千歌",
        "words": "讓妳看到那麼丟臉的模樣……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_064"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我要怎麼辦啊？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我竟然喊望媽媽，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像剛那樣子……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那不要緊的……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "害羞什麼的先不管了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳能說明一下事情的來龍去脈嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒辦法不管！　",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_066"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，真是的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我怎麼會做那種事……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "實在是害羞得沒辦法正眼看望了，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從今以後還有什麼臉活下去……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿，",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_067"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像手刀☆",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好痛！？",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_068"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望妳好過分，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也用不著打人吧！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哎呀，抱歉。",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_069"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌雖然優點就是謹慎認真，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不過一沮喪起來老是拖很久就是妳的缺點了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在沒時間拖拖拉拉了，對吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就是啊，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望永遠是對的。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才不是呢。",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_071"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……總之千歌妳恢復正常實在太好了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還不能放心。",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_072"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這只是暫時的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我只是藉由噗吉的力量暫時回復原狀而已。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且這很勉強，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該無法維持太久。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在我還保持正常時，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_073"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "先把事情全部說明清楚……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說來慚愧，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "希望各位能幫我處理這個異狀。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一切都起因於",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_074"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「記憶的大精靈霧奇」……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n它是非常強又偉大，在眾多傳說中留下名號的知名精靈。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "各位知道嗎？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不，",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_075"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "名字是有聽過……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我對精靈不太了解。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊……",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_076"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，說的也是。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然它也是繪本上會有的題材。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總之，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_077"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「記憶的大精靈霧奇」",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就跟他名字一樣，他擁有操控記憶的能力。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以讓人忘卻過去，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_078"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或是植入新的記憶。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我聽說了那個消息後……",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_079"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "實在很不好意思，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我本來是想說\n希望能幫忙取回{player}喪失的記憶，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以去尋找「記憶的大精靈霧奇」。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為我是唱喚士。",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_080"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以和精靈締結契約，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "借用它們的力量。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或許能使喚「記憶的大精靈霧奇」，或是拜託它，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n讓{player}取回記憶之類的。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌……",
        "unit_id": 102913,
        "voice": "vo_adv_5009005_081"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是這樣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總算明白了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就是嘛，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "無論何時千歌都是為了他人盡心盡力的孩子啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "簡直是偶像的模範，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我以千歌為傲。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才沒有，我才沒有那麼了不起……",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_082"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為{player}對我很照顧，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以想要報恩罷了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 108411,
        "voice": "vo_adv_5009005_083"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「記憶的大精靈霧奇」",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n其實比我想的還要危險，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "簡直就像是魔物一樣。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是個無法交涉",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也無法用言語溝通的可怕怪物。",
        "unit_id": 108411
    }
]