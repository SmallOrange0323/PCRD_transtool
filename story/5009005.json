        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "不過老實說連我自己",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "\n也不知道為什麼事情會變成這樣。",
