        "voice": "vo_adv_5009005_060"
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "快讓大家聽一下妳說話啊。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
