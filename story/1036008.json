        "voice": "vo_adv_1036008_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才沒有那回事。你想太多了！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的……還真是位失禮的人呢。竟然說是兄妹……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個人，如果真是人家的哥哥……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果是我的……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哥哥……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗚～～！！！",
