    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "兩人竟然為了準備晚餐而巧遇。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這也難得，那到蔬菜店的路上就一起吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "馬鈴薯、洋蔥、紅蘿蔔……？",
        "unit_id": 103611,
        "voice": "vo_adv_1036008_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "紅、紅蘿蔔……唉……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇呀！這、這道光？和那時候一樣……？",
        "unit_id": 103611,
        "voice": "vo_adv_1036008_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀────！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036008_003"
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}也是來買東西的嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還真巧呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我是被媽媽拜託來買一些晚餐要用的食材。",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天晚餐是吃咖哩喔。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你問明明是煮咖哩，怎麼不買紅蘿蔔嗎？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說、說得也是呢。那是因為，今天紅蘿蔔都賣光了……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……這裡不是還有一大堆？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真、真的耶～竟、竟然沒有注意到呢～",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明就裝沒看到了，竟然還……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！為什麼你連青椒都丟到了人家的籃子裡啊！",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "別鬧了好嗎！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你這人真是……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼，我就先走一步了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}，再會。",
        "unit_id": 103631
    },
    {
        "type": "still",
        "still": "103600801"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊？咦……？奇怪了……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "找、找不到錢包！？在、在哪裡給弄丟了嗎！？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_012"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這位客人，您沒事吧？",
        "unit_id": 1,
        "voice": "vo_adv_1036008_013"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n請別著急，再慢慢找找看。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對、對不起！",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇哇……後面已經排了那麼長……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果沒買成，回家了還會被媽媽給兇一頓……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、不行！不能拜託你這種事情！",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會先把這些東西放回去，然後再回家一趟去拿錢的！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你說那樣就太大費周章了？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可、可是……再怎麼說這也……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、那怎麼可以！沒關係的！",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我自己去找就行了！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇呀！你、你在摸人家的什麼地方呀！！",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果、果然……你是個變態對吧！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n奇怪變態的可疑分子！",
        "unit_id": 103631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？錢包在裙子的口袋裡？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的嗎！？",
        "unit_id": 103631
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的很抱歉。",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多虧了你，真的是幫了大忙。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明就是擔心會搞丟了錢包，所以才放到口袋裡的……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真丟臉……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "話說回來，",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}出來買的，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也是晚餐的食材對吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有肉塊和馬鈴薯、洋蔥、紅蘿蔔……",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是咖哩呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要學別人好嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請容我拒絕。",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果要我做，那麼就會變成去紅蘿蔔的咖哩了唷。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，你會做咖哩嗎？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼想，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都不像是能夠煮得出來的樣子……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但……是呢。",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "若不介意的話，下次有機會，請讓我來做點什麼請你吃吧。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n算是今天的回禮。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像是咖哩之類的。一些太難的料理我可能還做不太出來，",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但如果是簡單一點的……像是餅乾的話我會做。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嘻嘻。",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會做一大堆餅乾的，你可得吃得飽飽的唷。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊……",
        "unit_id": 1231,
        "voice": "vo_adv_1036008_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，請問怎麼了嗎？　",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "抱，抱歉～",
        "unit_id": 1231,
        "voice": "vo_adv_1036008_030"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n光聽你們的對話，還以為是對新婚夫婦呢。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "沒想太多就回頭一看，結果是我搞錯了呢。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "新、新婚夫婦！？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "和{player}是新婚夫婦！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳妳妳、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳說、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳說什……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "也是呢。你們是一對兄妹呢～",
        "unit_id": 1231,
        "voice": "vo_adv_1036008_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "兄妹！？",
        "unit_id": 103631,
        "voice": "vo_adv_1036008_034"
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚～～～",
