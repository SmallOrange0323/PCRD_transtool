    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "冬場の海に、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "しかもこの荒波で泳いだら大変なことになるからね！",
        "unit_id": 106012
