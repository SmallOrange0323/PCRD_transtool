    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "そもそも船の揺れとかあたし、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "苦手だし……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "べ、",
        "unit_id": 106012,
        "voice": "vo_adv_6056303_001"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "べつに今は気持ち悪くなってなんかないわよっ！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "で、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "でも……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "まぁ、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "心配してくれたことには、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "少しだけ感謝しとくわ。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "ちょ……っ！？",
        "unit_id": 106012,
        "voice": "vo_adv_6056303_002"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\nべつに船の上が恐いとかそういうのじゃないし、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "て、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "手なんか握ってもらわなくても平気なんだから！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "いや、",
        "unit_id": 106012,
        "voice": "vo_adv_6056303_003"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "さすがに冗談よね……！？",
