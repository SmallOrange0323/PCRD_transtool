    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "樂園的騷動也已經搞定了，",
        "unit_id": 124911,
        "voice": "vo_adv_5111411_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們的戰鬥也到此為止了。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但這次真的是有驚無險啊。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 124812,
        "voice": "vo_adv_5111411_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的發生了太多事情，",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經累壞了……",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是，",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不能再和大家一起戰鬥，",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可能有點寂寞",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是",
        "unit_id": 124911,
        "voice": "vo_adv_5111411_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能和祈梨或老大以外的人搭檔，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n其實也還不賴。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，妳們幾個！",
        "unit_id": 125011,
        "voice": "vo_adv_5111411_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是在感傷什麼啊！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不要隨便完結這件事啊！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祭典還沒有結束呢，",
        "unit_id": 125011,
        "voice": "vo_adv_5111411_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們之間的情誼",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也會持續下去的！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了邁向未來，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是需要妳們的力量的！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以，",
        "unit_id": 125011,
        "voice": "vo_adv_5111411_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是不會說再見的！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以後也多多關照啦！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未……",
        "unit_id": 124812,
        "voice": "vo_adv_5111411_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "矛依未……",
        "unit_id": 124911,
        "voice": "vo_adv_5111411_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然妳這番話說得很帥氣，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但比起壞蛋，更像正義的夥伴耶？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什、",
        "unit_id": 125011,
        "voice": "vo_adv_5111411_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼！？",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還不是因為妳們扭扭捏捏，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才忍不出脫口而出的！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那還真是抱歉啊。",
        "unit_id": 124911,
        "voice": "vo_adv_5111411_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "矛依未說得對。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感傷的氛圍不適合我們。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我們直到最後一刻",
        "unit_id": 124812,
        "voice": "vo_adv_5111411_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都閃閃發亮吧♪",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是呀！",
        "unit_id": 125011,
        "voice": "vo_adv_5111411_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會繼續在我們守護下來的這座城鎮",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大肆胡鬧的！",
        "unit_id": 125011
    }
]