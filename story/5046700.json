    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "牧場温泉開業に向けて着々と準備を進める"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n【牧場（エリザベスパーク）】のメンバーたちは"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n何やら頭を抱えていた。"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ん～",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_000"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "困ったな。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "どうすっべ。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私が",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_001"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "なんとかがんばれば……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "シオリちゃんには",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_002"
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "チラシを作り足してもらわないといけないでしょ。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "早めに仕事を片づけるから",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "私がやるわ。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "みんな難しそうな顔して",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_003"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "どうしたの？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "何かあった？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "リンリン！　",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_004"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ちょうどいいところに！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "な、",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_005"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なになに？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n面倒なことならいやだよ？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そっか……",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_006"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "やっぱりオラたちでどうにかするしかねぇか。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "そうですね。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_007"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\nリンちゃんは連日チラシ配りで疲れてるでしょうし。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あーもう！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_008"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんなの！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n言ってくれなきゃなんのことか分からないよ！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "一回言ってみなよ！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "そう？　",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_009"
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "あのね、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "倉庫を片づけてたら",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "\nお客さんのお土産にできそうな",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "熟成チーズが見つかったんだけど、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "チーズの匂いに釣られて",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "ねずみが来ちゃってるのよ。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "チーズを食べられないように見張りを立てなきゃいけないんだけど、",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_010"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私たちは",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "いろんな作業で手が離せなくて。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あー",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_011"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "確かに",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしはチラシなくなっちゃったから",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "手が空いてるね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "リンリン、",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_012"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "疲れてると思うけど",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "チーズの見張り",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "やってくんねぇか？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "…………",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_013"
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "疲れてるなら",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_014"
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "無理しなくていいのよ！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "見張りって結構疲れるし！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "そうです。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_015"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私はチラシ作りしかやってないし、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私が見張りを……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんなに気を使ってくれなくても大丈夫だよ。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_016"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしがやるよ、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "チーズの見張り。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ほんとだべか！？",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_017"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "うん。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_018"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "見張りって言っても相手はねずみでしょ？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そのくらいなら平気平気。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "本当に大丈夫？",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_019"
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "\n無理しなくていいんだからね。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "そうだよ。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_020"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\nリンちゃん",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "ずっと歩き回って疲れてるだろうし。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "平気だから！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_021"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そりゃ確かにめんどくさいけど、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n人手が足りないんだから",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "やれることはやるって！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしに任せて",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "みんなは自分の仕事して。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "リンリン、",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_022"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "ほんとうにあんがとな。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "リマ",
        "words": "手が空いたときは私たちも手伝うから！",
        "unit_id": 105211,
        "voice": "vo_adv_5040700_023"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "だから無理しなくて大丈夫だよ。",
        "unit_id": 103811,
        "voice": "vo_adv_5040700_024"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "…………みんな",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_025"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしのことなんだと思ってるのさ。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いやまぁ、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "手伝ってくれる分には助かるけど。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "そんじゃあリンリン。",
        "unit_id": 103311,
        "voice": "vo_adv_5040700_026"
    },
    {
        "type": "dialogue",
        "name": "マヒル",
        "words": "\nチーズのことは任せたべ。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "はいはい。",
        "unit_id": 102611,
        "voice": "vo_adv_5040700_027"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "大船に乗った気で居てよ。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "チーズくらいあたしが守ってみせるから。",
        "unit_id": 102611
    }
]