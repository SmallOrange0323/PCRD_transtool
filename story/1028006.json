[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦、咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那條小巷子裡，應該有間麵包店才對……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "建築物被拆掉了？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難道說是倒店了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "騙人的吧，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n工作結束之後吃炒麵麵包，原本是我最近的樂趣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉……總覺得有些失望。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然早就知道蘭德索爾的治安逐漸惡化，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是連經濟都開始變得不太好了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "皇室到底在做什麼啊，應該再多加努力管理政治吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉唉，不過也沒有辦法……",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟麵包店也只是個人經營的小店。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "地理條件不好，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是不刻意找，也找不到。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟沒有好好地宣傳呢～",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且稍微走一段路，就能到商業街。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原本大概是以附近的居民為主要客源，還能勉強餬口。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過客人都流失到那邊去了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是就算這樣……要是交給我經營，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n至少能讓店家有盈餘。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話雖這麼說～這也只是多管閒事呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我還只是個沒有績效也沒有手腕的年輕小姐……",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就連【咲戀育幼院】的營運狀況，也說不上順利。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "完全沒有照顧他人的餘力和實力。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，到昨天還理所當然存在的店家，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n突然就這樣在某一天消失……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我還是覺得有些寂寞呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，{player}！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是巧呢，你在這種地方做什麼？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你被不認識的人拜託，所以現在在顧攤位？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該說你雞婆呢，還是說你很閒，真是個濫好人呢～？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你要好好地向攤販主人收取和勞動相襯的報酬哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可不能被人隨便使喚……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要不然我替你交涉吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也是呢～剛好肚子有一點餓。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我就點個東西吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個攤販在賣什麼？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n竟然被看起來遲鈍的{player}發現了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來我，比自己想像中的還要失落。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒事的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並不是世界末日，也不是什麼人死掉了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只不過有點沒勁。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是為了那種一到明天就會完全忘掉的小事啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是，可麗餅的攤販呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過比起甜食，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我現在更想要吃炒麵之類的東西。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有製作炒麵的材料，所以做得出來啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就麻煩你了……",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要把炒麵包進可麗餅裡，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就能成為應急的炒麵麵包了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不知道？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n炒麵麵包……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，就像是Ｂ級美食的感覺。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是一種碳水化合物相互疊加，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n營養價值偏頗的平民小吃哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我呢，好像特～別喜歡吃呢……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "意外嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，畢竟我外表看起來就像是千金大小姐一樣吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……以前呢，我家裡其實非常窮。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "過了一段相當悲慘的生活哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有過把炒麵的醬汁用熱水稀釋以後喝掉的經驗。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那時我實在餓得受不了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的耳朵是尖尖的對吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我可是精靈族哦，基本上是居住在森林裡的種族……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在蘭德索爾算是少數派呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以以前，經常被其他孩子嘲弄或欺負。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那時候每個月只有一次，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只有那天我可以在麵包店裡買自己喜歡的麵包呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我猶豫了很久，才選了巧克力螺旋麵包。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在吃巧克力螺旋麵包之前，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就被欺負人的孩子搶走了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我生氣地想搶回來，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n巧克力螺旋麵包卻掉到泥地上……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而在我啜泣的時候，有個不認識的男孩站在我面前。",
        "unit_id": 102811
    },
    {
        "type": "still",
        "still": "102800601"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他買了炒麵麵包，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n然後和我交換了掉到地上的巧克力螺旋麵包。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他說他想吃巧克力螺旋麵包，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是賣完了，所以才和我交換。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他接著拿起滿是泥巴的巧克力螺旋麵包，邊吃邊讚嘆。",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還說謝謝、得救了……他甚至這樣向我道謝呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是個奇怪的男孩呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1028006_034"
    },
    {
