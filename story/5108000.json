[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "平穩的日子日復一日，一年又接近尾聲了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n三名女性走在準備迎接跨年，充滿活力大江戶町。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇～",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n大家看起來都好忙喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該是因為商人都在準備年末和年初的特賣，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而公務人員也忙著預防事故吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看到這種熱鬧的景象，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真的會讓人感覺到一年要結束了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "會讓人坐立難安，覺得自己也該動起來呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不去幫忙好嗎……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不行，美里，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "別想那種事情。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們這次",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來大江戶町是為了──",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──舉辦「大人的尾牙」",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而來的～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這我當然知道♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這趟溫泉旅行",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要持續到跨年，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是奢華的享受呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "深月、",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "帆稀，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n謝謝妳們",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "邀請我。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為什麼會想到要找我呢？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該算緣分吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n美里平常總是會分享治療藥的素材給我。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "精靈之森的植物是很珍貴的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以這幫了我不少忙喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而我的狀況是，",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n平時我們家的成員",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是受傷了都會找深月幫忙～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以美里也算是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "間接地幫助了我喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還真是",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "隔了好幾層的緣分呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "既然如此，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那我就不客氣地接受兩位的好意了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "帆稀，話說回來，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們要去的溫泉旅館在哪裡？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我之前也有來大江戶泡過溫泉，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再走下去，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就要走出城鎮了喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵呵～",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們今天要去的地方呀～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是一家在城鎮邊緣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在大江戶之中",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也屬歷史悠久的溫泉旅館老店喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "聽說年末那邊幾乎都客滿，",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這次有稍微努力一番，才成功預約到房間喔～♪\n………………………………………………………………",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓祈梨努力了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "剛剛",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "最後好像還有說了些什麼……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是喔，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真令人期待。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺會是能悠閒放鬆，最棒的一次跨年……♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真難想像地下社會極負盛名的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「獨眼惡魔」會說出這種話呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，妳不也是一樣。",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n幫派成員的頭目來泡溫泉跨年，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這樣能當家族的榜樣嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呵呵呵呵呵……♪",
        "unit_id": 1,
        "voice": "vo_adv_5108000_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳們感情真好呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "鎮上的人都被妳們嚇到了，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要在城鎮裡笑",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請適可而止喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……不過，",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只有我來享受，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "總覺得有點過意不去。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望哪天可以和孩子們，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有公會的大家一起來。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "然後，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也和他……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯～？",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "美里剛剛",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在想誰呀？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一臉含情脈脈的表情，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真好奇～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎、",
        "unit_id": 101512,
        "voice": "vo_adv_5108000_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我哪有擺出那種表情。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "深月，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "應該沒有吧？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "別擔心，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "帆稀她在捉弄妳而已。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我一直很嚮往，",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "聊這種姐妹淘之間的話題～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我身邊的孩子們，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "各個都血氣方剛～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感覺他們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "比起談情說愛，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "更喜歡以拳交心。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那也沒辦法，",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "誰叫我們的工作是這種性質。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要說有趣的人，也不是說沒有。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "什麼～",
        "unit_id": 106711,
        "voice": "vo_adv_5108000_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好在意好在意～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳說的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是怎麼樣的人啊～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我為什麼一定要告訴妳啊。",
        "unit_id": 105111,
        "voice": "vo_adv_5108000_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而且既然是姐妹淘話題，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
