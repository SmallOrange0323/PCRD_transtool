        "voice": "vo_adv_1095002_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你對空花那樣做的話，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會～！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
