    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了宣傳和服，{player}和空花\n來到了市區。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一、",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一來到市區，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "果然人潮就很多呢……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "擦身而過的人，",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "已經有好幾個",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都盯著空花看了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖說是為了宣傳，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還是讓人很害羞……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可、",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那些盯著空花……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "宛如舔舐般的眼神，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "讓我雖然穿著衣服，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "卻有種連裡面的裡面都被看光光的感覺……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊啊，",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不要……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不要用那種眼神",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "盯著空花看！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花的一切會失控的！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然、",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然後空花……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會在眾目睽睽之下，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n照虐待狂先生的命令做出恬不知恥的行為……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿……",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在這種大馬路上",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你想讓我做什麼下流的事情啊！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？　",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你什麼都沒說嗎？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哎呀呀，",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我失禮了！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一不小心……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就妄想過頭了……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣不行呢。",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n明明是要宣傳和服的，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "說不定反而帶給別人不好的印象了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "既然這樣子，空花就",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在眾人的面前被剝光和服，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n為了讓虐待狂先生把一絲不掛的空花都展示給大家看……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現、",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現在開始禁止妄想嗎！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼可以，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "竟然不讓空花妄想……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你是想要把空花的……",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "身體和心靈，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "全部都奪走嗎！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生的攻勢",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "實在是越來越厲害了……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣下去，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的身體就會變得沒有虐待狂先生就活不下去了！",
