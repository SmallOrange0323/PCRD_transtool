        "voice": "vo_adv_1095002_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不愧是人格異常的瘋子……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n不可以啦，虐待狂先生，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有小孩子在看呢……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻。",
