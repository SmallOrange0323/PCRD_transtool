        "voice": "vo_adv_1095002_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是的！　",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個叫作和服，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這是為了讓",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那邊的虐待狂先生",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "從空花身上脫下來，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這樣那樣實現各式各樣欲望的……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！　",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我不小心又妄想了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……",
        "unit_id": 109511
    },
