    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生讓空花動彈不得後，",
        "unit_id": 109511,
        "voice": "vo_adv_1095002_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n接著會在眾人面前對空花呢喃！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「妳逃不掉了吧？　",
