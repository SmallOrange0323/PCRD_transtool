[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "シグルドよ。",
        "unit_id": 113211,
        "voice": "vo_adv_6044310_000"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "貴様に聞いておきたいことがあるのだが……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "貴様、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ルカやナナカの姿を見て",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "どう思う？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "誤魔化したりせず、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "素直な感想を述べるのだぞ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そ、",
        "unit_id": 113211,
        "voice": "vo_adv_6044310_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そうか……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "た、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "確かに大人だな……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nあの二人はスタイルがいいし、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "シグルドもそう思っていたんだな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "……今からでも牛乳を飲めば、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もう少し大きくなれるのかな……？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ほ、",
        "unit_id": 113211,
        "voice": "vo_adv_6044310_002"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ほう？　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "かわいいだと？　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もう少し説明をしてみるがいい。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "……水着が似合っててかわいい？　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "なるほど、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そういうことか。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nちなみに私の水着は",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "似合ってるか？　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "……そうか、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "合ってるか！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "よし！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "確かに、",
        "unit_id": 113211,
        "voice": "vo_adv_6044310_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "強者の気配を放っているな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "しかし",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私が聞きたいのはそういうことでは……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "まぁ、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "シグルドはそれで",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "いいのかもしれんな。",
        "unit_id": 113211
    }
]