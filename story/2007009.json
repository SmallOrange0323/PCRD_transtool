[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咲戀，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "午餐時間到囉♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不用客氣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "儘量吃吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～！",
        "unit_id": 101711,
        "voice": "vo_adv_2007009_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今天負責料理的人是我啊～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是我故鄉的料理啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "希望能合大家的胃口？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不喜歡這個很苦的東西……",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n霞，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幫我吃。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "竟然沒辦法理解這種美味，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳的口味還真是孩子氣呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嚼嚼……",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這還真是非比尋常的珍餚呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我想若推出在妳居酒屋的菜單上，感覺會頗受好評呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711,
        "voice": "vo_adv_2007009_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果有興趣的話，可以告訴妳食譜唷～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～……",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起又苦或又辣的食物，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我還是喜歡甜一點的呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們【哞哞自衛隊】啊，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真一如往常的熱鬧呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看大家都挺有精神的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也讓人安心多了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好的～",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為我們家的孩子呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不會沉浸在那種沉重黯淡的氣氛中嘛。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n前陣子被【王宮騎士團】襲擊時留下的傷痕都還四處可見。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是卻沒有半個人因為畏懼",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而退出公會呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n公會小屋也如妳所見，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經重建到跟以前一模一樣……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總而言之，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這件事總算告一段落了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就像是奪回了和平一樣♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然公主這麼說呀～，",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但我還是一肚子火就是了呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那些",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "【王宮騎士團】的臭傢伙們，\n竟然如此放肆地就闖進人家的地盤裡隨處踐踏。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而主犯的克莉絲提娜，",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在被扔進牢後現在竟然還下落不明的樣子……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽到這消息真讓人消化不良啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "躁鬱無處宣洩，",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都覺得壓力快要爆炸了呀。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖是這麼說……",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但也不能隨意就去找【王宮騎士團】的人",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n挑釁吵架呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟是經過了無數次的交涉，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n才終於能夠平穩地解決這事兒了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n再不願意也得接受，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算是苦瓜妳也得給人家吞下去呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經受夠了，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看到有誰受了傷，或因此而哭泣了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道了啦。",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才不會這麼不識相又跑去鬧了。安心啦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不如說，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴，妳該好好反省反省呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n再怎麼說這事的起因，也都是因為妳喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n若不是妳擅自做了些不經大腦的決定，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不會演變至這樣的局面。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然不至於要妳得在事前就察覺看破他人的陰謀，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但平時也試著再多用點腦袋瓜看看吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真囉嗦欸。",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我就傻嘛，是負責幹些粗活的啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好意思打斷一下妳們的談話……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為什麼這次的三方會議",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n會在【哞哞自衛隊】的公會小屋舉辦呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去了以往開會使用的公會小屋，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才被突然告知說",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「這次在我們這邊辦唷～」，讓我相當困惑呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過也因此讓妳們招待了午餐而省下餐費，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫了我一個大忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵。",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聽說【王宮騎士團】\n這次會議會缺席。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總覺得～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他們最近好像相當忙碌的樣子呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但如果三方公會代表沒有全員出席，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就沒有開會的意義了吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n直接終止",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這次的會議也好吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是呀。",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還讓",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咲戀千里迢迢地跑了一趟了呀……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至少得請妳",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吃一頓午飯吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "除了前些日子那【哞哞自衛隊】的襲擊事件以外的事，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算只有咱們倆也能談。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想說可以一邊吃午餐，",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一邊談好",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那方面的協議～。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，妳是想說有關",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "『闇影』的事呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以妳們那邊有什麼進展？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "記得沒錯，已經委託霞",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "調查了吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有什麼進展嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔～",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然不想說這些好像會讓我的能力遭質疑的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但現況還是對『闇影』一無所知呦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然而最近，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "具體一點的時間來說是前幾天……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n大量破壞魔法炸裂以來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n『闇影』的目擊情報，突然就減少了許多。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在那之前，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一天少說也會有數次的目擊情報呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而最近這陣子，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n突然間觀測不到『闇影』的出沒了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原因依舊不明，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "絲毫沒有頭緒呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼……",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "若『闇影』就此滅絕，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不再出現的話～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就讓人能暫時放心了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但如果不明白其中原因，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總感覺有點不安呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟時機點來說相當一致，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也許該思考與大量破壞魔法的關聯性呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還無法斷言任何事情喔。",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "實在非常抱歉。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別這麼說。",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因為我相信",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "霞一定會盡全力做到最好的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但孩子們，還是很害怕呢……",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有關『闇影』之事，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還是希望至少能搞清它的來頭就是了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大量破壞魔法所造成的災害，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也已經降至最低了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牧場的重建也相當地順利，",
        "unit_id": 102811,
        "voice": "vo_adv_2007009_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n被擾亂的魔力，似乎也正逐漸恢復常態了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因魔力被擾亂……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而無法使用通訊魔法，所引起的混亂，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也大多處理好了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之雖然可以暫時安心了，",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該說恢復和平了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但可不能大意呢。",
        "unit_id": 101411,
        "voice": "vo_adv_2007009_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "無論何時何地，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n災禍的種子，總是埋藏在那輕薄的一層和平之下呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對～對，",
        "unit_id": 1,
        "voice": "vo_adv_2007009_047"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "和平什麼的不過是幻覺……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就是個在戰爭與戰爭的隙縫之間，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那極短的休止符罷了呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……！？",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這傢伙，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是哪張臉的皮厚到，竟敢出現在我的面前啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你問哪張臉？",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_049"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過就這一張而已喔～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對不起囉真琴，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "聽說這陣子好像發生了很多麻煩事呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "姑且替自己說句話，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_050"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也算是被害者唷～。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "只是被克莉絲提娜，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "當成顆便利的棋子來使用而已。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我在那站好！",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n死兔崽子，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看我怎麼宰了你……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為你這傢伙，",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n讓我受到多少的困擾，你到底有沒有搞清楚啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "乖喔乖喔，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_053"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以才說要妳冷靜點……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n真琴妳呀，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還是笑起來比較可愛喔♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "順帶先說一下。",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_054"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n現在的我，已經成了【王宮騎士團】的一員了喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟姑且還算是出身名門呢，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_055"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就算是除了貴族以外無法擔任的王宮職務一位，也能得到呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "正確來說。",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_056"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n只是順勢代替因逃獄，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n而行蹤不明的克莉絲提娜……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我可是以【王宮騎士團】的",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_057"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n副團長身分被招攬進去的喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若妳膽敢對我刀刃相向的話，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_058"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那也就像是變相地對王宮刀劍相向了唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還請理解這部分，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "再仔細想想妳該有的行為表現唷～♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚咕！？",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n尾狗刀前輩，竟然成了",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "【王宮騎士團】的副團長？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 104311,
        "voice": "vo_adv_2007009_060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你這傢伙！……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這次，又有什麼鬼企圖了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒什麼企圖唷～。",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_061"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我啊，只是想把被奪去的寶物都給拿回來而已。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若是為此，管他是什麼國王大人，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_062"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n還是神明大人的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "全都能利用呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "再補充一點，",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_063"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這次……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我可是代替那不知道在忙什麼的團長小姐，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n來出席這個會議的呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是受不了呢……",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_064"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n別突然擅自改變會議地點好嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不就害的我得到處找了嘛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "唔～嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_065"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然知道【王宮騎士團】的團長，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "純小姐……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是位",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "善良的人物。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但我可不",
        "unit_id": 101011,
        "voice": "vo_adv_2007009_066"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "相信你呦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你可是把咱家的真琴給騙得團團轉了呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是被騙的人太蠢了難不成也要怪我囉～？",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_067"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "若我這麼說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "搞不好真會被殺掉也說不定？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟我",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_068"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "現在也是站在個麻煩人的立場上呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n若可以不要這麼針鋒相對的話我會很開心的啦～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不僅如此。",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_069"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這頓飯，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "能否讓我與妳們同席呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "別這麼不領情嘛～。",
        "unit_id": 106211,
        "voice": "vo_adv_2007009_070"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不管怎麼說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "至少現在沒有要和妳們槓上的打算呢♪",
        "unit_id": 106211
    }
]