[
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「克蕾琪塔小姐！",
        "unit_id": 1,
        "voice": "vo_adv_0000322_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我和【美食殿堂】的大家",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一起去執行護衛任務☆",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這陣子就麻煩妳看家了！」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……尤絲蒂亞娜陛下交代完這些，",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經外出五天。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "絲毫沒有要返回的跡象……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "用通訊魔法的聯絡",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也突然中斷了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊啊啊啊啊啊……！",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這下子，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這下子……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "肯定是陛下出什麼事了吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我已經等不下去了──！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我克蕾琪塔‧凱許，",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "身為陛下忠實的僕人！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n將要前去救助陛下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "況且我徹夜完成的兩週份完美辦公計畫，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也已經交給秘書一號了！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如此這般，",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "隨從一號、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "二號！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們走！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "踏上尋找陛下的旅途吧！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "克、",
        "unit_id": 100511,
        "voice": "vo_adv_0000322_005"
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "克蕾琪塔小姐，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "冷靜、冷靜──",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "\n照公主殿下他們平常的表現，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "我想他們應該沒事。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "\n還有，請不要叫我",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從1號",
        "words": "隨從一號。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "我也不是二號，",
        "unit_id": 105311,
        "voice": "vo_adv_0000322_006"
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "也確實不用擔心公主他們的實力。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "況且，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "克蕾琪塔閣下──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "\n妳說要去救公主，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "隨從2號",
        "words": "但妳知道【美食殿堂】他們人在哪嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那當然，",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我已經從公會管理協會那該死的眼鏡女身上問到情報了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下他們，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是在北方的洞窟失去音訊的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且聽說",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "魔物也群聚在那，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下為何如此莽撞……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此，",
        "unit_id": 105311,
        "voice": "vo_adv_0000322_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然是魔物的巢穴，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n看來我可以表現一番，好對得起我的酬庸。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "交給我來開路吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純有",
        "unit_id": 100511,
        "voice": "vo_adv_0000322_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託過我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我也要履行身為【王宮騎士團】的使命！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳們兩位，",
        "unit_id": 118011,
        "voice": "vo_adv_0000322_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "精神可嘉。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就趕緊前往北方的洞窟吧──！",
        "unit_id": 118011
    }
]