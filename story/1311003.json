        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這次的",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "應該會比較好哦？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_059"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n感覺再煮久一點比較好～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_060"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是讓身體停止成長的藥唷～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "只要完成這個，",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_061"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小卡里莎",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就能永遠都是正太了對吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "果然不行嗎……？",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_062"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "算了～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也是啦……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n如果小騎士反對的話，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那我就不做了～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，涅婭持續嘗試了各種想法。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，沒有一個結果是令她滿意的，全都以失敗收場。"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "對不起～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_063"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "還讓你這樣一直陪著我～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "……不過，",
