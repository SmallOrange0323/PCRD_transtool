        "voice": "vo_adv_1311003_064"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "多虧了像這樣嘗試過各種方法，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我好像能搞懂到底是哪裡不對了～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "……當小卡里莎不再是正太的時候，",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_065"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我根本不知道我會變得怎樣～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n所以才會這麼地",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "焦急吧～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "至今為止，",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_066"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也歷經了無～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "數次與小孩的",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n相遇與別離……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但是從來沒有過，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "讓我這麼執著的情況呢～",
