[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "湛藍的天空與平靜的海洋。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，在充滿活力的沙灘上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻有一張格格不入的陰沉面孔。"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "唉……",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_000"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "好難受……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n你聽我說你聽我說～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是說",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_002"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "對不起啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "因為想給個驚喜，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "所以私底下偷偷做了很多準備～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "又來了啊……",
        "unit_id": 191618,
        "voice": "vo_adv_1311003_003"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳這次又在策劃什麼了。",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "作為調查蘭德索爾的交換條件，",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_004"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我拜託了姊姊當我的贊助者～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "還是被她拒絕了……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "贊助者……？",
        "unit_id": 191618,
        "voice": "vo_adv_1311003_005"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n【憤怒‧軍團】的嗎？",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "以妳來說，",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "還真是正經的提案呢。",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不是～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不是那個～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是小卡里莎遊樂園的贊助者～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啥……",
        "unit_id": 191618,
        "voice": "vo_adv_1311003_007"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳剛剛",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "說什麼……？",
        "unit_id": 191618
    },
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "姊姊～♪",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_008"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我按照約定，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "把調查結果彙整好了～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "辛苦妳了，",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "涅婭呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家瞧瞧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此次報告，",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "似乎過往都要更加詳細呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不錯吧～",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_011"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不錯吧～♪",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那麼，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就拜託囉～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小卡里莎遊樂園的贊助者～♡",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……汝剛剛，",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "說什麼？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n並非是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "贊助【憤怒‧軍團】嗎？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯……？",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_013"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是贊助小卡里莎遊樂園哦？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真是的～",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_014"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "振作一點啦～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n妳沒有在聽我說話嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "因為吉歐‧提格尼亞",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_015"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "有「大夢想樂園」～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "所以吉歐‧格黑納也來做個主題樂園對抗一下。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我之前不是說過了嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……不。",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_016"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此等事宜，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家還是初次聽聞。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是嗎？",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_017"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過算了。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "既然那邊有小卡巴邦，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n那我們的吉祥物",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就只有小卡里莎了吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "如果是吉祥物就不會變老。",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_018"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這樣一來，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小卡里莎就永遠都是正太了。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n簡直就是一舉多得？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "只要去小卡里莎遊樂園，",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_019"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n就能隨時見到小卡里莎，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這種如夢境一般的場所，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真讓人興奮～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "說真的～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這只能贊助了吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "對吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "對吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯，",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_020"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此事即便繼續討論，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n也是徒勞。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "哇～♪",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_021"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n謝謝謝謝，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "謝謝妳──",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……等等。",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_022"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n可別會錯意了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的意思是「不同意」。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "咦……！？",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_023"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "為什麼為什麼～！？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "卡里莎小子，",
        "unit_id": 129711,
        "voice": "vo_adv_1311003_024"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並非來自吉歐‧格黑納。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "故奴家無法贊助",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "小卡里莎遊樂園。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真是的～！",
        "unit_id": 123311,
        "voice": "vo_adv_1311003_025"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n姊姊妳這個大笨蛋～！",
        "unit_id": 123311
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "之前發生了這樣的事呢～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_026"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真讓人受不了～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "…………",
        "unit_id": 191618,
        "voice": "vo_adv_1311003_027"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "因為妳的關係，",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "讓我腦袋快變得不正常了……",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我去吹一下風……",
        "unit_id": 191618
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那是因為～",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_028"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "為什麼呢？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯嗯嗯……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "…………因為正太總有一天會結束？",
        "unit_id": 131111,
        "voice": "vo_adv_1311003_029"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "之類的？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但這麼一說，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
