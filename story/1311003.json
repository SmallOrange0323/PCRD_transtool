    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "能來阻止不斷掙扎的自己",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n也說不定？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "謝謝你～",
