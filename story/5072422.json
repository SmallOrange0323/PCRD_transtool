[
    {
        "type": "background",
        "background": "501364"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們辦到了，",
        "unit_id": 117211,
        "voice": "vo_adv_5072422_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072422_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這是一場很精采的戰鬥……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是演唱會。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說真的，",
        "unit_id": 117411,
        "voice": "vo_adv_5072422_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們的演唱會，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真不是每一場都能一帆風順呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 117211,
        "voice": "vo_adv_5072422_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我倒覺得非常耀眼奪目喔。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們三人都是。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話雖如此，",
        "unit_id": 117211,
        "voice": "vo_adv_5072422_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在還不能鬆懈吧？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為演唱會還沒有結束。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們看，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "觀眾們都還在等著我們呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛已經又唱又跳地戰鬥過一番了，",
        "unit_id": 117411,
        "voice": "vo_adv_5072422_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妳怎麼還是那麼有精神啊～！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只能說",
        "unit_id": 117311,
        "voice": "vo_adv_5072422_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為她是望嘛。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實我也覺得還唱不過癮呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……連千歌也精神百倍啊。",
        "unit_id": 117411,
        "voice": "vo_adv_5072422_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好啊，那就繼續吧，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也還可以上場！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就走囉，",
        "unit_id": 117211,
        "voice": "vo_adv_5072422_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就由我們去呈現出最棒的舞台吧♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "喔──♪",
        "unit_id": 1,
        "voice": "vo_adv_5072422_009"
    }
]