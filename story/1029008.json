[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}跟望來喝茶。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽說這裡的蛋糕因為好吃而評價很高。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "蛋糕怎麼還不快來呢～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，這是什麼光……！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊啊啊啊！！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，{player}，你來啦！",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很準時呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過很抱歉。",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你可以再等我一下下嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還在拍照。",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這個照片要刊登在下個月發售的時尚雜誌上。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用那麼驚訝吧～\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你忘了我是偶像嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，我希望你能自在地和我相處，",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以忘記了也沒關係啦……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總之",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！\n就是因為那樣，你再等我一下下喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "小望，妳表現的很好喔。",
        "unit_id": 1131,
        "voice": "vo_adv_1029008_008"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n辛苦妳了。",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是的，非常感謝您",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "102900801"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，抱歉讓你等這麼久。\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拍攝時間稍微延長了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天謝謝你能來。\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想跟你說說話，就算只有一下子也沒關係。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你看，因為最近工作太忙了，我們無法見面不是嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我剛好要來椿丘拍照，\n想說找你的話，你會不會來呢。",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你進到店裡來的時候，我真的很開心喔！",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多虧了你，我在最後好像展現出了完美的表情呢！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，你說這個蛋糕？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是拍攝用的蛋糕。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n拍攝也結束了，他們說可以吃掉喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "蛋糕，蛋糕～♪",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，說到蛋糕，就會想到生日蛋糕對吧？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、我沒有別的意思喔……",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你的生日是什麼時候？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……那個，是幾月幾號……？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔，在那天啊……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那天我已經安排了工作。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！是真的嗎？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是我早點問你就好了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣就不能幫你慶生了呢……",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好！\n那麼今天就當作補償，",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我來幫你慶生！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把這個蛋糕當作生日蛋糕，",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們一起吃吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我現在把它切開喔～\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……哇！怎、怎麼辦！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n水果和奶油都塌了！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚……要漂亮地切開還真難……",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n蛋糕都要糊成一團了。",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！？\n怎、怎麼了嗎……？\n你怎麼突然握住我的手……！？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你說要幫我切嗎？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那樣啊……那一起切吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "切得真好！\n漂亮地切下去了。",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，完整地切開了！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "生日快樂！\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來張開嘴♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，你在害羞什麼？",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n明明平常都無動於衷，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你是不是稍微對我心動了呢～？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了對了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n說到蛋糕，除了生日蛋糕外，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還有結婚蛋糕對吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩人一起切開大大的蛋糕……\n我很憧憬那樣的場景呢。",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被你這麼一說……\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，我們一起切了蛋糕呢……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……討、討厭啦！不要說些奇怪的話！",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們還只是學生……那個……",
        "unit_id": 102931,
        "voice": "vo_adv_1029008_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n結、結婚什麼的……那種事還太早了！",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也想跟望一起吃蛋糕呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不是在生日當天，",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但那位名人能替你慶生，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真是件了不起的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你真的是很幸運呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你要知福惜福喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是說你應該更加珍惜\n能和望在一起的時間。",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果對她的態度都那麼普通，\n說不定會耗盡她對你的好感喔？",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要好好地留意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼這次就先聊到這裡，",
        "unit_id": 190011,
        "voice": "vo_adv_1029008_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰～掰♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我睡著了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是因為在等蛋糕啊？\n所以才做了和你在咖啡廳的夢……",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？我幫你慶生？",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你為什麼會知道那種事？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔，我們做了同一個夢啊。",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n之前也發生過這樣的事吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "服務生",
        "words": "客人，讓您久等了。",
        "unit_id": 411,
        "voice": "vo_adv_1029008_045"
    },
    {
        "type": "dialogue",
        "name": "服務生",
        "words": "\n這是您的蛋糕套餐。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，這個……跟夢裡出現的蛋糕一模一樣。",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯、嗯……對喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們還一起切了蛋糕，那個――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，不要回想起那種事啦！",
        "unit_id": 102911,
        "voice": "vo_adv_1029008_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為太害羞了，你趕快忘掉！！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在享用蛋糕的這段期間，\n望一直呈現滿臉通紅的樣子。"
    }
]