[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ほらチエルって",
        "unit_id": 110911,
        "voice": "vo_adv_6023209_000"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "可愛いアイドルちゃんすこすこじゃないですかぁ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nもう最近はプロデューサー目線の妄想ごっこが",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "捗るんですよねぇ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "先輩がうちのギルドをデビューさせるとしたら",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "センターは誰にします？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "でしょうね。",
        "unit_id": 110911,
        "voice": "vo_adv_6023209_001"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ええまあ１０人に聞いたら９人はそう答えますよね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そっかー、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "先輩は残り１人の感性持ちだと思ったんだけどなぁ……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ま、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "べつに推すのは自由ですよ？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ガチ恋だけ勘弁してもらえれば。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "愛想悪い系センターか……",
        "unit_id": 110911,
        "voice": "vo_adv_6023209_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "世界観持ってる風でわりと良きかも。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nあの人運動神経いいから、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "パフォーマンスはキレキレだろうし。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "問題は当人の意思だけど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そこはまあ札束で引っぱたきましょう。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "それな。",
        "unit_id": 110911,
        "voice": "vo_adv_6023209_003"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ミニマムっ娘を軸にするパティーン。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あると思います。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "チエルとクロエ先輩が身長同じぐらいだから、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "並びが綺麗ですよね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "問題はユニ先輩の体力面か……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あの子、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ダンスとか出来ます？",
        "unit_id": 110911
    }
]