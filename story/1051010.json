[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拉提治療事件之後又過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深月前往山中採集藥草，同時腦中不斷思索著關於結婚的事。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……唉。",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我怎麼",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼反常啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n明明都過了好幾天了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我竟然還在煩惱結婚的事……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "腦海中就是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不由自主地會想起他。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "上次",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為意外而被他撫摸身體那件事太過衝擊了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n以致於我前所未有地",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "連在夜裡都會想起來。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可能沒有心理準備也是原因之一……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來我在不知不覺中迷上他了，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且陷得比我自己以為的還要深。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n他是個單純善良、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對誰都能毫不猶豫伸出援手",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "的孩子。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟為了研究可以不擇手段的我比起來，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "價值觀簡直天差地遠。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "正因如此我才會欣賞他，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也明白，我們終究是要分道揚鑣的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我所選擇的道路，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在他看來肯定是邪門歪道。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他一定會",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "找到一個配得上他的對象。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n年齡相仿、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "職業正當、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對任何人都體貼友善……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但願他和她",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "能夠幸福快樂。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結論出來了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今後我就當個好朋友吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這樣才是一個大人應有的成熟態度，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是說了什麼不該說的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "破壞我們一直以來的關係就糟糕了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼……",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你怎麼{player}會在這裡！？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "破壞是指、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是指聽診器！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我今早",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "睡醒時糊里糊塗就把它踩壞了！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "別露出那種",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "比平時還要覺得可疑的眼神。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "的確，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "把聽診器丟在地上就去睡覺的醫生是挺糟糕的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總之你就先別深究了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我再問一次，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你怎麼會在這裡？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……原來如此，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你接了幫人",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "採集藥草的打工啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n然後你想起我之前教你的事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "於是就來這裡採藥草了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還記得我所教的事固然令人欣慰，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但怎麼偏偏在這個尷尬的時間點遇上他呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我剛才已經決定要維持朋友關係了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "刻意迴避的話也挺奇怪的吧？　",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然這樣的話，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不如我們一起採藥草吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們分工合作去採集彼此需要的藥草，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "肯定會更有效率。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "像這樣一起採集藥草，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如今也已經習以為常了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "剛認識的時候",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你還什麼都不懂，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好在你就像一塊海綿一樣，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "迅速吸收了我所教你的事，讓我輕鬆不少。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那你覺得呢？",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n跟我共事",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開心嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太好了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖說我都有支付報酬，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但那也只是基本道義。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n沒有讓你覺得痛苦我就放心了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我偶爾",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "會提出一些不合理的要求對吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是真的覺得很難受，你要跟我說喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我也可以換成其他人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這樣啊，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你一直都對自己",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒有記憶這件事耿耿於懷對吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果與我共事",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真有讓你學到一些知識的話，那實在太好了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是你有心學習醫學或藥學方面的知識，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可以教你喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n培育未來的優秀老……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不對，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是說培育科學人才我也很開心。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你想想，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說不定我會增添一名得力助手對不對？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "幹嘛，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你怎麼一臉不可思議的表情？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我說了什麼奇怪的話嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "覺得我好像比平時更溫柔？",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而且說話無精打采，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "表情也悶悶不樂？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你一定要說得",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼毫不留情嗎……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結果",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一起採藥果然是失策。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明腦中已經得出結論了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但實際面對面時",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是會覺得很沮喪……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可我",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "又不能把我的煩惱對他開誠布公。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "拉提的案子雖然解決了，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我手頭上的工作還是一樣多。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可能因此覺得有點疲倦吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你要現在陪我一起回去？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再怎麼說這也擔心過頭了吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我又沒有過勞到隨時可能會昏倒的程度。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊……",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我現在",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是一副快要昏倒的疲態嗎。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看你表情這麼嚴肅，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應該不是在開玩笑的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來我好像",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "暈船暈得比自己以為的還要嚴重……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在這種狀態下採藥",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也只是事倍功半而已。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我也不想讓他為我操心。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那好吧，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天就先到此為止。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你接的工作沒問題嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n要是送我回家再回來，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可就得在夜晚的森林裡採藥囉？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……期限還早嗎，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聽你這麼說我就放心了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "勞你護送一趟了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一起回去吧。",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很抱歉",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天妨礙到你工作了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我平時總是頭頭是道地對患者說教，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n想不到自己卻拖累了你，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我得好好反省。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說我平時都在幫助他人，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n至少在身體不適的時候",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓他人回報一下……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想不到你是這樣看待我的啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我之所以幫助患者，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說穿了其實都是為了我自己喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為做研究需要資金和實驗品，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n而密醫這種可以一舉兩得的工作正合我意，僅此而已。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我跟你不一樣。",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我並不是出於體貼而幫助人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒什麼值得回報的吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦……",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你語氣突然這麼嚴肅，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嚇我一跳。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且你還拿藥草給我",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是什麼意思？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種藥草既不是我要找的，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也不是你要找的吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我記得這是具有恢復疲勞效果的藥草……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "莫非",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是要給我的？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "謝謝。",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n之前在合作時",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我有教過你可以在這座森林找到它對吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你這孩子",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "記性還真好。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我記得那次採完藥草後，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我就要你充當我的實驗品了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當時我是打算製作一種",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "適合疲憊的人服用的營養劑對吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為我接到一件",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "睡再多都無法消除疲勞的案子。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以你認為",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "動機並不重要。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n重要的是這工作能幫助到人，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而你也覺得能幫上忙很開心……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這樣啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真沒想到你竟然對我有這麼高的評價。",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我老是要你當實驗品，看你好像很抗拒的樣子。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說你是討厭服用來路不明的可疑藥物？",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "關於這點呢，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你想想，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你對於知識的好奇心也因此被滿足了不是嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……看你的表情，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "似乎是我一廂情願了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "抱歉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "然後，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_038"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……當你和我一起",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為了患者而努力進行研究時，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我感覺得出",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也過得很充實。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟你真的是個",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "時時刻刻都在為他人著想的人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我要跟你說聲謝謝。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "坦白說，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我最近一直在煩惱一件事。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n聽了你剛才說的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我現在豁然開朗了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……啊啊，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼這藥草我就收下了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一來這是你的一番好意，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "二來也是因為它真的能消除疲勞。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那我們加緊腳步吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太陽就快下山了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "得在入夜前離開森林才行。",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "501582"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼，",
        "unit_id": 105111,
        "voice": "vo_adv_1051010_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "本來只是純粹上山採藥一趟，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n卻莫名把壓力一口氣都釋放掉了。",
        "unit_id": 105111
    },
    {
