[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哼哼哼～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "散步散步～真開心呢～……♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "心情超清爽～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一直待在擁擠的城鎮裡頭，讓人感覺超級悶呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "偶爾也想要到大自然裡頭，悠閒地散個步呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且呢，這姑且也算是【哞哞自衛隊】的工作吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我可是在巡邏呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n【哞哞自衛隊】的工作就是守護城鎮裡的治安吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "畢竟這座森林很靠近鎮上呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最好還是要維持森林裡的和平呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "搞不好還有鎮上的人迷路跑到森林裡呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要將以城鎮為中心的周圍地區，",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n甚至更進一步讓全世界都維持和平就可以了呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀～那棵樹上好像長了像苦瓜的東西呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那個，應該是苦瓜吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼會從樹枝上長出來呢，是另一種植物嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在城鎮裡很久都沒有看過苦瓜，讓我很想要吃吃看呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得好懷念故鄉的味道呢～超級想要把它摘回家呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來。那東西搞不好不是苦瓜呢，但是就算這樣！",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要在調味方面下點功夫，應該就能弄出類似的料理吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過呀，",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個像苦瓜的東西，位置還真是有點高呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然我蠻擅長爬樹的，那也不是到不了的高度呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是兩手都拿著那個像苦瓜的東西的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要爬上樹爬下樹都相當困難呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我本來就只是想出來散散步而已～",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以也沒有攜帶裝東西用的袋子呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是每摘一顆",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就要回到地面",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一次，\n來回好多趟感覺也挺麻煩的呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但要是我把那些像苦瓜的東西摘下來……",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n直接往地面丟的話，感覺也會出問題吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難得的食材搞不好會直接泡湯呢～唔……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "算了～反正我的時間這麼多！",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比起在那邊東思西想，不如直接付諸行動啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n見機行事總是會有辦法的呀～船到橋頭自然直啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿咻、嘿咻……♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～高的地方景色真是不錯呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n呀齁～☆",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀，太過開心不小心直接爬到最高點了呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個像苦瓜的東西長在比較低的地方呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n得往下爬才行的呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n欸？好像有人朝這邊走過來呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喂～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那邊的人，嗨──呵！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "「嗨呵」是在跟你打招呼呦～這是我故鄉的方言喔～",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是這地區的人都不懂，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真是讓我有點寂寞呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n如你所見，我正在爬樹呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要不要也一起來爬樹呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你不爬嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n爬樹超～好玩的呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且一點也不難呦～我可以教你爬樹的訣竅呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，我得自我介紹才行嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對了對了，這是這個國家的規矩呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要先報上自己的名字和公會名稱呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我老是忘了這一點而被真琴罵呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "再跟你打一次招呼，嗨──呵！",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我的名字叫做香織啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我隸屬於【哞哞自衛隊】這個公會～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然說是屬於這公會，不過其實我沒其他地方去呢……",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我來到這個國家的時候，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n【動物苑】這個獸人互助組織介紹我去【哞哞自衛隊】～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他們覺得我大概可以在那裡活用我的特技。",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以就叫我加入了【動物苑】旗下的公會，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n成為了【哞哞自衛隊】的夥伴呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "別看我這樣子，我可是相當強的呢，",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才會要我加入負責維持治安的組織吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈。",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的名字叫做香織，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n公會的名字則叫哞哞自衛隊，真是不好記呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀～你的名字叫什麼呀？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，{player}是嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "請多指教呢～俗話說四海之內皆兄弟呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，請多指教～",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n啊哈哈，這個國家的人總是這麼優雅呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？你不是這個國家的人嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那你的立場和我一樣～我們是同伴呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "能夠在這裡相遇也是緣分，我們來當好朋友吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒問題的呀～我有穿類似安全褲的東西呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的衣服上頭有些輕～飄飄的裝飾，有點礙手礙腳的呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要是我在爬樹前就脫光光就好了～啊哈哈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總之呀！你現在有空嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_033"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你要是沒有其他事情做的話，可以來幫我一下嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我等等會把像苦瓜的東西丟下去，希望你幫我接住呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "本來好像要花上些功夫才能採收這些東西，",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有你剛好路過真是太幸運了～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，人間處處有溫情呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "OK嗎？那我要把這些像苦瓜的東西丟下去囉～",
        "unit_id": 101711,
        "voice": "vo_adv_1017001_035"
    },
    {
