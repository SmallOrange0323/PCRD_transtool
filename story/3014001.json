    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里、茜里與忍這三位魔族少女，\n一同來到了某個洞窟的深處。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "依里、茜里。",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n占卜出來的地方就是這裡。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "原、原來被封印在這裡……",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太古時率領魔族企圖征服世界的",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n『傳說的吸血鬼』！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚哇～",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里緊張得心臟怦怦跳～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼我要解開封印了。",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………嘿",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯、",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是誰～？什麼事啊～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子好～想～睡～喔～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……這孩子是『傳說的吸血鬼』？",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "『吸血鬼』～？",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子是幽靈唷～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……真不好意思。",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來我們搞錯了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "忍忍忍、忍……這已經是搞錯第幾次了……",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "搞錯人？因為這樣把宮子叫醒？",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好過分～！難得宮子悠閒地在睡覺～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "幽靈……還是第一次看到……但好像跟想像中不一樣。",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "完全不恐怖……還很吵……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好像還有點麻煩……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妨礙宮子睡覺可是罪孽深重的！",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n噗噗噗噗～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在是「因為不小心醒了，可是還有點想睡，",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "心想『來睡個回籠覺～♪』的時候，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "卻越來越清醒……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在宮子告訴自己",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "『不能清醒～』『再睡下去～』的時候，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "卻漸漸地越來越清醒，完全睡不著」的狀態！　",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子的憤怒，妳們打算如何賠償啊！？",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "宮子真抱歉……",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里用自己的身體來補償……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸……一起睡就可以嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那樣才不是賠償！",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這只能靠請宮子吃布丁來解決了～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "布、布丁？",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是個怪胎幽靈……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，忍，麻煩請她吃布丁。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不。我只是受妳們雇用而已。",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該還是由兩位來請才是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不管是誰都可以啦！不對，是每個人都要請宮子吃！",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "3個人所以總共3個布丁～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "話說回來，到底把宮子搞錯當成誰了～？",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸。",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "很久很久以前，企圖征服世界而被封印的『傳說的吸血鬼』。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在遙遠的太古，",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "率領著魔族，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n和人類、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "精靈族",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "以及獸人這3個種族作戰，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是魔族之王。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然在與眾神的最終戰爭『吠陀經』中落敗，",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但據說至今身體仍封印在某個地方，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n等候再次甦醒的時刻到來……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是住在蘭德索爾的人們……",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n特別在魔族當中非常有名的傳說喔。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "宮子也是魔族的話，應該有聽過吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "『傳說的吸血鬼』？",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_025"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子不大記得死前的事情了～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真的存在著那樣的傢伙嗎～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯、嗯～可能不存在……畢竟只是傳說而已……",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一定存在～！絕對！",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸，她是茜里。",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、我、我是依里。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我、我們是雙胞胎。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "其實是茜里說要找到吸血鬼的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸嘿嘿～『傳說的吸血鬼』呀，",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可以用魔力做到很多事情呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "然後茜里啊，有『祕密的願望』",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n想拜託吸血鬼幫忙實現。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯！",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里想成為世界第一可愛！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那不是祕密嗎！？",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊！不小心說出來了～",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里都沒有跟任何人說過耶～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好丟臉～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原來是為了這種理由啊……",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "（我、我也有『祕密的願望』",
        "unit_id": 102211,
        "voice": "vo_adv_3014001_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n想拜託吸血鬼幫忙實現……）",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，據說一般吸血鬼具有讓人傾倒……",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n『魅惑』的能力。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說不定可以讓茜里變美呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真的嗎～！？",
        "unit_id": 100611,
        "voice": "vo_adv_3014001_037"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸嘿嘿～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里要拼命找到！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哼～",
        "unit_id": 100711,
        "voice": "vo_adv_3014001_038"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那個吸血鬼",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n可以讓宮子死而復生嗎～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個嘛，一般來說吸血鬼的能力中，",
        "unit_id": 103111,
        "voice": "vo_adv_3014001_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也包含『死者復活』，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以我覺得有可能辦到。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
