[
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_000"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "真的來了……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "沒有啦，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊就",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "前幾天",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你不是有提到這裡嗎？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n說是這一攤的可麗餅吃起來超普通。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "所以",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我就想說",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你今天搞不好會來──",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "別、",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "別亂想喔？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "這絕對不是",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "那種跟蹤狂的行為喔！",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "咦？",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_001"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "好的……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "謝",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "謝……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "對喔，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "今天是28號嘛，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "是優妮博士的生日。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "嗯，",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_002"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "這麼說來",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "倒也是啦。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n畢竟多數人在阿斯特朗裡的角色",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "都是直接套用本名，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n就連生日",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "也設定成跟本人一樣嘛。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，哪有，",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_003"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "才不是好嗎？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我可絕對沒有",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "刻意",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "在賣弄迷糊人設喔？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "又不是",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "想讓你留下",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "「原來那個人還有少根筋的一面啊～」之類的印象──",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "──抱歉，",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_004"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "既然你都來祝賀了，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我就跟你說一聲好了。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n你要當今天是我生日也行啦，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "但事實上",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "不是今天",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "就是了……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "站著說話可以嗎？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "還是要坐著？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "坐著好了，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "附近找個地方。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "嚴格來說，我──",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_005"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我是說現在這邊",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "這個姓真行寺的我。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我在戶籍上",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "登記的出生日",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "不是28號，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "而是29號喔。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "沒錯，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "２月29號……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "簡單來說就是所謂的",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "「閏日」",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "順帶一提，",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_006"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "據說",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "學齡前的我曾經表示",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n「那我不就四年才能收到一次禮物嗎！」，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "時不時",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "就會在家裡大哭大鬧。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n當然，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我本人毫無印象，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "認為那高機率",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "是後世捏造之言。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "畢竟哪可能",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_007"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "四年才過一次生日啊。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "通常都會",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "選在前一天或隔天慶祝──",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "應該隔天的比例比較高，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "總之平年就是",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "把那個區間視為生日，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "歲數也照常在增長。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "咦？",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_008"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "怎麼會扯到這裡來了……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "在解釋",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我的生日是吧？",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "對，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "雖然不是今天，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "但要當成今天也沒問題。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n總之我想說的是，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "感謝",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "你的生日祝福──",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "嘿嘿。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "真的嗎？",
        "unit_id": 111031,
        "voice": "vo_adv_4010251_009"
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "好讚喔，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "竟然還有兩天生日這種事。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我賺翻了，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "真開心。",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "既然如此，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我明天",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "也會在這裡等你──",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "\n",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊，",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "不對！",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "我今天並沒有在等你啦！",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "啊哈哈……",
        "unit_id": 111031
    },
    {
        "type": "dialogue",
        "name": "由仁",
        "words": "差點露餡……",
        "unit_id": 111031
    }
]