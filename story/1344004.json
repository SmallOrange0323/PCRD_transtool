        "type": "dialogue",
        "name": "千歌",
        "words": "你的手……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_066"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的好溫暖……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n會讓我平靜下來……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是現在……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "新的精靈一定會……！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_068"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是精靈。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是一隻……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n有這麼多……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n為什麼？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "呵",
        "unit_id": 611,
        "voice": "vo_adv_1344004_069"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "呵",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "呵……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n原來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "原來。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "如此。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "老、",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "老婆婆……！？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n妳從什麼時候開始在那裡的？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "因為妳的不安消除了，",
        "unit_id": 611,
        "voice": "vo_adv_1344004_071"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n所以似乎連同之前失敗的份",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n都全部",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "誕生出來了呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_072"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那種事是有可能的嗎？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n明明就連誕生出一隻都是很罕見的事。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我好開心。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_073"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對啊！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……太好了……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真的",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很謝謝你！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_074"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "新的夥伴增加了，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n精靈們似乎也很高興。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "好了。",
        "unit_id": 611,
        "voice": "vo_adv_1344004_075"
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "接下來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "就是育兒了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "\n這是好不容易才誕生的精靈，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "隱居的老婆婆",
        "words": "要好好養育它們啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好的！",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_076"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會努力的！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實我有跟娛樂記者們",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_077"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約好要接受採訪……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n要是不趕快回蘭德索爾，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他們可能又會過來。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "不需要擔心那種事。",
        "unit_id": 1,
        "voice": "vo_adv_1344004_078"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_079"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請問",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有什麼事？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "我剛剛已經把明天",
        "unit_id": 1,
        "voice": "vo_adv_1344004_080"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "娛樂版的頭條寄回公司了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n是關於妳的獨家報導。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "「慈樂之音的千歌正祕密進行演唱訓練。",
        "unit_id": 1,
        "voice": "vo_adv_1344004_081"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "回歸後",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "應會讓大家聽見進一步升級的歌聲。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_082"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那是……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "妳在驚訝什麼？",
        "unit_id": 1,
        "voice": "vo_adv_1344004_083"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n作為記者，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "我不過是報導了事實而已。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "因為這次的事，",
        "unit_id": 1,
        "voice": "vo_adv_1344004_084"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "妳作為歌手又更上一層樓了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n關於精靈方面我雖然是個門外漢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "但在藝能方面可是專業的呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "──還是說",
        "unit_id": 1,
        "voice": "vo_adv_1344004_085"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "並非如此？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n妳打算讓我的報導變成捏造的嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_086"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我向你保證。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "回到蘭德索爾之後，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我保證會把比以前還要更棒的歌聲，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n送給所有的粉絲。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "我求之不得呢。",
        "unit_id": 1,
        "voice": "vo_adv_1344004_087"
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "這樣我也能免於被上司責罵了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者1",
        "words": "我就先告辭了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "………………",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_088"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的！",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_089"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我也會為了支持我的所有粉絲們",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "加油的！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要先養育出出色的精靈，",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_090"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後向望和紡希",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有蘭法小姐",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "報告好消息吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌成功地創造出了新的精靈──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不管是作為唱喚士、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "歌手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "還是一名女子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她都大幅地成長了。"
    }
]