        "voice": "vo_adv_1344004_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "精靈啊。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "回應我的……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼喚……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和心意吧！　",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唔唔……",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好刺眼……",
        "unit_id": 134411
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思突然把你叫出來。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你過來。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實我",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接下來打算要進行大冒險。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我希望你來",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "見證這件事。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……呵呵。",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我並沒有要去哪裡。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是要去",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "打倒邪惡的大魔王之類的。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我在想──",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要在這裡進行街頭演出。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你還記得嗎？",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這個地方",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是我和你初次相遇的地方。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你幫我撿起了",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我掉落的樂譜。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "假如",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那時候我沒有遇見你，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就不會有現在的我。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以……",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我很久以前就決定，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果要進行街頭演出，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就要把地點定在這裡。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你願意聽嗎？",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你那樣一說，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺我今天能唱得非常好……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就像有什麼新的東西要誕生一樣，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我有那種預感。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我開始了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1344004_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "快看啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在舉行演唱會耶。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "竟然只憑一支麥克風演出，",
        "unit_id": 1,
        "voice": "vo_adv_1344004_016"
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "真厲害呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性2",
        "words": "哇，",
        "unit_id": 1,
        "voice": "vo_adv_1344004_017"
    },
    {
        "type": "dialogue",
        "name": "女性2",
        "words": "好美的聲音……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性2",
        "words": "\n去聽一下吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "人聚集起來了……",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不要緊的。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我已經",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不會害怕在人前",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱歌了。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為第一次在這裡唱歌的時候也好……",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在打工的店裡",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "代唱的時候也好……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不論何時，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}都在守護著我。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這樣──",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……咦？",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聲音停止了……？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是喇叭故障嗎。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連麥克風也是！？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我昨天明明有好好確認過的……！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "什麼什麼？",
        "unit_id": 1,
        "voice": "vo_adv_1344004_022"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "器材出問題了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "哎呀──",
        "unit_id": 1,
        "voice": "vo_adv_1344004_023"
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "\n這是街頭表演常有的事呢──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性2",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1344004_024"
    },
    {
        "type": "dialogue",
        "name": "女性2",
        "words": "明明正精彩的說！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "觀眾",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好不容易才聚集過來的……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "乾脆在沒有伴奏的情況下清唱？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不行，",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一定會因為沒能好好抓住節奏",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而失敗的。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "麥克風也不能用，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是提高音量……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "步調一定也會亂的。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這樣子",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只會讓觀眾還有他失望的吧……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哎呀呀……",
        "unit_id": 1,
        "voice": "vo_adv_1344004_027"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "看來今天就這樣結束了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n雖然很可惜。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "沒辦法啊。",
        "unit_id": 1,
        "voice": "vo_adv_1344004_028"
    },
    {
        "type": "dialogue",
        "name": "女性1",
        "words": "畢竟是業餘的女生吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊真是的，",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該怎麼辦才……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "伴奏？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n難不成",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你會什麼樂器嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "用mimi",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來抓拍子？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "它有那種功能嗎……？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……啊！",
        "unit_id": 104232,
        "voice": "vo_adv_1344004_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是那麼一回事嗎！",
        "unit_id": 104232
