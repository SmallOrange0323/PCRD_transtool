        "words": "是啊！",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n一定……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會很可愛的。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我和你孕育的",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "新精靈……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在正是",
        "unit_id": 134411,
        "voice": "vo_adv_1344004_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
