[
    {
        "type": "background",
        "background": "501160"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "蒐集年菜材料之旅，",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要結束了呢……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "中途發生了許多事，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還覺得這趟旅程有點漫長，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n論實際時間，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "卻是比想像中還要短很多呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "獨自旅行的時候",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要考慮的事無論如何都會很多，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n自然會覺得漫長。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "發生了很多事",
        "unit_id": 120912,
        "voice": "vo_adv_5082431_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "倒也是事實。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "取回那些被奪走的材料",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可是費了不少力氣……",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那時候真的",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳們。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有兩位陪伴著",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是幫大忙了。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不必在意。",
        "unit_id": 120912,
        "voice": "vo_adv_5082431_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這次不是和平常的成員一同旅行，",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也玩得很愉快。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且年菜也相當美味。",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也過得很開心喔。",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n和至今的獨自旅行相比",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "又是別有一番風情。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也是，",
        "unit_id": 120711,
        "voice": "vo_adv_5082431_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能夠和大家一起旅行真是太好了。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這麼重要的回憶，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我絕對不想忘記。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 120811,
        "voice": "vo_adv_5082431_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我們開始最後的奮鬥吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "出發！",
        "unit_id": 120811
    }
]