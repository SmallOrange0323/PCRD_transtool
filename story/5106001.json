[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里一行人在牢房裡見到的，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是曾經攜手為蘭德索爾帶來幸福的天使少女。"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "請放我出去～",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_000"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "～！！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嚇了茜里好大一跳呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n還想說哥哥怎麼會帶我們來這裡……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲，",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳怎麼被關起來了呀！？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "啊！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_003"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n妳們兩個",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "都來啦……！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "終於得救了～～～！！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓我來解釋吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦！？",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n莫、",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "莫非妳是……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "【王宮騎士團】的團長！",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n妳是純小姐吧！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請跟我握手！！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦！？",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n呃，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也不是什麼大人物……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不好意思，戴著手甲跟妳握手。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "別這麼說！",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n能和團長……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能跟名人握到手，茜里好感動！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……那個，",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不好意思，我妹妹冒昧了。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我想請問一下，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲被抓起來的原因是……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們本來也無意逮捕她。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只不過……",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這裡也沒有異狀……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "真的嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_5106001_012"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n妳要買虎虎的玩具",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "給我嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這是給你的聖誕禮物呀♪",
        "unit_id": 1,
        "voice": "vo_adv_5106001_013"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n要好好珍惜哦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……時間過得真快。",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這已經不曉得是第幾次",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "仰望那棵聖誕樹了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嘿咻……",
        "unit_id": 1,
        "voice": "vo_adv_5106001_015"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嘿咻……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_016"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "還差一點點",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_017"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "就到最上面了……！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有、",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有小孩子在爬聖誕樹！？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小朋友──！",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳快下來──！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦？",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_020"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "好像有人在叫我──",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "啊……",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_021"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "哇啊啊啊啊～～～！\n哇啊啊啊啊────！",
        "unit_id": 1,
        "voice": "vo_adv_5106001_022"
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……就是這麼一回事。",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n幸好那時我有接到她，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n萬一有個差錯，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可就不是受點傷而已了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她後來又偷偷摸摸地爬上樹。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也是出於無奈才把她帶到客房來安置，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n問了一下原委，可是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個……",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我實在聽不太懂她想表達的意思。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n換作是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉和小智來問，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或許就能問出來龍去脈，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但她們都去遠方執行任務了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這段期間，拉菲多次從客房逃跑，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也只好採取強硬手段了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是想防止拉菲",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓自己陷入危險。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "基於安全考量，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只能請她待在牢房裡了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "原來是這樣呀……",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為什麼哥哥會知道這件事呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "拉菲拜託我「把依里她們找來」的時候，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n他正好來到我這裡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他經常來這邊送信呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為他認識拉菲",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有依里妳們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就請他去把妳們找過來了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以你才會急急忙忙地跑來找我們呀。",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "居然讓【王宮騎士團】裡",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "最偉大的人當保母……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這沒什麼……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "聖誕節期間",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "活動多，突發狀況也多，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此我們是不分階級全體出動的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳也不用太放在心上哦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……話說回來，",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "拉菲真的是天使嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個光圈和翅膀……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是玩具？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我懂妳的疑惑。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我一開始也覺得",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很像冒牌貨……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗚嗚～！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_036"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太過分了～～～！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我還以為把依里和茜里找來，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n就可以證實我的身分了！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我是",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_037"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "為了讓大家的聖誕節",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n變得超級無敵幸福而降臨的",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n貨真價實的正牌天使呀！！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "純小姐，",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_038"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲說的都是真的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲是個動不動就搞砸事情的",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "冒失天使哦！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗚……",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_039"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "茜里……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n妳這麼說完全沒有起到打圓場的效果呀……！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "抱歉抱歉！",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_040"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但茜里知道拉菲比任何人都還要努力哦！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n因為妳那麼努力，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里我們才會想要幫忙呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以呢？",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n妳為什麼要爬到樹上呀？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "……！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_042"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n其實呀……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「天使升級考試」？",
        "unit_id": 1,
        "voice": "vo_adv_5106001_043"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "是的！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_044"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n這對於見習生來說是最重要的考試，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我們要幫助大家",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "度過一個美好的聖誕節！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "考試的內容是，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_045"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "可以讓多少人感到幸福。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "在聖誕節結束之前，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n要請幸福的人們",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "分享他們的「幸福能量」！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我們將收到的能量稱為「幸福點數」，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_046"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "樹上的天界專用天線會自動收集點數，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n將樹作為媒介，把點數儲存起來……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "只要收集的幸福點數達到標準，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_047"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n就可以",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "往上升一個階級哦！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "此外，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_048"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "幸福點數在人們眼中就像小小的光芒一樣，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "收集到很多點數的時候，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n璀璨的聖誕樹會讓更多人感到幸福的！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "……",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_049"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "天使手冊上是這麼寫的！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「樹上的天界專用天線」……",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_050"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "難道",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲爬到樹上是為了……！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "……是的。",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_051"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "其實只要用魔法，一下子就能搞定了，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但我的魔法沒辦法傳那麼遠……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_052"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "一直升不了級，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "現在也還是墊底……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但今年",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我有信心！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但是，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_053"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "如果沒有辦法裝上天線的話，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n連考試都無法開始！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_054"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "無論如何都想在蘭德索爾升級！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n在這裡，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "有人稱呼不中用的我為「優秀的天使」，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n所以我",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "想在這個地方升級！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "所以！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_055"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "請讓我把蘭德索爾變得超級無敵幸福，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n來報答這個地方的恩情吧！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "情況我都了解了。",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_056"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但是，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是不可以爬樹！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……取而代之，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我會跟妳一起想想其他辦法的。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦？",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_057"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳的意思是……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我幫妳吧。",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_058"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n……畢竟",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還欠了妳之前幫忙實現願望的人情呢。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果姊姊要幫忙的話，",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_059"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也要幫忙♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只有茜里幾個人",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_060"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "總覺得好不安呀～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……所以啦！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥、哥哥♪",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_061"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n你可以再一次待在我們身邊",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "守護著我們嗎……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝你願意聽",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_062"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里的任性要求！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那茜里就給哥哥一個",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "很棒的回禮吧♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "抱",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "抱～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 102212,
        "voice": "vo_adv_5106001_063"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你不是很忙的嗎……？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我也覺得",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "人手越多越好啦……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那就",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拜託你……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是當我沒說！",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太好了！",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_064"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n有依里妳們在，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我就什麼都不擔心了♪",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……看來已經沒問題了呢。",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_065"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n拉菲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳可以出來了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有……",
        "unit_id": 104711,
        "voice": "vo_adv_5106001_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不管基於什麼理由，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我都很抱歉把妳關起來了，真的很抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還請妳見諒。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "啊，",
        "unit_id": 5511,
        "voice": "vo_adv_5106001_067"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "該道歉的人是我才對！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我因為又犯了急性子的毛病……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "而給妳添麻煩了。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "純小姐，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "謝謝妳救了我！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，",
        "unit_id": 100611,
        "voice": "vo_adv_5106001_068"
    },
    {
