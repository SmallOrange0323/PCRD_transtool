        "voice": "vo_adv_2209005_002"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n妳們退下。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "啥～？",
        "unit_id": 130213,
        "voice": "vo_adv_2209005_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n少命令我們了～",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼。",
        "unit_id": 130013,
        "voice": "vo_adv_2209005_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n真的好嗎？",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "妳們留在這裡的話，",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_005"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "也只會火上加油而已。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n快走。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……妳們兩個，",
        "unit_id": 130013,
        "voice": "vo_adv_2209005_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "走吧。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "失、",
        "unit_id": 130113,
        "voice": "vo_adv_2209005_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "失陪了……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "…………",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_008"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_009"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……那個。",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_010"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──呵。",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_011"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "呵呵呵……",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n哈哈、",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "哈哈哈……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "──喝啊！！",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_013"
    },
    {
        "type": "still",
        "still": "220900403"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "…………",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_014"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n居然能從不同的世界，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "發動如此強大的防禦魔法。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n即使是和這丫頭有關係的人，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "也不可能隨便就做到。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……我有同感，",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_015"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士──",
        "unit_id": 193711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220900501"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "別敷衍吾，",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_016"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "傳令……！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n妳的世界",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "居然有實力如此高強的人──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾可不許妳說妳不知道這個情報……！",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "您會生氣也是理所當然……",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_017"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n但是，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "能請您聽我說嗎，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那位女性是過去，",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_018"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "被視為世界管理者的存在。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n曾經占據了本應由您來登上的王座。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……只是。",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_019"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n她原本",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "應該已經消逝了才對……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "消逝？",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_020"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n哼……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾看她",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "倒是活得很好啊。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不……",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_021"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "恕我直言，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n她原本的性能",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "並非是那種程度。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n她在那邊的世界，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "正是擁有宛如神一般權能的人。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……妳的意思是她原本是在吾之上",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_022"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "的人？",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_023"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……呵呵、",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_024"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "呵哈哈……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "……有意思。",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_025"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n真是太有意思了。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾的願望",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_026"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "是支配將吾關禁起來的這個吉歐‧格黑納。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n並破壞隔絕",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "世界與世界之間的「牆壁」。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "在未來等著的世界，",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_027"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n若真有妳所說的那般權能、",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "那般光芒存在──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾絕對要將其奪取，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "並納為己有。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……一切如您所願，",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_028"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那麼，",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_029"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我們再次開始",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "攻略鬼岩城塞──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "慢著，",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_030"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妳這愚蠢之徒。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_031"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "真是何等地粗心輕率。",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_032"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n那座城塞遲早是屬於吾的，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "就算現在攻下來又如何。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n鐵皇女已經動彈不得，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾怎麼可能放過這個好機會。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……好機會？",
        "unit_id": 193711,
        "voice": "vo_adv_2209005_033"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那麼……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妳跟那群盜賊",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_034"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "和小蜘蛛們一起，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n去阻擋尤絲蒂亞娜公主的襲擊。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n這段時間，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "就像隻蜘蛛般，",
        "unit_id": 136013,
        "voice": "vo_adv_2209005_035"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "準備進行蛻皮吧。",
        "unit_id": 136013
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "502300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n「鬼岩城塞」附近的避難所──"
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "痛痛痛……",
        "unit_id": 50811,
        "voice": "vo_adv_2209005_036"
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "\n可惡，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "那個絲線究竟是怎麼回事啊……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男",
        "words": "如果不是皇女大人出手相助，",
        "unit_id": 50711,
        "voice": "vo_adv_2209005_037"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克男",
        "words": "我們就會自相殘殺而亡了……",
        "unit_id": 50711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那個，",
        "unit_id": 127712,
        "voice": "vo_adv_2209005_038"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要是不介意，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請讓我替你包紮。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "雖然只是簡單的處置……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "真抱歉呢，",
        "unit_id": 50811,
        "voice": "vo_adv_2209005_039"
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "小姐……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "\n妳們明明是其他地方來的客人，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "男蜥蜴人",
        "words": "卻害妳們捲了進來。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我們",
        "unit_id": 127712,
        "voice": "vo_adv_2209005_040"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不要緊的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "可是……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……老姊。",
        "unit_id": 127812,
        "voice": "vo_adv_2209005_041"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n妳又在想「要是自己有力量──」之類的事？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
