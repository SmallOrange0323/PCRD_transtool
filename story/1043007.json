[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哼嗯哼哼～嗯，今天也是開心的撿垃圾日……♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n現在每次有撿垃圾的工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}都會來幫忙了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然那傢伙一直說這是處理傷口和訓練的謝禮～？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過該道謝的，明明應該是我才對。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "每一次都幫忙我撿垃圾。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "和那傢伙一起，無聊又單調的工作也令人開心呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}還真是好事～",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n明明我也沒有特別拜託那傢伙幫忙撿垃圾，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙每次都會說「想要一起撿！」呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "撿垃圾到底有什麼有趣的，真搞不懂。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我是開心得不得了～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n都快搖起尾巴了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哦哦，{player}！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你先來了啊，真是充滿幹勁呢～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好很好，今天也努力工作吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "報酬對分可以吧，要你無償工作我也很不好意思。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n對於錢這方面，得好好談清楚才行。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個，是你之前幫忙得到的報酬。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n……你就收下吧，不要客氣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種事情，要是不好好處理我心裡就會很不舒服。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。你可以用那些錢去買好吃的東西哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n話說，我覺得你先去買把新劍換掉身上那把比較好哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你身上的那把，看起來很不銳利。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？有人對你說這把劍很重要，",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不可以買別的來代替？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n呃，是雙親遺物之類的東西嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是沒關係，就算是不銳利的劍也能當鈍器來用。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不必特別準備訓練用的木棍或木劍了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n今天的訓練就用那把劍吧",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，不過在那之前得先處理好工作……",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，怎麼啦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為什麼把臉靠這麼近，{player}？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有很香的味道？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，那個……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該怎麼說呢，我做了午飯帶過來。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "撿垃圾也得花上整整一天。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n之前都是買攜帶糧食帶來。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過今天，我早起做了便當帶來。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣要是肚子餓了，還有點心能吃呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哼哼，你也知道我很擅長做料理吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，你可不要誤會哦？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是因為想讓你吃我親手做的料理～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n才不是因為這樣哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只、只是因為自己做比較省錢而已哦……！",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啥？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊啊，嗯……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟我們家的居酒屋，完全吸引不到人流。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一定得減少支出才行呢。【哞哞自衛隊】也是，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n幾乎沒有能賺錢的工作，非常窮困。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說回來。你明明就腦袋空空，",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就不要用什麼「勤儉持家」這種很難懂的詞啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我一瞬間不知道你在說什麼哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸？你說我會成為一個好太太？",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝、謝謝你……為什麼要這樣誇獎我？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你啊，有好好理解話裡的意思再說出口嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "算了，是沒關係。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "至少有傳達了你想誇獎我的意思啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。沒～錯吧，畢竟你也常到我們店裡白吃呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我想比起沒什麼味道的攜帶糧食，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還是我做的便當會讓你比較開心吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我保證味道很好，你就好好期待等著品嘗吧～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……謝謝你啦，{player}。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我總覺得很不好意思，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以把做料理的興趣當成自己的祕密。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過因為你說很喜歡吃，而且還吃得那麼開心。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近我就不再隱瞞，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還會帶手工料理去給【哞哞自衛隊】的大家吃哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、啊哈哈。",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不小心就聊了起來呢，該來工作了吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，不過，今天地上的垃圾不多呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這也是因為我很積極，",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一直接受撿垃圾工作的成果呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且每次做這個工作都能和你見面。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "開玩笑的～",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們一面到處繞繞看哪裡有垃圾，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一面悠閒地散步吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n曬曬舒服的陽光，順便聊聊天。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯嗯～心情真好！",
        "unit_id": 104311,
        "voice": "vo_adv_1043007_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最近啊，我有種人生非常充實的感覺……♪",
        "unit_id": 104311
    }
]