[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家久等了，",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "開心的春節開始囉！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "來",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "～跟我一起說，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "新年快樂♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿嘿，",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝你精神抖擻的拜年！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有幸被叫來參加",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得的新年祭典，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我們就要全力炒熱氣氛啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也希望工商會那些負責主辦的人們",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能樂在其中呢。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……但他們用「因為莉瑪小姐是今年的主角」",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種理由",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "叫我來，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓我嚇一大跳就是了。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪居然被誤認成馬，",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是飛來橫禍的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖說今年是馬年，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但莉瑪莉瑪明明就不是馬啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就是說啊，",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太沒禮貌了！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n說到底，我根本不是動物，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是獸人族呀！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得遇上這麼喜氣的祭典。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家想好好慶祝的心情",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都是一樣的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不對，",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這不是可以敷衍了事的問題。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n應該向【里士滿工商會】的人",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嚴正抗議才對。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦，",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "似似花，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "新年快樂！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來妳也跟莉瑪莉瑪一起來拜年啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我只是路過而已。",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看見錯誤卻袖手旁觀",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "違反我的處事原則。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只因為是馬年就叫莉瑪當主角……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣做，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不只草率",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還大錯特錯。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n他們的確是誤會了沒錯，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但應該沒有惡意啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n感覺不需要說得那麼嚴重……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳看看莉瑪的手。",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有兩個趾頭對吧？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相對地，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "馬只有一個趾頭。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這就證明了，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她跟馬從分類上就是不同的動物。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦咦，",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這是在說什麼！？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在談什麼分類之前，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我原本就不是動物啊……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該說，",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "同樣擁有兩個趾頭的牛和山豬，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "跟馬相比才是更接近莉瑪的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽懂了嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦～",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此啊……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不愧是博學多聞的似似花，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也長知識啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等一下，",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的確是有學到知識沒錯！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但我就說了，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說到底我不是牛也不是山豬，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是獸人族呀！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "算了啦，",
        "unit_id": 103311,
        "voice": "vo_adv_0000443_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然有人認為妳可以帶來好預兆，那也滿幸運的啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "相信接受大家的膜拜後，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪的運勢也會上升，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n過上馬到成功的一年啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎？",
        "unit_id": 105213,
        "voice": "vo_adv_0000443_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣說",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好像也對！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然如此，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家多多跟我一起",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "慶祝新年吧♪",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼我也",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "特地說一句……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "新",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "年快樂。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "願這一年也成為美好的一年，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓我們共同努力吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤其……",
        "unit_id": 115011,
        "voice": "vo_adv_0000443_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "學習會讓人生變得富足。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果希望接下來能度過充實的一年，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就來依靠我吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n新年假期中",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要全程陪著你也可以喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵……",
        "unit_id": 115011
    }
]