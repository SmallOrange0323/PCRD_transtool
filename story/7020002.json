[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人在登塔時，有魔物擋在他們面前。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不會讓你對他們兩人出手的，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看招看招～！",
        "unit_id": 103311
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我掩護妳喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喝啊！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "敵人害怕了！",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就是現在，小希希，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們同時對它攻擊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好啊喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n唔喵──！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大獲全勝喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就像鯛魚燒和牛奶的組合一樣，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們的組合是最棒的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽，妳也這麼想喵？",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真陽？",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳該不會有受傷喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我完全沒問題啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛才的戰鬥，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "簡直就像是當紅組合的相聲一樣，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n讓我感覺非常合作無間。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "假如這裡是搞笑的舞台，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而我們負責逗哏跟捧哏，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "保證會引起大爆笑的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們明明沒特別練習過，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "完成度就這麼高了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難不成……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希是我命運的搭檔……？　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我已經有了我心裡決定好的搭檔……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇啊！",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n沒、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒什麼啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥雖然人很好，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但我的搭檔是伊麗莎白啦！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……不過，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也常聽說會有人和各式各樣的人組成搭檔，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n為了提升搞笑實力，這樣說不定也是好選擇？　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行不行，",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要做判斷還太早了啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的頭上",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "停了一隻蟲，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "此時就該華麗地吐槽他！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥──",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唔喵──！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你頭上停了一隻蟲，我幫你趕走了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好好感謝我喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好、",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好厲害！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那不放過細小變化的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "觀察力和敏捷的動作！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這不說是吐槽的才能還能怎麼形容！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……我、",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我說小希希啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳願意的話，要不要和我組搞笑──",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "剛才那邊有動靜喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那一定就是究極的食材，不會有錯喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我絕不放過你喵──！",
        "unit_id": 104611,
        "voice": "vo_adv_7020002_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！",
        "unit_id": 103311,
        "voice": "vo_adv_7020002_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n等、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等等我啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希毫不猶豫地往前進，真陽則慌忙地追在她背後。"
    }
]