[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼。",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "爬得相當高了呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n寶石也是，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都拿到這麼多了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔……",
        "unit_id": 101411,
        "voice": "vo_adv_7001002_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "拿到這麼多寶物雖然不是甚麼壞事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但問題是行囊變得未免也太重了吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是呢，",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "魔物也變得越來越強了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們得動作快點了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "？　",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼啦騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n欸？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "　不夠細心感到抱歉？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這大包包，",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你是要幫我揹嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不，不必了啦！　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生自己都已經揹得這麼重了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是……",
        "unit_id": 104311,
        "voice": "vo_adv_7001002_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、優衣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳稍微過來一下。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種時候就不應該拒絕的吧。",
        "unit_id": 104311,
        "voice": "vo_adv_7001002_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n上個月的『月刊戀愛指南』不是有寫嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "學會撒嬌就能征服愛情，這一句。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？　",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊、啊啊，是沒錯呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是有這麼寫道。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我還記得，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過這有甚麼關係嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是說啊，",
        "unit_id": 104311,
        "voice": "vo_adv_7001002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這時候就該這樣說啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "『謝謝你！　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "騎士先生",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是強壯，你好棒喔～』",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "用撒嬌來展現妳的魅力啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "展現妳的魅力！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那種羞恥的話",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我說不出口的啦～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快說！",
        "unit_id": 104311,
        "voice": "vo_adv_7001002_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n每個月跑去買戀愛指南不就是為了這種時候嗎。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說得是沒有錯，",
        "unit_id": 100211,
        "voice": "vo_adv_7001002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但我還沒有那個心理準備啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且真琴，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那種羞恥的話妳說得出來嗎！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔……現、現在該說的又不是我！？",
        "unit_id": 104311,
        "voice": "vo_adv_7001002_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉。",
        "unit_id": 101411,
        "voice": "vo_adv_7001002_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們到底，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是為了甚麼才來到這裡的啊……？",
        "unit_id": 101411
    }
]