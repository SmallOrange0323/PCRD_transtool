    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "小栞把圖鑑交由取回書籤的初音來保管。\n幾天後。{player}被初音約到蘭德索爾，\n和小栞一同交代整件事情的原委。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "經過這次事件",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【動物苑】和【森林守衛】就",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物圖鑑與書籤的處理一事\n進行了協商。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "結果將會出爐。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "（最後，看來是決定交由精靈之森來嚴加看守。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n圖鑑和書籤都已經不在我這裡了。）",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞……明明是很難得的禮物，真對不起哦？",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊又沒有錯不需要道歉啦。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不如說，謝謝妳還為了我……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……小栞小栞小栞",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊、姊姊……{player}也是，真的非常感謝你。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n幫了這麼多的忙……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要是沒有{player}的話根本無法解決。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇──！想去想去！對了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我們之前不是做了下次三個人一起去的約定嗎！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，說的對……那麼恭敬不如從命，",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們就來一場小小的慶功宴吧……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸欸，小栞妳想去哪裡？",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "光是一個圖鑑就讓我用盡了體力和腦力，",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "機會難得我想吃點甜品……好嗎。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊我也想吃！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好，那麼我們就向甜品店出發吧♪",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～♪好吃～♪來啊，小栞妳也來一口！啊～",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊唔……真、真難為情啊姊姊……",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊～……嗯，好好吃喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，不愧是小栞挑的店呢！妳經常來嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "欸……那個，姊姊，其實呢……",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這位客人。請收下這個。",
        "unit_id": 411,
        "voice": "vo_adv_5001007_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？什、什麼什麼？這個是……枕頭嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是我悄悄交給店員的。所以我才挑了這間店。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n想說來個驚喜的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！這是！這是……！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……一直以來謝謝妳了。這是我要送給妳的……禮物。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也是，從很多人那裡聽說了，姊姊非常努力。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……小、小……小栞！謝謝妳～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我太開心了！我一定會一直一～直好好珍惜它的！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊啊。對了！我必須回信給妳啊 ！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結果到最後還是沒把回信寫好！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊、姊姊，這個禮物本來就是我要送給妳的。",
        "unit_id": 103811,
        "voice": "vo_adv_5001007_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n姊姊再送我禮物的話，就要變成回禮的回禮了？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就算這樣我還是想給妳啊！　欸欸～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001007_025"
    }
]