[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可趁著公務的空檔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了享用魔物料理，打算前往魔物的棲息地。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？　這不是{player}嗎。",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你來得正是時候呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在正想要前往狩獵魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你要一起來嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會招待你好吃的魔物料理哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你懷疑我是從城堡偷跑出來嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這次是真正的自由活動時間唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖說如此，但還是工作間的空檔，",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我們要迅速地捕獵魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還要迅速料理完成才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為沒什麼完整的時間，",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能捕獲的魔物也有限，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真讓人困擾啊——",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對於味道我絕不妥協，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一定會獻上極品美味給你哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣回答表示你願意跟我一起去囉！",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天的獵物沒那麼危險，",
        "unit_id": 105812,
        "voice": "vo_adv_1804003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以放心跟我來吧♪",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天感覺是絕佳的狩獵好天氣呢～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為目標魔物會自投羅網撲上來襲擊我們，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想馬上就能捕獲唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會危險哦——",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然牠們很好戰但其實很弱唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也沒有什麼時間，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們迅速捕獲吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真奇怪啊——",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n平時的話會不斷襲擊過來的說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天連影子都沒見到呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "受到霸瞳皇帝戰役的影響，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔物的棲息地發生變化了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來，城鎮的人也有提到過巨大生物呢。",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不好好仔細調查的話不行呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個響徹肚子的巨大聲音。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是那個！　",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就是我們的目標魔物！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "追上去吧，{player}！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……被牠逃走了。",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那種魔物逃跑的情況，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是第一次見到。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果是平時的話，會很有精神地飛撲過來的說。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然感覺很奇怪呀……",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哇啊啊————！！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "慘叫聲！？",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聲音是從那邊傳過來吧！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！！　",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們走！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然事情演變成這樣，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你還是一點都沒變呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我非常",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "高興唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "巨大魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "馬車被巨大的魔物在追趕著！",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n必須快點救人！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊的那位！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請快點丟下貨物逃走吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "混蛋！！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_024"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n怎麼可能這樣做！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇！？　",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然反應出乎我意料，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但沒有比性命更重要的東西了唷！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這些可是要送到蘭德索爾的復建工程材料！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我怎麼可能這麼輕易丟下逃跑！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！！",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原來是這麼一回事。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼就讓我全力協助你逃跑吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳在說什麼！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_028"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n小姐妳才很危險，快逃跑吧！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別看我這樣，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我很強的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要上了唷――！",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n公主突……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "巨大魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n牠連看都沒看這邊就逃走了……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是怎麼回事。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我逃離的並不是那個魔物唷！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n比那個魔物更可怕的傢伙正追過來喔！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "周圍突然變暗……",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那隻超巨大的魔物是什麼呀！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "超巨大魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就是那傢伙！",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我躲的正的是那傢伙！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "該死！　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要被追上了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼巨大的身影很不妙呢！",
        "unit_id": 105811,
        "voice": "vo_adv_1804003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "必須就地把牠攔阻下來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳說要攔阻牠嗎，",
        "unit_id": 1411,
        "voice": "vo_adv_1804003_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那肯定是沒辦法吧！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我們只能逃跑了！",
