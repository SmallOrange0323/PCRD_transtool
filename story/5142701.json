[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這附近的魔物都解決掉了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n大家，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "去休息吧──！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "是的，",
        "unit_id": 1,
        "voice": "vo_adv_5142701_001"
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "教官！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話又說回來，",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然事先聽說了有多得像山的魔物，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但還真的是",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接連不斷地冒出來呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這也在想像的範圍內啦。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "用來累積實戰經驗也很適合吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "辛苦各位了。",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看樣子魔物掃蕩任務進行得很順利呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多虧有妳幫忙。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n新兵們也很努力地在戰鬥，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子也是……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然魔物非常可恨，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但一想到牠們會成為我們孕育愛情的養分，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就變得可愛了呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子也很有幹勁喔。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……雖然動機有點不太單純。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那就好。",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來本次訓練",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以進入下個課程也沒問題了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有什麼事要做的嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要做的事本身和目前為止一樣，",
        "unit_id": 104711,
        "voice": "vo_adv_5142701_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是同心協力打倒魔物而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只是之後便不會設立終點，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請各位只要還能保持隊伍，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就繼續行軍下去。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是說，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能前進多少就前進多少是吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的是",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很常強人所難的騎士團欸……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有問題的。",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n以他們的實力來看並非不可能，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵1",
        "words": "雖然我聽說要追加訓練時有點驚訝，",
        "unit_id": 711,
        "voice": "vo_adv_5142701_013"
    },
    {
        "type": "dialogue",
        "name": "新兵1",
        "words": "\n但魔物好像也沒那麼強，真是太好了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新兵2",
        "words": "不如說，",
        "unit_id": 717,
        "voice": "vo_adv_5142701_014"
    },
    {
        "type": "dialogue",
        "name": "新兵2",
        "words": "或許是我們太強了呢！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "新兵2",
        "words": "\n這樣看來，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "新兵2",
        "words": "我們在騎士團裡應該也能不斷地晉升啊！",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "跟我想的一樣，",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "開始出現小看敵人而掉以輕心的傢伙了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來很值得好好教育呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n懲罰新兵可不是這次任務的重點，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳可別忘了這件事喔？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，各位……",
        "unit_id": 129911,
        "voice": "vo_adv_5142701_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "得意忘形的垃圾蟲們。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在這前方",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是與以往不同層級的地獄在等著你們，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "做好覺悟吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "Y、",
        "unit_id": 1,
        "voice": "vo_adv_5142701_018"
    },
    {
        "type": "dialogue",
        "name": "新兵們",
        "words": "Yes, Ma'am！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不過，",
        "unit_id": 129811,
        "voice": "vo_adv_5142701_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不能掉以輕心也是真的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們也再次",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "打起精神來戰鬥吧！",
        "unit_id": 129811
    }
]