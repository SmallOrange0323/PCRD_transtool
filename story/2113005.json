[
    {
        "type": "background",
        "background": "501220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿擊退了入侵精靈族之村神廟的魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這個時候，一道聲音向她搭話──"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……是可可蘿",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_000"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "嗎……？",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "長老……！",
        "unit_id": 6511,
        "voice": "vo_adv_2113005_001"
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "\n您還不可以起身！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "都是因為保護我們才會這樣……",
        "unit_id": 5411,
        "voice": "vo_adv_2113005_002"
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "\n對不起，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "長老……",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "這種程度的傷勢……",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_003"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "妳們不需要太在意。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n而且……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人……！",
        "unit_id": 180511,
        "voice": "vo_adv_2113005_004"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "歡迎回來，",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_005"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "可可蘿。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n……不過，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "妳這身打扮……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 180511,
        "voice": "vo_adv_2113005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 180511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下和主人的羈絆",
        "unit_id": 180511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "化成的力量所產生的……",
        "unit_id": 180511
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "咦？",
        "unit_id": 5411,
        "voice": "vo_adv_2113005_007"
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "\n可可蘿姐姐",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "變回原來的樣子了～",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是因為戰鬥結束後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心情放鬆下來了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "不過可可蘿小姐",
        "unit_id": 6511,
        "voice": "vo_adv_2113005_009"
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "超級厲害的！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "嗯。",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_010"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n真的",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "變得很可靠。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "看來",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_011"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "是愛梅斯大人的庇佑",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "在引導我的女兒。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n能夠親眼見證妳的成長，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "著實讓人開心。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝、",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝父親大人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……果然",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「這位」父親大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不曉得愛梅斯大人背後的真相。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也就是說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他和這個世界一樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是虛幻的存在……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……妳怎麼了？",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒、",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒什麼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您不必介意……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人……",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n精靈族之村的長老，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "艾爾菲利亞‧塔雷爾‧達爾‧佐拉大人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次在下前來拜訪，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實有一事相求。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "──嗯。",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望父親大人能將手邊的索爾魔珠，",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n轉讓給在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了能夠",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引導在下的主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "索爾魔珠……？",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一顆拳頭大的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寶珠，裡面能看到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "塔的一部分……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……那顆寶珠，",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_022"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n就嵌在神廟最裡頭的神像上。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n我馬上派人過去拿。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "好的，",
        "unit_id": 6511,
        "voice": "vo_adv_2113005_023"
    },
    {
        "type": "dialogue",
        "name": "精靈族",
        "words": "請交給我……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您……！",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣沒關係嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這麼拿走",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神像的裝飾……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "這並非是我",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_025"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "徇私或是偏心，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "可可蘿。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n妳和妳的同伴們",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "從絕境中拯救了這個村子。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n那麼，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "你們理應獲得",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "相應的報酬。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可、",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下來說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拯救故鄉的同胞",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是理所應當的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "妳不必客氣。",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_027"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n對妳來說，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "這是為了",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "要引導最重要的「主人」吧。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n而……",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "對我來說，",
        "unit_id": 107212,
        "voice": "vo_adv_2113005_028"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "能向最重要的女兒伸出援手，",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n沒什麼比這更讓我開心的事情了。",
        "unit_id": 107212
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "對呀對呀！",
        "unit_id": 5411,
        "voice": "vo_adv_2113005_029"
    },
    {
        "type": "dialogue",
        "name": "精靈的小孩",
        "words": "\n不需要客氣！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好、",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……真是不可思議。",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「這位」父親大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是虛幻的存在……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和他",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "交談的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺就像是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和「現實」的父親本人交談一樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一股暖意",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "湧上心頭……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過去，",
        "unit_id": 105913,
        "voice": "vo_adv_2113005_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n回歸「現實」後，",
        "unit_id": 105913
