[
    {
        "type": "background",
        "background": "500133"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉，",
        "unit_id": 105212,
        "voice": "vo_adv_5061411_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種如夢般的日子，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就要在今天宣告結束了啊。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n還要跟難得認識的人們告別，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是寂寞……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "相遇與分離",
        "unit_id": 101011,
        "voice": "vo_adv_5061411_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "的確就像是一體兩面，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是絕對",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "無法分割的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在這裡獲得的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "經驗和回憶，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是不會消失的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可不能說出",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像「告別」這種寂寞的詞彙哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步……",
        "unit_id": 105212,
        "voice": "vo_adv_5061411_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且",
        "unit_id": 104311,
        "voice": "vo_adv_5061411_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳的牧場夥伴們，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有我們，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也都在妳身邊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴……",
        "unit_id": 105212,
        "voice": "vo_adv_5061411_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就是說呀！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 104311,
        "voice": "vo_adv_5061411_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是缺乏刺激的話就來我們這吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我會讓妳工作到沒有空感覺寂寞哦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也隨時歡迎妳",
        "unit_id": 101011,
        "voice": "vo_adv_5061411_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到真步真步王國來玩哦～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊哈哈，",
        "unit_id": 105212,
        "voice": "vo_adv_5061411_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我這個人",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "竟然被這麼美好的事物圍繞著呀。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如夢一般的日子，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在這之後也會持續下去。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這真是個有些太過美妙的幸福結局呢♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼最後衝刺也要充滿少女心，",
        "unit_id": 105212,
        "voice": "vo_adv_5061411_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "華麗地畫下句點吧♪",
        "unit_id": 105212
    }
]