    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦咦～！",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n原來是我的年紀比較大嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "似乎是這樣呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師這麼沉熟穩重，",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n還以為肯定比我年長呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "結果我才是姊姊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是嚇了一跳。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然年紀比較輕",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但仍是位稱職的老師，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我得向美里老師看齊呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}你還不累嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在這裡稍作休——",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好～痛，",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不小心摔倒了～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不起喔～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "兩位",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒事嗎！？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師！　",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "膝蓋流血了……！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這、",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這點小傷不要緊的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "先別管我了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}有受傷嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是嗎……",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然現在看起來沒事，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n等一下如果哪裡會痛的話，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定要讓老師看看喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯！　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事的話我就放心了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好痛！",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看見你沒事後鬆了口氣，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雙腿就突然……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請不要亂動喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我馬上幫妳治療。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美、",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}已經",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓伊緒老師看過了，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒問題了吧～？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "更何況，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你可是男孩子呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很快就會好起來的～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n痛痛、痛痛，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "飛走囉～♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好厲害……",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的馬上就不痛了……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "非常謝謝妳～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我常常",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會像剛才那樣不小心摔跤……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n得好好學習美里老師的沉著冷靜才行，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n雖然心裡這麼想，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但還是覺得自己很丟臉呢～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們老師",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也只是一介凡人而已，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "偶爾失敗是理所當然的。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話說回來，",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不顧自己的傷勢",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "優先替學生處理",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可真了不起呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "把學生擺在第一位，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n對於我們為人師表來說",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不正是最重要的素養嗎～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "連{player}都這麼說……",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我才剛當上教師不久，",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "仍然每天在不安中摸索，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過聽到兩位這麼說，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "稍微能拿出一點自信了！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "走吧，",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在這種地方停下腳步的話",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就太對不起你了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "繼續前進吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊？",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "——哇、",
        "unit_id": 101811,
        "voice": "vo_adv_7010003_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗚哇哇……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這邊不太好走，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請兩位小心喔～？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的―！",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵、",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師變得可靠了呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}，",
        "unit_id": 101511,
        "voice": "vo_adv_7010003_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起跟著伊緒老師吧～",
        "unit_id": 101511
    }
]