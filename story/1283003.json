    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哦！",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說得好呢！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然小哥都這麼說了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那就來吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說，",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_006"
    },
