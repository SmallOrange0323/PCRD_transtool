    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天……為了即將到來的年神祭決賽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被祈梨叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
