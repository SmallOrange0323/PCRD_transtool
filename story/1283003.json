    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "今天還有時間。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來全力準備吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n進行魔鬼特訓！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就我打聽到的消息，",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "板羽球好像是個非常危險的競技項目……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽說曾經有穿振袖和服的黑色貓妖一個揮拍，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n打出來的羽球就突然把周遭都破壞掉了……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也要成為不輸給那個貓妖的",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "地表毀滅者！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要達到這一點就必須來特訓！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也要想出必殺技才行！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過話說回來……",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼做才好呢？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要想輕鬆地創造出必殺技的話……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦～？",
        "unit_id": 128311,
        "voice": "vo_adv_1283003_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你不覺得那麼無趣的方法不太對嗎？",
