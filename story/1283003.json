    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "藉此想出必殺技吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當然，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你一定要拿出最大的真本事，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不然就沒意義了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了！",
