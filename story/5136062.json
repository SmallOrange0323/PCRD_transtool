[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾就和平常一樣熱鬧。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜與志那都一邊欣賞這樣的街景一邊漫步著。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……確實，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "風景和我熟知的蘭德索爾十分相似。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "建築物以及居民的氛圍",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也沒有什麼太大的不同。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那真是太好了。",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖說是異世界，但要是熟悉環境的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多少能夠放鬆吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哎呀，怜！",
        "unit_id": 1511,
        "voice": "vo_adv_5136062_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "來的正好啊。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳前陣子委託的藥草，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我找到了不錯的門路哦。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的嗎！",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想知道詳細的情況。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都不好意思，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去那邊稍微聊一下。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……放鬆，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然我也很想那麼做……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但是人…………",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好多啊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……說老實話，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在與其他人交流這方面，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怜似乎做得比我好。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n像那樣與城裡的居民親切交談這種事，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對我來說",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "實在是……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……唉……",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怜大人──！！",
        "unit_id": 1,
        "voice": "vo_adv_5136062_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唔！？",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n什……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "什麼人？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是我啊，",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是紡希！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟然能恰巧遇見怜大人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是多麼幸福的一天啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不是，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "等一下……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不、",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不好意思，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "能請妳先放開我嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怪了？",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天的怜大人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "氣質和以往很不一樣呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且還穿著我沒見過的衣服和裝備。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是想大膽地改變形象嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不……",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不是。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我不是怜──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希，",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳在做什麼啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我在這裡哦。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那邊也有怜大人！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那這個人是誰啊？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她叫志那都，",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "遠房親戚。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n聽說她是第一次來到蘭德索爾，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以和紡希是初次見面呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人的親戚！？",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是嗎，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來可以這樣蒙混過去……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "有一套啊，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怜……！　",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "抱歉，",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嚇到妳了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼嗯哼嗯，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來如此原來如此……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怎……",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怎麼了？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n是",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "有什麼奇怪之處嗎……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……應該是有吧……",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_021"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唉……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "陷入沮喪了！？",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像翻書一樣快！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是沒有什麼奇怪的地方……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過我對志那都的衣服有點好奇。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可以摸看看嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可以吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咦，",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n可、",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可以是可以……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過看了也沒什麼有趣的吧？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼會，妳不必謙虛！",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在乍看大膽的設計中，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "蘊含著穩健的格調……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n讓人感到有種",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難以親近的強韌，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n同時卻又引人注目的美麗哦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可以斷言……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件衣服是好貨！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然不只是衣服而已。",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "志那都本人是美女，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n加上身材又好，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "加乘之下使得魅力更上一層樓。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做為新服裝的",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n設計參考，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請允許我更仔細地好好觀察……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "美、",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "美女……？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "身材好……？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這是在形容我嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊───",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希不好意思，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能請妳先停下來嗎。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n志那都她有點困擾呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "抱、",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "抱歉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我可不是移情別戀，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我心目中的第一名還是怜大人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n只是志那都的美麗也不輸給妳而已哦！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們差不多該走了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希也多多保重。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好的，",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n新衣服製作完成後我會再拿去給妳的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人的親戚啊……",
        "unit_id": 105411,
        "voice": "vo_adv_5136062_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過她們長得真的好像喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n簡直就和怜大人本人一模一樣……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是我的錯覺吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……她就是紡希嗎。",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_033"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "想不到",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "居然會這麼地強勢……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是妳第一次見到她嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還以為在志那都的世界裡",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也有紡希存在呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……有是有。",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_035"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n不過，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我沒有直接見過她。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n畢竟離開索爾之塔的機會",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並不多。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊。",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過就如妳所見，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她總是那個樣子呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我……",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_037"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "其實不太擅長與人交流……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n尤其",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是面對那種會很積極地靠過來",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "的人……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呵呵。",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_038"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……怎麼了？",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_039"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n發生什麼有趣的事了嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒事，",
        "unit_id": 100311,
        "voice": "vo_adv_5136062_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是我沒想到志那都居然會那麼慌張。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看到有點令人意外的一面，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼說呢，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺滿開心的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……是這樣嗎。",
        "unit_id": 135614,
        "voice": "vo_adv_5136062_041"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "與人相處這種事",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "果然很難懂啊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對於認真思索的志那都，怜面帶微笑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n用溫暖的眼神關注著她……"
    }
]