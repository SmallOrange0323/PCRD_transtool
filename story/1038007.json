[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你今天也是過來",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n【伊麗莎白牧場】送信的吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你工作辛苦了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為你每週都是差不多這個時間過來。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我在想今天或許也是如此，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以就在【伊麗莎白牧場】的入口等你了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特來打個招呼吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}你好。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "見到你很開心的喵……牠這麼說♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "話說回來。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我有點事想拜託你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我才在這裡等你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再過不久，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n蘭德索爾就會舉辦我喜歡的小說家的簽書會。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我無論如何都很想去。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是最近我的身體狀況很不好，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有可能會無法下床走動。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我在想能不能請人去幫我代簽。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "平常的話我都是拜託姊姊的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過姊姊也住在森林裡，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n她去蘭德索爾太辛苦了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總是麻煩姊姊，我覺得很不好意思",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我記得{player}確實是住在蘭德索爾吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想，找你幫忙或許不會太麻煩你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當然我也會付酬勞給你。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……{player}？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你、你怎麼了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你的臉好紅喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且整個人搖搖晃晃的……難道你身體不舒服嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯嗯，你覺得腦袋昏昏沉沉，又不停地咳嗽流鼻涕？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想你應該是感冒了喔，最近似乎正在流行呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，你不知道什麼是感冒嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟你喪失記憶了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，感冒就是感染了流行性的病菌，也就是生病了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這種時候不能勉強自己活動。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為最糟的情況是會致命的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你這樣抱病跑到位在山上的",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n【伊麗莎白牧場】來，可是自殺行為喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你保重身體。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你向我道歉，我也很困擾。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你並沒有做錯什麼。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}送過來的信和包裹，就由我接手來搬吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你快點回家靜養。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你要好好保重喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為、為什麼你好像有點開心呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你覺得體驗新事物很開心？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我也是會這麼覺得。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是健康第一喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你不可以為了生病感到開心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇、哇？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "危險！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼……",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好險，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我在{player}倒地前扶住你了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【伊麗莎白牧場】的地面幾乎都沒有鋪馬路，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你要是跌倒了會弄髒衣服的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你不要緊吧，走得動嗎……？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼？",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說會把感冒傳染給我，要我最好別碰你……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種常識我知道的喔，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒關係的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為我就像個一直都在感冒的人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你放心。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們的居住區就在附近了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會揹你去那裡，請你暫時在那裡躺著休息。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那邊也有感冒藥的常備藥品……",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會照顧你的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我是第一次做這種事。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可是我只要做以往大家對我做的事就可以了吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一定沒問題的，我可以做到。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿咻……你的腳可能會有點拖到地上，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就這樣揹你喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事的，獸人的臂力可不小的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我受了你的、",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不對，是一直受到大家的照顧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我體弱多病的關係……",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我偶爾也想報答大家。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n老是接受大家的恩情，讓我很不好意思。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿咻，嘿咻。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好重……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n畢竟這個人是男生嘛。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可能是因為感冒的關係，我感受到非常高的熱度。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個人的生命正由我扶持著。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我必須好好珍惜這份生命的熱度。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也是，就算是我……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也是一個不知道何時會逝去、何時會消散的生命。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好不容易才誕生在這世上。",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "活著是一件很幸福的事，",
        "unit_id": 103811,
        "voice": "vo_adv_1038007_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這可是{player}你讓我明白的喔。",
        "unit_id": 103811
    }
]