        "words": "妳明天就要啟程前往其他世界了……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "\n早點休息不是比較好嗎？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──我沒事。",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_069"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n因為並不是",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "要去戰鬥。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "呃、",
        "unit_id": 50611,
        "voice": "vo_adv_1296001_070"
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "唉……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "我知道啦。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "夜班人員",
        "words": "那就……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……呼。",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_071"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n沒有異狀──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "───我原本，",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_072"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n是這樣想的。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_073"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "為什麼──",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_074"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "你會在這裡？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "你只是為了講這個",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_075"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就特地跑來嗎？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──難不成，",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_076"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n你知道我的祕密，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "想趁我一個人的時候",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "鎖定我……？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那樣的話──",
        "unit_id": 129613,
        "voice": "vo_adv_1296001_077"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──收起武器，",
        "unit_id": 1,
        "voice": "vo_adv_1296001_078"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "默涅。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "！",
        "unit_id": 129613,
        "voice": "vo_adv_1296001_079"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "皇女──",
        "unit_id": 129613
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "為什麼在這裡？",
        "unit_id": 129613
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不問自明。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_080"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的目的",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "和騎士閣下是一樣的呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_081"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家只是來說聲，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「明天起請多關照默涅了」。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "皇女……",
        "unit_id": 129613,
        "voice": "vo_adv_1296001_082"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_083"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家想這會讓恁很辛苦……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n但默涅的事，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "麻煩恁多多擔待，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129613,
        "voice": "vo_adv_1296001_084"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅呀，",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_085"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n要是板著臉，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就糟蹋汝如花似玉的容顏了吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尤其在吾等尚且所不熟悉的世界，",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_086"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這位人物",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃是唯一的依靠。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n不可欠缺禮數。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好了，",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_087"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "向他問候吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129613,
        "voice": "vo_adv_1296001_088"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "請──",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_089"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "多多指教了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_090"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝在蘭德索爾",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也要好好聽從這位閣下的指示。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅，明白的話……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就離開吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──是。",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_091"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我去執行",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "夜班的巡邏了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呼。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_092"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對於默涅的多次無禮，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是萬分抱歉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家只能在此處說──",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_093"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "儘管此次視察，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n僅有吾妹便可，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但奴家仍刻意讓默涅同行。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這也全都是",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_094"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為了向默涅展現廣闊的世界。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為了教導那女孩不受吉歐‧格黑納的處世束縛的生活方式，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n讓她的人生綻放出華美的花。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因此──",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_095"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再次",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "拜託恁了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請向",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那女孩展示恁的世界吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "感謝至極。",
        "unit_id": 129711,
        "voice": "vo_adv_1296001_096"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家現在便開始",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "期待視察歸來的日子了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要是能稍微治好她那",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "極為嚴重的怕生就好──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──哈啾！",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_097"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "真怪，",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_098"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這噴嚏──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我沒感覺有生病",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就是了。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──這麼說來，",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_099"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n涅婭小姐好像說，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "要是有誰在談論你，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n就會",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "打噴嚏。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不過──",
        "unit_id": 129612,
        "voice": "vo_adv_1296001_100"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這是",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "迷信吧。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "安涅默涅──身為吸血妖花遭人覬覦，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因而警戒心變得很強。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這位少女，將從這次視察中獲得的收穫是──？"
    }
]