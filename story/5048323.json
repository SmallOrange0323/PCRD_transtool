[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 113711,
        "voice": "vo_adv_5048323_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "魔、",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "魔力怎麼又提高了啊……？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊、",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能要撐不下去了……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "振作一點！",
        "unit_id": 113811,
        "voice": "vo_adv_5048323_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽好了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對方的魔力確實高得驚人。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "老實說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "光是被那股魔力擊中，就有可能昏厥過去。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811,
        "voice": "vo_adv_5048323_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對方面臨的也是一樣的絕境。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n他也是被逼到窮途末路",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才會做出垂死掙扎。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只要熬過眼前的難關，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "勝利就在我們手中了！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 113711,
        "voice": "vo_adv_5048323_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "來，",
        "unit_id": 113811,
        "voice": "vo_adv_5048323_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓我們握著彼此的手。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們兩個要守護好拉菲和蘭德索爾！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嗯！",
        "unit_id": 113711,
        "voice": "vo_adv_5048323_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們上吧，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會給姊姊",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一～大堆勇氣的！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也會",
        "unit_id": 113811,
        "voice": "vo_adv_5048323_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "把永不挫敗的強韌決心",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "託付給茜里的！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "蘭德索爾的雙胞胎美少女天使！",
        "unit_id": 113711,
        "voice": "vo_adv_5048323_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就在這裡，",
        "unit_id": 113811,
        "voice": "vo_adv_5048323_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們不會輸的！",
        "unit_id": 113811
    }
]