    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……而且在喪失記憶之前的{player}，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似乎還有著其他重要的伙伴呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許在那些伙伴之中，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也有喜歡{player}的人也說不定呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟{player}，可是這麼的帥氣呢。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可不能做出像是橫刀奪愛一樣的舉動。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果有一天你找回了記憶，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是願意和我這麼親近……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果你也有那個意思的話，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到那個時候",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再親可以嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如此溫柔的{player}……",
        "unit_id": 105813
    },
    {
        "type": "still",
        "still": "201100604"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明這麼弱，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使戰鬥到傷痕累累，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也還是願意來救我的{player}。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是王子一樣的你，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再一次喜歡上你嗎？",
        "unit_id": 105813
    },
    {
        "type": "still",
