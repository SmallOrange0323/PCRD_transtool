[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "真的",
        "unit_id": 711,
        "voice": "vo_adv_2011006_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "不用前往地下監獄",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "也沒關係嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n尾狗刀副團長？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯。",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那邊我會想點辦法來處理，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n大家就往",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "『王宮』的深處去吧～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那裡是『陛下』坐鎮的神域唷，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不優先防禦不行呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "歷史悠久的『王宮』",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "竟然被賊黨入侵了呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這可是",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "前所未聞的一大醜聞呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如果『陛下』有個萬一的話，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可就完蛋了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們全部的人，",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如果為了負責，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "掉個小腦袋就好的話簡直要謝天謝地了……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一個弄不好的話",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "國家就會從根本被人給推翻唷？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你們也不希望吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "而且。",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果真要為國家送上這條小命，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "當然也想光榮的死在戰場上嘛～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你們說呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "是的！",
        "unit_id": 711,
        "voice": "vo_adv_2011006_005"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "　您說的對，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n的確從深處也有傳來賊黨入侵的情報！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n該優先前往的應該是那裡對吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "全員，行動！",
        "unit_id": 712,
        "voice": "vo_adv_2011006_006"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n『陛下』的貴體就由我們來守護！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊哈哈。",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真老派呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過唬弄起來很簡單就是了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊～啊……",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如果被抓包了，我可真的要和腦袋分家了呢，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n怎麼想都是反叛的行為嘛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我也不打算被殺掉，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這工作不是做得很上手，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果被免個職反而還比較開心呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "【王宮騎士團】……",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所謂「正義的伙伴」，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我還真不適合呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "趁著現在『王宮』內部一團亂，",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我還是早早開溜吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "稍微低調一點行事，",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n專注在自己想要調查的事情上吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "為了防止洗腦魔法，",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n對自己的頭腦下了各式各樣的抵抗魔法呢……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也因為這樣，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不自然的記憶接二連三冒出來了呀。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就先沿著這條線索找吧。",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "傻傻的被蒙在鼓裡，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "被人耍得團團轉可真不是滋味啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "只要是人類不管是誰，",
        "unit_id": 106211,
        "voice": "vo_adv_2011006_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算是壞蛋也是有尊嚴的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n傷害、嘲笑、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "踐踏著他人尊嚴的那些傢伙，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "才是我們的敵人嘛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒錯吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牢房的鎖已經順利打開了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您趕緊到外頭來！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……貪吃佩可小姐？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請盡快！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡是『王宮』，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說到底依舊是敵陣之中！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再拖延下去的話，",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n出現新的敵人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擋住我們脫逃的路不就糟糕了嗎！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿……",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣子呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明你們千辛萬苦的把我救出來，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回程的時候被抓到的話就全都白費了呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一安心下來",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的腿也軟了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是的……",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還真拿您沒有辦法呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過。",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒什麼大礙真是太好了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很謝謝妳唷，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有{player}……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我呀，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這一次",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大概也覺得真的沒救了唷。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這種真的很糟糕的狀況，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『很不妙呢』",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種話反而說不出口呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呀啊呼！？　",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚇我一跳！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然把人家抱住可是不行的唷～{player}。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "立場相反了呢。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n平常的話，明明都是我先問",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『我可以抱抱你嗎？』",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種話的。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後等別人說OK了，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才會興高采烈的一頭栽進去",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "緊緊抱住人的呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸、",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實就算",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用每次都問。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你們也",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一次都沒有拒絕過我就是了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是啊，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一直都很不安。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我呀，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所有全都被人給奪走了……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "父親、",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "母親，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是平穩的日常……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所有的東西，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都一點也不剩地被人給奪走了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我很害怕……",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每一次，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當我開口確認的時候",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都很害怕。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想著「如果是」",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是被拒絕了的話該怎麼辦呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果就連你們，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都把我給忘記了……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像是陌生人一樣拒絕我的話，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可能就再也撐不下去了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是你們給了我再一次，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能夠和最喜歡的人們圍在一起吃飯的機會。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n給了我那早已被奪走的，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幸福的日常。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}、",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿、",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【美食殿堂】的大家，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給予了被奪走所有而窮途末路的我。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃佩可，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼棒的一個名字……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一次又一次的這樣喊著我，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還願意和這樣的我一起吃著美味的東西。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你們願意這麼做，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的非常開心。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幸福到不能自己……",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很害怕會不會連這些也被奪走。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明就算真的發生了也一點都不奇怪呢。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你們把自己",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "弄得傷痕累累……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算拼了命",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是願意來拯救我呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝。",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的非常的謝謝，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你們！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的真的，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最喜歡",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們了……☆",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以這麼想嗎？",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可以把你們當成我最重要的伙伴，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後深深愛著你們嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種事真的可以嗎，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使是我？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有什麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以不可以。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也不需要",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再做確認。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要深愛著某人、",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要怎麼樣的幸福，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有必要這麼客氣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是這樣的吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您看、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他也",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "點頭如搗蒜般地同意了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n實際上，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是連如同在下這般的孩子都明白的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "理所當然的事呢。",
        "unit_id": 105911
    },
    {
        "type": "still",
        "still": "201100601"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呀！？",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哇哇，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼突然要做什麼……{player}？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "臉靠得這麼近……",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是想親我嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是要親我了嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "救出了被囚禁的公主的王子，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當然",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有這個權力就是了？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您冷靜一點，",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎只是想要替您擦拭眼淚的樣子。",
        "unit_id": 105911
    },
    {
        "type": "still",
        "still": "201100602"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇？　",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好丟臉呀！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我竟然哭出來了呢～",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像個小孩子一樣……♪",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說的也是呢。\n畢竟是那個{player}嘛，",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n誤會了的我真是個笨蛋。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2011006_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果兩位真的想要接吻的話……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會識相地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "撇開視線的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請兩位在這段時間內完事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不不不！　",
        "unit_id": 105813,
        "voice": "vo_adv_2011006_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然要對喪失記憶的\n{player}做出",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這種事的話，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就像是欺騙了一個什麼都不知道的小孩子一樣",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會良心不安的唷～？",
        "unit_id": 105813
    },
