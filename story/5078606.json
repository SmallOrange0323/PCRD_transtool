[
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "閉会式か……",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あのときも色々あったな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "そっすね。",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_001"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nトンチキ案件てんこ盛りでしたね。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "アレがあそこでコレしたり、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ソレがこっちでナンだったり。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "指示代名詞ばかりで",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "要点の定まらぬ陳述だな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "通称ふわっとしてる。",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_003"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "いや、一応気ィ遣ってんだけど。",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_004"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あんま思い出したくないでしょ、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nチエルが逃げ出したり",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ユニ先輩の粘土像が暴れたりとかそんなん。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そんなことありましたっけ？",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "はて、",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "とんと覚えておらぬが。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "最後のライブで、",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_007"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nクロエ先輩が意外とノリノリだったことは覚えてますけど。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうだな。",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_008"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nクロエ君が意外と華麗なステップを踏んでいたことは覚えている。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "アレいつ練習したんですかね。",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_009"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なんとなくアドリブで、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ってレベルじゃなかったですよね。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あ？　",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_010"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんだ？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nうちが夜中に用途不明のフリをコソ練してたら問題あんのか？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ああッ？　てめ、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "やんのかコラ。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "やんならやんぞ、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "表出ろコラ。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いやあ、",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_011"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なんだかんだ言っても楽しかったですよね、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "テレフェス。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "シカトしてんじゃねえぞコラ。",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_012"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nやんならやんぞ、",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "かかってこいコラ。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "また来年も",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_013"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "みんなでちぇるっとフェスりましょう！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "なかよし部は永遠に不滅です！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうだな。",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_014"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nユニちゃんズは永遠に不滅──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "──あれ？",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_015"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nちょっと待って。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "来年ぼく卒業してない？",
        "unit_id": 116411
    }
]