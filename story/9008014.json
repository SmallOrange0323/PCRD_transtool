[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗨～♪",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n愛梅斯大人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再次登場囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天我向導播要到了",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很～充分的時間，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要來徹底聊個夠囉！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "不好意思，",
        "unit_id": 1,
        "voice": "vo_adv_9008014_002"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "愛梅斯小姐～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "\n時間並沒有到所謂很～充分……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這我明白啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "充分地、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "簡要地、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "適當地、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做出一個感覺不錯的表現就好了吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟偶爾也是會想在這種場合悠閒聊聊的呀♪",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "誰叫",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最近大家都跑出去冒險或修行，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都不太來理睬我了嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而我每天都在工作。",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一～直在工作。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "成天坐在塔裡面工作！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我說你呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不是有什麼話應該要對我說～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唔……",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不客氣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……聽你這麼乾脆地說出口，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總感覺有點鬧脾氣的自己",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎有點像個笨蛋呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也明白你們的使命，所以沒關係啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟我也是因此在努力著的呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……對不起唷？",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剛才我自己一個人在那邊鬧起脾氣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n由於最近沒什麼機會出場，讓我很寂寞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關於到新世界冒險……",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也會在此替你們加油的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n去好好表現一下吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊。",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "偶爾還是要帶點什麼伴手禮，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n回來看看我喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽到了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我們約好囉！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "愛梅斯小姐，",
        "unit_id": 1,
        "voice": "vo_adv_9008014_011"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "時間差不多……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "討厭，",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我知道了啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到此結束！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就這樣囉，",
        "unit_id": 190011,
        "voice": "vo_adv_9008014_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    }
]