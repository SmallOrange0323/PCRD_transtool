[
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束了聖誕節的視察，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "返回吉歐‧提格尼亞的萊拉耶爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了與她一起巡迴回憶之地，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}也跟著一起同行。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──終於回到吉歐‧提格尼亞了……！",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "果然，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是熟悉的地方最讓人安心。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今天一定都累了，",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士也來城裡休息吧。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "巡迴回憶之地，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "留到明天再出發。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們前往城裡──",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "萊拉耶爾殿下，",
        "unit_id": 9411,
        "voice": "vo_adv_1328004_003"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "那副模樣是……！？",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "發生了什麼事……！？",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "簡直像是惡魔一樣……！",
        "unit_id": 9311,
        "voice": "vo_adv_1328004_004"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n聖誕節",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "原來是很恐怖的祭典嗎……！？",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咦咦……！？",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請、",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請等一下，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請讓我做說明……！",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我已經完全",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "習慣這身打扮了……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n沒想到",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會引起騷動，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還真是盲點呢……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聖誕季結束後，",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "應該就會恢復成原本的樣子才對，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但看來似乎",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還會再維持一陣子……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是啊。",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然勉強平息了騷動，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但再這樣下去，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "對聖誕節的誤解會擴散開來。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "果然，",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有必要找個機會傳達正確的聖誕節訊息。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我想讓各位居民也能",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "更深入理解蘭德索爾的文化。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以嗎？",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果你能幫忙做確認的話",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那就太可靠了。",
        "unit_id": 132811
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──果然",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "象徵聖誕節的",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n聖誕樹是不可或缺的。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要重現聖誕樹，",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以用巧克力棒之類的……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不對，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "或許還有更好的點心。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "先來",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "找波波爺討論一下會不會比較好……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "感覺聖誕樹本身會被他改造……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯……",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要考慮的事情太多，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "遇到了瓶頸。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來先休息一下比較好。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n用吃點心與喝茶，",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來轉換一下思緒。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀……",
        "unit_id": 132811,
        "voice": "vo_adv_1328004_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這道光芒是──",
        "unit_id": 132811
    },
    {
        "type": "background",
        "background": "510091"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "終於",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_017"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "抵達你的房間了。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "「扮家家酒」也",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "逐漸進入佳境♪",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "親愛的，",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_018"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "振作一點啊。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "不是約好要一起吃火鍋的嗎？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "明明還一起挽著手",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_019"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "出門購物約會不是嗎。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "想起來了？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "是啊。",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_020"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n回到家前的空中散步，",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "真的很開心呢♪",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "雖然在引人注目的商店街",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_021"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "稍微引起了一點騷動，",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "但已經沒事了。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "因為",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "這裡是你的家呀。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "在這裡，",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_022"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "只有我跟你……",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "兩人獨處。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "不管做什麼，",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "都不會引起騷動。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "來吧，",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_023"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "讓我們來繼續夫妻約會。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "你想要",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "做什麼呢？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "……",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_024"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "遊戲是嗎。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "雖然我也",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "很喜歡阿斯特朗……",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "但現在先放一邊吧。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "在有限的時間裡，",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_025"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "像這樣玩著扮家家酒。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n應該做點像是夫妻會做的事吧？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "我想想……",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_026"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "那麼，",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "就來像夫妻一樣",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "詢問你吧。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "我說，",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_027"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "親愛的。",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n你想要吃飯？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "還是洗澡？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "又或者說，",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "想要我呢？",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "「咦？」",
        "unit_id": 126533,
        "voice": "vo_adv_1328004_028"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "並不在",
        "unit_id": 126533
    },
    {
        "type": "dialogue",
