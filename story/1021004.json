    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是那樣子的話就好了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可是如果身體不舒服的話要說唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天我也沒什麼急事，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_077"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n勉強哥哥來陪我真是不好意思……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫、呀……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_078"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥哥……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為什麼，要拉我的手呢……！？",
