[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥～哥……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天我們也一起，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n去買東西吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然這麼說……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可是我今天，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n並沒有特別被交代要買什麼……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我們就優先看哥哥要買的東西吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為總是讓哥哥，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n幫忙我拿買好的東西呀……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "作為報答，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果哥哥有想去的店之類的話我可以帶路喔……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然有些店的氣氛，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n讓我不敢一個人進去……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過跟哥哥一起的話，我就不怕……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥一直都幫了很大的忙呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我也在月初拿到了零用錢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果途中有看到我想要的東西，我也會買就是了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我有點想看一看，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n魔法少女鈴鈴噹的周邊商品之類的呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥不知道，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴鈴噹這個作品嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "她是以據說從前在這個國家活躍過的傳說英雄，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n來當做原型的角色呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很久之前有不知道是哪裡的劇團，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n演出了以鈴鈴噹為主角的戲劇……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那齣戲大大的流行起來，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n之後就一邊改寫登場人物一邊持續上演呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為是比較針對小孩子的內容……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以在文具、繪本、玩具等等……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小孩子喜歡的東西上常會使用鈴鈴噹的圖樣，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n周邊商品也有好多好多種唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我就是在蒐集這些周邊商品……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我從以前，就很喜歡鈴鈴噹……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這套衣服，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n還有這個鈴噹形狀的錘子，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n都是模仿鈴鈴噹的造型唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是不是有點小孩子氣呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我想變成像鈴鈴噹一樣，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "堅強又很溫柔的女孩子……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇呀！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n什什、什麼？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥全身都在發光呢……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這就好像，魔法少女在變身的時候一樣呢……！？",
        "unit_id": 102111
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥、哥哥……！",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我……！",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我、那個……！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好高興！怎麼辦……！？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔噫……！？",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚啊嗚……？",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不要用力摸我的頭……！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是想說「冷靜一點」嗎，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說出來的話我就知道了嘛……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有時候很壞心眼……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不喜歡被一直摸頭，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "況且我頭上還綁著喜歡的蝴蝶結呢……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是的，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這是之前哥哥幫我挑的蝴蝶結……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那時我買東西不太順利，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有點亂了手腳……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是哥哥，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n幫了我的忙呢。",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這是條充滿了回憶的蝴蝶結呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥說了些話後，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n感覺比較冷靜了……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃那個……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我有沒有提過，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我在國小有加入話劇社……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那是一個曾經培育出好幾位專業演員，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n很正統的社團……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也有很多很多的社員……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n明明是這樣，可是我……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "居、居然被分配到了角色……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且主題，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就是魔法少女鈴鈴噹……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我、我可以跟鈴鈴噹同台演出……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊啊，真的好像在做夢呢……♪",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝……！",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我就知道如果是哥哥的話，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一定會替我感到高興的……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為哥哥也擔心我怕生，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為我做了好多好多的特訓呢……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我能被分配到角色，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n 一定也是託了哥哥的福唷……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊哈哈……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然我其實是想，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "扮演主角「鈴鈴噹」的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是我的實力還是不夠，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以分到算是女配角吧……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總之，就是輔助角色……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過也是很重要的角色，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我會盡全力的……！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為主角「鈴鈴噹」，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有一些變身時的快速換裝場景……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對我來說，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_046"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n感覺還有點太難了呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得，全身輕飄飄的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺一點都不真實，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有現實感呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最近幾天，我都恍恍惚惚的……",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_049"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也讓爸爸媽媽，為我擔心了呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻。",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_050"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但是一直得意忘形，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也是不對的呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好不容易才分配到了角色，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_051"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要努力練習才行……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果可以的話，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_052"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n請再陪我進行特訓吧，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不不不。",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_053"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我會把票，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n寄給哥哥的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "多虧了哥哥讓我成長茁壯，",
        "unit_id": 102131,
        "voice": "vo_adv_1021004_054"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我才得到華麗登台機會……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請哥哥一定要來看唷♪",
        "unit_id": 102131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈。",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n胡桃她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n難得像這樣雀躍不已的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看到小孩天真快樂的樣子，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n連我都覺得心頭暖洋洋的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望話劇能夠成功呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也好想去看啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然你手上拿著票，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n表示你去看過話劇了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那份記憶，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可以讓我看一看嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉，我又自顧自地講話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你應該搞不清楚狀況吧，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我來簡略說明一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你醒來以後，很快就會忘記的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到時候會跟你說明的，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以現在不用太在意沒關係哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過啊，話說回來……",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "胡桃很喜歡演戲，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她還立志要當演員呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然在「這邊」，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個特質並沒有明確表現出來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我記得，她……",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像是被擔心她怕生的雙親鼓勵，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才加入話劇社的呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然而因為她的父母「消失」，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以通往演員的路就斷絕了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，那部分也逐漸在修復當中……",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "胡桃也應該，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會再次投入自己喜歡的話劇才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論是「消失」或「闇影」或其他諸如此類的，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正所有的異變，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都是在「再構築」時產生的不自然缺陷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要巧妙地移除並將之修復的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她就可以恢復正常的人生了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也會一起為此努力的。",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要加油啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說是這麼說……",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對現在的你說這些，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也沒有頭緒呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1021004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不能聊太久呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先在此失陪囉。",
