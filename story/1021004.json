        "name": "胡桃",
        "words": "咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_079"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是要我，往那邊看嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_080"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像有好多、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好多的人聚集耶……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇、",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_081"
    },
    {
        "type": "dialogue",
