    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像是為了宣傳新商品，",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_082"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以店員在Cosplay鈴鈴噹呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇、還原度好高……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_083"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那是在第三季登場的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n公主模式……！",
