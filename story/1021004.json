        "voice": "vo_adv_1021004_086"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊哈哈……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_087"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n非常喜歡魔法少女，光看到就會很興奮起來……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n看來我也就只是個一般的小孩子吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_1021004_088"
    },
    {
