[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……",
        "unit_id": 101112,
        "voice": "vo_adv_5084612_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直沒有醒呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n感覺",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "內心空蕩蕩的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥是「家人」……",
        "unit_id": 101112,
        "voice": "vo_adv_5084612_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我以為你會一直待在我身邊……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n從來沒有想過會有這一天……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5084612_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不行這樣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就算再失落也無濟於事！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是無論什麼難關都能克服的人！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這次應該也沒問題的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "身為妹妹，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我必須相信哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我得趕在哥哥醒來前，",
        "unit_id": 101112,
        "voice": "vo_adv_5084612_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n做足很多很多的準備！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就是所謂的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有備有嗨！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然沒辦法和哥哥聊天很難受……",
        "unit_id": 101112,
        "voice": "vo_adv_5084612_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我相信",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥會醒來的……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不論多久，我都會等你的哦，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……！",
        "unit_id": 101112
    }
]