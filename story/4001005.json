        "words": "正是在發生問題的時候，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n人類的本性就會盡顯無疑呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可思議的遭遇……",
