    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀～",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚～………",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "頭還是暈暈的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且感覺超想吐",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡呀！",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本小姐居然，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會被那種程度的幻覺所迷惑？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這也是沒有辦法的事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據花凜小姐",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的調查……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n盤旋在三樓的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是只有在『幻影湖』才會產生的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇妙的霧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論是多強大的魔法師、",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n功力高強的戰士、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至於高等的魔物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都會暫時被迷惑，",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是個非常恐怖的東西。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比如說一旦接觸到那個霧，",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就會把周圍的人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全部看成是敵人之類的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前仍然沒有明確的辦法去抵擋那個霧的影響，",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是個怪奇現象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼那種詭異現象",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會在我們的公會小屋三樓發生呀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是搞不懂……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個叫涅比亞的妖精，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n講的事情我也是搞不懂。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是對不起。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有{player}也是……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我因為霧的影響神經錯亂而大鬧了一番，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你沒有受傷吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很幸運的沒有受傷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請不用擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是因為凱留小姐很溫柔，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被不想傷害同伴的本能驅使……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓攻擊的魔法",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打偏了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那才不是溫柔呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你可別會錯意呦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反～正我還是個生手，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以攻擊的魔法才會打偏了吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_4001005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就當作是這樣吧……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～！",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿～！\n還有{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有那個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "涅比亞醬！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家應該肚子都餓了吧？",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在時間也差不多了，我們來吃午餐吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我因為剛剛全力使用了『皇家裝備』，",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以現在肚子已經餓扁了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我做了很多料理，",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起來暴飲暴食，吃到肚子撐吧～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不是一直都暴飲暴食嗎………",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們公會怎麼都一直在吃呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣下去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很快就會變成胖子喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈！",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稍微有點肉肉的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比較健康可愛呦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這個肚子上的肉啊～",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "軟綿綿地很有魅力呦～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我快受不了了～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好想要咬一口……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你已經完全回神過來了吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "言語動作也跟平常太像了，搞不懂呀……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_4001005_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我叫你不要一直黏著我亂碰啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我宰了你喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊哈哈。",
        "unit_id": 190811,
        "voice": "vo_adv_4001005_026"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "總是很熱鬧呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不要打鬧了，",
        "unit_id": 190811,
        "voice": "vo_adv_4001005_027"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "快來吃飯吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我也有幫忙作菜，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以份量很多喔～♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請趁熱吃吧～，",
        "unit_id": 190811,
        "voice": "vo_adv_4001005_028"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "涅比亞也請別客氣♪",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦～？",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妖精就算不吃飯，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n也沒什麼關係的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過也不是沒有那種功能，",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要我陪各位吃嗎。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯！",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起圍著餐桌，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "加深彼此之間的情感吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可是我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的信條呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起來充分滿足，",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n人類三大需求之一吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_4001005_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一來公會小屋的一二三樓，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就全部都可以使用了呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
