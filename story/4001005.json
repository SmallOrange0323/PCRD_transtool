        "words": "\n不過你拋下職務在這裡做什麼？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好像還很狼狽的樣子…",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_070"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不要緊吧？…",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n到底發生什麼事了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我一直被囚禁在那座監獄裡，",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_071"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n所以不知道現況如何。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被隔離這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對你來說也許是一件好事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吶，涅比亞。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我既傲慢又愚蠢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是卻無比可愛的妹妹……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在這個世界，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "阿斯特朗",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正遭遇著過去未曾有過的災厄。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那些被捲入這場災厄之中",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n的無辜玩家們……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就幫助他們",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "回到原本的世界吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你導引他們前進吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以「嚮導小妖精」的身分。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你在說什麼……",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_077"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我、我怎麼可能有那麼大的能力？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我可是瑕疵品，",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_078"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "根本派不上用場。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以沒人願意指派給我重要的任務，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我才會鬧彆扭，老是惡作劇。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你才不是派不上用場的瑕疵品。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你可是最新型的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只是還沒有完成除錯而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要對自己有自信。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你比任何人都還要新型，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以才會說是優秀的「嚮導小妖精」呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什，",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_081"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什麼嘛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "事到如今，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別擺出一副姊姊的姿態說話",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你過來一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓我抱抱你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "蛤？",
        "unit_id": 190911,
        "voice": "vo_adv_4001005_083"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "搞，搞什麼～……？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你啊，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是不是哪裡故障了！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_084"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許是這樣沒錯呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好溫暖呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是不可思議呢，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能夠透過與人接觸的體溫感受到幸福，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明我們原本應該沒有這種能力才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是我",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_086"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被賦予了這種能力。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得到了與人類相同的珍貴感受性，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也得到了自我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟人生。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從{player}他們的身上……",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_087"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想要報恩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_088"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我認為妳",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也獲得了和我相同的感受哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就如阿斯特朗的傳說所言，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_089"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要抵達索爾之塔的最頂樓……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抵達那個場所的人們",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠實現願望。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我呀，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_090"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是這麼希望的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……{player}他們的事情就拜託你了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_091"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要小心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這裡設置了強力的防壁，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要你離開公會小屋去到外面的話……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那你也會被「再構築」，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_092"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被現在的世界觀所污染，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後也會忘記各種事情吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以請你不要離開，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_093"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在公會小屋裡頭生活就好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒問題的。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_094"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳絕對不會寂寞，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不會感到無聊的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在我看來{player}所屬的公會，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_095"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是熱鬧到不行呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也很想要加入呢。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_096"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望有一天能夠和大家一起",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "過著熱鬧而幸福的日子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我希望不只在夢境之中，",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_097"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在現實裡也能夠碰觸到大家。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會努力加油希望有天",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_098"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能實現這夢想。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以請你也要加油呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠見到你真是太好了。",
        "unit_id": 190011,
        "voice": "vo_adv_4001005_099"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有你在真是太好了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011
    }
]