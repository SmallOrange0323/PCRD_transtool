    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_4001005_039"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因為隨便認可為公認公會的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n管理上會很辛苦呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果不分原由就提供資金，",
        "unit_id": 190811,
        "voice": "vo_adv_4001005_040"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "國庫馬上就會沒錢的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
