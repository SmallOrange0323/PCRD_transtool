[
    {
        "type": "background",
        "background": "500158"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽和{player}順利回到了牧場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但到達時太陽幾乎都已經下山了。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼～",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總覺得發生了好多意料之外的事，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n回來已經都這麼晚了啊。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在要摸黑走山路回去的話太危險了啦。",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天就先在這裡住一晚的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小事小事。",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我這裡也沒什麼好招待你的，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但食物要多少有多少的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你在這裡好好放鬆吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那麼趕快來吃飯吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天就招待你吃用牧場的乳製品",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "做出來的高級料理的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你真的很捧場耶。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看到你吃得這麼開心，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不枉我精心準備這些料理了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們這裡啊，栞栞是小鳥胃，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴又有點偏食，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n平常沒辦法煮太多。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家現在在做什麼呢……",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不知道有沒有好好吃飯？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會不會玩得太過頭了呢……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為平常都生活在一起，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "突然看不到人的時候",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就會擔心這擔心那的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想是一時不習慣吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "平常都熱熱鬧鬧的，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家在一起好像是理所當然的一樣。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一想到如果大家都不回來的話……",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我的心裡",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就會有點難過呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在有老哥陪在我身邊，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我一點都不會寂寞。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……老哥，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我知道你純粹是為了我才這麼講，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但這種話你可千萬",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不能對其他女孩子說。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不然可是會招來各種誤解，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且事情會一發不可收拾的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也不是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不願意跟你一起睡啦……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼了嗎老哥？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼突然站起來……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n咦？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼一直靠過來的啦？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種事情",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要按部就班……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊？",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說聲音嗎……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的耶，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也聽到了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這是什麼聲音？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道說是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "魔物？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你要去哪……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你要去外面查看狀況嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……我也",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一起去的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不能夠把事情",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都推給客人。",
        "unit_id": 112811
    },
    {
        "type": "background",
        "background": "500152"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "晚上果然很恐怖啦……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n如果是平常的話，栞栞和莉瑪莉瑪都會來幫我。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然頂著公會長的頭銜，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但只要沒有大家的幫忙，我就會像現在這樣，什麼事都辦不到。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我深刻感受到",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n大家的存在對我有多麼重要的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近大家實在太過努力了，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就連鈴鈴都",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很認真工作。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果連這種事",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我都沒辦法挺身解決，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就有損公會長之名的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這麼說也是。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太過逞強",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不會有好結果的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "噗哈！",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你怎麼了，為什麼突然發出牛叫聲啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道說",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你是為了讓我不要緊張嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呵呵，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的確",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是想著必須要努力，結果太過逞強了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯！",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "身為搞笑藝人，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "得隨時保持從容的笑容才行。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不然就",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒辦法帶給眾人歡笑的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "明明我比較年長，",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "卻總是受到老哥",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n提點的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔哇！",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛才是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "魔物的聲音嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那邊是動物們的……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們快點過去的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "出、",
        "unit_id": 112811,
        "voice": "vo_adv_1128003_029"
    },
    {
        "type": "dialogue",
