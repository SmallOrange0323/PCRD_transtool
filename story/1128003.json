        "name": "真陽",
        "words": "必須、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "必須要由我來守護我的家人才行。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為我可是",
