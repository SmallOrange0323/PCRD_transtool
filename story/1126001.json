    {
        "type": "dialogue",
        "name": "夫婦",
        "words": "小未央！？",
        "unit_id": 1,
        "voice": "vo_adv_1126001_029"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "在別人店門口吵架的話，",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_030"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "可是會妨礙到生意的對吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "稍微冷靜一下，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好嗎？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "……妳聽我說，",
        "unit_id": 1,
        "voice": "vo_adv_1126001_031"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "小未央。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n不只是因為特價品，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "是這個人老是——",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "沒辦法，",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_032"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我買到的特價品就讓給妳吧！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嘿欸，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "乾脆3人份全部送妳",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "拿去拿去——！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1126001_033"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "可是——",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好了，",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_034"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣就解決了。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不可以吵架囉！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你們兩個",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "一定要好好相處喔？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼就，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "掰掰——☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "怎麼行，我們不能收……",
        "unit_id": 1,
        "voice": "vo_adv_1126001_035"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "啊啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "跑掉了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "你們真幸運呢，",
        "unit_id": 1411,
        "voice": "vo_adv_1126001_036"
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "遇見小未央那樣的好孩子。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "那孩子不來阻止你們吵架的話",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "可不知道會怎樣呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "哎呀……",
        "unit_id": 1,
        "voice": "vo_adv_1126001_037"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "居然讓那麼年輕的孩子替我們著想，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n還真是做了件丟人現眼的事呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "果然拿小未央沒辦法呢。",
        "unit_id": 1,
        "voice": "vo_adv_1126001_038"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n那孩子總是讓大家活力十足，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "就像商店街的看板娘一樣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "哈哈，",
        "unit_id": 1411,
        "voice": "vo_adv_1126001_039"
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "這種說法太老派啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "\n現在不說看板娘了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "應該要說「偶像」才對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "喔喔～",
        "unit_id": 1,
        "voice": "vo_adv_1126001_040"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "這麼一說的確是呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n如果小未央成為了真的偶像，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "肯定每天都充滿樂趣吧。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊啊啊啊啊～",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_041"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "搞砸了！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "乘著勢頭就把肉送出去了，",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_042"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "晚餐要怎麼辦！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "沒有主菜，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "只準備青菜和湯嗎？　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "一點也不豪華啊！　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "到別間店重新買肉嗎？",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_043"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……不，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這可不行！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n這個月已經很吃緊了沒辦法再有意外的花費了啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "有沒有…",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "有沒有什麼好方法——",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "――啊！　",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_044"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我想到了――！！",
        "unit_id": 112611
    },
    {
        "type": "still",
        "still": "112600101"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "來吧～",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_045"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "妳們兩位，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "肯定餓了吧？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n小未央的特製晚餐，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "請盡情享用吧☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……吶，",
        "unit_id": 112511,
        "voice": "vo_adv_1126001_046"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "未央。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n這肉看起來是紫色的，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是錯覺嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊……",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_047"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那個……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對、",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是香辛料！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是香辛料的顏色啦！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n不小心一口氣放了太多就變成這樣了，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "小未央真是迷糊啊☆",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "另外這塊肉，",
        "unit_id": 112411,
        "voice": "vo_adv_1126001_048"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不覺得軟得有點詭異嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n感覺不像是動物，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "反而像是史萊姆之類的……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是、",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_049"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是錯覺是錯覺！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n大概",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "只是因為食材新鮮才會看起來像那樣啦～！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真是的～",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_050"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "兩位怎麼了呢？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n我都好好試吃過了，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "味道可是掛保證的喔？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不，",
        "unit_id": 112511,
        "voice": "vo_adv_1126001_051"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不是味道的問題……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n這些肉，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是從店裡買回來的嗎？",
        "unit_id": 112511
    },
    {
        "type": "still",
        "still": "112600102"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呃！",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_052"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我從來沒看過",
        "unit_id": 112511,
        "voice": "vo_adv_1126001_053"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "有商店賣這種肉品呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n妳去的是平常的那間店對吧？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "就是說啊。",
        "unit_id": 112411,
        "voice": "vo_adv_1126001_054"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n明明蔬菜和水果都很普通，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "為什麼只有肉……？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊――！　",
        "unit_id": 112611,
        "voice": "vo_adv_1126001_055"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊――！　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "菜都要涼了趕快吃吧――！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我要開動了～！！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "未央應急準備的魔物料理。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "姑且不論外觀，味道還是得到了好評。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而後，似乎也成為了拮据時期的固定菜色——"
    },
    {
        "type": "still",
        "still": "end"
    }
]