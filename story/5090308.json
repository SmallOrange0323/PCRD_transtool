[
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哈哈哈哈哈！",
        "unit_id": 16011,
        "voice": "vo_adv_5090308_000"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "太痛快了！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "就是這個……！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "這種令人窒息的刺激……！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n這正是我所追求的啊！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比之前都還要",
        "unit_id": 121511,
        "voice": "vo_adv_5090308_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "更強的壓迫感……！！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n腳抖個不停……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "心臟也撲通撲通狂跳……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "讓人害怕得不得了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說實話，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現在好想馬上逃離這裡……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是！　",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是現在逃走的話，",
        "unit_id": 121511,
        "voice": "vo_adv_5090308_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺會失去很重要的東西……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我必須要戰鬥……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……步未未真的是很厲害的人啊。",
        "unit_id": 121611,
        "voice": "vo_adv_5090308_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n竟然有勇氣對抗那個像是怪物一般的賭場王。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊。",
        "unit_id": 106511,
        "voice": "vo_adv_5090308_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算妳逃走了也不會有人責怪妳的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……妳真的很帥氣喔，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "步未。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是我的摯友……！",
        "unit_id": 121611,
        "voice": "vo_adv_5090308_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……賭場老頭！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "給我覺悟吧！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你會被我們怪盜團！",
        "unit_id": 121611,
        "voice": "vo_adv_5090308_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n徹底地！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "毫不留情地！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "打得體無完膚喔！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "有意思……！",
        "unit_id": 16011,
        "voice": "vo_adv_5090308_007"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "妳們就試試看吧！！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "來啊，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "賭局開始了！！",
        "unit_id": 16011
    }
