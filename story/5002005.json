    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥、哥哥……對不起……不過，就算只能放煙霧彈……嘿！",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊！？禊沒事嗎！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……就是啊，逃跑比較重要啦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊，再稍微忍耐一下！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好、好的！禊沒事的！沒事的……",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿……果然禊衝得太快了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_004"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈……哈……來到這裡應該沒事了……！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊，沒事吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒事啦……這種只算是擦傷而已。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "和禊比起來，鏡華呢？沒有受傷吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我，我怎麼樣都沒關係吧！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "當然有關係啊……鏡華在生氣嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "生氣啊！竟然這麼逞強！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我和這個人都超擔心的耶！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是，我想保護你們兩個人嘛……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不可以做這種犧牲自己來保護別人的事啦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "笨蛋笨蛋笨蛋！禊是大笨蛋！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……嘿嘿嘿，又惹妳生氣了……禊果然還是不行啊……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n好不容易以為可以和好了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我也，我也很想和好啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦……鏡華願意原諒我嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說什麼原不原諒，都是我太得意忘形才會鬧得不愉快……",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我明明知道，卻意氣用事沒辦法道歉……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊……對不起……真的很對不起！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊也是，拜託人家教自己唸書，",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n卻馬上半途而廢……今天也是惹了很多麻煩……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對不起啦、鏡華……其實禊，",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n根本不想和鏡華絕交啊……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為我很喜歡鏡華嘛。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也很喜歡禊呀！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華・禊",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5002005_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘻嘻……都已經和好了，",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊卻好像把鏡華弄哭了呢。",
        "unit_id": 100411
    },
    {
        "type": "still",
        "still": "500200401"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，對了……鏡華……這個送給妳。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_025"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？這是，杯子蛋糕？",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，鏡華說過，吃了杯子蛋糕，煩惱的事就會煙消雲散嘛。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以……因為想和鏡華和好，禊就做了杯子蛋糕。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊……謝謝妳。可以吃嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "當然呀。因為原本就是想做給鏡華吃的。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "欸嘿嘿，這樣啊……那，我就不客氣了。",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊嗯……啊，真好吃……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真的嗎？鏡華打起精神了吧？",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯……能吃到這麼好吃的杯子蛋糕，",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不管有多麼失落都能振作起來吧！！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的很謝謝妳，禊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_033"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太好了，鏡華高興起來了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘻嘻，平常老是麻煩鏡華……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真的很……謝……謝……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊？喂禊，醒醒啊……禊！！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_037"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……開玩笑的啦──！！",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_038"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n被騙了吧──！唉唷，痛痛痛",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳，妳……禊～！！還在惡作劇！！",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_039"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n過來，讓我看看妳的傷！我幫妳包紮！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿嘿，想說會不會嚇一跳嘛。",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_040"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n和那種事比起來，鏡華，那頭魔物該怎麼辦才好！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，才以為剛和好就搞這種把戲……",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯，那道光的攻擊，不想想辦法也不行吶……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是說啊，光……光……啊啊啊啊",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_042"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇！怎，怎麼了，怎麼回事！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002005_043"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哼哼哼，禊想到了哦……打倒那頭魔物的方法！",
        "unit_id": 100411,
        "voice": "vo_adv_5002005_044"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "禊想出了打倒魔物的策略。\n她驕傲地笑著，將她的戰術告訴兩人。"
    }
]