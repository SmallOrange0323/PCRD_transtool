        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "去進行屬於我們的冒險。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就只有這一點，",
