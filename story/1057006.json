[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於委託騎空團的工作量增加，\n吉塔與{player}過著相當忙碌的日子。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呼唔……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然有工作就值得感恩了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不過只有兩個人，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "果然是有點辛苦呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也沒有辦法一直承接這種工作量呢……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果不是我和你的話，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n現在一定已經兩個人一起倒下了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "──欸，",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳就是吉塔嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "現在方不方便說幾句話？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "找我？",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有什麼事嗎……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是的，沒錯哦。",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_004"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "騎空士吉塔。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n你們就是騎空團對吧？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們有話想對你們說，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "今天一直在找你們哦。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "看起來不像是……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來商量工作的事呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "沒有錯……雖然我是想這麼說，",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_006"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不過某個層面上也和工作有關呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……你們兩位，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "要不要加入我們的公會？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "原來如此。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "加入公會……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……欸欸！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "妳、",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "妳是什麼意思？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳會吃驚也是當然的。",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_008"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "首先我希望妳不要誤會，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我們不是因為你們是沒有騎空艇的騎空團，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n才可憐你們而邀請的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "啊哈哈……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真、",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真直接呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們的公會成員，",
        "unit_id": 1111,
        "voice": "vo_adv_1057006_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n人數這一陣子剛超過50人。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "5、",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "50人！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們乘坐好幾輛馬車，",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_012"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "在各地旅行承接工作。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n預計後天會離開這個城鎮。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "工作都像是討伐巨大魔物，",
        "unit_id": 1111,
        "voice": "vo_adv_1057006_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "或是護衛大規模商隊等等。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "全都是很辛苦的工作，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過因此也賺得很多。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "的確都是那種工作的話，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n報酬也會相當好呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "所以我們的工作隨時都與危險相伴。",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_015"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n正因為如此，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "選擇成員時就必須非常嚴格。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們可沒有餘力去培養沒辦法跟上的成員。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們最近非常活躍，",
        "unit_id": 1111,
        "voice": "vo_adv_1057006_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然是我們這邊自作主張，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n但我們判斷你們已經達到這邊挑選成員的標準。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們只有兩個人，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "卻做出了非常好的工作成果呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝誇獎。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "所以我們希望妳還有妳的夥伴，",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_018"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "務必加入我們的公會。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對我們來說能夠擴充戰力，",
        "unit_id": 1111,
        "voice": "vo_adv_1057006_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n而你們則能賺取更多的報酬。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想這對彼此都有好處，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳覺得如何呢？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔、那個……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n太突然了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我不知道該怎麼回覆……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不用立刻回覆我也沒關係。",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_021"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n那就下次見了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……走掉了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "該怎麼辦……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我今天就先回去了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "因為他們認真地邀請了我們，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我也必須好好回覆才行。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以讓我稍微思考一下，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "之後要怎麼打算。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就再見囉！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……唉……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n該怎麼辦呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "想不到竟然會被那麼大的公會邀請……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果和他們一起合作，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n一定能接到比現在更大型的工作……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "工作時也能到各種地方旅行，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n{player}也會比現在更好尋找，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n他記憶的線索吧……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果要實現我們的目標，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_029"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是不是解散騎空團，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "加入公會比較好……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那邊應該才是捷徑吧……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_030"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過我",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為什麼會這麼煩惱呢……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為什麼，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_031"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你會在這裡……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……謝謝。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_032"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你一如往常是個可靠的團員呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "吶，你也能陪我一起煩惱嗎……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_033"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n在這之後，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們應該怎麼做才好……",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──次日。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你們好。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_034"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "唉呀，",
        "unit_id": 1211,
        "voice": "vo_adv_1057006_035"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你們好。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n看你們的樣子，應該想好答案了呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可以讓我聽聽妳的答覆嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……是的。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我們……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我們兩個，不會加入你們的公會。",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_037"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "難得你們特地來邀請，實在非常抱歉！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這就是……",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_038"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "經過種種考量之後，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們得到的答案！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能告訴我們理由嗎？",
        "unit_id": 1111,
        "voice": "vo_adv_1057006_039"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我果然還是想和父親一樣，",
        "unit_id": 105711,
        "voice": "vo_adv_1057006_040"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "由我們自己的騎空團，",
        "unit_id": 105711
    },
