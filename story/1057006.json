        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真是太可惜了，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "像你們這樣可靠的人，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n可是非常少見的呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "吉塔",
