        "voice": "vo_adv_1057006_041"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "怎樣都沒辦法放棄……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n雖然聽起來可能很像在耍任性，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過即使如此，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這也是我的夢想……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "女性",
