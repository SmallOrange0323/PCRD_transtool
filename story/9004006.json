[
    {
        "type": "background",
        "background": "500584"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "慈樂之音的演唱會場地是下一個調查地點，\n而{player}來到此處──"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_9004006_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總算來啦～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "辛苦你了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我剛剛才在想你差不多該到了～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 105411,
        "voice": "vo_adv_9004006_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能讓我們在排練時抽出時間的人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就只有騎士先生唷？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你感到光榮吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 104211,
        "voice": "vo_adv_9004006_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然嘴上那麼說，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希還是很在意騎士先生到了沒，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n一邊偷偷瞄著會場的入口，一邊等著哦。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，千歌！？",
        "unit_id": 105411,
        "voice": "vo_adv_9004006_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我已經向公會管理協會確認過了。",
        "unit_id": 104211,
        "voice": "vo_adv_9004006_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我現在就去拿你要的文件過來，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請稍等一下哦。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102913,
        "voice": "vo_adv_9004006_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為預定下次要在大舞台上演出，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以就配合規劃，一直排練著。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且，",
        "unit_id": 105411,
        "voice": "vo_adv_9004006_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了想出能配合樂曲的演唱會表演，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們也決定要找顧問了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n希望能藉此得到",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "服裝或演出方面的參考意見。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以，",
        "unit_id": 101512,
        "voice": "vo_adv_9004006_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們這些老師就被找來囉～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要是能幫上忙，那就太好了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿嘿！",
        "unit_id": 101211,
        "voice": "vo_adv_9004006_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果要精神滿滿地替大家加油，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就包在小初音身上吧──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "上次的夏日演唱會真的棒到不行……",
        "unit_id": 102913,
        "voice": "vo_adv_9004006_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這也代表下場演唱會必須要更好才行。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎呀，",
        "unit_id": 105411,
        "voice": "vo_adv_9004006_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幸虧有和小望攜手走來，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們已經能克服大多數的難關了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 104211,
        "voice": "vo_adv_9004006_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這也是因為紡希做起事來非常認真的關係。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果有我們能幫上忙的地方，請讓我們幫忙哦？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，讓你久等了。",
        "unit_id": 104211,
        "voice": "vo_adv_9004006_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，這信封就交給你囉。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，",
        "unit_id": 105411,
        "voice": "vo_adv_9004006_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣一來，騎士先生也辦完事情了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們還要商量演唱會的排練，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要做的事情也堆積如山，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以請多加小心，趕快回去吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們會呈現最棒的演唱會給你看的。",
        "unit_id": 102913,
        "voice": "vo_adv_9004006_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n請你要",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多多關注我們哦！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "下次就在會場見吧！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}也是很努力的人，",
        "unit_id": 101512,
        "voice": "vo_adv_9004006_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要注意別太勉強哦。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果累了，就要好好休息唷～？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為了讓你幹勁滿滿，",
        "unit_id": 101211,
        "voice": "vo_adv_9004006_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要全力聲援囉──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "加油，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "加油，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要努力哦～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}得到了大家的溫暖聲援，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n動身前往下一個目的地。"
    }
]