    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了搶先找到{player}的記憶線索……\n兩名少女正在認真進行比賽當中。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這傢伙的記憶線索，",
