        "name": "秋乃",
        "words": "這樣說呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖然上次投資商品的比賽輸給我，",
        "unit_id": 103211
