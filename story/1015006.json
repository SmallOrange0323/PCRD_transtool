[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個假日。\n美里為了朗讀繪本，來到了王都。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家會不會喜歡今天的繪本呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哼哼哼哼～♪",
        "unit_id": 111,
        "voice": "vo_adv_1015006_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好～",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n怎麼了嗎～？好像心情非常好呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇！美、美里老師！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，嚇到你了嗎。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_004"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊，嗯……拜、拜拜──！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好像有什麼事情呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_007"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇～",
        "unit_id": 211,
        "voice": "vo_adv_1015006_008"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不快一點就要遲到了──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好～",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n太過著急的話會受傷的喔～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚哇！美、美里老師！",
        "unit_id": 211,
        "voice": "vo_adv_1015006_010"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你、你好！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這麼匆忙，怎麼了？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有困擾的話可以跟老師說──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "沒、沒事的！老師拜拜──！",
        "unit_id": 211,
        "voice": "vo_adv_1015006_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，好快的速度……下次的運動會肯定沒問題呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話雖如此，真奇怪呢……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n總覺得大家好像在躲著我……我做了什麼嗎。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔～嗯……雖然回想了一下，卻還是摸不著頭緒呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n但是，或許只是我沒有注意到……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀！你好～",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……太好了～你一如往常呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔～嗯，沒什麼事喔。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n比起那個，今天怎麼了呢──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好呀～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……太好了，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}和平常一樣呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔～嗯，沒什麼事喔。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n比起那個，找到了是？找老師有什麼事情──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀！怎麼了嗎牽著手……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天很愛撒嬌呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要去哪裡呢～？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n小心不要跌倒了喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，餐廳？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n難道是肚子餓了嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯～不對呢～到底有什麼呢？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_024"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "肚子不餓的話為什麼──",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_025"
    },
    {
        "type": "dialogue",
        "name": "男子、女子",
        "words": "美里老師──！一直以來謝謝你──！",
        "unit_id": 1,
        "voice": "vo_adv_1015006_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦……哎呀哎呀哎呀！",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n大、大家，怎麼回事～？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "欸嘿嘿！驚喜大成功──！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們想要向美里老師表達感謝，",
        "unit_id": 211,
        "voice": "vo_adv_1015006_029"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n所以偷偷的準備了派對！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，感謝什麼的……老師做了什麼嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為美里老師一直都很照顧我們！",
        "unit_id": 211,
        "voice": "vo_adv_1015006_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以是那個的謝禮喔！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "是大哥哥幫了我們的忙──！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_032"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n因為在村子裡準備的話就會曝光了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_033"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "去拜託店家啊，",
        "unit_id": 211,
        "voice": "vo_adv_1015006_034"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n還有幫忙點菜之類的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀、哎呀哎呀……那個，怎麼辦才好……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_035"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我，這樣的……我還是頭一次遇到這樣的事……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼會……我是因為喜歡才這麼做的……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家，真的、真的很謝謝你們。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在老師不知不覺中，大家都成長了這麼多呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "成為了能為他人著想的溫柔孩子……老師非常高興喔。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他也是……明明是個在相遇的時候吃了毒蘑菇，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_039"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n還相當亂來要挺身而出對抗魔物的孩子……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_040"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "成長了呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "至今為止，我明明是站在守護孩子們的立場，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_041"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如今卻能受到幫助、得到祝福等等……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n因為你我才明白了，被給予的那種喜悅。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "本來，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_042"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我還把{player}當作孩子般來看待，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n認為我必須要好好守護你才行呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你是個遠比我所想的還要更加堅強、溫柔的人……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_043"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "回過神來，",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_044"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n從你身上，我學到了至今為止我從未知曉的感情。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣不行呢……我明明是老師，但即使如此……",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_045"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "老師！來吃料理吧──！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_046"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n快被吃光了喔──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎、哎呀哎呀！現在就過去唷～",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_047"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真抱歉呢說了奇怪的話。來，我們一起，去吃飯吧。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "老師──！等一下讀繪本嘛──！",
        "unit_id": 211,
        "voice": "vo_adv_1015006_048"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊──不錯呢不錯呢──！",
        "unit_id": 111,
        "voice": "vo_adv_1015006_049"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我也要看繪本──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵……我，真的是個幸福的人呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015006_050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，王都的孩子們也聚集到這裡，\n派對看來變得更加熱絡了。\n這天發生的事，成了美里心中非常重要的回憶。"
    }
]