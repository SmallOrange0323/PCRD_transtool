        "voice": "vo_adv_1193003_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為有確實量過尺寸後才開始編織，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想應該會很合身。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你不用擔心！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果可以的話，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "希望你能試穿看看。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n雖說我在編織時就認為會很適合你，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我還是想看看",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你實際穿戴起來的樣子。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "尺寸",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_063"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "合身嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論是顏色還是花樣，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都很適合你呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我這做妹妹的很會挑選吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "連我自己都覺得自己做得很好！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "老實說，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我真的很想",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直和哥哥在一起……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但這並不容易。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我才會想說為你編織這些服飾，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓你穿在身上，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "代替我陪伴在你身邊！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我編織的服飾不只這些，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你全部都要收下喔，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n打工時",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "若能穿得暖和點，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣肯定",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就不會感冒了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有……",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你在打工時，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n若能不經意地",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "想到我，那就更好了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……你願意",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "穿戴這些嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的！",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明年我會替你",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "編織更多件的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……呃，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我好像操之過急了吧？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "俗話有說，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如意算盤不要打稻草嘛……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明年",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_070"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真想來",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "挑戰一下兩人的同款服飾……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣我就得再好好專研一下編織了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇啊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你在做什麼啊，哥哥……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "突然摸了我的頭。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該不會是……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "先前暫時保留的獎勵吧？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "除了那個之外，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_072"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有我送禮物給那孩子的事也……？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，你的手不知不覺地就動了起來。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這都是因為有哥哥的協助……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我能夠為她編織那麼多件禮物，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_073"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是太好了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是、",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_074"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是這樣嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被你這麼稱攢，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得怪不好意思的。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，我很高興你這麼做！",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_075"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你的手不想停下來也沒有關係！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我反倒非常歡迎呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的，",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_076"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請盡情摸我的頭吧，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥♪",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能夠",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_077"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在這棵聖誕樹下，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "把禮物送給哥哥，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我真的非常開心。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "和哥哥一起找到、",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_078"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起裝飾的這棵聖誕樹，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今天",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看起來特別漂亮呢！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果可以像這樣",
        "unit_id": 119311,
        "voice": "vo_adv_1193003_079"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直和哥哥待在一起就好了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n至少",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在這時候就好好享受一下兩人時光，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "並肩靠得比平時還要近的兩個人，抬頭仰望著眼前的聖誕樹。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而懸掛在聖誕樹上空的星星，今晚也顯得燦爛奪目。"
    }
]