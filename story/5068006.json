    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_079"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣就和好了呢……！",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「我最要好的無敵好朋友號」，",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_080"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝你……！",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n多虧了你，我們才能得救！",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "啊、",
        "unit_id": 7311,
        "voice": "vo_adv_5068006_081"
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "啊啊……",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "不用客氣……",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號！？",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_082"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "合體解除了……",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你、",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你你、",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你沒事吧？",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "我有點鬧過頭了……",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_083"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "\n因為總算能和碧直接說話太高興了，",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "不小心就……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號……",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_084"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "看樣子……",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_085"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "我只能陪妳到這裡了……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "\n抱歉啊……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒關係的，",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_086"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號。",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你今後也永遠都是",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_087"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的朋──",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "哎呀，",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_088"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "妳什麼都不用說……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "\n沒事的，",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "我都明白……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "畢竟我們心意相通嘛。",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸、",
        "unit_id": 116712,
        "voice": "vo_adv_5068006_089"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿嘿……",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說得也是……",
        "unit_id": 116712
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "我說，",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_090"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "團長……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "\n你今後也能",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "一直陪在碧身邊嗎……？",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "呼，",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_091"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "有這麼可靠的人在她身邊，",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "我也能放心了……",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "\n就麻煩你囉，",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "BB團的團長大人……！",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "再見啦……",
        "unit_id": 7211,
        "voice": "vo_adv_5068006_092"
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "碧！",
        "unit_id": 7211
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "下次再一起玩吧！",
