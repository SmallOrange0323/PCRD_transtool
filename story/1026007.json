    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那傢伙，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像拿著劍嘴裡還念念有詞……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎麼了呢，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n難道是肚子痛嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這麼說來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "曾經聽牧場的大家說過。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那傢伙，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像擁有提高夥伴力量的特殊能力。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "多虧如此，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我才變得可以……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "輕鬆地揮舞槍吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "提高、",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_048"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "夥伴的力量……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你把我當成夥伴，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n當成自己人啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得好開心啊，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸嘿嘿♪ ",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明我總是給你添麻煩呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_050"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n光是一直對你撒嬌、倚賴你、依靠你而已……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你卻沒有棄我於不顧，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n現在也依然支持著我。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好高興啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_052"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝你哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好喜歡你。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_053"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大概，",
