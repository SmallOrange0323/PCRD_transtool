    },
    {
        "type": "still",
        "still": "102600701"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "六～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "七……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n八、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "八……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "九……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我沒辦法練習揮槍100次。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "手已經舉不起來了……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【哞哞自衛隊】的訓練，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好辛苦啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好想回去牧場～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好想在溫暖的床上睡到中午。",
        "unit_id": 102611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是你。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n唷呼～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你來【哞哞自衛隊】的公會小屋做什麼呢？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就如你所見，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n正在因嚴酷的訓練而發出哀號哦……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然似乎得要提交報告書並接受訓練，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我才能夠回去牧場。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是在實力達到規定標準並獲得認可之前，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像要一直接受訓練才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我完全沒達標，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以已經受訓一周以上了哦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的老家在蘭德索爾，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因此先暫住在那裡呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "【哞哞自衛隊】的大家，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像每天都重複著同樣的訓練。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好厲害啊～已經到了搞不懂的程度了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的內心已經完全受挫了啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過【哞哞自衛隊】在獸人們的互助組織……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【動物苑】中是屬於武鬥派的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這種程度的訓練，當然也能輕易完成。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我覺得不太適合我呢……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然獸人的身體能力多半非常優越，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我不是戰鬥類型的動物嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是松鼠哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是可愛的草食性動物哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是在加入【動物苑】的時候，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有類似資質檢查的東西～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因此，我不知為何就被分配到【哞哞自衛隊】了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我想著據點離老家很近，通勤會很輕鬆，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以當時毫無怨言地被分配過來了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好後悔啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是在資質檢查的時候，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n能夠再更敷衍草率點就好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n媽媽說努力的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會為我做特製的橡子料理……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因此那時我可是幹勁十足呢～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為我是有獎勵就會發揮實力的類型。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "即使是這個麻煩的訓練，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只要有什麼獎勵的話，好像也能夠努力的感覺～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n呵呵呵，你也這麼想吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吶吶，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我會加油的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以給我獎勵吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不行？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n讓我提起幹勁嘛～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n拜託啦～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，真的嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，就努力看看吧……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是，即使是紅豆麵包也有各式各樣的哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在我小的時候呢～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有一間最喜歡的麵包店。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那裡所販賣的，特別的紅豆麵包很棒呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟其他的店家，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還有郵購買來的紅豆麵包，總覺得有哪裡不同呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其他的雖然也很美味，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但感覺哪裡不太滿足……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到底是為什麼呢，我也不知道原因啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦咦，為什麼？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然見了媽媽後確實就能加油了……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但別真的那麼做哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果讓媽媽看見我精疲力盡，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這麼丟臉的樣子，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想媽媽會擔心的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為工作太偷懶所以差點就被開除了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這我可不想被媽媽知道呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那麼，不好好努力的話就要帶媽媽過來？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那可不是鼓勵而是威脅哦～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "壞心眼！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要更加地，像在拜託客戶一樣拜託我！",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n一邊讓我的心情變好，一邊引出我的幹勁來！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吁吁、呼呼……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n邊和你說話邊練習揮槍，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都喘不過氣了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的。",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你剛剛說那些話啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不如說是在妨礙我吧～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會分心的，不要向我搭話啦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我會加油的，安靜地看著就好。",
        "unit_id": 102611
    },
    {
        "type": "still",
        "still": "102600701"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "十～",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "十一……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n咿，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼呼。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得，槍好像突然變輕了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難不成，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是手沒力讓槍掉下來了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我還握得好好的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那為什麼，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "突然變得這麼輕鬆呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不只是槍，",
        "unit_id": 102611,
        "voice": "vo_adv_1026007_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "全身都變得非常輕鬆？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
