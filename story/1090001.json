[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在周遭氣氛難得活躍起來的情人節前幾日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在市區裡時，\n被惠理子搭話了。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您總算注意到我了呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您在這個地方做什麼啊？",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在散步呀。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您問我這身裝扮嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人喜歡這種打扮的話\n我會很開心的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我是在做這次某個新藥的實驗。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n然後突然就――",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看到{player}大人在窗外，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "實在是坐立不安就……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n穿著圍裙跑來找您了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為呀。",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在我感到煩惱的時候……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人竟然會碰巧經過……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這簡直就是……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "命中註定……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我在煩惱什麼……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人也",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n對我很感興趣呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實是關於我現在在調配的藥……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n要是沒有「某樣材料」",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就做不出來。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣子拜託{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "或許有些失禮……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您能不能",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和我一起去找那個材料呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "太感謝您了，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你在我煩惱的時候出現，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還爽快地答應要幫忙我……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您就是我命中注定的那個他呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我都明白的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您裝作拒絕我，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實是打算自己去找吧？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我實在無法",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n讓{player}大人自己一個人",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "去幫我找。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也要與您同行……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "刻不容遲就出發吧……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想要的東西是……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n生長在這個高原的",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "特別樹木上。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "傳說中",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是自阿斯特朗誕生的時代開始",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就已經生長在此的神木……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想要的東西是",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "長在那棵樹木頂端的新芽……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "據說它高聳入雲，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要摘下新芽極其困難。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我調查過蘭德索爾王家中各式各樣的文獻，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是沒有查到能夠",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n確實摘下新芽的方法……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果能和{player}大人一起來，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我想或許能找出什麼好方法……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以才帶您過來的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "已經看得到那邊了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我想大概就是那棵樹。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n它比我想像得……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來得更加巨大。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "走吧，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您要怎麼做呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您打算爬上這棵大樹嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您竟然為了我做到這種地步……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還請您",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "務必小心行事……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請不要太過勉強自己了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人開始爬樹後已經過了一段時間了，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n他是否已經抵達樹頂了呢……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "已經完全看不見他的身影了，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也有些擔心……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那位是{player}大人嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要爬到樹頂好像還是有些困難呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀！",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說什麼摘不到很抱歉這種話，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還請別跟我道歉。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人根本就",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不需要感到抱歉的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "反倒是它",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然讓{player}大人感到抱歉……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n都是這棵樹的錯。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過就是棵樹……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還讓{player}大人道歉了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……對了！",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果沒辦法爬上去，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那就接近它就行了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "像這樣――！",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_034"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你這……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你這傢伙……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "快給我倒下來！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你這棵……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "結實頑強的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "樹木！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要我……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "出手的話，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還差一點就……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您為什麼要",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "突然爬上樹！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不好！",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n樹已經快要倒下來了……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人！",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您沒事吧！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您怎麼突然爬上快倒的樹……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼要這麼做。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您手上拿著的是……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "鳥巢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "裡面都是剛出生的幼鳥呢！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真不愧是{player}大人呢。",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "絲毫沒有注意到……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好可愛的幼鳥……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這些小小的幼鳥都還活著，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n實在太好了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……咦？　",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道我剛才",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n對幼鳥活了下來一事",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "覺得鬆了口氣？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "以前人們稱我「破壞者」的時候……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我從來不曾這樣想過的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也改變了呢……",
        "unit_id": 109011,
        "voice": "vo_adv_1090001_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想這大概是……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "多虧有{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管與過去的自己有所差距，\n但惠理子對這般改變莫名地感到愉快。"
    }
]