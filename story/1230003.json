[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}跟夥伴們一起戰勝霸瞳皇帝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並過了幾天後的晚上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在他像平時一樣上床準備睡覺的時候──"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡會有客人？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是誰呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你竟然會主動來這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還真是稀奇呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n天要下紅雨了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是不好意思，你好不容易才來到這裡，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但我現在正在工作，沒空陪你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請回那邊去吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你說什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……我並沒有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "告訴你來這裡的方法，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是誰教你的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好比說晶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……雖然是我自己說的，但不太可能吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那傢伙沒有教人的才能呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你稍等一下。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n等我做完手邊的事，就會讓你好好回到那邊的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個？",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我正在整理你的記憶資料。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……雖然你露出一臉要我別隨便亂弄的表情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但這只是複製資料。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣的話就能隨我高興了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正我有空，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之前整理到一半的，該說是標籤嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總之我正在進行分類標註。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你想想，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不是認識很多人嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果複製的記憶資料原封不動，就會按照時間線排序，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以我會為那些人個別製作資料夾，並進行管理喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會像這樣確認你找回了多少與誰之間的羈絆……",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼說不對啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是確認你是否有與誰加深羈絆喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你所擁有的力量，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正與羈絆一起變強。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我時不時向你展示的像夢境般的東西，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是你持續變強所需要的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為要是讓你恣意使用力量不去維護，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就會引起各種麻煩事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我會引導你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和你的力量的喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟我就算這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是你的嚮導小妖精呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你有什麼想看的東西嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡保存著你的所有記憶。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我今天就特別讓你看看吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果沒有特別想看的，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那我就從還沒整理的資料裡挑選了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想想……",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要選哪個呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是哪裡的資料？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就選這個吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開始播放。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我旁邊空著，你就坐下吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果這是約會，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就能去看個電影了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次我就用你的記憶將就一下吧──",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_018"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，開始播放的記憶內容是──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人在霸瞳皇帝的攻擊之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n全軍覆沒的場面，這是他本人並不記得的事。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚嗚……",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "變得如此滿身瘡痍……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你很努力了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經無法再繼續了啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……沒錯呢，",
        "unit_id": 106813,
        "voice": "vo_adv_1230003_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就如菲歐所說，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你真的做得很好了喔。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不僅是你，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大家都被打敗了啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡已經",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是徹底的死路，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是悲慘結局啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……但即使如此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也還有其他選擇。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓一切恢復原狀，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再重新來過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從頭開始。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然你至今所做的一切，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有締結的羈絆，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就會全部化為烏有……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但就算是那樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該也比你和大家的存在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "消失要來得好才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……你能接受嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別擔心，",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你只要",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "閉上眼睛就好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n之後我們會",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好安排的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1230003_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對不起。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
