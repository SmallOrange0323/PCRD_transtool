[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那匹馬",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又變成像是霧的模樣了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠又打算逃跑了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我早就料想到了！",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先用我的防水魔法做出袋子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n用這個把那些霧通通抓住！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真不愧是欲望魔人小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "皇家裝備火力全開！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看我的，嘿咻！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇，",
        "unit_id": 105911,
        "voice": "vo_adv_9039156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "化身成霧的聖獸",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這樣被收服進袋子裡。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我好像聽見了什麼不能假裝沒聽見的話，",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再怎麼說，1000萬盧幣就要……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n化身成霧的馬",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正在袋子裡大肆胡鬧呢！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可以鬆手嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不、",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行不行！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這樣牢牢抓緊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白了！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要抓緊是吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我緊緊抓住～～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過，袋子裡面好像越來越熱了耶？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，它慢慢膨脹了起來，像顆氣球一樣……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇哇……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_9039156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下印象中……",
        "unit_id": 105911,
        "voice": "vo_adv_9039156_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "氣體受熱後",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會膨脹。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再加上",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把袋子抓得密不透風的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以才會導致剛才那樣的結果吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼複雜的事，我才不懂啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n馬",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "後來怎麼了？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唔，",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在大概已經變成細小的塵埃了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n至於能不能恢復原樣……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看運氣吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是說，報酬也……",
        "unit_id": 105911,
        "voice": "vo_adv_9039156_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉，",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "遭受了剛才的衝擊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得一切都無所謂了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然世上沒有這麼輕鬆的事呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_9039156_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "學到一課了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "學費有點貴就是了。",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……與其花錢買那傢伙的飼料，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還不如拿去吃好料呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要大家能齊聚一堂，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪怕是路邊的野草或樹木的果實，\n都會是一頓佳肴的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快打起精神來吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……就是這樣！",
        "unit_id": 105811,
        "voice": "vo_adv_9039156_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看看，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個魔物肉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我看見它在那裡滑溜滑溜的蠕動",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就把它抓起來加工了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起來弄成炙燒吃吧！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_9039156_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我早就料想到了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我還是討厭魔物肉啦～～～！！",
        "unit_id": 106011
    }
]