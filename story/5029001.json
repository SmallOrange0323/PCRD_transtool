        "voice": "vo_adv_5029001_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不用像平常一樣牽手，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n或擁抱啊",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……還是有點寂寞呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "！　",
        "unit_id": 111711,
        "voice": "vo_adv_5029001_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身在說些什麼啊！？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快忘掉！　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那不過是妾身一時糊塗而已！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我說{player}！　",
        "unit_id": 111711,
        "voice": "vo_adv_5029001_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你為什麼要摸妾身的頭！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身可是你的主人喔！？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說你清楚？　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……那就好。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了！",
        "unit_id": 111711,
        "voice": "vo_adv_5029001_032"
    },
    {
