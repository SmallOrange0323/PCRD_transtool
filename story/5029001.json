        "voice": "vo_adv_5029001_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛剛那首歌？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你是說宮子剛剛在唱的那個？",
