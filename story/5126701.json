[
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}請凱留教他讀書，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這一天兩人也於放學後留在教室念書。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺不錯。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你明顯有進步了呢。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n哎，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟我的教得很好，這也是理所當然的吧～♪",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還有什麼不清楚的地方嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "數學？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我看看……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦哦，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那道應用題，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在歷年考題中常常出現呢。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是所謂的陷阱題喔。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你等一下。",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我課本上有筆記……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對了……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的課本借鈴奈了，還沒拿回來……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎，算了。",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正還有你的課本嘛。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這一頁……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下面有寫對吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這道公式",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要運用出現在稍微前面一點的這……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呀啊！",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你不要突然擅自翻頁啦！",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "手指！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然被碰到",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會嚇一跳欸！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "距離好近！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肩膀！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要靠在一起了！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還在耳朵旁邊提問！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "臉……",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "臉好近……！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼還能聽到這傢伙的呼吸聲……！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底是怎樣！　",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不……",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不如說，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼我的心跳會這麼快啊！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過是臉靠得很近而已，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至今為止也碰過好幾次了啊……！　",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是因為那個……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是情境不好啦！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放學後",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "兩人獨處的",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "教室",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算不想要也會變得酸酸甜甜的……！！　",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！！",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "離我遠一點啦───！！",
        "unit_id": 127214
    },
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是因為把課本借給鈴奈才會變成這樣……！",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我明天一定要去找她抱怨！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開心！？",
        "unit_id": 127214,
        "voice": "vo_adv_5126701_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才沒有開心呢～～～！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滿臉通紅的凱留，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的聲音傳遍了夕陽下的校舍──"
    }
]