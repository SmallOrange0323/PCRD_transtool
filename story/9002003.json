[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "手裡拿著神祕書本、來到王宮正門前的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}──"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀，",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我聽說了唷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "配送辛苦了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這本書就是那個……",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，沒事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我這邊的事啦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不要在意。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼接下來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就把它交給他們兩個吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智！茉莉！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "麻煩妳們了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "了解是也！",
        "unit_id": 100511,
        "voice": "vo_adv_9002003_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "用跑的會跌倒啦，",
        "unit_id": 103711,
        "voice": "vo_adv_9002003_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在她們回來之前，",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "稍微聊一下吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在這個王宮的正門前，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "與和你度過的那天一樣呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你還記得嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我沒發現你迷了路，",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一個人一直喋喋不休，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還一起拍了照片。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "300200301"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也有在王宮中",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被小克莉絲捉弄過呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n頭盔被你拿走過……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在回想起來",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還是覺得很丟臉啊……",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這些全都是所謂的「回憶」呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是你",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "與我們之間的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "和你",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "已經相處很久了呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這個事實，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我覺得很幸福唷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "打從心底的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純。",
        "unit_id": 103711,
        "voice": "vo_adv_9002003_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我和小智姐一起",
        "unit_id": 100511,
        "voice": "vo_adv_9002003_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "回來了是也──！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳們兩個。",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "書本還給你。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "另外，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是下一個配送地點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼",
        "unit_id": 104711,
        "voice": "vo_adv_9002003_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "路上注意安全。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今後也多多指教，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下次再見了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【王宮騎士團】諸位成員的目送下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}出發前往下一個配送地點。"
    }
]