[
    {
        "type": "background",
        "background": "509012"
    },
    {
        "type": "background",
        "background": "510101"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "名為「蛋糕」的西方甜點，",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_000"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "外觀如寶石箱般",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "燦爛華麗。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n種類繁多，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "數量亦是，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "教人目不暇給。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "若",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "能與情人穿梭其間，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "雖煩悶卻",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "也愉快……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "是吧，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "恁？",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "呵呵呵……",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_001"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "正是，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "正是。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "「過生日就是",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "要吃草莓蛋糕」，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "既是管事先生推薦，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "雖然「整個」份量大",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "，但年輕人的腸胃",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "想必毫無問題。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "沒錯──",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_002"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "此番情境",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "恰似夢中夢，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "實在古怪至極。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "正因如此，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "才會想享受享受現世的「生日」。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n畢竟在俗世，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "眾人總將奴家",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "視為金枝玉葉般",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "崇拜。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "況且，",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_003"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "若能得騎士閣下的祝賀，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "沒有比這更勝的喜悅──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "縱使經歷無數歲月，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "此也乃與眾不同的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "大喜之日。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "非常感謝騎士閣下。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "真沒想到──",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_004"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "騎士閣下",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "仍是如此口才了得。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n隨著除夕夜深，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "寒意更甚。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "不如攜手，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "趕緊踏上歸途。",
        "unit_id": 129731
    },
    {
        "type": "background",
        "background": "510083"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "嗯……",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_005"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "要在這「蛋糕」上",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "插上與奴家歲數",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "相同的蠟燭？",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "如此美麗的外觀，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "若成針山，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "實在有損風雅，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "應適度即可。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "至於",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "點火之後──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_006"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n心有所感，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "難以言喻──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "不，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "這正是",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "所謂的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "「氛圍」吧……♪",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家才要",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_007"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "深表感謝。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "吹熄蠟燭時的……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "心底雀躍，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "實在令人羞赧。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "幼童翹首以盼，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "實乃理所當然。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "再加上，",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_008"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "於微光下映照的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n恁的笑臉──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "多麼惹人憐愛啊，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n感覺如獲至高無上的獎勵一般。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "那麼，",
        "unit_id": 129731,
        "voice": "vo_adv_4010232_009"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "騎士閣下。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "先共享這塊「蛋糕」和",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "蕎麥麵──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "之後，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "再跟奴家攜手",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "前往跨年參拜吧。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n願明年",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "也能如今日",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "這般，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "與恁共度──",
        "unit_id": 129731
    }
]