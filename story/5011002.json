    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔著料理台互相對峙的靜流與惠理子。\n兩人之間飄散著緊張的空氣。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個時刻……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "終於來臨了呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳看起來挺從容的嘛，",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那當然了……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我今天就可以",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n擊潰纏在{player}大人身邊的煩人蒼蠅了呀！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵～",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來妳",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還沒有明白今天會和{player}分別的人",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是妳自己呢？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哦哦，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在對決開始前雙方就已經展現出驚人的魄力！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "互相瞪視的兩人，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要擲骰了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能投飛犀牛的人",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不就是超級大力士嘛？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n真的有那種人嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以投犀牛的人是大力士呢！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過這裡說的骰是指骰子，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "請別誤會了。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是這樣啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……璃乃當主持人真的可以嗎？",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸？　",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為什麼這麼問？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和靜流是熟人吧？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就算兩個人一起上，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也沒問題。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "反正今天會獲勝的人是我呀……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天是主持人啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以比賽的立場是中立喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，是喔……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話說回來，妳……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "似乎",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "稱呼自己",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n為{player}大人的妹妹呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的確是這樣沒錯啦？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不　可　饒　恕　！",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸欸……",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不僅有個自稱姐姐的臭蟲在，",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n居然還有個自稱妹妹的渣蟲！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人的周圍",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n總是會聚集些奇怪的女人呢……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可憐的{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n惠理子馬上就會替您剷除壞蟲的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n……請您稍等一會喔。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳好像",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很小看我的樣子，但我不會讓妳得逞的！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是{player}的姐姐，",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以讓重要的弟弟開心那是當然的吧？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就是",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "身為家人的姐姐身負的使命啊。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是我的戰鬥，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我會一對一打敗妳的！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯沒錯！",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我也一樣，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "身為一個妹妹，讓哥哥開心是理所當然的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就算是姊妹也同樣是情敵！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳、",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳說家人！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳們明明沒有血緣關係，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是莫名其妙……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳們利用那位大人的溫柔，",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "擅自自稱為那位大人的姐妹，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "藉此接近他……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是厚臉皮！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚……",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n惠理子選手的視線真刺人，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是時間已經遲了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "趕快開始比賽吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "規則很簡單！",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要在限制時間內做出巧克力",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓哥哥吃就行了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓哥哥覺得好吃的那一方",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是勝利者～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，忘了說……",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等比賽結束後，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "觀眾們",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也能夠試吃喔〜",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卯足勁上吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開始料理！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 109111,
        "voice": "vo_adv_5011002_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "兩人都在料理台上擺放了材料，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n順利地著手進行作業！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是否成為名留青史的一戰，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為人熱議的知名勝負之序章呢！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……！？",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊――糟糕，",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "惠理子選手在這時，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n掉落了一粒細心處理的",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開心果啊～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這失誤太沉痛了！",
        "unit_id": 101112,
        "voice": "vo_adv_5011002_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "惠理子選手，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是否能挽回損失的時間呢！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為何……",
        "unit_id": 109011,
        "voice": "vo_adv_5011002_038"
    },
    {
