    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ハロウィンの定番っていたずらですよね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "トリックオアトリート、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "って。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "騎士さんはどんないたずらしてみたいですか？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "…………いきなりなんですか？",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ああ、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それがいたずらのつもりだったんですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ずいぶんとかわいらしいいたずらで済ませるんですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ふふっ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それ別にハロウィンっぽくないですけど……",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "よく落ちてるから？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n騎士さんには猟師の知り合いでもいるんですか？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "あんまり猟の邪魔しちゃダメですよ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それはいたずらされないためにすることですよ。",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "はぁ……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いたずらするって考えが最初から無いんですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "まったく、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "筋金入りのお人よしですね。",
        "unit_id": 113911
    }
]