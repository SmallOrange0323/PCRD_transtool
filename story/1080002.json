    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了成為更好的度假村，接下來該做什麼呢。\n美冬正在煩惱。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔嗯──",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "料理的問題是解決了，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但這樣子還不夠啊……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯──",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯──",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能成為話題的……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "令人想再來一次的……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n嗯──",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯──",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "非到這裡來不可的服務……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，早安。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}也起得真早呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你看到我在抱頭苦思嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是嗎，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "讓徒弟看到難為情的場面了呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是關於這座度假村的事。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要更加……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "更加，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "該怎麼說才好呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想要有夏日風情的體驗！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個嘛。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡是度假村……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對吧？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我在構思籌備只有在這裡才能獲得的體驗。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而那份體驗，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "得在住客的旅程結束之後建立口碑，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n成為話題越傳越廣，這樣才好。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還沒發現什麼特別好的方法。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼，突然抓住我的手……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n等、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等等，你要帶我去哪裡啊？",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真舒服的風。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣可以轉換心情呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n原來你是想讓我透透氣啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幫大忙了，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "把腳踩進水裡，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "聽著海浪聲就會讓心情開朗了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n海真是不可思議……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "跟{player}一起到外面來果然是對的。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n光是在那裡嗯來嗯去喃喃自語，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "當然想不出什麼好主意啦。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要是有快樂、好玩、又有療癒感的主意就好了。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n畢竟是度假村，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還是要令人雀躍期待才行。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這片海",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是這麼地美好，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不知道有沒有……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n能傳達這個意象的方法？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "什麼啊，這麼直接的回答！？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有的！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "絕對有的。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我絕對不會放棄喔！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要事能一直住在這裡的話，那樣是也不要緊啦……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}可以嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一直跟我待在這裡。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "剛剛那句話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒有別的意思啊！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我只是想表達非得做出成果才行而已！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好主意，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "到底藏在什麼地方呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "當然了。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "畢竟立下目標，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要做就得做到最好嘛。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我想讓這座旅館……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不對，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我想將這片海打造成最棒的度假村啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼、呼呼呼……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔呵呵呵！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n等、等等……！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "剛剛那可不是需要你裝傻的話題喔？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n唔呵呵……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "實在、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "太癢了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n搔我癢的，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不是{player}嗎！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是什麼在弄我的腳……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼了？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "突然蹲進海裡。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我的腳底有什麼？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哇，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好透明的小魚。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "居然有這麼多……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n遠遠的看不出來啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "呀♪",
        "unit_id": 211,
        "voice": "vo_adv_1080002_026"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "又聚過來了！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊，",
        "unit_id": 111,
        "voice": "vo_adv_1080002_027"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "舔舔魚？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "今日好多啊。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 211,
        "voice": "vo_adv_1080002_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "突然被舔到會嚇一跳。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "但是好像有點舒服。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哦……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "他們說的舔舔魚，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是這種小魚啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "突然讓人腳底發癢，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真像喜歡惡作劇的小孩。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然嚇了一跳，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是還蠻舒服的，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是嗎……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是這個！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是這個啊！！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "馬上回來，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_032"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等我一下下──！！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "久等了！",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_033"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我向漁夫們借來了網子！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你問我想做什麼？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_034"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要用網子來撈舔舔魚！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "然後，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_035"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "營造有夏日風情的體驗！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不是要抓來吃的唷？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n真要說起來，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們才是被吃的那一邊呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總之這種舔舔魚，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n會帶給我們全新的體驗哦！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後──"
    },
    {
        "type": "dialogue",
