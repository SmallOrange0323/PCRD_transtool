        "unit_id": 1211,
        "voice": "vo_adv_1080002_038"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這好讚喔♪",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊哈哈哈！",
        "unit_id": 1111,
        "voice": "vo_adv_1080002_039"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然很癢，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是很舒服啊～這樣！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這樣子能讓腳皮光滑真是太棒了～！",
        "unit_id": 1211,
        "voice": "vo_adv_1080002_040"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "等回到蘭德索爾，",
        "unit_id": 1111,
        "voice": "vo_adv_1080002_041"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一定要告訴大家才行啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嘗試在旅館旁邊設置美體設施，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "評價反應很好呢！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "進行很順利啊！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個「舔舔療程」！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一面享受被舔舔魚搔癢的獨特體驗，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_043"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n一回過神來腳皮也變得光溜溜！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "用舔舔魚作發想的療癒系玩偶──",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_044"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n「舔舔娃娃」的銷售額也是順利成長中，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n能趁這股風潮變成這個度假村的吉祥物呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為口碑而來的客人也可以期待……",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_045"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看來發展跟當初設定的目標是一致的啊！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵。",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_046"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然商業的命脈就是速度！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n靈光一閃",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就馬上實行！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你不覺得這就是成功的祕訣嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你覺得很像我嗎？",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_047"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能被徒弟這麼評價正是我的心願呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為了不讓身為徒弟的{player}看到我出醜，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_048"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n以後也得好好努力才行。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就這樣，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_049"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們這一件工作也辦完了，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們也試試看吧？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "舔舔療程。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "光著腳，",
        "unit_id": 108011,
        "voice": "vo_adv_1080002_050"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "把腳放進水槽裡，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n腳皮會變得光滑，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
