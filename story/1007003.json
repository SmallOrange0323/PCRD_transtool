    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我們去了好幾個地方，",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n但是都沒有人認識宮子來的～",
        "unit_id": 100711
