        "type": "dialogue",
        "name": "宮子",
        "words": "結果宮子還是，",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n不知道變成幽靈以前的事來的～",
        "unit_id": 100711
