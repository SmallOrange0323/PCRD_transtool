        "voice": "vo_adv_1007003_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為什麼要問那些事情來的～？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……只要想起臨死前的事情，",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n或許就能知道宮子變成幽靈的理由？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哼嗯……的確是讓人有點在意來的～",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那我們兩人一起調查一下，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子怎麼會變成幽靈的吧～♪",
        "unit_id": 100711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯……",
        "unit_id": 100711,
