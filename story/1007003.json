    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n超開心的～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "雖然不記得臨死前的事情，",
