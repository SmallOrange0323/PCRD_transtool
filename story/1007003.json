        "voice": "vo_adv_1007003_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子自己也不清楚來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……死掉以前的事情？",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這個宮子也不記得了喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你突然怎麼了？",
