    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子想到了～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007003_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子飄上去～",
