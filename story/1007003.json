        "voice": "vo_adv_1007003_027"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n只要能和你在一起，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "什麼都好來的～",
        "unit_id": 100711
    },
    {
