        "voice": "vo_adv_1007003_026"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n明天也要一起玩喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算不知道變成幽靈的理由，",
