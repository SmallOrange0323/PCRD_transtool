[
    {
        "type": "background",
        "background": "501460"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在依里"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將禮物跟感謝的話語\n送給{player}的隔天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人再次為了天使的工作一起行動。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "來、",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "來吧！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n今天也是",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "天使！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要全力當天使喔！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一二",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "三，",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "加油～！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～啊～我辦不到～～！！　",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才隔一天，",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我根本就不敢面對他啊！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n昨晚也完全睡不著……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說回來，",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "把那個玩偶送出去後，",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n他不就能隨時聽到我的聲音嗎？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "昨天的我",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼沒注意到這件事啊～！　",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦！？",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就、",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就是說啊！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n可能因為睡眠不足，現在有點亢奮呢！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊哈哈哈哈！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "疲勞並沒有累積下來，你不用擔心！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在也只覺得太陽有點耀眼……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦，",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "奇怪？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太陽的光",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有那麼強嗎？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不對，",
        "unit_id": 124112,
        "voice": "vo_adv_1241004_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這也太強了吧！？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n熬夜是這麼危險的事嗎？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呀啊啊啊～～！！",
        "unit_id": 124112
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇～～",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n聖誕特賣",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是太棒了……♪",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "無論哪款桌遊都在特價，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "未免也太慷慨了吧？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣肯定得買下來啊。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不過，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也因此多了一堆行李就是了。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在不是沉浸於感動的時候。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然都找好座位，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那就趕快點餐吧。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你想點什麼都可以喔。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你今天陪了我一整天，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且還幫忙提行李。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這就",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "當作是謝──",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咳",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咳。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這就像是打工費啦，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……啊，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過上限只有500日圓喔？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n點餐時還請體諒一下國中生的錢包。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇……",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n排隊點餐的客人",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還真多呢。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "感覺有點幸運。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你想想看，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "站在櫃台面前不是會急著想點餐嗎？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之看到什麼就點什麼，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "類似這種感覺。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但如果排隊的話，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就可以趁這段時間考慮一下。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那麼，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要點什麼好呢……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不管是讓人放心的經典餐點，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還是期間限定的餐點都不錯呢。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "目前的期間限定是……",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然大多都跟聖誕節有關呢。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n有熱巧克力、巧克力蛋糕，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n以及……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我看看？",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哦～",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖說是套餐，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但原來是四種口味的杯子蛋糕啊。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "飲料得另外點……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……等一下？",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在杯子蛋糕套餐旁邊，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是不是有寫",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「跟朋友或戀人一起享用吧☆」？　",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "戀──",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "戀人！？　",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "冷、",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "冷靜一點！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n看清楚了，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "上面也有寫「朋友」兩個字。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒錯，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這傢伙才沒有考慮那麼多，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只是講出看到的東西而已……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想得太深的話，",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "反而會讓自己丟臉。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在要冷靜地挑選餐點，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不能受到影響……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "店員１",
        "words": "久等了！",
        "unit_id": 1,
        "voice": "vo_adv_1241004_021"
    },
    {
        "type": "dialogue",
        "name": "店員１",
        "words": "\n下一位客人～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員１",
        "words": "\n您可以開始點餐了～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦？",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n已經輪到我們了？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不會吧，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還沒有決定好……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、",
        "unit_id": 102232,
        "voice": "vo_adv_1241004_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎怎怎怎麼辦……！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "天啊，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "店員滿臉笑容地盯著我看！",
        "unit_id": 102232
