        "voice": "vo_adv_1032001_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你有著很棒的信念呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n越來越深入我心了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我絕對要雇用你……\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雇用{player}大人你當本小姐的騎士。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要準備什麼，你才肯被我雇用呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
