    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我說你，",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "值多少錢呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我要雇用你當我的騎士。要多少錢，你才願意接受呢？",
