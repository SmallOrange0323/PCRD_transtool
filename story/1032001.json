[
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在溪谷採集素材時，\n見到了一位女孩。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉，真是頭痛。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我明明只是要去父親大人的房間而已……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡到底是哪裡呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算我想要問路，也沒看到任何人。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這樣的話，我連城鎮也回不去了呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀？有聲音……",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我還以為這裡沒有任何人，原來還是有人在呀。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真沒想到竟然能遇到人啊。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你在這麼偏僻的地方做什麼呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "採集素材……？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n哎呀，太意外了。如果有想要的東西，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n用錢買不就好了？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然如此，但對我來說真是太剛好啦。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你能不能",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為本小姐\n帶路到紫藤家呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？你不知道紫藤家在哪裡？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、你是開玩笑的吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "紫藤家……",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那就是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我家啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……呵呵，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說到這裡，你應該就知道了吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒錯，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我正是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那位秋乃・紫藤啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼樣呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n果然讓你嚇了一跳吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然是這樣子呢。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就不需向你說明",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n紫藤家了吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……為什麼你要轉移目光呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你……其實是不知道的對吧！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦！？　",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的嗎？\n不管是本小姐",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是紫藤家，你都不知道嗎！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真不敢相信啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說到紫藤家，",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是在整個大陸中聲名遠播的商家喔！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "然後，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "他們的女兒",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是我，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "秋乃・紫藤喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒想到竟然會有人不知道……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……咦？喪失記憶？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "若是那樣，就沒辦法了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那麼，至少請你為本小姐帶路到城鎮吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你願意接受請求嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是幫了大忙啦。在這種地方迷路，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不知會變成怎樣……你是本小姐的救世主啊。",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼，我終於回到城鎮上了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也辛苦你啦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你真是幫了大忙啦。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n父親大人正在要求我，成為「獨當一面的商人」……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "今天沒有護衛跟隨，也是因為這個原因。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果是這裡，我一個人也能夠回得了家。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，今天真是謝謝你了。祝你身體健康。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我家大概在……",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這邊吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……哎呀？你為什麼要拉住我呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？你說我正要走回剛才來的道路？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是這樣子嗎……我差點回到剛才的地方了呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實我……經常會走錯路。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然，就算是從這裡，我好像也無法獨自回家呢 ……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果可以，",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我希望你能送本小姐回家，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可是你好像不知道紫藤家的位置……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是令人頭痛……",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣下去，我永遠都回不了家呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎、哎呀？你要去哪裡呢！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不要對我見死不救啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你在做什麼呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "啊，紫藤家嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1032001_026"
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "紫藤家的話，只要從這條路往前直走就會到囉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……原來如此！　",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算你不知道，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n如果是其他人，就會知道紫藤家啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要知道路的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你也能為本小姐帶路了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……那麼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n其他人已經為你指路了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你能帶本小姐過去嗎？",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，看得到我家了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣的話，我肯定能不迷路地回到家呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是多虧了你，幫了大忙呢。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "作為回禮，你能收下這個嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這只是微薄的謝禮。",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然這個金額……頂多只能",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n蓋一棟房子吧……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是不是太少了呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？你說你無法收下？",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……多麼清高的人啊，我很中意呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你的名字是？　",
        "unit_id": 103211,
        "voice": "vo_adv_1032001_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人……",
