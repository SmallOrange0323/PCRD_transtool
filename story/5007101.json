    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家要去要很多～布丁來的～♪",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子，",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在有空嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，",
        "unit_id": 108211,
        "voice": "vo_adv_5007101_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是忍啊～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳來得正好！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不給人家布丁的話就搗蛋來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就知道妳會說這個。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "給妳吧，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是布丁。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "太棒了～",
        "unit_id": 108211,
        "voice": "vo_adv_5007101_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是布丁來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後啊宮子，",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n其實我現在正要去調查一件事……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "調查～？　",
        "unit_id": 108211,
        "voice": "vo_adv_5007101_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍好認真工作喔。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "路上小心來的～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是的，",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我希望宮子可以陪我一同去調查……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦～",
        "unit_id": 108211,
        "voice": "vo_adv_5007101_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好麻煩喔～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子現在要到街上慶祝萬聖節來的～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣啊，",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那真是可惜呢……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想說如果妳願意幫忙的話，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就有個非～常好玩的萬聖節派對",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可以邀請妳來參加呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "萬聖節派對！？",
        "unit_id": 108211,
        "voice": "vo_adv_5007101_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這種事要早點講嘛～♪　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真拿妳沒辦法，我就來幫妳吧～♪",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝妳。",
        "unit_id": 108111,
        "voice": "vo_adv_5007101_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我們就出發吧。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "根據我的占卜，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今晚可能",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n會發生很不可思議的事……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍・宮子",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5007101_012"
