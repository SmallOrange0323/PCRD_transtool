    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "クラスの子たちとか、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nうちのこと謎に恐がってンだよねー",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "え、なんでよ、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "うちのどこがそんな恐いのかな。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "顔。",
        "unit_id": 110811,
        "voice": "vo_adv_6023108_001"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なるほど、顔か。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "うん、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "顔はどうしようもない。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "生まれつきだから。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ごめん諦めて。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "えー、",
        "unit_id": 110811,
        "voice": "vo_adv_6023108_002"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "そおかな、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "そんな声してるぅ？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nふみゅう、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "自分ではよく分かんにゃいけど……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "おい。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんだその目は。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "呆れか。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "憐れみか。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "やめろ見るな。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "見るな。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あ？　",
        "unit_id": 110811,
        "voice": "vo_adv_6023108_003"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんだァ、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "てめえ……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "うちがいつそんなオーラ放った？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あんたに脅迫とか恫喝とかしたことあるか？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "言ってみろゴルァ！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n声を荒げて脅したことなんか一度もねえだろ！　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "天使だコノヤロウ！",
        "unit_id": 110811
    }
]