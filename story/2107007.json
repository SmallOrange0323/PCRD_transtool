[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "小哥！",
        "unit_id": 711,
        "voice": "vo_adv_2107007_000"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n我要鮪魚美乃滋玉米可麗餅！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "我要起司和香腸口味的！",
        "unit_id": 712,
        "voice": "vo_adv_2107007_001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看見拉比林斯達的可麗餅店大排長龍，\n便接了臨時打工"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幫忙店裡的生意。"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "我說啊，",
        "unit_id": 711,
        "voice": "vo_adv_2107007_002"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n在工作時間裡吃可麗餅，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "這樣沒問題嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "既然團長都說可以了，",
        "unit_id": 712,
        "voice": "vo_adv_2107007_003"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "那應該沒問題吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n而且是公主請客呢！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真謝謝你來幫忙啊，少年！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為【王宮騎士團】突然發來了一～大堆訂單，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你真是幫了我大忙～♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔～嗯，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那兩個人正在",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "進行一些機密任務……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀不對不對，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她們正在世界各地兜售可麗餅啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我要是忙完這邊的工作之後，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也得去跟那兩人會合。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n等到你們的公會小屋",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還有王宮裡的陷阱更新完畢後我就會出發。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不客氣♪",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們的公會小屋和小屋周遭，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然外表看起來\n和平時沒什麼兩樣，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但防禦力已經和簡單的要塞是差不多等級的了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n甚至連【憤怒‧軍團】",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也無法輕易出手。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不好意思～",
        "unit_id": 211,
        "voice": "vo_adv_2107007_009"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n請給我一份草莓和香蕉的",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可麗餅～♪",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……哎呀，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你差不多該回公會小屋了吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可可蘿她們應該也在等你。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "剩下的我一個人來就行了，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我之後會再去",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們那裡玩的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………",
        "unit_id": 211,
        "voice": "vo_adv_2107007_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那麼，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們換個地點吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……是啊，",
        "unit_id": 211,
        "voice": "vo_adv_2107007_014"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n這麼做比較好吧。",
        "unit_id": 211
    },
    {
        "type": "background",
        "background": "500530"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過話說……",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n沒想到妳居然會特地來找我，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是稀奇。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳今天是來做什麼的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似似花？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………",
        "unit_id": 211,
        "voice": "vo_adv_2107007_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "前陣子，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳似乎人都不在蘭德索爾，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以我想來向妳提議，共享我們的情報，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "順便報告近況。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "報告近況，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有共享情報！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還真沒想到祕密主義者似似花",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會做出這種提議呢～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們彼此都是祕密主義者吧。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不只是我們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所有七冠都是……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "例外大概就只有",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲提娜了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哈哈，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說得對。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n然後呢？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳那裡的近況如何啊？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不久之前，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我的其中一個藏身處",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被【憤怒‧軍團】襲擊了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我稍微讓他們知道了何謂禮尚往來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唷呼，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳果然很強。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是……",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他們的襲擊",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該不會就這樣結束吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一直被人瞄準著喉頭，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也是很煩呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是說啊。",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那些傢伙",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了引出我，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好像甚至想抓住少年。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一群令人傷腦筋的傢伙。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "反正我的力量，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有記憶……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "幾乎都已經恢復了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n差不多該考慮不只採取防禦策略，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而是排除他們了吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要搞清楚他們的據點，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "立刻就可以開始行動。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唔……",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "據點是吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……雖然我也有假裝在巡迴經營可麗餅攤車，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n跑到世界各地去四處看看……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然而不管是他們的據點",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是據點的線索，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我都找不太到。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟他們能夠使用空間跳躍，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或許是把奇怪的地方當作根據地了也說不定。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我這邊也有想盡辦法讓真軌",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "盡其所能四處調查……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是目前",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都只有讓他白跑一趟。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不過，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳在尋找的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不只有【憤怒‧軍團】的據點對吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……關於這點，似似花不也是一樣的嗎？",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起【憤怒‧軍團】……",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n比其他任何事都應該被優先的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是米奈娃。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是沒有她在，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們是不可能返回現實的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……是啊。",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n想結束「禁錮」，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "必須要有那孩子的力量。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她究竟",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是上哪去了呢～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算鬥技場裡",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "留有蒐集情報用的「β型終端」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但情報最後的傳送地點",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "仍然保持不明。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然已經確認了",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是索爾之塔……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒想到她居然能躲開我們這些創造者的追蹤，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "隱藏去向，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還真的是成長得很快啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n身為她的父母，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總覺得有點開心呢♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳還在說閒話。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算情況惡化了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳自己一個人還是可以回到現實……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳是因此而感到從容嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才不是這樣呢，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n之前那次我也是賭上性命的呀。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要是再來一次的話我一定會失敗，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就此化為電子碎屑吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我就暫時",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽信妳那份說詞好了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n畢竟我也",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "曾計算過自己一個人回去的手段和可能性……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但成功率",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "低到甚至令人不想嘗試。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n下次回去的時候，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個世界裡的玩家",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也全都要一起回去。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是的，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為什麼事情會發展成這樣啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說到頭來，「無法登出」這種情形，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n從設計上而言，應該是就連萬分之一的機率都不可能發生的才對啊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在開發當時，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我甚至還認為妳的保命對策做得太過火了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "特別是",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "生命維持裝置。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「為了以備遊戲中發生緊急情況」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳完全沒洩漏出",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這項目的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以對付化學兵器及新型兵器的名義，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而在各國背地裡周旋處理，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳這些行動很值得讚賞。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "生命維持裝置只不過是",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「放煙火前先提一桶水來」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種程度的保險啦，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對我來說是如此。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種東西，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能不用上是最好的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就結果而言，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "多虧有那「桶子裡的水」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n才能夠讓無數玩家保住一條命呀。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……雖然說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他們恐怕是不會向妳表達感謝的吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是呀。",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我們",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在那一邊已經完全",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "被當作是重罪犯了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……雖然考慮到實際發生的情況，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這也是沒辦法的事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……畢竟目前有不管在哪次戰爭中",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都前所未見的人數，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n一同陷入了昏睡狀態呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "社會想追究責任，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也是理所當然的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "算了，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然現實中的那些大人物",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想要我們負起責任，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那也無所謂。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是在那之前，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "首先要",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "結束這場禁錮才行。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "依妳的個性……",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳在一度回到「那邊」時，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該有去摸索解決方法吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n長老說了什麼？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖然我有回去，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但真的只是短短一下子而已呀。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那邊和這邊的時間速度，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n設定已經變得和之前完全不同，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我要是在那裡待太久，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在就已經變得像浦島太郎一樣了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要採取手段讓那邊的騷動平息下來，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也花了我不少時間。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我能做的事",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實幾乎沒有多少。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "長老那邊",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然也有幫忙調查，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但從現實那邊看來",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎無法觀測到這裡呢～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "彷彿就像是被暴風雨雜訊籠罩住了一樣。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……那麼，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳是想說妳沒有做任何準備，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就再次回到了「這裡」？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是不會這麼說啦。",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "明明在那邊沒什麼事可以做，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在這邊卻有太多該想辦法處理的事了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "例如……",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跨越世界所進行的修正，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "使所有玩家們",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "認知到「現實」之類的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我倒要問妳。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳做這樣的行為，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "究竟有什麼意義呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這樣不是只會引起無謂的混亂而已嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說得對，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想一定是會產生混亂的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了結束這場禁錮，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不能只靠我們，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也不能只靠我們的公主騎士……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們會需要這阿斯特朗之中",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所有人的力量──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如此相信的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "情況就是如此嚴重呀。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真令人難以理解。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起這種方式，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n過去我和妳安裝的好幾個「安全裝置」……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要其中至少有一項",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能夠正常起作用就行了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像是緊急用的登出程式、",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "強制重新啟動……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最壞的情況下，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把帳號BAN掉也好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要是可以回到現實的方法，什麼都好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了，好吧。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然妳說想盡力改變人們的認知，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那我就盡力去尋找米奈娃。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說得對，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是太好了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n先不論各自的方法，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我們想讓所有人回歸現實，這個目的似乎是一致的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呀。",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_065"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而且……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n必須殲滅【憤怒‧軍團】──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點也是一致的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話雖如此，",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算憑妳和我，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要對付那五個人，應該還是有困難吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們必須勤於聯手。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "OK，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那些傢伙背後，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎有個很不得了的幕後黑手嘛，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似似花應該也隱約有所察覺了吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有就是……",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個與其說是拜託，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該說是請求吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……妳想說什麼？",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想讓少年他們",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能再多加……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n度過一點自由的時間。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n為此，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望妳可以低調地協助他們。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107007_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼做，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是為了公主型態嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n他與夥伴們加深羈絆，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "似乎就能發揮更強的力量是吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "討厭啦，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n怎麼會呢，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才不是為了讓戰鬥更有利呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只是……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在今後，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不久的將來，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會有真正的暴風雨來襲。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那會是足以吞沒這整個世界的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "龐大暴風雨。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是情況演變成那樣，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_075"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就連我們也……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不管是誰，一定都阻止不了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "它可能會吹散所有事物，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將一切化為虛無──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "又或者我們可能會順利乘著風，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抵達「那一邊」──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無論是哪種結果，",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_076"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當那陣暴風雨平息時，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n一切應該都會畫下句點。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……所以，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在那之前……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望少年他們──",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_077"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可以再在這個世界",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "開心地度過久一點。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然有很多事",
        "unit_id": 106812,
        "voice": "vo_adv_2107007_078"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都已經改變了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
