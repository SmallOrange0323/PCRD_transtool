[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「被玫瑰選中的您，",
        "unit_id": 114511,
        "voice": "vo_adv_5054101_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "受邀參加愛的交流會」",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然感覺有點可疑，",
        "unit_id": 114511,
        "voice": "vo_adv_5054101_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但為了過一個經費充足的聖誕節，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又怎麼能夠",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "錯過這個談生意的好機會呢！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵！",
        "unit_id": 114411,
        "voice": "vo_adv_5054101_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個聲音是……",
        "unit_id": 114511,
        "voice": "vo_adv_5054101_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃！？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀，",
        "unit_id": 114411,
        "voice": "vo_adv_5054101_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "看來我們兩人",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n參加了同樣的派對呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳的目的也是為了談生意吧？",
        "unit_id": 114411,
        "voice": "vo_adv_5054101_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們就來比賽誰能夠……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "談成更多的合約吧！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 114511,
        "voice": "vo_adv_5054101_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和我嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也想看看秋乃",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "露出不甘心的表情呢！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能受到秋乃的邀請，",
        "unit_id": 114511,
        "voice": "vo_adv_5054101_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺真高興呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就像是受到了她的認同嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該怎麼說呢……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "或許是因為她是我一直很憧憬的人，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此才更令人開心吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵。",
        "unit_id": 114411,
        "voice": "vo_adv_5054101_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀無論何時都是能與我",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "並駕齊驅……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不對，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n她甚至也有超越我的時候，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是我最大的競爭對手，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也是最好的摯友。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "正因為如此……",
        "unit_id": 1,
        "voice": "vo_adv_5054101_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5054101_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "「名媛初登夢想秘境",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "　聖誕夜的戀愛遊戲」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "我可不能輸……！\n我可不能輸呢……！",
        "unit_id": 1,
        "voice": "vo_adv_5054101_011"
    }
