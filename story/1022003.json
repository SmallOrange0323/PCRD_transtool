[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "受託要收集素材的依里，\n和{player}一起來到平原。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這次受託要採集的花，應該可以在這一帶找到。",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……那個，今天你來幫我……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――不對，我才沒有說要你幫忙呢！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是你自己擅自跟來的！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我又來了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼就不能好好道謝呢……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，要道謝的話等等也可以，",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在得先集中精神在受託的事情上！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，花在……有了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我想拜託你蒐集這種紅色的花。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種花會熏眼睛，",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n採集時臉不要靠太近喔。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果不小心碰到眼睛，會痛一整天的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你問我大概需要採多少……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之公會長是說要很多很多。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你很有幹勁呢。",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那要不要來比賽啊？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我最喜歡這種比賽了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n畢竟我的興趣是玩遊戲。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們就來一較高下吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "輸的人要完全聽贏的人話，如何？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "看來你自信滿滿呢。",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過那份自信可以持續到什麼時候呢？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "已經覺得自己贏了！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我才不會輸呢！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "蒐集到比較多花的人就是贏家！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "開始囉！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……………",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "完、完全找不到……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一開始那麼簡單地就找到了，",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在卻只找到一手就能抓住的量而已……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣下去我會輸掉。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！？什、什麼，怎麼了？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……因為你採到很多，所以先搬過來！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！？你抱著的那些花全部都是！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "已經那麼多了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――沒事，才那樣的量而已啊？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我已經採集到更多了呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊……好像讓他更有幹勁了……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n真是的，我為什麼要那麼倔強！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n怎、怎麼辦！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n要是輸了，就要完全聽他的話……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚啊啊啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我真不應該說什麼要比賽！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……可是事到如今也不能喊停，嗚……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總、總之得趕快去找才行！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "剛剛好像有紅色的……！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――有了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且數量好多！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太好了！有這麼多花的話我就能贏了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n說不定還有其他群生的地方……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "趕快摘一摘，再找下一個地方！",
        "unit_id": 102211
    },
    {
        "type": "still",
        "still": "102200301"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇啊！魔物！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且牠怎麼好像在生氣……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "該、該不會……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我剛剛摘的花，是從這個魔物身上長出來的！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你……危、危險啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就算兩個人也不知道能不能打倒牠……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然想逃跑……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但那魔物很生氣，一定會追上來的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？採集來的花？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那些花怎麼了嗎……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸欸！？為什麼丟到魔物那裡去！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算這樣做，也只會讓牠更生氣吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦、咦？牠好像很痛苦……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，對喔！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "因為那個花會熏眼睛……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要趁現在逃跑吧！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n知、知道了！快走吧！",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總算是順利逃跑了呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……可是好不容易摘的花，都留在那裡了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你都好好地帶回來了啊？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我連一朵都沒有，你卻有那麼多……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也就是說，比賽是你贏了？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚、嗚……我知道了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不管你說什麼我都會聽的！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他、他會說什麼呢？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果要求奇怪的事情……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "該、該、該怎麼辦！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可、可是……跟這傢伙的話……",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "――天啊，我在想什麼啊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……欸？",
        "unit_id": 102211,
        "voice": "vo_adv_1022003_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n以後也想跟我比賽……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就、就這樣……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
