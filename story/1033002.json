[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼、呼……♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯啊、嗯啊……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "伊麗莎白～不要跑走啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯啊。\n咦、咦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我睡著了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀……\n這裡是哪裡啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～睡傻了沒辦法好好裝傻。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔？\n啊，老哥……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸，在做什麼啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥好像用攤車載著我，\n綁架可是重罪喔～？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開～玩笑的……啊～連搞笑都不搞笑了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我大概知道怎麼回事，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為我累到睡著了，所以老哥推攤車載我的吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我今天推攤車到蘭德索爾，\n在那裡賣乳製品和肉。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "回程因為太累了，所以睡著了對吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥路過的時候看到我，\n所以才推車載我的吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯吧？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此、原來如此，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不過如果是搞笑的話，猜中就不有趣了♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此～\n這樣就欠{player}一個人情了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "其實老哥只要叫醒我就好啦，\n不用特地載我……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，不過這樣我很輕鬆就是啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，我完全睡死啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在【伊麗莎白牧場】每天都很早起，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "到這個時間就會很想睡啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我好像小孩一樣，真害羞的啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "城鎮外有魔物徘徊很危險，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是神經大條地在那邊打盹可是會小命不保的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "得小心一點才行啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……可是坐在攤車裡面，",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搖搖晃晃的很舒服，讓我又開始想睡啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好像搖籃一樣～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼哈♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？\n我睡一下沒關係？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是……讓老哥送我到山上太不好意思了啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n現在上山的話，下山都晚上了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣太麻煩老哥了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的嗎？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀……老哥真是男子漢的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是靠得住啊，老哥該不會想追我吧。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對我這種小丫頭這麼溫柔也沒什麼好處的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？你說對小朋友要溫柔一點……嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我才不是小朋友啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然個子小，但已經二十歲了啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥才是乳臭未乾的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是拉著攤車上山就很辛苦的啦。\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我每次光是來回【伊麗莎白牧場】\n和蘭德索爾，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就已經累壞了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？這麼小就努力工作很了不起？",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，雖然我個頭小，但已經二十歲了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n反而是沒工作才糟糕的年齡的啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯……這裡的話，比起回到蘭德索爾，",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n去【伊麗莎白牧場】比較快。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太陽也下山了，晚上的山路很危險的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}今天就在牧場過夜吧。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n為了謝謝老哥載我回來，我會提供晚餐和床鋪的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有我最私房的相聲表演喔……！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}，我也一起來拉攤車吧。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我可是知道怎樣不費力，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就能輕鬆地移動推車的訣竅的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "像你那樣拉的話，腰可是會痛的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓我來吧，我來示範。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看，像這樣……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對吧～推得順～順順的啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哼哼。我從小就在做",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n【伊麗莎白牧場】的工作，所以很習慣了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "每天都揮灑汗水照顧牛群。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我最近才開始把商品拿到蘭德索爾去賣。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "從小到大，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我都不知道【伊麗莎白牧場】外面的世界。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有個獸人的江湖藝人團體，\n偶爾會來到【伊麗莎白牧場】……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "他們到蘭德索爾公演之前，\n會來這裡稍微停留休息。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那時候我都會拜託他們簡單表演一下給我看……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n他們的表演，好笑又有趣得不得了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對我來說，那是與外面世界相連的唯一管道，也是我所嚮往的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也想……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想要像那些江湖藝人一樣，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n帶給其他人歡笑。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "至少他們的表演拯救了我。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然，【伊麗莎白牧場】的工作很有趣，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但是生活變得多采多姿的話，會更幸福的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我努力磨練自己的搞笑能力，但實在很難的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天也一邊賣乳製品一邊表演搞笑短劇，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但只有老哥笑了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥總是像小朋友一樣，\n雙眼發亮、笑呵呵地看我表演相聲～",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很高興，嗯，應該說有被鼓勵的感覺。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果可以的話，以後也……",
        "unit_id": 103311,
        "voice": "vo_adv_1033002_038"
    },
    {
        "type": "dialogue",
