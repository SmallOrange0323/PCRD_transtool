[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在城鎮內時――"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔唔唔唔唔……果然很可愛呢……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n如果再便宜一點的話，我就買得起了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸？ 啊……是你！",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你好！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那、那個，前陣子……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n欸嘿嘿，因為喝太多而讓你看見我丟臉的樣子……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然你那麼對我說……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n如果我真的沒被討厭就好了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊、啊哈哈……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、這樣啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔呵呵。謝謝！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真開心呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你還把我帶……回家。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎、怎麼會……！ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "完、完了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你說是開玩笑……？ 完全不討厭我？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真、真是的――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n怎麼能這樣戲弄姐姐呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，你問我在做什麼？",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我在購物……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喏，你看這間護具店的飾品！",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不覺得它很可愛嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是……\n重要的是它下面標示的價錢啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這似乎只有一個，而且真的很貴……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但考慮到公會的經營，我不能亂花錢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n沒有辦法，我只能羨慕地望著它。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉……真想要啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_012"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天。\n當{player}恰巧路過護具店前時――"
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "有小偷――！！",
        "unit_id": 611,
        "voice": "vo_adv_1034003_013"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "咕嘿嘿！ 這間店的營業額，",
        "unit_id": 811,
        "voice": "vo_adv_1034003_014"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "\n我全收下囉――――！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "啊？ 你這傢伙要做什麼，想討皮痛嗎――",
        "unit_id": 811,
        "voice": "vo_adv_1034003_015"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "呃！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "謝謝你！ 謝謝你！",
        "unit_id": 611,
        "voice": "vo_adv_1034003_016"
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "\n如果這個月的營業額全部被搶的話……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "\n我們就要面臨破產了！ 多虧你的幫忙！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "我送你一件本店的商品作為謝禮！",
        "unit_id": 611,
        "voice": "vo_adv_1034003_017"
    },
    {
        "type": "dialogue",
        "name": "防具屋店長",
        "words": "\n請隨意挑一件！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，當{player}正在尋找優花梨時――"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "阿，",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……你說我看起來很沮喪的樣子？",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，讓你擔心了，對不起。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實今天……我原本想買下那個飾品。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n帶著",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "積蓄，興高采烈地去了那間店……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但飾品已經被買走了。\n雖然那是我很喜歡的飾品……卻沒有順利買到呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但這也是沒辦法的事呢。這應該就是命運的機緣吧。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個飾品一定是有男朋友的人，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n吵著要男朋友買來送給她的吧――。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我沒有命中注定的人啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "必須接受這個事實呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……禮物？ 你要送我？",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦、咦？",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這是……我想要的飾品……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、你問我『打起精神了嗎』，但問題不在這裡……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n怎麼",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "辦……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我第一次收到男性送的禮物……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "優、優花梨，冷靜一點。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼――哈――，呼――哈――……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好、好好想想發生了什麼事啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為我沒有命中注定的人，所以才沒辦法得到想要的東西……\n但、",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是他，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n卻送了我禮物……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，也就是說，他是我命中注定的王子……咦？",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦咦咦！？ 怎、怎麼辦……要和未成年的人",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n去哪裡約會才好……！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……？ 啊……也、也是呢……",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你沒有特別的意思……對吧……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……但是，這無疑是份禮物。",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的、真的很謝謝你！ 我會好好珍惜的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總之，我今晚似乎能懷著最棒的心情睡個好覺！",
        "unit_id": 103411,
        "voice": "vo_adv_1034003_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我有了非常好的回憶呢！ 謝謝喔！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "非常開心的優花梨緊抱著飾品如此說著。"
    }
]