[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，是{player}啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你好～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在牧場做什麼呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又是送信的打工？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真辛苦呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n每天都得像這樣來山上送信啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "令人佩服呦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n感覺能鍛鍊到腰和腿呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我太不常走路了，腳的肌肉漸漸在衰退。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n光是一直站著，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "腳啊腰啊就會開始顫抖。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經可說是連走回到自己房間都覺得懶的程度了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "能背我過去嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你看，我也會給你酬勞的。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n作為午飯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會給你在路邊撿來的橡子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能是因為沒有人會特地來到這樣的山上撿橡子，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n掉在地上的橡子非常多，可以吃到飽呦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊啊真的是，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【伊麗莎白牧場】最棒了♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很好吃呦～",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我敢說就算我一生只能持續地吃橡子，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也不會吃膩。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊啊但是，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也是會想吃紅豆麵包。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有吃過橡子嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真是太可憐了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這可是人生的損失哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好吧好吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我給你一個試吃看看。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你看，這就是橡子。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為了以防肚子餓，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我經常會隨身攜帶幾個喔。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把一個，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "送給{player}吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼了嗎，{player}？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n表情不太愉快呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不好吃嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，比想像中還要硬？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然也有軟一點的品種啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但我比較喜歡這種有咬勁的嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能因為我是松鼠的獸人，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n門牙相當的發達呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，為什麼要問那種事……",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊，是因為剛才拜託你「把我送到房間」了呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想想喔。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n從這裡看得見的那座大建築物中有房間，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我現在正借用了其中一間呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我是從【哞哞自衛隊】派來的，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有點像是客人的身分……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以得到了不錯的房間呦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣也算是額外的好處吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然任期結束後就得跟牧場告別，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n必須要回到城鎮才行呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是我喜歡的各種家具也都搬進來了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有點難以離開啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也結交到了很多感情很好的朋友呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……話說，我的事情不重要吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n打擾你工作真抱歉啊，{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為現在是牧場的繁忙時期，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n都沒有人陪我聊天嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以我很寂寞，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不由得就向你搭話了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你問我不工作也沒關係嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～畢竟我不是牧場的員工嘛。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n連工作方法都不知道的外行人來多管閒事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不也只會造成麻煩嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我派不上什麼用場，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但至少不想困擾到正在努力的人啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那樣的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "簡直就真的只是個大型垃圾呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇哇？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼要拉著我的手呢……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "住手～會跌倒的。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我真的腰腿都很弱，走路搖搖晃晃的呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯……",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你說，剛開始的時候會成為累贅也是沒辦法的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n從能力所及的範圍開始幫忙就好？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家一定都會很開心的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是這樣嗎……",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你怎麼講得好像很理解這件事呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}你說你也因喪失記憶而對什麼都一竅不通，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就連打工也盡是失敗……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但漸漸地抓到工作的要領，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為能幫上他人的忙感到很高興？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望讓我也能知道這種喜悅？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該說你是積極",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是現充呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是能幹的人的發言呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}看起來好耀眼。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這世上，",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也存在著即使努力了還是一事無成的傢伙哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇哇？",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都說了不要拉我的手……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}還真是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "意外的強硬呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明長著一張連蟲子都不敢殺的臉～",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我還覺得你也會溫柔對待我的說。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且。",
        "unit_id": 102611,
        "voice": "vo_adv_1026002_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你也還在送信打工的途中吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
