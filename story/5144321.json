    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n小心喔，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔物植物的行動產生變化了！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它鑽進地底下了。",
        "unit_id": 130711,
        "voice": "vo_adv_5144321_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是有什麼目的嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然可能只是我的錯覺，",
        "unit_id": 130811,
        "voice": "vo_adv_5144321_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但我感覺到它好像正在積蓄力量……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果是這樣的話，",
        "unit_id": 130711,
        "voice": "vo_adv_5144321_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "放著它不管會有危險！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我們使出大量的攻擊，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "把它拖到地面上來吧！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我知道了！",
        "unit_id": 130811,
        "voice": "vo_adv_5144321_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n既然這樣，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那我就只管使勁攻擊！",
        "unit_id": 130811
    },
