    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的～",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又到了將美夢帶給大家的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「蘭德索爾時光」開播時間囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先，是這次的頭條新聞！",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "公主連結慶典♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今年活動似乎也大受好評，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓我感到安心多了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次可要讓我從企劃一開始就加入喔。",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像是「愛梅斯大人的夢境體驗區」，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或是「愛梅斯大人的夢想舞台」之類的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都是很棒的主意對吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_9008013_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們三個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼都默不作聲了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我看八成是我太會聊天，妳們跟不上了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 100111,
        "voice": "vo_adv_9008013_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這或許也算理由之一吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真要說的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "主要是因為看到菲歐突然冒出來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以嚇了一跳",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的關係。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯、",
        "unit_id": 100311,
        "voice": "vo_adv_9008013_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是說啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "菲歐，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳怎麼會跑來廣播節目這邊？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀？",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別看我這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也是有對廣播計畫提供協助的喔！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100213,
        "voice": "vo_adv_9008013_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "菲歐替節目",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "提供協助？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是呀。",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖這麼說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也只是在通訊魔法方面的技術協助而已啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，我的的確確是相關人員，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以再讓我多聊聊嘛？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想想，",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "愛梅斯小姐──",
        "unit_id": 1,
        "voice": "vo_adv_9008013_011"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "\n妳講太久了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "麻煩請加快速度～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦咦咦？",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我明明幾乎沒聊到什麼呀～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還想再講個三小時耶！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好、",
        "unit_id": 100111,
        "voice": "vo_adv_9008013_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "了好了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n畢竟節目時間長度是已經固定的，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n能聊的時間比想像中短呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "事情就是這樣，菲歐，",
        "unit_id": 100311,
        "voice": "vo_adv_9008013_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請把麥克風給我們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦～！",
        "unit_id": 190011,
        "voice": "vo_adv_9008013_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還想再繼續聊耶～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "菲、",
        "unit_id": 100213,
        "voice": "vo_adv_9008013_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "菲歐……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是老樣子",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很喜歡",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聊天呢……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵。",
        "unit_id": 100213
    }
]