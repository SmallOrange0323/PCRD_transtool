        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在姊姊妳",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是不是會硬是想壓制住",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n增強後的超能力啊。",
