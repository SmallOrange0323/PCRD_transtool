    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1012012_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只要打嗝，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "超能力就會失控呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時候好像也是呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012012_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n啊啊～！？　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我又發動了嗎！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n對不起～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事的，",
        "unit_id": 103811,
        "voice": "vo_adv_1012012_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n妳以前也有",
