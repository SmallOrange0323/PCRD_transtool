    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "發生過同樣的事唷。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦咦～",
        "unit_id": 101211,
        "voice": "vo_adv_1012012_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n有發生過這種事嗎？",
