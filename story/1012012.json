    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1012012_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然只是推測……",
