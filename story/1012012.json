    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "應該、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是這樣吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有點害羞呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
