        "voice": "vo_adv_1012012_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！　",
