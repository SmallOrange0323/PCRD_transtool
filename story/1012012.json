    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時候也是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟現在一樣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳會不由自主地用出超能力。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦咦？",
        "unit_id": 101211,
        "voice": "vo_adv_1012012_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有這種事嗎？",
