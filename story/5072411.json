        "words": "我們花了那麼多",
        "unit_id": 117411,
        "voice": "vo_adv_5072411_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "時間和工夫來籌備的演唱會，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也即將要",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "落幕了呢……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊……",
        "unit_id": 117311,
        "voice": "vo_adv_5072411_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然覺得有點寂寞，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們現在還站在舞台上。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒錯，紡希！",
        "unit_id": 117211,
        "voice": "vo_adv_5072411_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算快要結束了，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但演唱會現在還在進行著！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們得讓粉絲們",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "盡興到最後一刻！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是的，",
        "unit_id": 117411,
        "voice": "vo_adv_5072411_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我當然知道！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慈樂之音的演唱會，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從頭到尾總是火力全開！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們會帶來滿滿的精采演出，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓大家看得目不轉睛！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請你也聲援我們到最後吧！",
        "unit_id": 117211,
        "voice": "vo_adv_5072411_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的這份心意",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "將激勵我們邁向偶像的更高境界♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為我們總能很清楚地聽到",
        "unit_id": 117311,
        "voice": "vo_adv_5072411_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你的聲音。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是你稍微移開視線我也會注意到的喔！",
        "unit_id": 117411,
        "voice": "vo_adv_5072411_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211,
        "voice": "vo_adv_5072411_007"
    },
    {
