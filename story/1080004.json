[
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "最近好像，",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有很多人會在路上叫住我。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "大商會那邊的人",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "會稱呼我",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「帝王章魚獵人」，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n或默默遞給我名片……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我好像稍微有點名氣了呢。",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這下出門在外就不能太亂來了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你說這算是我努力之後獲得的獎賞？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "該說是獎賞、還是名氣稅……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有點微妙呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且如果要說獎賞的話，",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我希望是更好一點的呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "比如說，{player}給的……",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊啊啊！",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒有，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒有啦！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀？",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "吶，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是不是有亮光從海那邊靠過來了？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯……",
        "unit_id": 108011,
        "voice": "vo_adv_1080004_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是什麼，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好亮……！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總算是可以休息了！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為是包含住宿的度假村打工，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n雖然工作時間很長，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "錢也算是很好賺。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過呢，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "像這樣子悠閒的休息還真是久違了……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了。",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也該找找給家人的伴手禮才行。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你能幫忙我嗎？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這一帶的話，有許多大自然的伴手禮呢。",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看啊，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個貝殼，不是很美嗎？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "已經長大的兄妹不會想要，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但對小孩子們來說",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可是珍寶啊。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔～嗯，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這一帶沒有什麼適合的貝殼呢。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "到岩岸那邊去看看吧。",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也許能夠找到很珍稀的貝殼也說不定。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嘿……",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣的路面，不太好走呢，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個地方。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "螃蟹啊……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀！？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "痛痛痛痛。",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為了不踩到螃蟹結果腳好像扭到了……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要繼續在這岩岸走下去可能有困難……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "吶，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不好意思啊……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能不能請你幫我去找貝殼來呢？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "意、",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "意志這麼堅定我很高興，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但是不用那麼多啦！？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只要裝到有點重量就夠囉？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "加油？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "知、",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "知道了。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣的話……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "加油～！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "加油～！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}加加油～！！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣子可以嗎？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那就拜託你囉！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "…………",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "他沿著岩岸走了相當遠呢，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不要緊吧？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "回來了！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "吶，你沒事吧！？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在海浪洶湧的地方",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有美麗的貝殼？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "原來是這樣呀。",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}都這麼說了，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n應該是非常美麗的吧……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦！？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你說要去撿來……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，{player}！？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "走、",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_032"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "走掉了。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真、",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_033"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真的沒問題嗎？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "應該不會被海浪捲走吧……？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_034"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_035"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是讓人心急啊，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "快點回來吧……！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊！？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是的，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼這麼久！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你沒事吧？",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "身上沒有受傷吧？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等等，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你腳在流血──",
        "unit_id": 108031
    },
    {
        "type": "still",
        "still": "108000401"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀啊！",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_038"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對、",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_039"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對不起，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "扭到的腳絆了一下――",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊……",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_040"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呃、呃。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個……",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我很抱歉。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但是，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等{player}很久都不回來，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我很擔心。",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不說這個，重要的是{player}的腳呀！",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_041"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是不是在岩岸受傷了……",
        "unit_id": 108031
    },
    {
        "type": "still",
        "still": "108000402"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算是擦傷，",
        "unit_id": 108031,
        "voice": "vo_adv_1080004_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "受傷就是受傷啊！",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要是現在輕忽，",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "萬一感染細菌可就糟了喔！？",
        "unit_id": 108031
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總之，",
        "unit_id": 108031,
