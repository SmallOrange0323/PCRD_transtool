[
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "特別講座の事前説明会──"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nアキノたちの口から詳細が告げられたあと、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n聖テレサ女学院の生徒たちはしばらく騒然としていた。"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なるほどな……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "優れたアイデアがあれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "財団が経済力をもって其れを実現させる。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n此度の講座はそういう主旨か。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "実績も信用もない起業家は、",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "一般的な投資が受けづらく、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nビジネスエンジェルなどと呼ばれる富裕な個人を探すものと聞くが。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おそらく彼女らこそ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々にとってのエンジェルに相違ない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "エンジェリック・ドラゴンスレイヤー……",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_002"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n竜殺しの天使…………",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ふーん、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "いいじゃん。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "やー、",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_003"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "マザーのスクハラでしぶしぶ参加する講座でしたけど、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "まさかワンチャンセレブ入りのご案内だったとは驚きですね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n棚から牡丹餅どころか、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ガチョウが金の牡丹餅を産むレベルですよ。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ソレもう牡丹餅じゃなくてよくない。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_004"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そこはどーでもいいんです！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_005"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "学校のこういうイベント授業って、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nフツー長々とつまんない話聞かされたり、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "長々とつまんないレポート書かされたりするじゃないですか！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あーね。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_006"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ま、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "その点、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "今回は本番にバシッと一発",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n結果だけ出しゃーいンだから本当アドいわ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あ、",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_007"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そっか……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "結果だけでいいのか……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そしたらもう、あるじゃないですか。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "アレでよくないです？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nあのユニ先輩が飼ってる、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ほら、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "たまに文鎮代わりにされてる──",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ロゼッタか。",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_008"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "言われてみれば",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "即席簡易疑似ゴーレムというのは、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくの引きこもり精神──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もとい",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "独創的な発想によって産まれた",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n狂気の産物──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もとい",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "革新的な技術の結晶だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "財団の要求に符号する。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "マジか。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_009"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "え、じゃあソレじゃん。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "すでにあンじゃん結果。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\nヤバい、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "うちら戦わずして勝ったわ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "もうすることないわ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "さて。",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_010"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n特別講座の内容については",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "以上です。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "戸惑っているかもしれませんが、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "行うべきことは",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "とてもシンプルです。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "──チャレンジ、",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_011"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "ですわ。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "未来へと突き進む学生として、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n実現したい夢の形を",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "私たちにお見せくださいませ。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "え、",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_012"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんかアキノ先輩、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "こっち見ながら言ってンだけど。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "なんで。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "どゆこと。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "パイセン訳して、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "端的に。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_013"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "チャレンジ精神……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "結果だけではなく過程……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なるほどな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nどうやら我々に、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ズルはするなと言っているようだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "本件はビジネスではなく、",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_014"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ビジネスに学ぶ授業。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ビジネスなら成果がすべてだが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "授業となればさにあらず。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nおそらく財団は、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "クライアントの意向も尊重しているのだろう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "クライアント？　",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_015"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ああ、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "うちの学校か。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "然り。",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_016"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "学院め、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々四人の行動には注意するよう要請したに違いない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "マザーヒルダはそういうこと言う。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_017"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "マザヒルちゃん、",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_018"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "最近うちらの思考完全に読んできますよね。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "あ、それと。",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_019"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "今回の特別講座、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "過程の方も重視したいと思っています。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "発表の際、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "資料をまとめたレポートを提出していただきますわ！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "……と、",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_020"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "クライアントが要請したわけですね？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "えぇー",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふん、",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_021"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "過程をレポートだと？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの思考マップを開示しろと言うのか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "厚かましい、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "当学の教員には知的プライバシーという概念がないのか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "てか、",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_022"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "シンプルにめんどみ。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "レポートってか、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あの作文的なやつ？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "アレ系全般、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "クロエ",
