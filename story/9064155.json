[
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哇啊……",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好美的花田呀。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不知道有沒有適合晚膳的食材？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可璃亞小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9064155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於還有魔物的存在，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請不要走遠了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是說啊～",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再說了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這個溫室裡長大的千金小姐根本沒有摘採過食材，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是採了野草來，哪能用來做菜啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵。",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "別看我這樣，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我可是很了解野菜的。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "例如這個果實，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就類似山芋的「珠芽」。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "水煮後的味道保證很像馬鈴薯喔♪",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真沒想到……",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來可璃亞對這方面這麼了解。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道她很喜歡野外求生之類的活動嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就我目前對她的認識，實在看不出來耶～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以……",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實她曾經",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃過不少苦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "問妳喔，",
        "unit_id": 105811,
        "voice": "vo_adv_9064155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可璃亞☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳為什麼會對野菜這麼了解啊～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂……",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "噢☆",
        "unit_id": 105811,
        "voice": "vo_adv_9064155_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳的吐槽怎麼比平常還要嚴厲啊～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種事",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不能這樣隨口就問出來啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n人家搞不好",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以前曾經有過什麼經歷……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "妳們兩位",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼了嗎？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒什麼啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那不重要，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "倒是妳不用煩惱食材，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的不需要喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正我們也有乾糧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的不需要勉強，知道嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……？",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n凱留小姐？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n妳怎麼和平時的樣子不太一樣…………",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呀啊！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘶啊啊啊啊啊！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可璃亞！",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "危險──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "凱留小姐！？",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n妳為什麼會掩護我……？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因、",
        "unit_id": 106011,
        "voice": "vo_adv_9064155_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然是因為我是妳的護衛啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別管這些了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先打倒魔物再說！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "知、",
        "unit_id": 126013,
        "voice": "vo_adv_9064155_017"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "知道了……！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也會盡我所能，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "避免",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "拖累大家的！",
        "unit_id": 126013
    }
]