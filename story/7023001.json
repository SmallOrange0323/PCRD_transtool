    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳也",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跟我一起當英雄吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們可以組成英雄拍檔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦？",
        "unit_id": 100111,
        "voice": "vo_adv_7023001_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要我當",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "英雄嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦、",
        "unit_id": 100111,
        "voice": "vo_adv_7023001_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦～？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "突然跟我說這些，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也很煩惱呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳、",
        "unit_id": 100111,
        "voice": "vo_adv_7023001_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳那麼說我很難拒絕，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是我不行的啦……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒問題的！",
        "unit_id": 100511,
        "voice": "vo_adv_7023001_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳很強，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很溫柔，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還很帥！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "最重要的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是妳有一顆充滿正義感的心！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果是日和，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一定可以成為了不起的英雄喔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來，",
        "unit_id": 100511,
        "voice": "vo_adv_7023001_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "跟我一起",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "朝英雄雙人組努力吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈哈……",
        "unit_id": 100111,
        "voice": "vo_adv_7023001_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "事情好像",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "變得很複雜了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "困惑的日和與興致高昂的茉莉。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對比鮮明的兩人繼續在露娜之塔裡冒險。"
