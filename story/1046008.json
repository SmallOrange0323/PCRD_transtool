[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到珠希打工的鯛魚燒店的攤販。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喲！",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你怎麼會來這裡喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道是來吃鯛魚燒嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣的話，我會給你很多折扣喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，買點什麼吧――",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，這是什麼喵！？",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛、鯛魚燒發出光芒――喵啊啊啊啊啊啊！？",
        "unit_id": 104611
    },
    {
        "type": "still",
        "still": "104600801"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "瞧，是飼料喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有很多，所以盡情的吃吧喵……哈……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊……",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n歡迎光臨喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要買鯛魚燒嗎喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……不愧是你喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n立刻就發現我正在煩惱……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實，那個……",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你看到我，",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有注意到什麼嗎喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實我……最近，那個、胖了喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以正在減肥……當像這樣餵牠們飼料時，",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我也肚子餓了喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就連員工餐的鯛魚燒也只能忍痛割捨給貓咪們了喵……",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是……我已經餓扁了，",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n忍耐到了極限喵……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唔……！",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我相信你，所以有件事要拜託你喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請你、請你幫我減肥喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "靠我一個人的意志力做不到……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的嗎喵！？",
        "unit_id": 104632,
        "voice": "vo_adv_1046008_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n謝、謝謝喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "事不宜遲，明天開始減肥喵！",
        "unit_id": 104632
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼呼，呼呼！",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哈，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哈，到底要讓我跑幾公里馬拉松喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n雖然它是有氧運動喵啊……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哈，哈……終、終於看到終點了喵……",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n到那裡就能休息了……！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "最後衝刺，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "加油喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵啊啊啊啊啊啊啊啊……！",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "終、終點……！",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "抵達終點了喵……！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼啊啊，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "累死我了喵啊啊啊啊啊啊……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哈，哈……",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你怎麼了喵。",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n怎麼移開視線了喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，難道……",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你現在是因為看見我流汗而衣服緊貼著的身體，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有點心跳加速了嗎喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵呵，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我對你的視線很敏感喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "男孩子都是這樣的喵……",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……那麼，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n難道你也想看衣服裡面嗎喵……？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果是你……我，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓你看也沒關係喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "………………",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "騙──你的喵！",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n開玩笑的喵──！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你有期待嗎喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵呵。但是，有你看著我的話，",
        "unit_id": 104631,
        "voice": "vo_adv_1046008_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就能防止我偷懶喵！ ",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今後也請多多指教喵！",
        "unit_id": 104631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1046008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很難得，你會因為看見女孩子的身體而感到慌張呢～。",
        "unit_id": 190011,
        "voice": "vo_adv_1046008_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使如此，珠希她到底是積極，",
        "unit_id": 190011,
        "voice": "vo_adv_1046008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還是在戲弄你，真是令人摸不透的孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這說明她很任性啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1046008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和那種孩子交往的話，可能會很辛苦吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過，也許不會感到無聊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了。",
        "unit_id": 190011,
        "voice": "vo_adv_1046008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n實際上煩惱的人是你。那麼再見囉～。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗚喵……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唔……我好像不知不覺間睡著了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是不可思議的夢喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，就算在夢裡，我還是在鯛魚燒店打工喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……咦？",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_040"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你的夢裡，我也是在鯛魚燒店打工嗎？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……原來如此喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你好像跟我做了相同的夢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有這樣不可思議的事呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵，想起夢中的內容，",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就變得很開心喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不管怎麼說，即使在夢裡，",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你還是臣服於我的魅力之下喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，作為夢裡的延續……，",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就讓你看這裡面吧喵……？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，開玩笑的喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046008_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，重新開始工作喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "珠希開心地笑著回去工作。"
    }
]