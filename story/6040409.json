[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴的鎧甲，",
        "unit_id": 103811,
        "voice": "vo_adv_6040409_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常可愛呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且是媽媽送的東西",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這點也很棒。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果她能夠再更常穿一些就好了呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確，",
        "unit_id": 103811,
        "voice": "vo_adv_6040409_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為那套鎧甲很重，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以不太適合穿著巡邏呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是需要穿上鎧甲的工作",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又都是些危險的工作……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真難如人所願呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確，",
        "unit_id": 103811,
        "voice": "vo_adv_6040409_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不需要穿鎧甲這種危險的東西才是最好的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但那個樣子的鈴很犯規呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "搖搖晃晃的樣子真的很可愛。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果拜託她的話，她會不會願意再穿上呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我非常能夠理解想要珍惜收到的禮物的心情，",
        "unit_id": 103811,
        "voice": "vo_adv_6040409_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但有些東西我覺得要拿來使用才更讓人高興呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴平安才是最重要的事情。",
        "unit_id": 103811
    }
]