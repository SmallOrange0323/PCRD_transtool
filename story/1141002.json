    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我立刻去通知大家……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "在人潮這麼洶湧的地方",
        "unit_id": 711,
        "voice": "vo_adv_1141002_069"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "引起恐慌會非常危險，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n要盡量穩當地",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "引導民眾避難。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "雖然妳應該不怕魔物，",
        "unit_id": 711,
        "voice": "vo_adv_1141002_070"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "但年紀更小的孩子，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n有可能會因為恐懼而無法動彈。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n希望妳盡可能不要讓他們察覺，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "引導他們疏散。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不要讓小孩子察覺……",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_071"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗎？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我試試看！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "就算遇到魔物，",
        "unit_id": 711,
        "voice": "vo_adv_1141002_072"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "也不得單打獨鬥。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n一定要逃離那裡然後等待支援，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "明白嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我、",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我明白了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總、",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_074"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總之先跟剛剛那些人……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "該怎麼說才算是穩當啊？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在可不是思考的時候！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總之",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "先去找他們說話吧！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "魔物？",
        "unit_id": 1411,
        "voice": "vo_adv_1141002_075"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哈哈哈，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "每年都會有小朋友說這種惡作劇的話呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "哎呀？",
        "unit_id": 1511,
        "voice": "vo_adv_1141002_076"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "是還想要糖果嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "不過這種話只能在萬聖節這一天說喔？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔唔……",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_077"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被當成萬聖節的惡作劇了啦……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n該怎麼做他們才會明白呢？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "腳踏實地的努力會獲得成果呢……",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_078"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就和特訓一樣！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說的也是呢……",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_079"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n英雄是不能放棄的！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_080"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話說回來，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有沒有一個小男生跟一個小女生",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "來過這裡？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1141002_081"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "有來過喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "還說這裡是祕密寶地很開心呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n是你們告訴他們的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那些孩子去哪裡了？",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_082"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "他們說想要找更多祕密寶地，就往西地區去了喔。",
        "unit_id": 1511,
        "voice": "vo_adv_1141002_083"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "雖然我們有跟他們說那邊沒什麼人煙，去了也沒用呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳說西地區……",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_084"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "糟了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要去把他們帶回來！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "喔？",
        "unit_id": 1411,
        "voice": "vo_adv_1141002_085"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "怎麼了？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就如我剛剛說的一樣！",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_086"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n魔物入侵西地區了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大叔你們也",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不要驚慌，快回到家裡避難吧！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "咦？",
        "unit_id": 1511,
        "voice": "vo_adv_1141002_087"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "妳說的是真的嗎……？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明白了吧！",
        "unit_id": 114111,
        "voice": "vo_adv_1141002_088"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託你們了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了帶回小孩子們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茉莉與{player}奔向了西地區。"
    }
]