[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃──",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "第九次",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【美食殿堂】吃遍之旅開始囉……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒想到連海底都要去。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我已經無所謂了……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "水中呼吸魔法",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經放好了嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣就能在海裡面呼吸了對吧？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可以潛下去了嗎！？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……是可以啊，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過妳帶那個投網要幹什麼？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳應該沒忘記我們的目的吧？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那當然！",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "享用現撈的新鮮海產……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後順便完成花凜小姐的委託！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反了，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本講反了！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃遍之旅才是順便的那個！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n她拜託我們的是調查那個什麼海底神殿吧！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這片海中居然有神殿……",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一時之間還真是令人難以置信呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我自己也是半信半疑，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過好像已經有數名漁夫目擊了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "據說",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "海底神殿有個巨人，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他看守著寶藏之類云云……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道那裡的居民們，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過著怎麼樣的生活？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在水裡",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "洗了衣服不會乾，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n收到的信也會溼答答的……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺相當不便。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過吃的感覺就不用擔心了～",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在海裡，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每天都可以盡情吃海鮮……！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想住在海裡看看！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們喔……",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住在那裡的人，大概都像白癡佩可一樣吧？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳看這傢伙，一副躍躍欲試的樣子。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等實際見到面，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再和居民們聊聊吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次的委託。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也對，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這麼回事，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "希望單純講講話就能搞定。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，我猜到時候大概又會是一番折騰吧……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "水裡一切，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肯定與陸地相當不同。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定這趟旅程，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會比在下們在各地經歷的冒險都還要艱辛。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小心為上吧。",
        "unit_id": 107612
    },
    {
        "type": "background",
        "background": "501970"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊啊……",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有各種顏色的魚跟",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "章魚和烏賊！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有形狀從沒看過的貝類～！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道味道如何……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要亂跑啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我解除妳的水中呼吸魔法喔！？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那、",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那也沒辦法……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了品嚐極度新鮮的海產！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會努力憋氣的！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳解除吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我怎麼可能真的做嘛！",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是在鬧你啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，趕快回來啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在請先稍微忍耐一下。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下們已經潛到相當深的地方了……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n嗯？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像看見了什麼。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "底下好像有光……",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是傳說中的海底神殿嗎？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把這附近的石塊，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "用我的魔法連結起來，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像就能過去。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又深又暗的，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺好可怕喔～",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的要潛到這種地方的最底下嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抓些魚回去就好？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳只是單純想吃魚吧……",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有光線的確很麻煩，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是被偷襲那可就糟了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貿然前進可能會有危險。",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真希望",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能再獲得一些情報……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，可蘿仔，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不是能和精靈對話嗎？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能不能跟這附近的水之精靈",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "問些什麼？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您真是聰明。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都沒想到這個方法。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就趕緊來問問看吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是的，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天也是風和日麗。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "名叫可可蘿。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這樣啊，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來住在海裡的各位，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會曬日光浴呀。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果時間允許，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也很想與各位一同──",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂喂喂，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別在那噓寒問暖了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快切入正題啦。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然是這樣。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐、",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "住在那座神殿裡面的……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說是這片海域的海中之王。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "海、",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "海中之王嗎！？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼辦，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼都沒準備！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該不會演變成外交問題吧？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是自稱而已。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且據說個性非常爽快，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以不用擔心。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "同樣是王族，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且也是想住在海底的怪人……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞不好跟妳很談得來喔？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳去跟他聊聊看嘛。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要我自己去這麼黑的地方嗎！？",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果讓我",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "緊緊抓住小凱留的尾巴，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說不定能舒緩我的恐懼……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要抓我尾巴啦！",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們一起去總行了吧！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別想偷偷握我尾巴啦！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海中之王……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還在募集可以測試實力的挑戰者。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "挑、",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "挑戰者？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個王還真是個武鬥派呢……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他似乎也不喜歡使用卑鄙的手段，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不需要擔心會遭到偷襲，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈們是這麼告訴在下的。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……他好像有大肆宣傳，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望挑戰者與他正面對決。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔～",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰怕誰。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然他有這個意願，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我們就接受挑戰吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且，要是贏了搞不好能拿到財寶──",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也、",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有機會可以請他招待我們料理囉！？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是新鮮豪華的海產全席，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是只有在那才吃得到的海底珍饈……！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 107812,
        "voice": "vo_adv_4003019_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要拿獎勵的話選財寶好嗎！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要吃海產隨處都有不是嗎！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 107612,
        "voice": "vo_adv_4003019_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會招募挑戰者，代表他自身具有相當的實力。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好對付。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下們必須做好萬全準備。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別擔心別擔心，",
        "unit_id": 107512,
        "voice": "vo_adv_4003019_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，凡事都得先試試看！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且肚子也餓了，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們去挑戰看看吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這麼辦♪",
        "unit_id": 107512
    }
]