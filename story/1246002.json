[
    {
        "type": "background",
        "background": "501471"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在離開神殿的歸途上，美里與{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n路過新年熱鬧滾滾的大街。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你肚子會餓嗎？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n難得來到大街，要不要吃點什麼？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不知道有沒有賣些什麼新年料理呢……",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那就麻煩你帶路囉♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "別用跑的～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "「大江戶風餐廳」……？",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "店面看來頗有風情呢♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n還擺了許多豎旗……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "「迎新春！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "供應年糕湯！」",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……\n宣傳這樣寫著呢！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "年糕湯很不錯呢～～～",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n可以吃到大江戶風的年糕湯嗎～♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n嗯呵呵，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真令人期待。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，我們快進去吧……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，這樣啊～？",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "門簾的確",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還沒有掛出來。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話說回來，{player}",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你還真清楚呢～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為你之前曾在這裡打工過，所以才知道的嗎～？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "工作勤奮值得嘉獎～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很好很好♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔，抱歉。",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你們是來用餐的客人嗎？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "等等，",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_008"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "你不是先前曾在這裡打工過的小伙子嗎！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呿、你這傢伙！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "竟然帶著這麼漂亮的姑娘過來！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……呼、",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呼……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你沒事吧……？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……嗯？",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_010"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "啊，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "說來慚愧，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n因為新年玩過頭了，覺得有點不太舒服。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我只要好好睡一覺就沒事了！",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_011"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n因為現在還在準備中，可能會耽擱點時間，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n請你們再稍待片刻……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "嗚唔！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呼、",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呼",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……呼！！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是啊，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看起來很不舒服的樣子……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你還是多休息比較好吧……？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "嗚唔……",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_013"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "不，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我不能休息……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "每年過新年的時候，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "都會有許多常客，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n過來吃我煮的年糕湯呢……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "其中有不少是大江戶出身的客人，",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_014"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "新年期間無法返鄉，得留下來工作。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n招待他們享用一碗年糕湯，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "可說是我的使命……！！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……嗚唔",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……！！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老闆大叔！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你看看……",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你連站都站不穩了……！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我能深切感受到老闆大叔的熱忱，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n不過，你這樣子是不可能開店的……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "嗚唔……！",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_017"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "可是……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……那個，{player}。",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "果然是這樣～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就知道你會這麼說～！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以說……",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老闆大叔。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我們想",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n代替你來開店，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你覺得呢～？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……喂喂，",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_021"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我很感激你們願意幫忙。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n但是，你們太低估這份工作，我也會很困擾……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我專研此道已有30年之久，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "你們以為有那麼容易重現我的味道嗎！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你說得沒錯。",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我沒辦法製作店裡所有的料理。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果只限一道的話……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以請你只教我怎麼煮年糕湯嗎？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……我之前的確曾教過你這小伙子",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_023"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "如何備料。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n如果只有年糕湯，或許有可能辦到……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "不過……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我先問個問題。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "妳為什麼會提出這請求……？",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_024"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我們今天才第一次見面，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "妳應該沒有義務幫這個忙吧。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n既然如此，為什麼會……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "當然是因為……",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我沒辦法對有困難的人坐視不管啊。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……唔！！",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_026"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n好個既坦率又純真的眼神……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "……連你這小伙子也露出一樣的眼神……",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_027"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "呿，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "真是多管閒事的一群人。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我明白了……",
        "unit_id": 1412,
        "voice": "vo_adv_1246002_028"
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "我就接受你們的好意，請你們幫忙了……！！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "相對的，時間已不多了……！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "老大",
        "words": "\n我可是會很嚴格地指導喔……！",
        "unit_id": 1412
    },
    {
