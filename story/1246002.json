    {
        "type": "dialogue",
        "name": "常客1",
        "words": "裡頭的確……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "沒……",
        "unit_id": 1,
        "voice": "vo_adv_1246002_066"
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "沒錯！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "\n年糕湯裡滿滿都是溫柔的味道……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "\n溫柔可以說是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "最棒的調味料了……！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵……",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_067"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然被說是媽媽的味道，讓我有點驚訝，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n不過，看你吃得那麼開心，真是太好了！",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "喂～",
        "unit_id": 1,
        "voice": "vo_adv_1246002_068"
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "還有空位嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n才剛過新年就得趕赴上工，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n真是累死人了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "唔哇！？",
        "unit_id": 1,
        "voice": "vo_adv_1246002_069"
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n我、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "我走錯店了嗎……！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n怎會有這麼漂亮的年輕老闆娘！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_070"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你工作才剛結束嗎～？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "辛苦了♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我馬上為你煮一碗",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_071"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n熱～呼呼的年糕湯喔～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "常客們",
        "words": "唔喔喔～～！！！",
        "unit_id": 1,
        "voice": "vo_adv_1246002_072"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611,
        "voice": "vo_adv_1246002_073"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n好了，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請享用～♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因客人的笑聲吸引來更多客人，在門庭若市的店裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n美里與{player}面帶著笑容徹夜工作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n盡全力打理好店裡的一切。"
    }
]