[
    {
        "type": "background",
        "background": "500182"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "～……♪",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唉唷。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還在想怎麼有腳步聲，原來是主人啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n怎麼了嗎，在下明明要您先去就寢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做惡夢了嗎？要不要在下給您秀秀？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫非是在下大半夜裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n偷偷從被窩裡溜出來，讓您覺得很可疑。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以您不放心而尾隨在下追了過來嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您不要擔心，在下並非是在夜遊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是在這座精靈之森有點事情要辦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您放心。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下不會將主人丟在一邊，跑到太遠的地方去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下絕對不會不見的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會永遠陪在主人身旁……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下準備從這座森林裡放出傳信鴉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼說，牠就跟信鴿一樣。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在在下的故鄉，比起鴿子更習慣飼養烏鴉來傳遞信件。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。在下準備給故鄉捎封信。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下與主人相遇至今所有的事情，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都有義務向故鄉的長老報告。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……雖然稱呼為長老，其實他是在下的父親。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "女兒遠走他鄉，父親一定很擔心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以要定期聯絡，讓父親放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "順便一提，烏鴉可是很聰明的喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給牠食物的話就會親近在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也能理解在下所說的話，然後完成簡單的工作。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特別是這座精靈之森的動物和鳥類，",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不知為何很親近人類……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下定期地來這裡餵食牠們，事先馴服了好幾隻。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著讓烏鴉含住信件，",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓牠聆聽在下一族所流傳的歌曲。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將要傳達的指示放入歌曲的音階中，就可相當確實地差遣牠。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為牠是在這座精靈之森長大的烏鴉，",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為牠也不會知道在下故鄉的位置……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以才透過歌曲來引導牠到目的地。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非、非常感謝您。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能得到主人的讚譽，在下實在榮幸至極。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也很努力地練習歌唱。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "除了驅使傳信鴉，在下一族的歌曲在各方面也很有用喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n精靈族的歌曲中蘊藏著特別的力量喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比如說搖籃曲……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您不覺得困擾的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在主人無法入睡的夜晚裡，在下可以唱給您聽喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不單只是烏鴉，其他鳥類、昆蟲和動植物在下全部都喜歡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈族多半都有這種傾向喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟是生活在大自然中的種族。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此對於蘭德索爾這樣充滿人造建築、雜亂無章的地方……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下感到十分厭倦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偶爾就會像這樣來個森林浴，重新打起精神。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您稍待片刻，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n等在下確實地送出傳信鴉後，我們就一起回家吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "城鎮的外面很危險呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想保護主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下外出前，應該事先向主人報備。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您擔心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這座森林的烏鴉是夜行性的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不是夜晚的話，就沒有辦法驅使牠們。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "白天的時候，在下想要盡可能地陪在主人身旁。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到了晚上，主人也已經熟睡了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n此時也比較適合在下單獨行動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從下次開始，在下會盡量不讓主人擔心……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會事先詳細地向您報告和說明",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一天的計畫和行動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。您是說倒不如放您一個人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n自由行動也沒關係……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您覺得總是讓人照顧，感到有點愧咎嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一天二十四小時，被一個莫名其妙、",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一無所知的小女孩死纏爛打……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下造成您的困擾了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您覺得在下很礙眼嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說沒那回事嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您能那麼說，在下也感到值得了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一直夢想著能伺候主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以在下現在非常幸福。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n關於這點，請您不要懷疑。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很幸福。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n幸福到無法用言語來形容。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為這正是在下一直夢寐以求的……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下正活在自己憧憬的故事中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使在下無法成為男女主角。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少讓在下陪在心愛的人身旁……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此這般，生活下去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n抱歉，弄得主人一頭霧水……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明明就是『嚮導』，卻不擅長說明，真是抱歉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼失禮了，請聽在下一曲。",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和主人相處的時光實在太快樂、太充實了，",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n寫給故鄉的信也因此相當厚重……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很擔心傳信鴉能否順利飛起來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去吧，傳信鴉們……",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將在下的幸福傳遞到故鄉去吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "～……♪",
        "unit_id": 105913,
        "voice": "vo_adv_1059003_040"
    }
