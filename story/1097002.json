    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天也是一如往常的蘭德索爾。\n雷姆正急著前往與可可蘿等人約定碰面的地方。"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "糟了，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "有點太晚出門了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "育幼院的孩子們太可愛，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "一不小心就……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "要是不快點",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "會趕不上時間的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這樣雖然有點不得體，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是就跑過去……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂──！",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_002"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n那邊怎麼樣啊──！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不行──",
        "unit_id": 911,
        "voice": "vo_adv_1097002_003"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這個完全沒有辦法啊──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "真是的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "傷腦筋了啊──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗯，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_004"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "街上聚集了好多人……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是發生了什麼事嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不好意思，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請問怎麼了嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "哦？",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_006"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "女僕小姐？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "哎呀～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "沒怎麼了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "就是妳看到樣子。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "看到樣子……",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_007"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n是倒在路中央",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "的樹木嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還真大呢……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不久之前",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_008"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "有魔物在這附近作亂。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n雖然是成功驅逐了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但損害就是這個。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "雖然招集了男丁要來移走這棵樹，",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_009"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但是這相當艱難……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "看來會耗上一整天了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "街道沒辦法通行的話，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n馬車那些就會動彈不得呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……那個，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_011"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可以的話，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能讓我來幫忙嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_012"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n妳說幫忙，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是女僕小姐妳嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_013"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "力氣活的話，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我想應該可以幫得上忙，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "怎麼樣呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1097002_014"
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1097002_015"
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "哈哈哈哈哈哈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂喂，",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_016"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小姑娘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "很感謝妳有那個心，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但小姑娘是辦不到的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "可別用妳那瘦弱的手臂",
        "unit_id": 911,
        "voice": "vo_adv_1097002_017"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "勉強亂來啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n哈～",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "笑死我了",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "笑死我了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "唔……",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_018"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這絕不是在開玩笑……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "知道了知道了。",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_019"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "但是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這種事是男人的工作，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "女僕小姐。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "要是妳真辦得到的話，",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_020"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n就算要我們把今天的酒錢",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "全部給妳都行啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是這樣",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "的嗎。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我明白了。",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_022"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n是我多管閒事了，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真是抱歉。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "各位，",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_023"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請各位工作加油。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆就先告辭了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "哦哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1097002_024"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小心點啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n大力士女僕小姐！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1097002_025"
    },
    {
        "type": "dialogue",
        "name": "男子們",
        "words": "哈哈哈哈哈哈！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
