        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "很抱歉讓你們久等了。",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_027"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n剛才在途中",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "稍微和人交談了一下……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請別在意，",
        "unit_id": 105913,
        "voice": "vo_adv_1097002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種事情",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是會發生的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們在等的時候",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也很樂在其中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正好",
        "unit_id": 105913,
        "voice": "vo_adv_1097002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有很多第一次見到的攤販。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於是就隨著主人的好奇心",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "邊走邊吃了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自從和貪吃佩可小姐在一起以後，",
        "unit_id": 105913,
        "voice": "vo_adv_1097002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n把魔物當成食材的機會也增加了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但魔物料理",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是正在流行嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "魔物「風」",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_031"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這種",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "硬要與魔物扯上關係的想法",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆並不是很能理解……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 109711,
        "voice": "vo_adv_1097002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1097002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問您怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天的行程",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼覺得擔心的地方？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
