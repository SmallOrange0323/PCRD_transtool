[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很好──！",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是大姐姐大、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "獲、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "全、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "勝！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這附近暫時安全了吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝妳們的支援！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚哇哇……",
        "unit_id": 102511,
        "voice": "vo_adv_9078156_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好厲害……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n居然把那麼巨大的魔物",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "扔出去了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈♪",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n哪裡哪裡，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真的有那麼厲害嗎～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "開玩笑的。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我好歹也曾是世界的管理者呢♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "世界的、",
        "unit_id": 105911,
        "voice": "vo_adv_9078156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "管理者……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難道說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "埃拉小姐跟",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "米奈娃小姐有什麼關係？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就像厄莉絲",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小姐那樣……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哇，",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "光聽這句話",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就能猜得這麼精準啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n「這邊」的可可蘿知道很多呢～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過我已經從管理者畢業，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "如今只是個無業大姐姐。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "說好聽點，",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我就是在尋找好喝麥酒的",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "流浪旅途中。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "老實說……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是個走失兒童吧～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哈",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啾！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911,
        "voice": "vo_adv_9078156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再這樣下去",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會感冒的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱～",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "緊……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐在哪……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這裡……",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n腳好像絆到什麼，就摔倒了……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "等等！",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我馬上去救妳！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝……",
        "unit_id": 102511,
        "voice": "vo_adv_9078156_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "後方有魔物……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "了解，",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那大姐姐也再加把勁吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在那之前……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳們要不要雇我做保鑣？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抵達城鎮為止的這段路就好♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911,
        "voice": "vo_adv_9078156_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在抵達城鎮之前，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也會盡全力來照顧您的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了讓埃拉小姐不會覺得冷……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_9078156_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也會",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盡可能照顧妳的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟我的本職是女僕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我很冒失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但會加油的～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_9078156_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐左擁右抱好開心啊♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們出發吧──！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "走失兒童們的奇妙旅程還要持續一陣子。"
    }
