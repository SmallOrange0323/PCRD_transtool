[
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛才……",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳是不是說了要打倒吸血鬼？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "伊莉亞，怎麼了嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家和香織現在的身分是吸血鬼獵人啊！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吸血鬼獵人？",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀。聽說傳說的吸血鬼甦醒了，",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為吸血鬼是恐怖的存在，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n覺得必須驅除才行，所以咱們才會挺身而出。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "根據流傳的故事，以前蘭德索爾曾經",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n遭到傳說的吸血鬼毒手而變得很淒慘。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是放著不管，蘭德索爾就會變得很慘啦！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n畢竟再怎麼說，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那可是傳說中的吸血鬼呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為這樣，我們才會收集……",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比吸血鬼的弱點",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大蒜和白木樁……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "更厲害的東西嘛～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這麼說來，大蒜就改成『像苦瓜的東西』，",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n白木樁就換成『烏龍麵擀麵棍』這樣嗎……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒錯！希望伊莉亞也和我們一起",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n幫忙打倒傳說的吸血鬼吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵……呼呼呼……",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊哈哈哈哈！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這件事可沒得商量呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為什麼嘛～？",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們……",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n知道那個傳說的吸血鬼叫什麼名字嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那倒是還不知道……",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。那妾身就告訴妳們吧……",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個吸血鬼的名字就叫伊莉亞‧奧恩斯坦！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n過去用恐怖支配蘭德索爾的……傳說的吸血鬼啦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "伊莉亞‧奧恩斯坦……咦咦咦咦咦咦咦咦！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "伊莉亞……伊莉亞就是傳說的吸血鬼～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織・真步",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5003005_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這，不可能啦──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n像伊莉亞這麼小的女孩，不可能是吸血鬼──",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "伊莉亞真會開玩笑。",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，難不成吸血鬼的傳言，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也是因為伊莉亞的裝鬼遊戲產生的嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有可能哦！可能是真琴搞不清楚狀況誤會了吧！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們從剛才就一直說什麼小孩子、裝鬼遊戲，",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n實在很沒禮貌呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就讓妳們看看！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要有你在，妾身就能變成大人的模樣！\n變成大人模樣的話，魔力也會是現在的數倍！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "馬，馬上抱住我！集中精神！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎咿！別像小女生一樣找藉口！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "冷靜得下來嗎？閉上嘴抱住就對了啦！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要上囉！來囉！",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……為什麼只要被他抱住，",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n心臟就會跳得這麼快啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊……",
        "unit_id": 104412,
        "voice": "vo_adv_5003005_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身體……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好熱……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦耶！？伊莉亞……漸漸長大了！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎、",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼會有這種事……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "騙人！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……魔力要滿出來了……",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這才是妾身原來的模樣……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈────哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身才是統治黑夜的絕對頂點！傳說的吸血鬼！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n伊莉亞‧奧恩斯坦啦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我應該已經說過了吧？妾身是統御黑夜之人！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我還以為是小女孩所想的設定呢！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還覺得可愛想笑，結果是我自己愚蠢啊！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也是……以為那種設定",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只是王子先生在配合她而已。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……沒想到妾身以為是救命恩人的兩個人，",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n竟然是想取妾身性命的人……真是太諷刺了……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且……妾身竟然還一起去找打倒自己的道具……！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……哈～哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，妾身可不能乖乖的被殺！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧，妳們兩個，想要打倒妾身對吧？",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就用那個『像苦瓜的東西』和",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n『魔物之角』盡量上吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "唔……",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們也得",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "做好覺悟才行了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼這樣……可是……！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n伊莉亞是……我們的同伴啊……！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也是……對人家來說也是！",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n以為她雖然是小妹妹，但是是個見多識廣、可靠的孩子……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "根本就好像是認識很久的朋友那種感覺……",
        "unit_id": 101011,
        "voice": "vo_adv_5003005_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也是啊！",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "明明就……一起行動、一起戰鬥……！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "結果竟然是傳說的吸血鬼……",
        "unit_id": 101711,
        "voice": "vo_adv_5003005_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯，妾身就是人人畏懼的傳說中的吸血鬼！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_049"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是妳們想要打倒的敵人啦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以說……妾身也是，像妳們這種角色瞬間就能解決……",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_050"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然對我來說這真的沒什麼……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……好了，別再磨磨蹭蹭了！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n總之……上就對了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身也會全力對付妳們！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不行吧！妾身也不能死啊！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "事到如今還說些什麼啊！現在這種情況怎麼能變回去！",
        "unit_id": 104411,
        "voice": "vo_adv_5003005_053"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
