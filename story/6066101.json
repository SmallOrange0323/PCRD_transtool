[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然我們",
        "unit_id": 106611,
        "voice": "vo_adv_6066101_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】公會人數少，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但成員全都是菁英呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不會輸給其它公會。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你一定知道",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是託誰的福吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算是及格的答案吧。",
        "unit_id": 106611,
        "voice": "vo_adv_6066101_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n論打頭陣應該沒有人能比得過嘉夜夜！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那也是因為有我在後方支援她啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在說什麼啊！",
        "unit_id": 106611,
        "voice": "vo_adv_6066101_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大她只不過是個既腹黑又陰險，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只會在暗地裡搞小動作的小咖罷了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我和嘉夜夜才是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】的靈魂人物啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼，",
        "unit_id": 106611,
        "voice": "vo_adv_6066101_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這不是很懂嘛！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可說是靠我才撐起來的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是出了不少力呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "像是跑腿之類的！",
        "unit_id": 106611
    }
]