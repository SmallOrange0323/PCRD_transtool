    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "正在望著你的我，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真是格外美麗呢♪",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵呵♪",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等等，",
