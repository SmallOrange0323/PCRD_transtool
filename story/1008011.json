    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，真是的！",
        "unit_id": 190011,
        "voice": "vo_adv_1008011_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
