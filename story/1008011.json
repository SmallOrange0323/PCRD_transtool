[
    {
        "type": "background",
        "background": "500405"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和雪順利通過了第二道測驗。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接著，他們倆總算是成功抵達神殿所在處。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "終於、",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "終於到了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看這地方散發出的神聖氛圍，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡肯定",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是女神的神殿！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一路上歷經了各種辛勞，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n現在",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總算是能接受女神的祝福了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……不過，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "目前感覺似乎還沒有受到祝福哪。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟在來神殿的途中有碰上測驗，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我想在這邊",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大概也有類似的東西要挑戰吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "愛梅斯神該不會，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是認為忍耐是種美德",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n的那一種女神吧……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "反正傻傻站在這裡也不是辦法，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我們前進吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "根據聽到的消息，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡似乎有座女神像……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n啊！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "並且還正好有個",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "供人參拜的空間呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "去祈求一下，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "希望能平安通過測驗吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也要",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了我祈禱喔！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "女神大人，",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還請賜給我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美的祝福……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊……",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "發光了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難不成",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這就是祝福？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這光芒會不會有點太耀眼啦？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇、",
        "unit_id": 100811,
        "voice": "vo_adv_1008011_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇啊啊！",
        "unit_id": 100811
    },
    {
        "type": "background",
        "background": "510091"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在外頭處理完事情後，回到了家裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當他一打開自己房間的門──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有夠慢的。",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然這麼晚才回來，你是做什麼去了？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還問為什麼呀。",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我看了你的訊息，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這到底是什麼意思？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我原本可是很期待",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今天的約會，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "結果你竟然突然說要取消。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比起看一長串的道歉文，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我更想要你親口說明，所以就跑來啦！",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在你給出一個能接受的解釋前，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我可是不會回去的唷。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你為什麼想要逃跑、",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呢！",
        "unit_id": 100832
    },
    {
        "type": "still",
        "still": "100801101"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不會生氣的，就告訴我嘛？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "究竟是有什麼事，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比跟我約會還來得重要呢？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別把臉轉開啦。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好好看著我的眼睛呀。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我呀，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非～",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "常期待今天的喔？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不僅用玫瑰精油保養肌膚，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n還去了髮廊將頭髮弄得閃亮滑順，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也特地挑選可愛的衣服穿。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你應該看得出來吧？",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n今天的我，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是比平常還要耀眼喔。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然而，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你卻……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難得我特地想展示自己最美麗動人的模樣給你瞧瞧，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n結果你竟臨時說不來了……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這不像是你會做的事啊。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我問你……",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "到底發生了什麼事？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你平時",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是絕對不會做出這麼過分的事唷？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我希望",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可以至少說明一下理由。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣呀。",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "簡單來說，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n有其他學校的男同學誤以為",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是我的男朋友，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n並在今天早上",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "突然就跑來找你一決高下，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是嗎。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你不想讓我擔心，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就瞞著我私下去找對方談了……？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "結果對方一直不太能接受你的說詞，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但畢竟你又不是",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我真正的男朋友，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以也不敢表現得太強勢……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因此，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最後才會拖到這麼晚……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你後來還是有成功讓對方接受你的說詞了……？",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此。",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "確實很像你會做出的事。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然是為了可愛的我才這麼做的，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那也不能怪你了。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是下次再發生這種事，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "立刻通知我。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我會和你一起去找對方。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然實在是很懶得處理這種麻煩事，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但畢竟是我的可愛所引起的嘛。",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我還真是",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "罪孽深重呀……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有了，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不如就趁這個機會……",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓誤會成真如何？",
        "unit_id": 100832
    },
    {
        "type": "still",
        "still": "100801102"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的意思是，",
        "unit_id": 100832,
        "voice": "vo_adv_1008011_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「要不我們乾脆",
