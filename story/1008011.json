    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也用不著再顧慮太多，",
        "unit_id": 100832
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n而且以我的立場來看，",
