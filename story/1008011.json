        "voice": "vo_adv_1008011_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就這麼辦吧……",
