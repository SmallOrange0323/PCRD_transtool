    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對此現況具有相當的把握，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們究竟該做什麼才行？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝各位。",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "首先請大家專注在處理闇影身上。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "處理闇影嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_2014007_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n確實當下，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個城內，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n除了魔物之外也充斥著不少的闇影……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，",
        "unit_id": 101711,
        "voice": "vo_adv_2014007_057"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "闇影和魔物不一樣，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不但不會攻擊我們，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且大多還會自己跑掉唷～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_2014007_058"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起這麼做，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不如讓我們集合在場所有人的力量，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "將敵人的頭頭……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n將霸瞳皇帝直接給擊倒，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會不會還比較快呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下能明白各位的心情……",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n當下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一部份在此城內徘徊的魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和近乎所有的闇影，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎皆是能",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向霸瞳皇帝提供有益情報的終端。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要牠們還留於此處，",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸瞳皇帝就能",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "預測在下方的攻擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並且進行迴避……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此這般。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是從變貌大妃的似似花小姐那，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在方才不久前",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所聽聞的一番話。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "簡單講……",
        "unit_id": 104311,
        "voice": "vo_adv_2014007_061"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是為了封鎖他的眼睛，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以得先把雜魚們都幹掉嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然有點麻煩……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但不管魔物還是闇影，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n到最後都不全部揍飛也不行嘛，都一樣呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔呣唔呣！",
        "unit_id": 101112,
        "voice": "vo_adv_2014007_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就是俗話說『射賊先射王，騎人先騎馬』",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是「射人先射馬，擒賊先擒王」",
        "unit_id": 104911,
        "voice": "vo_adv_2014007_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是呀但是呀，",
        "unit_id": 100111,
        "voice": "vo_adv_2014007_064"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要說全部的闇影，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n可是不知道到底有多少隻唷？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "蘭德索爾還非常的大呀……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說得也對…‥",
        "unit_id": 100311,
        "voice": "vo_adv_2014007_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "儘管並非是不可能之事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但自然也得耗費不少相應的時間。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而就在這期間，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我可不認為霸瞳皇帝會就此輕易放過我們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝，",
        "unit_id": 105811,
        "voice": "vo_adv_2014007_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他現在",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正被我們所拜託的克莉絲提娜他們拖延著腳步中。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是那個人的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想應該不會簡簡單單就被打敗了才是。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "克莉絲提娜……",
        "unit_id": 104311,
        "voice": "vo_adv_2014007_067"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙嗎……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過嘛，",
        "unit_id": 101711,
        "voice": "vo_adv_2014007_068"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然是個討厭的傢伙……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但如果是當夥伴的話就很可靠呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且……",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人似乎從拉比林斯達小姐那，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被託付了兩種的力量。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其一為，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能與『七冠』抗衡之劍。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "另外一個是，",
        "unit_id": 105811,
        "voice": "vo_adv_2014007_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n比平常提升了更多效果的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能夠替我們進行強化的力量！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請各位，",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在此效果的範圍內散開……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並且一面配合著主人進行移動，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一面將敵人各個擊破。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然會變成得依靠空中的小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_2014007_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和【慈樂之音】的人來提供情報，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n並且會是一場必須到處跑來跑去的戰鬥……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但請大家能夠相信他，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且助我們一臂之力！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911,
        "voice": "vo_adv_2014007_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就拜託您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對各位一同進行強化了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "喔喔～！",
        "unit_id": 1,
        "voice": "vo_adv_2014007_074"
    }
]