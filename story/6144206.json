[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的是個很體貼的人呢。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n居然為狀況不好的龍次先生",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "特地舉辦茶會。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……如果說，",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "當你也像龍次先生一樣沒有精神的時候，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要做什麼才會讓你感到開心呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你說只要抱著這樣的心意待在你身旁，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "心情就會變輕鬆？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……感覺",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是很成熟的思考方式呢，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我很能理解。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會按照你說的，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "相信你會變得有精神，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "努力協助你的！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你很愛撒嬌呢！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你老是說這種話，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才會被人覺得",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是變態可疑分子喔？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……雖然我是會摸摸你的頭啦。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦……",
        "unit_id": 130711,
        "voice": "vo_adv_6144206_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦咦！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我認為就算模仿龍次先生的打扮，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也不會變得有精神喔！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "反而",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有可能會被花朵吸走養分！",
        "unit_id": 130711
    }
]