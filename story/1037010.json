[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾郊外。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}受到智的邀請，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和她一起進行劍術修練。"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "──呼！",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好可惜，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "剛剛的突擊太淺了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "劍法不錯喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你來作為對手的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺會是個不錯的修練。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是……",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就像我常說的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為我是御久間流繼承人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然被爺爺如此激勵了，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n往後",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就得比平時更加",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "提起幹勁鑽研劍術。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "特別是御久間流的奧義……",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果無法習得，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在找夫婿之前，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "首先無法自稱為流派繼承人呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "果然很好奇吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "御久間流的奧義",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "──又稱為",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "「開光的架勢」。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在一瞬間由守轉攻……",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如閃光一般發動攻擊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "進行所謂「防守反擊」的劍技喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "劍的速度、",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "動作身手、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "判斷情況的眼力……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "凡是劍士所需要的資質，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "全都會備受考驗。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "習得的難度並不一般。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……正因如此，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "才會希望你認真出擊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可別手下留情喔。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想著你要",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "連同這把劍將我擊倒，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "試著使出全力。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是這股氣勢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "隨意攻過來吧！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……等等。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我不是說了要你認真出擊嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比剛才更沒有氣勢了耶？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我可是使出全力了喔。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你如果特別放水的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可是會受傷的喔？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "──嗯",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也不怪你。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你啊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實在太溫柔了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n偶爾會讓我感到抱歉呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "暫時就先",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "習慣和我一起修練吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像這樣緊張得全身僵硬的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也很難出擊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我有個提議……",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要不要跟我玩個遊戲？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不需要認真出擊。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n任何形式都可以，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要擊中對方一劍就獲勝。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是輸的那一方",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要聽對方的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "任何要求。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……算是個打賭比賽吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也不覺得可以透過這個小遊戲",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "習得奧義就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天的話",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就當作互相緩解緊張吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如何？",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要試試看嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那我們就馬上",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開始第一回合吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來吧來吧……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呵呵，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像這樣觀望沒關係嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再繼續磨磨蹭蹭的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我要出手了──",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嘿！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈哈，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉抱歉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖說只是玩個遊戲，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和我正面對決的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就會變成這樣呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "剛才的就當作練習吧。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "接下來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會放水的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "首先，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我想想……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我只用一隻手跟你打。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n然後",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果我的劍掉落了也視為落敗。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要不然，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我連續取勝的時候，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再補上其他的放水條件也可以喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如此一來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你也會有勝算，對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呵呵，",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如何？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要挑戰看看嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好的，來吧。",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "接下來就正式開始囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……不要再呆呆觀望了喔？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "堂堂正正地",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一決勝負！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣開始的比賽打賭──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n放水的結果依然仍是智的連勝。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "──看招！",
        "unit_id": 103711,
        "voice": "vo_adv_1037010_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "又是我贏啦♪",
        "unit_id": 103711
    },
    {
