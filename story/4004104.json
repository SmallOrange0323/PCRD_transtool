    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明還沒有輸，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "氣勢不可以先弱掉啦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也對。",
        "unit_id": 105811,
        "voice": "vo_adv_4004104_004"
