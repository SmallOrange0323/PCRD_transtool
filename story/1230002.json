        "words": "這就是所謂的心煩意亂嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有的時候",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也會有這種情緒喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來該說什麼好呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來說那件事好了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽好囉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是在──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──事情就是這樣……",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了查明真相，你知道我花了多少時間嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就連待在系統裡的我來看，那也是件很混亂的事啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不僅有這回事，",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也真的是累慘了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會讓以前那麼天真爛漫的我這樣鬧彆扭，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這種的事件還多得是你所不知道的呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你能夠明白？",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說得也是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也遭遇了不少事嘛……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我守護著像這樣的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然無法對任何人說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我也是歷盡了滄桑……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了體貼愛梅斯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n原本還打算聽她說到心滿意足為止。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而──"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……就是這麼回事。",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我所做的努力終究全化為烏有。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正我已經很習慣這種事，倒也無所謂了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你肚子餓了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就你的體感時間來看，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我才只說了６小時而已耶……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你至少得陪我12小時。",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這之後，我就會依約放你回去。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你開始覺得無聊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那我就找些比較刺激的話題來說吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這樣跟你聊天，",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n感覺自己好像也越聊越開心了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n難得可以聊這麼久，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還有很多話題想說喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟，",
        "unit_id": 190011,
        "voice": "vo_adv_1230002_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "女孩子本來就比較多話嘛……♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……{player}在那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一直在夢裡聽愛梅斯說話，當天醒來時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那種睡不好的難受是他從未體驗過的。"
    }
]