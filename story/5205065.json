[
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "罪狀是打架造成破壞公物，",
        "unit_id": 51611,
        "voice": "vo_adv_5205065_000"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "以及爭吵噪音打擾到了鄰居～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n有什麼話想說的嗎～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "兩位？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "「都是華音的錯！」\n「都是紡希的錯！」",
        "unit_id": 1,
        "voice": "vo_adv_5205065_001"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "距離兩人吵架已經過了一段時間",
        "unit_id": 51611,
        "voice": "vo_adv_5205065_002"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "卻還是在氣頭上嗎～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎士閣下先生，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "該怎麼辦呢～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才不要，",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那樣子太丟臉了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你到底在說什麼。",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_004"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "胡鬧也該有個限度吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "……喵。",
        "unit_id": 1,
        "voice": "vo_adv_5205065_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼我要受到這種對待……",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有錯的明明是華音喵。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "在妳肯接受懲罰的那一刻起，",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_007"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n不就代表紡希妳自己也承認有錯喵？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "華音不也一樣喵！",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且說起來",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算我有錯，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也是華音妳錯比較大喵！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啥～～～～！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_009"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這樣的話比起本小姐，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n紡希妳還要錯更大更大喵！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那華音妳就是錯更大更大更～大喵！",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_010"
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "呼喵────！！！",
        "unit_id": 1,
        "voice": "vo_adv_5205065_011"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，她們又像小孩子般地吵了起來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一直到兩人精疲力盡為止。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "………………那麼，",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然百般不願意，就由我先來吧。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我認同妳那坦率的內心跟死纏爛打的毅力。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……畢竟我們也曾經共鬥過。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以姑且。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "勉為其難地。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哼……",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_013"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐也認同妳",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是個能託付背後的人。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "而且也不愧是個偶像，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "身上感受不到庶民氣場，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n也很有毅力。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "大概。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "可能吧。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是啊……",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是華音，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "希望妳放聲大笑時能再多看一下場合……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "看一下場合……？",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_015"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不對吧",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "紡希，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "何時、想在哪裡放聲大笑",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "都是本小姐的自由！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳就是這種部分不行啦！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n旁若無人的言行舉止總是",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "造成別人的困擾！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哦～",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_017"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "紡希妳動不動就馬上生氣找本小姐架吵這點，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不也一樣會造成困擾嗎～～～～？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所──",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "以──",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說──！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啥～～～～？？？？",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_019"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "明明一度看起來要和好了，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻又馬上開始吵架的華音與紡希。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n到最後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人還是持續吵架吵到了精疲力盡為止。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那有什麼問題！",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "決勝布幕拉起！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n看誰饒舌比較行！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正還是我會贏！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "看樣子，",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_021"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "比賽已經開始了呢。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那我也來！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "妳那歌詞，無力軟爛！",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_022"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我聽不見，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "毫無波瀾！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "再來一段熱度上翻！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還是妳已疲憊不堪？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "──笑妳不敢來嗆看看，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "即興饒舌可不簡單！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "服裝品味超怪！",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_023"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就說這不是本小姐的時尚品味啦──！！",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_024"
    },
    {
        "type": "background",
        "background": "502115"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "遜咖大小姐！",
        "unit_id": 134812,
        "voice": "vo_adv_5205065_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "悽慘地上貼！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "旁若無人就是妳的態度！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "時尚品味已經音訊全無──！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "傲嬌還裝！",
        "unit_id": 134912,
        "voice": "vo_adv_5205065_026"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "刻薄偶像！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "嘴巴狂妄就該拉鍊拉上！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "態度囂張等著吃我一掌──！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不只沒結束",
        "unit_id": 51611,
        "voice": "vo_adv_5205065_027"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "還反而越吵越激烈呢～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "用靈魂進行饒舌對決的兩位，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我其實並不討厭哦～♪",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這場饒舌戰鬥就在沒有評審也沒有判定的情況下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一直持續吵到兩人精疲力盡為止。"
    }
]