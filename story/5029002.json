    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 111611,
        "voice": "vo_adv_5029002_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那是舞台劇裡的正義英雄對吧？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "鈴鈴噹……？",
        "unit_id": 111711,
        "voice": "vo_adv_5029002_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　那是什麼？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「我要為全世界心中充滿愛的人們，",
        "unit_id": 111611,
        "voice": "vo_adv_5029002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "搖響這祝福的鈴聲！」",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「各位，久等囉，",
        "unit_id": 111611,
        "voice": "vo_adv_5029002_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就是魔法少女鈴鈴噹」……☆",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我記得是這樣。",
        "unit_id": 111611,
        "voice": "vo_adv_5029002_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也看過那個。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不自覺地就模仿了起來，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真有點害羞。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這一局我贏定了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n茉莉想要的東西，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我克莉絲提娜\n可是再清楚不過了……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧小伙子，",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你願意助我一臂之力嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果你拒絕的話，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只讓我帶走一臂也無妨……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以啦！製作人！",
        "unit_id": 111611,
        "voice": "vo_adv_5029002_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}你來幫我吧！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "謝啦，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我們為茉莉送上聖誕節的祝福……☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "茉莉她平時",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總是說想成為",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n正義的夥伴……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多麼惹人憐愛的夢想啊！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明明這世上根本沒有絕對的正義……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_026"
    },
    {
