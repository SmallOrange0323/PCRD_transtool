    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "告訴妾身那個女孩她想要什麼吧！",
