        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "天冷的時候就是要活動身體才行！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是個菜鳥的我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "想成為「正義的夥伴」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就必須得不斷練習！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我回來了，",
        "unit_id": 111511,
        "voice": "vo_adv_5029002_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的老家……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大家最愛的聖誕老人克莉絲提娜回來囉。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧～盛大地歡迎我、感激我，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "索性就這樣陷落吧……☆",
