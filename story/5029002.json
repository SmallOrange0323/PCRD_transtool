    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還一邊自我鍛鍊……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是個努力的乖孩子！",
        "unit_id": 111611
