    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不就是茉莉嗎……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來她還是一樣，喜歡這樣活蹦亂跳的。",
