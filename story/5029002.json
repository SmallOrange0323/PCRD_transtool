        "voice": "vo_adv_5029002_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "下一個獵物……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不對，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "送禮的對象",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就決定是她了！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
