[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利（？）交出暑假作業的幾天後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n惠理子跟靜流邀請了許多一頭霧水的人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備舉辦宴會。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了慰勞弟弟做作業的辛苦……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "兼向【王宮騎士團】的大家道歉，",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我們要舉辦烤肉派對。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼……",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_002"
    },
    {
        "type": "dialogue",
        "name": "靜流、惠理子",
        "words": "乾杯～！",
        "unit_id": 1,
        "voice": "vo_adv_5070007_003"
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "乾杯～！",
        "unit_id": 1,
        "voice": "vo_adv_5070007_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我被惠理子找來，",
        "unit_id": 113211,
        "voice": "vo_adv_5070007_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "又跟著大家一起乾杯，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但說起來，這個聚會的目的是什麼？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n慰勞做作業的辛苦？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "道歉？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "知道事情來龍去脈的我們更加搞不懂咧。",
        "unit_id": 110211,
        "voice": "vo_adv_5070007_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "她們到底為什麼會搞出那種事……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莫非惠理子大人",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又搞砸了什麼嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原本還以為她只是搞砸了什麼，",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n結果事件規模根本大到不能用搞砸兩個字解決啦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那天的惠惠跟小靜",
        "unit_id": 110011,
        "voice": "vo_adv_5070007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超搞笑的！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我一到學校就看見【王宮騎士團】的人倒了一大片，",
        "unit_id": 110211,
        "voice": "vo_adv_5070007_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n嚇死我了。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明發生過那種事，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼\n【王宮騎士團】的人會出現在這裡？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "其實是",
        "unit_id": 712,
        "voice": "vo_adv_5070007_012"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "因為我們沒能鎮壓她們兩個人，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n所以被團長狠狠教訓了一頓……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了向【王宮騎士團】賠罪，",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我們現在會參與他們的訓練。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難得有這個緣分，",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們就也邀請他們來參加這次的派對了。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那",
        "unit_id": 113211,
        "voice": "vo_adv_5070007_015"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為什麼也找我們來？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為妳們是跟{player}大人",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一起享受過暑假的夥伴。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是那個獨角仙之夜嗎……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那真的是……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該怎麼說好呢，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的是很特別的一晚啊……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 110111,
        "voice": "vo_adv_5070007_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我看過{player}的圖畫日記了。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你的暑假似乎過得非常開心呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真好～！",
        "unit_id": 110011,
        "voice": "vo_adv_5070007_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我也想跟",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "惠惠她們玩個痛快～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那是……",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說得也是呢。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請大家",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "務必一起玩吧。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "下次要去更加和平的地方喔！",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不要再去充滿魔物的森林了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈，",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當然了……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊！！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那邊的肉快沒了！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們來去補充吧，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我明白了。",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "各位請盡情享用吧。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n今天",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "由我們來招待各位。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "先失陪一下。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個惠理子",
        "unit_id": 113211,
        "voice": "vo_adv_5070007_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "居然說要",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "招待我們……？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種好事",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "以後可能不會再有了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天就盡情吃個痛快吧，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好！",
        "unit_id": 113211,
        "voice": "vo_adv_5070007_026"
    },
    {
        "type": "still",
        "still": "507000701"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後靜流閣下",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就拿巨大的投網",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "扔了過去！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇，",
        "unit_id": 110111,
        "voice": "vo_adv_5070007_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "她是用那個投網捉住巨大獨角仙的對吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "正確來說",
        "unit_id": 113211,
        "voice": "vo_adv_5070007_029"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是像獨角仙的魔物",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啦。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且",
        "unit_id": 110011,
        "voice": "vo_adv_5070007_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你們還在無人島上蓋了房子對吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "居然會",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "蓋房子，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也太秀才了吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不，",
        "unit_id": 110211,
        "voice": "vo_adv_5070007_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這也牛皮吹得太誇張了吧……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難不成。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好吧，",
        "unit_id": 113311,
        "voice": "vo_adv_5070007_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是惠理子大人的話，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "確實有可能辦到那種事呢……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那兩人",
        "unit_id": 110211,
        "voice": "vo_adv_5070007_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的很不簡單呢……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳看。",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家看起來都好開心。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我居然有這麼一天",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會招待{player}大人以外的人，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n過去真的是料想不到。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們因此",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才能看到只有我們兩人時所看不到的",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟的笑容呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "獨占他時所無法看到的{player}大人……",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n他肯定還有很多",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們還不曉得的一面呢。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不用因此難過喔，",
        "unit_id": 117111,
        "voice": "vo_adv_5070007_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "惠理子。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為那代表我們還能看到弟弟各種不同的一面！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "像這樣站在稍遠處欣賞的{player}大人，",
        "unit_id": 117011,
        "voice": "vo_adv_5070007_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n也是十分迷人……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
