[
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "你們根本就傷不了我的，",
        "unit_id": 11412,
        "voice": "vo_adv_5015211_000"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n竟然能做到這個程度，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "還真是令人吃驚啊！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這就是",
        "unit_id": 105311,
        "voice": "vo_adv_5015211_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "得到了同伴之力的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是我們",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "【純白之翼 蘭德索爾分部】的力量！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 109611,
        "voice": "vo_adv_5015211_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "惡代官！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n差不多是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "惡報來臨的時候了！！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "呵……",
        "unit_id": 11412,
        "voice": "vo_adv_5015211_003"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "這就是同伴之力啊。",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "原來如此。",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n那麼，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "我就教教你這股力量有多脆弱吧！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n出來吧出來吧！！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、",
        "unit_id": 109511,
        "voice": "vo_adv_5015211_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那是……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花他們！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還有我",
        "unit_id": 109611,
        "voice": "vo_adv_5015211_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和莫妮卡也在！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "妳就和重要的同伴自相殘殺吧。",
        "unit_id": 11412,
        "voice": "vo_adv_5015211_006"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n喂，你們！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "　把那個野蠻的傢伙砍死！！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別做無謂的事了。",
        "unit_id": 105311,
        "voice": "vo_adv_5015211_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們是同伴，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼可能被冒牌貨給迷惑……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哪、",
        "unit_id": 109511,
        "voice": "vo_adv_5015211_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "哪個才是真正的莫妮卡啊！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要是剛才有買點心的話，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n說不定就分得出來誰才是真的了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只要同時",
        "unit_id": 109611,
        "voice": "vo_adv_5015211_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "攻擊兩邊的空花就……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n結果只讓兩邊都很開心！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 105311,
        "voice": "vo_adv_5015211_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣下去真的要開始自己人打自己人了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然這樣，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就用",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "榮耀的軍人之劍",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n來證明誰才是本尊吧！",
        "unit_id": 105311
    }
]