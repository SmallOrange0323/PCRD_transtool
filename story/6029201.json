        "voice": "vo_adv_6029201_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還真是柔弱呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點寒冷，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要動一下身體就能克服了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
