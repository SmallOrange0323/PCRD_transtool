    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_001"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……我說，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_002"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "身上",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是不是有騷味？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "受不了，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_003"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是沒教養。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "來找我之前，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n先去好好洗個澡呀。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "受不了你，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_004"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n那就麻煩你",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "隨時保持清潔吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_005"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你身上會有騷味也是無可奈何的吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "畢竟這次",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "除了女孩子之外，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "又多了寵物呀。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是叫【蠻賊三姊妹】",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_006"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "聽說你對上那些盜賊",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "似乎打得很辛苦。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "也因此才能賣人情",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_007"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n給「吉歐‧提格尼亞」的人。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是太好了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "事情進行得很順利呢♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_008"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯……",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_009"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "有嗎？",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_010"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我有說過那種話嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯～",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_011"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n真拿你沒辦法～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……第一點",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_012"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你應該也心知肚明。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「認知修正」。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "老實說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "除了你們以外幾乎所有人都有被修正。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這點就死心吧？",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_013"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "並沒有那麼不好，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n反而",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "該說是必要的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "話說，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_014"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你們似乎也已經很習慣了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "所以才能抵抗？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是有夠囂張的──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……不過，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_015"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "虧你們都背負著「懲罰」回來了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n要是把目的也給忘了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "根本是適得其反啊。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這部分就先睜隻眼閉隻眼的感覺──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_016"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "唉……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你怎麼今天",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_017"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "一直狂問問題呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我說過好多次了，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_018"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我啊，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "可不是跟你站同一陣線喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我想捉弄耍著你玩。",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_019"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n懂了嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "因此──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我不會白白告訴你。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過相對的，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_020"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我就出問題來考考你。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對。",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_021"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我可以享受著看你煩惱的模樣，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n（搞不好）",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你也能找到答案──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哈哈。",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_022"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這麼做不是可以讓我們雙贏嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_023"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "要開始囉～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "第一題。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你快想想看，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_024"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "為什麼你這次",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "會打得那麼辛苦？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "在你心裡，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_025"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "應該有察覺到說",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n可以打得更輕鬆才對吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……♪",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_026"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哎呀，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_027"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這樣喔～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真不可思議耶～",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_028"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n為～什麼會用不出來呢──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "誰知道呢？",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_029"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "只不過……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我猜搞不好……",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_030"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n或許是可以使用時的契機，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n現在變得無法使用了吧──？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_031"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哎呀呀，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我又說得太多了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過啊，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_032"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就我而言，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「懲罰」的內容，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n還是公主型態之類的強化根本不重要──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "比起那些，",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_033"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我想出給你的問題是──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──為什麼",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_034"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "必須要進行認知修正呢？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "滴答、",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_035"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "滴答、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "滴答、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "滴……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好♪",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_036"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n時間到──♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_037"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯哼♪",
        "unit_id": 193211,
        "voice": "vo_adv_2202099_038"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就是這個，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就是這張",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "很不滿的表情──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
