[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……明明如此美味……",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "卻又曖昧朦朧、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "細膩而難解……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n入口時宛如清流的魚一般，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "迅捷而優雅地滑過喉間，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "餘韻轉瞬即逝，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "短暫到",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "甚至來不及",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓人沉醉……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "舌尖之上，",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只餘下一縷淡淡殘香。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "然而，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "卻讓人",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "無比滿足。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每一口都變化萬千的滋味，令人感到非常新鮮，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "絕對會讓人上癮！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "無論是食材還是烹調方式都完全無法猜測，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我還是第一次有這樣的體驗呢～！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "能讓您喜歡，",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_002"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "實在是我的榮幸。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這是在吉歐‧尼布爾黑爾之中，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也是少有人知的珍稀料理。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我在巨鯨城書庫中的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "古老書籍裡看到，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "並試著把它重現出來……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "拜託妳了，",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "吉歐‧尼布爾黑爾的公主。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳能不能告訴我，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這道料理到底是用什麼東西做的呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這可是商機！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "毫無疑問，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會成為一筆大生意的點子呀！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "生意……？",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "您的意思是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "要把這道料理，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "賣給某些人嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正是如此！",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算是在其他世界，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也肯定會掀起話題，大受歡迎！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "人們",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會被這道神祕料理的魅力深深吸引，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最後，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "吉歐‧尼布爾黑爾",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會因為大量訪客而變得熱鬧非凡！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "若能為吉歐‧尼布爾黑爾",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "帶來生氣，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我當然也會",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "感到開心。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "只是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有什麼",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "問題嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "其實，",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這道料理……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "每次製作、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "每次品嚐時，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不論味道還是外觀都會改變。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不只是完成後的料理，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就連食材本身，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也會持續變化。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "想要重現它極為困難，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也無法穩定提供──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_5213095_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這不是太棒了嗎！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一生一次的滋味，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這可是最棒的體驗價值了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "麼",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "薇歐莉特，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們立刻來擬定計畫吧！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n作為跨越世界經商的夥伴！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這正是",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們大顯身手的時候了，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦呵呵呵呵！！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "啊哇哇哇哇……",
        "unit_id": 133111,
        "voice": "vo_adv_5213095_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "難道，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我正逐漸被捲入某個不得了的大計畫中嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請救救我……！",
        "unit_id": 133111
    }
]