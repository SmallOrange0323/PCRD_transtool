    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然是在夢中，但我真的很膽小呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又是不熟悉的地方，",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_057"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n想到說不定沒有人會來幫助我，",
        "unit_id": 100111
