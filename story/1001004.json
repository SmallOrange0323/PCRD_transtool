    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就在這條路的中間……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那個。",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_054"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……難道騎士先生，在夢中幫助了我嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然！ 我們都做夢了呢！",
