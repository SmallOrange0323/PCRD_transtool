        "voice": "vo_adv_1001004_058"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不安的心情，在不知不覺間全都飛走了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來內心暖洋洋，是這樣子的感覺呢。",
