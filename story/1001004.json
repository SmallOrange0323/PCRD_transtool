[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步的時候，\n剛好碰上了在這附近閒逛的日和。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真奇怪呢……",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n明明應該在這附近的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，騎士先生！ ",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唷嗬！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？　騎士先生問我在做什麼嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個呀……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "並、並不是什麼大不了的事情所以請不用在意！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我看起來好像有煩惱是嗎……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……果然騎士先生很厲害呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過沒事的！",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這種程度的事情，我自己一個人也能――",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇，這是怎麼回事！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好、好刺眼喔……！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喂～、比奇～！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你到哪兒去了呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明應該飛到這附近的說……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然是鸚鵡，會不會開口說話回應我呢……？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比奇！ 你在哪裡呀～！？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然還是不會回應我呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n該怎麼辦才好……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然有點遠，如果從這裡折回學校，",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n叫人來幫我的話應該有辦法的吧……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這裡是哪裡！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然是學校，但不是我平時上課的學校呀！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道我……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一心只顧著追比奇，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不小心來到了陌生的地方！？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎、怎、怎麼辦呢！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～，學校是在……那、那邊的吧？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，我好像是從這邊的路走過來的……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道說，我迷路了嗎！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的！ 我該怎麼辦才好呀！？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才不是沒有事呢！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我想找人問路，但一個人也沒有……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，有人出現了！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你、你好！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真、真的有人來幫助我了！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了……有人在這附近出現了。你是這間學校的人吧？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，我好像迷路了……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果方便的話，你可以告訴怎麼走嗎？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在學校飼養的鸚鵡飛走了……我追著牠走著走著，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n結果找不到回去的路……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且我還沒找到那隻鸚鵡……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？　你說牠在那棵樹上──",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_021"
    },
    {
        "type": "dialogue",
        "name": "比奇",
        "words": "過來這邊，過來這邊！",
        "unit_id": 1911,
        "voice": "vo_adv_1001004_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊、真的呢！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n竟然在那種地方！？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比奇……我馬上過去捉你，",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要在那裡乖乖地等著我唷……！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這種程度的樹，我馬上就能爬上去――",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……現在開始不能抬頭往上看呦？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為會看到裙子裡面呀！　知道嗎？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明白了嗎？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n直到我回來為止，要乖乖等我唷？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唷！　喝！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比奇……不要動唷……！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……很好！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "成功了！抓到牠了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比奇，我現在爬下去了，你要乖乖的唷……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "比奇",
        "words": "不要，不要！",
        "unit_id": 1911,
        "voice": "vo_adv_1001004_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喂、喂！　不要亂動呀！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚哇！　要、要掉、要掉下去了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好痛痛……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？　不痛呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你沒事吧！？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉……你乖乖站著不動，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我卻把你當成墊背了…",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這樣呀！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是你把我接住了……！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你呢！　你真的很溫柔呢！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "托你的福，我和比奇才沒有受傷呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，我要回學校了……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對、對了！　我、我迷路了說！？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你能幫我帶路嗎？",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說回來，你是幾年級學生呢？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！？　原來你是我學長呀……！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我還以為你是跟我同年呢……嘻嘻。",
        "unit_id": 100131
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──來到這裡就已經沒問題了！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接下來就算是閉上眼晴也能回到學校唷！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長，今天真的很謝謝你！",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不只為我帶路，還有比奇的事也謝謝你！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的幫了我很多忙！　再見囉！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！　",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，學長你的名字是――！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……已經走掉了。",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來不及問他的名字呢……",
        "unit_id": 100131,
        "voice": "vo_adv_1001004_043"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我們還會再見吧，學長……？",
        "unit_id": 100131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，竟然不小心迷路了，",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n日和只要一專心的話就會忽略了周圍的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不覺得，不過就是隻鸚鵡而已嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但就因為學校的大家會傷心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而奮不顧身去找那隻鸚鵡……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子，比起自己的事，",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會更在意別人的煩惱呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該說是捨己為人嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是種很麻煩的性格呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，你也是同類呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果這樣的話或許就能體會呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你能理解日和的心情的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就請你讓她不要太勉強自己，好好扶持她吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼、這次閒聊到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1001004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯、嗯嗯……？",
