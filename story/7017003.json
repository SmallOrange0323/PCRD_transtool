[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "往塔頂繼續前進的一行人，於某個樓層稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼會如此美麗動人呢……",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真想",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "永遠注視著",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "完美無缺的",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我……♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "整天盯著那面鏡子看，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真虧妳不膩啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是自己的臉，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看久了也是會厭倦的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我是世界上最美麗的人。",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且每分每秒",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美麗",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都在與時俱進唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳的外貌出眾這點，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "確實不可否認。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而資質上呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看起來魅惑魔物是沒問題。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要讓我打磨一番，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一定能更加出色。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果妳有意願的話，我來幫助你出道吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "出道？",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別看我這樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我涉足的領域可廣著呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我曾著手支撐公會財政的大型事業，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也曾將某個牧場打造為觀光景點。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也正擔任著時下當紅偶像",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n的製作人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳意下如何呢？",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要交給我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我保證",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一定能將妳打造成比鑽石還耀眼的明星。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓我成為明星……？",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "意思是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "成為偶像出道嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不得不承認，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳那不為他人所動、忠於自我的色彩，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓妳相當地惹人注目。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在旁人看來",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也許太獨樹一格……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但換言之，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這也代表妳的個性絕無僅有，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不會被他人所取代。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想像一下。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳身處聚光燈照耀的舞台上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "成千上百的人們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n正屏息凝神的望著妳。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有很多的人",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沉醉於我的魅力……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這個情景",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真不錯，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我有點感興趣呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克莉絲提娜小姐，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n妳能否提供與我的美貌相襯的舞台呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼意思？",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然很高興妳這麼醉心於我……",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但我有點擔心，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳能否提供得出，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n能與我的美貌互相匹敵，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "甚至更加烘托的舞台。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "假如",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "本應照亮我的聚光燈，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n因為舞台上太過耀眼的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "反而",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "黯然失色的話",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼行呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果舞台不能襯托出我的美貌，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那不管在哪裡不都一樣嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為不論身處何方，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美麗都無懈可擊呢♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克莉絲提娜小姐，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳有辦法將我的美貌",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "發揮得比現在還要淋漓盡致嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來我還真是被小覷了啊？",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳想像的事情",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本不值一提。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "何止是那種程度。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果不能",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把妳提升到妳原本絕對無法到達的高度，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我來打造的意義不就沒了嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然是交給我負責，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就不會允許半吊子的成果。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會用克莉絲提娜式的斯巴達教育──",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n從早到晚、徹頭徹尾的訓練妳唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嚴苛程度保證連【王宮騎士團】的新兵都會落荒而逃呢☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不要露出那麼擔心的表情嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你大可放心，我自有分寸。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要精準地控制在讓新兵們勉強死不了的程度，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可不是件易事喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連士兵們都會感動到",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在訓練的最後一天痛哭流涕呢☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然該有的福利也不會忘。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n休假時",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就安排到冠以我之名的度假SPA",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n去做保養及美體吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不僅如此，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還會動用我所有的人脈，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n以各種資源及設施",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打造最棒的環境，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來讓妳",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "登上頂點。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在最棒的環境中，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最美麗的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n在世界的舞台上展翅高飛……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我彷彿也看見了那種光景……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我會生得如此可愛又帥氣呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來是因為",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要讓我的美麗",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "造福整個世界啊……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯！",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就用妳的那副美貌！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那美麗的雙眸、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蠱惑人心的嗓音，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來讓蘭德索爾的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "全世界的人們為你著迷吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我有個條件。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果能將我那無止境的魅力……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n更加琢磨的話，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管什麼條件都可以唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來吧，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓我聽聽妳的要求。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好……",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會負起培育妳的責任。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n相對的，妳的出道方式到服裝都得讓我一手打造。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也就是說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "條件是必須絕對聽從我的指令。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼啊，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_034"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就算了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼好的條件竟然拒絕，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我實在",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難以理解……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "姑且",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽聽妳的想法，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯。",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_036"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的存在本身就很美。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我並不討厭",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "將這份美麗更加琢磨，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也不排斥要將之傳遞給全世界……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我只想要",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_037"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "穿我自己覺得美麗的衣服。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算旁人如何奉承，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我自己",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不覺得適合的話，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不就沒意義了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "衣服這種東西，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不是任人擺布的事物。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的衣服",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "由我自己所選。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好吧，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就當我沒提過這件事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果她是新兵，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這時我會追加海量的地獄特訓，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n並且愉悅地欣賞他們的悲鳴……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算強迫人做不感興趣的事，",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n將來也不會成大器。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "本來",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個小姑娘就是被劍所指也不以為意的人物。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我知道她不為蠻力所屈服、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不會為財富及權力所動。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼就算施加再多的壓力，也不會改變她的回答吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "傻瓜才會繼續做無用功。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "此時靜待良機才是王道……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且……",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想確認看看，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個小姑娘",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是否能夠靠自己破蛹而出。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n觀察她",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也別有一番樂趣……♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了，克莉絲提娜小姐。",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_046"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n剛才",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳提到的各種人脈及資源……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了。",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這跟妳有什麼關係嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想說難得有這個機會，不如就讓我物盡其用吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳有聽到我剛剛說的嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我說要把這件事化為白紙。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 100811,
        "voice": "vo_adv_7017003_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這可是能為我的美貌做出貢獻唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會讓我使用的吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吶，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然還是",
        "unit_id": 107111,
        "voice": "vo_adv_7017003_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "搞不懂這傢伙……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對態度難以捉摸，用純真眼神拜託自己的雪，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不知該如何應付的克莉絲提娜陷入了苦惱。"
    }
]