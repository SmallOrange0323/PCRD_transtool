[
    {
        "type": "background",
        "background": "500553"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "睜大你的眼睛，",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看仔細了～！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這可是【龍族巢穴】大幹部，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人的新年和服裝扮！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就像崇敬曙光一樣，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好好地瞻仰我這身裝扮吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……只不過",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老實說，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了設計成看起來更強的樣子，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我有請嘉夜夜提供意見喔。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這套服裝的亮點",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當然就是",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "花紋！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了表現出強大又幹練的幫派分子魅力，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是下了很詳細的指示喔。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你要是喜歡的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也可以付錢給我讓你拍照喔？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你不要當真啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且還說要",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "拍合照！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要想個擺起來感覺很幹練的姿勢才行……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "繃著臉",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雙手抱胸……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總而言之",
        "unit_id": 128311,
        "voice": "vo_adv_5134401_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你就好好崇敬",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這充滿喜氣的祈梨大人吧！",
        "unit_id": 128311
    }
]