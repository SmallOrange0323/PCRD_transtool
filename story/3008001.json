[
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這一天，蘭德索爾這裡又誕生了一個新的公會。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "創建公會的申請也被受理了，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n立即展開活動吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨、美冬，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請多指教。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也請妳多多指教喔，秋乃。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "經營公會等較瑣碎的工作就交給我們。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨和我會好好支援妳的。",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n妳的父親也對我們說「我女兒就拜託妳們了」呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "曾在父親身邊擔任會計的優花梨、",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n擔任護衛，也擅長實務工作的美冬……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再加上我！ 真是完美的人才呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，具體的公會活動要做些什麼呢？",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳們有什麼想法嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "例如，即使和妳父親一樣做生意，",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也必須決定做什麼生意。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個的話不用擔心。我們先舉辦派對吧！",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "聚集鄰近的權威人士，舉辦記念公會成立的派對！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "馬上就亂花錢！？",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃，我們還沒有收入喔？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在這種時刻花大錢，太沒有計畫了吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美冬說的沒錯呢。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都還沒決定該如何賺錢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且資金也有限，我認為要謹慎使用比較好。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "兩位說的我當然明白。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但是，我們現在有的也只有錢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此，首先應該有效利用資金才對。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們要舉辦派對來大舉宣傳這個公會。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣一來，一定會有遇到困難的人來委託我們工作。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "換言之，妳們就把辦派對想成是跟發傳單一樣吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "原來如此……這樣的話，",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "參加派對的人，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也許能幫我們宣傳呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我明白秋乃也有自己的想法了，",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是派對的費用請交由我們管理。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n可以吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒關係啊。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n倒不如說，我不擅長計算瑣碎的帳目，所以妳們幫了大忙。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "馬上著手準備吧！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯……料理已經安排妥當，邀請函也已經送完了……",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "派對準備得很順利呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……哎呀？ 好香的味道喔？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是從那個攤位傳出來的……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎光臨喵！ 剛做好的鯛魚燒喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那邊的小姐，要不要來一份喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "鯛魚燒……？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那是什麼？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃，妳沒吃過鯛魚燒嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒有，我是第一次看到……",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是烤魚嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好有趣的形狀呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真有意思啊，請給我一份吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝惠顧喵～！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為很燙，吃的時候要小心喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我開動了。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊嗯。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……嗯嗯！？ 好……好吃啊！",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這世界上竟然有這麼好吃的東西！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我深受感動……這是我表示感激的心意。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請收下吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那不是鯛魚燒價錢的十倍以上嗎！",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不要在這種地方浪費錢！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "浪費錢！？ ",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不，這個名為鯛魚燒的食物，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n值得我支付這個金額。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好吃到我想乾脆把整間店買下來……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！ 把店買下來就好啦！",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "店員小姐。這間店，妳願意多少錢讓給我？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳要買下整間店！？ ",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "突然地在說什麼啊喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不要說些蠢話！ 會讓店裡的人很困擾的！",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喏，把鯛魚燒的費用留下，我們就回去吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是啊。派對還有很多事情需要準備。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是沒轍呢……先不說買下店面的事，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們會再來店裡買鯛魚燒的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼店員小姐，祝妳愉快，再見……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……那、那群傢伙搞什麼啊喵？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後――"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "……小、小偷──！",
        "unit_id": 1,
        "voice": "vo_adv_3008001_033"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n可惡！ 好不容易勒索來的錢……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n喂，你們！ 無論如何都要找到犯人！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵──哈哈哈！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n大家收下這個吧喵",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "哇──！ 是錢耶！ ",
        "unit_id": 111,
        "voice": "vo_adv_3008001_035"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "天上掉錢下來了──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "平時的人來了呢……",
        "unit_id": 611,
        "voice": "vo_adv_3008001_036"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n啊，真是多謝呀……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n這樣就可以買藥給孫兒了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯，做了好事心情真好喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好歹我也算一介商人，看不下這種黑心生意喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再來，只要躲起來的話，",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天的懲罰就結束了喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "話說回來，那個義賊似乎又出現了。",
        "unit_id": 1411,
        "voice": "vo_adv_3008001_039"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n聽說他跟往常一樣，撒完錢後就消失了呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "被偷的傢伙還真可憐呢。",
        "unit_id": 311,
        "voice": "vo_adv_3008001_040"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n雖然那傢伙只偷骯髒交易所賺來的錢，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n但誰知道哪天我們的錢會不會也被他偷了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "話說回來，你會去明天的派對嗎？",
        "unit_id": 311,
        "voice": "vo_adv_3008001_041"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n就是那個記念公會成立之類的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "我會去喔。",
        "unit_id": 1411,
        "voice": "vo_adv_3008001_042"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "因為主辦人是那個紫藤家的千金對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "若可以認識社交界的名人，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n說不定就會吸引有利可圖的生意上門呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃……？ ",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像在哪裡聽過這個名字喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……想起來了喵。是前陣子來買鯛魚燒的傢伙喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是想買下打工那間店的可疑傢伙……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聚集商人和社交界人士來舉辦派對，真是可疑喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "反正那一定是靠著狡詐的手段來斂財喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗅嗅……感覺嗅到了壞事喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有調查看看的必要喵～",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "派對當天"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "派對十分豪華呢喵……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，先找秋乃那傢伙喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美冬，後面似乎有一個可疑的男人，妳能去看一下嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_047"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我必須接待來客，所以走不開……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我知道了。秋乃呢？",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_048"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她正和許多人在裡面開懷暢談呢。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_049"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n應該也在洽談生意吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "洽談生意……？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_050"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼……說太多話，下巴似乎痛了起來。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_051"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨、美冬。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n從這一刻開始，我們將開始第一筆生意喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那是無所謂，可是派對還在進行喔？",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_052"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們這樣離開好嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "主辦方並非派對的主角。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_053"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n即使我們不在，大家也能聊得很開心的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "比起這個，先說第一份工作的事！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能幫我依照這份清單，將保險箱裡的錢分開嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也麻煩擬定借貸契約書。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦！　這、這麼大筆錢，要做什麼！？",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_055"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且，契約書……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我剛剛和許多人談過話，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n決定出資或是貸款給那些人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們的第一份工作，就是金融業喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "金融！？ 又在打腫臉充胖子了……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_057"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然這個公會的確擁有一定的資金……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我還以為剛開始一定是製作及販售物品，",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n一步步踏實地從小事做起……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那樣的話，賺到和花費的錢都太少了，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n無論經過多久，公會都無法壯大。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且我應該前幾天就說過，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_060"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們現在有的只有錢而已。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此，就只能用錢來賺錢了，不是嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "首先由金融業開始，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n再以利息為資本，涉足各種事業吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳們兩位都沒有異議吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……原來秋乃並非只是個不諳世事的大小姐呢……",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_062"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "似乎是這樣呢。老實說我也很驚訝啊……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔──呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可以再多誇獎我一點也沒關係喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_065"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳們兩位之前都小看我了吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……派對也結束了，",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_066"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家好像都離開了呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "金錢的貸借是最斂財的方法喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_067"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我必須確認契約書喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "若她們打算收取不合理的利息",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_068"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我就搶走公會所有的錢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯──，契約書應該收在這附近喵……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_069"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_070"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我來看看是怎樣的契約內容呢喵……？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……雖然金額都大得離譜，但利率都很正常喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_071"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "反正這份一定是誘餌，真正的契約書在其他……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……不要動。妳若是抵抗的話，我會讓妳一瞬間人頭落地喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_072"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什、什麼時候……！？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_073"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "（糟、糟了……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_074"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n 必須找機會逃走……）",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "美冬，那孩子似乎打算逃走。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_075"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "若在這裡打起來，之後會很難收拾，我來用魔法封住她的行動。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不、不能動喵……！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_076"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不該會這樣……！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "很吵呢……派對已經結束了喔？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_077"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬、優花梨，發生什麼事？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有小偷闖進來了喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_078"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是沒關係，我們已經抓住她了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳說小偷？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_079"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好厲害啊！ 我，第一次見到小偷呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我還是第一次遇到撞見小偷還這麼開心的人……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_080"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……哎呀？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_081"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳不是之前那間美味鯛魚燒店的人嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的耶，是在鯛魚燒店工作的孩子呢……",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_082"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼鯛魚燒店的人會當小偷？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_083"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果是那家的鯛魚燒，營業額應該不成問題啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我的事情一點都不重要喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_084"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n如果妳們想收取高額利息的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我原本是打算懲罰妳們的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳在說什麼呢？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_085"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n若是那樣做的話，客人可是會減少的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我家的家訓，就是要與同行對手以外的人攜手合作。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……也就是沒有想要騙人嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_086"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒錯，那當然。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_087"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我賭上紫藤的名聲，不會做什麼黑心生意的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那樣做也賺不了什麼大錢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是妳們很可疑喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_088"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n突然說要買下整間鯛魚燒店……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺就很像是奸商的想法喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那只是因為……秋乃的金錢觀有問題而已啦……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_089"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才、才沒那種事呢！ 若是有那麼好吃的食物，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_090"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳不覺得應該收購店鋪，再大舉販售嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我到現在還是想在全大陸設立分店喔？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……妳該不會是因為這樣，才想把店鋪買下來吧喵？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_091"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃就是這樣的人喔，不是什麼壞人。",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_092"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "似乎是這樣喵……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_093"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "敗給她了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我非法入侵這裡是事實，妳們要把我交給誰都可以喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳已經不會抵抗了吧。",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_094"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣的話，先連絡騎士團――",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬，稍等一下。我是秋乃・紫藤。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_095"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "方便請教妳的大名嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……珠希喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_096"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等一下喵……紫藤，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n莫非是大陸第一商人的那個紫藤嗎喵……！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來妳知道啊，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_097"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真開心。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難怪喵……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_098"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我明白為什麼每份契約書的金額都大得出奇了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希，妳要不要也加入我的公會呢？",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_099"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我剛好正在找一位能為我到處奔走的人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啥！？",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_100"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n為什麼會變成這樣！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳的正義感感動了我！",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_101"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且最重要的是……我不希望再也吃不到",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳做的美味鯛魚燒。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "竟然是因為鯛魚燒……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_102"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看樣子她非常中意",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那孩子和鯛魚燒呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……要我加入是沒問題喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_103"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，必須互惠互利喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n若沒有相對的報酬，是無法說服我的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "報酬我當然會確實支付。除此之外，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_104"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n若我發現生意對象是壞人的話，也會告知妳。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果妳不介意的話，我也會幫妳懲罰對方喔？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也無法放過那些",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_105"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n靠欺壓弱者牟利之輩。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我還以為妳又要脫口說出什麼了……",
        "unit_id": 104811,
        "voice": "vo_adv_3008001_106"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不過，就算阻止妳也是沒用的吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "放心吧，有可能會戰鬥時，我一定也會陪同前往的。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不愧是美冬！ 若有曾打敗龍的人當伙伴的話，",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_107"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就沒有什麼好怕的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我以前是聖騎士，",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_108"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以即使被捲入某種程度的戰鬥也沒關係喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然我並非積極地想要戰鬥就是了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃一旦說要做的話就停不下來了，",
        "unit_id": 103411,
        "voice": "vo_adv_3008001_109"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也得下定決心才行……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉，我還以為難得能在皇城",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n悠閒地生活呢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒想到兩位竟然都不是普通的隨從……",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_110"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬、優花梨似乎也能接受呢。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_111"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希，妳意下如何？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……談判成立喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_112"
    },
    {
        "type": "still",
        "still": "300800101"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後――"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃！ 有兩個好消息喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_113"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n第一個是，似乎有能成為新事業的消息喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，那真是有意思呢。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_114"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……另一個報告呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……我發現正在做黑心生意的傢伙了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008001_115"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵，那似乎有懲罰的必要呢。",
        "unit_id": 103211,
        "voice": "vo_adv_3008001_116"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位，要在裡面開始作戰會議了喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，表面與背面──\n兩邊的公會活動就這樣開始了。"
    }
]