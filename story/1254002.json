    {
        "type": "dialogue",
        "name": "栞",
        "words": "帶回牠們故鄉的森林吧。",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "501851"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不曉得",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣是否",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能作為對牠們的弔唁……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕……",
