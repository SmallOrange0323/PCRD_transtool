        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我要從小事來培養自己的能力，",
