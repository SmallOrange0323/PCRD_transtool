[
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人停留在魔物保護區裡的村子幾天之後的早上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與栞在村子周圍進行長跑訓練，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n訓練結束後，兩人回到了村子的入口。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "早上訓練很舒服呢，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n感覺身體也變輕盈了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵……",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在這種地方睡覺，可是會感冒喔。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我來拉你起來。",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿咻。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……！",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n感覺得出來嗎……！？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "其實",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我開始有肌肉了♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然只有一點點，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我的手臂也能擠出肌肉囉……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n現在我說不定也背得動你呢♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你、",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你這樣一直盯著人看，感覺有點難為情……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然看得出來對吧。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我努力練腹肌也是值得了♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我之前都完全胖不起來，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但自從開始每天訓練後，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我的食量也增加了很多……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然偶爾還是會生病，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我感覺身體狀況有漸漸在改善。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說不定",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總有一天……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "即使是這樣的我，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也能夠守護大家",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有你呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為了達成這個願望，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首要目標是",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "全身練滿肌肉呢♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 311,
        "voice": "vo_adv_1254002_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "找到了找到了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "遊俠小姐～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n有獵人公會",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "寄來的信件喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "信件？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是教官寄來的……",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n看來是",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "關於前陣子我們逮捕的男人的報告。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我來看信上",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "寫什麼──",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "501690"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "「關於你們逮捕的那個男人……",
        "unit_id": 414,
        "voice": "vo_adv_1254002_014"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n經過我們偵訊的結果，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "得知他是盜獵集團的成員。」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "「而且還不是普通的小混混。",
        "unit_id": 414,
        "voice": "vo_adv_1254002_015"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "他是會操縱魔物，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "從魔物和人身上搶走他們想要的東西……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n在遊俠間很有名的黑暗公會的成員。」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "「角、牙齒、毛皮……",
        "unit_id": 414,
        "voice": "vo_adv_1254002_016"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "就算被遊俠盯上，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n他們照樣會將眼前想要的東西狩獵殆盡。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "因為那些傢伙的關係，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "甚至導致有的魔物瀕臨絕種。」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "「即使夥伴遭到逮捕，",
        "unit_id": 414,
        "voice": "vo_adv_1254002_017"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "那群人也不會就此罷手。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n我想他們肯定還留在那個地區，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "希望你們繼續保持警戒。」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "「如果有得知什麼線索，",
        "unit_id": 414,
        "voice": "vo_adv_1254002_018"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我會再聯絡你們。」",
        "unit_id": 414
    },
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──以上就是信上的內容。",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個犯人",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然還有其他同夥呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "村長有說過。",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這附近的魔物們都很溫馴，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以容易被盜獵者盯上。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物的數量因此減少，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n導致毒沼產生、",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "暗夜精靈也增加，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "結果差點讓這裡變成無人可生活的荒蕪之地……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "多虧遊俠們開始守護魔物，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n才讓這裡又恢復成美麗的森林。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只是",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這似乎花費了長達幾十年的時間。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……我們的責任",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很重大呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "得繃緊神經，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "確實取締盜獵者才行。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也去叫上在村子外頭待命的喵特，",
        "unit_id": 125414,
        "voice": "vo_adv_1254002_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天就增加巡邏次數，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後擴大巡邏的範圍吧。",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "501850"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "第五個",
        "unit_id": 125411,
        "voice": "vo_adv_1254002_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "檢查點，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒有異常。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "待在這裡的魔物們，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的都很溫馴呢……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「魔物",
        "unit_id": 125411,
        "voice": "vo_adv_1254002_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是個蹂躪踐踏一切生命的",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "邪惡存在，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因此沒有辦法與我們共存。」",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不認為在書上讀到的內容是錯的，",
        "unit_id": 125411,
        "voice": "vo_adv_1254002_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只是看到這裡的魔物後，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我認為書中的內容",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "並不代表一切。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "……？",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我和喵特的相處方式……",
        "unit_id": 125411,
        "voice": "vo_adv_1254002_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也算是一個",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "證明對吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說不定",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "人和魔物──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞、喵特",
        "words": "！！",
        "unit_id": 1,
        "voice": "vo_adv_1254002_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛才的慘叫聲……",
        "unit_id": 125411,
        "voice": "vo_adv_1254002_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們去看看情況吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看。",
        "unit_id": 125411,
