    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "街道熱鬧不已的情人節當天。\n靜流為了{player}做了大量的巧克力，\n她帶著那些巧克力回到了可麗餅店。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼……",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "帶了這麼多好重呢～",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖說是為{player}弟弟做的，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會不會做太多了？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不不，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才不會呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為要表現對{player}弟弟的愛的話，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這些還遠遠不夠呢，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這也沒辦法啦♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天是和{player}弟弟二個人的",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n巧克力派對喔！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說不定可以餵{player}弟弟吃巧克力，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他也會餵姐姐我吃巧克力呢！？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "開玩笑啦……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "離跟{player}弟弟約好要\n碰面的時間還剩一下子。",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要在店裡工作，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "時間都過得好快呢！",
        "unit_id": 109111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然是這樣想，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但今天都沒有客人來呢……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道是因為情人節，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n才沒人來買可麗餅嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚……",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真閒啊。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這麼閒的話，感覺時間變得好緩慢……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且重要的是",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺無法達成這個月的營收額了。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺根本達不到目標額……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "該怎麼辦。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家好像都沉浸在情人節裡，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n沒有人要多看可麗餅一眼啊。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "請……",
        "unit_id": 211,
        "voice": "vo_adv_1091003_009"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "請問！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？　",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "您是客人嗎！？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "歡迎光臨～！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n您要買哪種可麗餅呢？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不、",
        "unit_id": 211,
        "voice": "vo_adv_1091003_011"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不是的。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n不是要買可麗餅……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你可以把這個賣給我嗎！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦！？　",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你是說這個巧克力嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "實在非常抱歉，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個是非賣品。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "怎麼這樣……",
        "unit_id": 211,
        "voice": "vo_adv_1091003_013"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "拜託",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "請賣給我！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚～",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算你這麼說也……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為這些全部都是",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了{player}弟弟\n而製作的巧克力嘛。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "給{player}弟弟以外的人吃\n是不可以的！",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是這位客人",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像因為沒有巧克力十分困擾的樣子……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是有了我的巧克力，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能讓他露出笑容嗎？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且今天感覺可麗餅也賣不出去了，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要是沒有錢，之後【拉比林斯】的活動也會很辛苦……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那不然",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只賣這個人……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "破例",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只賣一個……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……我明白了。",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那麼，這個就",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "破例只賣給顧客您喔。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝……",
        "unit_id": 211,
        "voice": "vo_adv_1091003_022"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝您！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因、",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為我",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "點心做得很差，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "實在很想要這麼可愛的巧克力！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵。",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "希望顧客您的心意",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能夠順利傳達出去喔。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我為您加油喔。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只有一個，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只有一個。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "剩下的全部都是{player}弟弟的喔♪",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "我聽說這裡的巧克力相當好吃耶。",
        "unit_id": 1511,
        "voice": "vo_adv_1091003_025"
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "我想要送給我兒子。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "給我3個！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這、",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這究竟是……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼回事？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼會有這麼多客人湧上來？",
