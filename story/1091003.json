    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道說是因為……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n剛才賣出的巧克力引發了話題？",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯，",
        "unit_id": 311,
        "voice": "vo_adv_1091003_030"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這裡是賣巧克力的店吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_031"
    },
    {
        "type": "dialogue",
