        "name": "靜流",
        "words": "那個……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這是非賣品……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "我想要買給兒子",
        "unit_id": 1511,
        "voice": "vo_adv_1091003_035"
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "還有我自己要吃的份！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我說了，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡是可麗餅店，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n巧克力是非賣品……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎、",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼辦……",
