        "voice": "vo_adv_1091003_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然營收逐漸提升，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可是要送給{player}弟弟的巧克力",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n慢慢的要見底了……",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉，",
        "unit_id": 109111,
        "voice": "vo_adv_1091003_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "客人總算變少也安靜下來了。",
