[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧來吧大家，",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃早餐囉～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請慢慢享用唷～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當做要報這份恩情，就稍微努力露了幾手唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個【拉比林斯】的據點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不知道為什麼就是廚房特別高級，嚇我一大跳唷～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能蓋成這樣的，",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是在蘭德索爾中也相當罕見耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "害得我越做就越起勁，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一不小心就煮太多道菜出來了呀！ ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈。",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n家具和設備，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是會長用『物件變更』造出來的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以可以說是非常齊全和完善的喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但因為時間不夠多，所以內裝沒弄得很仔細。",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "空有其表的東西，也有不少就是了呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長她意外的喜歡做一些小點心，",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以在廚房下了不少工夫。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個人明明就喜歡做做可麗餅或點心之類的東西，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但卻不知道麼搞的，就是沒什麼進步……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "到底是為什麼呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是不是那人本身就不適合做料理啊？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是不可思議呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是嘛，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是有句話說熟了就能什麼伸腳嘛！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『熟能生巧』唷，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～",
        "unit_id": 106112,
        "voice": "vo_adv_2008006_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別顧著說話",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們倆也快點坐下來囉！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要『開動囉』～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家準備好一起♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好喔。",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但這麼多人坐在一起位置會變得很小嘛，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以我們就先負責端菜吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果吃飯的空間太擠，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n大家吃起來也會綁手綁腳不方便呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，貪吃佩可小姐也請坐下來好好吃頓早餐吧！",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n端端菜倒倒茶這點小事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就包在我們的身上吧☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟是客人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還希望妳過得更輕鬆自在一點。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好哦～",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能這麼講真是幫了大忙呀～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老實說肚子都快餓扁了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下旁邊的這個位置讓給您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了挪出些位置讓佩可小姐能夠就座，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可以稍微擠過去一些嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再稍微，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貼近一點點也沒關係唷……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……？",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不、那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下並非是幼童。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此若在主人您的膝上用餐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍顯得會有點害臊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感～覺和平時一樣相親相愛呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真好耶，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像一家人一樣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呣，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那番話可不能就當耳邊風呢～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}的家人空缺，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n已經由我和璃乃填滿了唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊但是，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "若要再增加一些家人也很是歡迎就對了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "該怎麼辦啊璃乃！",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在我們潛藏在洞裡面的這段時間，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n難不成疏遠了和{player}的感情嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在該是時候來極力主張，",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "屬於我們倆姐妹的地位了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說的沒錯呀姐姐！",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實根本沒有血緣關係卻不知道為什麼很堅持家人身分呀～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之類的疑問雖然我一直搞不懂但我也支持這件事！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯！",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不愧是我的璃乃，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這麼懂我！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因此！",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就讓妳們見識見識真正的姐姐之力吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來嘛來嘛……",
        "unit_id": 104911,
        "voice": "vo_adv_2008006_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓姐姐來餵妳吃東西吧？ ",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊～",
        "unit_id": 101112,
        "voice": "vo_adv_2008006_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼強硬可不行的啦姐姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n妳看看這樣不是把哥哥嘴邊給弄髒了嘛。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這裡",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就讓我這個妹妹來替你弄個乾淨唷！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": " 我擦我擦♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呣……",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n『啊～』來餵主人吃東西的這件事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明就是在下的責任。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是。",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是主人的隨從而已……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不論主人再怎麼接納在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也始終不能夠成為『家人』。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是否該更有一點自知之明呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可可～蘿……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n偶爾呀稍微遵循自己的心之所向，不必去顧忌那麼多也沒關係唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看妳看。",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再這樣禮讓下去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}可會被人家搶走了唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在、",
        "unit_id": 105913,
        "voice": "vo_adv_2008006_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下雖然是主人的所有物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但主人他並非是屬於在下的什麼東西……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此並沒有搶不搶走，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的關係。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀哈哈～",
        "unit_id": 105812,
        "voice": "vo_adv_2008006_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有時候太乖巧聽話也並非都是好事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當失去了珍貴的事物時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才來後悔就來不及了唷。",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然不知道在幹嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008006_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但鬧得挺開心的嘛～妳們幾個……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我這有些重要的事情要說，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以希望你們可以靜一靜。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008006_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這話留到吃完飯後也沒差嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_2008006_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原則上，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在用餐時說話是違反禮儀之事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是嘛……照這看來{player}，",
        "unit_id": 107111,
        "voice": "vo_adv_2008006_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真是被女孩子圍得團團轉的後宮狀態呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "男孩子都會對那～樣的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "狀況心生羨慕嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……為什麼要問我啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2008006_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不是，",
        "unit_id": 107111,
        "voice": "vo_adv_2008006_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為在這之中看起來最不受歡迎的人就你呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來來來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "羨慕的話讓我也來",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『啊～』",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "餵餵你囉♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "宰了妳唷……！",
        "unit_id": 190711,
        "voice": "vo_adv_2008006_040"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n才、",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "才沒有羨慕那種事情啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n誰會想要像那樣子啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "呵呵。",
        "unit_id": 107311,
        "voice": "vo_adv_2008006_041"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n那麼堅決的否定，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "反而看起來更像是說假話唷。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不用那麼害羞呀，",
        "unit_id": 191011,
        "voice": "vo_adv_2008006_042"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "年輕人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n對一個健康的男孩子來說，這是正常的心理啦！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "乖喔乖喔，",
        "unit_id": 106112,
        "voice": "vo_adv_2008006_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好可憐的大吾呀……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那我也來",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「啊～」餵你吃吧，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別生氣了嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好不好？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n快點快點♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "吵死啦啦啦啦！",
        "unit_id": 190711,
        "voice": "vo_adv_2008006_044"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n可不可以別這麼煩啊，你們這些傢伙！？",
        "unit_id": 190711
    }
]