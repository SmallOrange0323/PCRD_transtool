[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在城鎮裡時，\n突然聽到從餐館中傳來爽朗的聲音。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊――哈哈哈！ 優花梨還能繼續――喝！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n再來一杯―――！",
        "unit_id": 103411
    },
    {
        "type": "still",
        "still": "103400201"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔呵呵　。啊哈哈哈哈哈。",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n啊――，工作完後喝一杯，真好喝啊～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦～？\n這不是前陣子那個可愛的男孩子嗎！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你看，這裡有空位喔！ 坐吧坐吧～！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯――？ 你問我是不是在喝酒？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯呵呵，既然在這種地方，喝酒不是理所當然的――嗎！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n麥酒最棒了――！ 啦啦啦啦啦――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，你說我的衣服敞開了……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔呵呵，別這麼死板嘛～，又不會少一塊肉。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好了好了，你也喝嘛～！ 是說，你還沒成年啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣的話，喝果汁也行！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們兩個一起忘記不愉快的事情吧～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚……那是……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_007"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚，我不喝酒的話就過不下去啊……！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為這個城鎮裡最近到處都是情侶嘛！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "即使走在城鎮裡，\n也只有以搭訕為目的的輕浮男人向我搭話……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就算是我，也有一個人感到寂寞的夜晚啊。",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也會想著若是有個出色的男朋友該有多好啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我現在仍幻想著能遇見出色的王子喔！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，到處都沒有出現那樣的人！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然如此，也就只能喝酒了不是嗎……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼哇，好溫暖……你在安慰我嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚――，會溫柔對我的，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也就只有你而已了啊～。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什――麼女性魅力嘛――！ 讓我隨意喝吧――！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n即使我喝到醉倒，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也從來沒被人帶回家過――啊！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "基本上！ 每次！ 都被放生在路邊！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也想被人帶回～家！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "成年女性",
        "words": "啊，我要帶回家，謝謝。",
        "unit_id": 411,
        "voice": "vo_adv_1034002_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啥、啥、啥米――！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "被、被、被、被帶回家的傢伙是……誰――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不……是本店賣的三明治……",
        "unit_id": 1411,
        "voice": "vo_adv_1034002_017"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我想帶回家吃……\n",
        "unit_id": 411,
        "voice": "vo_adv_1034002_018"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "那個，請問妳是……？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎、哎呀？　偶素…………啊，那個……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯――偶要……睡、睡了……！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……呼嚕――，呼嚕――。",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_021"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "唉，又喝到醉倒了……",
        "unit_id": 1411,
        "voice": "vo_adv_1034002_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你是這位客人認識的人嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n很抱歉，能請你帶她回去嗎？",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}將優花梨帶回公會小屋。\n將優花梨放到床上時，她醒了。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯――，這裡是……我的房間……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n咦，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是你？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "莫非是……我又喝過頭了？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊、啊啊……是這樣啊……又搞砸了啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓你看見我丟臉的樣子了……\n虧我",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還想在人前盡可能保持",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n工作能力強的出色大姐姐形象……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你一定也感到失望了吧……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你討厭我了嗎……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……？\n你說看見我意外的一面，覺得很開心……真、真的嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……呵呵。\n你真的很溫柔呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n謝謝。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼，今天失敗了呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n沒想到醉倒後，竟然被那孩子帶回房間。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦，等等。帶回家？",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這不是我生平第一次被帶回家嗎……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "第一次被……帶回家！",
        "unit_id": 103411,
        "voice": "vo_adv_1034002_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哇、哇哇哇！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨害羞不已，一個人在床上翻來覆去。"
    }
]