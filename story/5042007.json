        "name": "日和",
        "words": "\n景色慢慢恢復原狀了！！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對、",
        "unit_id": 113011,
        "voice": "vo_adv_5042007_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對對對、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對呀！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我們",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "成功了……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是真的！",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "拯救了這個世界！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳說得沒錯。",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_003"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n你們幾個，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "幹得漂亮。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼，",
        "unit_id": 106612,
        "voice": "vo_adv_5042007_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "本小姐出馬，這也是理所當然的！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_5042007_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大家都辛苦了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n拉格也辛苦了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉格",
        "words": "嘎喔♪",
        "unit_id": 1,
        "voice": "vo_adv_5042007_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "接～",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下來，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們只要找到回去原來的世界的方法就好了！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對、",
        "unit_id": 113011,
        "voice": "vo_adv_5042007_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對耶！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "找起來",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會很辛苦嗎……？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家一起找",
        "unit_id": 100113,
        "voice": "vo_adv_5042007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就沒問題的啦～♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……沒有那個必要。",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲……？",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哇！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這、",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是怎麼回事！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n四、",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "四周突然開始發光了！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這個世界……",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_013"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不對，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這本「書」，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n正在恢復成原來的模樣。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃等人",
        "words": "什麼……？",
        "unit_id": 1,
        "voice": "vo_adv_5042007_014"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "在黑之王消失之後……",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_015"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n我總算明白這一切了。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這個世界……",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_016"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這本書裡",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n寄宿著讀者形形色色的情感。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "許許多多的情感積累下來，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_017"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "形成了酷似魔力的力量。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n而這股力量",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "在偶然間將你們拉進了這裡。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……不對，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_018"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這不是偶然。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我一定是……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我想向妳傳達一件事。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "一點點的勇氣",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_019"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "就能夠改變世界。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "然後，妳的冒險",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "會永遠持續下去。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……不過，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_020"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這個世界裡的冒險",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "就到此結束了。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "你們不是故事裡的登場人物，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_021"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n所以會被彈出這個世界……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我們要在這裡",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "暫時分別了。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不過，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_022"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不需要因此難過。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "因為這是一個",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "圓滿的結局呀。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_023"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "怎麼了？",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_024"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n妳又露出我們剛相遇時的",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那副鬱悶表情了喔？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………我不要。",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_025"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "至少讓我……",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_026"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "好好道個別吧。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我說不要，就是不要！",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我絕對不會和愛麗絲妳道別的！",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是好朋友嗎！！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論發生什麼事，",
        "unit_id": 112912,
        "voice": "vo_adv_5042007_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我都不會離開愛麗絲的！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只要妳不從我身上離開，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳就不會消失了，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧！",
        "unit_id": 112912
    },
    {
        "type": "still",
        "still": "504200701"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦…………",
        "unit_id": 101112,
        "voice": "vo_adv_5042007_030"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "真是的……",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_031"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳怎麼講不聽呀。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n我都說了只是「暫時分別」呀！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲，妳等一下！",
        "unit_id": 101112,
        "voice": "vo_adv_5042007_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我還有好多話想跟妳說！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n還有好多事想跟妳一起做……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有好多……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好多……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳就一直待在我身邊嘛……",
        "unit_id": 101112,
        "voice": "vo_adv_5042007_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是一心同體的嗎……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……別擔心。",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_034"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我們很快就會再見面的。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "因為",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_035"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我一直都在",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "書中的世界裡嘛。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳隨時都可以來見我喔？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳和我的故事，",
        "unit_id": 4611,
        "voice": "vo_adv_5042007_036"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "雖然在這裡劃下句點了……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "但我會在這個世界裡",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "繼續我的冒險。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "所以妳也要",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "在妳的世界",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不放棄地繼續挑戰。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "我們說好了喔？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
