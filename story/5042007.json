    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人終於打倒了黑之王。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n將黑暗從這個世界驅逐出去。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你們看！",
        "unit_id": 100113,
        "voice": "vo_adv_5042007_000"
    },
    {
