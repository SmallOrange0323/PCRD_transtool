[
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼～",
        "unit_id": 112811,
        "voice": "vo_adv_5040322_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n總算把那幾個長得和我們很像的傢伙打倒了啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "喔……？",
        "unit_id": 13311,
        "voice": "vo_adv_5040322_001"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "還挺有兩下子的嘛。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n遇到這樣的對手，",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "我也差不多該拿出真本事了。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "什麼！？　",
        "unit_id": 2511,
        "voice": "vo_adv_5040322_002"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "你這傢伙！　",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "難道剛剛都還留了一手嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "別開玩笑了！　",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "你可別忘記我付了多高的薪水給你們！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n趕快讓那幾個傢伙",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "從世界上徹底消失！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "不用你說我也打算這麼做。",
        "unit_id": 13311,
        "voice": "vo_adv_5040322_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他們",
        "unit_id": 112711,
        "voice": "vo_adv_5040322_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼好像",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "起內鬨了？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然他們本來就不太像是夥伴，",
        "unit_id": 103811,
        "voice": "vo_adv_5040322_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但的確是那樣的吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓他們見識一下，",
        "unit_id": 105211,
        "voice": "vo_adv_5040322_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "同心協力地一起戰鬥會有多強大！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯啦！",
        "unit_id": 112811,
        "voice": "vo_adv_5040322_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只要我們團結在一起，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就所向無敵的啦！",
        "unit_id": 112811
    }
]