[
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了──！",
        "unit_id": 122411,
        "voice": "vo_adv_5096203_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n魔物回去海裡了喔──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……！",
        "unit_id": 122611,
        "voice": "vo_adv_5096203_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳們兩個有沒有受傷呀？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 122511,
        "voice": "vo_adv_5096203_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣，沒事的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是多了些擦傷而已……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "糟糕了！",
        "unit_id": 122611,
        "voice": "vo_adv_5096203_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳別動喔。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我馬上幫妳治療！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃、",
        "unit_id": 122511,
        "voice": "vo_adv_5096203_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是那麼需要人擔心的傷……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論之後的對決項目如何，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這點傷勢都不會造成太大的影響的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的，",
        "unit_id": 122611,
        "voice": "vo_adv_5096203_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不是那個意思……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n夥伴受傷的話，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當然會擔心呀。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒錯沒錯！",
        "unit_id": 122411,
        "voice": "vo_adv_5096203_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且大家健健康康的，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n拿出真本事來互相競爭會比較有趣呢！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳們說得沒錯。",
        "unit_id": 122511,
        "voice": "vo_adv_5096203_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那這次",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就大家一起過去那邊吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為那裡好像還殘留著魔物的氣息呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_5096203_008"
    }
]