[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一個人走在街上，\n看見正在討論事情的鈴奈。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家情緒很低落耶？",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "明天是在海邊拍攝，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家興奮一點呀～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有關那件事……",
        "unit_id": 411,
        "voice": "vo_adv_1100001_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "因為平時配合的工作人員身體不適，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n現在負責攝影的人手不足。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎！？　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真糟糕呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不好意思。",
        "unit_id": 411,
        "voice": "vo_adv_1100001_003"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n是我們這邊出了狀況，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們一定會想辦法的……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "請不要這麼說～！",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家是好夥伴吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一起來想辦法吧！",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也問問認識的人看可不可以",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～～～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！？　",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n時間點也太巧了吧～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "話說，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在不是笑的時候――！！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才明天有空嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n明天要去海邊拍攝，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果你能來幫忙，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就太好了――",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之類的。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的！？　",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才超級體貼～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛好有空所以來幫忙？",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n能撥空來幫忙真的超級感謝！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然如此",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那今天也來陪我準備吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "走吧，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說去哪裡，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然是去買泳衣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "去海邊的話，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可愛的泳衣可是必備！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看你看～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n好多可愛的泳衣呢～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺辣妹風格的泳衣很適合人家，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但會不會太暴露呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "試穿那邊的可愛泳衣應該也很有趣♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈――",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糕！　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超級可愛的啦！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂喂喂，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也這麼覺得嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說事務所不是早有準備好泳衣嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然有準備泳衣呀～",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也想帶自己挑選的泳衣去呀？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想讓粉絲看到人家各種不同的一面，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大概是這種想法？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "需要秀才的意見參考！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "話說，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才喜歡什麼款式的泳衣？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n可愛風格？　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還是性感風格？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說不太清楚？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家穿給你看，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺對了就告訴我吧～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 101611,
        "voice": "vo_adv_1100001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我去換泳衣唷～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "將將！",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這件泳衣，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如何呢？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "整個人僵住。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "快說些話吧～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為太可愛所以看傻了？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "被這麼直白稱讚，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會害羞啦～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可愛嗎？",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糕！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我現在超嗨的！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然秀才的反應也很好，",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n一定要買下這件泳衣吧！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我瞧瞧，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "價錢是……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦……",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "8000盧幣！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我以為頂多5000盧幣的說……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超出預算啦……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "上面好像貼著貼紙。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "20%的折扣？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～欸～秀才！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "8000盧幣的20%折扣是多少呢？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "1600盧幣！？",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那豈不是超划算的？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼呀――",
        "unit_id": 110011,
        "voice": "vo_adv_1100001_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我剛剛白擔心了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是搞笑～♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果這樣，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就決定是這一件！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那麼，",
        "unit_id": 110011
    },
    {
