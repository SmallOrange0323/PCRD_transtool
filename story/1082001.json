[
    {
        "type": "background",
        "background": "505030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節即將到來，蘭德索爾也變得熱鬧了起來。\n在前往打工的{player}面前，\n尋找布丁的宮子出現了。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，這麼巧，在這裡遇見你！",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你知道什麼日子快要到了嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒錯，就是萬聖節來的！　",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為宮子是真正的幽靈，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n所以一定可以拿到很多的布丁～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以呢，",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家是「不給布丁就搗蛋」來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要給我布丁才行～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這沒關係的！　",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果是這樣的話，就為了宮子努力地工作賺錢吧！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那種事怎樣都好吧～",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n世界上沒有其他事情比宮子的布丁還重要來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯，",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你是要去靈異旅行扮鬼嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚇人好像很好玩來的！",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n也帶宮子一起去～！　",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算不帶我去，我也會跟去的～！",
        "unit_id": 100711
    },
    {
        "type": "background",
        "background": "500034"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "嗨，",
        "unit_id": 311,
        "voice": "vo_adv_1082001_007"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "要扮鬼的工讀生就是你們對吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n今天就請多指教囉。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "包在我身上～！　",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就讓宮子來讓大家知道，什麼是真正的恐怖！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "啊哈哈哈，",
        "unit_id": 311,
        "voice": "vo_adv_1082001_009"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "真是可靠啊～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n那些預約的客人們，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "也都很期待唷！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "我們有準備一些扮裝的衣服，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "去選喜歡的穿吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有好多唷～！",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}要選什麼？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你準備的還真齊全～",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那宮子……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔～嗯，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～唔……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，這件！　",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我要選這個！　",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "感覺好恐怖來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我去換衣服，在這邊等我一下喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "窸窸窣窣，",
        "unit_id": 100711,
        "voice": "vo_adv_1082001_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "窸窸窣窣",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "鏘～！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家是狼女來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吼～，",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不給人家布丁的話就搗蛋來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "才不是那樣呢！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要更吃驚才對喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子可是冷血無情的狼女來的！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊嗚來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呵呵呵～",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "給我布丁就原諒你！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子不是肉食系也不是草食系。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是布丁系來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "很好！　",
        "unit_id": 311,
        "voice": "vo_adv_1082001_018"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那麼就請你們兩個在墓地待機吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n我會把客人帶過去，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "到時可要好好地嚇他們唷！",
        "unit_id": 311
    },
    {
        "type": "background",
        "background": "500535"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "已經有好幾個扮鬼的人做好準備了。",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我們也在這邊準備吧～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呵呵……",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子現在這樣，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "終於像是在做幽靈會做的事情！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n好期待喲～！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，馬上就有人過來了！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "魔物({0})",
        "words": "――吼歐歐歐歐歐！",
        "unit_id": 1611,
        "voice": "vo_adv_1082001_021"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀――！　",
        "unit_id": 411,
        "voice": "vo_adv_1082001_022"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是魔物幽靈——！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，感覺不錯來的！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也要試試看～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吼歐～！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_024"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快把布丁交出來喲～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n不給我的話，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就把你變成布丁給吃掉來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀――！　",
        "unit_id": 411,
        "voice": "vo_adv_1082001_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "別把我變成布丁――！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘿嘿嘿，",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_026"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大家好像都很開心來的。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "開始有萬聖節的感覺喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吼歐吼歐～！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_027"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家要繼續多嚇嚇大家喲～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……奇怪？　",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_028"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "入口那邊好像發生了什麼事。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n我去看看～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "啊？　",
        "unit_id": 811,
        "voice": "vo_adv_1082001_029"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這是什麼……靈異旅行？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哼，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "因為萬聖節要到了，所以你們才搞了這種無聊的玩意啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這位客人，",
        "unit_id": 311,
        "voice": "vo_adv_1082001_030"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "現在馬上就可以入場……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n招待你來場",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "恐怖的靈異旅行。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哈！　",
        "unit_id": 811,
        "voice": "vo_adv_1082001_031"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我才不相信有什麼幽靈勒！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n來啊，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "有辦法的話就來嚇我看看啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "不過啊，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "要是我一點都不害怕的話，可要罰錢喔～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "罰、罰錢！？　",
        "unit_id": 311,
        "voice": "vo_adv_1082001_032"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "這個嘛……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "怎樣，不敢是吧！？",
        "unit_id": 811,
        "voice": "vo_adv_1082001_033"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n連嚇人的自信都沒有，就別來做這種事情啦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "唔……",
        "unit_id": 311,
        "voice": "vo_adv_1082001_034"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "那麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "就讓你見識一下吧！ ",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "世界上最恐怖的魔物怨靈！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "魔物({0})",
        "words": "――吼歐歐歐歐歐！",
        "unit_id": 1611,
        "voice": "vo_adv_1082001_035"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "吵死了！",
        "unit_id": 811,
        "voice": "vo_adv_1082001_036"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊啊！　{player}！\n",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_037"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎、怎麼打人啦，這樣太超過了！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "一點都不恐怖唷～！　",
        "unit_id": 811,
        "voice": "vo_adv_1082001_038"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "來啊來啊，怎麼了！？　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "趕快過來嚇我啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我可是驅鬼獵人啊，嘎哈哈哈哈！",
