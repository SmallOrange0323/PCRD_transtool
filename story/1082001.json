    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "哼，",
        "unit_id": 811,
        "voice": "vo_adv_1082001_040"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這點程度連試膽都算不上啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n來吧，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "按照我們說好的，把罰金給我拿出來！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……我要對你下詛咒……",
        "unit_id": 108211,
        "voice": "vo_adv_1082001_041"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在你身邊作祟來的……",
