    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這、",
        "unit_id": 811,
        "voice": "vo_adv_1082001_045"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這傢伙是怎樣……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "飄在空中！？",
