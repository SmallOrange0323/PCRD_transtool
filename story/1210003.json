        "voice": "vo_adv_1210003_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可吧。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳果然",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在另一個世界啊。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那我就放心了……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幸好那傢伙",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是孤單一人。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想得沒錯！",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在蘭德索爾的小凱留",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然也在為我們努力！　",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話又說回來，",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來幫助我們的人多到很驚人呢……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都很關心{player}……！　",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留居然率領了這麼大一群人，",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好感動！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆　",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果{player}的力量太過強大到會滿溢出來，",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會承接住所有一切。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是肚子餓得咕嚕咕嚕叫的貪吃佩可！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是{player}的力量",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也會津津有味地品嚐喔！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為留下剩飯不符合我的原則！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果火力全開對這股強大的力量不管用，",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_079"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我只要超越火力全開的極限就行了。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要超越火力全開囉，",
        "unit_id": 121011,
        "voice": "vo_adv_1210003_080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把{player}和我的羈絆，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再一次，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "連結起來吧！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可為了承接從他身上滿溢而出的力量，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著超越火力全開的決心，與異狀的根源劍戟相交。"
    }
