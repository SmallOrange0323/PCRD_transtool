        "voice": "vo_adv_1210003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳們三個在玩到一半時",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
