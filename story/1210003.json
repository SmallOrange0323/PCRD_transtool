    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為{player}接連遇到了很辛苦的事情，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣好像能讓他的心情好轉。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不，",
        "unit_id": 103631,
        "voice": "vo_adv_1210003_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果沒有顧著他，我會很不放心。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為{player}是……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇哇！？",
        "unit_id": 103631,
        "voice": "vo_adv_1210003_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你別過來這邊！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你果然是",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態可疑分子！！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈☆",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小孩子是風的孩子，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "充滿了活力呢！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家好好玩吧～！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呼～",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這三個人果然，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也和我認識的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【小小甜心】一模一樣啊。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿和小雪菲也是，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然名字有點不一樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但那兩個人果然和我認識的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的她們沒有不同……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就只有小凱留和我們剛相遇時一樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "渾身都是刺啊～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算小凱留全身上下的刺多到不行，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她那樣也很可愛……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我卻",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "覺得有點不放心。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在回到蘭德索爾之前，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能不能再和她聊一次呢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳來得正好！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳、",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳突然講這什麼話啊！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要大聲地找我搭話啦……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……找我有事嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然能在這種地方再次見到妳，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好巧喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我現在剛好在想小凱留的事情喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳不覺得",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這果然是命中注定的嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻咻♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我才不覺得",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是那樣咧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "凱留是誰啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我叫希留耶啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "再者，",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳說「再次」是什麼意思？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我根本完全不認識",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳這個人啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚～",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為這個世界正在重複同一天，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我跟妳是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「初次見面」啊。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我很高興能見到妳，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就不自覺地……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我沒辦法陪妳聊這些莫名其妙的事情。",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不要妨礙我散步……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "再見。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請、",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請等一下！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……怎樣啦？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳還有什麼事？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想請妳帶我去一個地方！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我不熟悉這附近的環境，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒辦法自己過去……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳認識",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "剛才和妳在一起的那些人吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n找妳朋友帶路就好啦？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想請妳帶我過去。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果不是和妳",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起去那個地方……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以就拜託妳了，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小希留耶！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嘖……",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我知道了啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n等我帶妳過去後，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳就要從我面前消失喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～！",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳這種傲嬌的地方好可愛喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳說誰傲嬌啊！？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_031"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n啊～受不了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳再吵我就不帶妳去囉！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～☆",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別這麼說嘛，麻煩妳了！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好了好了，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們走吧！",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉……",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_033"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就是這裡沒錯吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n能從山丘上",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "眺望整個城鎮的地方。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這裡！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好令人懷念喔……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那時候",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會來到這裡，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是為了幫助小凱留吧。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我相信這個時候，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在蘭德索爾的小凱留，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也正在為了我們努力……！　",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那就這樣，",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_038"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我要走了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還有，",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算在鎮上看到我，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳也不要再裝熟跟我搭話了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n雖然",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們應該不會再見面了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請等一下！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "幹嘛？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_041"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳還有什麼事情？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我認識一個",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和妳非常像的人。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_043"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "反正那只是和我很像的別──",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對。",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳或許算是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和她神似的別人，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我並不這麼認為。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以……",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳可以聽我說說",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個人的事情嗎？一下子就好。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我和那個人的回憶之地。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和妳很像的那個人……",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫做小凱留。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳們的名字很像吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "長相也真的是同個模子刻出來的喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳和她有一個",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很大的不同。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳看起來……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像比她還要",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再痛苦一點。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "！？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我剛遇見",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留時，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她也渾身都是刺。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是個傲嬌全開的女孩。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她和【美食殿堂】的夥伴們，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一起取得了被譽為世界第一好吃水果的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "密林的果實，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃了用龍的尾巴做成的關東煮……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在一起經歷這些冒險的過程中，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們的羈絆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變得越來越深厚。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後她漸漸坦率了起來，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始會跟我們說出她難受的過去",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和真心話。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡……",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是小凱留把她一直藏在心裡的想法，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n坦承說出來的地方。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才想跟和小凱留很像的妳，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再來這裡一次。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "冒險？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_056"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "美食……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n妳在講什麼啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "再說，",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_057"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真虧妳有辦法一臉正經地……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n把羈絆這種",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "令人難為情的詞彙講出來啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽妳這麼一說，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許真的是這樣呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那只能用羈絆來描述喔。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後就是啊，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有個在【美食殿堂】中心的男孩子，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為這樣的我和小凱留",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "繫起了羈絆。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他那個人穩重",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又溫柔，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比一般人還要努力，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明明比較強，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他卻還是想要保護我……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……來到這個世界時，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是孤伶伶的一個人。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但知道",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他也在這裡後，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "減緩了我的不安。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那就和",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第一次見到他時的情況一樣。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我失去所有一切，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "獨自進行武者修行時，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他幫助了正在餓肚子的我。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喜歡他的人",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是只有我而已，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也非常喜歡他喔？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊？",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_065"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "誰喜歡那種人啊！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……呃，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳不是在說我啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但在聽妳",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_066"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "講過這些後……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我開始覺得",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那很像是我認識的人……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這、",
        "unit_id": 106031,
        "voice": "vo_adv_1210003_067"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這種感覺",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是怎麼一回事啊……！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "事情就是這樣，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我得想出辦法，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n盡快回到",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾才行……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我以後也想一直",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和小凱留一起繼續創造回憶！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且要是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比以前都還要棒的美好回憶！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105831,
        "voice": "vo_adv_1210003_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再等我一下喔……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "希留耶，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也為我們加油吧！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如此這般，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可在{player}不知道時與希留耶有所交流，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並加深了她想回到蘭德索爾的決心。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，為了取回{player}牽繫起來的羈絆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n脫離這個「人工世界」，貪吃佩可握起了劍。"
    },
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
