[
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "さあ、",
        "unit_id": 11111,
        "voice": "vo_adv_5012010_000"
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "貴様らも後悔と慟哭を",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "無様に垂れ流せ！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "\nそして絶望を貪る",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "我が眷属として、",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "\n永遠の闇へ",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "その身を堕とすがよいわぁああ！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "このっ……",
        "unit_id": 105511,
        "voice": "vo_adv_5012010_001"
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "わからずやー！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "なに！？",
        "unit_id": 11111,
        "voice": "vo_adv_5012010_002"
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "　この一撃を弾くだとっ！？",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "これは、",
        "unit_id": 105511,
        "voice": "vo_adv_5012010_003"
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "先輩がくれた大切な力！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "あなたを救うための力だよ！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "あなたが愛した人のことを、",
        "unit_id": 105511,
        "voice": "vo_adv_5012010_004"
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "私たちは知らないけど……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "大好きな人には笑っていてほしいよ！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "今のあなたを見て、",
        "unit_id": 105511,
        "voice": "vo_adv_5012010_005"
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "その人が笑っているとは思えない！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "知ったふうな口を",
        "unit_id": 11111,
        "voice": "vo_adv_5012010_006"
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "きくなと言っている！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "\n私の心は、",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "嘆きの女神",
        "words": "私しか知らぬ！！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "アユミさん。",
        "unit_id": 101411,
        "voice": "vo_adv_5012010_007"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "残念だけど、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "彼女は在りし日の王女ではない。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "絶望の中で魔物へと",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "その身を堕とした、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "怨念そのものだ。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "言葉で分かり合えないなら、",
        "unit_id": 104311,
        "voice": "vo_adv_5012010_008"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "身体でぶつかり合うしかねぇだろ。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "{player}！　とびっきりの強化を頼むぜ！",
        "unit_id": 104311,
        "voice": "vo_adv_5012010_009"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n頭でっかちの王女様に、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "お説教してやらねぇとな！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "うぉお、",
        "unit_id": 104311,
        "voice": "vo_adv_5012010_010"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "力がみなぎって",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ゾクゾクするぜ！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "おぉりゃぁああ！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "絶対に、",
        "unit_id": 105511,
        "voice": "vo_adv_5012010_011"
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "あなたを助けてみせる……！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "アユミ",
        "words": "てやぁあああー！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "嘆きの女神……",
        "unit_id": 101411,
        "voice": "vo_adv_5012010_012"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "あなたは十分苦しんだはずだ。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "私たちがあなたを、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "その呪縛から解放してみせる！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "神妙にお縄につくがいい！！",
        "unit_id": 101411,
        "voice": "vo_adv_5012010_013"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nこれで、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "捜査終了だぁあああ！！",
        "unit_id": 101411
    }
]