[
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211,
        "voice": "vo_adv_5072301_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們上吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "無論什麼時候，都別忘了要像個偶像般地",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "展露出笑容♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連在戰鬥的時候也要保持笑容",
        "unit_id": 117311,
        "voice": "vo_adv_5072301_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望果真",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "打從骨子裡就是偶像。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實我們啊，",
        "unit_id": 117411,
        "voice": "vo_adv_5072301_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也早已是完完全全的偶像囉，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒錯……",
        "unit_id": 117311,
        "voice": "vo_adv_5072301_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是這樣。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就讓我們好好炒熱舞台的氣氛吧！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在戰鬥中，",
        "unit_id": 117411,
        "voice": "vo_adv_5072301_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們也一定能呈現最棒的演出！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們兩位都好棒，",
        "unit_id": 117211,
        "voice": "vo_adv_5072301_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "十分耀眼呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好了，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "又唱又跳又有戰鬥的演唱會！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要開演囉！",
        "unit_id": 117211
    }
]