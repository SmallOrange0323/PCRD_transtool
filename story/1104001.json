[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在散步時偶然遇到真琴。\n為了幫忙她的工作，{player}來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔～喔～",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真不愧是酷暑，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n海水浴場裡的人還真多啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之前休假時跟公主她們去的海灘，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真是個不為人知的好地方啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　{player}，怎麼了？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n東張西望的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說今天不是要工作嗎？",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以現在……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、原來如此，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你以為是跟往常一樣的巡邏吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉抱歉，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有詳細跟你說明工作內容呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過啊，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我覺得你什麼也不問就跟過來也不太好呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不要被什麼奇怪的傢伙騙了喔？",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣會難過的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我？",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　我當然也……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，不要忽然問奇怪的問題啦！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個、",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我剛剛是要說甚麼啊，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是工作內容。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我今天的工作",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是巡邏海灘喔。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就像你看到的，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個時期來海邊玩的遊客很多對吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以很容易出現溺水意外啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這些事情",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然其實是王都騎士團的工作，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過他們在重要的時候總是會缺席呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "諸多原因，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就變成我們得出場啦。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了？",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　一直盯著這邊看……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我的打扮怎麼了嗎？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為、",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼要懷疑啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我穿什麼都沒關係吧！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔！",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　那就來去游……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才不是呢！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是危險，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "差點就忘記原本的目的了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為是來海邊，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不穿泳衣的話反而很奇怪吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可不是",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為想要玩才穿泳衣喔！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "居然做些奇怪的猜想。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總而言之，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "今天的工作是在海灘巡邏。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說的帥氣一點的話，就是救生員",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之類的吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為你失憶了所以聽不懂吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所謂的救生員呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是在像這樣的海邊，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n專門救人的專家喔。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過要以救生員自稱的話，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n其實要取得各種證照",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有通過許多檢定呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但我就不是了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了～",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n今天的我呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該說是……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "海邊的巡守員，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之類的吧♪",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在開始巡邏之前，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我先教教你在海邊救人時的基本救助方法吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不然要是真的遇到狀況卻什麼都不會",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那就沒意義了吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你挺有幹勁的嘛！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我會嚴格地指導你喔♪",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯，大概就是這樣了吧。",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n記住急救站的位置了嗎？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可別忘記囉？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你記東西算是很快了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "然後，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接下來",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是救助溺水的人時，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果失去意識的話，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "分秒必爭的急救方法，但是……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這部分到時候我來做就好了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不用教你也沒關係吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦咦……",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說要是記住了，",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總有一天說不定會派上用場？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種想法很不錯呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我知道了、",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "知道了啦！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要是跟幫助別人有關的事情",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的都很熱心呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就從心臟按摩的做法開始吧！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你先在那邊",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "躺下來。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別多問了。",
        "unit_id": 110411,
        "voice": "vo_adv_1104001_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不要多說什麼，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "平躺下來！",
