[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "經歷霸瞳皇帝之亂，蘭德索爾遭受到了重創。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由克蕾琪塔‧凱許擔任公會長的【里士滿工商會】，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在貴族議會的安排之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n目前正以復興城鎮為最優先事項進行著各種交涉。"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_000"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "歡迎回來，",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您外出前吩咐我做的街道整備花費估算資料，",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "已經整理好在這邊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n還請您在明早前",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "進行確認及簽章。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "辛苦妳了，秘書一號。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，您今天……",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是嗎，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n原來您是去評估",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "前幾天被【憤怒‧軍團】的玩偶怪物",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n所破壞的月光學院重新修建時需要多少花費啊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個公主殿下也真是的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然幫那些懶散不上進、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "以為年輕就是該享樂的笨蛋們說話。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n偏心自己人",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也要有個限度好嗎。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉，真受不了。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明人手就已經不夠用了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "結果那個混蛋議長還硬塞不可能的任務給我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種苦差事誰幹得下去呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種時候……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也只能到那個地方",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "轉換一下心情囉♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n呵呵呵……♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哦──呵呵呵呵♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n快看哪，秘書一號♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這便是！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我們【里士滿工商會】的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "寶物庫！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是啊，",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_011"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我常有幸拜見此處。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "倒不如說，您以為是誰在負責管理這邊的帳簿呀……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這些亮晶晶的金銀財寶！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "各種最高級的藝術品！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不是靠優渥家境，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也不是搶奪來的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這些全部，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都是我運用智慧、藉自身努力得來的成果哪──！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……完全沒在聽呢……",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然在建造以及撤除克蕾琪塔之塔那段時間，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n寶物的數量曾劇烈減少……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但總算是！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n像這樣把失去的份給補回來了♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不枉我熬夜實行投資理財計畫了♪♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……唔。",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_016"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n受到克蕾琪塔小姐放聲大笑的影響，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "堆積著的箱子失去了平衡……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不曉得到底是誰，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "竟然把箱子堆得這麼不穩……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哦呵呵呵♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也是多虧了復興工程哪♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然那些要我私底下給好處的貴族們",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有點煩人就是了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "然後！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要將自己成功的證明，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓這裡所有的居民都好好見識見識！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n昔日在小鎮角落挨餓受凍的我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如今站上整個鎮的頂點啦～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為了達到這目標──",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n今晚也要熬夜",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "賣力工作！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳也跟隨我的腳步吧，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "…………",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_020"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊。",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊？",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我要回去了。",
        "unit_id": 6111,
        "voice": "vo_adv_1180002_023"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n下班時間到了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要是妳現在放開手，箱子就會……！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……然後，幾個小時後──"
    },
    {
        "type": "background",
        "background": "501074"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蕾琪塔下班時間過後也仍留在勤務室內，繼續進行記帳作業。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………\n……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這麼說來……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我從中午開始就什麼也沒吃了呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我說！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n秘書……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "早就已經回去了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有人在嗎？",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可以幫我去附近的攤販",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "買點東西回來……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……（靜悄悄）……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沒有任何人",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在嗎……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……哼。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最近的年輕人也真是的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "說什麼注重工作生活平衡，用這種懦弱的藉口，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一～下班就立刻衝回家了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……別無他法了。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就當作休息一下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "隨便找家餐廳進去吃個飯吧。",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "──久等了，",
        "unit_id": 1411,
        "voice": "vo_adv_1180002_033"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "幫您上燒烤雞肉套餐和麥酒！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……謝謝。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "待會回去後，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我看就再拚一下……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然還要再拚兩、三下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可要避免吃太多啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n麥酒的量也得節制一點。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……話說回來……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位用筷子沒問題嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否有需要在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫忙準備圍兜呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "用、",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_038"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "用不著這樣啦。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n沒問題的，可可蘿小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就算記憶沒回來……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "身體也似乎",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還記得要怎麼用筷子啦。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……失禮了。",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位有所成長，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明是件非常值得欣喜的事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然而在下卻總忍不住想",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫忙照顧兩位……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒料到竟有這麼巧的事……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那一群傢伙",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟然正好就坐在附近位置。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要是我有在點餐前發現到，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "肯定就會立刻轉身離開，去找其他家店了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來～了～",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天有夠累的～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n工作辛苦了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哎呀？",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_043"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n貪吃佩可小姐沒和妳一起過來嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙還留在王宮啦。",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不如說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她今天恐怕不會過來了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似似花那傢伙好像也不在。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對嘛對嘛，就是該這樣！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這種位在偏僻巷弄的餐廳，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可不是公主殿下該來的地方哪～！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_046"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對了，凱留。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這個裡面包著肉的小包子，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很好吃唷。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳要不要",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也吃一個看看？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔～",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我吃吃看？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咬下……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好、",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好燙！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n肉汁有夠燙啦──！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊啊！",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_049"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n對不起！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我忘記凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是怕燙的貓舌頭了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉，真是的，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "受不了這群傢伙……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明明吃飯就是該安安靜靜地品嚐，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼他們就偏辦不到呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n到底為什麼公主殿下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要和這種水準的人走那麼近呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那邊的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記得確實是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "常出入王宮的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個商人公會的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真是巧遇哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然要說的話，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就我個人而言，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和你們在這邊巧遇，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也沒有什麼好感到開心的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這話什麼意思呀。",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是老樣子討人厭啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我看妳就是因為個性這樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才會一個人孤單寂寞地在這邊吃晚餐吧～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱、",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_058"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留，這樣說未免……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "用不著妳管！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我這可是在享受",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "獨自一人放鬆的時光。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是是是，",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那抱歉打擾啦～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……你這是在做什麼？",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然擅自就在我對面坐下了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你的桌子分明是在那邊吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……啊？",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你這是在",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "同情我嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這就真的是多管閒事了好嗎！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……老闆！",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_065"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我要買單！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n剩下的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "麻煩幫我打包！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好──",
        "unit_id": 1411,
        "voice": "vo_adv_1180002_066"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來好像惹她生氣了呢……",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然人家都說要回去，",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就別管她了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n更何況我們和她根本連朋友都稱不上。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可沒有任何理由",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要一起同桌吃飯哪。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_069"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……啊啊，討厭，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺真差。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一個人吃飯又怎麼樣了？　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "即使沒有",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像你們那樣可以一起同桌用餐的對象，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只要我回到我們【里士滿工商會】……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就會有",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們拚命工作一輩子也掙不到的金銀財寶可以安慰我！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更何況……",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_072"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是不可能",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和你們同桌吃飯的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要說為什麼……",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_073"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個肉餡小包子，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很好吃呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是貪吃佩可小姐有來，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定會吃得很開心的說……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳這麼說，",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_074"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不可能現在送去王宮給她吃啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n更何況大門肯定早關起來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 106012,
        "voice": "vo_adv_1180002_075"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蘿仔啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n先不論能不能完整重現，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以妳的手藝，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該有辦法做出類似的料理成品吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實是有可能的。",
        "unit_id": 105913,
        "voice": "vo_adv_1180002_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，回去後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下便試著挑戰重現此味道吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如此一來，下次貪吃佩可小姐前來時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便能招待她吃了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽起來不錯。",
        "unit_id": 106412,
        "voice": "vo_adv_1180002_077"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我也會幫忙的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "媽媽！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說錯了……",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_078"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……沒錯。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_079"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要說為何……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因為我可是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_080"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n打算把你們最珍惜的朋友……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "打算陷害",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "尤絲蒂亞娜陛下的人……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……不。",
        "unit_id": 118011,
        "voice": "vo_adv_1180002_081"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n別說陷害，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是正盤算要毒殺她哪。",
        "unit_id": 118011
    }
]