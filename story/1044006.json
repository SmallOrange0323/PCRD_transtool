[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在城鎮裡一個人走著的伊莉亞，被衛兵抓住了。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛才說過了，妾身不是迷路的小孩啦！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "嗯嗯，是啊。妳不是迷路的小孩呢。",
        "unit_id": 711,
        "voice": "vo_adv_1044006_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n……那麼，妳家在哪裡呢？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n能告訴我妳的名字嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就說不是了啊！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別把妾身當成小孩！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "是啊。",
        "unit_id": 711,
        "voice": "vo_adv_1044006_003"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n這位小小姐是個很出色的大人呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n那麼，妳爸爸跟媽媽在哪裡呢？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔～！你完全沒聽進去嘛！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別把妾身當作罪犯！是迷路的小孩啦！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……不對，妾身也不是迷路的小孩！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不准連你也把妾身當作迷路的小孩！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是這傢伙自己亂說的啦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "――還以為是誰呢，這不是妾身的眷屬嗎！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你也快幫妾身說句話！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說妾身實際上是個有著姣好身材的成熟女性！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "啊，你是她的哥哥嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1044006_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n可不能讓妹妹離開你的視線喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n那麼，我先告辭了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂，別想逃！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……可惡，一直到最後都搞錯狀況，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n還一副大功告成的樣子……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不可原諒！絕對不可原諒！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n什麼啊，那傢伙！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n居然把妾身當成小孩！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "誰、誰是你妹妹啊！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "誰是哥哥啊！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別開這種玩笑話啦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身是你的主人！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而你是妾身的眷屬！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才不是什麼兄妹！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而、而且……要是兄妹的話，會有很多困擾吧？",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n像那個、還是這個，甚至是……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不說清楚你聽不懂？",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……那、那個，是眷屬的話就應該懂吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n總之，要是跟你是兄妹的話，會有很多不便的地方！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯……是兄妹的話會很困擾的。",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若是看起來像兄妹，就沒辦法達成妾身的野心！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此，妾身無論如何都要取回原本的力量，",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n並且恢復成那副充滿魅力的大人模樣！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你也要來幫忙！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？想知道妾身的野心嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……那當然是征服世界，但在那之前，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要先與你――",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊，妾身在說什麼！",
        "unit_id": 104412,
        "voice": "vo_adv_1044006_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你別探問奇怪的事啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不僅是外表，\n她離能夠表現出大人般的沉穩態度的那一天，\n似乎還要等上許久。"
    }
]