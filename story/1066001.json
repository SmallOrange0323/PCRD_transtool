[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "迷失於蘭德索爾巷弄中的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在聽見背後傳來的叫喊聲後回過了頭。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別跑──！",
        "unit_id": 1,
        "voice": "vo_adv_1066001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼～！",
        "unit_id": 1,
        "voice": "vo_adv_1066001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哪有那種被說了別跑就真的不跑的笨蛋啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚哇！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n幹嘛呆站在路中央啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說，不妙了！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要被追上了啦！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這種事情一看就知道了吧！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊～真是的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要是我被抓到那就是你害的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是又怎樣？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n反正也與你無關……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊真是的！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我現在可沒時間在這裡耗啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n該該該、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該怎麼辦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你要做什……！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}將少女藏進披風的同時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現了兩個明顯衣著怪異的男人。"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "奇、",
        "unit_id": 911,
        "voice": "vo_adv_1066001_008"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "奇怪？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "沒人啊？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n她剛剛是轉進了這條巷子裡沒錯吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "我們該不會跟丟了吧？",
        "unit_id": 811,
        "voice": "vo_adv_1066001_009"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n喂喂喂，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "這下該怎麼辦啊……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔──！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔──！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔──！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔唔唔唔唔啊嗚！\n（啥！？這哪裡沒事了啊！）",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔唔唔──！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔唔唔嗚嗚！\n（我說你──！快點放開我！）",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "總之現在也只能先走了！",
        "unit_id": 911,
        "voice": "vo_adv_1066001_013"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "那孩子一個人的話總會有辦法的吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "就是因為她一個人沒辦法，才會派我們來啊……",
        "unit_id": 811,
        "voice": "vo_adv_1066001_014"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "喂不妙，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "他們已經追過來了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "快開溜吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "在這裡！",
        "unit_id": 711,
        "voice": "vo_adv_1066001_015"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那些傢伙逃得還真快……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n到底往哪裡跑了？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "噗哈──！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你做什麼啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "王、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "【王宮騎士團】！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "唔，",
        "unit_id": 711,
        "voice": "vo_adv_1066001_017"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那邊那位！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "你剛剛是不是抓著那名少女不放？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以才打算把我藏起來嗎？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這傢伙到底是怎麼回事啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "保護？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你在胡說什麼啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "原來如此……",
        "unit_id": 711,
        "voice": "vo_adv_1066001_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "是因為剛才那夥人……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n你做的很好。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這位少女就交由我們來保護吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什、",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給我等等！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我我我、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才沒有迷路什麼的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我可不需要【王宮騎士團】的幫助！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "唔嗯，",
        "unit_id": 711,
        "voice": "vo_adv_1066001_022"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這樣可不行啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n不過",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這位少女好像有點眼熟……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在說什麼呀──？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我聽不太懂耶──？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "哎呀，",
        "unit_id": 711,
        "voice": "vo_adv_1066001_024"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "現在可不是說這個的時候！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我得去追剛才那夥人才行。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n妳",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "知道他們往哪裡跑了嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "應該是那邊吧──",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大概就是那邊沒錯──",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好了！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你給我閉上嘴！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "這樣啊！",
        "unit_id": 711,
        "voice": "vo_adv_1066001_027"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "謝謝你們的情報！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n等等記得把那位少女帶到我們騎士團的據點！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "那麼我就先告辭了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我們走！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就說了我不會去啦！！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "哎呀──",
        "unit_id": 911,
        "voice": "vo_adv_1066001_029"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "剛剛還真是驚險啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "就是啊就是啊，",
        "unit_id": 811,
        "voice": "vo_adv_1066001_030"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "真是千鈞一髮呢。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "哎呀──能蒙混過去真是太好了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "祈梨。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說什麼「真是太好了祈梨」",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你們兩個！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然丟下幹部自己逃之夭夭！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "不是，",
        "unit_id": 911,
        "voice": "vo_adv_1066001_032"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "妳突然消失不見了我們也沒辦法啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "這位小哥也不需要擺出備戰架勢啦。",
        "unit_id": 811,
        "voice": "vo_adv_1066001_033"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n我們可是祈梨的同伴喔。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_034"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在這一帶竟然有人不認識我……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來你",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是做這行的人吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真沒辦法，就讓我告訴你吧。",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是祈梨。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是在暗中操控蘭德索爾的最強幫派，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n【龍族巢穴】的高級幹部。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還不快向我表示敬意！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "不不，",
        "unit_id": 911,
        "voice": "vo_adv_1066001_036"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "幹部什麼的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "只是祈梨妳自封的吧……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "再說，我們家族",
        "unit_id": 811,
        "voice": "vo_adv_1066001_037"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "也不是最強的啊……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀──！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們都安靜啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然老大和嘉夜夜都是幹部，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我當然也是幹部啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "反正，總之發生了很多事，",
        "unit_id": 811,
        "voice": "vo_adv_1066001_039"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "所以我們\n都在被【王宮騎士團】追著呢。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "話說回來，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "小哥你真是幫了大忙啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在胡說什麼啦～！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是差點",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就要被這傢伙\n推給【王宮騎士團】了耶！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "不過要是沒有他插手，",
        "unit_id": 911,
        "voice": "vo_adv_1066001_041"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "我們三個就都要被抓了喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "沒錯沒錯。",
        "unit_id": 811,
        "voice": "vo_adv_1066001_042"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "祈梨也向他道個謝吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不需要向這種傢伙道謝呢！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再說了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明是因為我靈機一動，巧妙地告訴了他們錯誤的方向才……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "可惡，",
        "unit_id": 711,
        "voice": "vo_adv_1066001_044"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "都走到死路了還是不見他們的蹤影！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n折回去再找一遍！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "呃，",
        "unit_id": 911,
        "voice": "vo_adv_1066001_045"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "那群人折回來了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "祈梨啊……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "\n妳為什麼偏偏要指給他們一條死路？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_046"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "死路……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "奇怪？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼好像變成全部都是我的錯了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "唉……",
        "unit_id": 811,
        "voice": "vo_adv_1066001_047"
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "對祈梨抱有那種期待才是錯的。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "開溜啦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "快點，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "祈梨也跟上。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "給、",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_048"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "給我等一下啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是因為那個，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這傢伙披風角度的關係",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之類的？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "害我當時只能指向那裡，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以就這樣那樣的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚唔唔唔……",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_049"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼嘛。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n幹嘛一直盯著我看！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有什麼好看的！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是記住",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這張臉了喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "再會啦，",
        "unit_id": 911,
        "voice": "vo_adv_1066001_050"
    },
    {
        "type": "dialogue",
        "name": "地痞1",
        "words": "小哥。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "地痞2",
        "words": "掰啦！",
        "unit_id": 811,
        "voice": "vo_adv_1066001_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我將來一定會回敬你的～！",
        "unit_id": 106611,
        "voice": "vo_adv_1066001_052"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "找到了！",
        "unit_id": 711,
        "voice": "vo_adv_1066001_053"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "給我追──！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}就這樣看著祈梨被幫派成員一手抱起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n目送倉皇逃跑的背影漸漸遠去……"
    }
]