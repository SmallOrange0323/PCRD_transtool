    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "あながち間違いじゃないって思えるわ。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\nそれだけ強くなれたってことなのかな？　",
