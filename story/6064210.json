[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "アキノさんがあたしのことを",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_000"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n『ライバルで大親友』",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "って言ってくれるの、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "すごくうれしいわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n……だから",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "もっと努力して、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "追いつきたいの。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ありがとう。",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_001"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でもね、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "最初",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "『ライバル』って言われた時、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n『アキノさんはあたしを過大評価している』って",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "慌てちゃったのよ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも今は",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "実力とか関係なく、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ただ『そうなりたい』って思ってるわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "うん。",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_002"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "まだまだ足りないかな。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nアキノさんに勝負を挑まれたら、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "『負けたくない』って思うから、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nあたしはもっと上を目指すわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "アキノさんを追い越すぐらいにね！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしもそう思うわ。",
        "unit_id": 114511,
        "voice": "vo_adv_6054210_003"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "それで、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "感謝もしてる。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でもそれを伝えるのは、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしが実業家として成功した時よ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……この話は、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "内緒にしててね。",
        "unit_id": 114511
    }
]