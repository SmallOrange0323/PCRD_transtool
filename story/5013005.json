        "voice": "vo_adv_5013005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿真的很幸運。",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "咿呀啊啊啊啊啊！",
        "unit_id": 109311,
        "voice": "vo_adv_5013005_009"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n露一點都不好吃啊！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "咦，",
        "unit_id": 109311,
        "voice": "vo_adv_5013005_010"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "你保護了露嗎！？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "哇，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "謝謝你！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡交給我來解決！",
        "unit_id": 105811,
        "voice": "vo_adv_5013005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝啊啊啊啊啊！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "巨靈",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 11211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_012"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "好厲害。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "之前我就這麼覺得了，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "貪吃佩可她……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_013"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "沒錯！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "該說是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "優雅嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "簡直就像是禮儀課的老師一樣。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒那麼了不起啦～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "馬納歷亞魔法學院",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連禮儀課都有嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊啊，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_016"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "禮儀課不是在學院上的，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那是在城堡裡學的。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n因為禮法是一定要學習的",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "修養課程之一。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "城堡？",
        "unit_id": 105913,
        "voice": "vo_adv_5013005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　修養……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難道安小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是位出身非常高貴的人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "這是當然的囉―！",
        "unit_id": 109311,
        "voice": "vo_adv_5013005_018"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "安前輩是",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "馬納歷亞王國的公主！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦～……",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在才說她是公主，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們的態度或用字遣詞，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也很難在一時之間改變。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_020"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "你們完全不用介意那種事！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "只要像平常那樣與我相處就可以了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就這麼做吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過安是公主啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實很有氣質……",
        "unit_id": 106012
    },
    {
        "type": "still",
        "still": "501300501"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯～……",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_022"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嚴格說起來，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "貪吃佩可比較有氣質吧？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討厭〜！",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　安真是的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然間胡說些什麼啊～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我有的充其量不過是對美食的好奇心而已！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是這樣嗎？",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_024"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "話雖如此，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "貪吃佩可",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n該不會其實是某個王國的公主吧～？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是不是，",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我只是個隨處可見，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子餓得咕嚕咕嚕叫的貪吃佩可！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都過著什麼樣的生活？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n果然，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一天到晚都有護衛在身邊保護自己嗎！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "當然不可能二十四小時都在一起，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_027"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n不過確實有一位",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "名叫歐文的護衛喔。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "基本上他是一位值得信賴的人……",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_028"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是該說他小題大作嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n總之他常常做得太過頭。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "遠足的時候，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "還做了奇怪的點心……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會做點心給你的護衛！？",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好令人羨慕啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真好〜☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊哈哈！",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_030"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "如果歐文是貪吃佩可的護衛，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n他一定會現場製作",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "魔物料理給妳吃！",
        "unit_id": 109211
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過身邊有護衛，",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎很麻煩。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不覺得很拘束嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯～",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_032"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "身為王族的我必須全盤接受，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我很明白這個道理……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可是我討厭一昧地被別人保護！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "的這種感覺。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "所以你才從王宮跑出來，",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_033"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "進入馬納歷亞魔法學院就讀吧？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵……",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_034"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我不想當弱小的公主，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n希望自己強大到能為守護別人而戰。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此。",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是了不起的想法！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果我也能成為這樣的公主，",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個國家一定也……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐？",
        "unit_id": 105913,
        "voice": "vo_adv_5013005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於馬納歷亞的事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還想知道得更多！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "真的嗎！？",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_039"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳有興趣真是太好了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n如果貪吃佩可能到馬納歷亞來，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一定會玩得很開心吧～",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "說得也是。",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_040"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "雖然多多少少有點危險……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "危險？",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_041"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "例如，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "異世界的門突然出現，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n魔物們紛紛從那裡面湧現，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "導致學院在戰鬥中半毀……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "或者",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_042"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "受到封印的墮天使突然復活，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n到處施放禁忌術式……？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好可怕！",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這哪算「多多少少」啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "在學院這種事",
        "unit_id": 109311,
        "voice": "vo_adv_5013005_044"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "只是家常便飯",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "而已唷～",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "而且，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "這些問題現在都已經解決了，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "沒問題的！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得重點應該",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不在那個地方吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "還有……",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_046"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　馬納歷亞魔法學院裡，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n有一座非常古老的魔法圖書館喔。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "裡頭有許多魔導書、",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_047"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "或是被稱為禁書的藏書，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不過偶爾也會引發一些問題……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽起來有點嚇人……",
        "unit_id": 105913,
        "voice": "vo_adv_5013005_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生了什麼事呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "圖書館的主人大發雷霆，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_049"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "將其封印……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我記得當時",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "漢娜因此感到很自責。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_050"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "漢娜是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "馬納歷亞魔法學院的學生會長。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n她是一位做事可靠，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "認真負責的好孩子。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "歐文和漢娜，",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_051"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "現在應該很擔心我們吧……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……是啊。",
        "unit_id": 109411,
        "voice": "vo_adv_5013005_052"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "一定是這樣的……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "嗯～……",
        "unit_id": 109311,
        "voice": "vo_adv_5013005_053"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n露",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "突然覺得胸口一陣刺痛。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n為什麼會這樣呢……？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "露……",
        "unit_id": 109211,
        "voice": "vo_adv_5013005_054"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "為了能見到大家，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們一定要打倒巨靈，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n回到密斯塔爾西亞！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "密斯塔爾西亞嗎……",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "光之裂縫與世界的毀滅什麼的、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都是些令人摸不著頭緒的事情啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許真的存在著呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "包含那個叫做密斯塔爾西亞的地方。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105812,
        "voice": "vo_adv_5013005_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留你啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太多疑了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n安他們所說的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "根本沒有需要懷疑的地方啊～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們說的可是異世界耶？",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_058"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "老實說，那根本不合理啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是……",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "待在【美食殿堂】這個公會裡，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "時常有不合理的事情發生，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n連我都要漸漸習慣了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其中最不合理的就是",
        "unit_id": 106012,
        "voice": "vo_adv_5013005_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為喪失記憶而變得傻呼呼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n卻仍有辦法生存下去的這個傢伙唷！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還在我們不知道的地方，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "出手幫助別人？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_5013005_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是個心地善良的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論是誰都會想要向他伸出援助之手。",
        "unit_id": 105913
    },
    {
