[
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從目擊到外表與自己相同的『闇影』，\n與父母感情很好地走在路上之後幾天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音變得鬱悶不樂，\n讓【咲戀育幼院】的大家都很擔心。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}，能占用點時間嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n打擾了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？　",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你在做什麼啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼坐在地上……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難道是肚子痛？　",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是在做聖誕節用的裝飾啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n剪下色紙，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再將色紙圈起來……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你幫我們這麼多忙，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總是受你幫忙了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？　",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說「如果當乖孩子就能收到禮物」？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那是聽誰說的啊……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，放心吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你的禮物",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也有好好準備了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起那個。",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等你這個作業完成後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可以麻煩你",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和綾音一起去買東西嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟是年尾了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有很多東西必須事先買起來才行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "綾音",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然不願把詳細的事情告訴我，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但她一直悶悶不樂地",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把自己關在房間裡對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她那樣子會生病的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你帶她去呼吸外面的空氣吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我剛好得參加",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【公主騎士】",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n年末最後的集會，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒辦法照顧綾音……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以想拜託你，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "造成你的麻煩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是嗎？　",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就太好了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我覺得綾音她",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也許會對你敞開心房，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她如果有什麼煩惱，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就聽她說說吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要和人吐過苦水後，",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她應該一下子就輕鬆起來了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "麻煩你囉，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哥哥♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哇，哦哦？",
        "unit_id": 102811
    },
    {
        "type": "still",
        "still": "108600201"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥～！",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看你看",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鏘～☆",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很可愛對吧？",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是咲戀媽媽給我的洋裝，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n說是和大家一起辦派對穿的衣服！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對吧～♪",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n再多誇獎我！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "來，你看！　",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是只有我，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n連噗吉都變得很有聖誕節的氣氛囉！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也誇獎噗吉吧！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒、沒問題的，哥哥！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該也會有哥哥的份啦！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所有人的份，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓會在晚上縫製好的，放心吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然到店裡去買也不錯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但還是我們自己做比較省錢啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊～",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽真是的……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就聖誕節奢侈一下如何？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "年末總是很花錢啊……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先不提這個。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳穿得很好看喔，",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "綾音。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣子一看，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "完全是個成熟的淑女了呢♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n謝謝妳，咲戀媽媽，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "最～喜歡妳了♪",
        "unit_id": 108611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈……",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n沒想到",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "心情突然就變好了呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說不定沒有必要把綾音託給{player}照顧呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『哈哈。",
        "unit_id": 2112,
        "voice": "vo_adv_1086002_022"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n她只是在逞強，",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "因為不想讓其他人擔心。』",
        "unit_id": 2112
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "吶吶，",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "接下來要去買東西對吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "走吧走吧！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我想去讓大家看看，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我這身可愛的洋裝！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1086002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "玩得開心點。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要注意別太晚回來。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我知道啦，咲戀媽媽！",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是小孩子啦！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "走吧，哥哥！",
        "unit_id": 108611,
        "voice": "vo_adv_1086002_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
