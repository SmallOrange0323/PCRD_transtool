        "type": "dialogue",
        "name": "碧",
        "words": "怎、",
        "unit_id": 104011,
        "voice": "vo_adv_3009002_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼這樣……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我、我原本就已經",
        "unit_id": 104011
    },
