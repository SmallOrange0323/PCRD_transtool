    {
        "type": "dialogue",
        "name": "旁白",
        "words": "身為公會「森林守衛」見習成員的碧，\n為了能成為正式成員，每天都在上課。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如此這般，",
        "unit_id": 101511,
        "voice": "vo_adv_3009002_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n今天請{player}來到這裡了喔～",
        "unit_id": 101511
