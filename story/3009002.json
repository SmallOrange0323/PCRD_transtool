        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一想到會在{player}面前失敗，我就……！",
        "unit_id": 104011
