        "name": "初音",
        "words": "也許因為如此，",
        "unit_id": 101211,
        "voice": "vo_adv_3009002_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所有植物都擁有神奇的力量，",
        "unit_id": 101211
    },
