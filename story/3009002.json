        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～，",
        "unit_id": 101211,
        "voice": "vo_adv_3009002_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這前面就是精靈之森了喔！",
