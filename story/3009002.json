    {
        "type": "dialogue",
        "name": "碧",
        "words": "為、為、",
        "unit_id": 104011,
        "voice": "vo_adv_3009002_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼{player}會！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們的公會",
        "unit_id": 101511,
        "voice": "vo_adv_3009002_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "肩負許多職責，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n也有精靈之森嚮導的工作對吧？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我麻煩{player}",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "扮演參訪者喔～",
        "unit_id": 101511
    },
