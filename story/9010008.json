    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從四周飄來美味的香氣！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該從哪裡開始吃起呢～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難不成，",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳打算全部都吃嗎……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲",
        "unit_id": 105812,
        "voice": "vo_adv_9010008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然也要一起來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳放心吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "攤販和店家我都調查過了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "準備萬全喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "辦、",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "辦不到啦……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我吃不下這麼多……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012,
        "voice": "vo_adv_9010008_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要陪著應付妳的食慾的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "派對都還沒開始，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n大家就會先吃到撐死啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那邊的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是莉莉和克蘿茜她們嗎。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_9010008_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n吉歐‧格黑納街道一行人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也在街道那邊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……真是引人注目呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "涅妃‧涅羅小姐和",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妖魔人的各位……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好的。",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n大家一起，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "走吧！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「好☆」\n「好的！」\n「嗯！」",
