    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用「什麼都能煮的大鍋」做的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【美食殿堂】特製的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "取名為",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「紀念日慶祝湯」！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好香啊☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……說是取名為，",
        "unit_id": 106012,
        "voice": "vo_adv_9010008_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就直接是字面上的意思啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿～",
        "unit_id": 105812,
        "voice": "vo_adv_9010008_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想說",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是要直接了當才好啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】盡全力做的湯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好喝得像做夢一樣喔～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做出了不同凡響的紀念日的，",
        "unit_id": 105913,
        "voice": "vo_adv_9010008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不同凡響的湯♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "美味的原因當然是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萃取自凱留小姐和雪菲小姐的高湯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟可可蘿小姐、",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n還有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}的高湯都加進去了呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下，",
        "unit_id": 106012,
        "voice": "vo_adv_9010008_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要連妳都跟著開玩笑啦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "湯很美味是理所當然的就是了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和大家一起做湯，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的十分有趣。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為之前慶祝的時候，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "做了禮物，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以其實",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也很想試試看做料理。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_9010008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很勇敢地進行挑戰了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然切洋蔥時陷入了苦戰，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還是忍著眼淚",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "努力完成了呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雪菲小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然途中",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也經歷了變成小嬰兒的場面……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 106412,
        "voice": "vo_adv_9010008_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "眼睛真的太痛了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n鼻子裡面感覺刺刺的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "眼淚也停不下來……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "下次",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會努力不變成小嬰兒的！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的☆",
        "unit_id": 105812,
        "voice": "vo_adv_9010008_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今後還有很多機會可以一起做料理！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把【美食殿堂】的至今與往後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全都做成美味的湯吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了，",
        "unit_id": 105913,
        "voice": "vo_adv_9010008_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "時間差不多了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n去迎接客人的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【幻變少女】的各位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該也快回來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好，",
        "unit_id": 106012,
        "voice": "vo_adv_9010008_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天要幹勁滿滿地享受喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}也",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "準備好了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾街道的大家，",
        "unit_id": 105812,
        "voice": "vo_adv_9010008_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也都開開心心地準備了各種東西呢♪",
        "unit_id": 105812
