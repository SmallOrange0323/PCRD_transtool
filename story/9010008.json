    {
        "type": "dialogue",
        "name": "旁白",
        "words": "７周年紀念日終於到來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n派對開始不久前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾中──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鏘──！",
