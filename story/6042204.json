    {
        "type": "dialogue",
        "name": "步未",
        "words": "日和",
        "unit_id": 113011,
        "voice": "vo_adv_6042204_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像對我有很多誤解……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "她說希望",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我能教她有關忍者的事情耶。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我該怎麼辦才好……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連、",
        "unit_id": 113011,
        "voice": "vo_adv_6042204_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連前輩也這樣～！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "教前輩的話……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這說不定",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是個好機會……？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只有我和前輩，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "兩人獨處……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "光是想像",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我就緊張到快昏倒了……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "躲藏……",
        "unit_id": 113011,
        "voice": "vo_adv_6042204_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我其實並沒有多小心翼翼地躲起來……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "事實上，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只是誰都沒有注意到我而已……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "才才、",
        "unit_id": 113011,
        "voice": "vo_adv_6042204_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "才不是呢！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "看起來有點失望……？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n呃……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我搞不好",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的是個",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "忍者喔……",
        "unit_id": 113011
    }
]