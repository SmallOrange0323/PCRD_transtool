    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "對啊！",
        "unit_id": 119911,
        "voice": "vo_adv_5080322_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n更何況宮子對布丁以外的點心都沒興趣喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果出現布丁妳打算怎麼辦？",
        "unit_id": 119311,
        "voice": "vo_adv_5080322_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………",
        "unit_id": 119911,
        "voice": "vo_adv_5080322_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "婆婆的布丁是最棒的喲！",
        "unit_id": 119911,
        "voice": "vo_adv_5080322_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……剛剛的停頓",
        "unit_id": 119211,
        "voice": "vo_adv_5080322_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就當沒這回事吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在宮子輸給誘惑之前，趕緊收拾掉吧！",
        "unit_id": 119311,
        "voice": "vo_adv_5080322_007"
    }
]