[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了找回遺失的記憶之鑰，{player}和極力尋找線索\n以重獲全盛時期力量的伊莉亞一起前往露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "途中，加入為了尋求小說創作題材而在街道閒晃的杏奈，\n3人來到通往露娜之塔的祠堂。"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這就是吉格魯特失去的記憶沉眠之所，",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_000"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "露娜之塔嗎……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵呵，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "好痛……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我的魔瞳好痛……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔喔。",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "感覺很有氣氛嘛。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你做好覺悟了嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔呣，",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真有膽識。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳是「移動龍卷風」吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳又如何呢？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這麼說來",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_003"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "還沒自我介紹呢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我的名字是安妮羅潔‧馮‧修特帕魯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n人稱",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "疾風之冥姬！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "隨妳高興怎麼叫都可以！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔呣，",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就稱呼妳為修特帕魯吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說回來，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳所說的吉格魯特指的是{player}嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "當然！　",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_005"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "熾炎戰鬼煉獄血盟暗黑團的第二連隊長，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n兼我的前世宿敵與",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "盟友……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "他就是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "閃光的吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是個有趣的傢伙。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不愧是{player}的朋友。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這麼說來，",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_007"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "「傳說的吸血鬼」",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這個名號",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n也相當響亮啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不愧是吉格魯特，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "在魔族之間也很吃得開呢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對了，",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也來自我介紹吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身名叫伊莉亞。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n統御黑夜之人，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯坦。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那麼，",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_009"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我就稱呼妳為",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "奧恩斯坦大臣吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵呵呵，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "聽起來是個充滿黑闇魔力的名字呢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那我們也差不多該進去了吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然關係到{player}的記憶，",
        "unit_id": 104412,
        "voice": "vo_adv_7007000_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n一定也和取回妾身力量",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的事情有關聯。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那麼，",
        "unit_id": 100911,
        "voice": "vo_adv_7007000_012"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "現在開始進行露娜之塔攻略戰！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "熾炎戰鬼煉獄血盟暗黑團，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "出擊！！",
        "unit_id": 100911
    }
]