[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，千歌為了練習唱歌，\n在找尋就算放聲高歌也不會打擾到他人的場所時，\n一路走到了海邊來。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我從現場演唱會那天開始，狀況就非常好……",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這都是多虧了{player}……呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天的練習就先到這裡吧――",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？說人人就到呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你今天在做什麼呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "討伐魔物……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊。今晚這附近有祭典是嗎……",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在那之前，得先確保海岸周邊的安全呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣的話，我也一起幫忙。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你不用客氣。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我平常受到你很多幫助，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就當作是平日的回禮。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "討伐魔物，",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "本來就是我的職責，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而且我想用唱喚術應該能幫上忙。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……不行",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那就這樣決定囉！",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n首先我先唱喚出精靈，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請她幫忙找出魔物的氣息。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "若找到魔物的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們就一起戰鬥吧。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……現在的好像是海岸附近最後一隻魔物了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們兩人合作，一下子就討伐完了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在海岸上也沒有魔物了，我想稍微再留在這裡一下。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為我有想要做的事情。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要陪我一起留下來嗎……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你說可能還有魔物在嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你要守護我呢……謝謝你。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那麼……就麻煩你了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～～♪",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……啊。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你醒過來了嗎？早安。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然這樣說，但太陽已經下山了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你很累了吧。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才馬上就睡著了喔？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "祭典也已經開始了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你聞，從城鎮那裡飄來了許多夜光花。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我看你睡得很舒服的樣子，",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以就沒有叫醒你而等你自己醒來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡非常的安靜喔。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧如此，我才能集中精神工作。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我剛剛在為樂譜填詞。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n為新的歌曲……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這首歌不是唱喚術的歌，",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也不是我作為偶像時唱的歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而是把我的心意原原本本地挹注進去所寫的歌曲。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……等到有一天。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "等到有一天這首歌曲完成的時候……",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我希望你能聽看看。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝……謝謝你……",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "天色完全變暗了呢，",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n今天就先到這裡為止吧。那麼，我們回去吧！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你願意跟我一起去嗎……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……真高興。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝、謝謝你。可是，那個……",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……如果可以的話，你要不要跟我一起去祭典呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "祭典上好像也有很多攤販出來擺攤。",
        "unit_id": 104211,
        "voice": "vo_adv_1042007_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們去買各式各樣的東西，然後兩個人分著吃吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……呵呵，突然讓人很期待呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，兩人和樂融融地一起享受祭典。"
    }
]