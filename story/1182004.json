        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "哇～★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "在這種狀況下",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_050"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "還真的說出這種話。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n不愧是你，",
