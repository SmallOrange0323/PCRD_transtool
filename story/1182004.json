        "voice": "vo_adv_1182004_051"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "真好呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n就像是男孩遇到女孩的吊橋效應之類的★",
