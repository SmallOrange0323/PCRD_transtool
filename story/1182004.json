    {
        "type": "dialogue",
        "name": "美空",
        "words": "就在結束的前一刻，",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_069"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "又更加",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "感到",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「心動★」。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就好像是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不小心？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的感覺♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這也是吊橋效應吧──？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵，",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_070"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不要在意。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "坦白說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我自己也嚇了一跳♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你可能",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_071"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "已經發現了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n該說我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是很隨心所欲又愛唱反調嗎。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還是該說我衝動又個性扭曲呢，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "哎",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呀，就是這種感覺。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被憎恨就會感到開心。",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_072"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n看到很重要的東西就會想破壞它。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真的是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "連我自己都開始討厭我自己了……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_073"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可是可是。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n被騎士同學抱住，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而決定放棄了結自我的理由，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我似乎已經搞懂了★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "果然是因為",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_074"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "剛才的「心動★」，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我覺得很美好喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果這個感覺是愛，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我還想瞭解更多──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這樣♪",
