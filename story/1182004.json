    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "因為",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_047"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "那些追兵的最終目標是我。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n如果陪我到最後，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n連你都會遭遇不幸喔？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "但是？",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_048"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "……哇★",
