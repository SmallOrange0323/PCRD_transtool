    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵★",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_075"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n愛上騎士同學的路，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "又更進一步了呢♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好啊★",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_076"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n什麼都可以問喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……♪",
        "unit_id": 192011,
        "voice": "vo_adv_1182004_077"
    },
    {
        "type": "dialogue",
        "name": "美空",
