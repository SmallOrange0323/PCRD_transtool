        "type": "dialogue",
        "name": "魅空",
        "words": "呵呵♪",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "不過怎麼說呢──",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_038"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n像這樣被別人幫助，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "感覺真好──★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "畢竟一～直以來",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_039"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "都沒有會為了我挺身而出，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n幫助我的人。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "一個都沒有。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "這個嘛，",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_040"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "因為我超級可愛★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "……才怪……",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "應該說我",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_041"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "是這個世界裡超乎常理的存在？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n之類的，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "像是系統錯誤一樣的存在呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "多虧如此，",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_042"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我就被綁架、被當成實驗品了。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n真希望他們可以放過我啊──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "順帶一提，我父母也因此死掉了呢？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "……啊哈。",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_043"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n我也已經不記得他們的長相了，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "所以不用在意喔★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "比起這個──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我們差不多",
        "unit_id": 118231,
        "voice": "vo_adv_1182004_044"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "要在這裡說再見了♪",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n謝謝你",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "這麼努力踩腳踏車幫我。",
