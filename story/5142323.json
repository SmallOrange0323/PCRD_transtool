[
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼、",
        "unit_id": 129811,
        "voice": "vo_adv_5142323_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快看，惠理子。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那傢伙，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像終於拿出全力了……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哼，",
        "unit_id": 129911,
        "voice": "vo_adv_5142323_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是最後的垂死掙扎吧……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n既然如此，我們也……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142323_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓牠見識我們最後的作戰吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "作戰？",
        "unit_id": 129911,
        "voice": "vo_adv_5142323_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳有什麼好策略嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿……",
        "unit_id": 129811,
        "voice": "vo_adv_5142323_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那還用說！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在這裡戰鬥的人可是我和妳耶？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "憑蠻力揍下去！！",
        "unit_id": 129811,
        "voice": "vo_adv_5142323_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n──除此之外還有別的嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻……",
        "unit_id": 129911,
        "voice": "vo_adv_5142323_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n以妳來說還真是個好作戰。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好吧，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我就竭盡全力來戰鬥吧！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好！",
        "unit_id": 129811,
        "voice": "vo_adv_5142323_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這場蠻力對決……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "勝利的──",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「會是我們！！」\n「是我們啦！！」",
        "unit_id": 1,
        "voice": "vo_adv_5142323_008"
    }
]