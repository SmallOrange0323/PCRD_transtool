[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某日，璃乃獨自從蘭德索爾來到附近的綠地公園。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n呼～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "空氣真清新！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這座公園跟以前都沒變呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最近這陣子",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "發生了太多事情，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓人有點疲累了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長的圍裙也做好了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今天就拋開各種煩心的事情，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好好放鬆一下吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "考試的準備……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就明天開始加油吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天有很多家庭和小孩來這裡呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也經常",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "像那個樣子和哥哥一起來玩呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "哇――！",
        "unit_id": 111,
        "voice": "vo_adv_1011009_004"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊～",
        "unit_id": 211,
        "voice": "vo_adv_1011009_005"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "等等我嘛～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "　哥哥～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就像那個樣子跑來跑去的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "探險隊出發～！",
        "unit_id": 111,
        "voice": "vo_adv_1011009_007"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "　跟著我來～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好～！",
        "unit_id": 211,
        "voice": "vo_adv_1011009_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "奇怪？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n和那孩子們一起玩的人，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該不會是……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你跟小孩子玩在一起做些什麼啊……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　是他們的父母",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "拜託你帶小孩子來公園的？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥你還是一樣這麼爛好人呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我並不是有什麼事才來這裡的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　我也來幫忙",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "陪小孩子一起玩吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "幫助哥哥",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也是妹妹的職責啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦――？",
        "unit_id": 111,
        "voice": "vo_adv_1011009_014"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "　如果是最小的小弟就可以。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可以喔～",
        "unit_id": 211,
        "voice": "vo_adv_1011009_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小弟是嗎……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我在公會已經習慣了，沒關係！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那就出發～！",
        "unit_id": 111,
        "voice": "vo_adv_1011009_017"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "出發～！",
        "unit_id": 211,
        "voice": "vo_adv_1011009_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得這種事很令人懷念呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不可以！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　要是跑那麼快的話……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "呀！",
        "unit_id": 211,
        "voice": "vo_adv_1011009_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　果然跌倒了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n還、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還好嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚……",
        "unit_id": 211,
        "voice": "vo_adv_1011009_022"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚嗚……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚哇――！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "　好痛喔――！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "什麼啊――",
        "unit_id": 111,
        "voice": "vo_adv_1011009_023"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妳是在做些什麼啊――",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚嗚……",
        "unit_id": 211,
        "voice": "vo_adv_1011009_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚嗚……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "對不起……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等一下喔，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在替妳處理傷口。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好～",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "痛痛、痛痛",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "飛走吧～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "已經沒事囉。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚……",
        "unit_id": 211,
        "voice": "vo_adv_1011009_027"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗚嗚……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妳很遲鈍耶，",
        "unit_id": 111,
        "voice": "vo_adv_1011009_028"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n所以我才說不想和妳一起來啊！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼可以那樣說呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥……！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_030"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那什麼嘛……",
        "unit_id": 111,
        "voice": "vo_adv_1011009_031"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不過我",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "一點也不遜喔。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "還好嗎？",
        "unit_id": 111,
        "voice": "vo_adv_1011009_032"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "　",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "來，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我來背妳吧。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯……",
        "unit_id": 211,
        "voice": "vo_adv_1011009_033"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝你，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哥哥……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "事情告一段落了呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真不愧是哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "掰掰～！",
        "unit_id": 111,
        "voice": "vo_adv_1011009_035"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "再見～！",
        "unit_id": 211,
        "voice": "vo_adv_1011009_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "掰掰～！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要小心點喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "和他們父母",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是約定好要在這碰面啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n幸好",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只是個小輕傷，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個也不會留下疤痕。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥接下來打算做什麼？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要繼續待在這裡一下子。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我姑且也把參考書帶來了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "想說念個書之後再回家。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可以嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起來念書吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖是這麼說，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我也好久沒接觸了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "先從初級篇開始喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我看看，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼什麼……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n『刻瑞斯森林的植物中，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其中擁有最強韌之纖維的植物，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n是下列何者？』",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就這樣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "答對了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哦哦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　好厲害喔，哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n原來如此，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是在打工和公會活動中，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "親身體驗學會的吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對了，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下次也請帶我一起去！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要透過親身體驗來學習！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔唔，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "答錯了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n才初級篇就這樣，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "後面可要擔心了呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_047"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來看下一個問題吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這次",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來答答看中級的問題。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『希德雷克的鱗片",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因可作為飾品",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "與閃光飾片而受到重視，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n　請問曾經目擊過其蹤影的地方",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為以下何者？』",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這題，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺就像是超容易出錯的問題耶……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "答錯了……",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這問題太難了啦……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n想得太深反而被騙了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n完全開始在疑神惡鬼了啦……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……答對了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好厲害好厲害！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你怎麼會知道？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真不愧是哥哥！",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這就是有本領的章魚會隱藏利爪！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　……章魚是有爪子的嗎？",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_052"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　不知不覺已經傍晚了？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺時間轉眼間就過了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n天色也差不多要暗下來了呢～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然有很多事情要煩惱，",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但和哥哥一起度過後，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺輕鬆多了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天非常謝謝你，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸？",
        "unit_id": 101112,
        "voice": "vo_adv_1011009_054"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥要送我回家嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就能再多和哥哥在一起了呢。",
        "unit_id": 101112
    },
