    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個午後。{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被雪叫了出來，陪他一起購物。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哦～",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真棒呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這瓶紫色的指甲油。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你不覺得這個顏色",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟這件禮服很搭嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能幫我放進購物籃嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有，",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我從以前就很在意",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那邊的護髮油呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n聽說用了頭髮會變得光澤閃耀。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也把那個",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "放進購物籃吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哈哈，",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼可能。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我身上可是一毛錢都沒有喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "先前，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我才剛把全部財產",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "通通拿去買了美容液呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我變得越來越美的機會吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也說過對吧，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n說想要看到變得更美的我。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說，",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是來自宇宙最美的我的請求！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你願意替我支付",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這筆費用嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我會變得更美作為給你的償還♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……咦，",
        "unit_id": 126311,
        "voice": "vo_adv_1263004_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然又突然",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "發出耀眼光芒……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然還是太狡猾了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明我也想要像那樣發出光芒！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不能用禮服的力量",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想想辦法嗎……？",
        "unit_id": 126311
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管什麼時候來，這房間都一樣簡樸呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我滿喜歡",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你房間這樣",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "乾淨整潔的感覺。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又覺得有點太過簡樸了。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "舉例來說，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是在牆壁上貼上我的海報，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你不覺得房間",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會變得更華麗、更棒嗎？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔嗯。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總之，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是你想要，隨時都可以說喔。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管你要多少張，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我都會把海報準備好♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "言歸正傳。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我今天",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會來的理由……",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你應該還記得吧？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "──沒錯，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了要留存永恆之美！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一直很期待今天這個日子！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也是吧？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我去換個衣服。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你也",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "將桌子收到一旁，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "開始著手準備吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我換好衣服了。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那就開始吧──",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的攝影會！",
        "unit_id": 100831
    },
    {
        "type": "still",
        "still": "126300401"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如同先前所提到的，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這次的主題是永恆之美……",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了表現出這個主題，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我準備了符合吸血鬼形象的服裝！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "高貴、神秘且妖豔……",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再適合我不過了吧？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好了，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你就盡情地拍吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n從各種不同的角度，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "將我的美",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "收入鏡頭內！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……話說回來。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了攝影會，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你在短時間內",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "準備得很仔細周全呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了營造氣氛，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你不讓直射日光照進房間，而且……",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "帶有日常感的電腦與書桌",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也都收了起來。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太棒了。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這正是",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "適合拍攝我的舞台！",
        "unit_id": 100831
    },
    {
        "type": "still",
        "still": "126300402"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵呵。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "選了你真是太好了。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這樣子才是",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的專屬攝影師。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……嗯？",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你說我現在的表情很棒？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是嗎？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我的表情",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "無論何時都是最棒的……",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說的也是呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n或許我有著只有與你在一起時，才會露出的表情。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總覺得",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有點不可思議。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算了。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更重要的是，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你儘管拍吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了將我的美",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全部留存為照片！",
        "unit_id": 100831
    },
    {
        "type": "still",
        "still": "126300403"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那還用說。",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要上傳到SNS。",
        "unit_id": 100831
