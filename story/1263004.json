        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "未來的人們",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然也會有救贖。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我打從心底感到遺憾，",
        "unit_id": 100831,
        "voice": "vo_adv_1263004_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但我的肉體",
