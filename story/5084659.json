[
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "想再去探望小哥……",
        "unit_id": 106611,
        "voice": "vo_adv_5084659_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但我是幫派成員呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不能讓其他探望小哥的人感到害怕。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥睡著後，老大給人的感覺好不舒服哦。",
        "unit_id": 106611,
        "voice": "vo_adv_5084659_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算我拿組織的錢",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "買點心吃喝，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大也不發火，說什麼馬上就要「結束」了，所以隨我便……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個瞇瞇眼老太婆，",
        "unit_id": 106611,
        "voice": "vo_adv_5084659_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "舉止比往常還要更讓人摸不著頭緒啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不會就這麼結束了，對吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥不在的話，",
        "unit_id": 106611,
        "voice": "vo_adv_5084659_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰來和我聊慈樂之音的話題啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還有，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當我搞砸什麼事情的時候，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n會陪我去和老大道歉的人",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大概就只有小哥了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以要快點醒來哦，",
        "unit_id": 106611,
        "voice": "vo_adv_5084659_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再幫我完成我的下剋上哦！",
        "unit_id": 106611
    }
]