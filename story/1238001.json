[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【王宮騎士團】結束了與獸人族的和平活動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茉莉進行了一場超級英雄秀，幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n身穿兔子族鎧甲的克莉絲提娜出現在{player}面前。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "找到了找到了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，終於找到你了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我突然想起來還沒有問你的感想呢。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以特地穿成這樣來找你。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "心懷感激吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，小子，告訴我。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你覺得",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我穿這身鎧甲",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼樣？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其他人的反應都像晴天霹靂一樣，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n嘴巴上倒是讚不絕口哦？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用見外，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也坦率地",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "表達內心的感受吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦♪",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想也是。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哪裡適合我？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你覺得哪個地方特別適合我？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用見外，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "仔仔細細地、",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "鉅細靡遺地",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說出來吧☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嘿，小姐。",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_005"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n那邊那位可愛的",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "小姐。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_006"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_007"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "滿可愛的嘛～",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n要不要跟我去",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喝杯麥酒呀？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喲喲？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你這傢伙難道是",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在搭訕我嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯，",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_009"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是啊。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，你看不出來嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我現在身邊",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是有男伴呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你打算強取豪奪嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯，",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳確實是帶著男伴。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n但妳看起來是",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "軟綿綿的可愛類型呀？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n感覺妳是那種積極主動一點就有機會的女孩嘛～",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嘿嘿。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "積極主動一點、",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就有機會的、",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "女孩",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你說我嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該不會……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我問你一個問題。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你知道「克莉絲提娜」",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這號人物嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "克莉絲提娜？",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_015"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n當然知道啊～",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "她超有名的耶。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不過，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "比起她那種類型的，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳這種軟綿綿的更對我的胃口啦～♪",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然是這樣……！",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我的穿著打扮跟平時判若兩人，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這傢伙",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本沒認出我是誰……！　",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可有意思了♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──走吧，小子！",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想到了有趣至極的消遣方式☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "咦，",
        "unit_id": 6311,
        "voice": "vo_adv_1238001_020"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳就這樣走了！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n那我呢？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂──！",
        "unit_id": 6311
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來問問大家",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "關於克莉絲提娜的看法。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來只要穿上了這個，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "周圍的人就認不出來是我了呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我穿上這個隱藏真實身分，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "假借採訪的名義，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n向民眾打聽一下自己的風評，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是這樣的玩法。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼樣，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽起來很有意思吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "平時不會有人來跟我講他的意見呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我覺得偶爾聽聽民眾的心聲",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是一種樂趣呀♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了，小子，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在擔心什麼？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "萬一有難聽的批評，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會很受傷？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n根本是杞人憂天，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不想想我是誰！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──走了，小子！",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我當主要採訪員，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你來當副手。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "對克莉絲提娜這個人有什麼看法？",
        "unit_id": 311,
        "voice": "vo_adv_1238001_029"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n雜誌要做關於她的專題報導嗎，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這樣啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "唔……簡單來說，",
        "unit_id": 311,
        "voice": "vo_adv_1238001_030"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "就是生人勿近",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "的感覺吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n該說是「敬鬼神而遠之」嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "就各方面來說，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個人都算是危險人物吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼個危險法呀？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "唔……",
        "unit_id": 311,
        "voice": "vo_adv_1238001_032"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不是有個",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "傳聞嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n一站在她身後，小命就不保了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "偷偷跟你們說，",
        "unit_id": 311,
        "voice": "vo_adv_1238001_033"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我認識隔壁鎮的一個人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "聽說他叔公的",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n雙胞胎孫子裡的弟弟，好像認識那個站在克莉絲提娜身後，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n下場很悽慘的人呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "怎麼想",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "都很危險吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "克莉絲提娜？",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_035"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "哎呀，該怎麼說呢……",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_036"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n那個女人偶爾會出現在",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我的夢裡呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "沒有，",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_037"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我們不認識呀？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我只聽過傳聞，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "從沒見過本人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "但她還是出現在我夢裡了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "多麼厚臉皮的人啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我往懸崖下面一看，",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_038"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "那個女人就在那裡，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "嘴巴張得大大的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我心裡想著，會被吃掉，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "千萬不能過去……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "越想越覺得",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_039"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "自己要被那響亮的笑聲",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "給拽下懸崖。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n就是那樣一場惡夢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "該死，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "我們明明素昧平生啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "抱歉，我失態了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "那應該是",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_040"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "「瘋狂」吧……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n寫作瘋狂，唸作克莉絲提娜……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她最近給人的印象是為和平做出貢獻，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n或是為了民眾表現很活躍吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "喔！",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_042"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "妳說之前獸人族那件事嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "大家都議論紛紛的呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "很驚訝那個克莉絲提娜會做出那些事。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那就是因為和平活動",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大大改善了人們的印象囉──",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "不不不，",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_044"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "怎麼可能會改善啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "那個戰鬥狂",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "不可能會協助維持和平的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "大部分的人都覺得她很可疑啊。",
        "unit_id": 2511,
        "voice": "vo_adv_1238001_045"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n說這一切都是為了推翻國家所佈下的局。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "唉……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "感覺又要出現在我的夢裡了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是指什麼？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……你問我",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還要不要繼續？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然要啊，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有什麼不繼續下去的理由嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實際一打聽，發現盡是一些不中聽的風評，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你擔心我是不是受傷了？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你又在擔心這種無關緊要的事嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我都說了，你這是杞人憂天。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "輿論是好是壞都無所謂。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n比被蟲咬還要不痛不癢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……最重要的",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都不是這些。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也看見了吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那些貶低我的人，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那副生氣勃勃的表情。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當面貶低對方……",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當面被貶低……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這簡直就是",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "刀劍相向的",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愛意交歡啊☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n太令人激動了……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太熱血沸騰了！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……當然。",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，是的，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我才不是那種會因為負面評價而受傷的人。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的心情反而很愉悅呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……但這是怎麼回事呢？",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看見這小子滿心關切又沉重的表情，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "心裡居然",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有些內疚……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該不會──",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓小子陪我這麼嬉鬧，",
        "unit_id": 123811,
        "voice": "vo_adv_1238001_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
