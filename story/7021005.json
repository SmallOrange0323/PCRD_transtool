[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人在與一大群強大的魔物們戰鬥後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n露娜之塔的地板上堆滿了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被深月的毒藥所毒殺的魔物們。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這景象……",
        "unit_id": 103711,
        "voice": "vo_adv_7021005_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是壯觀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_7021005_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也很開心能夠蒐集到綽綽有餘的資料。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "魔物的遺體也得好好調查一番……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那個是什麼？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是塊很不可思議的石頭。",
        "unit_id": 103711,
        "voice": "vo_adv_7021005_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不同於塔的牆壁和地板，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且還淡淡地發著光……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……原來如此。",
        "unit_id": 105111,
        "voice": "vo_adv_7021005_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這是{player}在找尋的記憶線索吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這塊石頭上竟然有記憶的線索，",
        "unit_id": 103711,
        "voice": "vo_adv_7021005_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真令人難以置信……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "光突然變強了……！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好刺眼……！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就像我剛才所說的，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "希望你能來協助我探索\n間隔數十年後再次在山上被目擊到的植物。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而且在找到之前，我絕不放你回去，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你可要做好覺悟喔♪",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦～？",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這不是{player}嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然會在這裡遇到，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是巧啊。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳是……",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n{player}的朋友嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "初次見面。",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是御久間智。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為看到{player}和可疑的，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呃、不是，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和漂亮的人在一起而",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感到好奇，所以就來打聲招呼。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "剛剛",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好像有聽到她說了什麼可疑……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是我聽錯了嗎……？　",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原、",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來是這樣啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是宵濱深月。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n正在邀約{player}來幫我做研究。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦～",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "研究啊！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽起來很有趣呢！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也可以加入你們嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呃、",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "人手增加是幫了我一個大忙，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我完全不介意。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總、",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總覺得她好像話中帶刺，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我曾對她做過什麼嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們應該是第一次見面",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "吧？　",
        "unit_id": 105131
    },
    {
        "type": "background",
        "background": "510400"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來是要找尋\n不知道是不是真的存在的植物啊？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是在確定有這種植物的前提下來尋找的。",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "況且",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是以前理當曾經存在過的野生植物，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就算有也不足為奇。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為受到森林砍伐和外來種的影響，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一般認為\n它已在這一帶絕跡。不過，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果真能夠找到，將會是一大發現，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n得趕緊與地方政府合作展開保護活動。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來妳真的是研究者啊。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳會這樣說",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "，那妳原先是",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼看我的啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我聽到妳對{player}說：",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n「我絕不放你回去，你可要做好覺悟喔♪」",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n以為他是不是",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "碰到什麼麻煩事……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……！？",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是天大的誤會",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n。我的意思是說，在找到植物之前絕不會放他走。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不管怎樣，在我聽來，這種說法也是有問題的喔。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "從深月小姐的口吻",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以知道妳的確是個研究者。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我也會認真給予協助的",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n。因為得讓{player}能夠平安地回來呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請不要再捉弄大人了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就是喜歡捉弄人。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚嗚～！",
        "unit_id": 231,
        "voice": "vo_adv_7021005_027"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "好痛～！！！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "小孩子的哭聲？",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聲音是從那邊傳來的！",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們走吧！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103731,
        "voice": "vo_adv_7021005_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好、",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好的！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚",
        "unit_id": 231,
        "voice": "vo_adv_7021005_031"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗚～！！！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 1231,
        "voice": "vo_adv_7021005_032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "老公……！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n這該怎麼辦……！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "呃、",
        "unit_id": 1031,
        "voice": "vo_adv_7021005_033"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個……！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看你們好像遇到了麻煩，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一切還好嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這孩子被蜂螫傷了！",
        "unit_id": 1231,
        "voice": "vo_adv_7021005_035"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我、",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們完全不知道該怎麼幫她！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來如此，",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是蜂嗎？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不好意思，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請讓我看一下她的傷勢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "毒囊還留著……",
        "unit_id": 105131,
        "voice": "vo_adv_7021005_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣看來，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
