        "voice": "vo_adv_2012004_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n謝謝您的惠顧，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
