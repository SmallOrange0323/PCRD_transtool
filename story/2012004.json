        "type": "dialogue",
        "name": "香織",
        "words": "但別光顧講話停下手中動作囉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n排隊的客人可是排得越來越長了唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎唷喂，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這可不好了呀！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈呀～",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今年的客人比料想中還要更多呢～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就靠開小店攤販給它賣到發大財了吧～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "畢竟可以拿來當重建【伊麗莎白牧場】的資金，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n可說是謝天謝地了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……資金，",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還夠喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果需要的話可以去拜託秋乃，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓她從【墨丘利財團】那邊多要求一些援助的唷喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們已經接受她們很多幫助了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "託大家的福已經恢復到和原先差不多了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以目前還沒問題的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然如果又出現問題的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還得再麻煩妳們了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不論何時都歡迎妳們唷喵！",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "【墨丘利財團】，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是站在需要幫忙的人和金錢這邊的呀喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "吶吶，",
        "unit_id": 101711,
        "voice": "vo_adv_2012004_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那邊那個乳牛裝的姐姐是牧場的人嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在牧場那也有送了幾個",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "【哞哞自衛隊】的夥伴過去了嘛，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家都過得還好嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然栞常會寄信回來，",
        "unit_id": 101711,
        "voice": "vo_adv_2012004_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但鈴就常常偷懶，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我們也還不是很清楚狀況的呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "前陣子還發生了大事故嘛，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們的人也很在意",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家的安危呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說來妳是【哞哞自衛隊】的人嘛……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "托老天的福，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞和鈴鈴都沒事唷，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n最近也一直在幫大家一起忙著",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場或是重建的工作呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是再怎麼說也是身心俱疲了嘛，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n所以害得栞栞她身體不太舒服，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而大家都留在牧場輪流照顧她。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n也因為無法參加祭典，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看起來好像很遺憾。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那還真是可憐呢～",
        "unit_id": 101711,
        "voice": "vo_adv_2012004_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "請她要保重呀……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n其實是我們警備人手有些不夠，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以才想說如果她們有來的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還希望讓她們也可以幫點忙的嘛～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟人潮這麼誇張喵～",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然有更多的商機，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "生意興隆當然是再好不過了喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但光是計算收入的份量就夠恐怖了，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "美冬倒是笑到合不攏嘴了喵。",
        "unit_id": 104611
    }
]