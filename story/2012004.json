        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈。",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來這陣子還挺認真在工作的嘛，",
        "unit_id": 103311
