    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼～",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總算是想辦法糊弄過去了喵……！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n義賊還真不好當呀喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不能在光天化日下閒逛，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只能偷偷摸摸在暗處前進喵？　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸等下小希希，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳再發愣下去鯛魚燒就要烤焦了唷？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哇喵～！？　",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這可不妙，",
