        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "身為【哞哞自衛隊】的一員，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "祭典會場警備可是我的工作呀～！",
        "unit_id": 101711
