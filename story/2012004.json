    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "用火要小心呀喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "若是把鯛魚燒給烤焦，將會是恥辱呀喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n浪費食材的話，",
        "unit_id": 104611
    },
