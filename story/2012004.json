        "voice": "vo_adv_2012004_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過嘛，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟也沒有其他的叫法可以選擇了喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n小珠珠……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聽起來有點不太妙喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔呣，",
        "unit_id": 103311,
        "voice": "vo_adv_2012004_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果是笑人家名字，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "或講黃色笑話來逗別人笑，就有點不上道了啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n小希希對搞笑好像也挺懂的嘛，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要不要和我搭擋看看呀？",
