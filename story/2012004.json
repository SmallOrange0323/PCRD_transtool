    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵？　",
        "unit_id": 104611,
        "voice": "vo_adv_2012004_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然我也覺得能把人逗笑是件很棒的事情，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但最近還真是有點忙啊喵～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "人家呀，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不論白天黑夜可都是很忙的呀喵。",
        "unit_id": 104611
    },
