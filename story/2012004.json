        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈哈哈！",
        "unit_id": 101711,
        "voice": "vo_adv_2012004_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然聽不懂妳們在講什麼，",
        "unit_id": 101711
    },
