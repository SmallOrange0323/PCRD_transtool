[
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】的成員，\n抽獎獲得『迷人的南國旅行招待券』的隔天。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是夠了！",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "工作、工作、工作！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直工作壓力越來越大，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺都要禿頭了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔……",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，得加油才行。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要和【美食殿堂】的大家一起去的什麼『迷人的南國旅行』，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是四天三夜的行程啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是我，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是個忙翻天的公務員……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可能一下子就請假那麼多天啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要提前做完四天份，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不然至少也希望能做好兩天份的工作。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要能先處理完兩天份的工作……",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "第一天就直接從職場出發去海邊，到當地跟他們會合，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最後一天再從海邊直接回到職場工作，就總會有辦法了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的工作不是能找人替我接手的內容，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不能讓那四天的工作都開天窗啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n否則會被「陛下」罵的～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最糟還有可能被處罰到要人命呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "光是想像就讓人不寒而慄……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是其他人都要到海邊快樂玩耍，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我無法忍受只有我一個人不能參加啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能和氣味相投的夥伴去海水浴，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺就超開心的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對這種事",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也有點嚮往呢～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對絕對",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要參加！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為了這個要",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一工作，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "二工作，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "三四還是工作，五也是工作！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "加油吧……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔呀！？",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嚇死人了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以不要突然出聲嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n小心我宰了你喔……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，奇怪？",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！晚安！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在這種地方",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做什麼啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼嗯～",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你打工完正要回家啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你說走這條路比較近？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這附近警備森嚴，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你如果隨便亂晃，可是會被帶走的喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，算了……",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正要走哪裡，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是你的自由。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然變得這麼恭敬……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你平常都是故意來嚇我的吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我被嚇到慌慌張張的，有這麼有趣嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵。",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也感覺很抱歉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你明明只是來找我說話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我卻反應過度了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在「王宮」被當作燙手山芋對待，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以不怎麼會有人親切地來找我說話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果突然被叫住，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的會讓人嚇一跳。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們不會有顧慮，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "願意輕鬆地來找我說話，我很開心。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開玩笑的啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就像是個沒朋友的陰暗傢伙呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你難得很關心我耶……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我沒什麼精神。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為很累了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連要陪你我都嫌麻煩。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵。",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正{player}對我來說怎樣都無～所謂……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我很忙的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我現在打算回「王宮」內的職場繼續加班。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為此，我才來鬧區吃晚飯，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "順便買宵夜的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在正要回去～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "甚至暫時不會回家，要埋頭工作。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該說是時期嗎……",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得最近",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蘭德索爾週邊開始頻繁發生怪異的事。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像是出現新種魔物，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是發生無法解釋的怪異現象。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這附近的瑪爾傑海岸，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也好像發生了漁獲量驟減，以及海中的魔物失控的問題。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要去的地方是南國的海邊，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以應該沒什麼關係吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是也不能不處理，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這麼置之不理對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像是要聯絡政府機關，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是擬訂對策……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每當這種時候，就會有大量的文件，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n光是確認文件就是個大工程了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是負責類似秘書的工作，",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以都是處理這些文書工作。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "單純是量就非常驚人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺都快被文件堆成的山給活埋了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過……",
        "unit_id": 106012,
        "voice": "vo_adv_1078001_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是打算在「迷人的南國旅行」當天前，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想辦法把工作大致都打理好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
