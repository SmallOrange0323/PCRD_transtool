[
    {
        "type": "background",
        "background": "502330"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳不熱嗎？",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還真突然呢……",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小涅比亞，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳理解自己現在正在被人追趕嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我當然知道啦。",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但妳看，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我的天性就是無法讓在意的事只停在在意的階段而置之不理呢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "天性啊……",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "借那個詞一用的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我會像這樣身穿鎧甲也是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "類似於天性喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以，",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "會熱嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………這",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我算是不否認。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "原來如此呢～♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那那身鎧甲",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就由我幫妳脫下來！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊？",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別這樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "展開環境系統！",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我按～♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這、",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "暴風！？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是要把鎧甲剝下來嗎……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但這種程度的風暴，",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對於因訓練而徹底鍛鍊過的我而言是不管用的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我一天二十四小時穿著鎧甲，可不是白穿的……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳知道《北風與太陽》嗎？",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "知道的吧？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該不會……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我按～♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好燙",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是熱，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而是燙……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n鎧甲",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在發燙……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好了好了，",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要是不趕快脫下來，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就要被鎧甲燒成煎蛋了喔～♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……唔，",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好燙……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n地獄之盾！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什……",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "撐住了嗎！？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看好了，",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這就是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】團長的驕傲……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還真了不起呢……",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是我輸了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "作為賠罪，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我來讓妳涼快一下。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔哇……",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好涼……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身體好涼爽……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真舒服呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "──嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這水",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "滑溜溜的……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等一下，小涅比亞？",
        "unit_id": 104711,
        "voice": "vo_adv_5150066_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳在我身上施加了什麼？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身體",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "滑溜溜的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "鎧甲要──！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150066_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n中招了呢！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n很舒服吧？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "滑溜溜的史萊姆果凍♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好、",
        "unit_id": 113611,
        "voice": "vo_adv_5150066_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好過分……！",
        "unit_id": 113611
    }
]