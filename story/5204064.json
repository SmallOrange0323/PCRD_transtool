        "name": "旁白",
        "words": "就這樣，少女們在奇蹟的引領下相遇了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n總有一天她們會作為監督、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "製作人、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "腳本家，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n攜手製作動畫，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但那是遙遠未來的事了。"
