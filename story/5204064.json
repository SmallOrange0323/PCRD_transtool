        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "大家都喜歡神巴哈，",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "所以我們做朋友吧！！",
