    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成為了森林守衛正式成員的碧，\n在精靈之森擔任導遊的工作。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這裡是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_5023000_001"
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "妳看妳看～！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "\n這隻蝴蝶，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "沒有出現在城鎮裡吧！？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "真的耶～",
        "unit_id": 411,
        "voice": "vo_adv_5023000_002"
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "顏色也好怪～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "導遊小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "這個叫什麼名字？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，那那、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_5023000_004"
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "這裡長了一個好奇怪的東西～！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "精靈之森，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "真有趣～！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "對呀～！",
        "unit_id": 411,
        "voice": "vo_adv_5023000_005"
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "\n導遊小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "我們接下來要去哪裡？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "接、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "接下來……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔……",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "採集",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或照顧植物的工作就算了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我怎麼會擔任導遊的工作……！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好、",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好想逃走……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "嗯？　",
        "unit_id": 1211,
        "voice": "vo_adv_5023000_009"
    },
    {
        "type": "dialogue",
        "name": "指引客1",
        "words": "這是什麼草……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "！　",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不可以，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是曼德拉草……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n一拔起來就會發出很大的叫聲――",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "妳、",
        "unit_id": 411,
        "voice": "vo_adv_5023000_011"
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "妳沒事吧導遊小姐！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "對不起～",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "指引客2",
        "words": "我們玩得太瘋了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不要緊",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "的……！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "歡迎回家，",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小碧。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "導遊的工作如何？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這對我來說還是太……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "會嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "剛剛的客人",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說她很感謝小碧妳喔？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……是，",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像我這樣不擅長和人交談的人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "做導遊實在是不太……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是嗎？　",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯～……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來還是必須",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要讓妳習慣",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在人前說話……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小碧。",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n妳知道聖德蕾莎女學院嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是有聽過……",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是城鎮裡的學校",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯吧？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯。",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他們向",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "【森林守衛】",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "提出一項申請。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為了要促進與【森林守衛】的交流，",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就算短期入學也沒關係，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他們希望我們能",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "安排一個女孩插班入學。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……？",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "然後",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望我們能運用精靈族的知識，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在學院舉辦特別講座。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……呃，",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難不成？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以，我打算讓小碧，",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n妳去聖德蕾莎女學院",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "上學〜！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦咦咦咦咦咦咦咦咦咦咦咦咦我辦不到！",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不行，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不行不行不行！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是辦不到之助先生！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是這樣嗎？　",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我覺得這是一個很好的機會。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n為了能讓小碧妳",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "稍微地",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "鼓起勇氣。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒問題的。",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小碧妳是個好孩子，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "妳一定作得到的。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是制服，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "學校簡介，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有課本一套。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小碧妳",
        "unit_id": 101511,
        "voice": "vo_adv_5023000_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一定沒問題的，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我相信妳。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "加油！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、不、",
        "unit_id": 104011,
        "voice": "vo_adv_5023000_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不不……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不行……",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "等、等等……！",
        "unit_id": 110711,
        "voice": "vo_adv_5023000_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不行啦啊啊啊啊啊啊啊啊啊！",
        "unit_id": 110711,
        "voice": "vo_adv_5023000_032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "小碧因確定插班進入聖德蕾莎女學院就讀而發出的慘叫，\n一點也不輸曼德拉草的叫聲。"
    }
]