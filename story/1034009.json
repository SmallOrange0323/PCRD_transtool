    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺就會鬆懈。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為被{player}那個……",
