        "type": "dialogue",
        "name": "道具店",
        "words": "會有一段時間暫時無法行動……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是那這樣嗎！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對不起，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都是我的錯……！",
