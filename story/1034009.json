    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "整個人都搖搖晃晃了。",
        "unit_id": 1411
    },
