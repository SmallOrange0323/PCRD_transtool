    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "臉、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "臉太近了臉太近了",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "臉太近了……！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "道具店",
        "words": "那邊的客人",
