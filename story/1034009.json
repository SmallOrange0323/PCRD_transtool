        "voice": "vo_adv_1034009_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是為了保護我……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔、",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒想到",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你竟然會挺身來保護我……",
        "unit_id": 103411
