        "voice": "vo_adv_1034009_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "全部都給看光光了啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我失態的一面。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵。",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來繼續，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "把嘴張開。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好好幫你呼呼――地吹冷的♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難道是害羞了？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過還是請你忍耐，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要是用左手會灑的到處都是。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "小心別燙到囉。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嘴邊都髒了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我來幫你擦乾淨。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這麼說來，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖說是不自覺這麼做的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但這樣",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_034"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就等於是我不僅把他給帶回家，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且還要照料他生活上各種事耶？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該該該、",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_035"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該怎麼辦？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣簡直就像是……！？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "冷、",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_036"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "冷靜下來，優花梨。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這是我給人家造成的麻煩啊……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說你啊，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_037"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺真是超級冷靜耶？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n姐姐我明明都慌張成這樣了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "習慣了？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n習慣被人餵？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……也習慣被人照顧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難道說這種事，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是每個人都習以為常的事情……？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_040"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過……",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_041"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要再次向你道歉。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我竟然會喝過頭造成{player}的麻煩，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_042"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我真是個失職的姐姐……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔～",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_043"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你又說出這麼善解人意的話！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是不行！　",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_044"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就這次",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我沒辦法原諒自己！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以我……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "決定了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我――",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_045"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要戒掉麥酒！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_046"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你那是什麼反應！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你是不是一臉絕對不可能的表情啊！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_047"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我絕對會戒掉的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這次，我",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_048"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "優花梨要",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "禁掉麥酒……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似乎有點太長了呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "禁麥",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺不太對呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那就……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "禁酒！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我――",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_049"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要禁酒！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨的禁酒宣言，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在寂靜的夜裡高聲回響。"
    }
]