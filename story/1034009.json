    },
    {
        "type": "dialogue",
        "name": "道具店",
        "words": "要緊的是那個人！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "道具店",
        "words": "\n他保護妳的時候，",
        "unit_id": 311
