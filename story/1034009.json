        "type": "dialogue",
        "name": "店長",
        "words": "拜託妳可別給其他客人造成麻煩喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1034009_007"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這裡也有在談道具生意的人啊。",
        "unit_id": 1411
