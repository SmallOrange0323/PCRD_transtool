        "voice": "vo_adv_1034009_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呀～！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嗯，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "痛痛…",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n{player}，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你為什麼會撐在我身上……？",
