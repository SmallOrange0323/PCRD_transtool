        "voice": "vo_adv_1034009_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我平常都是這樣的――",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊喵？",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_009"
    },
