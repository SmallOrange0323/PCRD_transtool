        "voice": "vo_adv_1034009_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n手不方便的地方，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓我來照顧你吧？",
        "unit_id": 103411
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊～。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如何，",
        "unit_id": 103411,
        "voice": "vo_adv_1034009_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好吃嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為給店家造成麻煩覺得很不好意思，",
