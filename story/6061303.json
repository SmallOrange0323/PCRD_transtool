[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主的課程，",
        "unit_id": 115911,
        "voice": "vo_adv_6061303_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我只有偷偷去看過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但感覺相當獨特呢……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "該說真不愧是公主嗎。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔喔，",
        "unit_id": 115911,
        "voice": "vo_adv_6061303_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也學得不錯嘛。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真了不起。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像那種很不可思議的教學方法，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然還是有辦法讓大家都學會，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n公主果然不是等閒之輩。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在說什麼啊。",
        "unit_id": 115911,
        "voice": "vo_adv_6061303_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也是來當講師的。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話雖如此，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我對於那個步行術倒是稍微有點興趣。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "或許可以運用在戰鬥上也說不定，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之後再請她教我一下好了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂，",
        "unit_id": 115911,
        "voice": "vo_adv_6061303_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "課程已經結束囉？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "已經變成口頭禪了？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只是上堂禮儀的課，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就可以讓人真步真步化……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主也太可怕了。",
        "unit_id": 115911
    }
]