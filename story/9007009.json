[
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜和祈梨正在帕菲之城的城前廣場上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與5.5周年的魔物對峙中。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊！",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "5.5～！",
        "unit_id": 1611,
        "voice": "vo_adv_9007009_001"
    },
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈哈！",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "太窩囊了啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拿出更多鬥志來──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊！！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "5",
        "unit_id": 1611,
        "voice": "vo_adv_9007009_003"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": ".",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "5……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀、",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n魔物都陷進牆壁裡了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n嘉夜夜",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "完全進入打手模式了～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒那回事啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我只是讓它變得安分點而已。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳看！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "確實抓到它了啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟這隻魔物的精力莫名地旺盛，",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "能抓到它是很好。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是嘉夜夜，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳不會也點太過鬥志高昂了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "聽妳這麼一點，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像真的有？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n可能是因為好久沒打得這麼爽快了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟最近都沒打架啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說得也是……",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟自從來到這個世界後，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就沒遇到什麼好事情啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "尤其是前陣子那件事！",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n沒想到會被龍人族的同族給抓住，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還被迫穿上超變態的女僕裝來打掃！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那件事我們也有錯啊……",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳已經清楚知道那並不是超變態女僕裝了吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過……",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也不想",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n再做那種難為情的打扮了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜也一樣覺得很難為情不是嗎──！",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那果然是超變態女僕裝！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的。",
        "unit_id": 1,
        "voice": "vo_adv_9007009_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n麻煩妳們別再胡言亂語了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸？",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個聲音是……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我可不允許妳們侮辱",
        "unit_id": 127712,
        "voice": "vo_adv_9007009_015"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n萊拉耶爾殿下準備的女僕裝。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊！",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我記得妳是……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "烏爾姆？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我是琳德。",
        "unit_id": 127712,
        "voice": "vo_adv_9007009_017"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "雖說是雙胞胎，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n但居然把我和那個儀容不整的妹妹認錯，太讓人傷心了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳們好，",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_018"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我是儀容不整的妹妹。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈……",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們還是老樣子呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天怎麼了？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們也來捕捉魔物的嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……唔。",
        "unit_id": 127712,
        "voice": "vo_adv_9007009_020"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_021"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "個……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n琳德好像心情不太好……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎怎、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎樣！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳們該不會",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又對我們有什麼意見吧～！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "被妳說對了，",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_024"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "就是那樣。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳們看，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那邊的城牆。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "城牆～？",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才嘉夜夜把魔物打飛，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n把牆壁撞破了一個洞，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那有怎樣了──",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_9007009_026"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "總算察覺到了？",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_027"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n如果多了一個這麼大的入口，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "感覺會讓守衛的工作倍增呢。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的……！",
        "unit_id": 127712,
        "voice": "vo_adv_9007009_028"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n妳們光是把城內搞得亂七八糟還不夠，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "竟然還學不會教訓嗎！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106611,
        "voice": "vo_adv_9007009_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這不是故意的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是嘉夜夜打架打得太開心，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有～點鬧過頭了而已！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔、",
        "unit_id": 106511,
        "voice": "vo_adv_9007009_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔唔……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "藉口太爛了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n完全沒有可以辯解的餘地……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的很抱歉！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……她們是這樣說的，姊姊。",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_031"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不過",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "她們也沒有惡意吧？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "就算如此，",
        "unit_id": 127712,
        "voice": "vo_adv_9007009_032"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也不能輕易原諒妳們。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n再讓妳們好好反省一次吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n作為懲罰……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我要妳們再幫忙打掃一次！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "要收拾被破壞的牆壁，",
        "unit_id": 127812,
        "voice": "vo_adv_9007009_033"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "感覺會很不容易呢。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "總之，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我去把兩位的女僕裝拿過來～",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "咦咦咦～～～！？",
        "unit_id": 1,
        "voice": "vo_adv_9007009_034"
    }
]