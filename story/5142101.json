[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽好了，",
        "unit_id": 129811,
        "voice": "vo_adv_5142101_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這裡是【王宮騎士團】的新兵訓練所！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳接下來將以教官的身分就任，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要好好指導新兵啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我明白的，",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也在以自己的方式",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "學習如何擔任一名教官。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "首先，這些新兵們都是明明超弱卻滿懷抱負，",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n什麼都辦不到",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只會在地上爬的一群豬隻吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在經過一遍一遍又一遍的嚴厲訓練後……",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓他們成為能拿著劍戰鬥的豬。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就是我們的使命……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔、",
        "unit_id": 129811,
        "voice": "vo_adv_5142101_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔～嗯……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n感覺好像是沒錯，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然好像感覺不太對但是沒有錯……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就先不管說法的部分了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那真是太好了。",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們就來嚴格地進行吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，各位新兵……",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我個人為了滿足自身野望，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所帶領的基礎訓練即將開始。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然，",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你們沒有拒絕的權利。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "回答只有",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「是」或是「Yes」……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又或者是",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "兩者一起♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻嘻……♪",
        "unit_id": 129911,
        "voice": "vo_adv_5142101_008"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5142101_009"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「冷酷・火爆・新兵訓練營　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "魔鬼教官和鞭子與……糖果？」",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～",
        "unit_id": 129811,
        "voice": "vo_adv_5142101_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的沒有問題嗎？",
        "unit_id": 129811
    }
]