[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請別亂動。",
        "unit_id": 103812,
        "voice": "vo_adv_1038004_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你一動，我就會發射弓箭。",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊，",
        "unit_id": 103812,
        "voice": "vo_adv_1038004_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}？",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣弓矢相向，真對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最近……",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有些穿著打扮很少見的人在這附近的山林走動，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我們有稍微加強戒備。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我負責這座【伊麗莎白牧場】的警備。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "本來我是在這裡靜養的，但是沒事做也很無聊。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "受到她們諸多照顧，我也想報答這份恩惠。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "先不說這些了。\n",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請問你來【伊麗莎白牧場】有什麼事嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你是在散步，偶然地……走到這裡來的嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣呀。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是辛苦你了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以的話，請你下次來時從正門進來。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為你跨越柵欄進來，我還以為你是魔物或山賊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "話說回來，",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你還是走有好好鋪整過的道路比較好喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這邊的路面凹凸不平，你要是跌倒了會滾到山坡下的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣你可是會受重傷喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然牧場裡也有療養所，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要沒死的話還是有得救的機會。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "儘管如此，還是請你要小心點。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，對不起。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的年紀比較小，還這樣擺架子……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，我很擔心你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊？",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請、請你不要摸我的頭……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我是不討厭這樣，只是好癢喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你是覺得我的耳朵很稀奇吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我姊姊也會說「我好喜歡妳這麼蓬鬆柔軟的樣子～」",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n每次見到我就會摸我的耳朵跟尾巴喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有個姊姊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n她住在附近森林裡的",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "精靈族聚落裡。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的父親是獸人，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "母親是精靈族，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為遺傳的關係，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們明明",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是姊妹卻生成不同的種族。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我是獸人，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊是精靈族。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我和姊姊到底有沒有血緣關係……",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之類的事。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n從我還很小的時候，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就開始常常在意了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是就算我們沒有血緣關係、種族不同……",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我還是最喜歡姊姊了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不管發生什麼事，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唯獨這點不會是假的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你是不是在發光？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是什麼，好刺眼！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "猜猜我～是誰……？",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_021"
    },
    {
        "type": "background",
        "background": "510260"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n沒錯，就是我。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}，你好。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，我是柏崎栞。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你不知道嗎，我在這裡住院喔。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "難得會在醫院見到你呢。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你怎麼了，身體不舒服嗎。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真令人擔心。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你是因為覺得好像有點感冒了，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n保險起見來看個醫生是吧。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，初期治療很重要。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請你要保重身體喔，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好乖好乖……♪",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦、咦？",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你為什麼稍微退開了……？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，是我表現得太親近了嗎？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……你說要是把感冒傳染給我就糟了？",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟我的免疫力很弱呢。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你的顧慮，不過這樣我會覺得有點寂寞♪",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說我比平常還要亢奮？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，你說得沒錯。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我今天覺得心情還不錯。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你覺得是為什麼呢？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "答～錯了。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的生日在十一月，還要過一陣子呢。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，你說要辦慶生派對……？",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，那個，我是很開心啦。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是那時候我大概還在住院，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在醫院吵鬧會給院方添麻煩的。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要能像這樣，偶爾和你見面聊天……",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就覺得很幸福了。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對的，非常接近正確答案。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "接下來會有好事發生呢。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿嘿。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n其實是我的姊姊等一下會來探病。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我記得，\n你好像也認識姊姊吧。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我長期住院，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以她偶爾會帶換洗衣物等各種必須物品來。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊都會趁著送東西過來的機會，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一直陪我聊天。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我非常期待這樣的時刻……♪",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒怎麼去上學，也沒有朋友。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我與醫院外的聯繫，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n幾乎都是依靠姊姊。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊她替我",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n打開通往「醫院外面」這個異世界的門……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對我而言，是這世界上最棒的魔法師。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然姊姊也有自己的生活要過，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n讓她常常來探病會讓我感到抱歉呢。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，我果然還是覺得很開心。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿嘿。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}如果願意的話，待會要不要加入我們？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "與你一起分享幸福……♪",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？你說你不想打擾我們姐妹相聚，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_045"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且要是把感冒傳染給我們就糟糕了……？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "其實你不用這麼顧忌的。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，姊姊來了。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_046"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總覺得她好像閉著眼睛在走路，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n她那樣子是清醒的嗎……？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊真是的，不論何時都讓人放不下心。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "話說回來，",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你如果願意的話只跟姊姊打個招呼也好。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊一定也會非常開心的。",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_049"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為她是一個能坦率地喜歡別人的人。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喂～姊姊！",
        "unit_id": 103832,
        "voice": "vo_adv_1038004_050"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這邊喔，我在這裡喔！",
        "unit_id": 103832
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說到栞的姐姐，",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該是指初音吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說是將姐妹種族的不同歸因於父母種族不同，",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過這個理由總覺得是勉強編出來的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好在唯獨她們的姐妹關係是個不變的事實。",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n誰叫她們姐妹倆的感情這麼好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，抱歉。",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不小心就開始自言自語了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為同樣的事情要不斷重複解釋，",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也開始覺得麻煩了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，這是我的使命。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正我想你醒來後就會忘得差不多的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想接下來我還會不斷地",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像這樣讓你做不可思議的夢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我說再多也沒用，你就做好心裡準備吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，這次就先這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1038004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊，你醒來了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "早安。",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為你突然就睡著了，害我嚇了一跳。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_060"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過我姊姊也是個在哪裡都能睡的人……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我好像已經習慣這種事了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你一定是每天工作太疲勞了吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_061"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果沒有很要緊的事，就請你繼續休息吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你就安穩地、好好地休息。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，好的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_062"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的大腿借你躺。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也不能讓你睡在荒郊野外，",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且憑我的臂力也很難搬得動你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，覺得舒服嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的大腿也頗受姊姊好評喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，{player}？",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "難道又睡著了嗎……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好乖、好乖。",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請你慢慢地休息吧，{player}。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，總覺得這樣好平靜啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038004_067"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然由我這樣說很不吉利，但這樣就好像在天堂呢。",
        "unit_id": 103811
    }
]