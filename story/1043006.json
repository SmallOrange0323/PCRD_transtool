[
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好～囉，大部分都清理完了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "清掃垃圾，結束～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～{player}基本上派不上用場，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還得同時教你很多東西……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以花了不少時間呢，太陽完全下山了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過算了。一個人安靜地工作也很無聊，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "邊和{player}聊天，也能讓我開心完成工作呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以說，謝謝啦～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了，竟然打起瞌睡……",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你累了啊，真是沒什麼體力呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n多鍛練身體吧，很不像話哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n現在想想你到城鎮外頭做什麼……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是為了鍛練身體嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是搞不懂你呢，在城鎮裡也能夠鍛練吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n健身之類的～或是去附近的道場接受指導？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不用特地跑到城鎮外面也行吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你是來慢跑的嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n到處都有魔物在出沒，很危險哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n來打倒弱小的魔物，賺經驗值？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼是經驗值啊……",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然沒有比實戰更好的訓練，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過還是有既安全又可鍛練身體的方法對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，真～的腦袋空空呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要說你少根筋，更像是從遙遠的世界來的一樣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真是個怪傢伙。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你不介意的話，就由我來幫你特訓吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你的武器就是繫在腰上的那把劍對吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也是劍士，說不定能夠指點你？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，我會的應該說是打架吧……",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我沒去過什麼道場學劍術，幾乎都是自學的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該怎麼指導，我也不清楚就是了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，就連握劍的方式都很奇怪。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那樣握的話，劍很容易鬆開哦……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我能教你那方面的基礎招式，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而且有個練習對象比較好對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "反正啊，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n回收垃圾袋的人員到這裡之前我都很閒呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n也能當作你幫忙我工作的回禮對吧，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如何？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。我的工作就是從收集垃圾到裝進袋子裡為止。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n回收是其他公會負責的哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這麼大量的垃圾袋，也不可能只靠我一個人搬到垃圾處理場。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒錯沒錯，在對面那座山的附近有垃圾處理場。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n有專門負責的公會常駐在那裡，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n用魔法燒掉垃圾或是掩埋到土裡處理掉。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "他們專門負責處理垃圾，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而回收垃圾則是委託其他公會哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們【哞哞自衛隊】，\n就是接受那個回收垃圾的公會的委託，才來撿垃圾的。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然要是拜託「公主」的話，這點程度的垃圾，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n她用魔法就能全部處理掉就是了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但我不太想讓她接近垃圾和髒東西呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一個公會什麼都不做，也不和其他公會並肩處理事情，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣是不行的呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然在城鎮裡生活，就不能只顧自己獨自生存哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們獸人在蘭德索爾算是少數派，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就更不能因為這樣就有排外的想法對吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也想要和你一起好好相處哦……",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為了加深感情，我們來玩玩擊劍遊戲吧～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只是稍微訓練一下哦，你去撿那邊的木棍吧？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來吧，隨便你怎麼打！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "首先呢，得看清你的實力是什麼程度。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好啦來吧，不必多慮！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n努力變強，爭口氣給我瞧瞧吧♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很～好很好，就是這個氣勢！",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不錯哦，你肯做就辦得到不是嗎！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "把木棍好好握緊，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是不認真可是會受傷哦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n怎麼了，可不要呆站在那裡哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "把我當作是你雙親的仇人！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒辦法拿木棍朝女孩子打過來嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n笨～蛋，在戰場上都是善良的傢伙先死的哦……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……怎麼啦，那種畏畏縮縮的樣子？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你有幹勁嗎？你想要變強對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那就拿出全力來啊，抱著殺了我的氣勢放馬過來吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊啊，受傷的地方會痛嗎……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉抱歉，我完全忘記你受傷了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那就別勉強啦，今天的指導就到此為止。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n辛苦了～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你的傷痊癒後，我會再當你的對手的。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n今天就先回去好好靜養吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不好意思呢，我一開心腦袋裡就會忘掉很多事情～♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你受傷的地方，再讓我看看。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，真是抱歉，傷口又裂開了呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，不過這種程度只要抹點口水就能治好了吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要我替你舔嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……開玩笑的啦，我的獸性還沒到那種地步。",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不過聽完玩笑笑一笑，疼痛也飛走了對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說，{player}……",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝你啦，今天真的很開心。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要被麻煩又無聊的工作毀掉這一天，",
        "unit_id": 104311,
        "voice": "vo_adv_1043006_039"
    },
    {
