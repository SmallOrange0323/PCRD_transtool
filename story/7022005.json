    {
        "type": "dialogue",
        "name": "七七香",
        "words": "清理",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "完畢",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "☆",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好厲害！",
        "unit_id": 101211,
        "voice": "vo_adv_7022005_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "竟然在一瞬間就解決了那麼多的魔物！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然我照著小七七香說的做了，但沒有很懂，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那是什麼魔法呀？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸嘿嘿～",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我試著",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "活用了之前",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n初音美眉施展出的轉移魔法喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就不解釋得太詳細了，",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n簡單來說感覺就像是，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "把魔物軀體的一部分",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和其他物品交換的魔法吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但因為我一個人無法妥善控制，",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以這魔法離完成還差得遠，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但總之，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有成功真是太好了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為太大的東西我無法操控，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以只有將",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "路邊的小石頭",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一點點地進行轉移而已唷。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光是這樣，就有那麼大的威力，",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是不得了的魔法呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "以創造新魔法的靈感來說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "目前發現的結果應該已經足夠了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是，",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和你的記憶相關的線索，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "卻還沒有找到呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這件事也該來……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀呀？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n地上好像有一顆奇怪的石頭呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是不小心",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從其他地方轉移過來的嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔～嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來操控技術還要多加強呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 101211,
        "voice": "vo_adv_7022005_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這石頭會閃閃發光，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好漂亮呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "著實如此哪～",
        "unit_id": 101311,
        "voice": "vo_adv_7022005_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼回事！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n光是不是越變越強了！？",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿咻，",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好了。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真的放在這邊就可以了嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是啊，",
        "unit_id": 1,
        "voice": "vo_adv_7022005_012"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這裡就是我家，這樣就好囉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n不過話說回來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "小姑娘妳還真有力氣啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n如此重的東西，瞧妳搬得這麼輕鬆。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我可能算是",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "比一般人來得有力氣沒錯啦～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "糟糕，",
        "unit_id": 1,
        "voice": "vo_adv_7022005_014"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這樣對女孩子說，是不是有點失禮啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n妳真的幫了很大的忙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "謝謝啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n那麼先失陪了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "多保重喔～",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼。",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是不是有點",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一口氣搬太多了呀～？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那點小事，不用太在意啦～",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過由於得抑制住超能力的力道，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結果似乎反而更累了呢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可能是抑制力量產生的反作用吧～",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過既然這裡只有你在，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "稍微飄個一下下……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什、",
        "unit_id": 1,
        "voice": "vo_adv_7022005_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼～～～～！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有女孩子飄在空中！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n好厲害！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "完全重現了魔法少女驚奇甜心的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "初次變身場景！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇哇哇……！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才她確實看起來是飄在空中啊……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "錯覺嗎？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}也在呀！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我剛才太驚訝，沒發現到你啊。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是你認識的人呀？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之就是，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才妳的狀況，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n乍看之下很像過往",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "某部魔法少女動畫名作的其中一幕，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我才忍不住變得很激動啦。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然嚇到妳了，",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱歉喔。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳剛才確實是",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "飄在空中吧？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸、",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃～～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼說，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那是～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n意思是初音美眉",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也是熱愛魔法少女的同好囉？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n應該算、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是吧？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真沒想到",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以在同年齡層中發現夥伴。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要說的話不朽名作",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鐵定是能擄獲各種年齡層粉絲的啦！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這下正好。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "目前",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "電影院正在播映動畫電影的重新剪輯版本。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n要不要一起去看呀？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "動、",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "動畫電影？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "重新剪輯？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟小七七香",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看起來相當期待呢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我也有點想去看看了。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就一起去看吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太好了！",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該朝電影院",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "進軍囉！",
        "unit_id": 101331
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "…………",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚、",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚嗚……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔嗚……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這部電影看幾次都很棒啊。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n好不容易互通心意的兩人，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在戰鬥結束後，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "卻面臨",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "超越時空的別離……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "故事結尾仍有留下再次相會的希望……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "…………",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉唷～",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "得回去重新複習動畫啦！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳怎麼變得那麼安靜呀？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莫、",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_038"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "莫非",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳不喜歡重剪版的新繪製畫面嗎！？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然原本",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "舊版的豪邁筆觸確實令人印象深刻，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但這次修改過的畫面",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也是別有一番風味……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真～～",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "的好好看喔！！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我還是第一次在電影院發出那麼大的喊聲！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟這次",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正好買到應援場的票嘛。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "多年粉絲們一起",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大聲加油的光景，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可是和單純欣賞電影有著不同的樂趣喔。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且，",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "勁敵角色的那個女孩，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "實際上竟然不會用魔法，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而是使用超能力……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉？",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒什麼啦！",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我看得",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很開心唷！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣呀～",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_044"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "見到妳滿意真是太好了。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們就準備來享受看完電影後的樂趣吧。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是還有什麼活動嗎？",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_045"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那當然。",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "身為阿宅，這可是基本。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那就是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "回家路上的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感想大會！！",
        "unit_id": 101331
    },
    {
        "type": "background",
        "background": "510361"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就在此時，",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_047"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "時空產生了扭曲，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n而兩人必須兵分兩路才能修復時空……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對對對。",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_048"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然一開始是主角打算到時空的另一頭，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但勁敵角色的女孩卻把她推開……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果妳消失，會有很多人傷心吧。",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_049"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我的話……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就不會有了。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒有那回事！",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_050"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳消失的話，我會很傷心呀！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後勁敵就開口回道……",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_051"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "儘管我的人生充滿謊言，",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不是騙人就是被騙，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但最後總算是得到了",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真實的羈絆。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣我就已經",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很滿足了……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯沒錯！",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這時候",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "角色臉上的表情似哭又似笑，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "表現得恰到好處……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "…………",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_054"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其實對小七七香",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說了謊。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……？",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_056"
    },
    {
        "type": "still",
        "still": "702200501"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_057"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其實是個",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "超能力者！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳、",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳說什麼！？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現、",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在這是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為我",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_059"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不想對",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "朋友說謊……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n之前小七七香看到的狀況確實是……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是原本動畫的電視播映版有，",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_060"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但在電影中卻被改掉的那一幕！！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來如此，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是想要自己演出，來完美重現該場面對吧！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在下",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然願意奉陪！",
        "unit_id": 101331
    },
    {
        "type": "still",
        "still": "702200502"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳無須再多說了。",
        "unit_id": 101331,
        "voice": "vo_adv_7022005_061"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n比起眼淚，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "祕密更能襯托女人的美，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是嗎？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃、",
        "unit_id": 101231,
        "voice": "vo_adv_7022005_062"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不是那樣的……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我真的是……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒關係的，",
