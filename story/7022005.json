        "voice": "vo_adv_7022005_065"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對呀。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可是…………",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小初音已經非常努力過，想將謊言化為真的。",
