[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長！　",
        "unit_id": 110911,
        "voice": "vo_adv_6038105_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這到底是怎麼回事？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家都知道克蘿依學姐個性冷淡，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是她就只有在那個叫美冬的人面前，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n兩眼冒愛心害羞到不行！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她到底是什麼人？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不管什麼事，都很重視效率……",
        "unit_id": 110911,
        "voice": "vo_adv_6038105_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒對於這種急性子的人很有\n共鳴呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所謂的青春，就是從小孩長成大人之前的緩衝期。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這有限的\n寶貴時間，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要一點都不浪費地好好享受！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓我們一起，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "享受緩衝期吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔……",
        "unit_id": 110911,
        "voice": "vo_adv_6038105_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "從送貨到傭兵，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼都能做的優秀打工族啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這正是博而不精派的琪愛兒所憧憬的大人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n比起專家更想成為什麼都會的人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真不錯……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "心動",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是那個就是那個，",
        "unit_id": 110911,
        "voice": "vo_adv_6038105_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐一直興奮地說好酷的那個。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是琪愛兒也有那種風格的綽號，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐會不會重新愛上我呢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "以後可以請你改用桃色颱風或是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "漂亮大魔神之類的稱呼來叫我嗎？",
        "unit_id": 110911
    }
]