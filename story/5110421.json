        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想不到自己",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "竟然還能獲得開創未來的力量。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 124911,
        "voice": "vo_adv_5110421_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話說回來，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這身裝扮好像有點太暴露了吧？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這不是我該負責的賣點啊……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 124911,
        "voice": "vo_adv_5110421_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也因為這樣，活動方便許多，就不多計較了。",
