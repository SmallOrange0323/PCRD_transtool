[
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我說伊莉亞，",
        "unit_id": 126311,
        "voice": "vo_adv_5120308_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n對方的力量",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "完全深不見底呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這到底是怎麼回事？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "假如流傳的內容無誤，",
        "unit_id": 126211,
        "voice": "vo_adv_5120308_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那應該是連世界都能稱霸的力量。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不會只有這點程度就結束。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可惜……",
        "unit_id": 126211,
        "voice": "vo_adv_5120308_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不湊巧，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n此刻在這裡的",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是統御黑夜之人。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "稱霸世界這點程度，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對妾身來說易如反掌。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵♪",
        "unit_id": 126311,
        "voice": "vo_adv_5120308_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n的確是很倒楣呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為這裡",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有稱霸世界之美的我在啊！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼，",
        "unit_id": 126211,
        "voice": "vo_adv_5120308_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n既然咱們都攜手合作了，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就代表你的命運早已底定。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會稱霸世界的",
        "unit_id": 126311,
        "voice": "vo_adv_5120308_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我們♪",
        "unit_id": 126311
    }
]