        "name": "雪菲",
        "words": "\n總之",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先盡快走出森林──",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呀啊！？",
        "unit_id": 106411,
        "voice": "vo_adv_1064009_068"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好痛～",
        "unit_id": 106411,
        "voice": "vo_adv_1064009_069"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n竟然被藤蔓絆到了，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚呀！？",
        "unit_id": 106411,
        "voice": "vo_adv_1064009_070"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有、",
        "unit_id": 106411,
        "voice": "vo_adv_1064009_071"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有什麼東西正在朝這裡過來？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n魔物？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "盜賊？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "盯上龍人族的傢伙？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "其實是幽靈！？　",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "敢對我下手就把你冰起來……！",
        "unit_id": 106411,
        "voice": "vo_adv_1064009_072"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n敢對我下手就把你冰起來……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "敢對我下手就──",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "打打──！！！！",
        "unit_id": 106414,
        "voice": "vo_adv_1064009_073"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………真的",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_074"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很對不起。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你擔心我才特地來接我，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_075"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我卻誤會了而出手打你，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且還讓你背我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_076"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n謝謝你……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……\n…………",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_077"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_078"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你怎麼知道？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難道",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_079"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他是擔心這個才來接我的？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他一定",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有很多事想問吧，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但他只是靜靜地",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等著我開口。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個人",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是這一點……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_080"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你真不愧是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「哥哥」呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_081"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "做了個夢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "夢裡有人",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_082"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "幫我慶祝生日……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是個非常幸福的夢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我以為「以前的我」",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_083"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也曾有過親近的人。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "即使到蘭德索爾外面去找，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_084"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "卻還是找不到。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說實話",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_085"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我有點灰心，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過更覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不可思議。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我能理解，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_086"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n見不到大家和你，我會感到寂寞……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_087"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼想到一個連長相都不記得的人，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也會感到寂寞呢……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也許……？",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_088"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_089"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我從來沒有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣想過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然如此，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_090"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不能忘記這種寂寞的心情。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這樣",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總有一天……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_091"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_092"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總有一天一定",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還能再見！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_093"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n之前",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽可可蘿小姐說過，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n在【美食殿堂】大家會一起做料理、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "辦慶生會對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "聽說你負責做蛋糕。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_094"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我能恢復記憶，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也想起生日是哪一天……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "到時候，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_095"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你也可以",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "烤蛋糕給我嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_096"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我很期待那一天。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝謝你。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_097"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n{player}。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……好溫暖。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_098"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺我",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_099"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就算再次失去記憶，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也永遠不會忘記",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個人的溫暖……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在黑暗的森林中──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲輕輕摟住{player}的背，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n露出了微笑。"
    }
]