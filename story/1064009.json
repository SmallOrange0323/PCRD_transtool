    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是今天吧？",
        "unit_id": 1,
        "voice": "vo_adv_1064009_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……生日快樂。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……我說過不需要",
        "unit_id": 1,
        "voice": "vo_adv_1064009_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "生日蛋糕的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還這麼大一個……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不過……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝你──",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………嗯。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又是那個夢……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最近都在做同一個夢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "身旁的那個人",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是誰？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想不起來，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我什麼都想不起來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有一點我很清楚。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那是個幸福的夢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你們兩位",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "早安。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛好早餐準備好了。",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐也請坐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "我開動了。",
        "unit_id": 1,
        "voice": "vo_adv_1064009_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天氣真好。",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是適合打工的絕佳好日子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打算怎麼過呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我本來……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也要去打工的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過上班地點的店主大叔，最近孫子剛出生，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以店裡會休息一陣子。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「是今天吧？",
        "unit_id": 1,
        "voice": "vo_adv_1064009_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……生日快樂。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個奇妙的夢",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "夢到好多遍了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然之前想要尋找「以前的我」的線索，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n已經和這個人一起在鎮上到處找過了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但說不定",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在城鎮外頭，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n會有人認識「以前的我」。",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……啊。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱歉。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我在",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想事情。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想趁打工休息的期間，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n去旅行一下……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是指……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人去嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒事的。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我之前也有自己辦好跑腿工作呀。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我已經能",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "獨自旅行了！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人們總說捧在手心疼愛的孩子，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "終有一天會獨自出外旅行呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要哭，媽媽……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……不對！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐妳放心，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我很快就會回來的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……信？",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n怎麼突然要我寫信……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……或許",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他察覺到什麼了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "儘管嘴上不說但還是會擔心……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以才要我寫信嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你能把我的心思看透，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n而我多少也對你",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有些了解了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好啊。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就當在寫旅行日記。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼做好像也滿有趣的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1064009_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n當確定好要回來的日期時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請通知我們一聲。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會做一頓好吃的飯菜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等您回來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你們",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就期待",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我帶伴手禮回來吧！",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想想……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「我現在",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "正要前往下一個村子。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n第一次自己出門到這麼遠的地方，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點不安……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但幸虧有你給的地圖，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我應該不會迷路。」……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這張地圖上……",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有好多手寫的筆記。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "住宿的地方、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "安全的飲水處、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "魔物的棲息地資訊等等……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定是他",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為我蒐集了資訊吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……都離開蘭德索爾了，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_031"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n感覺他的溫柔依然陪伴著我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 106412,
        "voice": "vo_adv_1064009_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我這麼快就開始想家了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不過",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
