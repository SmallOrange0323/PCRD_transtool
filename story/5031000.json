[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為今天想向各位做歲末問候，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "正在\n前往大家的公會小屋途中呢，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能遇到你們真是太好了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這一年來，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是承蒙",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家的照顧。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我代替咲戀大小姐，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在此向各位致上深厚的謝意。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不敢當不敢當～",
        "unit_id": 111811,
        "voice": "vo_adv_5031000_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們才一直受她關照呢！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今年",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的非常感謝你們！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家都穿著和服呢，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是等一下要去參拜嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 111911,
        "voice": "vo_adv_5031000_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "機會難得，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們想在神殿迎接新年以後，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就這樣直接去參拜。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果鈴莓小姐方便的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要也一起來呢？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請務必讓我參加！",
        "unit_id": 112111
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 112011,
        "voice": "vo_adv_5031000_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真難得妳會落單。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n平常總是一直叫著大小姐大小姐～",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的嘛。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為大小姐她",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "最近十分忙碌……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔，",
        "unit_id": 111811,
        "voice": "vo_adv_5031000_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳的嘆氣感覺別有深意呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是和咲戀吵架了嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我怎麼膽敢跟大小姐吵架！",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是我一直給大小姐添麻煩……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難得的除夕",
        "unit_id": 112011,
        "voice": "vo_adv_5031000_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也太鬱悶了吧～",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳冒冒失失又不是一天兩天的事了？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有必要這麼沮喪嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……其實是，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "前幾天大小姐和",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "談生意的對象有個晚宴，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而我",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "擔任了晚宴的服務員。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我一緊張就打翻了湯品……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n把、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "把湯",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "灑在生意對象身上了！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就算我想挽回名譽，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "最近也沒什麼",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能和大小姐說話的時間……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說不定，",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐會如此忙碌",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也是我造成的，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我一直在想她是不是",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在忙著幫我善後。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是說，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她已經對我厭煩了，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "正在找其他的女僕呢……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐，",
        "unit_id": 111911,
        "voice": "vo_adv_5031000_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳想多了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n無法與",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己侍奉的人交談，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確會很難受。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 111911,
        "voice": "vo_adv_5031000_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是會因為那種事就對鈴莓小姐",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n做出刻薄舉動的人。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請妳",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "千萬不要迷失了自我……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說、",
        "unit_id": 112111,
        "voice": "vo_adv_5031000_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說的也是呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難得的除夕，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還跟你們說這些，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是抱歉。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多虧了你們，我稍微安心一點了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你們。",
        "unit_id": 112111
    },
    {
        "type": "background",
        "background": "500910"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 111811,
        "voice": "vo_adv_5031000_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　那裡好像人山人海的耶――",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "一定要獲勝喔喔喔喔喔喔喔喔！",
        "unit_id": 1011,
        "voice": "vo_adv_5031000_018"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "根據這個算式，",
        "unit_id": 1211,
        "voice": "vo_adv_5031000_019"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們一定會獲勝的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我會……",
        "unit_id": 911,
        "voice": "vo_adv_5031000_020"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "打倒……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "敵人……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 112011,
        "voice": "vo_adv_5031000_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊，怎麼這麼吵！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是有什麼活動嗎？",
        "unit_id": 111911,
        "voice": "vo_adv_5031000_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在這個人潮中前進",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎很困難呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "今天！",
        "unit_id": 1,
        "voice": "vo_adv_5031000_023"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "也就是在這個除夕……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "將會確定即將到來的新年福氣要落在誰家！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n讓各位久等了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n「蘭德索爾的新春公會競速賽」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "馬上就要開始了！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "競速賽？",
        "unit_id": 1,
        "voice": "vo_adv_5031000_024"
    }
]