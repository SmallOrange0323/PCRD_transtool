[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞與{player}，\n來到了某個洞窟前。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n開心吧，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的眷屬啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身終於找到了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "其實這個洞窟，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是個眾多英靈所沉眠的地下墳場……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是地下墓穴。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "據說進入這洞窟的人，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可藉由英靈之力，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n讓魔力獲得提升……的樣子。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是說！",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若是在這裡，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或許就能讓妾身恢復為真正的姿態！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯、",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說的沒錯，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這不過只是個傳聞。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身認為還是值得來確認看看！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "走吧，{player}！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n一定要讓妾身",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "取回真正的姿態！",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……還真是個深不見底的洞窟呢。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n對這雙小孩的腳來說，有點累啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身現在准許你來背著妾身。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那麼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是魔物啊。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "數量有點多……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但這種程度的魔物，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是妾身的對手。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像這種傢伙，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身一瞬間就能打倒牠們。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好好品嘗一下……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統領黑夜的支配者之力吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還以為在這個地下墳場就沒問題了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但憑這身姿態果然還是沒辦法擊倒魔物啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "受到妾身的攻擊後，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n對方也生氣了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}，要逃了哦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "特、",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "特別准許你",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "背著妾身！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快帶著妾身逃跑吧！",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看樣子總算是逃掉了……",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不愧是妾身的眷屬。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從今以後，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也要好好地為了妾身賣命，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n保護好妾身哦？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼繼續朝著洞窟深處──",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……哦，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看樣子，似乎沒那個必要了呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你問為什麼？",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}、仔細看看周遭吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身猜想，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這些應該就是在這洞窟裡死去的英靈們吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你仔細看看。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n放眼望去，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "周遭不都是化為白骨的屍體嗎。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣看來，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這裡似乎就是這洞窟的最深處了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就趕緊，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓英靈之力成為妾身的囊中物……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "竟然又追上來了啊。",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是一群煩人的傢伙。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算想逃，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "出口也都被魔物們給堵住了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看來免不了一戰。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是妾身，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "能恢復真正的姿態，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才不會輸給那種雜魚們呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……既然如此！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沉眠於地下墓穴的英靈們啊……",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身名為伊莉亞・奧恩斯坦。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n乃是統御黑夜之人。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "將你們的力量，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "獻給妾身吧！！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈～哈哈哈哈哈！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恢復成原本的姿態了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看來，那個傳聞是真的呢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然恢復這身姿態了，",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們根本就不足為懼！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n化為塵埃消失吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘰哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵……",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這份力量，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "與全盛時期相比，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也毫不遜色！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在正是征服世界的時候！",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "走吧！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的僕人啊！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先要先離開這洞窟，",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n去最近的城鎮――",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什…！？",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n又變回小孩的模樣了……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才剛離開地下墳場就……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難、難不成，",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只有在這裡，才能變回原本的姿態嗎……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣根本就沒意義嘛！",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n{player}！咱們趕快離開這種地方──",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不、",
        "unit_id": 104412,
        "voice": "vo_adv_1044005_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不對，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等一下。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再回去洞窟的深處一次。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好，",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恢復成原本的姿態了呢……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n好了，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬啊。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你沒有什麼話要對妾身說的嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這胸部、",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這腰線、",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有這張臉……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎麼樣？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很美對吧？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是因為你的努力，才能看得到哦。",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就稍微，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身聽聽你所期望的事吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎麼樣啊……？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你、",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你問說，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是什麼意思？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你該不會，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真的不知道妾身在說什麼吧……？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身這副模樣――應該有很多能做的事吧！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾、",
        "unit_id": 104411,
        "voice": "vo_adv_1044005_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身特地為了你……！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n{player}，妾身命你原地跪坐！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不知為何，\n{player}在洞窟裡被伊莉亞發了一頓脾氣。"
    }
]