    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是志那都和埃拉兩人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在與{player}等人會合不久後發生的事……"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼～",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要來吃什麼呢？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家也快趁現在先決定好要吃什麼東西吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要點什麼都可以喔♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的可以嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_5137064_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不用客氣不用客氣！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟姐姐我可是",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有討伐魔物得到的賞金呢♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "討伐魔物的賞金……",
        "unit_id": 100311,
        "voice": "vo_adv_5137064_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n原來如此。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……埃拉。",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n話別說得太滿。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n要是妳手上的錢不夠怎麼辦。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒事沒事！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n要是真有什麼萬一，就去洗碗或做其他事抵債吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n而且……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "只要志那都別喝太多就行了，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………！！",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "別喝太多……？",
        "unit_id": 100213,
        "voice": "vo_adv_5137064_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是指什麼呀？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很在意嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "其實呢……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉……",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n等等，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "別再說了──",
        "unit_id": 135614
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "乾杯～！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "乾杯。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咕嚕咕嚕咕嚕……",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "噗哈──！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊～",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真暢快～～～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哈哈，",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "客人喝得很豪爽呢。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n久等了，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "為兩位送上",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "烤雞肉串兩人份。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "太棒啦～！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我等很久了♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……謝謝。",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_017"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不過，沒想到客人",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "確實很有本事呢。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "竟然",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "轉",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "眼間就把魔物給打倒了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "就是說啊！",
        "unit_id": 1,
        "voice": "vo_adv_5137064_019"
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n雖然天空變紅也很讓人震驚，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n但這件事更讓我驚訝呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "再加上，同行的另一位大姐感覺也是個大美人……",
        "unit_id": 1,
        "voice": "vo_adv_5137064_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要是只顧著看這邊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "小心麥酒會變得不冰了喔～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "大姐說的沒有錯。",
        "unit_id": 411,
        "voice": "vo_adv_5137064_022"
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n你們兩個就適可而止吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "真抱歉啊，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "還請兩位慢慢坐。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝謝謝～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……我說，志那都。",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_024"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳要是一直戴著面罩，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就什麼都吃不了也喝不了耶？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………因為我不曾，",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_025"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n在人多的地方露出自己的面貌。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所以……",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_026"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "需要一點心理準備。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊～",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_027"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟我們能出現在人們面前的機會有限呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n基本上",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是一直關在塔裡嘛。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉為何可以這麼平靜？",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_028"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……妳不會緊張嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_029"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為我在原本的世界裡，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "姑且是作為一個友善的神明在活動嘛。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "出來見人的時候，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也基本上都是在慶典這類的場合。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣啊……",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_030"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n和我那邊",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "相差很多呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我在眾人面前現身之際，",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_031"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就是進行試煉的時候。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我會給予大家建議或課題，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "幫助他們克服困境。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_032"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有夠像神明的～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過我說啊，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_033"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "待在這邊的期間，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳也只是個「很普通的一般人」。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n稍微放輕鬆一點也沒關係吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要是周遭的視線很令人在意，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_034"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "到時候我會幫妳擋住的。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n好嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……聽妳這樣講好像年紀比我還大呢。",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_035"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "論「原本」的話，妳的年紀應該比我小吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "別在意別在意！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_036"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就交給姐姐我吧～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "開玩笑的♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……呵呵。",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_037"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊啊……",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_038"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n每一樣都很好吃呢。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n尤其是這道燉煮牛肉，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "味道非常地有深度……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "濃厚的滋味令人欲罷不能。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很美味對吧～！",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_039"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n要不要",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "再續加一份燉煮牛肉？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "麥酒要不要也再來一杯？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大杯的可以嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯，",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_040"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "大杯。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_041"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "看來妳挺能喝的嘛♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "老",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "闆！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n兩杯大杯的麥酒！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還要再續一份燉煮牛肉～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "了解～！",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_042"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過話說回來……",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_043"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這邊的麥酒。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n雖然很好喝，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但總～覺得和我那邊的不同呢……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怎麼個不同法？",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_044"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我那邊的顏色更紅。",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_045"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然風味也比較獨特啦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但只要愛上了，就忘不掉那個滋味呢……♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唔嗯。",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_046"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n果然是因為不同世界而有所差異嗎……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "世界不同的話，麥酒也會不同啊～",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_047"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這樣說起來……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "管理者也會不同……",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_048"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是呀。",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_049"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……這個世界的管理者，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_050"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不曉得是怎麼樣的人呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "考慮到目前在此的是我們兩人……",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_051"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n那麼最有可能的，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就是優衣的「複製品」。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n當然也有可能是其他人。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也不曉得其他還有多少個",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_052"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "「複製品世界」存在呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "唉～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "光是想到就覺得累了啊。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_053"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不管怎麼說，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n要是可以和這邊世界裡的日和好好相處就好了。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟她們也只是資料被拿去利用了而已。",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_054"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n打造出我們世界的，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n終究還是我們自己呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是啊。",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_055"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……妳說的沒錯。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "久等了，",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_056"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "兩杯大杯麥酒。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n還有燉煮牛肉。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝。",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_057"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對了，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_058"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "老闆。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這附近，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有沒有",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "顏色更紅的麥酒呀？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "紅色……",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_059"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳是說赤麥酒嗎。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這附近雖然沒有，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但我記得到西部地區應該就喝得到了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "西部……",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_060"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是我入侵時所在的地區嗎。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "入侵？",
        "unit_id": 4911,
        "voice": "vo_adv_5137064_061"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_062"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "只是我們在談的事情而已！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "老闆謝謝你，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "打聽到好情報了～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n志那都，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們明天就往西──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "呼。",
        "unit_id": 135613,
        "voice": "vo_adv_5137064_063"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "再來一杯，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "麥酒。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "大杯的。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "喝得有夠快的！？",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_064"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉。",
        "unit_id": 135614,
        "voice": "vo_adv_5137064_065"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n到此為止了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳如果",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要再繼續回想下去──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我、",
        "unit_id": 135512,
        "voice": "vo_adv_5137064_066"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我知道了啦！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我不說我不說！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n所以妳不要拔劍啦～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得……",
        "unit_id": 100111,
        "voice": "vo_adv_5137064_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她們感情很好呢。",
