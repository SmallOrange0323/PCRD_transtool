[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在任務結束後的歸途中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n諾維姆不禁大嘆了一口氣。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那些傢伙們",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真的",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "很會使喚人呢。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "怎麼了嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n看妳一臉壓力爆表的模樣。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我是在說七冠他們。",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你不覺得他們使喚我們有點過頭了嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這也沒辦法啊。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們被分派的任務就是要做那些事──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我當然知道那是我們應做的工作。",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n但是我有時候",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就會很想像這樣宣洩一下不滿啊～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真拿妳沒辦法。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我就聽妳抱怨吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n具體而言，妳最受不了哪個人呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這個嘛～",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_006"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n做得最過分的，就是……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "克",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "莉絲提娜！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這又是為什麼呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "因為她很愛罵人、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_008"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還會拿人當誘餌──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "前陣子",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n更因為覺得無聊，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要我把附近的怪物全都打倒！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "等等之類的。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "原來如此",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……嗯，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "其他還有什麼嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "每次開口就是",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "「還不快行動！」",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "之類的，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n任務稍微出點錯就會被說",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "「看來該給妳一點懲罰了吧？」",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n之類的，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "光是看她那副模樣，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就帶給人很大的壓迫感──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "嗯嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_011"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n妳可以再多說一點喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好啊，",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要講多少有多少！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n話說回來，尾狗刀你是怎麼了？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n今天",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "特別懂得傾聽呢。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……是吧？",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……咦？",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_014"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "那傢伙已經不在這裡了。",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_015"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "他很爽快地把這場有趣講座的特別座讓給了我。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……好啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "繼續說下去吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "妳不是說要講多少有多少嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "克、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "克莉絲提娜！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n等一下，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳誤會了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不，應該說，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "妳是從哪裡開始聽的啊！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "「那些傢伙們",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_017"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "真的很會使喚人呢。」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那不就從一開始就聽到了！",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "怎麼了？",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "這有什麼好奇怪的？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "「做得最過分」的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "克莉絲提娜會好好當個傾聽者，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "妳就儘管說吧",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……給我說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這壓迫感！",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_020"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是這股壓迫感啦～！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "呵呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n看來偶爾來點",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "排解無聊的散步也挺不錯的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "因為或許有機會碰到如此令人愉悅的瞬間呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_022"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "狗刀！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你給我記住────！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，又過好幾個小時後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n諾維姆才得以從克莉絲提娜身邊解脫。"
    }
]