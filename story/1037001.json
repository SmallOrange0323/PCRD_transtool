[
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為完全無事可做，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有點無聊呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "反正我只是在前輩午休的時候幫忙代班，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "負責留守而已……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是真的有什麼麻煩的事情，我還真的會有點困擾呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會需要我留守的原因，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n與其說是要我接待來這個「職業介紹所」的客人……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不如說是為了避免重要的文件被偷走，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而需要有人在這裡監視。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖說現在王宮的威嚴變得很薄弱，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n應該也不至於有什麼笨蛋，故意跑來找國家機構麻煩吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呆坐在這裡真的很浪費時間，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還真希望有賊人或魔物襲擊呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那也是不錯的運動，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還能打發一些無聊的時間。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開玩笑的～",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "期待發生那種壞事可不行呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但這就表示我還是個愚昧又血氣方剛的年輕人吧，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是太危險了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "糟糕，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有點太放鬆了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n櫃台前有人進來坐下了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是客人嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n總之，還是得接待一下才行。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你好。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n請問你來「職業介紹所」想辦理什麼事務呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你一定是來找工作的對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n「職業介紹所」",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是國家為此而設置的嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這裡有份文件，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請你寫下必填資料。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果不會寫字，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你也可以用口述的方式，我來幫忙填寫。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然這個國家的識字率很高，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但偶爾還是會遇到不會讀寫的人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像是來自外國的旅行者之類的。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們才準備了這類代筆的服務。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "另外，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也請讓我先跟你說明一件事……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我並非正式職員，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以可能無法好好地接待你。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在正式職員午休回來前，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就暫時由我為你服務吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果是些簡單的事情我還是會處理啦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟還是有受過教育訓練。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我隸屬於名為【王宮騎士團】的公會……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以說像是軍隊一樣的地方。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是之前，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有段時期對自己的未來覺得有些迷惘。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也曾試著進入許多不同的機構，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n或是公會等等。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也有在這個「職業介紹所」待過一陣子，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以還算知道要怎麼處理這裡的工作。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我的事情不重要吧……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真不好意思。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我實在是太閒了，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以很想找人陪我聊聊天。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最喜歡跟人聊天了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "特別是，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n最喜歡捉弄像你這樣年紀比我大的人……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你真的不會",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "寫字嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你失去記憶了啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n像寫字之類的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n忘了這種很基本的事而感到很困擾？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我最近",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像有在哪裡聽過這種事呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，別想了。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那你用說的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我來幫你填寫這些文件，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n請你一一回答下述問題。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就麻煩你囉～♪",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "首先，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以告訴我你的名字嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔呣。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n名字是……{player}？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒有隸屬公會，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也沒有固定的居住地點……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯～",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果是這樣的狀況，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可能比較難介紹工作給你呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但如果是領日薪的勞力活或許還有機會，",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有誰可以當你的保證人嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔呣。",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你叫做……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "蘭德索爾……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不對不對，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "蘭德索爾是我們這城鎮的名字才對。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你剛剛該不會是故意裝傻的吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你好有趣唷……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過你這樣開玩笑我很困擾呦～",
        "unit_id": 103711,
        "voice": "vo_adv_1037001_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n麻煩你好好回答。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但如果是私底下聊天的話，",
        "unit_id": 103711,
