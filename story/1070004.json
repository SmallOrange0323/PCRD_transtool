[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "分身似似花在與{player}的談話中，\n觀察了暫時未見的他成長了多少。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……公主騎士的力量變得比以前更強大，",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不對，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是漸漸恢復到原來的狀態了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來就如同我的判斷，",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你喪失的記憶",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n似乎就是公主騎士之力的關鍵呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今後的戰鬥，",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤其是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與真那的決戰，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我認為你的力量是必要的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此，",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我現在要從留在我體內",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "約3成左右的記憶裡，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "將現實世界中",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與你相遇的記憶",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "播放出來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也是第一次做這種事。",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以不曉得會發生什麼事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這對我們而言",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是必須進行的事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你明白吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很好的回答。",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼現在開始",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "播放記憶――",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――那一天{player}為了參加\n在學校裡舉辦有關學生網路使用的演講，\n而前往體育館。"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊！　",
        "unit_id": 1,
        "voice": "vo_adv_1070004_006"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "{player}！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n下一節課",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "聽說從體育館改成教室了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "原本預定要來的講師……",
        "unit_id": 1,
        "voice": "vo_adv_1070004_007"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "厚生勞動省的人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n好像病倒了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "所以",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "特別改成利用網路直播",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n由別的人來演講了〜",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "老師是這樣說的！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "反正",
        "unit_id": 1,
        "voice": "vo_adv_1070004_008"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "就是聽大叔在長篇大論吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n不曉得能不能早點結束……",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "107000401"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――大家好，",
        "unit_id": 1,
        "voice": "vo_adv_1070004_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "椿丘高校的同學們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看得到這裡的樣子嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "是女人耶……",
        "unit_id": 1,
        "voice": "vo_adv_1070004_010"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "老師，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "這個沒有正常播放嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來影像似乎沒正常顯示呢。",
        "unit_id": 1,
        "voice": "vo_adv_1070004_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n變更這裡的設定吧。",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "107000402"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這樣有播放出來嗎？　",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大家好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我是現士實似似花。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次是",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "代替熟人進行演講。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "我記得這個人就是那個吧？",
        "unit_id": 1,
        "voice": "vo_adv_1070004_013"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n是WISDOM的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "七冠！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "好厲害～！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "是本人耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "咦！？　",
        "unit_id": 1,
        "voice": "vo_adv_1070004_014"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "是本人嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請各位安靜。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是本人。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今日因為不方便，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以很遺憾無法直接與各位見面。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "什麼七冠啊……",
        "unit_id": 1,
        "voice": "vo_adv_1070004_016"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "不管怎麼看都是小學生吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原本是想和各位",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "談談有關",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n正確使用網路的方法……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但我改變主意了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說我是小學生的",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那邊那位同學。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這次的樣本",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就用你了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "咦……？",
        "unit_id": 1,
        "voice": "vo_adv_1070004_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "2年級，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "座號是……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "5號。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "籃球社員，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "自家的格局是……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "4LDK。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有個妹妹呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "等等，",
        "unit_id": 1,
        "voice": "vo_adv_1070004_021"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "為什麼！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "是怎麼知道的……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "上次的考試",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為不及格被母親罵了……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那就算把我誤認成小學生，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也沒辦法呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "真、",
        "unit_id": 1,
        "voice": "vo_adv_1070004_023"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "真的很抱歉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n對不起！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "是我錯了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好吧。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就看你謝罪的份上原諒你。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "各位剛才",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是不是認為我",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n入侵他的手機",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "偷看個人情報呢？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那完全錯誤。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "其實",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才的情報",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n全都只是收集了網路上現有的情報。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "其實剛才他的個人情報也是，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他本人自然是不用說，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還有他的家人及朋友，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是說，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是你們發送出去的訊息。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才的同學",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等回家後，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就去對朋友與家人說，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n並確認過去上傳到",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "SNS的照片與視頻吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在的時代",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "從本人或其他人的SNS帳號，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就能簡單地",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "查出個人情報。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對機械的防範對策",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然是日益精進，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但重要的",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是使用那些的使用者本人。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "使用mimi的VR遊戲",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或使用網路時",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也同樣應該注意",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "個人情報的管理。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "mimi",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或VR網路的防護系統，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n都是接近完美的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相對的，使用者本人",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就必須注意",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在網上含有個人情報的發言。",
        "unit_id": 107031
    },
    {
        "type": "background",
        "background": "510221"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1070004_034"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "找到了找到了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n吶，{player}。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "可以拜託你一下嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "其實",
        "unit_id": 1,
        "voice": "vo_adv_1070004_035"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "老師拜託我",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "把東西搬到頂樓……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n可以請你幫忙嗎？",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510181"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊哈哈哈……",
        "unit_id": 1,
        "voice": "vo_adv_1070004_036"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "沒想到你居然這麼輕易就接受了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n真令人驚訝。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "或許我根本",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "不需要做出這種事來呢――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "――面對你，就算繼續偽裝也沒什麼用吧。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是濫好人到讓人都失去騙人的意義了呢，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這個人。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你好，{player}。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不能什麼情報都囫圇吞棗地相信喔。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼輕易就跟著我過來了，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你的濫好人程度真令人訝異。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你那樣的處事態度，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或許就如同晶所說的，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那正是我失敗的理由吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對究極個體的",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們七冠而言，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是個完全相對的存在……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我現在",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對你抱有非常深的興趣。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我忘了說，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天的演講",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n全是借用校內的空教室",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "進行發送的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個男學生的個人情報，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n及全學生的情報都只是我事前調查的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為還是高中生，所以也無可奈何，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但沒想到所有人都相信了……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但明天應該會有什麼爆料吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個擊敗我的公主騎士的模樣，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我很想親自看一眼。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以拜託熟人協助我，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n替我調整成能夠",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以代理身份進行演講。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我只是尋找了日本未發布的ID所分配的mimi，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n然後再調查",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "來自該裝置的網路使用蹤跡而已。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "公主騎士的mimi",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是七冠特別準備的東西。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要查出那些事，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對同樣身為七冠的我而言並不是難事。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你不需要那麼警戒我也沒問題的。",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算把這麼大甜頭的情報",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "交給其他七冠",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也沒什麼意思。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天的事情",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就當作我們兩人的祕密吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……要找出他的蹤跡",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "實在太過簡單了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來晶",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是想讓他和我們七冠碰面吧……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該不是希望我們照顧他",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這種天真的想法吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要推測妳的想法還是依然這麼麻煩呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在現實中進行個人攻擊，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並不符合我的喜好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能像這樣見到面我就滿足了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我像這樣出現在你面前，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是第一次也是最後一次。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "否則到戰鬥時，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可能會讓我動了不必要的情感。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "下次",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在阿斯特朗中再見吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在那之前，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你一定要好好保重。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……下次再見面時，",
        "unit_id": 107031,
        "voice": "vo_adv_1070004_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我絕對會打倒你。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼再見了，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶的公主騎士。",
        "unit_id": 107031
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……播放結束。",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才的就是我和你",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在現實世界中的記憶。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以前就算在那之後我們彼此也仍然是敵人，",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但現在為了逃離這個世界，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會協助你。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個嘛……",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "視你的行動而定，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "目前就先這麼決定吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊……",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但願能夠如此。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我期待你的表現。",
        "unit_id": 107011,
        "voice": "vo_adv_1070004_061"
    },
    {
