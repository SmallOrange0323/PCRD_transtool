[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一個人走在蘭德索爾大街上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n街上因為迎來新的一年而十分熱鬧。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是小哥啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這還真巧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "新的一年剛開始，你就很有活力呢。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "新年快樂。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n今年也請多指教啦。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這句話還真令人開心啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n都讓我想包紅包給你了。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說到這個，小哥，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你接下來有什麼事情嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒什麼",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "特別的事情？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那你接下來",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要跟我",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一起去神殿？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是也要去參拜，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但那不是我",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唯一的目的。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "護身符？",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說到這個，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我聽說神殿的護身符",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "相當靈驗啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "去求護身符是也不錯，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但我還有其他的目標。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "神殿中祭祀了特別的御神刀，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每逢一年一度的新年，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n神官都會用那把御神刀來進行舞蹈表演。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我聽說那好像十分精彩，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很想來看一次。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也有邀請公會的人，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但大家都有事。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且我難得準備了新的新年和服，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就自己一個人來了。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "事情就是這樣，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果小哥不介意的話，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要一起來？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你願意陪我嗎？",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝你啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就馬上前往神殿吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想占個好位子。",
        "unit_id": 120811
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯～",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼等都不開始啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "早就已經超過表演開始的時間了……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "我問一下，",
        "unit_id": 1511,
        "voice": "vo_adv_1208001_012"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "表演什麼時候才要開始啊？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "我都要等得不耐煩啦。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "哈",
        "unit_id": 3512,
        "voice": "vo_adv_1208001_013"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "啾……！",
        "unit_id": 3512
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "嗚嗚，",
        "unit_id": 3512
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "好冷啊……",
        "unit_id": 3512
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n別讓老人家在大寒天裡等著啊。",
        "unit_id": 3512
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "非、",
        "unit_id": 417,
        "voice": "vo_adv_1208001_014"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "非常抱歉。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "我們目前正在為表演做準備。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "\n還請各位",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "稍待片刻……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……小哥，我問你，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不覺得情況有點奇怪嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "舞台已經搭好了，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來只要讓拿著御神刀的神官\n上台就行了。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他們究竟是在忙著準備什麼？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再說，仔細一看，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那位巫女不是遍體鱗傷的嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只是有事情要忙的話，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "她那副模樣也太奇怪了。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也這麼認為嗎？",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最好還是去問一下啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小姑娘，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以耽擱妳一點時間嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "是、",
        "unit_id": 417,
        "voice": "vo_adv_1208001_018"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "是的……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "那個，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "如果是要問舞蹈表演的事情，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "可以勞煩您再等一下嗎？",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不是要問這個。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我問妳，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "究竟",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是發生什麼事情了？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果妳不嫌棄的話，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以跟我們商量。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "沒、",
        "unit_id": 417,
        "voice": "vo_adv_1208001_020"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "沒有……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "完全",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "沒有問題……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但看妳講話時一臉苦惱，實在沒什麼說服力啊。",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳不用擔心，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然我穿得花枝招展，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但也經歷過不少風浪喔。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "可、",
        "unit_id": 417,
        "voice": "vo_adv_1208001_022"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "可是……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再說，",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總不能讓觀眾",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "永無止盡地等下去吧？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "……我明白了。",
        "unit_id": 417,
        "voice": "vo_adv_1208001_024"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "因為這件事不好張揚，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "請兩位往這邊走。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "其實是",
        "unit_id": 417,
        "voice": "vo_adv_1208001_025"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "發生了一點狀況，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "\n讓今天負責進行舞蹈表演的神官大人支不開身。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是什麼樣的",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "狀況？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "這座神殿收管了",
        "unit_id": 417,
        "voice": "vo_adv_1208001_027"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "各種另有隱情的物品，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "\n",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "但因為出了一些差錯，\n導致被封印在壺中的惡靈",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "被解放出來了。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什……",
        "unit_id": 120811,
        "voice": "vo_adv_1208001_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "惡、",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "惡靈……？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "神官大人立刻展開結界，將惡靈壓制下來，",
        "unit_id": 417,
        "voice": "vo_adv_1208001_029"
    },
    {
        "type": "dialogue",
        "name": "巫女",
        "words": "\n",
        "unit_id": 417
    },
    {
        "type": "dialogue",
