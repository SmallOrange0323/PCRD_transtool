    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這還用說嗎！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_034"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那就是代替無能的妳，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "好好地治理這個國家啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "站在民眾之上者，",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_035"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "必須是與其地位相稱、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n具有支配能力的大人！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那是誰呢！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "除了您以外別無他人，",
        "unit_id": 2511,
        "voice": "vo_adv_2107002_036"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "豪紳議長！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "王者‧豪紳！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "沒錯！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_037"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "既然如此，這國家",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "就只能由吾輩來支配了！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "支配……",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不好意思。",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的這個答案，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒辦法將王位讓出來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "啥啊？",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然，",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是從代代祖先繼承得來的重要之物。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但除此之外……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當我坐上王位後，",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再次明白……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n站在他人之上指揮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實是件很不容易的事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往往無法",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "顧全每件事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連最近一起吃飯的朋友",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也老是責備我說：",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「陛下不夠公正」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哼！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_044"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩雖然不知道是誰說的，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "但多少有直中要害吧？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……可是……",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要持續賜予公平，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這對人而言，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是絕對不可能辦得到的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連神也辦不到。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那是因為",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_046"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳太無能了！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在吾輩成為支配者之際，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n吾輩會賜予蘭德索爾的居民完全的平等！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所謂完全的平等……",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那不是賜予，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而是從大家身上奪走權利",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和自由。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這跟利用恐懼鎮壓民眾的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝有何不同。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔……",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪紳先生。",
        "unit_id": 105812,
        "voice": "vo_adv_2107002_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我絕不會讓您成為第二個霸瞳皇帝。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我無法",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "將王位讓給你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "住口！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_050"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳這小丫頭！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n把這蠢蛋抓起來，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾的軍隊【黃金之手】啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵們",
        "words": "喔",
        "unit_id": 1,
        "voice": "vo_adv_2107002_051"
    },
    {
        "type": "dialogue",
        "name": "士兵們",
        "words": "喔喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "──御久間流劍術‧",
        "unit_id": 103711,
        "voice": "vo_adv_2107002_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "陣風！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔！？",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_053"
    },
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "到此為止了，豪紳議長、",
        "unit_id": 104711,
        "voice": "vo_adv_2107002_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【黃金之手】部隊！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們不會讓你們",
        "unit_id": 100511,
        "voice": "vo_adv_2107002_055"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "碰公主殿下一根寒毛的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……呼，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "講得好……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "什……",
        "unit_id": 2511,
        "voice": "vo_adv_2107002_056"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "【王宮騎士團】！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "而且還是全副武裝的",
        "unit_id": 1011,
        "voice": "vo_adv_2107002_057"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "主力部隊……！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】隊長",
        "words": "這怎麼可能！",
        "unit_id": 4312,
        "voice": "vo_adv_2107002_058"
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】隊長",
        "words": "\n【王宮騎士團】應該早已出發去執行驅除魔物的任務了吧……！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "是、",
        "unit_id": 4311,
        "voice": "vo_adv_2107002_059"
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "是的！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "\n今天早上門衛有傳來",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "他們已出城的報告……！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "\n還說純團長",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "【黃金之手】士兵",
        "words": "也在部隊之中……！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正牌的我現在就站在這裡。",
        "unit_id": 104711,
        "voice": "vo_adv_2107002_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n比起外表的盔甲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "更重要的是內在呀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為純",
        "unit_id": 100511,
        "voice": "vo_adv_2107002_061"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "擁有好幾副相同的盔甲嘛！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你們會在今天",
        "unit_id": 103711,
        "voice": "vo_adv_2107002_062"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "造反作亂一事，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們早已收到情報。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以即便我們人手不足，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "仍可做足相當的準備。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "唔、",
        "unit_id": 2511,
        "voice": "vo_adv_2107002_063"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "唔嗚……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我們中計了……！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "別慌張！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_064"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "要動員這麼多的兵力，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n難免會走漏一些情報！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "再說，純團長。",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_065"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n吾等兵力可是妳們的十倍以上。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "妳以為單靠頂多只有數十來人的部屬，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "就阻止得了我們嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們的確很難",
        "unit_id": 104711,
        "voice": "vo_adv_2107002_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再召集更多的人手過來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟以你為首的貴族會議，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n找了種種理由刪減我們的軍隊預算，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "撤除了不少我們的權限呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哼！",
        "unit_id": 191411,
        "voice": "vo_adv_2107002_067"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n誰讓妳頭戴著那怪水桶，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "導致視線狹隘，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n不好好注意腳下，才會被趁虛而入！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "腳下，",
        "unit_id": 104711,
        "voice": "vo_adv_2107002_068"
    },
    {
        "type": "dialogue",
