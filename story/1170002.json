    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "惠理子重新製作了媚藥，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著{player}來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n去玩之前，先來塗防曬乳吧。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這次由我來幫您塗，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一定要……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一定要讓我來……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就算您想敷衍也沒用的……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您死心，讓我幫您塗吧……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "已經沒有要參加的人了嗎！？",
        "unit_id": 411,
        "voice": "vo_adv_1170002_002"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n這是一年一度的",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "最佳情侶競賽！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n馬上就要截止報名囉～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……最佳……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "情侶競賽……？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "要不要試著拿到第一名，",
        "unit_id": 411,
        "voice": "vo_adv_1170002_004"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "在這片海灘證明",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n兩人之間的羈絆多麼強大，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "愛情又是何其深沉呢！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我們也去參加吧～！",
        "unit_id": 1,
        "voice": "vo_adv_1170002_005"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n反正恩愛的我們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "一定能拿第一！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n輕輕鬆鬆♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "就是說啊～！",
        "unit_id": 1,
        "voice": "vo_adv_1170002_006"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳說得一點都沒錯！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n走吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "用我們熾熱的愛情",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "讓炎熱的夏天更加火熱吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "他們認為……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n……自己是這片海灘上……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最相愛的人嗎……？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這也誤會得太離譜了……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為在那邊的臭蟲們講了莫名其妙的話",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "，\n我火氣都上來了……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n在這片沙灘上最相愛的人",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然是我和您了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……既然如此，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們該做的事情就只有一件。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那就是讓臭蟲們",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "體會到這是天大的誤會……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也沒辦法了……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們去參加吧，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "已經沒有要參加的人了嗎～？",
        "unit_id": 411,
        "voice": "vo_adv_1170002_010"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那報名就要截止囉～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們也要參加……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "規則很簡單！",
        "unit_id": 411,
        "voice": "vo_adv_1170002_012"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "大家聽清楚囉？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "從這片海灘再往外海過去一些，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n就能看見一座小小的島對吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "島上",
        "unit_id": 411,
        "voice": "vo_adv_1170002_013"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "插了旗子！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n最快把那根旗子",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "拿回來的隊伍就能獲勝～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這樣哪裡有最佳情侶競賽的要素了？",
        "unit_id": 1,
        "voice": "vo_adv_1170002_014"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "條件就只有一個！",
        "unit_id": 411,
        "voice": "vo_adv_1170002_015"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "在參賽的兩個人之中，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n需要由其中一個人",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "抬著搭檔來跑～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "搬運的方法不限。",
        "unit_id": 411,
        "voice": "vo_adv_1170002_016"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "不管是要公主抱",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "還是揹著對方都可以！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "順帶一提，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "如果受傷或",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "妨礙其他隊伍，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n就算喪失資格，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "請各位多加注意！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "請大家",
        "unit_id": 411,
        "voice": "vo_adv_1170002_017"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "相親相愛地努力吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n那麼……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "各位準備好了嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您這是把我……！？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n公、",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "公主抱……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "起來了嗎！？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼……",
        "unit_id": 411,
        "voice": "vo_adv_1170002_019"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "預備～",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "開始！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "等、",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "等等，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您在摸哪裡啊？",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然維持這個姿勢",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "直接跑起來的確會……！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我知道在沙地上很難跑，但是……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呀啊！",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您的手換個地方……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "幫您……？",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是要幫您跑起來",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更輕鬆吧……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我明白了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只讓這位大人抱著我，的確是不夠穩……",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然這樣……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我只要緊緊抓住這位大人就好了。",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這麼一來，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們簡直就是",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一心同體……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "失禮了，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請讓我抱著您的脖子……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "進入海濱後",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更加難以行動了……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而其他的",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "情侶組跑得越來越前面……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊～",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真讓人生氣……！　",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這時候乾脆",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把敵人都擺平……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗚。",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妨礙他人會馬上喪失資格……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這我非常清楚……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這麼一來，",
        "unit_id": 117011,
        "voice": "vo_adv_1170002_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "幾乎沒有什麼事情是我能幫忙的……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
