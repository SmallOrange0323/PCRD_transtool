        "type": "dialogue",
        "name": "旁白",
        "words": "也所剩無幾了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這就表示──"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們的新婚生活",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也再過不久就要結束了……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真希望就這樣",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一直放假下去啊～",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……說這種話，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是太任性了對吧。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也補充了滿滿的維他命O，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n新婚夫妻的生活",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "每天都過得很充實♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "目前為止，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也沒有被弟弟提出離婚",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呢。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然我一開始非常擔心就是了……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "意思就是，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟也",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很享受新婚生活，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對吧？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然有點寂寞，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但好好享受剩下的時光吧。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "了，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "手伸出來，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想跟新婚夫妻一樣，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "用恩恩愛愛～",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "的感覺",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "手牽手去買東西♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這樣子也不怕走丟，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又能感受彼此的體溫，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可說是一舉兩得！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "買完東西後，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_005"
    },
