    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然是自誇，但這個計畫真的很不錯呢。",
        "unit_id": 136511
