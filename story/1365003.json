        "name": "靜流",
        "words": "也不曾在意，但是……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不管是弟弟的事，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_057"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是自己的事，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也許現在，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "正是該好好想清楚的時候了。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好好思考吧……",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_058"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要一想到",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是弟弟",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "回應了某個人的心意，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不知怎麼地，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_059"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會忍不住非常心煩意亂……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_060"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "歡迎回來。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我稍微",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_061"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想了點事情，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像不小心自言自語起來了。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "別說這個了……",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_062"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們回程不要牽手，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想挽著你的手臂，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以嗎？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了～♪",
        "unit_id": 136511,
        "voice": "vo_adv_1365003_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那就回家吧，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人挽著手臂，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "相親相愛地並肩而行。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n即使能待在東國的時間已接近尾聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n現在這個當下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "他們仍是「新婚夫妻」。"
    }
