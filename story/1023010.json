        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n也有這麼難得的事呢。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "討、",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_070"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "討厭，噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我可是成熟的淑女，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n才不會一天到晚跟人撒嬌啦！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「哈哈，",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_071"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這很難說吧！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_072"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n撲通撲通的感覺停下來了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "剛才的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到底是怎麼回事？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "現在還可以不用去想那些吧！　",
