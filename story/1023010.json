[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──由於回去得太晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓育幼院的大家擔心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了賠罪，綾音便主動幫忙打掃。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼～哼～哼哼～哼～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n和哥哥一起",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "打掃、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "打掃～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「哦，",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "今天沒有東張西望，有乖乖在打掃嘛。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你在說什麼啊，噗吉？",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我一直都是很認真的乖孩子啊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算是打掃，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也會掃到乾淨發亮的♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「哦哦，",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_003"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音也會老實努力的時候呢。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "話說回來，哥哥。",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你不覺得我這個有乖乖打掃的乖孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n應該可以獲得一些獎勵嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……原來是我的錯覺。」",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以，",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "作為給我的獎勵，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥要和我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一起到城鎮上去♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太好了～！",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和哥哥一起外出～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「真是的……",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "小子真的很寵綾音耶。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n你偶爾不對她嚴厲點可不行喔。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以，",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們趕快打掃完出發吧～！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──一行人來到城鎮，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而綾音前往的地方不曉得為何是一間花店。"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請看。",
        "unit_id": 411,
        "voice": "vo_adv_1023010_010"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n這一個，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "是很適合現在這個季節的花朵喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好漂亮……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就選這個！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以幫我把康乃馨放進這束花裡面嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "呵呵，",
        "unit_id": 411,
        "voice": "vo_adv_1023010_012"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "畢竟是位這麼可愛的客人。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "康乃馨就當作是送妳的吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太好了～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "謝謝妳！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「沒想到",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_014"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音要買的東西會是花束……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不過，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "今天有人生日嗎？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "花店的人多送了我花。",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥覺得怎麼樣？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這束花",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很漂亮吧♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對吧對吧♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……希望他們",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會喜歡這束花。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「那束花果然是要給人的禮物啊。",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_017"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我說綾音，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳要送給誰？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "………………",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_018"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……綾音？」",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……跟你說，哥哥。",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "接下來",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有一個地方，希望你能陪我去。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一直任性要求你很對不起……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果我一個人去，也許就會想要逃走……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以拜託你！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "陪我一起來！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "謝謝你♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「所以，",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_023"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳到底要去哪？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呃……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "等、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "等去了就知道了！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……好，",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「妳說到了……",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_026"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n綾音，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這裡是……！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這裡是爸爸媽媽住的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我的家。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對爸爸媽媽說過很過分的話……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大吵大鬧……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還逃家了無數次的家……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n除了每週規定要回來兩次的日子以外，我好像好久沒來這裡了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音！",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_029"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "馬上回去吧！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n現在對綾音來說還太勉強了！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……沒事的！",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_030"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾、",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_031"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音……？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……沒事的，",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為哥哥和噗吉",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n告訴過我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所謂家人的羈絆！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音……」",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "其實我",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到現在還是覺得爸爸媽媽有點不對勁……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像不是真的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就像是虛擬的一樣……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……可是！",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我知道他們會作為爸爸媽媽來對待我……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是因為他們真的愛我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不管是不是真實的都沒有關係……",
        "unit_id": 102311,
        "voice": "vo_adv_1023010_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是由羈絆連結起來的家人啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音……",
        "unit_id": 2111,
        "voice": "vo_adv_1023010_037"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n在不知不覺間",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
