    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖誕節這天，城鎮被染成一片雪白。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克莉絲提娜、伊莉亞、望三人大顯身手（？）的事情，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n慢慢地在蘭德索爾傳開了。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～",
        "unit_id": 100411,
        "voice": "vo_adv_5029003_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好想來弄個規模大一點的惡作劇～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過，陷阱和驚嚇箱我都玩膩了，",
        "unit_id": 100411,
        "voice": "vo_adv_5029003_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然不管我做什麼哥哥都會上當，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但是難得的聖誕節，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "玩大一點比較有意思～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～？　",
        "unit_id": 100411,
        "voice": "vo_adv_5029003_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像有什麼東西從天上掉下來了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是什麼～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "黑黑圓圓的，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "該不會是……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "炸彈？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好厲害！　",
        "unit_id": 100411,
        "voice": "vo_adv_5029003_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好厲害喔！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我還是第一次看到這麼大的炸彈！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太棒了！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有了這個哥哥一定會嚇一大跳的！",
        "unit_id": 100411
    },
