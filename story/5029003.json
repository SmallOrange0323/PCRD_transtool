        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是外面",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "能有棵很大的聖誕樹，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就能一直享受聖誕節的氣氛了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦！？　",
        "unit_id": 102111,
        "voice": "vo_adv_5029003_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦咦咦咦！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n外面，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "竟然長出了一棵大樹……",
        "unit_id": 102111
