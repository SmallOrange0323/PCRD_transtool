[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我回來囉～♪",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有沒有乖乖的？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咿呀！？",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡歡歡、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡迎回家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不是一直說，",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要再叫我『媽媽』了嗎。\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "人家我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才17歲而已哦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好意思……現在肚子很餓，",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果有剩飯或什麼的話給我吃吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果沒有，那就叫外送吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，沒關係……",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐說，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天會遲些下班所以……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "幫我們準備好食物了……",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，呃……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有、有食物！",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我先去加熱……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇啊！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小心呀！",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用那麼慌張哦，胡桃。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且只是準備吃的東西而已，我可以自己來……",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經很晚了，胡桃妳先回房間睡覺吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但、但是……",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽好不容易才回家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想跟咲戀媽媽聊天……嗚嗚？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我們一起做用餐的準備吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我一直都不在家，真對不起。很寂寞嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，大家都覺得很寂寞唷……",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是，只要再忍耐一下就好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然今天好像又捲進了什麼不必要的麻煩，",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n未來也不知道會發生什麼事。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，你們安穩的生活還是最重要、最優先的唷♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇哇？",
        "unit_id": 102111,
        "voice": "vo_adv_2003001_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽，不要抱這麼緊……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好、好難受！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問……？",
        "unit_id": 105913,
        "voice": "vo_adv_2003001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人該做些什麼才好？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，對不起。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓客人呆站在玄關了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們還有幾間空房，帶你們去看看吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把行李搬到那邊去吧。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好意思，床舖什麼的就請自己整理囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然比不上高級飯店的套房，",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，還是可以遮風擋雨的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天大家都很累了，好好休息吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喔，忘記好好的打招呼。",
        "unit_id": 102811,
        "voice": "vo_adv_2003001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要正正式式溫柔地跟你們說……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "歡迎來到我可愛的家【咲戀育幼院】♪",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500122"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天好像總是被情勢發展牽著鼻子走。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您應該累了吧。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下已經趕快鋪好床了，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請就此歇息了吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。行李的話，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n之後會從先前住的旅館運送過來。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天就請先好好休息吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。多虧咲戀小姐的厚待，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人才可以，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這【咲戀育幼院】過夜呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在要回到旅館的話，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也已經很晚了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果一直住旅館的話，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n光是住宿費在下等人就要想方設法賺錢呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐幾乎免費提供寢床，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對在下等人來說有如及時雨。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖說是對在下等人捲入麻煩事表示的歉意……",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今晚就恭敬不如從命，接受人家的好意吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算說到生活安定下來之前",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都可以住在這裡……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣給人家添麻煩，在下心中有些過意不去。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且現在也還無法判斷，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n咲戀小姐等人值不值得信任。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，在下還是遵從主人的意思。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請依照您的想法行事就好。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論發生什麼事，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下都會盡全力保護主人的性命。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖說如此……",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天被捲入許多混亂的紛爭，已經很疲累了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也要歇下了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晚安，主人……♪",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_034"
    },
    {
        "type": "still",
        "still": "200300101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔？",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣，有什麼不妥嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，與其說是問題，",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖說可可蘿還是個孩子，但是年輕男女同床共枕的？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n莫非，你們兩位是那種關係？",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500123"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那種關係，是什麼意思？",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下跟主人，正如您所見，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只是很常見的主僕關係而已♪",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人睡著的時候，就是處於毫無防備的狀態……",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下像這樣與主人同寢，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也可以對周遭保持戒備。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管發生什麼事，都可以馬上處理。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下似乎體溫比較高，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人都讚賞說，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n擁著在下入眠，懷中就好像有個熱水袋……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，不可以嗎？",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不行呦！",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你們既不是父女也不是兄妹對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若出了什麼差錯可不得了，對孩子們的教育很不好！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我有替可可蘿準備其他房間，",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就在那邊睡吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "喏，過來？",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快點，在被孩子們看見之前……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼要這麼慌張呢，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n鈴莓小姐……？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人，從始至今都睡在同個房間呢。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟兩個單人房，住宿費就會高出許多。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、這樣不行嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不行喔～真是的。",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你們啊，有時還真是沒有常識呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這不是需要道歉的事啦……",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說回來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你好像喪失記憶了對吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以才會，",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忘掉各種重要的事情呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣的話就還有斟酌情形的餘地，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒辦法了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只不過，",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "年輕男女同床共枕還是大有問題……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在正對面的，就是可可蘿的房間。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可可蘿就",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在那邊睡吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，不想離開主人的身邊。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要說這種任性的話。",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然我明白妳會感到孤單。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果覺得不安的話，我會陪妳一起睡……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人不行，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是鈴莓小姐就OK的意思嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這道理在下不理解。",
        "unit_id": 105912,
        "voice": "vo_adv_2003001_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以的話，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下還是想跟主人一起……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，真是的……",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼解釋才好，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真困擾呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐正在大廳等候……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請兩位一起到那裡用餐吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，若是覺得睏的話，直接睡也沒關係。",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你們暫時會在【咲戀育幼院】生活吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果是這樣的話，談話的機會……",
        "unit_id": 102511,
        "voice": "vo_adv_2003001_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今後還多得是呢♪",
        "unit_id": 102511
    }
]