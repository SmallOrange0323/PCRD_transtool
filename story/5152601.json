    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯～",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好悠閒……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我這麼地享受著夏天",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒有問題嗎。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟，",
        "unit_id": 107812,
        "voice": "vo_adv_5152601_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們可是打倒那樣的大傢伙，守護了海灘的和平啊？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種程度是理所當然的權利啦。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為",
        "unit_id": 107512,
        "voice": "vo_adv_5152601_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在是夏天，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而這裡是海邊呀！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不好好享受一番可就虧大了！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海水浴、",
        "unit_id": 107612,
        "voice": "vo_adv_5152601_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沙灘排球、",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "烤肉……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們就盡情享受",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各種夏天的代表性活動吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這正是",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夏日假期呀。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那樣也是",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "「夏日佳期」呀。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我好像能理解了呢。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 107512,
        "voice": "vo_adv_5152601_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n愛蜜莉雅的世界有沒有什麼",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夏天特有的事物呢？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以的話希望妳能告訴我。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想想，",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_006"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然不知道是不是夏天特有的……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "如果是那個的話，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "「廣播體操」怎麼樣？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的廣播體操，",
        "unit_id": 107612,
        "voice": "vo_adv_5152601_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是以前",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛蜜莉雅小姐展示過，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很多人一起跳的那種舞蹈嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒錯。",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_008"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n昴之前說夏天做的廣播體操是很特別的喔。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "大家每天早上在固定的時間集合，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "然後一起做。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "說是多虧了這個讓他能調整生活習慣，",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_009"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也能當成開始玩耍前的暖身運動。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還有，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "參加的人可以被蓋一個章，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "收集之後……",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "收集之後……？",
        "unit_id": 107812,
        "voice": "vo_adv_5152601_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道說，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以獲得什麼好東西嗎？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "收集印章之後，",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "會非～常高興喔！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼都沒得拿啊！！",
        "unit_id": 107812,
        "voice": "vo_adv_5152601_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 107512,
        "voice": "vo_adv_5152601_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那確實感覺很有趣呢。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n廣播體操，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我久違地想要做做看呢！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "透過廣播體操",
        "unit_id": 107612,
        "voice": "vo_adv_5152601_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進一步感受夏天氛圍，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是個很棒的點子呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也讓其他公會的各位，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起來體驗吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107812,
        "voice": "vo_adv_5152601_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是那樣的話我也來參加吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是那個啊，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得要練習跳舞才行呢……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然我也不是很了解廣播體操，",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_016"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n但我覺得重要的是，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "大家一起開心地做喔。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們一起來想",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "能輕鬆做出來的動作應該也可以吧？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 107612,
        "voice": "vo_adv_5152601_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "決定好每一天負責帶頭的人，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請那個人",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向大家示範動作，這個主意如何呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "聽起來非～常有趣呢！",
        "unit_id": 131911,
        "voice": "vo_adv_5152601_018"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我要把各種不同的廣播體操記下來，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "然後也教給昴。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以那樣嗎！？",
        "unit_id": 107812,
        "voice": "vo_adv_5152601_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "異世界還真是相當自由呢……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 107512,
        "voice": "vo_adv_5152601_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起開始做吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾式‧",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "廣播體操！",
        "unit_id": 107512
    }
]