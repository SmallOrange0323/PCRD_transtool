    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "媽媽～！",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_055"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳們兩個，",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_056"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有受傷吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "沒事～！",
        "unit_id": 102011,
        "voice": "vo_adv_2103005_057"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "就只是黏答答的而已！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唔～",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_058"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這些傢伙，",
