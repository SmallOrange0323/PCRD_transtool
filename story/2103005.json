        "name": "禊",
        "words": "有了有了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n鏡華！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可可蘿！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這裡這裡！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "等等！",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_047"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這傢伙是誰啊！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "別欺負哥哥他們呀～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳這傢伙是誰啊，",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_048"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "吵死了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你們去和那群小鬼玩玩，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "紅的藍的黃的！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕噗嚕嚕！",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
