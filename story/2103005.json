        "voice": "vo_adv_2103005_064"
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕噗嚕噗嚕！",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼！",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_065"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n就憑妳一個人就想要當我的對手嗎！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就憑妖精族的小鬼！",
