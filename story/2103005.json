        "voice": "vo_adv_2103005_059"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這次是妳嗎！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n別礙事啦！　",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳這個妖精族的小鬼！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "你那邊才是……",
        "unit_id": 105911,
        "voice": "vo_adv_2103005_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請別妨礙主人與我們相處的時間！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【憤怒‧軍團】的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卡里莎……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105911,
        "voice": "vo_adv_2103005_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請稍待一會兒！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會先將",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這名少年趕走……！",
