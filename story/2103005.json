        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 180511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同先前的貪吃佩可小姐與優衣小姐一樣，",
        "unit_id": 180511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下能夠維持『公主型態』的時間",
        "unit_id": 180511
    },
