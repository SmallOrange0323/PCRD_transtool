    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼！",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_069"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n真拿妳沒辦法！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "上吧，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "阿諾爾德！　",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "伊諾利斯！",
