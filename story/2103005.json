        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在主人",
        "unit_id": 180511,
        "voice": "vo_adv_2103005_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "尚未能夠完全駕馭這份力量的現在……",
        "unit_id": 180511
    },
