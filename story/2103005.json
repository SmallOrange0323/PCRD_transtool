        "words": "嚕啦啦～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我們玩了好多遊戲呢～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "玩了好多呀～♪",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘻嘻。",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n如果哥哥能一直是這樣子那一定會很有趣的啊～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華妳也這麼覺得吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要說那種蠢話了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……雖然說，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天我也過得很開心……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是果然，",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果繼續這樣下去會很令人困擾的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個人雖然變態，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且是個可疑份子，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n又愛惡作劇，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是個讓人拿他無可奈何的人……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……可是可是。",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "之前……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "姑且，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "偶爾……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "或許還是稍微有點帥的時候，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也不能說完全都沒有這樣覺得過。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "值得信賴的人們正著手盡力在想辦法了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想必不用多久的時間，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人便能",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恢復原貌了才是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "真的嗎！？",
        "unit_id": 102011,
        "voice": "vo_adv_2103005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一塊來祈禱吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "況且……",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算經歷了無數的辦法最後卻皆以失敗告終。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也必定，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會將主人養育成一位值得眾人所引以為傲之人的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟得花費多長的時間……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "葛格～",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "葛格～",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那是",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "什～麼～？",
        "unit_id": 106414
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "噗嚕噗嚕噗嚕噗嚕……",
        "unit_id": 191612
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是什麼呢～？",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "話又說回來呀～",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "剛剛鏡華的那個真是太搞笑了呢～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳是什麼意思呀，真是的。",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "更何況懲罰遊戲竟然是要吃青椒，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳一開始又沒有講！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿。",
        "unit_id": 102011,
        "voice": "vo_adv_2103005_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n如果是紅蘿蔔的話，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美就能幫妳吃了呢～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的。",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果可可蘿沒有煮得好讓人嚥下去的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還真不知道會怎樣……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……可可蘿？",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "——沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n向主人教導語言、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "教導文字、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "教導何謂文化。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在各式各樣無窮無盡的事物上指引著他……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這些事就由在下來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "？",
        "unit_id": 102011,
        "voice": "vo_adv_2103005_024"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n……可可蘿？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n妳怎麼了？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "——啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "剛剛",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的非常感謝妳。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n為了能讓青椒可以更好嚥下口，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳還特地替我炸成了天婦羅……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用客氣。",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要像那樣去除苦味，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管是再小的孩子們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都能展現笑容享用。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下說的對吧，",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 105913,
        "voice": "vo_adv_2103005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不見了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "雪菲也不見了唷？",
        "unit_id": 102011,
        "voice": "vo_adv_2103005_031"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n明明直到剛剛",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "都還走在我們旁邊的……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦咦！？",
        "unit_id": 103611,
        "voice": "vo_adv_2103005_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就在轉眼間，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有看著他們就……！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——{player}和雪菲兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因為對史萊姆奇怪的動作感到有趣而被吸引，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n所以一直朝著小巷子的深處走了進去……"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等、等等～♪",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n噗嚕噗嚕～！",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕噗嚕噗嚕……",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等、等等～♪",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……？",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "很～好很好。",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_035"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n很順利地把他們釣過來了……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "紅的藍的黃的，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "以你們來說算做得不錯嘛。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……啊啊～！",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_036"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你、",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是……！",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "唷。",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_037"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n模索路晶的公主騎士。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你似乎記得我的長相呢。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我稍微有點事，",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_038"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "只想要找你這傢伙呢。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "雖然多餘的龍族女也跟著你過來了，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不過嘛，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就當算了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……總之，",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_039"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我很不爽你這傢伙啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n雖然我還有其他該做的事沒錯。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "但是，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你欠我的這一份該先讓你還清啦。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "讓我的垃圾魔獸們被人打爆的，",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_040"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你那個讓人搞不懂的強化能力。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "結果說到頭來，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "還是你這傢伙的能力最棘手啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……但也就是說。",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_041"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n只要趁你這傢伙……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "像現在這樣落單的時候把你給宰了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "剩下的那個粉紅毛和白癡王女",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "也不過就是幾隻雜魚而已了啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈。",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_042"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "才不會讓你跑掉啦！",
        "unit_id": 191611
    },
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊嗚～！",
        "unit_id": 106414,
        "voice": "vo_adv_2103005_043"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_044"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你可別怪我了啊？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這可是戰鬥啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "相對的——",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "做為替你上香的供品。",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_045"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我不會忘記把那隻囂張的垃圾貓，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "也連你一起塞進墳墓去啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你就感謝我的大恩大德吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！　",
        "unit_id": 100411,
        "voice": "vo_adv_2103005_046"
    },
    {
