    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下並非只有一人！",
        "unit_id": 105911,
        "voice": "vo_adv_2103005_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人——",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您賜予在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "力量！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "轉換",
        "unit_id": 105911,
        "voice": "vo_adv_2103005_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "‧公主型態！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊啊！？",
        "unit_id": 191611,
        "voice": "vo_adv_2103005_068"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n就連妳這傢伙也能變成那個模樣了嗎！？",
