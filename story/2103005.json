        "voice": "vo_adv_2103005_063"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "把這個史萊姆",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "打倒的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你這傢伙～！",
