[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀、",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀啊啊啊！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n討厭討厭討厭！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有好大隻的魔物！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "牠、",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "牠在看這裡！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥好可怕，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎麼辦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "既然如此，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就用噗吉全力揮擊……！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，不可以？",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n太危險了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可、",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是魔物就在那裡！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n如果不打倒牠，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會被牠給吃掉呀～！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯。",
        "unit_id": 2111,
        "voice": "vo_adv_1023003_004"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n其他弱小的魔物",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n是害怕那個大塊頭才逃離這附近的吧。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「難怪……",
        "unit_id": 2111,
        "voice": "vo_adv_1023003_005"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n森林裡明明應該是危險地區，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我們卻完全沒有遇到魔物。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們卻和最危險的魔物撞個正著了呀！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n運氣再差也該有個限度啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為什麼？",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我明明就很聽話！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是當乖孩子，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n應該就能獲得幸福啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是、是因為我不遵守咲戀媽媽的叮嚀，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n擅自跑進森林裡的關係？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為我是壞孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "才會遇到這麼恐怖的事？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔、",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n拉住我的手～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我害怕到",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "腳都快軟了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n腳沒辦法好好走，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以你拉著我的手快點逃！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也可以抱著我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦？",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你光是被我的噗吉全力揮擊給波及，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就會暈過去的說！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你、你不可能打得贏那種魔物啦！",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們快點逃吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥～！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呼～",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噫！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n總、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總算逃離魔物了……！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「是啊，",
        "unit_id": 2111,
        "voice": "vo_adv_1023003_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "總之暫時安心了。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n看來我們在逃跑時，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "也剛好跑到道路上來了。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n也不會",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "因迷路而回不了家了。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「總之，",
        "unit_id": 2111,
        "voice": "vo_adv_1023003_016"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這算是結果圓滿吧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n只要結果好，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就一切都好。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔……",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有得到感冒藥的材料。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也害怕到",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不敢再進去",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "森林裡了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊～啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有總白費功夫的吃虧感。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，光是能活著回去，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算運氣好了吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "「姐姐」要是沒有回去，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n胡桃也會覺得很寂寞吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而且咲戀媽媽",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和鈴莓，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還有其他人也都會擔心呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒有給家人添麻煩，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是太好了。",
        "unit_id": 102311
    },
    {
        "type": "still",
        "still": "102300301"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇、啊啊？",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼了，哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你為什麼要「背」我……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然這對我來說正好需要，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我的確已經累到快不能動了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是感覺像是被當小孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我不開心！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "已經是個成熟的淑女囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我可是「姐姐」喔……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "受到咲戀媽媽的拜託……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n而來找我的？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以你才會在森林裡呀……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽看到書房翻開的書本，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以推測我們「可能是去森林了」吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "原來是這麼回事。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你順利回收我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "任務達成了呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "恭喜你啊～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是的。",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽她",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n老早就猜透我要做的事了啊……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是無所謂。",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n人家擔心我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n叫表示人家有重視我，對吧……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "跑了好多路，好累喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以就這樣睡一覺嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這可是我人生",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "第一次的大冒險呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "結果",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然很可惜……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但感覺",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "自己似乎成長了一點～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有得到",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "製藥的材料……",
