    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以相對的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會盡力去照顧胡桃。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也可以去拜託咲戀媽媽",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n讓我預支零用錢去買藥。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是個小孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還有很多做不到的事情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但我會努力去思考，",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後行動，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "希望可以守護自己珍惜的事物。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我要一件一件",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n去學會各種事情……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "成為出色的「姐姐」。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "希望至少",
        "unit_id": 102311,
        "voice": "vo_adv_1023003_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n能夠變強到足以保護家人。",
        "unit_id": 102311
    }
