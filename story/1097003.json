    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "美乃滋不夠……！",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請、",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問是怎麼了嗎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "突然間",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說出那樣的話……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "啊，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "很抱歉這麼突然……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n不小心",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就慌了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗯，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那是一種調味料。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這也是昴告訴雷姆的東西……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那是昴最喜歡的味道，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_004"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n所以那邊世界的宅邸",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "總是會常備著存貨。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "在這裡並沒有製作美乃滋，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "所以",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "等到真的想用的時候，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "才發現手邊並沒有……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因此，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "必須要盡快",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n在這裡製作美乃滋才行！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐的心情在下明白了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們應該做什麼才好？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_009"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "畢竟機會難得，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n所以比起做一般的美乃滋，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還是想用這裡的特產",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "做出特別的美乃滋吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "為此，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n希望兩位",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能和雷姆一起去採買……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "採買是嗎。",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明白了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是很想與您一起去……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但其實這之後，",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有事必須外出處理……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人好像",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有送貨的工作吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "送貨的工作，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_013"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n請問，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個工作",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆也可以一起去嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "要是可以的話，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_014"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請讓雷姆也一起去，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n然後在回來路上把東西買完，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請問這樣如何呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這是我擅自提出的請求，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_015"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n就算被拒絕也是無可奈何的，但……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "咦，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可以嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果主人和雷姆小姐一起的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也能放心地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "送兩位出門了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1097003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以將主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "交給您嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_018"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我明白了！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請交給雷姆吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "非常感謝！",
        "unit_id": 109711
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "所以說，",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_019"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "送貨的地點就是這裡嗎……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是【伊麗莎白牧場】",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "對吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是的啦！",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳是第一次見到的客人呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我是這個牧場的主人，真陽啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝妳特地把東西送過來呀～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "妳真是太客氣了。",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_022"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我叫做雷姆。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "現在正受到{player}先生",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_023"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n和【美食殿堂】各位的照顧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請多多指教。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "受到{player}照顧……？",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我看起來倒覺得在照顧人的是雷姆耶？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳把他背了過來，",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還用扇子幫他搧風，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "感覺照顧得",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "無微不至啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為這裡",
        "unit_id": 109711,
        "voice": "vo_adv_1097003_026"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是位於山上的牧場，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n他在路上擦傷了膝蓋。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣啊這樣啊～",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "得要小心才行啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果你們不是在只有我一個人的時候來就好了啊～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我現在一個人",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要處理牧場的事而忙不過來呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n從剛才就忙得不可開交啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔嗯～",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在時機很不巧呢～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n剛好",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家都有事情要忙。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪和栞栞出去了，",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴也被【哞哞自衛隊】叫出去了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而我",
        "unit_id": 103311,
        "voice": "vo_adv_1097003_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也要照顧牛隻們，所以忙得不得了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "其實原本是想趁鈴鈴不在的時候，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n打掃被鈴鈴弄亂的房間。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "打掃房間，",
