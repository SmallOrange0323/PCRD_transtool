        "voice": "vo_adv_1268003_076"
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "感覺一點也不意外，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "看起來也不像是稍微略懂一點點……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然你們好像對觀光和水產資源的方案不感興趣……",
