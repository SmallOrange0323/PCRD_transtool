        "words": "那是因為你們先攻擊過來了啊。",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_063"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我想說的只有一件事。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們在這種地方偷偷摸摸地私釀，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_064"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n都不會對麥酒感到羞愧嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "這是",
        "unit_id": 1411,
        "voice": "vo_adv_1268003_065"
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "什麼意思？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "應該要更加盛大地宣傳，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_066"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n讓它可以在那個超棒的海灘上喝到才對啊！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們也不是喜歡才這樣偷偷摸摸的。",
        "unit_id": 511,
        "voice": "vo_adv_1268003_067"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但是，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這種規模的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "麥酒釀造場",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "如果沒有國家許可，\n是會被問罪的吧？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "何況我聽說事後申請",
        "unit_id": 511,
        "voice": "vo_adv_1268003_068"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "還會收取追徵金，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n但是這個村莊沒有可以繳納的錢……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "所以，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "為了守護村莊的傳統才會不得不……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼嘛，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_069"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "原來是在意那種事啊？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個沒問題啦。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為這邊",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是神殿嘛。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在大概兩百年前的時候，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_070"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "做為神殿維持費的資金源，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n神殿取得了釀造麥酒的特別授權許可。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那條法律現在也還存在喔。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "那、",
        "unit_id": 414,
        "voice": "vo_adv_1268003_071"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "那是真的嗎！？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_072"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這也有出現在今年的「國家認證準一級聖騎士資格測驗」題目裡。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為是完全合法的，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以也不會有追徵金。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_073"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果是關於資金面的問題可以找我商量喔。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我還沒有給你",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的名片對吧。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "【墨丘利財團】……？",
        "unit_id": 511,
        "voice": "vo_adv_1268003_074"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我記得",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那是王都也相當有名的企業公會……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們或許會很意外，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_075"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但其實我",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很喜歡麥酒……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以關於麥酒",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也稍微略懂一點點。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "不過",
