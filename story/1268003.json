        "voice": "vo_adv_1268003_083"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "非",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "常感謝。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是身為聖騎士，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而是做為一個麥酒愛好者……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會盡我所能的！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是圍繞在優花梨的「國家認證準一級聖騎士資格測驗」的騷動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就這樣和平落幕了。"
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在收到優花梨的報告後，【墨丘利財團】立刻送了援助到村莊來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓村莊轉眼間就充滿了活力。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這樣的情況下，{player}與優花梨被找去海邊。"
    },
