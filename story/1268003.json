        "voice": "vo_adv_1268003_077"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但如果是以這種麥酒為核心的振興村莊……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能否讓我來幫忙呢？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "可是，",
        "unit_id": 4911,
        "voice": "vo_adv_1268003_078"
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "不覺得事情聽起來太美好了嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "\n是不是",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "背後有什麼陰謀……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "村長，",
        "unit_id": 414,
        "voice": "vo_adv_1268003_079"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "那樣好嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "當然",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "如果是真的，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "那的確是很美好啦……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}……",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_080"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這兩個人的眼神都非常真誠……",
        "unit_id": 511,
        "voice": "vo_adv_1268003_081"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我明白了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我就相信你們看看吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我都已經下定決心，",
        "unit_id": 511,
        "voice": "vo_adv_1268003_082"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n要讓這兩個人見證這個村莊麥酒的末路了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "就算被背叛了我也不後悔……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……！",
