        "name": "村長",
        "words": "優花梨大人",
        "unit_id": 511,
        "voice": "vo_adv_1268003_088"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是這個村莊的大恩人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n這件事是全體村民的共同意見，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "也是全村的請託。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n還請您",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "務必幫我們這個忙！",
