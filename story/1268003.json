    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "需要有銷售策略。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n她說為此，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "必須要有海報。",
