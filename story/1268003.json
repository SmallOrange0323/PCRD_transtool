[
    {
        "type": "background",
        "background": "501570"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "融入在夜晚的黑暗中，{player}與優花梨監視著神殿。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不久後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在兩人的眼前出現了一群人。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然……",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你看。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n有人過來了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "呼……",
        "unit_id": 511,
        "voice": "vo_adv_1268003_001"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "說起來還真是",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "令人頭疼啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n沒想到中央會派聖騎士過來……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "不過",
        "unit_id": 414,
        "voice": "vo_adv_1268003_002"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "目前正在測驗中，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "所以正確來說不是聖騎士啦。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "但是",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "差點就要露餡，嚇死我了……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那還不都是因為你多嘴。",
        "unit_id": 511,
        "voice": "vo_adv_1268003_003"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這個村莊的祕密可不能被傳出去。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n得想辦法隱瞞過去才行……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "就是說啊。",
        "unit_id": 414,
        "voice": "vo_adv_1268003_004"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n要是曝光了，那可就完了……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……你有聽到",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他們說的嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽起來神殿裡面確實有藏著什麼東西呢。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不知道裡面會有什麼在等著呢。",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n進去可能會有危險……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……你可以的話，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那我們就走吧。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就拜託你囉。",
        "unit_id": 126811
    },
    {
        "type": "background",
        "background": "500342"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優花梨與{player}就這樣尾隨村長他們進入神殿內部。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而神殿內部的通道連接著位於地下的可疑小房間。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……總覺得",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有點涼耶。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n難道是",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "地下的",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "儲藏庫嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "穿泳裝來",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好像是個敗筆呢……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就、",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就這麼辦好了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對啦！　",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在要以保持警戒為優先。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n畢竟不知道會發生什麼事，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要維持方便活動的狀態才行。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說回來，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個神殿的構造",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我好像在哪裡看過……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "停下來！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他們就在這前面呢。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "所以",
        "unit_id": 511,
        "voice": "vo_adv_1268003_011"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這次的品質如何？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "哼嘿嘿，",
        "unit_id": 414,
        "voice": "vo_adv_1268003_012"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "是這幾年來最棒的呢。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n讚到會讓人升天喔。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這樣啊，",
        "unit_id": 511,
        "voice": "vo_adv_1268003_013"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那還真令人期待呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "要是沒有那個聖騎士，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們就能在白天進行了……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他們好像在製造什麼東西……",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個味道……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可是……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不會吧，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該不會就是……？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "充斥在周遭、",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這股融合了獨特芬芳與甜味的濃厚香氣。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "知道這個！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是好奇怪……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在這種地方應該不可能會有才對……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這能讓人預期會有獨特暢快感的香醇風味……！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "肯定沒錯，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這就是",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "傳說中的……！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "什麼人！",
        "unit_id": 511,
        "voice": "vo_adv_1268003_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好像被發現了呢。",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是「國家認證準一級聖騎士資格測驗」的考生，優花梨。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "為、",
        "unit_id": 414,
        "voice": "vo_adv_1268003_019"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "為什麼你們會在這裡！？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "果然",
        "unit_id": 511,
        "voice": "vo_adv_1268003_020"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是來探查了啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雖然希望你們能在一無所知的狀態下離開……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但既然都被你們知道了，可不能就這樣放你們走。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很抱歉我擅自尾隨你們。",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n針對沒有聽從忠告這件事我也道歉。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是來調查這個村莊的問題的。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了自己的測驗。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在不一樣了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n既然看到了這裡，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可就沒有辦法那樣說呢。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "哼，",
        "unit_id": 511,
        "voice": "vo_adv_1268003_023"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "看你那麼年輕，不知道也沒辦法。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "沒錯，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這裡是……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是麥酒的私釀廠！",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n難怪",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "根本就不需要賣麥酒的商店呢，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為是像這樣自己釀造的。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "所以才會說聖騎士大人洞悉一切嗎……",
        "unit_id": 414,
        "voice": "vo_adv_1268003_025"
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "\n沒辦法了！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "你們幾個，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民1",
        "words": "要上了！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村民2",
        "words": "好！",
        "unit_id": 1411,
        "voice": "vo_adv_1268003_026"
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "要要要、",
        "unit_id": 4911,
        "voice": "vo_adv_1268003_027"
    },
    {
        "type": "dialogue",
        "name": "村民3",
        "words": "要上了！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們這些人！",
        "unit_id": 126811,
        "voice": "vo_adv_1268003_028"
    },
    {
