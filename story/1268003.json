        "voice": "vo_adv_1268003_085"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然不做不行嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "因為有【墨丘利財團】大力協助，",
