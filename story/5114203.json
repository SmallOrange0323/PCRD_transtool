    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這職員教育訓練的難度也太高了喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 125211,
        "voice": "vo_adv_5114203_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "總算讓牠冷靜下來了。",
        "unit_id": 125211
    },
    {
