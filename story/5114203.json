        "words": "那麼，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "接下來該怎麼辦才好呢……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵？",
        "unit_id": 125111,
        "voice": "vo_adv_5114203_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n剛剛還以為牠變乖了……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但氣氛好像不太對勁喵～？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳說什麼！？",
        "unit_id": 125211,
        "voice": "vo_adv_5114203_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們明明還得",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "趕快去做營業前的準備耶……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒辦法啊。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然事情都這樣了，可不能退縮！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再加把勁，",
        "unit_id": 125111,
        "voice": "vo_adv_5114203_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "給牠好看喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
