[
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔，",
        "unit_id": 101411,
        "voice": "vo_adv_5092322_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "魔物們突然聚集起來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣下去就沒辦法攻擊守護者了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼，",
        "unit_id": 121911,
        "voice": "vo_adv_5092322_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "應該是小弟們在保護老大吧。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真是會耍小聰明。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過",
        "unit_id": 122011,
        "voice": "vo_adv_5092322_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "每一隻魔物都很難擊倒，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "攻擊力也不能小看。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再加上",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼大量的魔物要是湧上來，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n難保會被它們強行壓制。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不愧是占卜師，",
        "unit_id": 101411,
        "voice": "vo_adv_5092322_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是敏銳的觀察力呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "忍。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡就由我和忍來掩護，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓杏奈能確實的擊倒每一隻魔物，妳覺得如何？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真有意思。",
        "unit_id": 121911,
        "voice": "vo_adv_5092322_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不管有多少數量，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "它們都是一群烏合之眾。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓它們曉得，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不可能和擁有智慧和羈絆的我們為敵！",
        "unit_id": 121911
    }
]