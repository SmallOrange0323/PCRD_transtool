    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "薇歐莉特公主──",
        "unit_id": 126511,
        "voice": "vo_adv_5213301_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n妳那副模樣究竟是……！？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁想必覺醒了如汪洋般，",
        "unit_id": 129711,
        "voice": "vo_adv_5213301_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "包羅萬象的慈悲之心吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此景此情，恰如親見神佛天降，令人心生敬畏。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "從內心深處湧現出的這份情感，",
        "unit_id": 138012,
        "voice": "vo_adv_5213301_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "正是慈愛。",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "無論發生什麼事，",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我都要守護",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "國家與子民──",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而這……",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "正是，",
        "unit_id": 138012,
        "voice": "vo_adv_5213301_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我的驕傲！",
        "unit_id": 138012
    }
