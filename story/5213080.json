[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "於吉歐‧格黑納橫行之魔物，",
        "unit_id": 129711,
        "voice": "vo_adv_5213080_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可謂千奇百怪、種類繁多。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "譬如，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此乃翱翔天際的龐大鳥獸。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不僅體型龐大，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "份量亦相當可觀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖不及萬花菲尼克斯那般誇張，",
        "unit_id": 129711,
        "voice": "vo_adv_5213080_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但無論捕捉或烹食，皆需費一番功夫。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "話雖如此，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "食用所能得之滋養，奴家可以擔保。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不妨以此為用餐兼修行之道。",
        "unit_id": 129711
    }
]