[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和初音一起來買東西。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想要改造房間，讓它看起來更可愛──。",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n如果有可愛的擺飾就好了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n可是不知道該選什麼。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也想聽聽你的意見，",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就叫你來了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，我們趕快去買東西──",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇，",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好刺眼……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這是，之前的……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "奇、奇怪……？",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n又變得好想睡……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕。",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "510010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "動物園真好玩呢～",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂喂，我們去看看伴手禮吧──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得來一趟，我想買禮物送小栞──♪",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哪個好呢──？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，這個熊貓玩偶也許不錯！",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這種可愛的東西很適合小栞對吧──。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 你、你說也很適合我……！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_008"
    },
    {
        "type": "still",
        "still": "101200801"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦咦──才沒那回事呢──。",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n適合我的是……這個老虎之類的！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": " 吼──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "吼──，吼──！",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我要吃掉你喔──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……什麼？ 你不好吃……？",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是嗎？ 看起來很好吃呢──。",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n而且你身形比我大，吃了好像會很有飽足感～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且，你非常溫柔、有趣、",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n認真、帥氣、親切……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦、咦？",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這些應該和看起來很好吃無關……？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、啊哈哈……",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我在說什麼啊？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為什麼你要配合啊！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是說……我、我不會真的吃掉你啦──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、那是當然的啊──！",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你把我當成什麼啦！？",
        "unit_id": 101231
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是的──，都是你說了奇怪的話，害我嚇一跳……",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為了賠罪，你要買這隻老虎給我？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎！？ ",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那麼，也讓我給你回禮。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咬。",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿……吃、吃掉了。",
        "unit_id": 101231,
        "voice": "vo_adv_1012008_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖、雖然是臉頰……",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "初音相當大膽呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我很驚訝呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咬是怎樣啊！ 咬！？",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不覺得太可愛了嗎！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，你們似乎像在『那邊』的時候一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在『這邊』也保持友好的關係，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請暫時再享受一會這樣的生活吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不久之後應該需要麻煩你努力，",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在那之前，請好好享受吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，這次就先聊到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1012008_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～，下次見囉 ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼……我又睡著了？",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，你也睡著了呀──。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 動物園的夢！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我也做了那個夢喔──",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "之前也發生過這種事對吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，對了！ 我房間的改造，",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你覺得放玩偶怎麼樣？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我覺得很可愛呢──",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦，你要買給我！？ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太棒了──！ 謝謝──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n必須要送點什麼謝謝你呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 說、說到謝禮……？",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，那個……不、不是啦！",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我在夢裡吃了你，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n該說是因為一時衝動……因為太開心，所以忍不住……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚、嗚……雖說是夢，",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但我怎麼會做出那種事……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不算，不──算！",
        "unit_id": 101211,
        "voice": "vo_adv_1012008_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "給我把夢忘掉──！！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音因為太過害羞，\n而當場逃走了。"
    }
]