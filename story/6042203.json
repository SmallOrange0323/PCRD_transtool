[
    {
        "type": "background",
        "background": "501000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "救世主嗎……",
        "unit_id": 113011,
        "voice": "vo_adv_6042203_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "璃乃真是厲害呢！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總覺得她比平時",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "更沒精神耶……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "平常她見到前輩的話都會",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "激烈地",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "飛撲過來不是嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 113011,
        "voice": "vo_adv_6042203_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那種事情是應該的！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為我想變得",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n和璃乃一樣",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "積極向上……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以，為了讓璃乃\n恢復往常開朗的模樣，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也必須",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "做點什麼才行！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "發生什麼事了嗎……",
        "unit_id": 113011,
        "voice": "vo_adv_6042203_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真讓人擔心。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有沒有什麼是我能幫上忙的呢……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總之，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我先去暗中",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "觀察一下璃乃！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣或許能看出點什麼！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 113011,
        "voice": "vo_adv_6042203_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n沒、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒這回事，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該說我只是偶然間看到過很多次，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "並、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "並不是因為我一直注視著前輩才……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃……",
        "unit_id": 113011
    }
]