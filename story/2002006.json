[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又見面了呢，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "歡迎，來到幕間的故事。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓你和我，一塊享受這美好的密會吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是嘛，你呀這次也地被捲入了大事件之中呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要有你在的地方就會發生騷動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "主角可真辛苦呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次比較像是克莉絲提娜的個人秀",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的感覺呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，她看起來凶神惡煞也是沒辦法的事唷，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為她也是這個世界的重要人物呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就和你一樣呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要有重要人物出現的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "故事就會產生劇烈的動搖與影響。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你這一次，則是被那龐大的脈絡……",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n被那命運的大浪給徹底捲進去了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管怎麼說。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次你所體驗的這些事情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若沒有理解「公會」這概念，大概不太能夠明白呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你已經從誰那聽過了一次說明。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以真想知道的更詳細，那就試著回頭反芻一下過去的記憶吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯但是這次我還是會簡單地告訴你個大概就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在你們所居住的，這名為蘭德索爾的城鎮中……",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所有的居民，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都有義務，必須要參與一個被稱呼為公會的集團。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個就形同戶籍一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若沒有所屬於任何一間公會，是不會被承認他的住民身分的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n無法接受各種社會福利，以及公共服務呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連找工作也相當不方便呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但，也只有在蘭德索爾能使用這套概念。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若是從他處前來的旅人，則可免去這些問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但以你的故事來看，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是以蘭德索爾地區為中心展開的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以絕對無法無視公會這件事呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接著，這個國度",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n代代皆由王族統治，也就是所謂的中央集權政治。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而那居住著支配者立場的王族的地方，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n則稱作王宮呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也因此，王族……",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也常常有人以『王宮』稱呼支配者的人們呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而『王宮』直轄的公會，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n則叫做【公主騎士】唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "各種的局處、警察與消防、司法部門，等等五花八門……",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要是為官方公職機關，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n全都算是【公主騎士】呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "講真的嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幾乎可說是政府機關～的意思了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而襲擊了你們的，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n克莉絲提娜她所屬的公會……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是隸屬於【公主騎士】旗下的",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "【王宮騎士團】公會唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可說是『王宮』直屬的軍力，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是同時扮演了警察與軍隊角色的公會喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然在這個世界中，因為經歷了長時間的和平時代，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以預算被削減而弱化了不少",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但儘管如此，【王宮騎士團】以政府機關的名義，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可說是代表這個國家的正義也不為過呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你們一行人，不知為何被這群傢伙們給盯上了喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這次看起來像是克莉絲提娜個人的武斷決定就是了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過你們仍像是被當成罪犯，而被警方給緊咬著不放唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管最後躲過了立即性的危機，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但狀況可能不太樂觀呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "往後的處理若沒處理好，可就無路可退了唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟對方就算再腐敗，也是這個國家的警察……，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是象徵整個國家的【公主騎士】唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……說到公主騎士。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最好連這個詞也牢牢記住喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還記得吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n握有世界之謎關鍵的那個矛依未，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不是也曾對這詞彙有過強烈的反應嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你應該也忘了就是了。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管如此，它也是個相當重要的名字唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "漫長的一日終於結束了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來，你終於能在安全的場所中好好休息了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個地方名為【咲戀育幼院】，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也將成為你往後生活的地方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "它也是今天一整天與你一塊的，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那位鈴莓所屬公會的據點唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴莓的主人、咲戀，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎也願意為你們提供保護的樣子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在她的身邊接受這份庇護過夜吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很想跟你說，你可以暫時安心點……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鑽進那溫暖的床鋪，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好好地睡個好覺。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀～。",
        "unit_id": 190011,
        "voice": "vo_adv_2002006_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n照這樣看來，這『漫長的一天』似乎還沒結束呢。",
        "unit_id": 190011
    },
    {
