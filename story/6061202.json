    {
        "type": "dialogue",
        "name": "真步",
        "words": "您覺得如何呢？",
        "unit_id": 116011,
        "voice": "vo_adv_6061202_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是人家為了這次的任務",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所準備的禮服。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還挺有自信的喔～♪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇～",
        "unit_id": 116011,
        "voice": "vo_adv_6061202_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生坦率的讚美，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家好感動～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒有半點虛情假意的讚美，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會讓少女顯得更加耀眼奪目喔。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再多讚美幾句吧～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀是呀～？",
        "unit_id": 116011,
        "voice": "vo_adv_6061202_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這件禮服充滿了許多人家對細節的堅持。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且這次",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我也準備了真琴的禮服。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到時還請多多",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讚美她一下喔～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您說了會讓人家開心的話呢，",
        "unit_id": 116011,
        "voice": "vo_adv_6061202_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "回到蘭德索爾之後，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家馬上就為您測量尺寸。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是真琴也能",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像這樣坦率地",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "穿上我做的禮服就好了。",
        "unit_id": 116011
    }
]