    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "原來如此原來如此。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯、",
        "unit_id": 100911,
        "voice": "vo_adv_7007003_021"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯嗯……",
