[
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這次來的，是長得跟我們很像的敵人嗎……！",
        "unit_id": 117311,
        "voice": "vo_adv_5072322_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這樣接二連三地來襲，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "感覺已經累積了不少疲勞呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然要模仿我們，",
        "unit_id": 117411,
        "voice": "vo_adv_5072322_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就不要來妨礙舞台上的表演啦！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有著跟我們一樣的外貌和",
        "unit_id": 117211,
        "voice": "vo_adv_5072322_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "相同的動作……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是以前的我們。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n現在的我們已經不一樣了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我們",
        "unit_id": 117211,
        "voice": "vo_adv_5072322_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即便是站在這舞台的當下，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也一直都在成長。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072322_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不會去否定過去的自己。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯。",
        "unit_id": 117411,
        "voice": "vo_adv_5072322_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正因為有過去的自己，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有那段經歷過的歷史，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才有現在的我們。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我們超越過去的自己吧。",
        "unit_id": 117211,
        "voice": "vo_adv_5072322_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n要好好跟上來喔！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "好的！",
        "unit_id": 1,
        "voice": "vo_adv_5072322_007"
    }
]