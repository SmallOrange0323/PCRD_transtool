[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束竹葉舟海釣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到岸上的{player}等人──"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像有點放鬆過頭了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你覺得怎麼樣？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "玩得還開心嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也是。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n很雅致的休閒娛樂呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來呢？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有沒有什麼想做的事呀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……怎麼，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的肚子餓得發慌了嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "竟然都中午了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們釣魚釣到忘我了呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正好，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "魚也釣到了",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不如準備吃午餐吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "機會難得，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就來料理這些鮮魚。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別太過度期待啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我只不過是會做點料理，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "並不是專業廚師喔。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是呀，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現釣的魚是無可比擬的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n究竟差距有多大，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你就親自吃了確認看看吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大叔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟你打聽一下。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這裡有",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以處理魚的地方嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "喔，",
        "unit_id": 1411,
        "voice": "vo_adv_1131002_008"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "倒是有個",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "給釣客和露營客用的炊事場。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這邊的遊客大多都是去那裡處理食材的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "只要沿著那條路直走就會看見了。",
        "unit_id": 1411,
        "voice": "vo_adv_1131002_009"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "服務台有提供器具，可以跟他們借。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "過去那邊看看吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "歡迎光臨～",
        "unit_id": 411,
        "voice": "vo_adv_1131002_011"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "兩位嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你們是不是",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "剛去體驗過竹葉舟海釣呢？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對呀。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n聽說這裡有提供場地",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "處理剛才釣到的魚。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有的，",
        "unit_id": 411,
        "voice": "vo_adv_1131002_013"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們的炊事場可供遊客使用喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "使用費為500盧幣，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可以嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "地點是隨我們挑嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這個嘛～",
        "unit_id": 411,
        "voice": "vo_adv_1131002_015"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "客人是情侶的話，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們有推薦景色優美的地點──",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦！？",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等等，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是的！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們只是，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "單純的好朋友，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "普通的地點就可以了，普通的！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哎呀，",
        "unit_id": 411,
        "voice": "vo_adv_1131002_017"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "失禮了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們並沒有特別指定客人的位置，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "兩位請自便。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──就在這裡吧。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "肚子也餓了吧？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我現在就做料理，你等一下啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你有興趣的話，當然可以呀。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不然",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你試著拿看看菜刀？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……嗯，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我覺得你還是別動手吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n像你那麼危險的拿法，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會看不下去的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心，我一個人能搞定的。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n魚的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我三兩下就能處理好。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "事實勝於雄辯，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不如讓你親眼看看。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "先刮掉魚鱗……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看好，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要開始囉。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像這樣",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拿菜刀在這裡劃幾刀……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你看，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一眨眼就分出魚肉和骨頭了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再切成一片一片的，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "生魚片就完成啦。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "之後也差不多是這樣，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "放心吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔……",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你能幫忙煮個飯嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n只有生魚片",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也吃不飽吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不對，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等一下。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n說到底",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你會煮飯嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒問題嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你知道怎麼用釜鍋？",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那白飯",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像可以放心交給你。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就拜託你囉。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "待會我們一起做魚骨湯吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣一來，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "馬上就能做出生魚片定食了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大功告成！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n來，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "從這道鮮度超群的生魚片開始吃看看吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很好吃對吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種魚",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "平時是不會做成生魚片料理的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種魚很容易損傷，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "街上幾乎沒有在賣。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這可是現釣的時候才能品嚐到的奢侈料理呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也喝看看魚骨湯吧。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這種天氣炎熱又易出汗，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以我有把味道弄得比較濃一些。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不用這麼急啦。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n飯要多少有多少，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你慢慢吃吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好事？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……喔，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你是說我看起來很開心嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那是因為看到你吃得很香，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "忍不住就……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和我一個人吃的時候相比，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "料理本身雖然沒有太大的差別。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但身旁能有個人吃得很開心，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺就完全不一樣了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_036"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的情緒還全寫在臉上。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可以近距離看見你的反應，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也很開心。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也來吃吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我要開動了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝招待。",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "吃飽了，吃飽了……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "稍微休息一下，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們再接著度假？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也是。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "稍微休息一下後再出發吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……我說啊，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_040"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總覺得，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n好希望這樣平靜安寧的時光",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以一直持續下去。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不用",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_041"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "冒什麼險",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "或擊退魔物。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每天就這樣悠悠哉哉地度過，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不曉得是什麼感覺呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_042"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "身邊有你在的話……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_043"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只是說說而已。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是真的一直這麼悠閒的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我可能又會說",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想要出去冒險吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "天天都是暑假",
        "unit_id": 113111,
        "voice": "vo_adv_1131002_044"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也是會膩的。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "走吧，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天你可要陪我玩個盡興喔。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏對著{player}如此說道，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n臉上揚起愉快的笑容──"
    }
]