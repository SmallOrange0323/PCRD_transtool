    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "播放著音樂，",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "紅茶的溫柔香氣……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "感覺心靈自然地就平靜下來了。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是待起來很舒服的店呢，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "平時",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人都會在放學後過來嗎？",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有幸來到兄長大人經常光顧的店家，",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我感到榮耀至極……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "欣喜雀躍。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n不知道該如何回禮……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我的……？",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n今天的確是我的生日……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道說，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這個是……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "傳聞中的",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "驚喜……？",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如、",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果是我來慶祝兄長大人的生日",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那還能理解……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但您平時都這麼照顧我了，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "居然還幫我準備了這種驚喜……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "呀！？",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "蛋糕上面插著煙火，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我第一次",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看到這種蛋糕……！",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還有用巧克力寫的訊息！",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n色彩繽紛的",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是果凍嗎，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "鮮奶油的顏色也很鮮豔……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "沒想到會有",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這麼華麗的蛋糕呢。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n因為在宅邸時",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都是收到日式糕點居多。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "鮮艷又可愛，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "令人不禁看得入迷了。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人？",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果不介意的話，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n可以和我一起享用嗎？",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這個蛋糕",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對我來說有點太大了……",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這短暫的時光，",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我希望能和兄長大人",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一同品嚐蛋糕享受，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "肯定會如夢一般美味。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請先吃一口吧。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "恕我冒昧，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請讓我餵您吃。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是啊。",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即使是夢肯定也無妨。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n因為和兄長大人度過的每一刻，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我都",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "絕對不會忘記。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不管是溫熱的紅茶、",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "色彩鮮艷的蛋糕、",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還是兄長大人的臉龐。",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是至高的幸福。",
        "unit_id": 125831,
        "voice": "vo_adv_4010171_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n謝謝您，",
        "unit_id": 125831
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……♪",
        "unit_id": 125831
    }
]