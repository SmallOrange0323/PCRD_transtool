    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "未料沒有小子在的日子，",
        "unit_id": 107111,
        "voice": "vo_adv_5084663_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會是如此無趣呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟敢不回應我的呼喚，持續沉眠……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不可原諒……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107111,
        "voice": "vo_adv_5084663_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是要睡到什麼時候才滿意……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可一點也不好笑啊……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還不趕快起來，好好取悅我……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此，",
        "unit_id": 107111,
        "voice": "vo_adv_5084663_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論用上什麼手段，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也絕對會把你給叫醒的……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你也很清楚吧……？",
        "unit_id": 107111,
        "voice": "vo_adv_5084663_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說的絕對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是「絕對」！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也只有現在有辦法",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "悠哉睡了……！",
        "unit_id": 107111
    }
]