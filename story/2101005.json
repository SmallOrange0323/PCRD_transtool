    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可可蘿。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "凱留她呀，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是不是有點",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不知道要該怎麼面對我們啊？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有時候，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感覺她好像在躲著我們似的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是如此，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為應該沒有這回事才是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n倘若真要講的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大約是因為她本身就有些怕生……",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_058"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……哼。",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_059"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真是的……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不管走到哪裡都鬧哄哄的。",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_060"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還真是吵得快要吵死人了呢……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……看來那霸瞳皇帝所造成的傷口，",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_061"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n終於恢復得差不多都結起痂來了嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼如果……",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_062"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我去揭揭這個傷疤的話，會不會噴出點鮮血呢？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n還是說，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "會讓人聽到那吵死人的悲鳴呢？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿嘿……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那麼嘛。",
        "unit_id": 191611,
        "voice": "vo_adv_2101005_063"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n雖然有點對不起贊恩他們……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但就讓我來個亂入，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然後提前結束這場遊戲吧――",
        "unit_id": 191611
    }
]