[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在霸瞳皇帝被打敗，輾轉過了三個月後的某日――"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "乖喔乖喔～",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們兩個～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是乖寶寶喲～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘎呀",
        "unit_id": 106414,
        "voice": "vo_adv_2101005_001"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘎呀……♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……♪",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n他們倆，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都相當親近凱留小姐您了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那安心地卸下心防的笑容，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是可愛……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對呀我是你們的保母喔！",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n宰了你們唷！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我把你們一起給宰了唷！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "宰了、",
        "unit_id": 106414,
        "voice": "vo_adv_2101005_004"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "宰了～♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常謝謝兩位充滿精神的『宰了你們唷！』",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而凱留小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時在短時間內，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若您可以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍稍注意一下自己的遣詞用字那可就幫大忙了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟主人與雪菲小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很可能會模仿您說的話……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔……",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拿你們沒辦法耶……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟在【美食殿堂】做勞動服務是我緩刑的條件嘛？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以不管是要當保母還是要幹嘛我都會乖乖去做就是了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過話說回來……",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她叫雪菲嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這孩子的名字終於決定好了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼是叫雪菲？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是因為當初在向她詢問名字時，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「雪……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "芙。」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己曾如此地發出了聲音。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且她本人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也相當中意這個名字的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雪～芙～♪",
        "unit_id": 106414,
        "voice": "vo_adv_2101005_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雪～芙～♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～好好好，",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了我知道了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，結果這傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是哪來的啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然最後順勢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就和{player}一起照顧起來了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關於雪菲小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實話說相當的遺憾，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今仍然毫無線索。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然貪吃佩可小姐也有出份力，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "試著在城內收集相關的情報了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是擁有著像她一樣的翅膀與尾巴，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "且藍色頭髮的少女，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到現在，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎仍然完全沒有任何的線索。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確很稀奇呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這孩子有一樣翅膀和尾巴的傢伙。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是叫龍人族……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來著？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話又說回來，",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可那傢伙還真出頭天了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可以像那樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "使個眼色就能夠叫人下去辦事情了呀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟貪吃佩可小姐",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她原本就是擁有著尊貴身分的大人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為她平時",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願意放下身段與在下等人相處，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才導致在下等人逐漸疏忽了這一回事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而有關於主人精神上的退化狀態，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在查明原因",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與尋找解決辦法的調查上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她也曾提及過會試著想些辦法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅管因為宮殿內大圖書館的修繕，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎得延後的模樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而為籌備出重建相關的資金，",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎決定將寶物庫裡頭的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "金銀財寶，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以及相當數量的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔法物品拿出來拍賣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『裡頭或許有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠對精神有作用的\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特殊道具也說不定。』",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "――她當時如此說道。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是『說不定』喔，",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺她的這話不太可靠呢――",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……喂！{player}！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要扯我的頭髮啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "噠～",
        "unit_id": 106414,
        "voice": "vo_adv_2101005_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "噠～……♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咿呀！　",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下，連雪菲妳也這樣！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要在那邊舔人家的耳朵啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吼唷～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位真的是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當地親近您的樣子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍稍有些心生羨慕……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來可蘿仔！　",
        "unit_id": 106012,
        "voice": "vo_adv_2101005_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也太冷靜了一點吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這種狀況這麼奇怪耶！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳還能那麼冷靜地",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在照料這兩個傢伙啊～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……您說的是。",
        "unit_id": 105913,
        "voice": "vo_adv_2101005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
