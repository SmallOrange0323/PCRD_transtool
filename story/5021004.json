    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人成功奪回亞瑟。\n並為了奪回其他玩偶們，開始展開了行動。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從現在起",
        "unit_id": 110611,
        "voice": "vo_adv_5021004_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "兵分兩路行動，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家準備好了嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "當然",
        "unit_id": 110511,
        "voice": "vo_adv_5021004_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒問題～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊。",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然知道解決方法了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要應付那麼多對手，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "分頭行動是最有效率的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 110611,
        "voice": "vo_adv_5021004_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴就",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "拜託您照顧囉？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 110611,
        "voice": "vo_adv_5021004_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生真是可靠呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不不不，",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼想都是我保護他吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道這傢伙",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有時候真的很可靠啦……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說什麼啊！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那種話說給優衣聽啦！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴，",
        "unit_id": 110511,
        "voice": "vo_adv_5021004_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳的臉好紅呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 110611,
        "voice": "vo_adv_5021004_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們等等見。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太陽下山前，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們約在海灘那裡集合吧？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你們兩個，",
        "unit_id": 110511,
        "voice": "vo_adv_5021004_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "記得不要到處閒晃呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們才要令人擔心呢！",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的。",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們走吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們負責找漁村裡面，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還有停泊漁船的碼頭。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看起來",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一切正常呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你那邊怎麼樣？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看樣子",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你那邊也是一樣啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒辦法。",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒頭沒腦找下去只是浪費體力，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n稍微等等看吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？　",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "坐下來啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幹嘛那麼緊張啊？",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒事的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管什麼東西出現，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我都會保護你啦♪",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎呀哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_5021004_017"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "居然有情侶來這種地方呀？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "情…！？",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才、才不是那樣，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "突然間是誰冒出來啊！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒事兒。",
        "unit_id": 611,
        "voice": "vo_adv_5021004_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咱剛才看到你們倆生面孔年輕伙子。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n還以為你們要對漁船做啥壞事才來瞧瞧呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來是這樣。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉讓妳會錯意啦，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "老婆婆。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那的確是很可疑。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過這是誤會。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們是【哞哞自衛隊】……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咱知咱知。",
        "unit_id": 611,
        "voice": "vo_adv_5021004_021"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咱就不打擾你們年輕小倆口親熱啦。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就―說―了，這一切都是誤會啊！？",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，你也幫忙說幾句話澄清啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦、",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也不需要裝作不認識我啦。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幹嘛把誤會加深啦！？",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那種事……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哎，算了！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "呵呵呵。",
        "unit_id": 611,
        "voice": "vo_adv_5021004_025"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咱說笑的呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不過，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們可得小心呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這附近有奄美魔物出沒呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "老婆婆也知道。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "用不著擔心，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們就是為了尋找那個奄美魔物才到這裡來的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "喔。",
        "unit_id": 611,
        "voice": "vo_adv_5021004_027"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n試膽嗎，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但看上去也不像是呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吶老婆婆，",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳知道就告訴我們吧，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "奄美魔物究竟是什麼東西？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咱也沒親眼見過，",
        "unit_id": 611,
        "voice": "vo_adv_5021004_029"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n只能說村里相傳的事呀……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那也行。",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們得多收集點情報。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "奄美魔物是",
        "unit_id": 611,
        "voice": "vo_adv_5021004_031"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "形容那些惡靈、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "駭人生物、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可怕生物的詞彙。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n傳聞它們有著千奇百怪的模樣。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跟香織說的一樣。",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "它們為什麼要奪取靈魂啊？　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "目的是什麼。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "誰知道呢。",
        "unit_id": 611,
        "voice": "vo_adv_5021004_033"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "唯一",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "知道的是，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "奄美魔物會",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "受到善良靈魂",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "吸引。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "善良靈魂……",
        "unit_id": 110411,
        "voice": "vo_adv_5021004_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該不會，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "玩偶們最先被當成目標是因為……",
