    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "馴鹿們在聖誕夜發起的造反行動"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在{player}等人的努力之下結束了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n城裡的人們變回原形後也紛紛回家，然後――"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了～",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們打算怎麼贖罪。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是啊。",
        "unit_id": 111711,
        "voice": "vo_adv_5029007_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟你們都反抗主人了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可不是一句抱歉就可以饒恕的。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先看看馴鹿先生牠們\n怎麼說吧？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿1",
        "words": "噗、",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_003"
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿1",
        "words": "噗喔喔喔！\n（那個，我們幾個，覺得很煩躁……）",
        "unit_id": 4011
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿2",
        "words": "噗喔噗噗！\n（每年都只會被胡亂使喚……）",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_004"
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿3",
        "words": "噗喔噗喔！\n（而且也沒有收過禮物……）",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜、伊莉亞",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_5029007_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜、伊莉亞",
        "words": "完全聽不懂。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖、",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然聽不懂他們在說什麼！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能感覺到他們想要表達的事情……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}你也這麼覺得吧？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然你的眼神看起來很誠懇，",
        "unit_id": 111711,
        "voice": "vo_adv_5029007_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不過",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}，你不是隨便亂講的吧？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔？",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到你會說馴鹿語。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然這樣，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你願不願意做我的馴鹿呢？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用了？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真可惜……☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "等一下，",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_010"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "小姐們。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕老人……",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_011"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "能不能",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_012"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n讓老夫和牠們說幾句話呢……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿們",
        "words": "…………",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_013"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "……",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_014"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "抱歉。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "你們。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "你們一直在協助我，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n可是老夫卻完全沒有察覺到你們的感受。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "當老夫變成馴鹿的時候，",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_015"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "聽見了你們的心聲。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "不只是哀傷、",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "憤怒、",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "還有對於自己無法享受聖誕節的不甘心……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是這樣……",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿先生，真的很抱歉。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們幾個，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直做一些任性的事……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿們",
        "words": "……噗喔……\n（……主人……）",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_017"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "真的很抱歉。",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_018"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n馴鹿明明是聖誕老人",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "無可取代的搭檔……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n老夫身為一個分送喜悅的人，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "怎麼會這麼愚蠢。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "請你們……",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_019"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "請你們，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "原諒我吧……！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "若沒有你們，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "老夫就沒有辦法繼續當聖誕老人了。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n有了馴鹿的幫忙，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "聖誕老人才能是聖誕老人啊……！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿們",
        "words": "噗喔……",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_020"
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿們",
        "words": "噗喔～……！\n（我們也是……我們都忘了如果沒有主人，別說是菁英了，\n我們根本就只是普通的馴鹿而已……對不起……！）",
        "unit_id": 4011
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……太好了。",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n馴鹿先生牠們，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像原諒我們了……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以，",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有共識了嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我們走吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_023"
    },
    {
        "type": "dialogue",
        "name": "精英馴鹿們",
        "words": "噗？",
        "unit_id": 4011,
        "voice": "vo_adv_5029007_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂。",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你們該不會以為攻擊我以後，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還能全身而退吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯。",
        "unit_id": 111711,
        "voice": "vo_adv_5029007_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n造反的這筆債，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們得親自來還啊？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們是認真的嗎！？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "抱歉！　",
        "unit_id": 3911,
        "voice": "vo_adv_5029007_028"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "這次這件事，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "都是因為老夫思慮不周而引起的！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n可以請妳們",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "原諒",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "這些孩子嗎……！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是啊！製作人！　",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "伊莉亞！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好不容易快要達成共識了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別說這麼多，跟我來。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是啊。",
        "unit_id": 111711,
        "voice": "vo_adv_5029007_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不快一點，聖誕節就要結束了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊真是的！",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等一下嘛！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳們太我行我素了啦……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這裡是……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在幹嘛？　",
        "unit_id": 111511,
        "voice": "vo_adv_5029007_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "趕快脫了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是妳希望我幫妳脫呢？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是愛撒嬌……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！？　",
        "unit_id": 111611,
        "voice": "vo_adv_5029007_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等一下！製作人！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}還在那裡耶……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
