    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在救下倒在路旁的普蕾西亞後，又過了幾天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}再次看見"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n普蕾西亞一個人走在路上。"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……（啪噠啪噠）",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_000"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "哥。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_001"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "早安。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "之前，",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_002"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n救了、",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "我，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n謝謝。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_003"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "沒問題。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_004"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "那麼，",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_005"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n我走了。",
        "unit_id": 126112
    },
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這樣啊……",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您遇見了",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "──其實，",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我今天也是為了這件事，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "特地前來找您商量。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即便先前",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞餓倒在路上，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n然而那之後她還是會一個人外出……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然我也曾多次詢問她",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要出門做什麼，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是她只會回我說",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「一個人沒問題」……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過就如您所知，",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n普蕾西亞",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是個自由自在……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常隨興的人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也無法保證",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "她不會被捲入壞事之中。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "和璃亞",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都很",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "擔心她……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦？",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您是指要尾隨普蕾西亞",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的意思嗎……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此……",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也就是說，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要默默探查她的隱情對吧……！",
        "unit_id": 125812
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "…………（啪噠啪噠）",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……她",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正在走路呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不對，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這是理所當然的……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "她在魚販前面",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "停下來了。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "普蕾西亞，妳來妳來！",
        "unit_id": 1411,
        "voice": "vo_adv_1261002_017"
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "這是用店裡的魚做的竹輪，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "剛剛才烤好的！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "很好吃喔～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "非常，",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_018"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n謝謝你。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嚼嚼……",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_019"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_020"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n優勝。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "對吧？",
        "unit_id": 1411,
        "voice": "vo_adv_1261002_021"
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "\n我包一些讓妳當伴手禮啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚店店長",
        "words": "拿去吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看起來",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_022"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "跟店長很親近呢……",
        "unit_id": 125812
    },
    {
        "type": "background",
        "background": "501960"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "哦，",
        "unit_id": 611,
        "voice": "vo_adv_1261002_023"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "歡迎光臨。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "\n今天也很努力呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "來，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "這個給妳。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店店長",
        "words": "棒棒糖。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "謝謝。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_024"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n我開動了",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……舔舔。",
        "unit_id": 126112
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這、",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_025"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這次是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "小菜店的人給了她關東煮！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有蘿蔔、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "蛋，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "跟蒟蒻……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看起來很美味。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……不過，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "她是怎麼付錢的呢……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "吃光光。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_026"
    },
    {
        "type": "dialogue",
        "name": "小菜店店長",
        "words": "妳的吃相",
        "unit_id": 1511,
        "voice": "vo_adv_1261002_027"
    },
    {
        "type": "dialogue",
        "name": "小菜店店長",
        "words": "還是一樣很棒呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "小菜店店長",
        "words": "\n記得要再來喔！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "多謝。",
        "unit_id": 126112,
        "voice": "vo_adv_1261002_028"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是啊……",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_029"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我想……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "她之所以會一個人外出……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看起來",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_030"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "似乎是這樣呢……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……的確，",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_031"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不管是我還是璃亞，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n都很難跟上普蕾西亞吃東西",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的速度。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看來她是希望",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_032"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可以不用顧慮任何人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n獨自悠哉地享受",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "邊走邊吃的樂趣……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來是這樣……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "知道她是想邊走邊吃後，",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_033"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然有點鬆了口氣……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但單獨行動還是會讓人擔心呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "究竟",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "該怎麼做才好……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……咦？",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_034"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n為了讓普蕾西亞可以放心地邊走邊吃，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要幫忙解決周遭的危險……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原、",
        "unit_id": 125812,
        "voice": "vo_adv_1261002_035"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
