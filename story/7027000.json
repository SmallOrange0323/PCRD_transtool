[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "通往露娜之塔的入口。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那裡有位夢想一獲千金的龍人族少女充滿了幹勁。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "感覺到了，",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我感覺到了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那座塔",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "散發著有大賺頭的氣味！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不是那個意思啦！",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你之前不是有說過嗎！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你曾經在露娜之塔內，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "找到寶石和稀有魔導具之類的寶物！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些東西肯定能賣很多錢！",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你懂嗎，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這可是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為億萬富翁的大好機會！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要有錢，",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就無所不能！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n連要收買蘭德索爾中的幫派成員，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也都能靠錢來搞定！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "裝備準備萬全！",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我一定要在露娜之塔內得到寶物！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n然後一口氣",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "登上黑社會的頂點！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊，",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了對了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我記得塔內好像也有小哥的記憶線索吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我會在尋寶時順便幫你找的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰叫我這麼溫柔呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵……",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的計畫真是太完美了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……只不過",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有一點除外。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……這是我聽嘉夜夜說的。",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽說露娜之塔中會出現各種危險的魔物。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以我本來也希望嘉夜夜能來的……",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但她今天卻偏偏有生意要忙，不能來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只靠我和小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n真的有辦法爬這座巨塔嗎……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不對！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都走到這一步了，事到如今還在怕什麼啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們應該要做好萬全的準備對吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很、",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很遺憾，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次或許放棄探索露娜之塔比較好……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這就是所謂有勇氣的撤退！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好了，",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然麻煩，但我們回去吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──呀哇～！",
        "unit_id": 1,
        "voice": "vo_adv_7027000_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哀號聲！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聲、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聲音從哪傳來的……！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊、",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊哇哇哇哇……！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n有人掉下來了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這到底是怎麼回事～！？",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "痛痛痛痛痛……",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還真是粗暴耶……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "之前好像也發生過這種事……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "無所謂。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "壞蛋在哪裡！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n由我來打倒你們！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "奇怪？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦～",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有祈梨！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們過得好嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳在那裡",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "悠哉地問候什麼啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底是發生了什麼事，才會讓妳突然從天而降啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這也沒有那麼稀奇吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被人打飛到天上，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事滿常發生的啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼可能會有",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種事啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n夠了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快點說妳為什麼會來這裡！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒什麼，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原因很簡單！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我在旅途中請認識的人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n幫我施加了魔法。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是「轉移到壞蛋所在之處的魔法」！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "居然特地請人對自己施加那種奇怪魔法……",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "矛依未真是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "相當危險的傢伙呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說的",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「危險」",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是在誇獎我吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼哼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以再多誇獎我喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這才不是在誇獎妳啦！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……總之，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳是用奇怪的魔法飛到這裡來的對吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這樣！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……話又說回來，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "壞蛋在哪啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼、",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來妳的眼睛是裝飾用的呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要找壞蛋，不就在妳眼前了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是我這個世紀壞蛋，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯？",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨是壞蛋？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼說來我記得",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳是黑手黨啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳說「這麼說來」是什麼意思啊！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不是黑手黨，是幫派！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，無所謂……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳少給我小看恐怖的幫派幹部！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔～",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳是幹部啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都不知道耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管怎麼說……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我似乎是被祈梨吸引過來這裡的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我原本是打算狩獵壞蛋……",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也是有這種事啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們為什麼會在這裡？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼嗯，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們正在煩惱要不要探索露娜之塔……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想到會碰到危險的魔物，讓你們感到害怕了啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼～！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是那樣啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n區區的魔物，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "靠我的力量根本輕鬆解決。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然是這樣，我來幫忙吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n能在這裡見面，也算是某種緣分啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就算是我，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "偶爾幫助一下弱小的傢伙也行吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂──！！",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳少給我擅自決定啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳如果想加入我們，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不是不能讓妳加入啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很強嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對啊，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我滿強的喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼～！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大壞蛋～！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼大壞蛋啊！",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果妳是大壞蛋，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我就是Big Boss，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯……？",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\nBig Boss……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說妳！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n該不會就是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個祈梨！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……什麼？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我剛才就一直是在說",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是祈梨啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是怎樣？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是奇怪的傢伙。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎呀～",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊這樣啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我不曉得妳是用什麼樣的角色！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以至今都沒認出妳耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "角色……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉抱歉！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳別在意！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我很開心喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "居然能和妳一起來個像樣的冒險！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……我是不太懂妳在說什麼，",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但妳聽好了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在露娜之塔中，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要跟緊我這個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大中的老大，祈梨大人！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不准妳擅自行動！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對，",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是妳要跟著我才對！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳可別因為害怕魔物",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就走丟了喔，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027000_047"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽好了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是老大！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳是手下！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要乖乖聽老大的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不然走散了就等著吃苦頭吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說誰是手下啊！",
        "unit_id": 106113,
        "voice": "vo_adv_7027000_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大壞蛋不會服從任何人！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會按照自己的意思行動！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "走吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在探索前就起爭執的祈梨與矛依未。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人將{player}夾在中間不停吵架，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人就這樣進入了露娜之塔。"
    }
