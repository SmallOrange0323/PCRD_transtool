[
    {
        "type": "background",
        "background": "500163"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美空、涅婭、莉莉與卡里莎，以及{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到沙灘進行做好事社團的活動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}走在沙灘上時，有人從後面叫住了他。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………兄、",
        "unit_id": 1,
        "voice": "vo_adv_1316001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "兄長大人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……請、",
        "unit_id": 1,
        "voice": "vo_adv_1316001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請恕我由樹後方打擾了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為我看到了兄長大人的身影……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n若您時間方便的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是否能與您說些話呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是我。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "無論如何，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "首先是兄長大人……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您此次",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在做好事社團的成果，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是卓越非凡。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您的表現",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正正",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "體現了何謂大顯身手……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我打從心底",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "感到敬佩。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "身為受兄長大人指導之人，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不只是讓我感到驕傲。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也讓我再次立定了",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要加倍努力，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "以成為優秀冒險者的志向。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非、",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常抱歉。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我明白隱藏身姿向人搭話",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是極度失禮的事情。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我雖明白，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我……",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我感到",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "很害羞……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "美空小姐為我挑選的",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這套泳裝……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n對我來說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "稍微……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有些",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "前衛。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在全心投入做好事社團的活動時，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n光是為了跟上各位就已竭盡全力……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n完全沒有餘裕能顧及自身。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是……",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "現在",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "冷靜下來之後……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n該說是太過赤裸了嗎，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n看起來是否有些興奮過頭了呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正、",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正如您所說……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n無論哪位，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都穿著相當開放的服裝呢",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……連兄長大人也是……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……或許只是我",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "想太多了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非、",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常感謝您……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "既然兄長大人都這麼說了，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那麼我個人的害羞",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "只是微不足道的小事呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "失禮了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如何呢……？",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請容我再次確認，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是否會不堪入目呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您是多麼地溫柔",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "又心胸寬闊……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "接納了我那彷彿在海浪中",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n載浮載沉的心。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……但是……",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即便如此，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "像這樣……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兩人獨處時。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我果然還是無法不去在意",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人的視線。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n……無論如何，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我的心都會悸動不已。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊啊……",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n希望",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這心跳聲",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不會被兄長大人聽見……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……啊！",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "什麼事都沒有。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "先、",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_020"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "先不提我的事了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在這之後的預定沒有問題嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不小心就占用您太多時間了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "幫忙……",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_021"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "告訴了莉莉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由於他想報答在海邊為美空"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出了部分保釋金的人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是就被請去海之家幫忙。"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_022"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是這樣啊……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我到底",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_023"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有多麼地不成熟呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "僅只是承蒙在海邊的各位的厚意，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n而不像兄長大人一般",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有著體貼他人的餘裕……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……那個，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_024"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n若不會妨礙到您的話……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您說的幫忙，",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_025"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n能否讓我一同參與呢……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n可以的話，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也想要報答在海邊的",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "各位……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常感謝。",
        "unit_id": 131611,
        "voice": "vo_adv_1316001_026"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為了不扯兄長大人的後腿，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我會竭盡全力幫忙的……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接受了莉莉請託的{player}"
    },
    {
        "type": "dialogue",
