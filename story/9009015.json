    },
    {
        "type": "dialogue",
        "name": "公主們",
        "words": "「──崩雷夜天。」\n「公主突襲──！！」\n「滅裂萬化‧輪迴轉掌。」",
        "unit_id": 1,
        "voice": "vo_adv_9009015_001"
    },
    {
        "type": "background",
        "background": "502115"
    },
    {
        "type": "dialogue",
        "name": "奇妙的魔物",
        "words": "……六……",
        "unit_id": 1611,
        "voice": "vo_adv_9009015_002"
    },
    {
        "type": "dialogue",
        "name": "奇妙的魔物",
        "words": "點……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "奇妙的魔物",
        "words": "五……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "哇……",
        "unit_id": 133111,
        "voice": "vo_adv_9009015_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n各位的力量",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "實在是太驚人了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n出現的魔物",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "瞬間就化成灰燼了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸國公主們，",
        "unit_id": 129711,
        "voice": "vo_adv_9009015_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "萬分抱歉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n吉歐‧格黑納乃充斥魔物之地，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "故而此般侵擾",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可謂家常便飯之事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_9009015_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "別放在心上，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "涅妃‧涅羅皇女。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n沒有任何人受傷",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就已經是萬幸了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種程度，",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全是輕輕鬆鬆☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……雖然那個叫聲，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽起來有種似曾相識的感覺……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過我已經忘得一乾二淨了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……確實",
        "unit_id": 129711,
        "voice": "vo_adv_9009015_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是未曾見過之魔物呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許是為此次祭典之喧囂",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所吸引而來的亦說不定──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說呀！",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常非常盛大的祭典呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哼嗯……？",
        "unit_id": 129711,
        "voice": "vo_adv_9009015_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為何如此拘謹呢，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_9009015_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "原來如此。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n如果不是我們給予許可",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並提供人力，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這場跨越世界的夏日祭典",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就不可能實現……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是嗎。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我度過了非常愉快的時光。",
        "unit_id": 133111,
        "voice": "vo_adv_9009015_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "映入眼簾的一切都非常有意思……♪",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……總有一天，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我們",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吉歐‧尼布爾黑爾也可以……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "向大家表達謝意。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多虧了大家的大力協助，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能夠舉辦",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如此盛大又精彩的夏日祭典♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無足掛齒之事。",
        "unit_id": 129711,
        "voice": "vo_adv_9009015_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家等人",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "現已是同舟共濟",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "的至親之交。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "相互幫助可謂理所當然。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是的……",
        "unit_id": 126511,
        "voice": "vo_adv_9009015_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "現在",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們必須克服眼前的危機。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n畢竟沒有一個世界",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以稱得上是安穩的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是……",
        "unit_id": 133111,
        "voice": "vo_adv_9009015_015"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "透過這次的祭典，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我重新明白了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如果是和各位一起，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "肯定可以跨越世界，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "齊力合作。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "謝謝你，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀。",
        "unit_id": 126511,
        "voice": "vo_adv_9009015_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n剛好",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是放煙火的時間呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n看起來就像一顆顆小小的糖球一樣……♪",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "由人類之子親手",
        "unit_id": 129711,
        "voice": "vo_adv_9009015_017"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "點燃的火之花，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也別有一番情趣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常地漂亮呢！",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還想再像這樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和大家",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起看煙火！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以──",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也齊心協力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起加油吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，在公主們的通力合作下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n連同其他世界所舉行的「6.5周年紀念夏日祭典」大獲成功。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是呀♪",
        "unit_id": 105812,
        "voice": "vo_adv_9009015_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超美的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明年。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定一定──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也要和小雪菲",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起看煙火喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～！",
