[
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……狀況一轉眼就陷入了混亂了呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還逐漸的在惡化。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n儘管搞得亂七八糟的狀況我也不怎麼討厭，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但若不盡快決定行動方針，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可真的會無力回天喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "問題是，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一股腦衝出去的蒂亞娜嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她是個好對手啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可不想在這無趣的局面下失去她呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "公主‧蒂亞娜！",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果是公主的話",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "偶爾也要聽底下人的要求啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n馬上停下有勇無謀的行動，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "回到這裡來！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和大家會合，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "同心協力從這個窮途末路中脫身！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我很高興妳能用本名來叫我！",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但非常抱歉，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不能在這裡退下！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是我自己做的決定，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會給妳們添麻煩的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最糟的情況，",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請大家果斷放棄我趕緊脫逃吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇啊，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還真勇猛呢～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但是不是，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "有點太魯莽了呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "【王宮騎士團】的大家～",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n以不危及性命為前提給她一點小教訓再抓起來唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n盡可能將她給活捉，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "上頭這麼說的，殺掉可不行唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……？",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼你能對【王宮騎士團】頤指氣使？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "裡頭也有幾個我看過的前部下，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你是用了什麼魔法？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不是魔法而是權力呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在克莉絲提娜被送進牢裡後，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n【王宮騎士團】便開始找起了後繼呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n最後找到我這來了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟我也是貴族之門的子嗣，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不太好婉拒呀……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過我也算是替克莉絲提娜妳盡了職責呢，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n反倒是妳還得感謝我不是嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈！ ",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接了我的位置，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n成了【王宮騎士團】的副團長嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那真是飛黃騰達呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "作為前輩也替你感到驕傲啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尾狗刀小少爺！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "謝謝～！",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就當是慶祝就任副團長，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不要抵抗乖乖束手就擒就幫了大忙呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "克莉絲提娜妳呀，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可是讓陛下非常中意的樣子呢……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果提幾位【拉比林斯】成員的腦袋當作伴手禮回來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "或許能免掉逃獄的罪刑唷？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈！",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "斷然拒絕！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n誰會笑咪咪的當沒事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n回到原先要出手殺了自己的人身邊做事啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你可以閉嘴了，小子！",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我開始想把你這可愛的傢伙給宰了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好好，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_019"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我閉嘴了唷～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "說真的我呀，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n其實也不想做這種滿是血腥味的工作就是了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以呀，",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可說是沒什麼幹勁就是了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n但我不僅是菜鳥還是公務員，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真的沒辦法去違抗上頭的決定呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 106112,
        "voice": "vo_adv_2008015_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的願意就這樣子嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽從上頭的指示就甘願了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n壞蛋會願意聽從的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只有自己",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以及跟自己同等的夥伴對吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_2008015_022"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳又懂我的什麼了呢，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "小矛依未？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚哇哇哇啊～",
        "unit_id": 102011,
        "voice": "vo_adv_2008015_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！ ",
        "unit_id": 100411,
        "voice": "vo_adv_2008015_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好可怕～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}……\n不惜賭上性命也要前來救我們呢。",
        "unit_id": 103611,
        "voice": "vo_adv_2008015_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有一點對你刮目相看了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103611,
        "voice": "vo_adv_2008015_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我已經完全沒事了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n反倒是美美、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊……",
        "unit_id": 103611
    },
    {
        "type": "still",
        "still": "200801501"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇呀呀，",
        "unit_id": 103611,
        "voice": "vo_adv_2008015_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你想要做什麼呀！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n請、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要把我抱起來！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做得漂亮，",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請保持這樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶著她們來這裡！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 106112,
        "voice": "vo_adv_2008015_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n快點，{player}！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總算是成功的將敵方陣型給打亂了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快過來這！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "好。",
        "unit_id": 107311,
        "voice": "vo_adv_2008015_030"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n敵人似乎",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "都是以凱留為中心在行動。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n只要遠離的話",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "危險度想必就會降低了吧，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "那往反方向逃脫吧。",
        "unit_id": 107311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……話說回來，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "凱留似乎有著能夠操縱魔物的力量呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若能拉開距離，支配權、影響力也會因此而薄弱，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n至少也能使得魔物的動作變得遲緩才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您、",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是在說什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐竟然有那樣的能力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可未曾聽聞過此事……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想必是無法對妳們坦承吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然我也並非很清楚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但那傢伙似乎是個背景相當複雜的孩子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "好勒～",
        "unit_id": 190711,
        "voice": "vo_adv_2008015_034"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "附近的魔物全都被我給揍飛啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n看到了沒有！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "機不可失！",
        "unit_id": 191011,
        "voice": "vo_adv_2008015_035"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n貪吃佩可小姐，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "趕緊回來吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n該一起逃出此處了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……非常抱歉！",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再一下下，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能到小凱留的身邊了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！",
        "unit_id": 106013,
        "voice": "vo_adv_2008015_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「凱留！」",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……被接近到如此地步還真是預料之外。",
        "unit_id": 106013,
        "voice": "vo_adv_2008015_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但我可是國王陛下的代理人，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請希望別這麼小看人家呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受死吧，",
        "unit_id": 106013,
        "voice": "vo_adv_2008015_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "逆賊。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就用我的魔法",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把妳燒成灰燼吧。",
        "unit_id": 106013
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔……！！",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託妳了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕快清醒過來吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯、",
        "unit_id": 106013,
        "voice": "vo_adv_2008015_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個距離都能閃過嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳可沒辦法全部都躲開唷……！",
        "unit_id": 106013
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底是怎麼回事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這可是最糟糕的情況。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在如此近的距離遭受魔法攻擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不可能會平安無事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還一息尚存對吧？",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若不快點去救她的話！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們！",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n已經要撐不下去了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管很遺憾，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蒂亞娜的事就放棄吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣下去連你們也會被幹掉啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "趕緊過來……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再慢吞吞的下去，",
        "unit_id": 107111,
        "voice": "vo_adv_2008015_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真的會被全滅的啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但……",
        "unit_id": 105911,
        "voice": "vo_adv_2008015_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐她！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105811,
        "voice": "vo_adv_2008015_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真是遺憾呢。",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知道妳想要做什麼，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這面具單純就只是魔力增幅器唷？",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算被妳摘了下來，",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "靠我本身的魔力，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "區區攻擊魔法還是能施展的。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "目標一名，",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "捕獲。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抓起來，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "押送到王宮地下監獄。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剩下的，也趕緊一網打盡吧。",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不會讓你們逃掉的，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "蒙昧無知的逆賊們。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓我把世間的膿瘡都給除去，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將那些害蟲全都消滅，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n替您的權勢有如磐石般屹立不搖吧。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請為此，",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請為了那理想，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我用盡我的生命吧。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實現的話，",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請讓我成為您所築起的，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這夢之千年王國的榮譽子民吧。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是我唯一的心願，",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我生存的意義。",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼、",
        "unit_id": 106014,
        "voice": "vo_adv_2008015_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哈哈、",
        "unit_id": 106014
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈哈哈哈……♪",
        "unit_id": 106014
    },
