[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了參加遊戲同好的線下聚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n依里來到會合地點等待{player}的到來。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唉……",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "當初因為是那傢伙邀請，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n才會沒想太多就答應參加，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n事到如今卻緊張起來了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我……",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "除了茜里之外，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "熟識的人也就只有公會成員，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的有辦法跟初次見面的人聊開嗎……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我怎麼會",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這麼窩囊啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "明明是參加喜歡遊戲的線下聚，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n卻為了這點芝麻小事煩惱。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天幸好有{player}陪我一起去，",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但是這樣下去總不是辦法啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唉……",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要是我也能像茜里一樣",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "跟誰都能無所不聊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n像她一樣舉止大方，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就不用為這種事煩惱了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "倒是{player}怎麼這麼慢啊？",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n要是那傢伙今天沒來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我豈不就得一個人參加線下聚……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這怎麼行！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n算我求你了，你快點來啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼這麼慢啊{player}！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n才想說要不要乾脆自己先過去呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝、",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝天謝地，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他總算是來了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之！",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "因為你遲到，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "時間所剩不多了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我們趕緊出發吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什麼小女孩……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們好啊。",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇呀！",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她是什麼時候……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這小女孩是誰啊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸妳，",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "找我們有事嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是說",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳迷路了？",
        "unit_id": 102211
    },
    {
        "type": "still",
        "still": "504800001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "迷路？",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不是的不是的。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是個天使！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n負責指引大家才是我的工作！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n至於迷路這種事，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一天頂多兩三次而已。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼哼！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽起來還挺頻繁的嘛……",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "倒是妳說",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳是天使？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一般所謂的那種天使嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這翅膀跟弓箭",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的確是有天使的樣子……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n啊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "仔細一看還真的離地飄著呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "感覺又有點冒牌貨的味道。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我、",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_016"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我不是冒牌貨啦！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我可是",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "為了讓大家變得超級無敵幸福",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n而降臨的資優生天使，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "名字叫做",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "拉菲～！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那個……",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_017"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "請問妳叫什麼名字呢？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦，",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "名字？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我叫做",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "依里……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼依里，",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_019"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳現在，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "心中懷抱著很大的煩惱對吧？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她是怎麼看透我心思的？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n難不成",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她真的如她所言是個天使……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "就算想瞞",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_021"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "也瞞不過我的喔。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n因為妳剛剛的自言自語，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "全都被我聽得一清二楚了！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不會吧，被她聽見了！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這下丟臉也就算了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還被怪怪的小孩纏上，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到底是怎樣嘛～！　",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不過依里妳放心。",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_023"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n接下來",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我要幫妳實現願望。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n讓妳變得",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "超級無敵幸福！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不必了啦。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我想妳該幫助的應該不是我",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n而是那些更有困難的人吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "……不，",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_025"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我想幫助依里。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "只要能讓依里變得幸福，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼我一定能……！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這話是什麼意思……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等等，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼拿箭對準我？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n妳嘴巴說的跟手上做的根本互相矛盾啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不要怕喔，",
        "unit_id": 5511,
        "voice": "vo_adv_5048000_027"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這個不會痛的，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我是不會失敗的……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "大概。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "超級無敵幸福，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "天使之箭！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇啊──！？",
        "unit_id": 102211,
        "voice": "vo_adv_5048000_028"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 113811,
        "voice": "vo_adv_5048000_029"
    },
    {
        "type": "dialogue",
