[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "續‧",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "研究報告",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「源於與世界相連的更高次元見聞」。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "又名",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「我這絕對不是在偷懶的小優妮說詞」。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "前略，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聖德蕾莎女子學院學務處負責人閣下。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n筆者在不久前，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "經由教務主任修女希爾達轉達，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n接獲了學院提出的下列要求。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請優妮博士在將於幾天後舉辦的動靜兼備祭典",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「聖學祭」中，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n發表平日學習的成果──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要點如上。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無須贅述，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在本學院最盛大的年度活動「聖學祭」上，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n出席的並不僅限於學生的家長與當地居民，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也囊括了許多的教育相關人士、贊助者和",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "支持者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個要求就是想向這些權威人士，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n展現本聖德蕾莎女子學院身為教育機構，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n培育出了多少傑出的學生吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是本學院的愛慕虛榮。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n睥睨筆者的教務主任──修女希爾達藏在眼鏡後方的眼神，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n暗示著「妳偶爾也該派上點用場吧，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個米蟲不良資優生」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對此，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "筆者立刻脫口而出的回答是：",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n「呃辦不到」四個字，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但修女並沒有因此輕易地放過筆者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳之前沒來上課，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一直窩在圖書館裡，到底都在做什麼？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n該不會要說自己日復一日",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都在呼呼大睡吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n──她那有如蘭德索爾藏狐的眼神是這麼說的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為了洗刷加諸於筆者身上的嫌疑，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n以下將記述筆者至今的活動紀錄，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "並附帶筆者的陳情之詞。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的根源性虛構」。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是筆者過去鑽研的研究課題，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n向學會提出後，卻遭到了大肆嘲諷。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而筆者本人，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也被批判為誤解學術層面假說與誇大妄想的蠢材，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n該研究徹頭徹尾地被當成了「沒有存在過的東西」──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──似乎是如此。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "坦白說，筆者記不太清楚了。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們的大腦",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎擁有防衛機制，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n會適當地遺忘",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可能造成精神層面傷害的可憎記憶，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這大概就是原因。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是說，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "老實說原因無關緊要。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "總而言之，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想言語化筆者的遭遇並非易事。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "早晨輕撫眼皮的陽光，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n夜裡令血液沸騰的亢奮，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n世界上的各種物事與現象，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都在平靜地妨礙筆者進行思考。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是筆者開始嫌動腦這件事很麻煩。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若要質問這難道並非肇因於筆者天生的特質，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n筆者也只能以「啊，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟筆者本來就有這一面啊？」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n曖昧地含糊帶過，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就連筆者都對此感到相當遺憾。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "照理來說，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n旁人應該會認為筆者的認知遭受到了某些妨礙，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但該說不出所料嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "本國的學者對此說法不屑一顧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "倘若有一名真正的有識之人，能不受停止思考的誘惑所困，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n筆者的研究或許將能迎來不同於當今的結果。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，事情並沒有如此發展。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無所謂。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n反正沒有任何人",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會認真聽我這種人說的話。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在本學院的圖書館──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "通稱為「象牙之塔」中，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有著無數具備頂尖歷史資料價值的文獻與古文書。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是一座寶山。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但不可思議的是，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不論是什麼樣的學者和有識之人，\n都對此不感興趣。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡直就像感興趣這件事本身就受到禁止一般。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "回歸正題。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在那些書籍當中，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也包含了荒誕無稽，無從判斷是神話還是童話的故事。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "舉例來說，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那之中有一份自其他境界造訪此地的異界人們留下的活動紀錄。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n或者，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那其實是那些異界人與彼此通信的紀錄。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "至此，筆者就像個蠢材，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "試著建構了一個愚蠢的假設。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n倘若這些荒誕無稽的冒險故事是「真理」──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個世界，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是由所在境界與我們相異的高次元存在所創造，\n有如某種沙盒的世界──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而在此呼吸的我們，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也同樣屬於與那些高次元存在相連的系譜──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換言之，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果要直接換個說法，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們是──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我本來要講什麼？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊算了。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真麻煩。",
        "unit_id": 116411
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "筆者正是世人所謂的筆記狂人。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n會不分大小而無謂地紀錄",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在日常生活中獲得的學問與發現。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而在相當於本人外部記憶的筆記本中，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有數個被撕掉的項目，底下是這麼記述的──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「貪婪於睡眠　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "享受餘生吧」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「和解業已成立　",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "吾正是贏家」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那道筆跡毫無疑問",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是出自於筆者的手筆。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不得要領的筆致",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "宛如逃避檢閱制度的暗號。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那一定是某個時刻的我",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "留給自己",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "博識的脅迫──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n抑或是搏命的祈求。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那也沒辦法了。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然筆者已經勝利，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n剩餘的日子就只是無關於勝負的比賽。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼筆者就遵從這些遺言，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "仿效愚蠢的眾生，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在這個孕育了欺瞞的世界中",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "盡情地輕鬆享受餘生吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這個封閉的沙盒中，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n早一步捏痛自己臉頰的我很幸福。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因為這讓我發現到夢中的夢仍然是夢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好啊，世界，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我跟你妥協。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我往其他方面學習。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你就儘管讓我在這個悠靜的清醒夢中",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "愉快地自由行動吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以你愛怎麼封閉就怎麼封閉吧。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我會擅自在你的手掌心上，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n繼續體驗過去夢寐以求的青春劇場。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣你沒意見了吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個混帳世界。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_043"
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──前略，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學院閣下，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n基於上述的理由，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n筆者決定徹底推辭為「聖學祭」的",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學術展覽",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "提出論文一事。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反正就算我高聲疾呼，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也傳達不到任何人耳裡。",
        "unit_id": 116411
    },
    {
        "type": "still",
        "still": "506400201"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "追記。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n當然了，出於設籍於貴學院的義務，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n筆者將以其他形式參加該展覽，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敬請放心。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敬請期待新銳藝術家‧",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮博士的自信之作。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "謹此。",
        "unit_id": 116411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "世界今天也是封閉的嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這片天空的遙遠另一端，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有著什麼樣的事物？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我獲得的學問，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "到底有沒有意義呢？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我問你，羅塞塔，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的聲音有傳達到嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_052"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n無法為妳的問題找到解答！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n請對假想人格提出清晰的指令！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剛才說的話有點太詩意了嗎……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好吧，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那我換個問題。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\nOK羅塞塔，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那些人還在稱我為笨蛋嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "自我搜尋",
        "unit_id": 1,
        "voice": "vo_adv_1164001_054"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "可能會損害精神健康！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n請小心不要過量攝取輿論！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真相未必保證會帶來幸福──",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這就叫無知便是福嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我說你啊，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "面對主人時再慎選一下言詞吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡單來說，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是想知道自己的選擇是否正確。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_057"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n「正確」的定義十分模糊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n優妮博士以前說過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "正義與正當性全憑主觀認定！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就愛跟我唱反調，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我養的石頭真叛逆。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n受不了，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這到底是像到誰了？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不要把一切都想得黑白分明。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那種二元論",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可是會讓靈魂墮入理科的喔。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "重點在於漸層。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "愛上留白處吧，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "世界可以是曖昧不清的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是再多寵溺我一點吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1164001_061"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "我就開啟模糊功能來回答！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n最近的優妮博士",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "每天看起來都很開心，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "所以應該沒問題！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乖孩子，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就是在等你講這種話。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n剛才的玩笑話",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "當然不可能呈給學院。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就不留痕跡地捨棄吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……咦？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n說到這個，沒問題是指什麼？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n世人到底是怎麼談論我小優妮的？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_065"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像有人來了唷，羅塞塔。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_066"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n日安，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "「同志」先生！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_067"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是{player}啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n歡迎來到休憩的小睡處，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很抱歉嚇到你了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一如你所知，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_068"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是象牙之塔的優妮。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這邊則是試著把會說話的石頭羅塞塔",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "搭載在人型身體上的個體。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為目前還在實驗階段，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_069"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法讓它做出複雜的動作，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但我在它的身體上投射了與我很像的幻影。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如何？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在旁人看來，簡直就像是對美女雙胞胎姊妹吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是、",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_070"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是嗎……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一模一樣啊……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然這話是我自己講出來的，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但你的眼睛",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是不是不太好啊……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "「像」的定義全憑主觀認定！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_071"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n不必認真看待個人的感想",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "也沒關係！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_072"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為要再等幾年才會實際運用人型羅塞塔，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我有為仿生體預先設置一點成長空間。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要是相似到連自己人都分不出來，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_073"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只會被克蘿依或琪愛兒她們以各種方式濫用啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的目標是似像非像",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但又有點像的絕妙界線。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "「絕妙」的定義全憑主觀認定！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_074"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "先講先贏！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……好了，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_075"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "名為休息的逃避現實到此為止。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n羅塞塔，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "慢慢來開始調整自動運動迴路吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_076"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志，你怎麼了？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看你一臉驚訝的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你該不會以為我逃離克蘿依的瘋狂特訓，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就只是來找我養的石頭，耽溺於在它的大腿上睡覺吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "答對了！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_077"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "這是無從逃避的真相！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別說傻話了。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_078"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n表面上看來或許是這樣，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但內情是我沉浸在調整迴路的思考實驗中。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_079"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你還不懂嗎？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我打算讓羅塞塔在聖學祭上扮演我的替身。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你問為什麼？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_080"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你也有聽學生會長說過了吧，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n即將來臨的「聖學祭」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "攸關我們優妮們的命運。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "是啊！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_081"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n事關我們好朋友社的命運呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_082"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是一場不能輸的戰鬥。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以被評為比上陸的海豚還要慢的優妮博士，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可不能厚著臉皮，踰矩地參加激烈的運動競賽。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮們就由我來守護！",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_083"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不管要耍什麼手段，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我都不會讓這如夢似幻的青春劇場結束的！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "消極中的積極！",
        "unit_id": 1,
        "voice": "vo_adv_1164001_084"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n博士",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "好帥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別說了，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_085"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我會害羞的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好了，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我要請你一起來幫忙，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "共同研究者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_086"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}學弟，你怎麼了？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你在那邊東張西望又左顧右盼個什麼？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我不是拜託其他人，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是要請你來幫忙啊，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "共同研究者。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我明白。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_087"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但那有什麼問題？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我有求於你的並非知識，也不是技術。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我以前",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_088"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該有說過啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你只要在旁邊",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽我說話就夠了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的學問",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_089"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是只為我存在的東西。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n本來就沒有要讓別人知道的企圖和野心。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……但是呢。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_090"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只有一個人也好，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_091"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果有個願意傾聽的人站在我這邊──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "光是如此，",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_092"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就覺得自己的學問是有所回報的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我很感謝你。",
        "unit_id": 116411,
        "voice": "vo_adv_1164001_093"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n謝謝你平日的關照。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不太明白"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優妮在說些什麼，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻知道優妮好像很高興，便跟著一起露出了微笑。"
    }
]