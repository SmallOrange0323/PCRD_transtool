    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "急に初夢に願いを込めようみたいな流れになったけど……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんな大げさな目標、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしにあるわけないんだよね～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そもそも願ったところで夢を自由にできるわけないし。",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_001"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "深く考えず、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ぐっすり眠った方がいい夢が見れそうだよ……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ふぁ～……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そういうわけで、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_002"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "おやすみなさい～……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ぐぅ……",
        "unit_id": 102611
    },
    {
        "type": "still",
        "still": "513406401"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "むにゃむにゃ……",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_003"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ん～……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あれ、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_004"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたし、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n寝たんじゃなかったっけ？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nなんでこんなところに突っ立ってるんだろう？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "試しに、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_005"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "尻尾をつねってみよう。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "……うりゃ！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "痛くない……",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_006"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nということは、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "もしかしてこれって夢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "夢ならではってことは何も起こってないし、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_007"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "何も願わなかったせいで",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "つまんない夢になっちゃったのかも。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "でも逆に考えれば、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_008"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "誰にも邪魔されず",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n好きなだけダラダラできるってことでは……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そう考えたら、",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_009"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "割と悪くない初夢だね～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "とりあえず、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "横になって……",
        "unit_id": 102611
    },
    {
        "type": "still",
