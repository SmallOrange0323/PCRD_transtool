    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いや～",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_010"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n普段ならこんなところで寝転んだら、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n絶対リマリマとかしおりんが注意してくるもんね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "まっひ～はボケと勘違いして",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_011"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nツッコミ入れてきそうだけど。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "これで",
        "unit_id": 102611,
        "voice": "vo_adv_5134064_012"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "お菓子とジュースがあれば言うことなしだったけど、",
