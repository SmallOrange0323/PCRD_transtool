    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "とりあえず二度寝しよっと……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "おやすみ～……",
