[
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "找到了！",
        "unit_id": 129811,
        "voice": "vo_adv_5142302_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是那隻魔物！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "居然不學乖",
        "unit_id": 129911,
        "voice": "vo_adv_5142302_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又開始作亂，真是令人難以置信。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "到底是對自己的力量有多過度自信呀……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是啊……",
        "unit_id": 129811,
        "voice": "vo_adv_5142302_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "牠看起來比上次還要難纏喔？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在作亂的途中逐漸變強了呢……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哼。",
        "unit_id": 129911,
        "voice": "vo_adv_5142302_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這沒什麼大不了的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n畢竟是個只會用蠻力",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的愚蠢敵人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n根本不是我的對手。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "「只會用蠻力」……？",
        "unit_id": 129811,
        "voice": "vo_adv_5142302_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n跟某人有點像呢……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳有說什麼嗎？",
        "unit_id": 129911,
        "voice": "vo_adv_5142302_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 129811,
        "voice": "vo_adv_5142302_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有啊～？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起這個，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "走吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們趕快打倒那傢伙吧！",
        "unit_id": 129811
    }
]