        "type": "dialogue",
        "name": "初音",
        "words": "\n這裡是世界第一的好地方",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對吧，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哎呀！",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_061"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不、",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不要突然從後面抱住人啦……！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嚇了我一跳……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_062"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嚇到妳了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是的，",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣對心臟很不好呢，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抱歉抱歉。",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_064"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "誰叫小栞一個人站著發呆嘛～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我只是想起了以前的事。",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天的景色，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也像那時候一樣……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很漂亮呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_066"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今天是難得的野餐行！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我們來編花環吧，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就像那時候一樣！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "姊姊我",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_067"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "會幫小栞編一副",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "最適合小栞的漂亮花環喔～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……姊姊，",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_068"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時候的花環，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是我編給妳的喔。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈～！",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_069"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是這樣嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊雖然有心想要自己編，",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_070"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最後卻「果然還是太難了～！」",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "地喊著，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "結果，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "把採來的花朵",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "撒成花瓣雨了不是嗎？",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……那也",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很漂亮呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真不愧是小栞，",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_071"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "記性真好。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我都快沒了姊姊的威嚴啦！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣一來，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞不就成了姊姊了……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過小栞當姊姊……",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_072"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺好像也不能說是不好不是嗎……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳在說什麼啊……",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_073"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我的姊姊",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就只有初音姊姊一個人",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而已。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喔～",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_074"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這真是令人開心的發言呢，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我的好妹妹……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我的寶貝妹妹",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也只有",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞一個人喔～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "等一下，",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_075"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n妳這樣一直摸我的頭，頭髮會亂掉的……！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_076"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抱歉抱歉！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你！",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_077"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n難得來到這裡，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就讓我們好好享受一場快樂的野餐吧♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好啦，",
        "unit_id": 101211,
        "voice": "vo_adv_1807001_078"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞也是，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "笑一個笑一個！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……！",
        "unit_id": 103813,
        "voice": "vo_adv_1807001_079"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一如既往的美麗景色之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人就這樣開開心心地享受著野餐的樂趣。"
    }
