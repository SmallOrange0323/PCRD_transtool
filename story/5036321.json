    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "說的對，",
        "unit_id": 112611,
        "voice": "vo_adv_5036321_003"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "島村村！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "畢竟我們",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "可是偶像嘛！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是的！",
        "unit_id": 112411,
        "voice": "vo_adv_5036321_004"
    },
    {
