[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──收藏家七七香的公會小屋中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴跟七七香正在小屋裡熱烈地玩格鬥遊戲。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔唔唔唔……！",
        "unit_id": 101311,
        "voice": "vo_adv_5102101_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "鈴閣下，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳變強了呢……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這場勝負，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會贏的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳太認真了啦。",
        "unit_id": 102611,
        "voice": "vo_adv_5102101_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有破綻。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀──！",
        "unit_id": 101311,
        "voice": "vo_adv_5102101_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "輸掉了──！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再打一場！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再打一場吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……哎呀？",
        "unit_id": 101311,
        "voice": "vo_adv_5102101_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們玩得正盡興的說。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n到底",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是誰呀？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來了──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我現在就來開門喔──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦～！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "午安，",
        "unit_id": 104711,
        "voice": "vo_adv_5102101_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小七七香。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n抱歉，我突然來訪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為、",
        "unit_id": 101311,
        "voice": "vo_adv_5102101_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼【王宮騎士團】的團長，\n會到我的公會小屋來！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難道說……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是來逮捕我的嗎！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_5102101_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是那樣的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……不過妳",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有做了該被逮捕的壞事嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不不不不！",
        "unit_id": 101311,
        "voice": "vo_adv_5102101_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我怎麼敢呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總之，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "比起那個！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳找我有什麼事嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5102101_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實我有事情想要拜託妳……",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同一時刻。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n智在郊外巡邏時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到了某面旗幟。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那是",
        "unit_id": 103712,
        "voice": "vo_adv_5102101_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "「蘭德索爾文化祭」的旗子……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真好……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看起來好有趣……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我至今為止",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都沒參加過呢……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102101_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不能因為那種祭典而分心。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我除了是【王宮騎士團】的團員……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還是御久間流的繼承人啊……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智等人",
        "words": "下回",
        "unit_id": 1,
        "voice": "vo_adv_5102101_011"
    },
    {
        "type": "dialogue",
        "name": "智等人",
        "words": "「點讚！最愛！大集合！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智等人",
        "words": "至高祭典與少女祕密的本命任務」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我",
        "unit_id": 103712,
        "voice": "vo_adv_5102101_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會把我的「喜歡」隱藏好的……！",
        "unit_id": 103712
    }
]