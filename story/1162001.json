[
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我本來並沒有打算進德蕾女的。",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我從小就很討厭唸書，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n只要看到難一點的書，不用幾秒就會睡著。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一堆有錢人家大小姐在唸的嚴謹名校，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n根本不可能出現在我人生的選擇裡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我可是生長於偏僻又充滿麥酒味的街道，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n半輩子都混在雜亂的夜晚小巷，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n和同鄉的人們聊一些無關緊要的話題。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "將來我要隨便找個冒險者公會之類的組織加入，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n到處狩獵設有懸賞金的魔物，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n用賺到的錢買好吃的東西給家人──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n再用剩下的錢",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "讓自己偶爾穿一點帥氣的衣服──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說實在的，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當時我只有思考到這些事。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n畢竟想事情很麻煩嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n而且我母親以前也常說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "思考太多事，會變得像爸爸那樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以我就決定",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不再多加去做思考，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n只要隨興",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "想著「算了怎樣都好啦」就好了。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我父親打從骨子裡是一個森林精靈族，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不知道該說他是有點太纖細，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還是太熱愛鄉土，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他不管過了多少年都習慣不了住在街道的生活，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是個笨拙的人。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在回想起來，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他當時腦袋可能是有點切嚕了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等我成長到可以拿刀叉的年紀後，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n他就開始一天到晚帶我進森林",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "教我劍和弓的使用方式。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我爸爸小時候",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "目睹了氏族居住的森林裡的大災難，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n他一輩子一直很悔恨",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "自己沒能保護重要的家人，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想就是因此，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他才會想讓我這個長女",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "擁有保護人的力量。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "同年紀的男生都拿著網子和籠子追獨角仙的時候，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我則是一直拿著鋒利的短劍，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真正獵捕著森林裡的兇猛魔物。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "後來爸爸一個人待在森林裡的時間逐漸增加了，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這也代表",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "他回家的日子變得越來越少，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n最後他慶祝完長女14歲的生日，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "便至今都沒有回來。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，怎樣都好啦──",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當時我是這麼想的。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是某天晚上，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我和同鄉夥伴閒扯蛋完",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "偷偷摸摸回家時，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n發現我的母親一邊在哄我剛出生的弟弟睡覺，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n一邊蓋著棉被",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "蒙頭默默地哭。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "或許是在擔心夫妻的事、",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n小孩們的事、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n或是她自己得的病。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "或是擔心家人們的未來──",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我也不太清楚，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但我想應該有很多理由吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以我就心想，我要好好當個長女。",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當我母親說有認識的人向她推薦，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要我去上德蕾女的時候，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我心裡當然",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只覺得「妳在說什麼啊？」，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但我莫名地說不出口。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n相反的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我笑著說了「怎樣都好啊無所謂」。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後媽媽她也笑了，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n弟弟們也笑了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n他們還說「姊姊妳會讀書嗎～？」",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這種話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真煩人。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大家都一起笑了。",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之後我仔細調查，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n發現其實德蕾女的畢業生，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "將來好像都去從事了好工作。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n讓我感受到了能賺大錢的氣魄。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「這樣喔……」",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我這麼心想到，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之後就拚了命地在唸書。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "結果，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我總算是勉強考上了。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在散發著青剛櫟味的教室裡，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "幾乎都是從小學一路唸上來的純德蕾女學生，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n正如傳聞中所說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她們都是用詞高尚又優雅優雅的大小姐們。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "從外部「中途」進來的庶民很明顯不適合這裡，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n大家都會遠遠地看著我竊竊私語。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那時並不是我可以去搭話的氣氛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "像瑪麗亞，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙可是剛入學沒多久就一直狠瞪著我。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然是沒差啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但為什麼她會從初次見面就那麼討厭我，直到現在還是個謎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我也不是為了交朋友而來的所以沒差，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但還是滿不自在的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n「我待在這裡沒問題嗎？」",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這種念頭說實在也不是沒想過。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是到了第二年，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我就莫名地",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有了棲身之處。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該說是因緣際會嗎，",
        "unit_id": 110811,
        "voice": "vo_adv_1162001_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那就是個當場隨興組成的社團風公會。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
