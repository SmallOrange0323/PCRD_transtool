[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿～將軍，將～～～軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我有些事情想要拜託將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n所以今天才是來找你是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我覺得打仗並不是統一天下的捷徑。",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "俗話說欲速則不達是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以呢，請將軍帶我去圖書館！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "拜託啦……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妮諾接下來每天",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都會把將軍的草鞋放入懷裡暖鞋喔。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太棒了～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不愧是將軍是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那麼，我們趕快出發吧！",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哎呀～我今天去圖書館得到了很棒的成果～",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最棒的是，我終於讀到了一直都想讀看看的《武士道》！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我感動到內心震撼不已呢，祇園精舍的鐘都敲響了是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸？將軍問《武士道》是怎樣的一本書嗎？",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵，",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個啊……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "寫了很多關於將軍",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "或武士們的生活、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "想法，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n還有料理等等，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是一本非常棒的書是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有了！因為將軍今天帶我去了圖書館，",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n所以我想要送點回禮！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍想要什麼呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那可真是個好主意是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n馬上就能活用《武士道》的內容了呢！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個……對了。既然這樣的話，",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我就先從料理來試看看是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿嘿……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然我覺得很害羞……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但既然是將軍的請求，那就沒辦法了是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我知道了！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n那請將軍先去做些訓練，等到肚子餓了後再過來！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妮諾會在公會小屋做好料理等著將軍來的！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "料理的關鍵是愛心、真心，還有男子氣概。",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且還要裝得滿滿，裝成一座山！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n敬請期待是也～！",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，{player}以訓練來消磨時間後，\n回到公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "歡迎將軍回來是也！",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那、那～個……那個……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_017"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾不知為何紅著臉，扭扭捏捏的。\n隨後，像是豁出去似的。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "親、親愛的……？",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你想要先吃飯、洗澡、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n還是……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要・我・呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "…………",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請、請不要整個人都僵住了呀……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚嗚……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "果然還是不行嗎。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真的很對不起……我自己也清楚，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我有準備不足的地方是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可、可是……那個……裸體圍裙，",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n果然還是太令人害羞了是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "裸體圍裙……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n在《武士道》裡面有寫到這部分，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n那好像是在幫將軍做料理時的傳統規矩是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我有想說要試著做看看……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但真的要做時，臉紅得跟紅燈籠一樣，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不管怎樣都還是做不到是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來，我也會為了能遵從將軍的命令而修練是也～",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_025"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n所以……請不要把我扔掉……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚……嗚……嗚啊啊啊啊啊！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽到哭聲後，莫妮卡及空花等\n純白之翼 蘭德索爾分部的公會成員，\n也都陸陸續續靠過來了。"
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍……裸體圍裙……",
        "unit_id": 103011,
        "voice": "vo_adv_1030005_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n就裸體圍裙這件事，請放過我吧～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看到眼前的景象後，所有人都誤以為\n{player}要強迫妮諾做什麼變態行為。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後，為了要消除公會成員的誤解，\n{player}辛苦了好長一段時間……"
    }
]