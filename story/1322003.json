        "voice": "vo_adv_1322003_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "竟然都被你聽到了……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這樣就不算驚喜了呀～",
        "unit_id": 132212
