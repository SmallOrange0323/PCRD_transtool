    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因此，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}跟的鍊金術師生活，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n暫時也宣告到今天為止。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想要用鍊金術送你些什麼。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為你陪我一起留守嘛。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "調製書上記載著許多很棒的鍊金道具，",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n讓人看得眼花撩亂。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我正在傷腦筋",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你喜歡什麼樣的東西呢。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦、{player}！？",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的……",
