        "type": "dialogue",
        "name": "望",
        "words": "所以，{player}！",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n告訴我你想要什麼！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是來自我的禮物♪",
