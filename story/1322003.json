    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在阿爾克絲鍊金堂的工作室裡──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}發現了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一臉煩惱地在翻著鍊金術調製書的望。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯…………",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼比較好呢？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這年紀的男孩子",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "收到什麼會開心呢……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 132212,
        "voice": "vo_adv_1322003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易她們明天要回來蘭德索爾了。",
        "unit_id": 132212
