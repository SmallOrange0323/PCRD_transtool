[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在成功入手烤雞食材的隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和咲戀來到了街上。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉啊，又讓你來陪我。",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過今天",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不會像昨天那樣犯險了，放心吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天……",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要做蛋糕唷！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "它和烤雞並列聖誕節主角！",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一個蛋糕就能讓派對一口氣華麗起來喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也知道，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們人數眾多，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果只是買一塊大蛋糕，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很顯然完全不夠分。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果要買足夠所有人吃的蛋糕數，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有再多預算都不夠用。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以呢，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我決定備齊食材自己動手做。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是完美的計畫！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別小看【咲戀育幼院】的公會長啦。",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然平時家事都是鈴莓負責，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我還是能完成大部分的事喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在育幼院做蛋糕的話",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會被孩子們發現，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以我已經安排好能讓我們使用廚房的店家了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先去買食材吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "前面有間",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和我們有生意往來的食品店，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就麻煩你幫忙拿東西啦。",
        "unit_id": 114511
    },
    {
        "type": "background",
        "background": "500610"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "歡迎光臨。",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_009"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是咲戀小姐啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n連聖誕節都在做生意，真熱衷於工作呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很遺憾，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我今天只是個普通的客人喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我來買做蛋糕的食材。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "需要麵粉、牛奶、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雞蛋還有……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "咦，",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_011"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "蛋糕的……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "難不成是小姐要做的？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有什麼問題嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難道說，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你覺得我不會做蛋糕？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不，",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我不是那個意思。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "其實，做蛋糕用的食材都已經缺貨了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "騙、",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "騙人……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些東西是不可能缺貨的吧！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是在聖誕季，這也太不可思議了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "當然，我們為了迎合聖誕節的需求，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "每年食材的進貨量",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n都很龐大。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但今年好像有一個大型的聖誕活動，",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "活動的看點是一個巨型蛋糕，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n他們買了大量食材，都快把倉庫搬空了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎、",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼這樣……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不能去蛋糕店買現成的嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊對了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我記得小姐家裡孩子很多呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就算要買，在這種時期蛋糕店的預約都爆滿了，",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_019"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n連能不能買到都很難說。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……放棄……",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的選項可不存在我腦海裡呢！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n首先要確保現階段能獲得的食材！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再來，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會試著聯絡其他同行。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想為孩子們",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做出最棒的蛋糕！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小姐……",
        "unit_id": 1411,
        "voice": "vo_adv_1145002_023"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好，我知道了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我也常",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "受到妳的關照。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我會幫妳向其他店家打聽看看！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "總之先把水果拿去吧，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "有了這個的話蛋糕也會好看很多吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "店長先生……",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太謝謝你了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "你好──",
        "unit_id": 2511,
        "voice": "vo_adv_1145002_025"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我把訂購的商品送來了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "哎呀，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "咲戀小姐。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "妳之前介紹的那間店，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "已經和我們成功簽約囉。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你來的正好！",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你那裡",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n做蛋糕的食材嗎？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_1145002_027"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "原來如此。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "其實，我們也有為那個活動提供食材，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n現在已經沒有庫存了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "不過，",
        "unit_id": 2511,
        "voice": "vo_adv_1145002_028"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "如果是為了咲戀小姐，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我會試著幫妳收集看看。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "只不過，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "沒辦法保證數量……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣就夠了！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在只剩以防萬一用的，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能讓蛋糕富含變化的材料……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "你好──",
        "unit_id": 311,
        "voice": "vo_adv_1145002_030"
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "我想買要放入巧克力中的堅果……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "咲戀小姐！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "巧克力店",
        "words": "妳之前幫我安排的原料，",
