        "name": "咲戀",
        "words": "不過契機是你",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無意間的一句話喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n光靠我一個人的話，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可能想不到這種點子呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很感謝你喔。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我從沒如此慶幸過自己有在從事買賣呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "至今為止構築的商業合作關係，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我收集到了這麼多的食材。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我開始覺得，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這一塊塊蛋糕，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都飽含了我這段時間的工作成果。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能和孩子們炫耀了呢。",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對他們說",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「這就是咲戀媽媽的工作」。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 114511,
        "voice": "vo_adv_1145002_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "作為回報，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就讓你試吃看看吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可是第一個吃到",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咲戀媽媽手作蛋糕的人喔？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n感到光榮吧，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵呵♪",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咲戀手上拿著最棒的蛋糕，露出了滿足的笑容。"
    },
