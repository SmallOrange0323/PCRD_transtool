[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "～……♪",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n啊，{player}！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在這裡做什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，這可是在下的台詞喔。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難得會在廣場見到面呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直以來都受您照顧了♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊小不點，妳也在啊。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們好像一直形影不離呢～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，其實也並非如此。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過可以的話，在下還是希望一直跟主人在一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是個隨性的人，也常常會迷路。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有時候也會和主人分開活動。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然……為了能在發生事情時趕到主人身旁，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也會密集與主人聯絡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小不點還真是溺愛呢～",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳呀，感覺就是{player}的監護人。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就目測年齡來說明明就應該是相反的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直以來都辛苦妳啦，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真乖真乖♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請、請不要摸在下的頭。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，在下從之前就想跟您提這件事，",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請不要叫在下小不點。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下個頭也沒有很小喔？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，很小隻嘛。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……妳的名字，叫可可蘿嘛。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我就叫妳小可可蘿或可蘿仔囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃那個，請用正常的方式叫在下……",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，還是用凱留小姐喜歡的方式就好，",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下不會介意的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過話說回來，你們在做什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n約會嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是，只是漫無目的隨意逛逛而已。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人對蘭德索爾還不太熟悉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在確認地理環境，順便散散步。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，您在做什麼呢？",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來好像在吃什麼路邊攤小吃。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一不小心買太多了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們不嫌棄的話，可以幫我吃一點嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下食量很小。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果現在吃東西的話，晚飯就會吃不下了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最近跟大家一起吃飯已經成為慣例了。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果坐在一起卻因為吃飽而無法進食，會讓在下過意不去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，這個小吃就給主人享用吧。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，主人，啊～♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然之前覺得你們像父女……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是這已經是寵物跟飼主的關係了吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是奇怪的一伙～♪",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，妳說得有道理。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知為何，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最近我跟妳，還有那個笨蛋……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟蒂亞娜一起吃晚餐，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經變成每天的例行事項了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蒂亞娜？",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問是指佩可小姐嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對對，貪吃佩可。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是這麼稱呼的呢，嗯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎麼樣。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直以來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都是由那個貪吃佩可決定要吃飯的餐廳吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。畢竟在這群人之中，",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最熟悉餐飲店家的就是佩可小姐了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖說就讓她決定，不過她也介紹許多餐廳給在下等人呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是啊～",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然那傢伙選的店家都很棒，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過也有很高機率會出現奇異料理店呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我很不喜歡呢～",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n之前也被強迫吃了蟲。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蟲很好吃呀。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n前幾天的餐廳，真的非常地棒♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不太甘心，但是好吃的東西就是好吃。",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我生理上不能接受……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以啊，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n從今以後要不要輪流選餐廳用餐呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，被餵食可怕東西的機率就會下降了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正因為這樣，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我到處品嚐跟比較每個路邊攤跟餐廳的菜呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "美食，也開始變得有趣了♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也對呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大家總是教導在下等人飲食的樂趣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且，就像您所說的，",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人似乎過度依賴佩可小姐了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓她一個人承受負擔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人要是也能夠介紹店家的話……",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n佩可小姐就會輕鬆很多了吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐是這樣的心意吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您認為",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只受人施予很過意不去對吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n呵呵，凱留小姐真是貼心♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，請妳不要誤會？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我呀，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只是不想要被強迫吃奇異料理而已！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "四處品嚐食物也會增長知識，而且",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n即使被誤餵了蟲還是什麼的時候也會發覺呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就只是這樣而已，不要有奇怪的誤解喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下知道，",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就當作是這樣吧♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這什麼令人匪夷所思的語氣……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎樣，妳有沒有看到那邊有家破破爛爛的餐廳？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那家餐廳的菜可是美味超群喔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天晚餐就在那裡吃吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "菜色也很豐富，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最近我很常去呢～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下沒有異議。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先別管這個。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像有個龐然大物正在接近這裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那該不會是佩可小姐吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、什麼龐然大物？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好可怕！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，真的耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是那個笨蛋呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她在幹什麼啊，",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像揹了個很大的布包巾包裹在走路呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉呀，小可蘿跟小凱留！",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也在！阿囉哈～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還悠哉地打什麼招呼呀，妳到底在幹嘛……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼要揹著這麼大包的東西，妳是笨蛋嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不要幫妳搬？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事的～",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的臂力很強的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且這全部都是食材呢～……",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為知道這些都會變成美味佳餚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以完全不覺得重呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "食材？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看起來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼全部都像是魔物呢……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物很好吃唷？",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是處理起來比較困難。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n魔物可是我在城市外頭時的主食呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管怎樣。",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天是受了認識的人委託，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n取得了這些食材呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們看，就是那家餐廳！",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒有招牌你們看不出來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那可是魔物料理的專賣店唷～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾絕無僅有，就是這裡！",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，那家店……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會，就是那家破破爛爛的店嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，是魔物料理的專賣店嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我最近才成為常客的說！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，我有聽說唷。",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我跟店主認識。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他說有可愛的獸人女孩子，",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃得非～常津津有味的樣子……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來就是指小凱留呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留喜歡魔物料理呀～真高興！",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛好今天我也獲得許多的食材，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就請妳多吃點吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_064"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噁。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我、我突然不太舒服。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我吃的，居然是魔物嗎～！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物很好吃唷？",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看，這魔物的眼球，可是好吃到不要不要的～……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要給我看這個醜惡的生物……！？",
        "unit_id": 106012,
        "voice": "vo_adv_3001003_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、我真的吃了那種東西嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵呵……",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先別管這個了，佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下剛剛跟凱留小姐聊了一下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望今後可以輪流選擇晚餐的餐廳。",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每天都讓佩可小姐決定，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺給您添了不少麻煩。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人也想藉此感謝您一直介紹美味的餐廳……",
        "unit_id": 105913,
        "voice": "vo_adv_3001003_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是凱留小姐的意見。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係啦～ ",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，有這樣的心意我很高興！ ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\nOKOK，那就這樣吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很期待你們兩個會介紹什麼樣的店家喔～♪",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好興奮唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很感謝大家的心意～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遇到好夥伴是上天賜給我的恩惠！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們，身為食遍天下專業公會【美食殿堂】……",
        "unit_id": 105812,
        "voice": "vo_adv_3001003_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從今以後也要相親相愛地一起吃吃喝喝呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下？",
