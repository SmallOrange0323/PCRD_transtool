        "voice": "vo_adv_5064700_002"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n出てこないね～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "オレたちのこと忘れてるんじゃないか？",
