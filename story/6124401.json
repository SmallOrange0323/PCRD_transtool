        "voice": "vo_adv_6124401_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]為什麼你總是、",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]總是被美女包圍著啊！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]有什麼內情！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]到底是有什麼內情啊～！！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124401_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]你說總是順勢就變成這樣！？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]以統計數據來說太奇怪了！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]這世界上可是男女各半喔！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]把你的運氣給我啊小伙子～～～！！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124401_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]原來如此，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]你就是這樣裝成人畜無害的樣子去拐騙人家啊！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]真是個超乎想像的好色之徒！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]給我去死吧小伙子～～～！！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]咦……",
        "unit_id": 2415,
        "voice": "vo_adv_6124401_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]也、",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]也想跟我……？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]你雖然",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]看起來像好色之徒，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]但其實就只是個天真無邪的好人啊……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]你以為我會這樣說嗎小伙子～～～！！",
        "unit_id": 2415
    }
]