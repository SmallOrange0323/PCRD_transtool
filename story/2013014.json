        "voice": "vo_adv_2013014_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n明明這邊都已經到極限了呀！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "至少，",
        "unit_id": 103111,
        "voice": "vo_adv_2013014_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得確保好退路……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊啊，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不行，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "每個方位",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都顯示著凶兆。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不論往哪邊逃都不成。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎怎怎、",
        "unit_id": 102211,
        "voice": "vo_adv_2013014_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼辦才好呀？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我們，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "全都要死在這了嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚，",
        "unit_id": 102211,
        "voice": "vo_adv_2013014_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里～！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n至少，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "至少就只有妳也要活下去呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呣嘎！？",
        "unit_id": 100611,
        "voice": "vo_adv_2013014_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n難、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "難得竟然是姊姊主動抱上來了呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n害得連我也動搖了啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是。",
        "unit_id": 100611,
        "voice": "vo_adv_2013014_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "畢竟我們是一起出生的嘛，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n那麼就算是死也要在一起唷……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒、",
        "unit_id": 100711,
        "voice": "vo_adv_2013014_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒沒、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒問題的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就算死掉了也活的下去喲！　",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "像宮子這樣！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2013014_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子妳算是相當例外的存在就是了呢……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過嘛，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果大家都變成了幽靈然後飄在一塊兒",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎也挺有趣的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……啊，",
        "unit_id": 103111,
        "voice": "vo_adv_2013014_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是開玩笑的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "當然，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我可沒有死在這裡的打算。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我心愛的女兒啊，",
        "unit_id": 2411,
        "voice": "vo_adv_2013014_011"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳這笑話很難懂啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們還挺放鬆的嘛。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但是不用多久，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們全部人可就再也笑不出來了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……呣？",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_013"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嗚喔啊啊啊啊！",
        "unit_id": 190711,
        "voice": "vo_adv_2013014_014"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你們都沒事吧？拉基拉基兄，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我們來支援你們啦啦啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不錯不錯，",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真不愧是大吾！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真是驚人的突破力呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_2013014_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等等給你摸摸頭吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我等一夥只要傻傻的跟在這小子的後頭就好了呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是輕鬆呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們的朋友們看來都到齊了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位！",
        "unit_id": 105911,
        "voice": "vo_adv_2013014_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否無事呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　",
        "unit_id": 105811,
        "voice": "vo_adv_2013014_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家也請快點到我們這邊來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有相當不尋常數量的魔物正朝著這來……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快點讓{player}替大家進行強化吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不用！　",
        "unit_id": 190711,
        "voice": "vo_adv_2013014_020"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "老子這天然純度100%，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n打從娘胎出生後經過了超強鍛鍊的肉體，管他怎樣的敵人我都贏得了啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這就是所謂打手的堅持啦，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘎哈哈哈哈☆",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且啊，",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "同樣也應該算是「公主騎士」的大吾，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}的力量會有效嗎……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這方面的設定，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是被怎麼樣來解釋來著的？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂！諾維姆，",
        "unit_id": 190711,
        "voice": "vo_adv_2013014_022"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別還在那碎碎念了趕快準備好要幹架啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "四周都被魔物塞得滿滿滿了呀，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n可不知道會有怎樣的攻擊從哪邊殺過來的啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是傻眼了呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然為了尋死專程聚集過來呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "盡愛做些蠢事呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是我故意進行了誘導，你們才能夠如此輕易地",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n進到魔物的包圍圈內的，連這都沒發現？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就讓我來送你們上路。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好好盡情地絕望吧，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "戰爭靠的可是數量唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原～來如此，",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這可真是受教了呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你好像也太小看了我們一點呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n確實戰爭是比看誰人較多，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這樣的話",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們也把數量堆起來就好啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳想說什麼。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳可別忘了自己是個笨蛋，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以為了讓他人能夠理解，至少在說話上",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再加把勁吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n在『前世』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這話我是不是說到",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳耳朵都長繭了？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔！　",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就是個笨蛋！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果因為這樣就放棄",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才是大笨蛋呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以我才拚命的學習，",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後思考，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "並且把重要的事情告訴給了大家！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就為了有朝一日，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以奪回我們和平的日常！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們一定會阻止像你這種壞蛋的邪惡企圖，",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n然後建立一個讓溫柔又善良的人們可以笑著過日子的世界啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "盡是些臭小鬼的屁話。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哎呀？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "克莉絲提娜！",
        "unit_id": 101711,
        "voice": "vo_adv_2013014_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今天可是一定要讓妳付出代價的呀～，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我一定要讓妳去和那些被妳傷害過的獸人們",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "低頭道歉呀～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我站住呀啊啊啊，",
        "unit_id": 104311,
        "voice": "vo_adv_2013014_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "克莉絲提娜啊啊啊啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳可別給我再跑了啊，",
        "unit_id": 104311,
        "voice": "vo_adv_2013014_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我這可是整個肚子都火大了的啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在我面前擺著一大塊鮮嫩多汁的肉，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n別還以為能夠一直叫我『等一下』的呀呀呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真、",
        "unit_id": 100211,
        "voice": "vo_adv_2013014_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴，妳冷靜一點！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "狀況",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像有點奇怪唷，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且四周還都充斥著魔物……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……！",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "草野優衣？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211,
        "voice": "vo_adv_2013014_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n為什麼，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就連妳也用",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "草野優衣來叫我呢……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯……",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_038"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別放在心上。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這話和『妳』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒有什麼太大的關係呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我這可還真是心想事成了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳還真是個好孩子呢，諾維姆，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "最後總還是派得上用場……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是為了我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "特別準備了這一桌豐盛的大餐嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106113,
        "voice": "vo_adv_2013014_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你是什麼意思？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "那位霸瞳皇帝的目的，",
        "unit_id": 107311,
        "voice": "vo_adv_2013014_041"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是要將我們趕盡殺絕。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "再正確一點來說，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是要將我們殺害後抽出魂魄，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n然後再吞食下肚……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "的樣子。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒錯。",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "照這樣看來是你們自己成了餌，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而弄得對克莉絲有私怨的【哞哞自衛隊】一行人，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n被引誘到這裡來的樣子呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而對我這來說，",
        "unit_id": 106914,
        "voice": "vo_adv_2013014_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可是求之不得的呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不論質與量",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都是一級品，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這些優良的活祭品可是自己湊到這來了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊？　",
        "unit_id": 104311,
        "voice": "vo_adv_2013014_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是怎樣啊妳這傢伙？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n別在那邊說些什麼讓人聽不懂的話啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等妳有點太衝了喵～",
        "unit_id": 104611,
        "voice": "vo_adv_2013014_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真琴。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n再怎麼說",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在還是先想辦法讓城裡的人去避難，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還有解決這些魔物才是最優先的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "私人的恩恩怨怨，",
        "unit_id": 104611,
        "voice": "vo_adv_2013014_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "之後會再讓妳有機會討的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真不愧是珠姐呀，",
        "unit_id": 100111,
        "voice": "vo_adv_2013014_047"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "講話意外的成熟！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "實際上，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在也不是吵架的時候了呀～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "首先得要守護好這座城，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有大家的和平才行！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也認為日和她這話說的沒有錯唷。",
        "unit_id": 100311,
        "voice": "vo_adv_2013014_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "僅管現在還不太能夠釐清現況……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而從對立的位置來推測，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那名浮在空中的謎之人物，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎正是操縱這群魔物的罪魁禍首。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是這樣，",
        "unit_id": 100311,
        "voice": "vo_adv_2013014_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼將該人物擊敗，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "事情應該就會告一段落。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真不愧是怜！",
        "unit_id": 100111,
        "voice": "vo_adv_2013014_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明看起是冷靜的深思熟慮，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但不知為什麼每次給出的結論",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都很極端！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100311,
        "voice": "vo_adv_2013014_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\nSimple is best唷，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和♪",
        "unit_id": 100311
    }
]