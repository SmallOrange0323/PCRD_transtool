        "voice": "vo_adv_1106004_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "馬先生的背上，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還挺高的呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能陪我來，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "選擇兩人一起騎乘的路線，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是正確呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n騎在馬先生背上的王子先生，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "前來迎接人家這個公主，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n兩個人",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "悠閒地約會……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不覺得很浪漫嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可以再抱得緊一點嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為要是掉下去可就不好了呀。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀。",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "難道您在害羞嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真可愛。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～！",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "碰到身體的海水冰冰涼涼的，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好舒服～",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "天空好藍，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大海也好寂靜。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n和王子先生騎在馬上",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "悠閒地在大海散步……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是最棒的暑假了～♪",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呀啊！？",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n請、",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請您不要",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "突然搖搖晃晃的。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "馬先生",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "去絆到小石子了啊。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好乖好乖，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "冷靜下來，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "乖孩子。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您怎麼了？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n身體突然動來動去的……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為剛才的晃動嚇了一跳，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n讓您冷靜不下來嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？　",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會無法冷靜",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是因為人家身體貼著您的關係？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是容易害羞的人呢♪",
        "unit_id": 101031
    },
    {
        "type": "still",
        "still": "110600402"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像這樣",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "緊緊抱著後，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感覺好像能聽到",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生的心跳聲呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101031,
        "voice": "vo_adv_1106004_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一直以來",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都覺得夏天的海邊",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
