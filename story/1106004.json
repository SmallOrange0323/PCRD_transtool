    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與聖獸開心交流的真步與{player}，\n等回過神已經日落時分了。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "轉眼間一天就過去了呢。",
        "unit_id": 110611,
        "voice": "vo_adv_1106004_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 110611,
        "voice": "vo_adv_1106004_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您看呀。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在夕陽的照射下，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大海也一閃一閃的。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "宛如",
        "unit_id": 110611,
        "voice": "vo_adv_1106004_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "光芒",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從天而降一般呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n璀璨閃耀，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是好耀眼～",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀？　",
        "unit_id": 110611,
        "voice": "vo_adv_1106004_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "難道說",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "光芒真的從天而降了？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真漂亮♪",
        "unit_id": 110611
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您好。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家想說",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來這裡就能見到您呢♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個……",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實今天",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有事想拜託王子先生，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以才在這埋伏您的。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您果然",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "願意聽人家說呢。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果真是個溫柔的人♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為人家無論如何",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都想見到王子先生嘛。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我有很重要的事要拜託您～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次的假日，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想去見",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "馬先生。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國的馬先生呀，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是在草原上，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而是海中走路的喔。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n然後，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓王子先生和公主小姐",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "騎在背上，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一起去散步。",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "悠悠地～",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "悠悠地～",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "望著蒼藍天空與大海，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一邊度過悠～閒的時光……",
