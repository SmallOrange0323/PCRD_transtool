    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不覺得這很棒嗎？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生要不要",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也和人家一起去見",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真步真步王國的馬先生呢？",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不愧是王子先生，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "二話不說馬上答應了♪",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101032,
        "voice": "vo_adv_1106004_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下次的假日，",
        "unit_id": 101032
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "兩人一起去見馬先生吧♪",
        "unit_id": 101032
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "是，",
        "unit_id": 1231,
        "voice": "vo_adv_1106004_014"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "明白了。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n水中騎馬體驗路線對吧。",
        "unit_id": 1231
    },
    {
        "type": "still",
        "still": "110600401"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇啊～",
