[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在解決幽靈船秘寶騷動的幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n忍和{player}來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天非常安靜呢。",
        "unit_id": 122012,
        "voice": "vo_adv_1220004_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n讓人覺得前陣子的騷動",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就像是謊言一樣。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為這陣子都在忙，",
        "unit_id": 122012,
        "voice": "vo_adv_1220004_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以今天我想好好休息，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "放鬆一下。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "話說回來，",
        "unit_id": 122012,
        "voice": "vo_adv_1220004_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "天氣真好呢。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n陽光還有些刺眼。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我覺得好睏……",
        "unit_id": 122012
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n竟然在這裡碰面，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是巧呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你是要去哪裡嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………？",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n怎麼了嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你是在意這把鏟子嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我接了某個尋物委託，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "正準備出去呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你一臉感到不可思議的表情呢。",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你有興趣嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想想……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "兩個人感覺會比較有效率呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你有空願意幫忙的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會很感激的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你好像很高興呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那我們就出發吧。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我今天是要",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來這裡找東西。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這並不是工作……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "利用占卜兼職的空檔，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n聽幽靈他們的請求，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n從旁協助他們，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓他們能順利成佛。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "至於這次的委託……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對方拜託我",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來這裡確認",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "古代埋藏的寶藏……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是否真的存在。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "埋藏的寶藏。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就是常常被電視節目",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "視為傳說的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那種。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "根據那個幽靈表示，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他生前似乎透過某種管道，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n取得了疑似",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "埋有傳說寶藏的地圖和鑰匙。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "從那之後，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n他腦中無時無刻",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都在想著傳說是否屬實……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "以至於在他過世之後，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不小心成了幽靈。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我才會代替無法親自尋找的幽靈",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "前來調查。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我就",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "把這些交給你了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "調",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "查所需的地圖，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來這裡的路上，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我買了給你用的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我們",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就從重點區域開始找起吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我在事前根據委託幽靈的情報，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n透過占卜篩選出可疑的地段了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "首先",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就從那裡開始吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我的探測術顯示",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要再稍微往右……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是那邊。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請挖看看那裡，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也來幫忙。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沙子裡",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有東西出現了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別人遺失的錢包嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n等一下拿去派出所吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接著是……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來是在那邊呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這次是戒指呢。",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個等一下",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也跟錢包一起拿過去。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嘿咻……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n把我們挖的洞",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "填回去吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要是絆倒別人會很危險的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好熱……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這工作比我想的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還要辛苦呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們連一半都還沒找完，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以要再趕一下進度……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……對不起，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我好像絆到腳了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是你救了我呢。",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以說，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我已經不要緊了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n一直被這樣抱著……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓人有些",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難為情……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你別一直道歉，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "畢竟這本來",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是我的一個不小心才造成的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……對不起，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n看來我似乎",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太勉強自己了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就到那邊的陰涼處",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "休息一下吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我買冰涼的飲料過來了。",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你也請喝吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然我父親的頭抖得很厲害，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不過你不必在意。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他從剛才",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你救了我的時候開始，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就一直用各式各樣的話語",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唸出帶著恨意的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但是那不會讓人遭逢詛咒之類的危害。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我問你……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}也有",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "即使變成幽靈……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也想實現的夢想嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我只是想聽聽看而已。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為聽了幽靈他們的請求後，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n讓我偶爾會這麼想。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "即使變成幽靈也想實現的夢……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有那樣的夢想",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "到底會是怎樣的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "心情呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算死了",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "仍流連在人世……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n有著那樣全心投入的夢想",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真好呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有著即使死了也想實現的夢想和憧憬，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n讓人感到有些……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "羨慕。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對不起，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我長篇大論了起來。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "繼續回去挖地吧。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510251"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……？",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我好像敲到了什麼。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺體積很大呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "把它挖出來吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好大的一個木箱……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "上頭用了鐵製零件裝飾，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺非常牢固。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n似乎還上了鎖呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請等一下，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我記得",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他有交給我鑰匙……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果委託人說的沒錯，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該可以用這把鑰匙打開……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "打開了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "裡面放的是……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "骨董嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "破掉的陶器，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有泡水變得皺巴巴的書籍……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "全都受損得很嚴重呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "假如裡面的物品沒有受損，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n或許是有一定的價值……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但說真的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我覺得並不是特別值得期待的高價物品。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也就是說，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_048"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "委託者所說埋藏的寶藏……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n看來果然是不存在呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許這樣就好了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "委託幽靈所留戀的是，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_050"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n傳說中埋藏的寶藏是否存在，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他想確認這個真相。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因此……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算沒有埋藏他期盼的寶藏，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該也能化解",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一直將他困在人世的留戀之心。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣就算是",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "完成委託了呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}，你也辛苦了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在只剩回去……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就大功告成了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過都跑來了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要不要",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在回去之前欣賞一下大海呢？",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510251"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……好美呢。",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如烈焰燃燒的夕陽沉入地平線下，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n天空漸漸變黑……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n即使如此，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太陽仍綻放著耀眼的光芒直到最後一刻。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "假設夢想",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就像那顆太陽……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n感覺光是懷有夢想，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就能從胸口深處",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "湧現力量。",
        "unit_id": 103131
    },
    {
        "type": "still",
        "still": "122000401"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……剛才，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會說很羨慕幽靈他們，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是因為我想像不到",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "自己有像他們一樣的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "夢想和憧憬。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "做占卜的兼職，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也讓我替許多人",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "占卜過他們的夢想，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n實際上",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也有人真的實現了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然而，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "換成了自己卻看不清自己的夢想，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這真是奇怪呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該就是因為這樣吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看到幽靈他們，",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_060"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n懷有寧願不成佛也不放棄的熱情和願望……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n有時讓我覺得",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "非常耀眼。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_061"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許是透過幫助大家，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n好讓自己分心不去想吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許我沒有……",
        "unit_id": 103131,
        "voice": "vo_adv_1220004_062"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那麼耀眼又溫暖，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "會打從心底湧現的力量吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n……一想到這裡，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就讓我好害怕。",
        "unit_id": 103131
