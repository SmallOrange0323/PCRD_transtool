[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "正月で賑わうランドソルの繁華街を、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nモニカとメドゥーサは散策していた。"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "っくしゅん！",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_000"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "蛇祭りのときは気づかなかったけど、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ランドソルって寒いわね……！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "この国の人たち、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "よくこんな寒い所で生きていけるわね……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "たしかに寒いが、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "この時期ならこれくらいは普通だな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nしのげないほどではあるまい。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nさらに寒い土地に暮らす人々もいることだし。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "うえぇ、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_002"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "信じられない……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "蛇には絶対に無理ね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ジオ・ゲヘナが快適なんて全然言えないけど、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_003"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n少なくともこんな凍えそうな目に遭ったことはないわ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ランドソルはいい所だけど、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_004"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "今はちょっとだけ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ジオ・ゲヘナの暑さが恋しいわね……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ならば其方にうってつけの店があるぞ。",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_005"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "案内してやろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ちょうど腹も減ってきた頃だろう？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "別にいいけど。",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_006"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アンタのことだから甘いもののお店でしょ？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "甘酒とかおしることか。",
        "unit_id": 133611
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "お待たせしました、",
        "unit_id": 1,
        "voice": "vo_adv_5160602_007"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "特製ボルケーノカレーです！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お、",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_008"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "来た来た。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "熱いうちにいただくとしよう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "いや、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_009"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ちょっと待ちなさいよ！　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "これって激辛料理じゃない！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nジオ・ゲヘナのと同じくらい真っ赤だわ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "あぅ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "か、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "辛さが目に……！　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "こんなの食べられないわよ！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ん？　",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_010"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうか。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ジオ・ゲヘナの貴族なら",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nこれくらいはあっさりと完食できると思ったのだが……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "まあ無理はするな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "其方の分も私が食べよう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "は、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_011"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "はぁ？　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "このアタシがこれくらいで退くはずがないじゃない！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n食べるわよ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "食べきってやるわよ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "はむっ。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "……ん、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_012"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "んんんん！　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "か、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "辛いいいいー！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "口の中がヒリヒリするし、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "一気に汗が噴き出してきた……！　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "この強烈さ、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_013"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ジオ・ゲヘナのご飯にも負けてないわよ。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nああ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "全身がカッカしてなんだか向こうにいるみたいだわ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "もしかしてモニカのヤツ、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_014"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nこのためにアタシを連れて来てくれたの？　",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どうした？　",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_015"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "手が止まってるぞ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "さすがに辛すぎたか？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふ、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_016"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふん。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "おいしくてちょっと感動してただけよ。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アンタこそ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ギブアップするなら今の内よ！",
        "unit_id": 133611
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "は、",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_017"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふうぅ……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どうにか食べきったが、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "口の中が熱くてたまらんな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あれを私より先に完食するとは、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "さすがだな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "と、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_018"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "当然よ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アタシを、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "だ、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "誰だと思ってるのよ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "あー辛かったぁ……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "今は確かに、",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_019"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "冷え込む時期だが",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nだがいずれ季節が巡って暖かくなり、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "楽しいことも沢山待っている。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "だから",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_020"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "もう少しだけ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "我慢してほしい。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "そうね。",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_021"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "また寒さに耐えられなくなったら、",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nまたあのカレーを食べるから大丈夫。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "もちろんアンタのおごりでね。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふっ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160602_022"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "了解した。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "その時はさらに辛さ増し増しを食わせてやろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "の、",
        "unit_id": 133611,
        "voice": "vo_adv_5160602_023"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "望むところよ……！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "こうしてモニカの荒療治によって"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nメドゥーサのホームシックは見事解消されたのだった。"
    }
]