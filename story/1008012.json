        "voice": "vo_adv_1008012_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我以前都不曉得，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n原來我在你面前，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會露出這種笑容呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是我原本也不知道的，",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_053"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗的我。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果我們沒有兩人一起來此，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許我便沒機會有所發現。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光是察覺到這點，",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_054"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是很大的收穫了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然被困在鏡中時，",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_055"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我是想要讓世上所有人",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都徹底欣賞我所有的美麗模樣……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是……",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_056"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許唯獨「那個我」，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n繼續讓你我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "兩個人獨占",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也不壞呢……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "隨口說說而已～♪",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_057"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們快點回去吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在回到城鎮前，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給你好好護送我的機會喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說真的，",
        "unit_id": 100811,
        "voice": "vo_adv_1008012_058"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你真是個幸運的傢伙呢♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夕陽照耀出雪臉上的燦爛笑容，"
    },
    {
