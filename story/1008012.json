    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即使碰上如此悽慘的狀況，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我依然很美呢……",
