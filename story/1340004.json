    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "熟悉的風景、",
        "unit_id": 1,
        "voice": "vo_adv_1340004_001"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "令人懷念的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "氣氛──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "──看來我",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_002"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "回來了呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "等等，",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_003"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "為什麼啊！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不是原本的模樣了！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是晶搞的鬼？",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_004"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n難道出了什麼差錯嗎？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真是的……",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_005"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊……",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_006"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那是我平常在說的！",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_007"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是說，",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_008"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我費了這麼多功夫才回來，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你對我說的第一句話卻是這個！？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n你只是想說一次看看而已吧！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "一般而言，這種時候要說──",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_009"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_010"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我……",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_011"
    },
    {
        "type": "still",
        "still": "134000401"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我回來了～～～～～！",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_012"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我好害怕～！",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_013"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n真的好害怕！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我第一次用人類的身體，",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_014"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n還被國際刑警追趕，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n也不知道該怎麼做才好！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "──而且你也不在！",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_015"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我真的……",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_016"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好害怕……！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "至少有你的聲音陪在我身邊，",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_017"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真的幫了大忙……！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……！",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_018"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那當然。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n因為我",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "要成為",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "獨當一面的嚮導小妖精嘛。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這點程度的事，",
        "unit_id": 134011,
        "voice": "vo_adv_1340004_019"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "完全",
