[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……是因為現在已經用星素之力",
        "unit_id": 128911,
        "voice": "vo_adv_5136204_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "強化過了嗎。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n可以清楚感覺到",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "環境的變化呢。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽妳這麼一說……",
        "unit_id": 128711,
        "voice": "vo_adv_5136204_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n感覺皮膚好像在隱隱作痛？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這就代表精靈是這麼地憤怒嗎。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟妨礙到它的工作了呢，",
        "unit_id": 128811,
        "voice": "vo_adv_5136204_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n心情想必是不會好的吧。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無論如何，",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要趕緊做個了斷才好。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我來探查看看",
        "unit_id": 128911,
        "voice": "vo_adv_5136204_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "精靈的氣息吧。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "經過在精靈族之村的修行，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我現在",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "應該可以比較容易掌握到它的所在地。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拜託妳了，",
        "unit_id": 128711,
        "voice": "vo_adv_5136204_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也來仔細聆聽一下周遭的聲音！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我聽聽看……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哈啾！！",
        "unit_id": 135512,
        "voice": "vo_adv_5136204_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊啊！？",
        "unit_id": 128711,
        "voice": "vo_adv_5136204_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嚇了我一跳！！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉抱歉！",
        "unit_id": 135512,
        "voice": "vo_adv_5136204_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我脖子周圍的這個茸毛啊？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n有點搔得鼻子癢癢的～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "了……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈。",
        "unit_id": 135512
    },
    {
