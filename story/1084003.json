    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "～～♪　～～～♪",
        "unit_id": 1,
        "voice": "vo_adv_1084003_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯嗯，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱得比剛才大聲呢！",
