    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "白天也受到他們的幫助是有點不好意思，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不過去拜託看看吧。",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很爽快的直接借我們場地呢，",
