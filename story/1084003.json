    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就出發吧。",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好大的會場啊……",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然是有聽說過，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但比想像中更大。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不努力可不行。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想要唱出幸福的聖誕歌，",
