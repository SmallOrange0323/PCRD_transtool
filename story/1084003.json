    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不過……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "確實距離正式演出，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有一段時間。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你、",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你在說什麼啊？ ",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為沒有精神……",
