    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天要加油喔。",
        "unit_id": 108411
    },
