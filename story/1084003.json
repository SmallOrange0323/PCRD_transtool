        "name": "千歌",
        "words": "然後現在，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也還是一樣繼續支持我呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "原本以為藉由【慈樂之音】的活動，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_068"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓我已經習慣了",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n在人前歌唱――",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "看來我仍是，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_069"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒人作為依靠，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就會動搖而靠不住的人。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣下去可不行呢。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就像我身後的小朋友一樣，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n也有需要我支持的人也說不定。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這些小朋友的想法，我要背負著……",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_071"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "保護著、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n帶他們前往連接著未來的道路。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "以唱喚士的身分。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}。\n請你看著我。",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_072"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你接受……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我的……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們的歌！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "非常優美的歌聲啊……！",
        "unit_id": 411,
        "voice": "vo_adv_1084003_073"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "　這場演出太棒了……！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "聖誕－快樂！！",
        "unit_id": 1,
        "voice": "vo_adv_1084003_074"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "全心全意的千歌與小朋友們的表演，\n在當天最熱烈的掌聲中謝幕。"
    }
]