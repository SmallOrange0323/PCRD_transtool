        "voice": "vo_adv_1084003_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼大家，",
        "unit_id": 108411
    },
