        "voice": "vo_adv_1084003_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當害怕得不知所措時，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
