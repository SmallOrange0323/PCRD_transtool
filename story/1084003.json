    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說的也是，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在那邊的話……",
