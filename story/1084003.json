    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家好像比我想的還要緊張……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "怎、",
        "unit_id": 211,
        "voice": "vo_adv_1084003_012"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "怎麼辦，",
