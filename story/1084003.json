        "voice": "vo_adv_1084003_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家冷靜點。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒問題的。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n至今都練習很多次了，",
