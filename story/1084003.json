    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n最後的部分，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要把喜悅的感情盡量展現出來喔！",
        "unit_id": 108411
    },
