        "voice": "vo_adv_1084003_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還是謝謝你。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n{player}在我身邊的話我會很有信心。",
