        "voice": "vo_adv_1084003_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼辦，",
        "unit_id": 108411,
        "voice": "vo_adv_1084003_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我必須要振作起來。",
