    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說得也是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然離別讓人覺得很捨不得，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過今天一天，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就讓我們共度一天不要留下任何遺憾。",
        "unit_id": 111011
    },
