[
    {
        "type": "background",
        "background": "500122"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，主人您這樣不行……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不可以淘氣喔，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個壞孩子。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您這樣舔的話，在下的臉會黏答答的。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好不容易一起泡澡，我們都洗得乾乾淨淨的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣豈不是又髒掉了？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，請您不要把頭埋進在下的衣服底下。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好癢啊，啊哈哈♪",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n呵呵，主人您真愛撒嬌呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哎呀？",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n深夜裡有何貴幹，主人？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說聽到在下的房裡傳來奇怪的聲音，放心不下所以來看看？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下深感抱歉，明明已經這麼晚了。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定也有人已經就寢了，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都是在下思慮不周。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人會來在下的房間，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還真是稀奇呢……♪",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "房間的格局都一樣，私人物品也還很少。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n彷彿像照鏡子一般，很相似吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡確實有點煞風景，在下也有意想好好裝潢。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在找到在下與主人的愛巢之前，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡不過是借宿的地方而已。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說什麼？",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……前幾天我們不是撿到了迷路的汪汪嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然我們有請相關機構的人員幫忙尋找汪汪的主人。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但似乎不太順利。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且近來公家機關的辦事效率太差，盡是負面評價呢。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們只好耐心等待……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在找到牠的飼主前，就由在下來收留牠。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也知道的吧。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為汪汪沒有名字，叫起來挺不方便，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以在下把牠叫做『主人』。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過主人您本人在場的話，容易搞混就是了。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_014"
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "開心……♪",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您聰明一點，主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正在跟人類的主人說話。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您先去睡，在下待會就過去了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠現在已經是在下的家人了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛開始的時候，牠連飯都不肯吃呢。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下很有耐心地照顧牠……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠已經知道在下不是敵人了吧。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n終於向在下敞開心扉了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒是牠最近太愛撒嬌，讓在下很困擾。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您看看，牠現在還在用臉磨蹭在下呢……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊主人，您實在太可愛了♪",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，不可以嗎……？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多虧了汪汪主人陪在下一起睡，",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最近都能一覺睡到天亮。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然身旁能感受到他人的體溫，就會令人覺得安心呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總有一天牠會回到真正的飼主那邊，",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與牠分開的話，在下會很寂寞的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話，在下也想跟人類的主人一起睡。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但很可惜那是被禁止的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉唷。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n汪汪主人好像睡著了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小心不要吵醒牠，讓在下慢慢地抱到床上吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下要給牠蓋被被、哼首搖籃曲……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n陪在牠旁邊睡、摸摸牠的頭，直到牠睡著為止。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，您覺得很懷念嗎？",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在我們來【咲戀育幼院】之前，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下都是這樣哄主人入睡呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n人類的主人也好久沒這樣了……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您想對在下撒嬌嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人想要撒嬌的話，在下隨時都非常歡迎。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，是在下想要這麼做。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算只有一下子也沒關係，要不要一起睡呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓我們感受彼此的體溫吧。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您靠過來。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請從後面抱住在下。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊主人，您總是把在下當成易碎品一樣……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n溫柔地對待在下。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被主人這樣抱著，讓在下想起小時候的事情。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那時忙於工作的父親，很少有機會回家。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每當父親深夜晚歸的時候，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不時會心血來潮地陪在在下身旁睡覺。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下忘不了當時父親的溫暖。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是懦弱又愚昧的小孩……",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了尋求父親的溫暖而貼近主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下甚至抱著汪汪主人，把牠當作是父親的替代品。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一個人睡果然還是寂寞難耐。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912,
        "voice": "vo_adv_1059007_038"
    },
    {
        "type": "dialogue",
