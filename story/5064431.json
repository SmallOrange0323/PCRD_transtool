[
    {
        "type": "background",
        "background": "501260"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這次的學習終於也要落幕了啊……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然發生了很多事，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但回想起來還是會覺得有些捨不得。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "{player}學長，",
        "unit_id": 116311,
        "voice": "vo_adv_5064431_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你聽我說！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "儀式表演之後，我找到小碧跟她打招呼，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n久違的重逢",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她第一句話竟然是",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「噫」耶！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "久違的重逢就遇上琪愛兒的威壓，",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對那孩子來說應該很苦吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然如此，",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她還是大老遠地趕來了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "連邀請函都沒回覆，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想她應該也很忙吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "的確。",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n聽說好像跟公會的工作撞期了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她也不確定能不能來。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "最後公會那邊的工作好像拜託初音幫忙了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "順帶一提，",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也跟好久不見的美美她們小敘了一番。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「跟大姐姐們一起努力，真了不起──」",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "像這樣，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n被當成小孩子摸了頭呢，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦呵呵。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學長，",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她們該不會還以為",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "優妮只有八歲吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來，",
        "unit_id": 116311,
        "voice": "vo_adv_5064431_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好多人來幫我們加油，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我們好朋友社還真是幸福呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯。",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n優妮們真的很幸福。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "瑪麗亞好像也暫時不會來找碴了。",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這次應該算順利過關了吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可以說聲",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可喜可賀了？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……啊。",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_010"
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "……忘了。",
        "unit_id": 1,
        "voice": "vo_adv_5064431_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "光是處理解散危機就夠忙了，根本沒空管那個了呢。",
        "unit_id": 116311,
        "voice": "vo_adv_5064431_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好啊，修女，",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該不會是想趁亂當作沒這回事吧？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可得問清楚才行，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "準備進攻職員室。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志們，",
        "unit_id": 116411,
        "voice": "vo_adv_5064431_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拿起你們的武器！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "衝啊──！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊啊……！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "老師──！",
        "unit_id": 116311,
        "voice": "vo_adv_5064431_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "香蕉算是武器嗎──！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "搞笑，",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之算是維持現狀吧？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}也辛苦了。",
        "unit_id": 116211,
        "voice": "vo_adv_5064431_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n總之，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之後也要請你多指教。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我也不太清楚啦。",
        "unit_id": 116211
    }
]