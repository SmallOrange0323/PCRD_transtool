[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然繼續前進著，但是{player}一行人\n還是仍未找到記憶線索。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們先，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在這裡休息一下好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 103211,
        "voice": "vo_adv_7006004_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這次換我先去站哨唷。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "兩位，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請好好休息呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小心一點唷，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是這麼有精神呢。",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……到底，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你對她做了什麼呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在那邊的那個人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不必勉強想起來……",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正我大致都想像得到。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃真的都沒變呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n竟然連找尋{player}的記憶線索這件事",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也可以變成比賽。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "第一次遇見好像是在……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們家族成為貴族過後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才一年左右的時候吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那時候的我，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拼命地學習",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "作為貴族的舉止儀態。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "終於以貴族之姿參加聚會，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在那裡都是相互猜忌的大人們、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有想要透過我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n接近父親的男人們……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很差勁。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了留給父親面子，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n隨便回應",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "敷衍著他們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是他們漸漸變得煩人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "後來我忍無可忍，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n正想要徹底吼出來的時候，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個女孩就出現了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "『這裡是",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "紳士淑女的交流場合。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n無視於對方心情的愚者，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請馬上離開！』",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她這樣說道。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……雖然很不甘心，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是那時候的秋乃",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的很帥氣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "完美的舉止儀態、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "氣質滿溢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個高尚純潔的精神。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看到了她，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我真心覺得貴族",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是應該要那樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從那之後",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才真正認真地學習。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想成為真正的貴族……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "想要變成可以跟那個女孩",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並駕齊驅的人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呃，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也沒想到會變成",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如此這般的競爭關係。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有……",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們會在一起還有",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其他的理由，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我就先保密了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說我們",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很像……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n果然你們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前也討論過同樣的話題吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說我們很像就",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太超過唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個女孩對我來說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是我理想中的人呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n等我更努力，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以跟那個女孩並駕齊驅時",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再跟我說吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你稱讚我也沒用……",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦！？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n怎、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼突然",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "摸我的頭呢！？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因、",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我很努力嗎……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來秋乃",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前也被這樣對待嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，才露出那個表情。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這種事情",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "與其對我做，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還不如對綾音、胡桃",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "或可可蘿做吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她們一定會很高興的吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "――那麼，",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然有點早，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我去換班了唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……秋乃。",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然有點早",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但可以換班唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？　",
        "unit_id": 103211,
        "voice": "vo_adv_7006004_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的可以嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那我就恭敬不如從命唷",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳發生了什麼事呢！？　",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "臉",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都紅透了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦！？　",
        "unit_id": 102811,
        "voice": "vo_adv_7006004_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼都沒有！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這就是平常的我，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才沒有不自然的地方呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、",
        "unit_id": 103211,
        "voice": "vo_adv_7006004_022"
    },
