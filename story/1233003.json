    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "歡迎回來～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你花了不少時間呢。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n剛才那位老婆婆的家，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "看來挺遠的～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我嗎？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_034"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我不要緊啦。",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我只是在看著那邊那座公園的正太",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "養眼一下而已～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "別管那個了～",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_035"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小騎士，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你真的很溫柔呢～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "可是～",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_036"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n你這麼善良～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n說不定",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "會被很壞～的人騙喔～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "因為到處都會有奸詐的傢伙，",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_037"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n有心利用像小騎士一樣的孩子～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "……！",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_038"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小騎士你啊～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你這一點",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_039"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就像小孩一樣呢～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n像是個純真無邪的男孩子～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "如果你是正太，我早就不小心出手了～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_040"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你真的要多加注意喔～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n不然，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你遲早會被壞人纏上的～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_041"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我嘴上這麼說，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n但我也不全然是你的夥伴啦～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_042"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那麼，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我為什麼要嘮叨個不停呢？　",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "拜託了～",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_043"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "要是大家不買點什麼，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n在家等我的小孩",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "就要沒飯吃了～",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "唔，",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_044"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那位大叔真吵呢，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n難得我正在想事情～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "呃，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士……？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我這邊",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_045"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "都是些超稀有的商品。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "如何？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n請當作這是助人為樂～！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗚哇！？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_046"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "難道說？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n又要幫助別人～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真是善良過頭了……",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士覺得好就好～",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_047"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "可是啊～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "謝謝你啊小哥～！",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_048"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n那你多買一點吧～！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我家中還有一個體弱多病的老婆需要醫藥費～",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "求求你！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "拜託你！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_049"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我好～像不太喜歡那個大叔～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "去看一下狀況吧～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "如何？",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_050"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "可以吧？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "這世界都是些冷酷無情的人，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "但小哥你不一樣吧？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我不會讓你吃虧的，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "就在我這裡買吧～",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那個～",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_051"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我說～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小騎士，你在做什麼～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我們該回去了喔～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "哎呀？",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_052"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "小姐，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳是這位小哥的同伴嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳真可愛呢～！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n買點什麼吧。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "像是使肌膚充滿光澤的保養品等等，如何──？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這是保養品～？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_053"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～～～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗅嗅……",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "哎呀，",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_054"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "等等～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n大～叔，你在跟我開玩笑嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這是",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "史萊姆的黏液吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "！？",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_055"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "為、",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "為什麼她會知道這件事……！？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "為了不被發現，我明明已經添加香氣，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "沖淡氣味……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "……哈哈哈，",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_056"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "小姐，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳在胡說什麼啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n這",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "可是高級品喔──",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n小姐妳還年輕",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "不懂它的品質之好吧。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啥～？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_057"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n大叔你才是，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你不曉得裡頭放了什麼嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n還、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "說～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你是明知故騙～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我騙人？",
        "unit_id": 4911,
        "voice": "vo_adv_1233003_058"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n喂喂喂，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳不要沒事找碴啦。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳妨礙我做生意～",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我會很傷腦筋的，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "小姐～",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "唔～嗯？",
        "unit_id": 123311,
        "voice": "vo_adv_1233003_059"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "你要裝傻嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那我就這麼做～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
