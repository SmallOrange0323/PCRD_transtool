        "name": "智",
        "words": "我知道。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n追上{player}他們的事，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就先放一邊吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳先趕緊跑一趟，\n到【王宮騎士團】的集合所說明當前的事態。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再怎麼說像這樣的大傢伙，",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒集結一定的兵數是打不倒的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然【王宮騎士團】現在，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n漸漸快變成一個非常可疑的集團就是了呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "擁戴正義，",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "守護人民的這個基本理念，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也就只能相信大家都還沒有忘掉了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在救援到達之前，",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會想辦法來引起魔物的注意來拖時間。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其他事就拜託妳了茉莉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "快去快去！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": " 跑起來！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是呀那個，",
        "unit_id": 100511,
        "voice": "vo_adv_2009010_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也能夠戰鬥的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟是出現了像這麼巨大的魔物，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不可能沒人去通報的嘛……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就算不去叫也會有人來幫忙的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯～……",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果可以的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的不想讓妳站在最前線的呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚～？",
        "unit_id": 100511,
        "voice": "vo_adv_2009010_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我雖然還是見習，但也是【王宮騎士團】的一員啊，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也想要為了守護大家",
