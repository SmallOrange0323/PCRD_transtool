        "voice": "vo_adv_2009010_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n啊、",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "糟糕！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎、",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼了嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n從剛剛開始，集中力就微妙的很沒辦法專注唷～……千歌？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "畢竟是第一天，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還不習慣所以有點緊張嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定是騎士先生他，",
        "unit_id": 105412,
        "voice": "vo_adv_2009010_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n又隨便做了模仿吧。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "譬如說飛吻之類的……",
        "unit_id": 105412,
        "voice": "vo_adv_2009010_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那人呀，偶爾就會突然做出這種像傻子一樣的舉動呢。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊不是這樣，",
        "unit_id": 104212,
        "voice": "vo_adv_2009010_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}他不知什麼時候，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n似乎就混入人群中了……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比起此事大家，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有緊急事態了。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從剛才開始，",
        "unit_id": 104212,
        "voice": "vo_adv_2009010_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不知為何精靈們開始有所騷動……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n啊啊，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "竟會演變成這樣。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "？ ",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底是怎麼了呢，千歌？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳臉色很不好唷……？",
        "unit_id": 102912
    },
    {
        "type": "still",
        "still": "200901001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 104212,
        "voice": "vo_adv_2009010_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳們看。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n在粉絲們的對面，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就在蘭德索爾的正門附近……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎有著什麼不祥之物。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "？ ",
        "unit_id": 105412,
        "voice": "vo_adv_2009010_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔哇，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好像有什麼大傢伙在那呀！？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是什麼？",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　魔物……？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n從來就沒看過那種的！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 104212,
        "voice": "vo_adv_2009010_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那隻魔物，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "正直直的朝這邊前來中！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這下不好，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得讓粉絲們趕緊避難才行！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說得也是……",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚～",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才第一天的演唱會就被搞砸雖然很不甘心。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是嘛這也沒辦法，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "粉絲們的安全更重要！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了避免大家陷入恐慌之中，",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們也來幫忙誘導讓避難更順利吧！",
        "unit_id": 102912
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500581"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位～！ ",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請聽我這裡！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n請冷靜地，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慢慢地往後看！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你們看，",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是有隻看起來好可怕的魔物嗎？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為很危險，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以請大家冷靜地遵照工作人員指示避難唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "演唱會暫時中止～！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用擔心，",
        "unit_id": 102912,
        "voice": "vo_adv_2009010_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果確保沒有安全的問題後就會重新開始的！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n總之現在，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請大家別急別驚慌也別奔跑的前往避難唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "絕對，不可以把周遭的人給推開或撞倒喔！",
        "unit_id": 102912
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913,
        "voice": "vo_adv_2009010_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　魔物？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n哦哦，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真有隻不明的巨大魔物呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何，",
        "unit_id": 105913,
        "voice": "vo_adv_2009010_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事到如今都並沒有注意到的跡象呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成是過於沉醉於那偶像們的歌聲之中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此才未能有辦法查覺到魔物的接近……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是有生以來最大的失誤。",
        "unit_id": 105913,
        "voice": "vo_adv_2009010_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否先依照指示進行避難呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小、小小小、",
        "unit_id": 100511,
        "voice": "vo_adv_2009010_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～！ ",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有魔物呀！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來還是一隻超強的傢伙喲～！",
        "unit_id": 100511
    },
    {
