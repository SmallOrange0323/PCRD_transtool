        "voice": "vo_adv_2009010_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果死掉了可就都免談了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且若讓妳受了什麼傷，我也不好和妳的雙親交代呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話又說回來，",
        "unit_id": 103711,
        "voice": "vo_adv_2009010_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也不是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能悠閒地在這爭論個輸贏的狀況了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……拼了命，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也得將那魔物給討伐呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】團員",
