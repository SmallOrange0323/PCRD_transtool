[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然本來就覺得小鈴是肯努力就辦得到的孩子，",
        "unit_id": 105211,
        "voice": "vo_adv_6040304_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過她真的很拼命呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也不能夠輸，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要努力工作囉！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然這麼想，",
        "unit_id": 105211,
        "voice": "vo_adv_6040304_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但我也開始想念起",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴懶洋洋的樣子了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "儘管不會直接跟小鈴說，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但她那樣其實也是牧場和平",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的象徵呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "給小鈴的獎勵……",
        "unit_id": 105211,
        "voice": "vo_adv_6040304_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "除了讓她休息以外還有什麼可以給呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "橡子的話……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她好像",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很享受自己收集的樂趣。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是能一起玩玩遊戲",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "之類的就好了的說。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然小鈴應該會害羞地敷衍過去，",
        "unit_id": 105211,
        "voice": "vo_adv_6040304_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但她真的非常重視牧場呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是她能再稍微坦率一點就好了。",
        "unit_id": 105211
    }
]