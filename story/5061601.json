[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在莉瑪回到【伊麗莎白牧場】後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n已經過了一陣子。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "優雅優雅……",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "距離在宅邸學習課程的那些日子，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n雖然已經過了好幾天，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但我已經能夠自然地表現出優美的舉止了。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "現在想起來，",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還是覺得那段日子真的像在做夢呢……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "羅伊德先生和公主殿下，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不知道相處得好不好呢？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哎呀，",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你來啦♪{player}。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天有什麼事嗎？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "現在",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "除了我以外的大家都出門囉，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒問題嗎？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "今天是送信的打工啊。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "話說回來",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有我的信？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n到底是誰寄的呢……",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這、",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這是",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "公主殿下寄來的信！",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這時機還真是剛好呢。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然我想應該是好消息，",
        "unit_id": 105213,
        "voice": "vo_adv_5061601_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但總覺得有些心跳加速呢。",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "吶，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你也跟我一起讀吧？",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我馬上泡杯好喝的紅茶，",
        "unit_id": 105213
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "快進來吧♪",
        "unit_id": 105213
    }
]