    {
        "type": "dialogue",
        "name": "忍",
        "words": "就越會要求付出使用的代價……",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們必須在更多人受害之前……",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_061"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n快點",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "解開詛咒才行。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "水晶占卜師",
