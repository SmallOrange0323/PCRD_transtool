[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在幽靈船委託的幾天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}受到忍的邀請，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n依約造訪了海邊的一間店。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "前陣子謝謝你。",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多虧了{player}，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們才能平安回到蘭德索爾。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就讓我請你吃飯作為答謝吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n聽說這家店的餐點",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎很好吃哦。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "料理店的老闆娘",
        "words": "嗨，",
        "unit_id": 1511,
        "voice": "vo_adv_1220002_002"
    },
    {
        "type": "dialogue",
        "name": "料理店的老闆娘",
        "words": "歡迎光臨！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "料理店的老闆娘",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "料理店的老闆娘",
        "words": "空出來的位子",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "料理店的老闆娘",
        "words": "都可以自由入座哦。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝。",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼就",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "挑那邊視野不錯的位子吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺吹著海風會很舒服──",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "喂，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_004"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "那邊那個女人！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "站住！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "到底有什麼事……？",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這傢伙態度還真是囂張啊。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "嗯……",
        "unit_id": 711,
        "voice": "vo_adv_1220002_006"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n跟受害者描述的特徵",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "一致呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請問有什麼事嗎？",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "不好意思，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_008"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "想問妳一點事情。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n我們目前",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "正在調查某起事件。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "最近，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_009"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "有些受害者尋求我們協助，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n說在蘭德索爾這一帶，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n有人硬是賣給他們高價的壺和護身符……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "依據",
        "unit_id": 711,
        "voice": "vo_adv_1220002_010"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "受害者提供的情報，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n犯人是穿著白衣服的女人，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "自稱為占卜師的樣子。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "白衣服……",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是嗎？",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼說來，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也正好穿著白衣服呢。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "還有，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_012"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "她會用奇怪的水晶占卜，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n然後說受害者是「被惡靈附身了」、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "「被前世的孽緣纏上了」等等，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n用話術哄騙，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "讓對方買下商品。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "什麼？",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_013"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "奇怪的水晶……",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "難道是說我？",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "看到我這樣的俊男不可能會說出那種話吧。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "綜合上述的情報來看，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_014"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n眼前的女孩和目擊證言實在是如出一轍。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "……等一下，",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_015"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "從剛才的說詞來看，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你該不會",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是在懷疑忍吧？",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我家寶貝女兒哪可能跑去騙人呢！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_016"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就算找遍蘭德索爾，",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_017"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n也很難找到像忍這麼可愛又純真的孩子啊。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n你這臭傢伙，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "聽懂的話就快給我滾！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "還有這是最後的情報……",
        "unit_id": 711,
        "voice": "vo_adv_1220002_018"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n受害者們似乎",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "都一下子就被犯人的美貌給騙上鉤了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n聽說是在蘭德索爾",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "也很少見的超級大美人。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那肯定是我家寶貝女兒不會錯！",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_019"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n首先是難得一見的大美女這點絕對不會錯。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n想不到你們還蠻有看人的眼光呢！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哇哈哈！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_020"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "好，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_021"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "已確認嫌犯的自白了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "啊，",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_022"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "糟了！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我剛才說的不是那個意思……！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "不好意思，請麻煩跟我們到局裡一趟。",
        "unit_id": 711,
        "voice": "vo_adv_1220002_023"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n拒絕的話，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我們就不得不動用武力了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔唔唔唔……",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_024"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我說你，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "快想個辦法！！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "……有什麼事嗎，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_025"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "少年？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n一直盯著我瞧，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "是我的頭盔上有些什麼嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "幽靈……？",
        "unit_id": 711,
        "voice": "vo_adv_1220002_026"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "你在說什麼？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n之前，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "在幽靈船見到……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "無頭騎士？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "不好意思，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_027"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我沒時間聽你開玩笑……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n……不，等等。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "你剛才",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "說了什麼？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "解決幽靈船事件的人原來是你們啊。",
        "unit_id": 711,
        "voice": "vo_adv_1220002_028"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n稍早我們打聽到的情報也確認了你們有不在場證明，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n不好意思懷疑了你們。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "假如有任何跟事件相關的情報還請聯絡我們，",
        "unit_id": 711,
        "voice": "vo_adv_1220002_029"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n我們會繼續調查的。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "那麼，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "先告辭了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然設法解開了誤會……",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對不起，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來現在不是請吃飯作為答謝的時候。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且我們",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也打擾到店裡的人了……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再加上……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有件事讓我很在意。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也有試著占卜一下這件事，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n看能不能提供什麼情報……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……占卜中我看到了",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "深黑",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又巨大的影子。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那影子",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大到可以把人吞噬。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我覺得不管這件事，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可能會引來巨大的災難。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們也來去找出犯人吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "首先去試著",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "問問看受害者吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n搞不好在現場附近，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也有幽靈目擊到些什麼哦。",
        "unit_id": 122012
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我試著去問了",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "受害的人，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n大家都說",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "買了占卜師的開運商品後，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n一直持續不斷的糾紛就突然解決了。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "驅魔鍊墜、",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "吸收不幸的神秘瑪那壺。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不會再做惡夢的安眠枕、",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難以形容之藝術性的神秘雕像。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是啊，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "令我在意的是……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不管哪個物品",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都感覺不到具有驅魔之力。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "反倒是",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "魔力的痕跡",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "跟詛咒很相近。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個感覺",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好像在哪裡……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我也跟忍持相同的意見。",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_040"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n但是魔力的痕跡太薄弱了，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這樣根本",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就不知道是什麼咒術。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n假如能更強烈一點的話",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就感應得出來了。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……在這邊煩惱",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也無濟於事。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要能掌握更多的線索，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許就能知道些什麼。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "犯人似乎都是",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "趁目標落單時才會行動，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這邊",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們也分兩路搜索吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只不過",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "犯人似乎也是個中高手，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你是個善良的人，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可要小心",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別被對方牽著鼻子走",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是受騙上當哦。",
        "unit_id": 122012
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "哎呀，",
        "unit_id": 417,
        "voice": "vo_adv_1220002_044"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "哎呀呀？",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "我說，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "那邊路過的少年，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n要不要聽大姐姐我",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "說個幾句話呢？",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "……對，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "就是你。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "你",
        "unit_id": 417,
        "voice": "vo_adv_1220002_045"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "被惡靈附身了呢。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n放著不管可能會接連遭逢不幸。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "但是，",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "我有祕密法寶可以幫你化解哦。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "你看──！",
        "unit_id": 417,
        "voice": "vo_adv_1220002_046"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "這是不讓任何髒東西靠近的",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "驅魔護身符哦。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n現在買的話我算你優惠價。",
        "unit_id": 417
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "看你的表情",
        "unit_id": 417,
        "voice": "vo_adv_1220002_047"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "似乎還是一頭霧水呢。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "呵呵呵……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "可是",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "我的占卜很準哦。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n我建議你在遭遇不幸之前",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "買下來比較好。",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_048"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你在這裡呀。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這位是……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這……",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_049"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這這、",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這小妞真是個大美女啊──！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n身上的白衣跟妳也很搭！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n還有摸著水晶的",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "優雅手指……！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯？",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_050"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "等一下，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n白衣跟水晶……",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我好像在哪裡聽過……",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "跟我們正在找的占卜師",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "特徵一致呢。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也就是說……",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "我、",
        "unit_id": 417,
        "voice": "vo_adv_1220002_052"
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "我想起了",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "自己還有一點事情……",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "神秘女性",
        "words": "\n先告辭了！",
        "unit_id": 417
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那個的占卜師就是事件的犯人嗎！",
        "unit_id": 2413,
        "voice": "vo_adv_1220002_053"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "要被她給逃了！！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯，",
        "unit_id": 122012,
        "voice": "vo_adv_1220002_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們快走吧。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "必須早點阻止她才行……！",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛才靠近她，",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓我弄清楚了。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那顆水晶是幽靈船上的寶物……",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是拴住幽靈海盜們的一部分詛咒。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓受害者遭逢不幸和受傷也是……",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n全都是用那顆水晶之力引起的。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她做的",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並不是替人占卜，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而是下了害他人不幸的",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "詛咒。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一開始假裝占卜，",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對客人下詛咒，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要客人不買高價的商品",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就不解開詛咒的話……",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就會如預言所說的一樣遭逢不幸。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也就是說，",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她所言惡靈帶來的災害或不幸，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只是靠詛咒捏造出來的……",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "自導自演。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是……",
        "unit_id": 122011,
        "voice": "vo_adv_1220002_060"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "任何詛咒都伴隨著反蝕之力。",
