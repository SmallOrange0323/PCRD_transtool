[
    {
        "type": "background",
        "background": "509011"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉～",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼我非得被騎士先生叫出來呢？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然都要被叫出來，我寧願跟怜大人見面。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真受不了你。",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可是百忙之中撥空前來的，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果是無聊小事，我不會原諒你喔。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大多時候，",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生總是很強勢。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要是以為所有人都跟騎士先生一樣閒，那可就大錯特錯了。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "會像這樣特地過來陪你的人，恐怕只有我──",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──咦？",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來你……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有注意到",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天是我的生日嗎……？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是，",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我平時老愛對你碎碎念吧？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n明明如此，為什麼……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為你是騎士先生，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起，我一直碎念個不停！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個盒子是……",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "生日禮物，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會心懷感激地",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "收下",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "的……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是……",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "衣服",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我之前為騎士先生挑選了要穿的衣服，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你才會送衣服當禮物吧。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我看看……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔……",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "非常輕薄飄逸的哥德蘿莉服裝……！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n連陽傘都有的套組！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我反而想問你是在哪裡買的！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎、",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我的",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "私服的確是這種感覺沒錯！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但我喜歡的是甜美風……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種風格……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我並不是不要啦！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請不要感到沮喪！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了，",
        "unit_id": 105431,
        "voice": "vo_adv_4010202_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我穿！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會穿！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只不過，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有我們兩人獨處的時候！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "被其他人看到會有點……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "兩人獨處的時候？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是，我、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不是那個意思啦！？",
        "unit_id": 105431
    }
]