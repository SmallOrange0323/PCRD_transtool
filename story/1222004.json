    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳想捉弄我們到什麼時候啦？",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "吃烤肉吧。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳也是和男友一起來的吧？",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拿去給妳男友吧。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "同事",
        "words": "是是是～",
        "unit_id": 1,
        "voice": "vo_adv_1222004_027"
    },
    {
        "type": "dialogue",
        "name": "同事",
        "words": "我就心懷感激地收下了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同事",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同事",
        "words": "綾瀨小姐和那邊的男朋友，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同事",
        "words": "你們也玩得開心點喔～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "剛才真是驚險……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……那、",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對不起。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我不只拜託你假裝成我的男友，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還要你負責阻擋我喝麥酒",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種莫名其妙的事……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請你再稍微陪我一下……！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在這場懇親會結束之前，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我必須徹底禁酒才行……！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "……哎呀～",
        "unit_id": 1,
        "voice": "vo_adv_1222004_031"
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "真的很不好意思。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "\n連收拾善後的工作也全丟給你們做……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "別這麼說，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這不是什麼大不了的事。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n之後請交給我們兩人吧。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "這樣啊。",
        "unit_id": 1,
        "voice": "vo_adv_1222004_033"
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "\n那就恭敬不如從命，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "我們先離開了喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "對了，",
        "unit_id": 1,
        "voice": "vo_adv_1222004_034"
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "剩下的食材之類的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "\n你們可以帶回家吃沒關係。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "\n這雖然是用經費買來的東西，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "但就當作是你們負責收拾善後的補貼。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1222004_035"
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "星期一再見。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "上司",
        "words": "辛苦了。",
