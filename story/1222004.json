    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噗哈～！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在戶外喝麥酒最棒啦～！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_042"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個解放感",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "會讓人上癮耶……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為能夠不用在意他人目光盡情暢飲呀。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的個性雖然不是喜歡戶外活動……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_043"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但如果是這樣，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "或許意外地不錯呢♪",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_044"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你盡量吃吧。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n畢竟這可是",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在收拾善後啊。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊姆、",
