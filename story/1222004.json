        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "………………",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好了──！！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我總算是滴酒不沾熬過這場懇親會了！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n徹底保護住",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的社會性了！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵呵……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_039"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和預料得一樣，食材果然也有剩……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n和參加人數比起來，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "食材明顯就是準備太多了……！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好了！",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_040"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來享受飲料和食材的收拾善後吧！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n讓我來好好感謝你今天陪我參加懇親會吧！",
