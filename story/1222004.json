        "voice": "vo_adv_1222004_045"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊姆……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "用公司經費的烤肉真好吃呢～",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n連麥酒也能喝到飽，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要把平時累積的疲勞都一掃而空！",
        "unit_id": 103433
    },
    {
        "type": "still",
        "still": "122200402"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊、",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_046"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n最近這陣子都工作滿檔，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我好久沒像這樣好好放鬆了。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為工作告了一個段落，所以今天才會決定要辦懇親會……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_047"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但參加者都是上司、同事，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和各自的家人或伴侶……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_048"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也好久不見到你了。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以感覺累積了很多欲求不滿……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊、",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_049"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對不起，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我說了奇怪的話。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓、",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓你覺得反感了嗎？",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "…………或、",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "或許是吧。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我似乎連情緒也整理好了。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不小心就說出喪氣話了……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_051"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只要是在他面前，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不曉得為什麼就會覺得",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "掩飾自己很愚蠢呢……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且我也只有在他面前才能像這樣",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_052"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "展現自然的自己……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就算稍微跟他撒嬌──",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_053"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來來來，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再靠我近一點。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們必須繼續",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "假裝成情侶才行。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "否則萬一同事們如果回來了，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_054"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就會被他們發現我是說謊了啊。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大家",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_055"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似乎都真的相信",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們是情侶喔。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_056"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對了……！",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不要是假裝的……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要不要真的",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和我變成情侶？",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……呵呵，",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_057"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才怪呢。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我開玩笑的啦，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "開玩笑的。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你連麥酒都還沒辦法喝，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這對你是不是有點太刺激了呢～",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種話……",
        "unit_id": 103433,
        "voice": "vo_adv_1222004_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "至少要等你到了能喝麥酒的年紀再說呢。",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……你要快點追上我喔，",
        "unit_id": 103433
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會等你的。",
        "unit_id": 103433
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……居然用公司的經費",
        "unit_id": 190011,
        "voice": "vo_adv_1222004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吃烤肉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優花梨真是的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她外表看起來很認真，沒想到也有不容小覷的地方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然優花梨的理想或許是當個",
        "unit_id": 190011,
        "voice": "vo_adv_1222004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "認真又工作能幹的女性……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但我認為",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最自然的她也非常有魅力。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且",
        "unit_id": 190011,
        "voice": "vo_adv_1222004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算裝得再成熟，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不可能有辦法一直掩飾自己……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n任誰都遲早會感到疲累的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為如此……",
        "unit_id": 190011,
        "voice": "vo_adv_1222004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你待在優花梨身邊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好讓她能夠保持最自然的樣子吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託你囉，",
        "unit_id": 190011,
        "voice": "vo_adv_1222004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這對她來說是不可或缺的下酒菜啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……唔嗯，",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_064"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我在收拾的途中睡著了……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好像做了個不可思議的夢……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是因為太早起了嗎……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_065"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺暢快多了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就像是內心的煩躁感一掃而空，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓人心情舒暢的感覺。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這也是",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_066"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "多虧有和你",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一起喝「真正最棒的一杯」吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我開始露營的契機，",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_067"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n雖然只是為了想喝麥酒……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是像這樣純粹享受自然、",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_068"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "講究料理……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有聊些平常不會對別人說的事情……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果我沒有下定決心挑戰露營，",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_069"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就絕對無法注意到",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像這樣度過的樂趣……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_070"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "自從迷上露營後，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我工作也變得非常順利。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "前陣子",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我還因為財團的業績提升而受到誇獎呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想這一定是",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_071"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "平日和週末的公私分得很清楚的關係吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n像之前那樣忙到慌慌張張的情況也減少了……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃雖然是個有點奇特的人……",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_072"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但能得到上司的稱讚，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然很開心呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈……",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_073"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這些話",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對你好像還太早了？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等你變成社會人士後，應該就能懂我的心情了。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以……",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_074"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等你年紀再大一點後……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n到時候我們就找個時間",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一起露營喝麥酒吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大姐姐我會好好期待並等著，",
        "unit_id": 122211,
        "voice": "vo_adv_1222004_075"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n等著能和你一起品嚐大人味道的那時候到來喔♪",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人之後也持續享受週末露營，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並過著比以前還要充實的日常生活。"
    }
]