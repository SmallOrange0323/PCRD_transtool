    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音為了進行森林守衛與動物苑交易品相關的工作，\n而來到蘭德索爾……原本應該是這樣的。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不行啦～！已經不可能趕上了～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣的話……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……這裡一個人也沒有……對吧？",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆奇蹟躍傳！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "到達蘭德索爾啦！再來就是衝刺了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_002"
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你好～！我來送貨了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼……呼……應該是……趕上了吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "嗯嗯，是在約定時間內喔。",
        "unit_id": 413,
        "voice": "vo_adv_5001000_004"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "那麼就趕快來進行點檢吧。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好……不好意思，稍微先讓我……",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "……還真是到哪裡都能睡的孩子。喂。初音。",
        "unit_id": 413,
        "voice": "vo_adv_5001000_006"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "\n該起來啦。交易品數量和清單確實吻合。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "交……易……啊！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真的嗎？沒弄錯真是太好了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "森林守衛的草藥在治療上真是幫了大忙。",
        "unit_id": 413,
        "voice": "vo_adv_5001000_008"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "\n因為我家的孩子經常受傷。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，能這麼說真是太好了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我才應該說謝謝，非常感謝你們總是給我們豐盛又美味的食物♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "【伊麗莎白牧場】的乳製品賣到哪裡都是好評如潮呢。",
        "unit_id": 413,
        "voice": "vo_adv_5001000_010"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "話說回來，聽說小栞在各種工作上都非常努力喔？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_011"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "她說受到了大家的照顧，想好好報答大家。",
        "unit_id": 413,
        "voice": "vo_adv_5001000_012"
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "動物苑員工",
        "words": "真陽也有稱讚道『那孩子很能幹』喔。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是嗎……小栞嗎……欸嘿嘿。",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了！我想到一個好主意了♪",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵呵！好，來開始尋找送給小栞的禮物囉！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "（作為姐姐，要為自己努力又可愛的妹妹",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n挑一個超棒的禮物哦～♪）",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "（該挑什麼好呢～♪",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說到小栞喜歡的東西，果然還是書吧～？）",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "（不過，小栞已經有那麼多書了，",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且要是小栞不中意就糟了……）",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……要是能有個驚喜一點的禮物就好了……",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊。妳在做什麼？",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇啊啊啊！小、小栞！？",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你怎麼會在這裡！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和牧場的大家一起買完東西回來了……",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n然後聽到了姊姊的聲音……不、不可以和妳打聲招呼嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼會不可以呢！最近還好嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯。牧場空氣不錯的緣故吧？身體狀況越來越好了，",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n最近也不會搖搖晃晃的了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……又開始暈起來了……",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊嗚……是因為太久沒出遠門的關係嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n又開始搖搖晃晃的了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳、妳沒事吧！？呃呃～附近的醫院是在哪裡～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒事的。我已經恢復過來了。",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔，那、那就好……妳可不要太勉強自己啊！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……謝謝。姊姊在做什麼啊？",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我嗎？我啊，我來和動物苑做商品的交易啊☆",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "然後呢，我也聽說了小栞的事喔～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的事？",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！聽說小栞在牧場的工作上非常勤勞喔！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我聽了之後，感到非常高興啊～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以呢！想給努力的小栞……",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "（……雖然想問問看小栞想要的東西……",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是想想還是來點驚喜比較好呢！）",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想好好稱讚努力的小栞一下啊！好棒好棒！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唔……",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那我也差不多該回去了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "　小栞也是路上小心喔！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "幫我向伊麗莎白牧場的人們打聲招呼！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那就先這樣囉！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……走掉了……",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，似乎有什麼事想跟我說……",
        "unit_id": 103811,
        "voice": "vo_adv_5001000_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊、風開始……啊嗚……",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒想太多就先跑了～！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n會不會很奇怪啊，這樣很奇怪吧～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞腦袋那麼聰明或許已經注意到了！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒事的！不過就那樣聊下去肯定會更危險吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好！一定要給小栞一個超驚喜的禮物！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "初音的禮物大作戰！",
        "unit_id": 101211,
        "voice": "vo_adv_5001000_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n開始啦♪閃亮亮☆……咕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
