[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將神殿外的攤販從頭逛到尾的貪吃佩可兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n悠閒地在神殿散步著。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子也飽了，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們去求籤吧。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇、",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊啊。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "對、",
        "unit_id": 611,
        "voice": "vo_adv_1118003_002"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "對不起。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n水濺到妳了吧……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒事的。",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這個，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老婆婆妳沒受傷吧？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "謝謝妳啊，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_004"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我沒事。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n只是不小心絆了一跤而已。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "唉，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真不想老這麼快啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "老伴啊，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_005"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "怎麼了？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我沒事，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_006"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "只是不小心把桶子裡的水濺到這位小姐……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "對不起啊小姑娘。",
        "unit_id": 511,
        "voice": "vo_adv_1118003_007"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "把妳漂亮的和服弄髒了……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n放心吧，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我們會賠償妳的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用不用，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒事的，請不必費心了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這個，老婆婆，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳拿著這麼重的東西很辛苦吧。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我去幫妳打水好了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不必不必，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我不能讓妳做這種事。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "況且，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這些都是我們自願做的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自願……？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們不是神殿的相關人員嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我們兩人是因為來這座神殿參拜而結下姻緣的。",
        "unit_id": 511,
        "voice": "vo_adv_1118003_011"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n所以每年新年都會來這裡幫忙打掃。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "話雖如此，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "還真是歲月不饒人啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是啊。",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會在這裡相遇也算是一種緣份。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請務必讓我們幫忙。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "說實話",
        "unit_id": 511,
        "voice": "vo_adv_1118003_014"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "禮貌上是該婉拒你們的……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n但能麻煩你們幫把手嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是啊。",
        "unit_id": 611,
        "voice": "vo_adv_1118003_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n清掃做得不夠徹底，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就太對不起神明大人了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "包在我們身上吧！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們會把神殿打掃得一塵不染！",
        "unit_id": 111811
    },
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我們負責打掃神殿內部，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_017"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n能麻煩小姑娘你們",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "去掃參拜道路嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們真的不需要勉強喔。",
        "unit_id": 611,
        "voice": "vo_adv_1118003_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n現在就拒絕離開也沒關係的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題的！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們對體力活可是很有自信的喔！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真是可靠啊。",
        "unit_id": 511,
        "voice": "vo_adv_1118003_020"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n真的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "很謝謝你們。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那我們就去掃神殿了。",
        "unit_id": 611,
        "voice": "vo_adv_1118003_021"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n要是有什麼事就來叫我們吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好啦！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就回應老婆婆他們的期待，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快速俐落地打掃乾淨吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要把石頭擦乾淨",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "意外地很費力呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n老婆婆他們",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每年都在做著這種事啊。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我們每年都來參拜，",
        "unit_id": 411,
        "voice": "vo_adv_1118003_024"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n今年還是第一次遇到結緣之神呢！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這下我們的感情之路也會",
        "unit_id": 311,
        "voice": "vo_adv_1118003_025"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "走得順順利利吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結緣之神……？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是有這樣的神，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也想見見看呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以不可以。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在要先認真打掃才行！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終於打掃完了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到處都閃閃發光啦！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們去告訴老婆婆他們吧。",
        "unit_id": 111811
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼聚集了這麼多人。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在那裡的是……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老婆婆他們？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那、",
        "unit_id": 1011,
        "voice": "vo_adv_1118003_030"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n請問能和我握個手嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不嫌棄我這老頭子的話，想握幾次都沒問題。",
        "unit_id": 511,
        "voice": "vo_adv_1118003_031"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那個，",
        "unit_id": 1211,
        "voice": "vo_adv_1118003_032"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "請告訴我夫妻感情和睦的祕訣！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我是很想告訴妳，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_033"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但我們其實也沒",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "做什麼特別的事……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個──",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_034"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎呀小姐，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_035"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們已經打掃完啦。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "果然年輕人就是手腳快呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請問，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些人是……？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "什麼？",
        "unit_id": 1011,
        "voice": "vo_adv_1118003_037"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "你們不是來見這兩位的嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們只是碰巧遇見了而已。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "這樣啊？",
        "unit_id": 1211,
        "voice": "vo_adv_1118003_039"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "那你們運氣很好呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n在新年這天遇見這對老夫婦的情侶，都能幸福地終生相守，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n這個傳聞非常有名喔。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以剛剛在參拜路上聽到的",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n結緣之神指的難道就是……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "神？",
        "unit_id": 511,
        "voice": "vo_adv_1118003_041"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "哈哈哈！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n我們才沒有那麼偉大呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒錯沒錯，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_042"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我們只是相伴多年的老夫老妻而已。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n沒什麼稀奇的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "全都是碰巧、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "碰巧罷了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "但老婆婆你們很出名呢。",
        "unit_id": 1211,
        "voice": "vo_adv_1118003_043"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "聽說有很多人都在遇見你們後",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "幸福修成正果呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是動人的佳話呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "就是說啊，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_045"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "年輕人幸幸福福的是好事啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我們也絕對",
        "unit_id": 1211,
        "voice": "vo_adv_1118003_046"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "會幸福下去的！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不會讓老爺爺你們失望的！",
        "unit_id": 1011,
        "voice": "vo_adv_1118003_047"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "哈哈哈！",
        "unit_id": 511,
        "voice": "vo_adv_1118003_048"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不用顧慮我們兩個啦。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n只要你們期望能帶給對方幸福，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n這就算是",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "一種幸福了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒錯沒錯，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_049"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "雙方都盡力而為就行了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我們老人家能給的忠告也就這麼多了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "女性2、男性2",
        "words": "謝謝您！",
        "unit_id": 1,
        "voice": "vo_adv_1118003_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那兩人臉上",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "掛著滿足的笑容離開了呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "每年都能見到年輕人的笑容，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_052"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我們才是幸福的那一方啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "希望他們明年也能",
        "unit_id": 611,
        "voice": "vo_adv_1118003_053"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "像這樣一起前來。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像有點明白",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼你們兩位會被稱為",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結緣之神了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "咦？",
        "unit_id": 611,
        "voice": "vo_adv_1118003_055"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "怎麼了嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們兩位會替對方著想，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並由衷地為他人的幸福感到欣喜。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正是一段好姻緣的最佳範本呀。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是、",
        "unit_id": 511,
        "voice": "vo_adv_1118003_057"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "是這樣嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "被這麼誇獎，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "很讓人害臊啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也想和你們學習呢。",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_058"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳在說什麼啊，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_059"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "小姑娘。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就是說啊。",
        "unit_id": 611,
        "voice": "vo_adv_1118003_060"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "小姐妳們不是早就如此了嘛。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_061"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "因為擔心我們",
        "unit_id": 611,
        "voice": "vo_adv_1118003_062"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "而幫忙打掃、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n為陌生人的笑容而開心。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "而且，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_063"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "你們兩個並肩打掃的樣子，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n和我們年輕時一模一樣。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是、",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "當然，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_065"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我們可以掛保證。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你們兩人很登對喔。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個嘛……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好害羞喔☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "呵呵，",
        "unit_id": 611,
        "voice": "vo_adv_1118003_067"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "純純的愛真好啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "打擾這對小情侶也不太好意思，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_068"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n我們",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "就此告辭吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊──！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請等一下！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有什麼",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我們能幫忙的嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不必了，",
        "unit_id": 511,
        "voice": "vo_adv_1118003_070"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我們這裡也做完了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "剩下的事差不多也就求個籤後回家去吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "求籤！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我完全忘記了！！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也去吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "數兩秒後同時看結果吧？",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要數囉，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一、二！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往好處想，這代表之後會越來越好，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也算是好結果嘛。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒必要因此而沮喪。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我也是末吉。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們一樣呢☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼那麼，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "重點是裡面寫了什麼呢？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我看看……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 111811
    },
    {
        "type": "still",
        "still": "111800301"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你快看！",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "籤上說「等待的人就在身旁」",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這一定是指你吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好害羞喔☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊、",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼說……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是預料之外的答案。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種會讓人怦然心跳的回答",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太狡猾了啦……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 111811,
        "voice": "vo_adv_1118003_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個嘛，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我還有很多",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
