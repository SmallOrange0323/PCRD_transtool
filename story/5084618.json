[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你",
        "unit_id": 101711,
        "voice": "vo_adv_5084618_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "究竟打算睡到哪時候呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你不在，我不管是唱歌還是跳舞都提不起勁呀……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然很寂寞，",
        "unit_id": 101711,
        "voice": "vo_adv_5084618_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但或許對你而言，像這樣沉睡是有必要的哪。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "畢竟你這個人呀，老是為了他人過於勉強自己，",
        "unit_id": 101711,
        "voice": "vo_adv_5084618_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以偶爾也要順著局勢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "悠閒休息一下才行呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我現在",
        "unit_id": 101711,
        "voice": "vo_adv_5084618_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也就悠閒地等你回來囉。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n等你醒來之後，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "再一起做很～多開心的事吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，",
        "unit_id": 101711,
        "voice": "vo_adv_5084618_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你就好好休息到下次見面吧，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "晚安囉～",
        "unit_id": 101711
    }
]