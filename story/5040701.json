[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了保護熟成起司而一個人站在倉庫內的鈴，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n很快就遇到了與老鼠對峙的局面。"
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～！！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊！　",
        "unit_id": 102611,
        "voice": "vo_adv_5040701_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "馬上就出現了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只要老鼠不出現就是一份輕鬆的工作了說。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過既然我已經向眾人誇下海口了，",
        "unit_id": 102611,
        "voice": "vo_adv_5040701_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那我就得確實把老鼠都趕走才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "給我出去！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個起司可不是你的東西！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱！\n吱吱！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_5040701_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可惡！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n想不到還挺頑強的嘛！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "給我出去～～～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～！？"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611,
        "voice": "vo_adv_5040701_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總算趕跑了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "老鼠還真是出乎意料地難纏啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過既然都趕跑了，",
        "unit_id": 102611,
        "voice": "vo_adv_5040701_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就保持這個步調，繼續保護起司吧。",
        "unit_id": 102611
    }
]