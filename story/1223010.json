    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "該不會……",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_018"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n這些垃圾，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是你們丟的？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "……",
        "unit_id": 811,
        "voice": "vo_adv_1223010_019"
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "這些小鬼是怎麼回事，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "居然完全不怕我們。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "是",
