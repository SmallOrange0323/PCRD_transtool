    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚！",
        "unit_id": 8311,
        "voice": "vo_adv_1223010_005"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "對吧～！",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "順利蓋好的話，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就招待伊莉亞來玩吧。",
