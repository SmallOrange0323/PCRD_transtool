    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "你胖嘟嘟的臉頰肉肉還在！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "馬上用冰涼的水水幫你冰敷哦！",
        "unit_id": 6311,
        "voice": "vo_adv_1223010_033"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真是的～",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_034"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "太誇張了啦。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n與其說是龍，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你們幾個",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "更像蠑螈吧。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "話說回來，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_035"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "現在你們知道這裡是班比的家了嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n知道的話",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就快點回去自己的家！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "魔龍兄弟",
        "words": "是、",
        "unit_id": 1,
        "voice": "vo_adv_1223010_036"
    },
    {
        "type": "dialogue",
        "name": "魔龍兄弟",
        "words": "是的────！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "魔龍兄弟",
        "words": "對不起──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "班比",
