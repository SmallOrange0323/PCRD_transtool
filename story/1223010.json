    {
        "type": "dialogue",
        "name": "超龍",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "沒辦法了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "講不聽的小孩",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "就用這個懲罰你們！",
