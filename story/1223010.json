    },
    {
        "type": "background",
        "background": "500530"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這是怎麼回事～！？",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比的家",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "到處都是垃圾！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀噗……",
        "unit_id": 8311,
        "voice": "vo_adv_1223010_009"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是誰做了這麼過分的事！",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_010"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比現在非常生氣耶！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂喂，",
        "unit_id": 811,
        "voice": "vo_adv_1223010_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有隻可愛的老鼠不小心闖進來了啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真可憐啊，",
        "unit_id": 6311,
        "voice": "vo_adv_1223010_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要回不了家囉？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為這裡，",
        "unit_id": 911,
        "voice": "vo_adv_1223010_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是可怕的龍穴啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇哈哈哈哈哈！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……你們幾個，",
