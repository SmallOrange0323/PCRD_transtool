    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "錢要怎麼使用，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好困難哦。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "啊，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "對了！",
