    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "喂喂，",
        "unit_id": 811,
        "voice": "vo_adv_1223010_015"
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "她好像什麼都不知道就闖進來了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "那麼我來告訴妳吧！",
        "unit_id": 6311,
        "voice": "vo_adv_1223010_016"
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "我們是",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "會讓哭泣的小孩哭得更大聲的恐怖化身！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "人稱大盜賊",
        "unit_id": 911,
        "voice": "vo_adv_1223010_017"
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "「魔龍兄弟」，",
        "unit_id": 911
    },
