        "type": "dialogue",
        "name": "班比",
        "words": "班比有一陣子沒去了，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_007"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "先去看看班比的家吧！",
