        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "炎龍！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "好啊雷龍！",
        "unit_id": 811,
        "voice": "vo_adv_1223010_027"
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "接招吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "「雙龍連擊」！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_028"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "呀嗯！",
        "unit_id": 811,
        "voice": "vo_adv_1223010_029"
    },
    {
        "type": "dialogue",
        "name": "雷龍",
        "words": "嗚嗯！",
        "unit_id": 6311,
        "voice": "vo_adv_1223010_030"
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "好痛！",
        "unit_id": 911,
        "voice": "vo_adv_1223010_031"
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "好痛啊──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "欸，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "被削掉了嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "\n我臉頰的肉肉被削掉了嗎？",
