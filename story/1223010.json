        "voice": "vo_adv_1223010_020"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這裡是班比的家。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n壞孩子現在馬上離開啦。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "喔～喔～",
        "unit_id": 911,
        "voice": "vo_adv_1223010_021"
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "妳很勇敢嘛。",
