        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "炎龍",
        "words": "\n看到它的人沒有人能活著回去！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿。",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_024"
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "啊哼！",
