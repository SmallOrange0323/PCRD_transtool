    {
        "type": "dialogue",
        "name": "班比",
        "words": "真祖嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_069"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只要是同胞，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我想任何人都會察覺到喔。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為吸血鬼十分罕見，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其中",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真祖大人的魔力更是不同凡響啊。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "是的，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_070"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我是吸血鬼，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "和他一起",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "漫無目的地在各地漂泊，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n最後流浪到真祖大人的土地。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她原先在我的家鄉和我一起靜靜地生活，",
        "unit_id": 1011,
        "voice": "vo_adv_1223010_071"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n從未攻擊過人類，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "和居民們也相處得很好。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可是，",
        "unit_id": 1011,
        "voice": "vo_adv_1223010_072"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "當她被發現是吸血鬼後，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "村民就把她趕出了村莊……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "怎麼這樣？",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_073"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好過分～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "沒辦法。",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_074"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "吸血鬼自古",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "便是人們畏懼的對象。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n不過，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "他為了我拋棄家鄉，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "選擇與我攜手前行。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "跟著所愛的人走是理所當然啊。",
        "unit_id": 1011,
        "voice": "vo_adv_1223010_075"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "即使世界各地都沒有我們的歸宿，我也會這麼做。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚……",
        "unit_id": 8311,
        "voice": "vo_adv_1223010_076"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "就在此時，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_077"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我們聽說了真祖大人城堡遺址一事。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n我們心想",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "若是這裡，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n一般人類不會靠近，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "正適合隱居。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒有這回事喔？",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_078"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這裡有奇怪的叔叔",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "還有魔物，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "很多人闖進來呢。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "是的，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_079"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "實際上",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "像是出於好奇過來的人類，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n或是被真祖大人的魔力吸引而來的魔物，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我們",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "都遇到過好幾次。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "先不提魔物，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_080"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我很驚訝",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "有不少人",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "會特地來到",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "傳聞中可怕駭人",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "的地方……",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過，",
        "unit_id": 1011,
        "voice": "vo_adv_1223010_081"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也因為是這種地方，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只要確實嚇嚇他們，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "很容易就能趕走，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "弱小的魔物",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也不是她的對手呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "但是，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_082"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "如今統治這片土地的真祖大人歸來，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n我們就無法繼續待在這裡了。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "擅自占用真祖大人土地之過，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_083"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我會以此身贖罪。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "等、",
        "unit_id": 1011,
        "voice": "vo_adv_1223010_084"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "等一下。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要問罪的話針對我這個人類就行了吧？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她和妳同樣是吸血鬼，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "拜託妳",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "饒她一命！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯──",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_085"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "其實你們不必道歉，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "也不必離開哦？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "咦？",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_086"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "可、",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "可是……",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為你們",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_087"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒有亂丟垃圾，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n也幫班比趕走了",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "奇怪的叔叔們對吧？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "而且班比，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_088"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n現在住在伊莉亞那裡嘛～",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n如果你們想待在這裡",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "也可以喔。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "這、",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_089"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "這多麼讓人惶恐……",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "可是……",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不愧是僕從！",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_090"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那麼～",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你們可以待在這裡，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n交換條件是",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要照顧好班比的家，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拜託你們囉！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這件事就當成是租金了！",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_091"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "……真祖大人寬宏大量，",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_092"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "實在感激不盡。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我們就聽大人的，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "會擔負管理這片土地的職責。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "我們一定",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_093"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "不辜負真祖大人的期待──",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯～",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_094"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那個",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "「真祖大人」的叫法",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有點討厭。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這個名字，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n叫班比的名字吧。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "……我明白了。",
        "unit_id": 51412,
        "voice": "vo_adv_1223010_095"
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "那麼",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "班比大人，",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "\n今後",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "女吸血鬼",
        "words": "還請您多加關照了。",
        "unit_id": 51412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "哼哼～",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_096"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "做這點小事是當然的啦。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "而且……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "而且那個人，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_097"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "和班比有點像嘛。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n失去歸宿的部分，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "還有……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n受到重要的人",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "幫助的部分。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以，",
        "unit_id": 122311,
        "voice": "vo_adv_1223010_098"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "總覺得沒辦法丟下她不管……",
        "unit_id": 122311
    },
