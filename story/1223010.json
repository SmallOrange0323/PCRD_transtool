    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比的家！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n雖然那裡已經",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "變成了「遺址」，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n不過那裡還是",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比的家呢。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以班比來把那裡整理乾淨，",
