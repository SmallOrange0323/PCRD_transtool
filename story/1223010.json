    {
        "type": "dialogue",
        "name": "超龍",
        "words": "喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "小兄弟你也勸勸她啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "超龍",
        "words": "\n如果太過調皮搗蛋，",
