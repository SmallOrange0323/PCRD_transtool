    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，聖誕節的早上。\n胡桃主演的戲劇在派對上演的當天，\n【咲戀育幼院】的每一個人都到了會場。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿♪",
        "unit_id": 108611,
        "voice": "vo_adv_1085004_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "GOGO，LET'S GO！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "昨天是派對！",
        "unit_id": 108611,
        "voice": "vo_adv_1085004_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　今天也是派對！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "每一天都像祭典一樣狂歡～！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聖誕節最棒了……☆",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂喂。",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有雪積著很滑的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跑來跑去小心滑倒哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒問題的，",
        "unit_id": 108611,
        "voice": "vo_adv_1085004_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "又不是鈴莓，才不會滑倒呢♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「又不是鈴莓」",
        "unit_id": 102511,
        "voice": "vo_adv_1085004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這句話是多餘的吧，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小綾音～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難得穿著這套衣服要是弄髒就糟了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真的要小心一點喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是啊～",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "用不著那麼著急，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "腳下多留意一點。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n派對會場也還沒完全準備好，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n提早到了只會給人添麻煩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……哎？",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "　胡桃，反而走得太慢了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為年底的返鄉潮，馬車的往來很頻繁，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們還是盡可能走在一起不要散開比較好哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃～？",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n怎麼了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無精打采的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……這麼不喜歡演戲的話，",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們可以拜託劇團人員讓他們代替就好啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你可以不用勉強的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒、",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒問題的！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好不容易才被選為主角，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會加油的！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是。",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n昨晚有點沒睡好，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現在很想睡……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以有點走不動，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀。",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就，讓{player}抱著你過去好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃，",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天要演的戲，主角是公主對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "給你來個公主抱，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不是剛好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚哇哇？",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "能抱著我的話那真是幫大忙了……哥哥。",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我是真的，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好睏啊……♪",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 108611,
        "voice": "vo_adv_1085004_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只有胡桃太狡猾了！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　我也要我也要！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只靠哥哥抱我們兩個好像有點難，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就讓鈴莓來抱我吧～♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈啊？",
        "unit_id": 102511,
        "voice": "vo_adv_1085004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　不要撲上來啊小綾音，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噗吉比我想得還要重我一個人抱不動啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇哇，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要跌倒啦！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_1085004_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你們兩個，在幹嘛啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是聖誕節也不能興奮過頭了唷～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種事就是造成事故的主因了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀啊……",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼好像在發光……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　咲戀媽媽他們，沒有注意到嗎……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看見這道光的，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只有我一個人嗎……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 108511,
        "voice": "vo_adv_1085004_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不行了……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n無法思考了，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "越來越想睡了……",
        "unit_id": 108511
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥～……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好久不見！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……哇呀！？　",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼要摀住我的嘴巴啊？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要突然碰我啦！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊 ，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在圖書館裡要保持肅靜……的意思嗎？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n對不起，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "遇見哥哥很開心，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太興奮了……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼辦，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想和哥哥聊聊……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "既然不可以在圖書館內吵鬧，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那麼",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那麼……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那樣的話，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不就很像是在約會嗎……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這、",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這太害羞了，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我沒有辦法……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　用筆聊……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸……",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥認識的人裡，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有個平常不太說話的孩子呀……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為了和他交流，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以嘗試了各種方法嗎……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然那孩子能用腹語術交流，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但完全無法搞懂他本人的心情……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "腹、",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "腹語術？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　真是個奇怪的孩子呢……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "他是個很怕生的孩子，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n完全不和別人說話呀……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼感覺和我很像呢……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那孩子，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "叫什麼名字呀？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯嗯，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "北條綾音……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不認識的人呢……",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥的人緣，真的很好呢……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵。",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "話說回來，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那邊有個談話室……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小聲點說話應該不會挨罵，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我們去那邊聊吧……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果不要的話也沒關係……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥大概，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也不是為了聊天才來到圖書館的吧……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "馬上就是考試了所以才來這裡讀書嗎……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "高中生真是辛苦呢，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且不是義務教育……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不好好努力的話，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就要被丟下了呢……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我知道了。",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我所屬的劇團也是這樣的氛圍，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "實力至上主義，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n太散漫的話是得不到演出機會的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "競爭非常激烈，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我也錯過了下一次公演演出主角的機會了……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也好想嘗試看看呢，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "扮演公主……",
        "unit_id": 102131
    },
    {
        "type": "still",
        "still": "108500401"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是個非常棒的角色呢……",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在富麗堂皇的城堡中的舞會，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "互相訴諸愛意，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n和仰慕的王子一整晚……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "幸福愉快地跳著舞♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我夢想著這樣的光景，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n希望自己一定要被選上，出演公主的角色……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n大家也是一樣，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想只要是女孩子都會這麼想的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是被選上這種大家都想出演的角色……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就要連同大家的份一起努力，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不拿出最好的演技可說不過去……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿……",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我啊，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是主要演員因為意外無法出演時，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n才能上去替補的演員……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為了能夠進入角色，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天是來讀劇本的原作……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n既然有那麼一點點出演的可能，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我就要全力以赴……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不想逃避，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n因為在現實裡",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我總是畏首畏尾的四處逃竄……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n至少，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在舞台上我想去面對。",
        "unit_id": 102131
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是說，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們就這樣聊開了……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "抱歉了哥哥，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那我先離開了哦……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然只稍微聊了幾句，但我很開心……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_046"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "下次我還有機會站在舞台上，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我一定會給你入場券的……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n請你一定要來哦，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "絕對不會讓你感到後悔的。",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那我就，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "先告辭了。",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對了……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然有點早，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不過不知道什麼時候才會再碰到哥哥……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "趁現在，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "先和你說一聲吧。",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102131,
        "voice": "vo_adv_1085004_049"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "聖誕節快樂……♪",
        "unit_id": 102131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聖誕節快樂……{player}♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來之後，就會全都忘光囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不多說了～",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "慣例的說明也是夠麻煩的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天我可是一點幹勁都沒有呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也是啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聖誕節或是年末年初也想好好休假的啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過可惜的是作為神明根本是全年無休的呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過認真說起來我也不是神明就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且。",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛好胡桃也睡著了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓你們一起做個夢緩解一下緊張的情緒……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想說鼓勵一下，從背後推他一把應該會好一點。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和『那裡』不一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "『這裡』的胡桃，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n作為舞台演員似乎一開始就不是很順利呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟踏上戲劇之路的時間稍微晚了一點呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在『那裡』可是主演了無數次、",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n作為專業劇團裡出名的演員活躍著呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n『這裡』的話，感覺是個還不習慣舞台的初學者呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過。",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "胡桃，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n他可是……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "擁有著勝任主演的潛力呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有才能還有熱忱。",
