        "voice": "vo_adv_1085004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就像剛才你所見到的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n完全體現出了他努力不懈的姿態。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "『這裡』也是，就只差推她一把了……",
        "unit_id": 190011,
        "voice": "vo_adv_1085004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要給她一個契機，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我認為她的才華定能迅速開花結果。",
