[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪……",
        "unit_id": 110811,
        "voice": "vo_adv_5140204_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "暫停──等一下。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳們不覺得……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這一帶的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "氣氛好像哪裡怪怪的嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 111011,
        "voice": "vo_adv_5140204_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個不吉利的鐘聲是……！？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不好了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "諸位，快躲起來！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "♪聖～～",
        "unit_id": 18211,
        "voice": "vo_adv_5140204_002"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "德蕾莎～",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "女子～學～院──",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噫欸！",
        "unit_id": 110911,
        "voice": "vo_adv_5140204_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n剛才應該已經被我們打倒的魔王，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "正一臉平靜地若無其事走著！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「逃犯們＜那群傢伙＞」是跑哪去了……",
        "unit_id": 18211,
        "voice": "vo_adv_5140204_004"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "啊啊──",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "一找到就要把她們處以「斬首刑＜斷頭＞」，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "還想玩玩\n把砍斷的「頭顱＜臉部＞」拿來踢的「球類運動＜遊戲＞」呢，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "呵哈哈哈！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "糟糕，",
        "unit_id": 110811,
        "voice": "vo_adv_5140204_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她還活蹦亂跳的呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "皮膚也充滿了光澤呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛才的戰鬥，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "到底是有多優待新手啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這下不妙，",
        "unit_id": 111011,
        "voice": "vo_adv_5140204_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在兩種意義上都要加快動作。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在絕對不能被富美惠修女抓住，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要是拖得太久，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "公會管理協會也會碎碎唸的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也對，",
        "unit_id": 110911,
        "voice": "vo_adv_5140204_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總之",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "快點前往「飛翔切嚕號」吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "墨團的飛空艇，",
        "unit_id": 110811,
        "voice": "vo_adv_5140204_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是叫這個名字的嗎？",
        "unit_id": 110811
    }
