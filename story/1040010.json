    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "宣布BB團重新開始活動後，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定帶碧離開精靈之森，前往城鎮。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我我我我我我我我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我該怎麼辦才好……！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像我這種邊緣人",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "居然要上街交朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有問題嗎……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我果然",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會在被發現是邊緣人的瞬間，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n被大家扔石頭跟欺負吧……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "快冷靜下來，碧！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n像這種時候",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要用力深呼吸，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在掌心裡寫下「精靈族」再吃下去，就能放鬆了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說得也是……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吸吸吐……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吸吸吐……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n然後……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "寫下「精靈族」……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我吃……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀啊啊啊～～～！？\n對不起對不起對不起對不起！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n拜託了，請不要丟我石頭～！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來是團長嗎……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一聽說要去街上，我就感到很動搖……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我是想讓自己冷靜下來，才會一直跟「有我在喔好朋友號」說話。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "果然",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不去不行對吧……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n老實說……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我非常害怕……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我是有去過街上……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是有目的才不得不去的程度……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一定會跟人擦身而過時，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會改成匍匐前進",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來避免跟人對上目光……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就算去街上，我也不認為自己交得到朋友。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n畢竟光是跟{player}成為朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也已經像是奇蹟一樣了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "交朋友檢定只有10級的我，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n再交新的朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還太早了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n正論刺得我好痛……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "確實是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那樣沒錯。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既然{player}都那麼說了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n肯定是有什麼用意……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我明白了……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n雖然很害怕，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我會試著努力看看……！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "到、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "到了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我首先要做什麼……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦～！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛到就要嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我我我、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我辦不到啦！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……真的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "非做不可嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是認真的呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然如此，只好豁出去了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會盡力試試，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯！！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯？",
        "unit_id": 1211,
        "voice": "vo_adv_1040010_019"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有什麼事嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃…………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……？",
        "unit_id": 1211,
        "voice": "vo_adv_1040010_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今、",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天天氣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n天天……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天………………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "天上天下唯我獨尊～～～！！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_023"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1040010_024"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "等等……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "她",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是怎麼了……？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n無論試幾次，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要想向誰搭話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就會說不出任何話，雙腳不停發抖……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我果然是沒藥救……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自從跟{player}相遇後，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我完全沒有任何成長……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你真的很溫柔呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n能聽到你那麼說，我很開心……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n難得都來街上了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "別說交不到朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n居然沒能跟任何人正常交談……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我果然是",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無藥可救呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該沒任何人",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會在乎這樣的我吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以我才會一直都是個邊緣人對吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了下次來時能和人搭上話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就先練習過再回去吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "把附近的垃圾收集起來……",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像這樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿咻……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "再像這樣……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "完成了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040010_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這是用來練習在街上跟人交談用的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔好朋友號」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我把它取名為",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔都市好朋友號」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿。",
