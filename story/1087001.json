    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在新年首賣的鬧區上，\n{player}遇見了日和。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是騎士先生耶～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哈囉～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你在做什麼？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣呀～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也餓了耶～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一直都是餓扁扁的～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得像佩可小姐一樣呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在大家一起去看了新年的日出之後，",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我直到昨天都一～直",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n在幫忙動物苑的新年會，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可真累壞了呀～",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天也是收拾到了剛剛才結束，",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以到現在還什麼都沒吃……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒想到竟然能夠遇到騎士先生，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真開心～♪",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛那聲音，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是騎士先生的肚子在叫？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看來肚子是非常餓了呢！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔啊……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛那是我的肚子在叫。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要不要一起邊走邊吃？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n從攤販傳來的味道實在太香了，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我啊，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經快忍不住啦～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當然可以囉！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼就趕快",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "Let's go～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從什麼東西開始吃好呢？",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生你已經決定好",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想吃什麼了嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗅嗅……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是糰子和年糕紅豆湯的香味～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "烤年糕的味道，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很能勾起人的食慾呢～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚嗚嗚～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還只是聞到味道，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺就像吃得飽飽的了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶吶騎士先生！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們把想吃的東西，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "全～部都吃一遍吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有炒麵甚至還有章魚燒……！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦！？",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那邊的攤販，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然還有巧克力香蕉和棉花糖！？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "突擊啦～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不好意思！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請給我一盒章魚燒～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好咧！",
        "unit_id": 1411,
        "voice": "vo_adv_1087001_018"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哎呀，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "日和！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "前陣子我家的女兒受到妳照顧了呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不用客氣！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就該互相幫助幫助嘛！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳能這麼講真是幫了大忙唷。",
        "unit_id": 1411,
        "voice": "vo_adv_1087001_020"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "話說回來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "只買一盒夠吃嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我才吃不了那麼多啦～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，對喔。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也得點騎士先生的那份才行！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請再給我一盒！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好咧～！",
        "unit_id": 1411,
        "voice": "vo_adv_1087001_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝光臨～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "久等啦，騎士先生！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這盒是",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生你的章魚燒！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有什麼想吃的東西嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "日和妹妹～！",
        "unit_id": 411,
        "voice": "vo_adv_1087001_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼～？",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "賣鯛魚燒的姐姐！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "前陣子妳來幫忙我搬東西，謝謝妳啦！",
        "unit_id": 411,
        "voice": "vo_adv_1087001_026"
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "今天就當做謝禮，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "給妳點福利唷。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "這鯛魚燒，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員1",
        "words": "拿去吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝妳！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "日和妹妹，",
        "unit_id": 1511,
        "voice": "vo_adv_1087001_028"
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "要不要吃烤花枝？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "給妳一支！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想吃！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的可以嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "可以啦可以啦！",
        "unit_id": 1511,
        "voice": "vo_adv_1087001_030"
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "去年妳也幫了我們很多忙啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性店員2",
        "words": "\n讓我們給妳一點優待嘛！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就不客氣地收下了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "日和妹妹～！",
        "unit_id": 311,
        "voice": "vo_adv_1087001_032"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "這個妳也拿去吃吧！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦呀，騎士先生！",
