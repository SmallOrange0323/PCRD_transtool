        "voice": "vo_adv_1087001_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然收到這麼多東西！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我一個人的話沒手拿啦～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一起吃吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "兩個人分著邊走邊吃的話，應該就吃得完呢！",
