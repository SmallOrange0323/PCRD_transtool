        "voice": "vo_adv_1087001_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個給你！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有這個，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟這個！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣就差不多了……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有騎士先生你在實在太好了～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果我是自己一個人來的話，一定吃不完的～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊……",
        "unit_id": 108711,
        "voice": "vo_adv_1087001_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦，騎士先生。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的兩隻手都空不出來。",
