[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……我回來了。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基！",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "花了不少時間呢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "發生什麼事了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n外面的情況怎樣？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……是的。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_002"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n情況很不妙，諾維姆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "這個【拉比林斯】的據點週遭，",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_003"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n已確認聚集了無數蠢蠢欲動的魔物。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n再加上，極可能是【王宮騎士團】的武裝軍隊。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "於這個當下，我們處於被如此外敵團團包圍的狀態。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_004"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n戰力差距一目了然，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n若不趕緊避難，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我們勢必會在此被全滅的吧。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "魔物加上，軍隊……？",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那不是糟糕了嗎！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然並不覺得可以一直躲在這裡沒事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但也發現得太早了一點！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然是【王宮騎士團】親自出陣，\n這麼看來敵人就是王宮派來的準沒錯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一直來一直來，真是群煩人的傢伙。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是要來抓逃獄的大吾他們，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或是來殲滅反政府勢力的【拉比林斯】。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管怎樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都早就不是可以坐下來好好談的對手了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，也不是沒有料想過這樣的事態。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n趕緊包一包行李，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要開始逃囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}你們也一起來，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛那話題就留到下一次吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在的你好說話多了，還真幫了大忙。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在記憶喪失前的你，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是相當叛逆的傢伙呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，那時候畢竟是敵對關係所以沒辦法嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這點我也一樣。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就只是我單方面的一～直在講，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n沒有給你們整理思緒的時間，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的還挺抱歉的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果是能悠閒地等到我們把重要的話都說完，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就像是那種給小孩子看的卡通裡登場的壞蛋一樣就好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊真是的，",
        "unit_id": 105812,
        "voice": "vo_adv_2008011_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "安穩的時間總是沒辦法長久呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很有可能會演變成戰鬥，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我們也先暖身一下吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913,
        "voice": "vo_adv_2008011_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能夠利用拉基拉基先生的空間跳躍來脫逃嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能那麼做的話，在下想事情會簡單許多，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否可行呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "關於這件事，出了點問題……",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_015"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "真的非常抱歉。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "似乎在這整個區域的空間中，",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_016"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n被設置了類似魔法的陷阱……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n剛才到外頭探究情勢時，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "使我受到了相當深刻的損傷。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "儘管不至於危害到性命，",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_017"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "但短時間內再次空間跳躍是不可能的。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘖，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來敵人也早就想好對策了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是因為這麼方便，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n才會過於頻繁的使用拉基拉基的空間跳躍呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過嘛，拉基拉基可是『七冠』……是極為特別的存在。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "永遠的、不論地點的將那個權能封鎖是不可能的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之一面確保拉基拉基的復原狀況，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n一面突破敵人包圍逃往安全的區域。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要成功逃到可以使用空間跳躍的地區，",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再移動到【拉比林斯】其他的藏匿處……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能這麼順利就好了啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂喂，妳也太沒骨氣了吧。",
        "unit_id": 190711,
        "voice": "vo_adv_2008011_022"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n雖然逃跑不太合我的意就是……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "看看對方有多少人，不多的話把他們都解決掉也行吧？",
        "unit_id": 190711,
        "voice": "vo_adv_2008011_023"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n一直被人家追著跑也不太爽啊，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "就踢飛他們吧。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……大概有些困難呢。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_024"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不僅數量懸殊，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "甚至還有像建築物一樣的超大型魔物。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "從考量到對我的封鎖策略這點可以推斷，",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_025"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n對方應該確實",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n準備了能將我方給全數殲滅的充足戰力才對。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "與他們正面對抗，並非妙策。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_026"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我不太能夠贊同。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟{player}他們，可還有客人在呢。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們不該勉強去進行戰鬥，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n臨陣脫逃雖然可恥，但這裡還是乖乖夾著尾巴撤退吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……你能接受的話我會很開心的，大吾。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_028"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真是的，真拿妳沒辦法……",
        "unit_id": 190711,
        "voice": "vo_adv_2008011_029"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但是如果要避難的話，不把拉比林斯達給一塊扛走不是不行嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我跑一趟去回收她！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 107111,
        "voice": "vo_adv_2008011_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n拉比林斯達可說是我方的殺手鐧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不能夠失去的重要關鍵呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不知道為何，",
        "unit_id": 107111,
        "voice": "vo_adv_2008011_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n以個人的角度來說我也不想見到那傢伙受傷或者送命。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2008011_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳們倆，在世界被改變以前好像是好朋友的樣子呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不知不覺～那樣的記憶也殘留下來了吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呼。",
        "unit_id": 107111,
        "voice": "vo_adv_2008011_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說得就像是上輩子的事情，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一點頭緒都沒有呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了。",
        "unit_id": 107111,
        "voice": "vo_adv_2008011_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n閒聊就到這，趕緊逃吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……叫拉基拉基的，你自己走得動嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_2008011_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若不行就算你賺到，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我來抱著你離開吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "這好意我心領了。",
        "unit_id": 107311,
        "voice": "vo_adv_2008011_036"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n若只是普通移動的程度，沒有問題。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "呣。背對著擄走似似花大人的那群敵人，",
        "unit_id": 191011,
        "voice": "vo_adv_2008011_037"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n不得不逃走之事雖令人恨得牙癢癢。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可是嘛，比起誤判戰局而白白掉了性命還來得好吧。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "此處不該為喪命之處。",
        "unit_id": 191011,
        "voice": "vo_adv_2008011_038"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n至少，在救出似似花大人以前就是得苟且偷生也在所不惜。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家～逃跑的準備ＯＫ了嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_2008011_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這裡有個緊急時用的逃生出口，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓姐姐替你們帶路唷♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這邊唷，",
        "unit_id": 101112,
        "voice": "vo_adv_2008011_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這邊！ 快點！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個什麼出了事就要補魚池的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～是想要說『事不宜遲』的嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_2008011_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好哦。",
        "unit_id": 105811,
        "voice": "vo_adv_2008011_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼我們也去避難吧，{player}。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105811,
        "voice": "vo_adv_2008011_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿，妳也在我的身後躲好唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是得以此身為盾，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也絕對會保護好你們的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為對於本應被奪走一切的我，",
        "unit_id": 105811,
        "voice": "vo_adv_2008011_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像奇蹟一樣邂逅的你們是最重要的朋友呢。",
        "unit_id": 105811
    }
]