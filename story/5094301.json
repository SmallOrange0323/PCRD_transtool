        "voice": "vo_adv_5094301_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n膽子還挺大的嘛，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這冒牌阿斯特賴亞菇！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我們對狀況的掌握過於天真，仍是事實。",
