        "voice": "vo_adv_5094301_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "撇除掉這一點，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對方也確實是會使用狡猾戰術的魔物。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n必須得儘早做出應變，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "否則肯定會出現更多受害情形。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說、",
