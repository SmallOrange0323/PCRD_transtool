[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在城鎮中散步時，\n耳邊傳來了熟悉的歌聲。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n果然，我的身體還是記不太住比較複雜的舞步……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我得再多練習才行……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……呀！是、是誰呢！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真抱歉，我以為只有我自己一個人――",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……咦？原來是你呀。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太好了……我還以為一定是被其他不認識的人聽到了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在，正在進行作為偶像必要的訓練課程。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "公會的夥伴，",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n幫我設計了偶像用的練習項目……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的、的確我們是有做過這樣的約定……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是呀，那個……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這、這個練習，很令人害羞……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以今天我自己一個人就可以了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且你看！這地方的話也不會有魔物出現，沒有危險的！",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以我自己一個人也沒關係！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗚……正如你所說的。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所謂偶像，的確是那樣沒錯呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我、",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我知道了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那就麻煩你陪我練習了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天我要做的是……邊唱歌邊跳舞的練習。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "平常我都只集中精神在唱歌而已……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然而作為偶像，好像不得不邊唱歌邊跳舞……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那麼，我要開始了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……請你仔細欣賞吧。我的舞蹈……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……呼、",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……到這裡就告一段落了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你、你覺得如何呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵……那是騙人的吧？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然很溫柔呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然是這樣子呢……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你這麼坦誠地告訴我。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的動作很僵硬對吧？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而且舞步的部分，也跳漏了好幾個地方。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我自己也很清楚……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？唱歌也……是這樣嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你覺得跟之前聽到的好像是不同人在唱歌一樣……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為我之前",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱的是唱喚術的歌曲。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天這個只是普通的歌曲而已。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……可是，我想原因大概不僅僅如此。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該是因為，我的心中還有迷惘…",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是唱喚士。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n明明為了保護別人而唱歌才是我的使命……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了那以外的目的而唱歌究竟好不好……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我真的不知道。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什、什麼！？這樣我會很害羞……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你怎麼突然這麼說！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是、是這樣嗎……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我一直覺得，",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的歌聲只是為了唱喚精靈而已。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還有其他能夠做到的……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "欸欸，",
        "unit_id": 211,
        "voice": "vo_adv_1042002_024"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "大姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "妳不再繼續唱歌了嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？你、你們是……！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_025"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "因為我們聽到很好聽的歌聲，所以就跑來了！",
        "unit_id": 111,
        "voice": "vo_adv_1042002_026"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "欸～再多唱一點嘛！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "我也想要聽～",
        "unit_id": 211,
        "voice": "vo_adv_1042002_027"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩３",
        "words": "我也是我也是～！",
        "voice": "vo_adv_1042002_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的歌聲……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的有這麼好嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "嗯！",
        "voice": "vo_adv_1042002_030"
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "\n真的很好聽喔！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那、那麼、",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就再多唱一點點唷。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "萬歲～！！",
        "voice": "vo_adv_1042002_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嘻嘻……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家看起來",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都很高興的樣子。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我覺得我可以理解你所說的意涵了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我用剛剛的歌聲，讓小孩們都露出笑容了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我跟我的歌聲，或許真的能夠做到更多事情……",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……謝謝你。",
        "unit_id": 104211,
        "voice": "vo_adv_1042002_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧了你，讓我不再迷惘了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌的迷惘一掃而空，\n並且對偶像的訓練課程努力不懈。"
    }
]