[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人進入了露娜之塔內部，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n調查著陰暗的迴廊。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "暗暗的，看不太清楚呢……",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n手摸到黏答答的東西了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這難道是魔物的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還是別去想了吧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這次換成有東西纏到臉上……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我沒辦法看清楚前面……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家究竟在哪裡……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊！",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有牆壁……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在看不見時",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能摸著某個東西，就會讓人覺得很安心呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "…………剛才的聲音",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是什麼？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也就是說……",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這代表我們出不去了嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼會突然……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這是因為那個啊。",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n女僕妹妹摸著的牆壁",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好像被設下了陷阱喔。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這難道",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是我造成的！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "沒錯沒錯！",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是女僕妹妹造成的！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n作為懲罰，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就請妳做些壞壞的事情來服務本大爺吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n……本大爺剛才是在開玩笑，所以妳別瞪我啦，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然這……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "非常難以啟齒，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但妳其實被附身了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的很抱歉！",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為了挽回這次的冒失，我會賭上性命……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被附身？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有個惡靈",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "附身在妳身上。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦咦咦咦！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就、",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就在我身旁嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我是說",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個惡靈！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它一直都在嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然我還看不到它的模樣，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻能感覺到那股氣息。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n它似乎對鈴莓下了詛咒，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為妳帶來了各種災難。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "而且這還是那種惡靈喔？",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_014"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "它很享受女僕妹妹因為冒失",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n而發生的那種事情",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "和這種事情。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n真受不了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "世界上居然還有這麼不要臉的惡靈啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這句話輪不到爸爸來說喔……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然只是有這個可能……",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但鈴莓以往經常失敗，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這或許是惡靈帶來的影響。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼會……",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個事實太令人震驚，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的腦袋一時轉不過來……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，等一下，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果能和那個惡靈分開，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我就能成為不再冒失的女僕了嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "交給本大爺吧，",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺會把妳調教成了不起的超色情女僕──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，你安靜一點。",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_019"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "噫，",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍好可怕！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我先來",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "試著和惡靈談判。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n順利的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "它應該馬上就會願意離開了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，鈴莓，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請妳站在我面前。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好、",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如、",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如何？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n它說了什麼！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………對不起，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這個惡靈",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "蘊藏了非常強大的力量。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為它無論如何都不願現身，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我沒辦法和它溝通。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果要說我因此知道了什麼……",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "它好像打算",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "奪走鈴莓所有的瑪那。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎、",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼這樣……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "活不了多久了嗎……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請妳放心。",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然不像父親那麼厲害，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我也",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "擁有除靈的力量。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我會",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫助鈴莓的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍……",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝妳！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那就",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "萬事拜託了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼……",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請妳閉上眼睛，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雙手交握。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n保持這個姿勢，集中意識……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳的手",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該會變得越來越溫暖。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "手變溫暖……",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但這不只是溫暖了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊哇哇哇！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我覺得",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像全身上下都燙起來了耶……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "燙？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n難道是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "惡靈在對鈴莓下詛咒……！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "鈴莓，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會接收這個詛咒的！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……嗚！？",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳的臉色好蒼白……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請妳別管我，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快放手吧……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我沒事……",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n只是頭有點暈而已……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "全身都好燙……",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "詛咒太強大，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來不及淨化……！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不行，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我要倒下去了……！　",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你們還好嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你們都摔得很重耶……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後我總覺得",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個情況非常似曾相識……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我沒事……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為{player}",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接住了我……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍，",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_040"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳沒事吧！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呃……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔喔喔喔！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小伙子，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "馬上戳爛你自己的眼睛！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不許你和我家寶貝女兒發生幸運色狼事件！！！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_7018001_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你在說什麼？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}只是在幫我……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……！？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇……！",
        "unit_id": 102511,
        "voice": "vo_adv_7018001_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n忍的衣服破掉了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有好多地方都……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔！？",
        "unit_id": 2411,
        "voice": "vo_adv_7018001_043"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "本大爺聽見了惡靈的笑聲！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就是你這傢伙吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "居然讓我家寶貝女兒做出這麼色情的打扮！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n本大爺要把你給驅除掉──！！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴莓急急忙忙地修補忍的衣服。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n骷髏老爸對著看不見的惡靈怒吼。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n忍則是因為這不幸的巧合而滿臉通紅，僵在原地。"
