[
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成功舉行進獻儀式數日後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n原本心情愉快的萊拉耶爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n此刻或許是因為在思考著什麼，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "臉上彷彿籠罩著烏雲。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "食物",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能讓人幸福……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這句話的意思，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我現在",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "更能夠深刻感受到了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "已經讓我的國民及騎士，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都品嚐過我做的點心了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……烏爾姆。",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我還沒",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "讓妳品嚐過……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不久前",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "烏爾姆才終於恢復意識……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖說有琳德在照顧，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但離康復",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還很遙遠……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然希望可以讓妳品嚐我做的點心……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n可是烏爾姆",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會願意吃嗎……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "烏爾姆之所以做出那樣失控的行為，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n說到底，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是因為我……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣的我做的點心，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也不知道她是否會接受……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "啊，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你看得出來嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "竟然在表情和態度上流露出來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "果然我",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還不夠成熟呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝你。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你願意聽我說嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "其實──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──事情就是這樣，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然我想要做點心給烏爾姆……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但不知道她會不會收下，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "想做點心給她的想法，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n感覺也只是我一廂情願……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_011"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "錯，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說得也是。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n在這邊什麼都不做，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才更加一廂情願呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼首先",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就開始行動吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝你，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就麻煩你了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n為了烏爾姆，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請助我一臂之力。",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們現在",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要去採集特別的蜂蜜，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那個蜂蜜，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在吉歐‧提格尼亞採集得到的蜂蜜中，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可是數一數二的，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n烏爾姆也很喜歡。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要是城裡有的話，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "大家",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都會爭相使用，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n所以才刻意不放在城裡，就是好吃到這種程度。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "總是一不小心就用太多了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……咳咳。",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以呢，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我打算要用那個蜂蜜",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來製作點心。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "差不多",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要到可以採集蜂蜜的地方──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請等一下，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "魔蜂群",
        "words": "嗡……！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那是……",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "魔蜂……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n是獄蜂手下的魔物呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒想到還留在吉歐‧提格尼亞……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是大意了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒錯。",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_018"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n數量非常多，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "先觀察一下情況──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n小心……！",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "魔蜂群",
        "words": "嗡……！",
        "unit_id": 3
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來在不知不覺間",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_019"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "被繞到背後了呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n應該在我們注意到之前，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就先發現我們了吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然現在",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_020"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "應該已經不受獄蜂支配了，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但從剛才的攻擊性來看，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "似乎一樣凶暴。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n更重要的是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "數量相當龐大。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣下去，",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_021"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "寡不敵眾……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然如此，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就用更強大的力量來對付。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這裡就交給我吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「至高的彩虹塔」──",
        "unit_id": 126511,
        "voice": "vo_adv_1381003_022"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我開動了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然不被獄蜂操控的魔蜂，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_023"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "與我無冤無仇。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要是有會突然襲擊人的魔物",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "存在於吉歐‧提格尼亞，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n有一天可能會對國民造成傷害。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我絕對不接受",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_024"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那樣的事情發生。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並且，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_025"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果是想要阻止我們",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "採集正在尋找的蜂蜜，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那麼就只能",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將你們排除了。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……我，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_026"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還想握住烏爾姆的手。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n雖然烏爾姆",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "傷害了他人，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但我想原諒她。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "然後讓她恢復活力，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_027"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再次回到我的身旁。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那才是",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "理想的和諧──",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n是這個國家的驕傲，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也是我的願望。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "即使身分有別，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_028"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "種族相異……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "即使這個世界",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並非真實世界。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就算這樣",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_029"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也愛著吉歐‧提格尼亞，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n愛著",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吉歐‧提格尼亞的國民！",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我不允許",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_030"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再有人來妨礙我們。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……永別了，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "被獄蜂操控的魔物們。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請安息吧。",
        "unit_id": 138111
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好了，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_031"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然都平安回來了，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就開始製作吧。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "牛奶、",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雞蛋、",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "焦糖，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以及蜂蜜……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "準備就緒。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n麻煩你預熱烤箱了，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_033"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很好的回答。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n為了烏爾姆，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們要做出最棒的一道點心。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我看看……",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_034"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "顏色、",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "形狀，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "冷卻程度也沒問題。",
