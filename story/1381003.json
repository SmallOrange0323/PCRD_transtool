        "voice": "vo_adv_1381003_046"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "可以吧，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆？",
