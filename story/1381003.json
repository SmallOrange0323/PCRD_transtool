        "voice": "vo_adv_1381003_043"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n您來探望烏爾姆嗎？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯。",
