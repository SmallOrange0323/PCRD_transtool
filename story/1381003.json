    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的重要情報。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n即使不是能輕易說出口的內容，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n也請讓我為保持沉默一事，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
