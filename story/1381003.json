    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "完成了，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n非常感謝",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你的幫助。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是的……",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_035"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n只剩下拿給她，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "讓她品嚐",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而已……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_036"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "抱歉。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我果然",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是很不安……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要是她",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_037"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不想吃我做的點心……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要是被拒絕的話",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "該怎麼辦？",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……我總是忍不住",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "想到這些事。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……好的。",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_038"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n只是一直覺得不安，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就無法向前邁進呢。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……！",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_039"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士……",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 138111,
        "voice": "vo_adv_1381003_040"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝你。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們去見烏爾姆吧。",
        "unit_id": 138111
    },
    {
        "type": "background",
        "background": "501730"
    },
