[
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接到嘉夜的聯絡後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}來到了電子遊樂場。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這邊、這邊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝啦，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你還特地跑一趟。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你看到mimi的通知了吧？",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n今天我想慶祝紀念日，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或者說是跟你道個謝。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你還記得嗎？",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們第一次見面的時候，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我被一群小混混糾纏……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "結果",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你救了我。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "自己人裡有個麻煩精就是這麼棘手……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在阿斯特朗傳奇見到也是那之後的事了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不過能像現在這樣混在一起",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是多虧了這傢伙。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是這樣，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天我請客。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n儘管玩吧……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "鬼道──！",
        "unit_id": 1,
        "voice": "vo_adv_9006011_005"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "你這傢伙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我今天一定要收拾你！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "小嘍囉吵死了！",
        "unit_id": 1,
        "voice": "vo_adv_9006011_006"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "\n你們這種雜兵再多湊幾個人也不會有改變的啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃────！",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為為、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼那傢伙會在這裡呀？　",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我姓鬼道呀？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這又怎麼了嗎，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎喲，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是剛好有個同姓氏的人在這裡吧～？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你想，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "鬼道這個姓氏",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很常見的嘛。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈哈……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "先不管那個了。學長，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "試試這個遊戲吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我幫你投幣……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你看，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要開始了！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我去找其他遊戲玩哦！",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔啊啊啊啊──！",
        "unit_id": 1,
        "voice": "vo_adv_9006011_011"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "搞什麼啊，",
        "unit_id": 1,
        "voice": "vo_adv_9006011_012"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "沒有嘴上說得厲害嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說啊……",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n要打架可以換個地方嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n真是讓人困擾。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "啥？",
        "unit_id": 1,
        "voice": "vo_adv_9006011_014"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "……什麼嘛，是妳呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "\n妳在這個地方做什麼啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我在什麼地方做什麼事都無所謂吧。",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n話說回來，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "電子遊樂場不是用來打架的地方，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是玩遊戲的地方。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "懂不懂啊？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "我也是來玩遊戲的啊？",
        "unit_id": 1,
        "voice": "vo_adv_9006011_016"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "\n是對方先找碴的，我只是陪他過兩招而已。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那種事不重要啦，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟我又沒有關係。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還有，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天爸媽都要上夜班",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以沒有晚餐。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你自己在外面隨便解決吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "我知道了。",
        "unit_id": 1,
        "voice": "vo_adv_9006011_018"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "\n那妳呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我跟朋友一起吃。",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n要交代的事情就只有這個。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就這樣。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "喔，",
        "unit_id": 1,
        "voice": "vo_adv_9006011_020"
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "好……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "被稱為鬼道的男子",
        "words": "\n那我也隨便解決吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是累人……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長？",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算是吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然是個不太想碰到面的人。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個……",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果和我待在一起的話，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n有可能會像初次見面時那樣被麻煩的小混混糾纏……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n學長不反感嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣啊……",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "問我謝什麼？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為你聽我說了",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不少煩惱呀。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不能因為自己人的恩恩怨怨害春咲受牽連，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n能聽我說這些事的人，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也就只有學長了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "氣氛突然有些沉悶。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難得的慶祝活動，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一定要大玩特玩才行呀。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是這麼一回事，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今後也請多多關照囉，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長♪",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們來找有雙人模式的遊戲吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿嘿，",
        "unit_id": 106531,
        "voice": "vo_adv_9006011_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可是會一直前進的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
