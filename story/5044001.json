        "voice": "vo_adv_5044001_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們有決定住宿的地點了嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n事先聲明，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我可不接受因為找不到空房，最後必須露宿野外喔！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼哼哼～",
