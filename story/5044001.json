        "name": "旁白",
        "words": "數日後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與流夏、杏奈和七七香動身前往這趟度假的目的地──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "順利抵達～！",
