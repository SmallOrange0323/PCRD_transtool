        "voice": "vo_adv_5044001_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n哎呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "路途比想像中",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還要遙遠呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 105611,
        "voice": "vo_adv_5044001_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為來這裡的路很不好認啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難怪會被說是",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "隱密的私房景點呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "話說回來，",
