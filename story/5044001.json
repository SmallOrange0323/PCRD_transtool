        "name": "七七香",
        "words": "我們就馬上來……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看招，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚哇！？",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " 妳、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳做什麼～！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀哈哈、",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯哼哼，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快來",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抓我啊～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看她們玩得那麼開心，",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想必是真的很想來度假吧。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "天曉得她們到底有多期待呢……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……好，",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們表現出享受度假的樣子了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣一來，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "關於「祈願竹」的事應該不會被發現！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "畢竟製造驚喜感很重要嘛。",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們是不是",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "差不多該去蒐集情報了？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是啊──",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡好像會舉辦和七夕有關的祭典，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我們只要問了關於祭典的事，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "自然也能得到「祈願竹」的情報……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "了吧！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_034"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們現在就若無其事地",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "提議休息……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔唔～！",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " 這樣玩一玩，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我突然覺得口乾舌燥耶！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這附近，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有沒有什麼，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "適合休息的地方啊！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊～！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 那裡好像，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有一間能讓人好好放鬆的店喔！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐也，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和我們一起，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去那裡休息一下嘛～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要休息是無所謂啦……",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過妳們兩個",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是怎麼啦？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "來，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_038"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這是妳點的飲料。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "請慢用～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大叔，",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能佔用你一點時間嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n聽說這村子",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會在七夕時舉辦祭典，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是真的嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "喔，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_040"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "在這個村子裡",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "有著祭拜織女大人與牛郎大人的神殿。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "每一年，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "村子裡都會舉辦慶祝七夕的祭典。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "傳說中織女大人、",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_041"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "牛郎大人",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "以及銀河中的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "眾多星辰精魄，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "都會齊聚於此，實現人們的心願喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦哦，",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真是個充滿奇幻色彩的由來呢。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "根據傳說，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_043"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "曾經甚至人能夠從村子前往銀河，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "與眾星辰對話呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "到了現在",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這也只是個童話故事罷了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有夢想是件好事啊。",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_044"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "竟然能夠參與淵源已久的祭典，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們真是來對時機了呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "只不過，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_045"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "今年是否能如期舉辦還不太好說……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "什麼！？",
        "unit_id": 1,
        "voice": "vo_adv_5044001_046"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是為什麼！",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_047"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " 莫非",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是「機關」從中作梗！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "機關……？ ",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_048"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是因為今年織女大人和牛郎大人感情不睦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n兩位的化身都已經降臨於神殿，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "卻似乎出現了點問題。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_049"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 所謂的化身",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是指？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "畢竟兩位星宿，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_050"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "實際上身處銀河啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n所以在七夕的前一週，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "祂們會將類似於自己分身的化身派來人間。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔。",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_051"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "降臨這片土地的兩人，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感情不睦是嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明是這麼難得的祭典，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是可惜了啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大叔大叔！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_052"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 我還有一個問題……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請問",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「祈願竹」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "和那個七夕祭典",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有關係嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哎呀，",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_053"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "妳們竟然還知道「祈願竹」的事。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n有喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "七夕祭典開幕後，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "「祈願竹」就會出現。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n它會從裝飾著短冊的細竹，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "變為閃閃發光的祈願竹。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "順便一問，",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_054"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有從祭典之外的管道",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "獲得「祈願竹」的方法嗎……？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我想大概是沒有吧。",
        "unit_id": 1411,
        "voice": "vo_adv_5044001_055"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n「祈願竹」",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "只會在那個時候出現。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "怎、",
        "unit_id": 1,
        "voice": "vo_adv_5044001_056"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "怎麼會……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "該怎麼辦，七七香。",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_057"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這樣的話，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們不就得不到「祈願竹」了嗎！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好的我沒轍了～！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_058"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣說然後就此放棄，這種事我辦不到啊。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n況且我是真的很想為釣竿的事向流夏姐陪罪！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_059"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你有沒有什麼",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好辦法？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對耶！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_060"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣下去沒辦法獲得「祈願竹」的話，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就反過來思考。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我們來幫",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "織女和牛郎解決問題",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不就行了嗎！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔姆……",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_061"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有道理呢。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要怎麼和流夏說？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們突然熱心助人，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "她不會覺得很奇怪嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "超奇怪呀～",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_062"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n畢竟我們公會",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可都是些糟糕到出名的問題人物嘛～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你們幾個，",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_063"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "從剛剛開始就在",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說什麼悄悄話？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_064"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 沒、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒有啦，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒什麼是也～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 對吧？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就、",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_065"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是啊！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " 妳想太多了，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈哈哈！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "算了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話說回來，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我有事",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想問你們。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦哦？",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_067"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 是什麼事呢？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "今天",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_068"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是聽說七夕祭",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可能會中止嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們要不要",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來想想辦法？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得的祭典要是就這樣中止了，",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_069"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你們不覺得有點可憐嗎。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能碰上這種事也算是某種緣分，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以我想幫幫他們。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也願意來幫忙嗎？",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_070"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 謝謝。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "至於妳們兩個，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是想好好度假的話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是不會強迫──",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真巧呢～流夏姐！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_071"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們剛剛也在想著要為七夕祭做點什麼喔！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦，",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_072"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "祭典也是度假行程的一部分。",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_073"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要是沒享受到祭典，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們不就白來了。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯沒錯！",
        "unit_id": 113311,
        "voice": "vo_adv_5044001_074"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": " 我們剛剛也是在討論",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想參加祭典的事啦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不必擔心喔，",
        "unit_id": 113211,
        "voice": "vo_adv_5044001_075"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "流夏。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有了我們的協助，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個問題",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "肯定馬上就解決了！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總覺得，",
        "unit_id": 113111,
        "voice": "vo_adv_5044001_076"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "被妳這麼一說",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我反而不安起來了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是錯覺吧……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到了明天，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們再去打聽看看牛郎織女的事。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管原因各異，眾人的目的卻只有一個，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那就是，解決織女與牛郎之間的問題。"
    }
]