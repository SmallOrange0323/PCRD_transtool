        "voice": "vo_adv_5044001_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在想對策之前，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
