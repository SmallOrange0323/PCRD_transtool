        "voice": "vo_adv_5044001_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不必擔心！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n七七香已經預約好房間了",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒事沒事☆",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……雖然，",
        "unit_id": 101311,
        "voice": "vo_adv_5044001_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當時被其他通訊魔法強行截斷，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓人有一點點不安。",
