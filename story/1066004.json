        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我會用龍人的力量幫助你的！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哇～",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈哈哈哈！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後，",
        "unit_id": 106631,
        "voice": "vo_adv_1066004_052"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是哪裡啊？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要怎麼從這裡去車站……？",
        "unit_id": 106631
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你剛剛看見的一切就和夢境差不多喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得和那邊的祈梨不太一樣……",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過看來是這邊的祈梨比較接近本人的個性呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這之後，",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生了很多事，祈梨和你變得親近起來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們甚至會一起在阿斯特朗裡展開冒險呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許對兩邊的她來說，你都是能讓她",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "放心展現自我的特別存在吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要特別注意龍人族，",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然話是這麼說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那孩子，該怎麼說……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻是在其他意義上更需要特別注意呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要看好她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在可是最容易被趁虛而入的時期，",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "誰都不知道會發生什麼事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這方面要是我這邊也能干涉的話就好了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這只是我自說自話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不需要在意喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正，",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等這場夢境結束後你就會幾乎都忘掉了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟一直以來都是這樣嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，祈梨",
        "unit_id": 190011,
        "voice": "vo_adv_1066004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就交給你好好關照囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒問題吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你自己也要加油喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次再見啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼哇！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_060"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n剛才那個，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底是怎麼回事啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看起來好像沒事呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "太好了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該不會，",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_062"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才那一切都是老大搞的鬼吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不對，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再怎麼說也太……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了，",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_063"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥現在是不是也夢到奇怪的夢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_064"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是延續之前的話題",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥他",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "相信我……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "無論是夢境還是現實，",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_065"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥都沒有任何改變呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸嘿嘿……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小、",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_066"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥本來就應該",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要相信我的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟我可是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要成為幫派大人物的龍人族！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥可別太得意忘形了喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_067"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我果然",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是再去跟老大和嘉夜夜道一次歉好了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不然，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我都沒辦法",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "正視小哥了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是因為這個原因呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了成為大人物，",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_068"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我必須去把事情講清楚。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就只是這樣！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算不陪著我去也沒關係喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_069"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是小哥無論如何都想要陪我去的話也是可以啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸嘿嘿，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們就一起回公會小屋吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥再不走快一點的話",
        "unit_id": 106611,
        "voice": "vo_adv_1066004_070"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就要被我丟下囉～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的巷弄裡，不同於往常的輕快腳步聲、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與祈梨開朗的說話聲響徹其中。"
    }
]