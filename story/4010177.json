    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你剛剛……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說了什麼……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "生日……",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "派對……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那種東西，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我只在傳聞中聽過……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "生日派對",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是要在生日的時候舉辦對吧。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n今天是平凡無奇又普通的一天……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n究竟是",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要幫誰慶祝呢……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗎……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天是……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的生日……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為邊緣人就是會忘掉這些紀念日的生物，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以我完全沒發現……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說，",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是要舉辦",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的生日派對……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是認真的嗎，",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n生日派對……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我和你",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一起……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道了……",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就舉辦……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "生日派對吧。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在我們的邊緣人歷史上踏出值得紀念的一步吧。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "兩個人一起",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "過生日……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嘿嘿。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "首、",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "首先要做什麼才好呢……？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對、",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要準備禮物才行。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n紀念生日派對的禮物……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長。",
        "unit_id": 104033,
        "voice": "vo_adv_4010177_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們一起",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "創造最棒的生日吧……♪",
        "unit_id": 104033
    }
]