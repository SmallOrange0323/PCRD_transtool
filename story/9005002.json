[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲提出想要負責製作紀念日禮物的想法。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她興高采烈地來到街上，並馬上開始思考。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼……",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "該送什麼禮物才好？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然說要自己一個人準備，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但我其實還沒有決定好要送什麼。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他喜歡的東西……",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "食物的話我倒是略知一二，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但還是送可以長久留存的東西比較好吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣的話……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……雪菲？",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n怎麼了嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我看妳好像有什麼煩惱……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "優衣小姐……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怜小姐跟日和小姐也在……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳們好。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真難得啊，",
        "unit_id": 100311,
        "voice": "vo_adv_9005002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳一個人在散步嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n走路時不好好看著前方",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是會撞到人的喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就跟日和一樣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好過分喔，怜──！",
        "unit_id": 100111,
        "voice": "vo_adv_9005002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才沒有那麼常撞到人──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請教各位一個問題，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要送禮物給他……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n【破曉之星】的各位",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會送什麼呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "送、",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "送禮物給騎士先生……！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個嘛……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳會送什麼啊，怜？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可能會送新披風",
        "unit_id": 100311,
        "voice": "vo_adv_9005002_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或是衣飾之類的吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又或者是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可供消遣的實用品",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之類的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比方說釣竿。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得有誠意的用品",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會讓人愛不釋手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～",
        "unit_id": 100111,
        "voice": "vo_adv_9005002_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的話",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會送什麼呢～？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我想騎士先生",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "肯定收到任何禮物都會很開心，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我會送個可以跟他同樂的東西！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來如此，",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很有參考價值。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "優衣呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的話……",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會選擇能夠傳達",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "自身心意的東西。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_9005002_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "每當看到這個禮物時，",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都能夠露出笑容。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還會想起我來，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就算是一下子也好。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……唔、",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我在胡說八道些什麼啊……！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，雪菲！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這種意見完全沒有參考價值吧！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當我沒說～！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這意見很棒……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "深深打動了我。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n謝謝妳們，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "優衣小姐、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怜小姐、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "日和小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她們三位……",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎都對他很用心。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以才會如此認真思考，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "並提供意見。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那我……",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也再加把勁，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "試著找出屬於我自己的答案吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呵呵。",
        "unit_id": 100213,
        "voice": "vo_adv_9005002_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳的表情豁然開朗了呢，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雪菲。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用在意我們的意見，",
        "unit_id": 100311,
        "voice": "vo_adv_9005002_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳就繼續思考",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳想要的方向吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雪菲，",
        "unit_id": 100111,
        "voice": "vo_adv_9005002_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "加油喔～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 106412,
        "voice": "vo_adv_9005002_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很謝謝妳們。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n下次見……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "向【破曉之星】道謝後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲繼續踏上她的旅程。"
    }
]