        "voice": "vo_adv_6029304_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　沒想到還有這招……！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這真是個驚人的想法……",
