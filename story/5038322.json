[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗～……",
        "unit_id": 110811,
        "voice": "vo_adv_5038322_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n總之那些盜版藝人都退場",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "了～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切嚕切嚕切嚕切嚕切嚕切嚕切嚕切嚕～！",
        "unit_id": 13211,
        "voice": "vo_adv_5038322_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？　",
        "unit_id": 110811,
        "voice": "vo_adv_5038322_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼，怎麼了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n臭遜廢鐵丸，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好像突然慌張了起來耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "似乎是好朋友X的動力核",
        "unit_id": 104611,
        "voice": "vo_adv_5038322_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "引起了熱失控喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在的好朋友X，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "正在發揮超越極限的力量喵……！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "糟了喵！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "捲起尾巴快逃才是上策喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "熱失控引起了極限運作……",
        "unit_id": 111011,
        "voice": "vo_adv_5038322_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它解除了限制器是吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是個困難的局面啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不知為何，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我無法解釋地湧現了一股興奮感。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是越來越熱血了呢！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……優妮學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5038322_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n有時候興奮的點真的很像男孩子耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～",
        "unit_id": 110811,
        "voice": "vo_adv_5038322_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我家的弟弟們也喜歡這個呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n失控跟",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "限制器之類的用語。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_5038322_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼辦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所謂的失控，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "簡單的說就是比要命更要命吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n要逃跑了嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只留下興奮的優妮學姐。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這可不行！",
        "unit_id": 103211,
        "voice": "vo_adv_5038322_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n身為創造出好朋友X的開發者，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們必須負責到最後！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我說的沒錯吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "悄～悄地，",
        "unit_id": 104611,
        "voice": "vo_adv_5038322_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "躡手喵、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "躡腳喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n沒、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要戰到最後喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那才是負責的表現喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "——嘴裡這麼說還擺出認真的表情，",
        "unit_id": 110811,
        "voice": "vo_adv_5038322_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但珠希的脖子以下還維持著躡手躡腳的姿勢耶？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那可是能用以責任推諉的罪名，現行犯逮捕的案件喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依，妳等一下。",
        "unit_id": 111011,
        "voice": "vo_adv_5038322_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敵方的攻擊接下來會越發激烈。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這個困境之下，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們應該心連心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用炙熱的羈絆突破難關！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳說是不是啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕地、",
        "unit_id": 110911,
        "voice": "vo_adv_5038322_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "躡手切嚕、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "躡腳切嚕……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是這樣！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家齊心戰鬥一定會贏喵！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這裡才沒有半個",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種只顧著自己逃跑的膽小鬼喵！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯喵！　",
        "unit_id": 111011,
        "voice": "vo_adv_5038322_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯喵！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好，我要上了，",
        "unit_id": 103211,
        "voice": "vo_adv_5038322_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好朋友X！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就讓你看看上下一心的我們",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "力量有多強大！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_5038322_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在這樣，算是有上下一心嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來是這樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "知道了啦～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼，就是那麼一回事～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮",
        "words": "沒錯喵！　",
        "unit_id": 1,
        "voice": "vo_adv_5038322_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮",
        "words": "沒錯喵！",
        "unit_id": 1
    }
]