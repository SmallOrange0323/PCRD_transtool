[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲帶著{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在策劃接下來要玩什麼樣的遊戲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，她身旁卻出現王宮騎士的身影──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接下來要做什麼好呢……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "求求您了，前副團長！",
        "unit_id": 711,
        "voice": "vo_adv_1238004_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n別再惡作劇了……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂喂。",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你這個不實指控也太離譜了吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我確實是用",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這副鎧甲隱藏身分",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來當作消遣。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也或許得到了一些",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "民眾的協助。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也沒有勞煩到你們吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，你說是吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "可是……！",
        "unit_id": 711,
        "voice": "vo_adv_1238004_005"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n團長",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "下達了嚴令，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "要我們阻止您繼續失控下去──",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊～哈哈☆",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n派你這樣的普通士兵，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來阻止我嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不愧是團長，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "笑話也很有品位呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……對了，",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想到了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下次穿上這個",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "參與國政怎麼樣？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "您、",
        "unit_id": 711,
        "voice": "vo_adv_1238004_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "您又在開玩笑了──",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我看起來像是在開玩笑嗎？",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "決",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "定了，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下次我要競選議員。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以這身打扮，",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還擁有兔子族或胡蘿蘿☆粉絲的組織票。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果參加競選，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即便不是貴族，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也能獲得一個席位。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次我要從內部攪亂國政！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不不不，",
        "unit_id": 711,
        "voice": "vo_adv_1238004_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "拜託您了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n別再繼續下去了──",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看起來那邊更耀眼呢。",
        "unit_id": 123811,
        "voice": "vo_adv_1238004_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "支持者們已經來迎接我了嗎……？",
        "unit_id": 123811
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂──",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不是說過，關於新商品的所有問題，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都要經過我逐一做出判斷嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n把漏報的事情通通都找出來",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再重新提交。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下一個。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又有公司內部謀反？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還真是惹人厭呀。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他們是在自取滅亡，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別管了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……讓你久等了。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你那邊是早上嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "早啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我有關於併購的事情要跟你商量，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天下午給我一些時間。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個是……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──喂，小子！",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們又見面了呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你問這個嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是在開線上會議。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天難得比較有空。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n多方通話只有五件而已。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "等我10秒，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會通通結束。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，讓你久等了。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……怎麼了？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你怎麼目瞪口呆的？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我果然很厲害？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不愧是跨足全球的天才企業家？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂喂，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在不至於那麼驚訝了吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們可是在聖誕節同床共枕的關係呀♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了，小子。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你接下來有什麼事嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……喔，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在散步呀。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那正好。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我現在正要去看看有趣的東西。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們一起去吧，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不耽誤你多少時間的。",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──啊，這邊。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡可是看得最清楚的",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "特等席哦♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在緊張什麼。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與妙齡美女肩並肩，把身體靠在河岸的欄杆上，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對你來說",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就那麼刺激嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要我說是有趣的東西，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺就會發生不得了的大事，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以你在戒備著？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來如此。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你就等著瞧吧。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該可以看到一些不會讓你失望的東西♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n…………",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真有趣。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太有意思了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒那回事。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你仔細看看",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "面前的河流。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──你看，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才剛說完就漂過來了♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個是……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從顏色上看，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是落葉吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是櫻花",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是輕飄飄的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺好舒服啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那是什麼呀？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n假人模特兒的……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "手臂嗎……？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼會只有手臂漂過來啊？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "弄丟的人肯定很傷腦筋吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "它被石頭卡住了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "它好像要在那裡多撐一下子呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看樣子他還",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有放棄回歸本體呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……怎麼樣？",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n很有趣吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呵呵，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你都楞住了呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，沒錯。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說的有趣的事，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就是在這裡像這樣",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "眺望河流",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呀♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──哦，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次是烏龜。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "牠在拚命逆流而上呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "牠緊緊抓住假人模特兒的手臂……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一腳踢進水裡了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那隻手臂",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太可惜了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你覺得對克莉絲提娜來說，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個遊戲太平淡了？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來你",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也覺得，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是個相當不受控的人啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的生活方式就是這樣的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該沒辦法斬釘截鐵地說不是吧……",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "123800401"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不過呀，小子。",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜我，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也不是只是喜歡那些",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "莫名其妙的東西哦？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我只是喜歡",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最真實的東西。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在世界的洪流中，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有安穩的地方。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但即便如此，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對他人充滿期待",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不保證能得到回報。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抱有期待才是自私的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "存在的",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就只有世界和自己。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果不展現出自己該有的樣子，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就會立刻被沖走。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就像河流一樣。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n人和事物不依賴他人，不揣測他人，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n呈現出自己最真實的模樣，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再也沒有比這更有趣的了♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "併購、",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "激烈的企業鬥爭，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有時候是永續性的融合……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果這是我們每個人當下真實想要的，",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼一切都會很有趣。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我",
        "unit_id": 107131,
        "voice": "vo_adv_1238004_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會在一旁煽動、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順勢",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "參戰。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
