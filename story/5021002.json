[
    {
        "type": "background",
        "background": "500710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在海水浴場發現玩偶們莫名消失後，\n【哞哞自衛隊】的成員們便開始在海邊尋找著。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我從海邊頭一路跑到尾端了，",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n四處都沒看到玩偶們的蹤影～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該不會是遭小偷對吧。",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們的行李都還在，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "何況",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要偷走那麼多隻玩偶太引人注目了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說是玩偶們自己擅自",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跑到其他地方，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還比較",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有可能呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "自己擅自……",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是不是",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經討厭人家了。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴！",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉公主！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　我不是那個意思！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳那麼珍惜那些玩偶們，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n它們根本不可能會討厭妳的啦！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不要緊。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果是自己跑出去的話，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那它們也一定會自己回來的。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "先別說那個，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們先吃午餐吧。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天可是難得的假期，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "應該要悠悠哉哉地度過呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步……",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主……",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生……",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對了、",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我剛剛在游泳的時候發現附近有個漁村～！",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也許我們能在那裡找到線索也說不定～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果霞在場的話，",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "肯定會說",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要先去打聽情報的吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴、",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那樣沒關係嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝。",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別放在心上。",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然決定要找了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們還是先填飽肚子吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n三明治能直接拿來吃很方便呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之先吃點食物墊墊肚子吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說起來肚子真餓扁了～！",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "吃飽了",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "再開始展開調查吧～♪",
        "unit_id": 110511
    },
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種地方竟然有漁村。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這裡似乎很吵雜呢～？",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是不是在舉辦祭典呀～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跳舞就交給我吧～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就祭典而言，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這些聲音又有點太刺耳了。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有種不祥的預感……",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "去問那個男的吧！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n吶、",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "能否打擾你一下？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "呀！？",
        "unit_id": 311,
        "voice": "vo_adv_5021002_021"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "什、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "什麼啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "是人啊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "你不要嚇我。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幹嘛突然怕成這樣啊。",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我有這麼恐怖嗎？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴一點都不恐怖唷～",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "打起精神來～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "突然向您搭話，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真抱歉呢，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個村子好像很吵雜，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發生什麼事了嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "――出現了。",
        "unit_id": 311,
        "voice": "vo_adv_5021002_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊！",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　你說什麼？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "奄美魔物出現了！",
        "unit_id": 311,
        "voice": "vo_adv_5021002_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "奄美魔物？",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "　沒聽過的名字呢？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是某種動物嗎？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……不是～",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "知道～",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒想到會在這種地方",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "聽到故鄉的詞彙呀～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來是香織故鄉的詞彙呀。",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "確實",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "用字挺奇怪的呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主也差不多吧。",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個奄美魔物",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是什麼意思？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "奄美魔物",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_033"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我的家鄉――",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "――就是惡靈、",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妖怪的意思～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "哦。",
        "unit_id": 311,
        "voice": "vo_adv_5021002_035"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "有人知道這個詞真令我意外。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這個漁村以前",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "是由一群移居到這裡的人們所建造的，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n他們曾是位於這片海洋遙遠另一邊的某國國民。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "奄美魔物",
        "unit_id": 311,
        "voice": "vo_adv_5021002_036"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "好像就是那個國家傳過來的詞彙……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那一定就是我的家鄉了～！",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_037"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "居然能聽到家鄉的故事，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得好高興呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一點都不值得高興吧！？",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n惡惡惡惡靈和妖怪！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這就表示……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "沒錯。",
        "unit_id": 311,
        "voice": "vo_adv_5021002_039"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n剛才",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "奄美魔物一出現，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "就有不少村民遭殃了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "遭殃了是什麼意思，",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底是怎麼一回事！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "據說奄美魔物",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會奪取靈魂～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "傳聞眾說紛紜，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "「穿過跨下，奪取靈魂」",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是其中一個著名的妖怪傳說～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "將、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "將靈魂……？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "雖然那並不是在奪取性命，",
        "unit_id": 311,
        "voice": "vo_adv_5021002_043"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "但受到奄美魔物襲擊的人",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "會失去氣力",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "無法動彈。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "實際上，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "那些被襲擊的人們",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "現在都臥病在床。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那樣的確",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很像是",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被奪走靈魂呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴，妳怎麼啦～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　走路姿勢變內八了唷～？",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像平時那樣邁開大步走路呀～♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳說什麼啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　我一直以來都是這樣走路啊！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好歹我也是女孩子好嗎！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "蛤、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "蛤！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　才沒有這種事好嗎！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我怎麼可能因為那種傳言就感到害怕啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你那什麼意思啦。",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n講的好像是我平常",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一點都不可愛啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃嗯、",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也不是想要你說我可愛還怎樣啦……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之，",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我沒在害怕啦！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　你在幹嘛，{player}，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼蹲下來了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為什麼往我這過來……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呀！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此，",
        "unit_id": 110511,
        "voice": "vo_adv_5021002_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跨坐在肩膀上就不怕被妖怪穿過跨下了～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}真聰明呀♪",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真好呢，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下一個可以換我嗎……♪",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不不不、",
        "unit_id": 110411,
        "voice": "vo_adv_5021002_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "重點不在這好嗎！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快放我下來！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　用腳夾死你喔！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "還真有活力呢，",
        "unit_id": 311,
        "voice": "vo_adv_5021002_053"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "你們幾個。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "讓我也稍微放鬆起來了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能讓您安心",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是太好了。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我們家公會",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最自豪的就是成員感情融洽唷。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話題不小心扯遠了，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說那個",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "奄美魔物",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "長什麼樣子呢？",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們",
        "unit_id": 110611,
        "voice": "vo_adv_5021002_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在雖然有重要的事情要去處理，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但身為【哞哞自衛隊】，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一旦看到遇上困難的人可不能坐視不管呢。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n你願意告訴咱們詳情嗎。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "好的。",
        "unit_id": 311,
        "voice": "vo_adv_5021002_057"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n我也是剛才偶然間",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "看到那種輕飄飄地飛在空中的模樣，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "那個",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我怎麼看都覺得是――",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "――玩偶的樣子。",
        "unit_id": 311,
        "voice": "vo_adv_5021002_058"
    }
]