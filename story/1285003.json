[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞和{player}兩人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n盡情遊玩新年遊戲直到深夜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隔天早上……"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好冷……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真冷呢……",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……？",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔哇啊啊啊啊啊！？",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我、",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我為什麼會緊緊貼著助手先生睡覺啊～～～！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而、",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且還醒著～！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你這個人",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "到底要看到我多少醜態",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才滿意──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還在睡？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太、",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太好了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這次似乎沒有被看到。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這件事",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就藏在我的心底吧……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咳咳！",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以說助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "已經早上囉。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "快起床吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "早安。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你感覺睡得很飽呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈哈哈，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是太好了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來你記得呀～～～！！",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉……",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n一大早就多災多難的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "抱歉啊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n忍不住就一直嘆氣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為這兩天的關係，我感覺整個人都累壞了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先不說這個了，",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你頭髮亂翹得很誇張喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你順便",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也去洗把臉吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會在這段時間",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "烤好早餐要吃的麵包的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的……",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然助手先生平常就很孩子氣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但早上特別像小孩子呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n本來還以為今年的新年假期會很寂寞……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n結果多虧了助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我過得很開心呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也不討厭一個人獨處。",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在的我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比較想要跟人待在一起……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……沒有錯",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這就是我現在的真心話。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然如此……",
        "unit_id": 101411,
        "voice": "vo_adv_1285003_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n太好了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "亂翹的頭髮都整理好了呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我今天",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想去一個地方呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "穿這個樣子去",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比較適合。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "手先生。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你可以",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再陪我",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一天嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我有個",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "無論如何都想要去的地方。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝！",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就知道你會這麼說。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等我們吃完早餐，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就馬上出發吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在霞的帶領之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了某座山中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那裡有著兩人從未見過的景色……"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇啊……",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "跟傳聞中的一樣。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是不可思議的景色呢，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這座山啊，",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "據說叫做「靈山」。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n它似乎跟蘭德索爾的神殿一樣，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是起源自",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "東國。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽說只要把木板",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "掛在這尊狗的石像上，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n願望就會實現喔。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這地方既神祕又不可思議對吧。",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n自從在書上讀到之後，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就一直",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "覺得很好奇。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "穿過這些鮮紅色的拱門之後，",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就能到達山頂了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那裡就是我想去的地方。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想要在那裡許願。",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之前",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然有去神殿做過新年參拜……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是我",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想要換個願望了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵……",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實呢，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在新年參拜時，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n許下的願望是",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「想度過安穩平靜的一年」。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過……",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我現在發覺到",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "獨自一人的寂寞，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以及與人共處的快樂……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以我的願望是……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……哈哈。",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n把願望說出口似乎不太好呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我就不繼續講下去了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好了，",
        "unit_id": 128511,
        "voice": "vo_adv_1285003_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要朝山頂前進囉！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 128511
    },
    {
        "type": "background",
        "background": "500400"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼……",
        "unit_id": 128511,
