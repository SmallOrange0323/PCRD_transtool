[
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "猫たちと職場をともにしているわけだが……",
        "unit_id": 105312,
        "voice": "vo_adv_6106105_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "困ったことに、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いまだに仲良くなれない猫が何匹かいてな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n貴公には懐いているようだが、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なにかコツがあるのか？",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "というと、",
        "unit_id": 105312,
        "voice": "vo_adv_6106105_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "まかないで出している食事に",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n不満があったということか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "猫とはいえ味の好みはあるものな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nいくつか種類を工面して好き嫌いを探ってみるか。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "押してだめなら引いてみろ、",
        "unit_id": 105312,
        "voice": "vo_adv_6106105_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "と？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なるほど、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それであえて",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n興味を引いてみようという作戦か……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "しかしなんというか貴公は、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n本当に周囲から好かれる術に長けているな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "べ、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "別に他意はないが……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "か、",
        "unit_id": 105312,
        "voice": "vo_adv_6106105_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "神さま……！？　",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それほど格の高い動物だったのか……",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "しかしそう聞くと、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あの気位の高さにも納得がいくな。",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n次からは献上品も持参して、",
        "unit_id": 105312
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "もっと丁重に接してみるとしよう。",
        "unit_id": 105312
    }
]