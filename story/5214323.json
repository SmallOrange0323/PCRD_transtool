[
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就連姊姊",
        "unit_id": 138711,
        "voice": "vo_adv_5214323_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "都開始氣喘吁吁的了……",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "再、",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "再加把勁吧……！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138811,
        "voice": "vo_adv_5214323_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "終於到了千鈞一髮之際，",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正是生死一線。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許接下來才是真正的背水一戰。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為了不淪落到一蹶不振的地步，",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我們拿出九死一生的爆發力吧。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……好、",
        "unit_id": 138711,
        "voice": "vo_adv_5214323_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好厲害的詞彙量……",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n讀很多書的人果然不一樣呢。",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "換成是我只講得出",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "什麼頭髮一根或酒一升來。",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 138811,
        "voice": "vo_adv_5214323_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是溫和的若菜小姐呢。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在作為臀士、",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "作為桃鬥者──！",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "作為有著超厲害姊姊的",
        "unit_id": 138711,
        "voice": "vo_adv_5214323_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妹妹！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜、栞",
        "words": "最終決戰！！",
        "unit_id": 138811,
        "voice": "vo_adv_5214323_005"
    },
    {
        "type": "dialogue",
        "name": "若菜、栞",
        "words": "\n預備──────！",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "若菜、栞",
        "words": "\n開始────────！！",
        "unit_id": 138811
    }
]