        "unit_id": 101011,
        "voice": "vo_adv_5118062_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]別那麼慌張啦～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n人家只是開個小玩笑♪",
