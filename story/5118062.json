    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]吉塔等人今天也來到跳蚤市場。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n然後，突然有人從某個攤位上叫了{player}的名字。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]王子先生～",
        "unit_id": 101011,
        "voice": "vo_adv_5118062_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n這邊這邊～",
