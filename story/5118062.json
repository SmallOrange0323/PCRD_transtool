    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]可、",
        "unit_id": 105712,
        "voice": "vo_adv_5118062_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]可愛……？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]王子先生很受歡迎",
        "unit_id": 101011,
        "voice": "vo_adv_5118062_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]是很令人驕傲……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]但是丟下人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]跑去約會……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]王子先生真是壞心眼呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]約……！？",
        "unit_id": 105712,
        "voice": "vo_adv_5118062_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
