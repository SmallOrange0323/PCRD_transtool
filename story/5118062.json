        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]是的，",
        "unit_id": 101011,
        "voice": "vo_adv_5118062_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]他是真步真步王國的王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]王子先生也來了啊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n而且……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]還是跟這～麼可愛的女孩子一起。",
