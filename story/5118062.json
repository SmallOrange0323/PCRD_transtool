        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]不、",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]不是那樣的！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n我們只是同個騎空團的夥伴，",
