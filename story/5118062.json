    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]在那之後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n吉塔和真步重新自我介紹。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n在互相了解對方後，吉塔詢問關於真步攤位的事。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]話說，",
        "unit_id": 105712,
        "voice": "vo_adv_5118062_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]真步的攤位都在賣些什麼呢？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]是賣玩偶和衣服喔～♪",
        "unit_id": 101011,
        "voice": "vo_adv_5118062_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n人家想說可以貼補【哞哞自衛隊】的預算。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]這全都是人家手工製的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]外面可～是買不到的唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]全是妳手工製的？",
        "unit_id": 105712,
        "voice": "vo_adv_5118062_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]好厲害，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]妳的手真靈巧！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]謝謝誇獎～♪",
        "unit_id": 101011,
        "voice": "vo_adv_5118062_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]有看上什麼",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "[FFFFFFFF]就別客氣盡量說，",
