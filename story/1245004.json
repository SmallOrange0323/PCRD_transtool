    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我已經決定好",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
