[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "帆稀與{player}結束了新年參拜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人之後在新年的鬧區中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n漫無目的到處閒晃。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是理所當然的，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但果然因為是新年，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大部分的店家都關店了呢～",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也多虧如此，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "路上才沒什麼行人……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以相當悠閒地度過呢♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟新年一年只有一次呀，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我們悠閒地度過吧☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你在擔心我啊？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的確很忙。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "目前正在構思各種計畫……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也希望讓嘉夜和祈梨繼續成長。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有漫畫必須要畫……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我有很多",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想去做，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以及必須做的事。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為定下了某個約定……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我已經決定了",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至少在新年",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要好好放鬆。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個呀……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是祕密☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n隨你想像囉♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……咦？",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你那道光……",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是愛梅斯做的對吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大新年的，",
        "unit_id": 124511,
        "voice": "vo_adv_1245004_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她就想讓我們做什麼夢呢？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n某種程度上，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是已經能猜想到了。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先暫時晚安。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們在夢裡再會吧……♪",
        "unit_id": 124511
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年的椿丘。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}在去新年參拜前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在路上散步順道隨便逛逛商店街時……"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……咦？",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真奇怪～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n每家店都關起來了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "人家難得出來買食材的說……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "才想說有個人在，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來是你啊。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n沒想到會在這種地方見面，真巧呢☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "新年快樂……？",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n……該不會",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天是新年？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難怪每家店都關了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我的時間感徹底失常了呢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……我本來想去參加",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除夕舉辦的同人誌販售會呢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真沒辦法，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只能透過網路來買了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我這一週左右",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一直在進行駭客。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n主要是",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了調查與阿斯特朗相關的情報♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我首先",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "試著調查了一位",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也有參與開發mimi，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "名叫宵濱的人。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "公主騎士的mimi，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是七冠準備的",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "特別東西……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因此我認為",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要對其專用mimi有所了解，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或許能成為",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有效對抗七冠的線索。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖這麼說，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但如果直接調查七冠中的某人，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "怎麼想應該都會很花時間……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n因此，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我才先著手調查了",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "宵濱身邊的事情……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但我似乎猜錯了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至少我目前",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒有找到任何",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n宵濱",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "與公主騎士專用mimi有關的線索。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也認為她要跟那種東西扯上關係的可能性很低，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以心裡也只有",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「果然是這樣」的想法呢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在進行各種調查時，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我反而對她本人產生興趣了♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n希望有機會",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能和她在阿斯特朗中一起玩☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有……",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我姑且問一下，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你在用的mimi，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能暫時",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "借我一段時間嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n如果可以借我一個月左右，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在各方面",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都會有進展呢☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真可惜♪",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這也是當然的呢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "公主騎士這種",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n能夠對抗七冠的手段，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是片刻",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都不可能交出去的呀。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106731,
        "voice": "vo_adv_1245004_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先不談這些……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這一週",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我還潛入了公安的伺服器，",
        "unit_id": 106731
    },
