    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天能夠悠閒地度過。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如同你自己說過的，",
        "unit_id": 190011,
        "voice": "vo_adv_1245004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n日常也很重要。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你今年大概也會很忙碌吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但可別忘了這一點喔。",
        "unit_id": 190011
    },
