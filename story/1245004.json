        "voice": "vo_adv_1245004_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "明明沒人拜託，卻讓人作新年初夢，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不會有點太不解風情了嗎，",
