[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "完成工作後在街上漫步的{player}，\n偶然碰到了修特帕魯。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵……吉格魯特，",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "找到你了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我想說來這裡的話，應該就能遇見你。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為我和你在前世有深厚的關係。",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你的想法，我輕而易舉地就能知道。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "新的「組織」已經被發現開始行動了，",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n今天是為了應對與他們的戰鬥，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你也要準備一下――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚，",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這道光是……！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n「組織」的攻擊",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來得那麼快嗎！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "保持住清醒啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "光線太強烈了……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚哇哇哇！？",
        "unit_id": 100911
    },
    {
        "type": "still",
        "still": "100900801"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵……我知道的。",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_005"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n這座城叫，龍岩堡！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "哇！",
        "unit_id": 131,
        "voice": "vo_adv_1009008_006"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "好帥氣喔！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵呵，對吧？",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_007"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這座城堡的頂樓，囚禁著一位美麗的公主。",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_008"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n雖然想救出公主，但有一條龍在看守著這座城！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "而接近這座城的人，都會成為那條龍的食物……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "嗚嗚，好可怕喔……",
        "unit_id": 231,
        "voice": "vo_adv_1009008_009"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不要害怕。只要交給我，一下子就可以殺死那條龍了。",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_010"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我一定會救出公主的！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "哇！",
        "unit_id": 131,
        "voice": "vo_adv_1009008_011"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "好厲害，好厲害──！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "因為這些小孩，",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_012"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n是發自內心覺得我說話很有趣，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n所以我不自覺地也很開心。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……吉格魯特！？想不到是你……！",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_013"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "為、為、為什麼你會在這裡！？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不、不是！不是這樣的！",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_014"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我是疾風之冥姬，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n怎麼會和小孩們開心地玩在一起呢？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "他們是住在這附近的小孩……",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_015"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "所以就幫忙照顧一下……？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "杏奈姊姊。這個人是誰？",
        "unit_id": 231,
        "voice": "vo_adv_1009008_016"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "他是姊姊的朋友嗎？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊、喔喔……吉格魯特……",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_017"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "該怎麼解釋才好呢……？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "吉格魯特，是這個……在前世和我一起戰鬥……",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_018"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "至死之前都經常和我在一起的盟友。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "一直在一起？",
        "unit_id": 131,
        "voice": "vo_adv_1009008_019"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "哇！他是姊姊的丈夫吧！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不、不是！",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_020"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那個、是前世的事啦！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……確實，我們在前世的時候關係親密。",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_021"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n最後我和吉格魯特成為了伴侶――也就是夫妻！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "但這只不過是前世發生的事而已……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "姊姊已經結婚了──！？",
        "unit_id": 231,
        "voice": "vo_adv_1009008_022"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "如果是夫妻的話就親嘴看看──！",
        "unit_id": 131,
        "voice": "vo_adv_1009008_023"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我也想看你們親嘴──！",
        "unit_id": 231,
        "voice": "vo_adv_1009008_024"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n親嘴、親嘴──！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你、你們在說什麼！？",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_025"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n我不是說過那是前世的事嗎！？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n這一世的我們不是那種關係……！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯、嗯……所以，是不同的……",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_026"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n那個親嘴什麼的……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗚、嗚哇哇哇哇哇！！",
        "unit_id": 100931,
        "voice": "vo_adv_1009008_027"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "杏奈她，比想像中純情呢──",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然角色設定上經常會說出很勁爆的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但實際上好像還是會對那樣的對話感到困擾。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，但就是這一點令人覺得可愛呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這樣說，但對於那種狀況她好像不太開心啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，像你這樣不會過於相信角色設定，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但又沒有完全否認的方式就恰到好處。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是前世的盟友嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真是有趣的設定……該不會她知道了什麼吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論如何，你們是一個不錯的組合呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今後也要在杏奈身邊，",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n全力地支持她喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "閃光的吉格魯特先生。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，這次就先聊到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1009008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰～掰，再見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……這裡、",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是哪裡……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我剛才、在做夢吧……！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉、吉格魯特！",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道，你也作了那個夢！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不、不是！",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那是另一個世界的我們……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我們親、親嘴什麼的……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "而、而且……",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_038"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們是伴侶這點也是前世的事！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不要會錯意呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這一世，我對你才……",
        "unit_id": 100911,
        "voice": "vo_adv_1009008_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對你、你……！",
        "unit_id": 100911
    },
    {
