    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "若菜也一如既往地投入屁股相撲的特訓。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在美冬和{player}的注視下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她正和栞進行實戰形式的練習，但是──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是現在！",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看招！",
        "unit_id": 138812
    },
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呀",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "！？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "剛、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "剛才那一下讓泳裝歪掉，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "陷在肉裡了……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "騎、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "騎士先生會看到的啦～！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有機可乘！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還不行呢，",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "若菜。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n現在的妳，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "應該能冷靜地把泳裝調整好才對。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "無論什麼狀況都必須保持冷靜，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "否則屁股之神是不會眷顧妳的！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是、",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_005"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是的……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n鼻、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "鼻子進水了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "哈啾！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳沒事吧，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請抓住我的手。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "栞小姐……",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "比以前強多了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n不只是屁股，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "連心態好像也更加成熟了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "然而，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "卻還遠遠不及……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "若菜是那種對於「被看見」",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "會感到特別羞恥的類型呢。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳需要的是",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「看好了！」",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這種強烈的決心",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "和心態。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不只是屁股相撲，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "任何事都是如此！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚嗚……",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這莫名的說服力……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一直以來，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我的確都在對周圍的人",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "說「對不起」，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n所以我總是想著",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如何不引人注目……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐性情溫柔，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因此對任何事都很拘謹克制呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我認為",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是非常棒的優點……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯……",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我決定了！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "今天的練習就到此為止！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n作為代替，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "明天舉辦一場表演賽吧！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "讓若菜",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "和社會人士的屁股相撲橫綱進行比賽！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "社會人士的屁股相撲……",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_012"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "居然有這種比賽啊。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……等等，橫綱！？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n明明是表演賽，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "卻是面對這種強敵！？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳在說什麼啊。",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳和栞的實力已經是世界級的了。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n橫綱不過是小菜一碟！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n如果贏不了，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那就是心理層面的問題！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "仔細想想",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我剛才說的話。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n什麼樣的自己，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才會抱有「給我看好了！」",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "的想法……",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算渾身赤裸也無所謂喔！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我很期待妳的表現！！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一起加油吧，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也可以陪妳討論。",
        "unit_id": 138812
    },
    {
        "type": "background",
        "background": "502822"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "什麼樣的自己",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會想讓大家見識見識",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗎……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "完全沒有那種想法呢。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "或者該說我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對各方面",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "都沒有自信嗎……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "美冬教練她",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也會放棄我嗎……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也是呢……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我就是個笨手笨腳的遲鈍烏龜……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n無法變成鶴……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "兔子也一定",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會超越我的……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎、",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼辦，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n若菜小姐她",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像非常沮喪……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有沒有方法能讓她打起精神呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我說，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……那個，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳身上總是有香皂的味道呢！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n味道非常好聞。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "覺得很安心。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "香皂？",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_020"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是因為我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "經常洗衣服吧……？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿。",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_021"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "因為我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也經常做咖哩嘛……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不過，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "被人一直聞味道，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺好害羞……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "話說回來……",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_022"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "栞小姐和騎士先生，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是在鼓勵我嗎？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我這種人……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "居然讓你們這樣關心……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可不能",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一直沮喪下去呢。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也不擅長引人注目，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以可能不太懂……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不過，當我看著若菜小姐時，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "發現到一件事。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "發現了什麼？",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐妳，",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很擅長為了別人而努力，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但相對地，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "卻好像不擅長為了自己",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而努力……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "美冬教練說的，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大概是這個意思吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯，",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_026"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好像",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "的確是這樣……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "內心非常想要",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "獲得倭姊姊的認可，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n可能就因此",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "沒把心力放在自己身上……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯……",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_027"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊她即使獨自一人也能堅強活下去。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n布武機也是，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "性格方面比較像姊姊。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我則是一個人",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就無法活下去……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如果只有我一個人，",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_028"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可能連吃飯都會隨便解決吧。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊大概也覺得，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我自己一個人的話",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會餓死在路邊。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "所以才想鍛鍊我，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對我這麼嚴格吧……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這也是身為姊姊的愛呢。",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_029"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯。",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_030"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我想肯定是的。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n……但是，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "看著栞小姐和初音小姐的相處，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我開始覺得，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "現在這樣",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是不行的。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我想證明，",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_031"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就算只有我一人，也能做到些什麼。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n總是在逆境中頑強生存並奪得勝利的姊姊……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我想證明她身上的【蠻賊三姊妹】靈魂，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也同樣存在於",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我身上！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是這股氣勢，若菜小姐！",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這就叫",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「雜草精神」",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喔。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "無論被",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "踐踏多少次，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都要頑強地站起來！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雜草精神……！",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_033"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我想",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "向姊姊證明自己的實力。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n也想同時從「笨菜姊」畢業，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n還要告訴布武機攝取青椒和紅蘿蔔的重要性！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是的！",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_034"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不會再迷惘了！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "無論穿什麼樣的衣服，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我都會堂堂正正地展現「我自己」！！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "明天的表演賽，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我會全力以赴！",
        "unit_id": 138712
    },
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣重新打起精神後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "迎來了表演賽當天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人在會場等候若菜到來──"
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "怎麼了？",
        "unit_id": 1,
        "voice": "vo_adv_1387003_035"
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "若菜怎麼還不出來啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "\n我可是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "特地來欣賞那孩子的蜜桃臀耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "那蜜桃臀可是吉祥物呢。",
        "unit_id": 1,
        "voice": "vo_adv_1387003_036"
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "據說只要像這樣雙手合十禮拜，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "就能保佑無病無災喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼還出現神祕的庇祐效果了……",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n話說若菜小姐，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "發生什麼事了呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n她已經到準備室了吧？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像發生了一點狀況。",
        "unit_id": 108013,
        "voice": "vo_adv_1387003_038"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過沒問題的。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果是現在的若菜──",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "快看！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "她出來了！",
        "unit_id": 108013
    },
    {
        "type": "still",
        "still": "138700301"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "…………唔，",
        "unit_id": 138712,
        "voice": "vo_adv_1387003_039"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "讓、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "讓、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "讓大家，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "久、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "久等了……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若！？",
        "unit_id": 138812,
        "voice": "vo_adv_1387003_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐！？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那件泳裝是怎麼回事？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "平常穿的泳裝呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "太、",
        "unit_id": 1,
        "voice": "vo_adv_1387003_041"
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "太厲害了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "\n多麼大膽的泳裝……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "整個超緊身……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "\n這哪是「蠻賊」，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性粉絲",
        "words": "根本是【內衣賊三姊妹】吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "胸前那片",
        "unit_id": 1,
        "voice": "vo_adv_1387003_042"
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "充滿智慧的開口是怎樣啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "是桃子嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "\n是想展現蜜桃碰撞的概念嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "\n可惡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "我真想從",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "那顆桃子裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "呱呱墜地啊！",
        "unit_id": 1
    },
    {
