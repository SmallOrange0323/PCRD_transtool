[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨拿著席茲爺爺給的「年神祭參加券」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}來到了懷舊點心店。"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "這個是",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_000"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "「年神祭參加券」……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "什麼？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳贏了席茲爺爺嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "爺爺跟我說了什麼神的寶座……",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後要我來這邊詢問詳細的內容。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "嗯，",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_002"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "好吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "既然妳手上有參加券，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "就表示妳有詢問的資格。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳知道，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "這條巷子的深處有一座小小的祠堂嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祠堂……",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我記得",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是一座很小很小的對吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這麼說來，那邊有時候好像會有一些裝飾……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "那個是來自東國的喔。",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_004"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n在這一帶也不乏有人供奉祭祀。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "到這邊為止的情報其實也並沒有刻意隱瞞。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳說到這邊為止，",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽妳的說法，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就表示在那之後還有些什麼對吧……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "沒錯。",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_006"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "只有有資格的人才能獲得傳承，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n接下司掌那間祠堂一整年的年神。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "實際上祈梨妳也不知道這件事，對吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "年神……",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來如此，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那的確是神的寶座呢……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這件事感覺大有搞頭啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "不過，",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_008"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "年神祭畢竟是對那座祠堂的供奉。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n因為是喜慶，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "所以絕對不能見血。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說，",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要和持有這張奇怪票券的傢伙戰鬥，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對吧？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "透過",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "新年的遊戲！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "真是一點就通呢。",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_010"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n就是這麼一回事。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "那麼……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳打算怎麼做呢？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是愚蠢的問題呢！",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當然是只有",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「參加」這個選項啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為新時代的神！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "這樣啊。",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_012"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "那麼就往這邊走吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "接下來要比的是……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "打陀螺！",
        "unit_id": 1511
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們就這樣",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來到了什麼第一場戰鬥……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說是要比打陀螺，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不過這個場地，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來要比的是激鬥陀螺吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈──哈哈哈──！",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這下贏定啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n居然要跟我比賽激鬥陀螺，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然不知道對手是誰，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但只能送他一個慘字啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "少年等人",
        "words": "那可不好說！",
        "unit_id": 1,
        "voice": "vo_adv_1283002_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個聲音是！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "嘿嘿，",
        "unit_id": 416,
        "voice": "vo_adv_1283002_017"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "沒想到祈梨姐姐也有參加呢！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "復仇的機會來了！",
        "unit_id": 111,
        "voice": "vo_adv_1283002_018"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "讓妳看看我們脫胎換骨後的實力吧！",
        "unit_id": 5311,
        "voice": "vo_adv_1283002_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈！",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還以為是誰，原來是你們啊。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們該不會",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要三個人打我一個吧？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過也沒關係啦。",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "管你是三個人還是多少人，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "儘管放馬過來！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們這些雜魚連我的一根指頭都動不了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "根本就不足為懼！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉～",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這場仗顯然已經贏定了呢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看我一擊",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就把你們幾個都收拾掉！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "事情有這麼簡單嗎？",
        "unit_id": 416,
        "voice": "vo_adv_1283002_023"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "等妳看到我們的全新力量，肯定會嚇一跳的。",
        "unit_id": 111,
        "voice": "vo_adv_1283002_024"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "好了好了，",
        "unit_id": 5311,
        "voice": "vo_adv_1283002_025"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "在那之前，我們先完成裝備檢查吧。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼，",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還有裝備檢查啊……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，也沒什麼關係。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "來～",
        "unit_id": 1511,
        "voice": "vo_adv_1283002_027"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "裝備在這邊檢查喔～",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "哎呀，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "歡迎妳啊，祈梨。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "登錄名稱是",
        "unit_id": 128311,
        "voice": "vo_adv_1283002_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「三女神‧慈樂之音六周年紀念版改裝‧",
        "unit_id": 128311
    },
    {
