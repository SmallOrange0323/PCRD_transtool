    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n也希望",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "米奈娃",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以幫我實現",
