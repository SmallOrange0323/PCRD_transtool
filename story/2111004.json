    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我還在想要是認錯人了",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該有多尷尬呢～",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇──！",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是現實的優衣──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太開心了──！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "春咲日和。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天要麻煩妳多多關照了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──我是第三位就代表，",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他一定是",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最後一個來的呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳是怜！？",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好厲害，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟在阿斯特朗時幾乎一模一樣耶！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但總覺得",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說話方式",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像又跟在遊戲裡不太一樣……",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉介紹晚了。",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "士條怜。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n今日還請多多指教。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是草野優衣。",
        "unit_id": 100231,
        "voice": "vo_adv_2111004_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我可以",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟在阿斯特朗時",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一樣稱呼大家嗎？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我沒問題。",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n優衣想怎麼叫都可以！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝妳，",
        "unit_id": 100231,
        "voice": "vo_adv_2111004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳也同意嗎？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以喔。",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我平日在校風嚴謹的學校上學，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以才會像剛才那樣咬文嚼字。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩遲到了？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我之前有確實跟他說",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "集合時間耶。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是說啊……",
        "unit_id": 100231,
        "voice": "vo_adv_2111004_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳剛剛稱騎士先生",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為前輩……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和。",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳該不會",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也之前就見過他了吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對啊！",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n之前學校養的",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鳳頭鸚鵡比奇逃走的時候，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n他還有幫我抓呢！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個，",
        "unit_id": 100231,
        "voice": "vo_adv_2111004_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其實我也是，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n該說見過騎士先生呢，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還是一直都認識他呢……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說回來，",
        "unit_id": 100131,
        "voice": "vo_adv_2111004_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣穿著",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "椿丘的制服呢。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這不是",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟前輩同一間學校嘛！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也太巧了！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒想到他已經跟我們個別",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "見過面了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以日和",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才沒問他住在哪裡。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳說我們……",
        "unit_id": 100231,
        "voice": "vo_adv_2111004_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以怜也",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在這裡跟",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生見過面了吧。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "算是吧。",
        "unit_id": 100331,
        "voice": "vo_adv_2111004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "遲到很不應該耶。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他居然讓我等他，什麼意思啊──",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "still",
        "still": "211100201"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──美空借助厄莉絲之力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n將【破曉之星】3人關在結界裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她們一個接一個，開始慢慢取回了過去的記憶……"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2111004_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一點點……",
        "unit_id": 100111,
        "voice": "vo_adv_2111004_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然只有",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一點點……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒錯。",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想起來了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對啊……",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們是在一款叫做阿斯特朗傳奇的遊戲裡相遇的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我和優衣、",
        "unit_id": 100111,
        "voice": "vo_adv_2111004_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有騎士先生……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們４人一起",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "經歷了許多冒險吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且……",
        "unit_id": 100111,
        "voice": "vo_adv_2111004_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n「那邊」的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現實生活，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們也是一起度過的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "擁有一樣的回憶",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就表示……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果這些",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都不是被捏造的記憶，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就表示我們",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很久以前就認識……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們早就是夥伴，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是朋友了吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過……",
        "unit_id": 100111,
        "voice": "vo_adv_2111004_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是為什麼呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一直以來",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們因為「認知修正」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這件事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n總是無法回想起",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現實世界的事情，現在卻……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會是因為修正",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無法傳遞到結界內部嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
