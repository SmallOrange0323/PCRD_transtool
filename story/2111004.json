        "words": "\n這個世界說不定早就被霸瞳皇帝支配。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果不是她在一旁干擾，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "願望或許就能順利達成……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯……",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們身上也有",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "扭曲這個世界，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n與阿斯特朗的罪。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n其他還有……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有保護好菲歐的罪。",
        "unit_id": 100311,
        "voice": "vo_adv_2111004_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n以及即便沒有實證，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們還是對優衣隱瞞了有關「現實」知識的罪。",
        "unit_id": 100311
    },
