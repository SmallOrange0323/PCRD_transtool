[
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ほう、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "こんなところにも落ちていたか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これは……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "制御系の回路だろうか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やあ同志、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "奇遇だな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n何をしているかと問われれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "答えは一つ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いつだってぼかあ",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この世界を知的散策しているのだよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "悲しいな、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "悲しいぞ同志、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君はまだ視覚情報に囚われているのか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それは魂を近眼にさせる愚行だ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "真理を眩ませるぞ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この場所は現在、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ある種における知の宝庫だというのに。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よかろう、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ではその旧き目で見たまえ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれは爆発四散した",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nスーパーユニちゃん号……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もとい、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なかよしＸの残骸だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n校舎は完璧に修築されたが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ここにはまだ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "かの日の名残りがある。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なかよしＸ……",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_004"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "是非はさて置き、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれは革新的なプロダクトだった。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n既成観念に捕われない、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "独創的な挑戦があった。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "空想科学に描かれる、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "飽くなき浪漫があった。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼奴との邂逅は、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくにとって皮肉にもブレイクスルーとなった。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "知らず囲われていた常識という壁を、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "粉々に打ち砕いてくれたのさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やべーなアレ！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "の連続が",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ひとを劇的に成長たらしめると実感したね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その極めて貴重な体験を漂白させないため、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nあるいは、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "鮮烈なまま確たる形で記録しておくために、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼかあこうしてゴミ拾……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "知的散策をしているわけさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "逆に問うぞ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_007"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君は思わないのかね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふたたびあの得も言われぬ",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "とびきりの知的高揚を味わいたいと。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うむ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_008"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よく言った。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nさすがはぼくの見込んだ共同研究者、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "実にいい浪漫だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ならば、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_009"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "少しばかり手伝っていくといい。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そう答えた君には、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この体力なしの引きこもりを助ける権利がある。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nさあ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "この場に落ちているゴミ……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もとい",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "知の欠片を回収するのだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_010"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "よく分からないという顔をしているね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これは失敬、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "つまり端的に換言するとだな……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いや、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_011"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やめておこう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n無闇に何でもかんでも端的にするものではない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nぼくは文系だからな、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "サプライズという浪漫も解するのさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さて、",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_012"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうと決まれば始めるとしよう、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あれの製作を──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『なかよしＸ　",
        "unit_id": 111011,
        "voice": "vo_adv_5038602_013"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "Ｍｋ-Ⅱ』を！",
        "unit_id": 111011
    }
]