        "voice": "vo_adv_5201076_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太聰明了？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\nAI是AUTO戰鬥的關鍵，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要再增加測試次數才行……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶，",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在做什麼？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼待在這麼暗的地方。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊……",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "克莉絲。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "辛苦了～！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我還要再繼續工作一下，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不需要在意我喔！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是難得",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳會留下來加班。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我看看吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看在作為朋友的交情，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我來幫妳。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "等等妳別看──",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……喂，晶。",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳這個，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不就是之前會議上廢案的東西嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "咦！",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是這樣嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "少裝傻了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都已經當廢案了還留下來加班製作……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳到底在搞什麼啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哎呀妳想想，",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老不是問我誰來負責做嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n沒人要做的話，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就只能自己來了～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打算做出來之後再重新塞進討論會議裡是吧。",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "耍這種小聰明。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說得真難聽耶，",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我才不會硬塞進會議裡呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可能會直接塞進程式裡就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那才更糟糕！",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這麼惡質的彩蛋可不多見啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "果然不行嗎？",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不。",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n反正其他人",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多半也不會讓自己的提議就這麼廢棄，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是不會阻止的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是嘛～！",
        "unit_id": 106831,
        "voice": "vo_adv_5201076_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很好，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這下克莉絲也是共犯了！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳啊，",
        "unit_id": 107131,
        "voice": "vo_adv_5201076_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個性還真是難對付呢……",
        "unit_id": 107131
    }
