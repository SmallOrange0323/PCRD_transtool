    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萊拉耶爾跟{player}等人前往城外，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帕菲之城的大廳"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "只剩下琳德與烏爾姆。"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我說，",
        "unit_id": 127712,
        "voice": "vo_adv_2204003_000"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我們也快點動起來吧，烏爾姆……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n萊拉耶爾殿下",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n交代我們引導鎮上的人們避難啊……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "…………",
        "unit_id": 127812,
        "voice": "vo_adv_2204003_001"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……好懶。",
        "unit_id": 127812,
        "voice": "vo_adv_2204003_002"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊！？",
        "unit_id": 127712,
        "voice": "vo_adv_2204003_003"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "都、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "都這種時候了……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "好懶之類的、好麻煩之類的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "現在不是說這種話的時候吧！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "明明萊拉耶爾殿下他們，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "都去戰鬥了……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "話是、",
        "unit_id": 127812,
        "voice": "vo_adv_2204003_004"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這麼說沒錯。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……話說。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "跟皇家裝備沒關係，",
        "unit_id": 127812,
        "voice": "vo_adv_2204003_005"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我覺得我們家的公主殿下，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "跟貪吃佩可小姐不一樣，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n不習慣戰鬥。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這、",
        "unit_id": 127712,
        "voice": "vo_adv_2204003_006"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "種事！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n不用烏爾姆說，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我也知道……！！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "就算是我，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也非常擔心啊！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "公主殿下她，",
        "unit_id": 127712,
        "voice": "vo_adv_2204003_007"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不喜歡爭執，這我也知道！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要是跟克蘿茜小姐他們一樣會戰鬥的話，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我早就去了！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那妳說，",
