        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真受不了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "前所未聞耶？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n竟然會收到要「做夢」的請求。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來你房間裡開生日派對是吧。",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很榮幸收到你的邀請啦……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但你可要小心",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別被人誤會了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夢裡也沒辦法帶蛋糕跟禮物進來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還得靠我來準備是吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難得的日子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就把你記憶中的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "豪華料理通通都變出來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開始只有我們兩個的生日派對吧♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝。",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不是其他任何人──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你來為我慶祝生日，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對我而言",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是最棒的禮物了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──來，",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我餵你吃蛋糕。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嘴巴張開。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幹嘛扭扭捏捏的啦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種事你很有經驗了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來，",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……好吃嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嗯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也來吃一點吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也要嗎！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要啦，好難為情……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這時候",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你倒是很積極嘛！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n討厭，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道了啦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真受不了你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你最近",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對我也太沒有分寸了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我好歹也是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "女神愛梅斯大人耶？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不要害我像普通女孩子那樣",
        "unit_id": 190011,
        "voice": "vo_adv_4010249_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "臉紅心跳好嗎。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "謝謝♪",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你還真是禮數周到呢～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "竟然還幫嚮導小妖精慶祝生日。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "念在你這麼有心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "今天我就不惡作劇了♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哎呀，",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "甚至還要送我生日禮物啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那我就跟你討一顆高價的寶石好了～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別當真啦，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我亂講的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "其實我從好久以前",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就很想要做一件事。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你可以幫我拜託菲歐看看嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就是你記憶裡的──",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510320"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "──沒錯沒錯，",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是這個♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n在你記憶裡",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有一大堆看起來很好玩的地方對吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我有好多地方都想進去看看呢～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "走吧，",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "把所有遊樂設施通通都玩過一遍～♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡就是所謂的",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "遊樂中心啊……！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呵呵，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看好了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我來示範夾娃娃的必勝法！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只要利用妖精的嬌小身軀，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "像這樣",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "鑽進取物口裡……！",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "搞什麼嘛～",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "購物中心不是應該什麼都有賣嗎～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n完全找不到妖精尺寸的衣服啊！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你說在模型店的玩偶服專區會有？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那就",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "趕快過去吧♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510340"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這種商店裡",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有賣各式各樣的玩具對吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "比起懷舊點心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我個人對那些",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "能用來惡作劇的東西",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "更感興趣♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n像是這個會發出巨大噪音的裝置，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還有黏糊糊的史萊姆之類的～♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊～",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "太好玩了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n今天享受了好多",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你記憶裡的有趣東西♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "明年生日",
        "unit_id": 190911,
        "voice": "vo_adv_4010249_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我還想要再去更多地方逛逛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "對了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你也邀請我去你房間玩嘛♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n放心，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我不會惡作劇的～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好嗎？",
        "unit_id": 190911
    }
