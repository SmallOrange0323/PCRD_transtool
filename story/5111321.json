[
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "喔喔喔喔喔喔喔喔！",
        "unit_id": 17212,
        "voice": "vo_adv_5111321_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可惡，",
        "unit_id": 124911,
        "voice": "vo_adv_5111321_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這傢伙外觀雖然好看，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但是戰鬥方式",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻挺下流的……！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算躲過寶石攻擊，",
        "unit_id": 124811,
        "voice": "vo_adv_5111321_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也會因為鎖鏈而無法靠近……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣有點犯規呢……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊──討厭！",
        "unit_id": 125011,
        "voice": "vo_adv_5111321_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "超煩躁的！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，尾狗刀！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有沒有什麼好計策？",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 124911,
        "voice": "vo_adv_5111321_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們都是肌肉笨蛋，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜託你想些簡單易懂的好主意吧。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 124811,
        "voice": "vo_adv_5111321_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該沒有把我算在肌肉笨蛋裡面吧？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有對吧？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好吧，",
        "unit_id": 106211,
        "voice": "vo_adv_5111321_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟這種工作從以前就是我在負責的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我看看，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "他發動寶石攻擊的同時，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "似乎還另有目的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是、",
        "unit_id": 125011,
        "voice": "vo_adv_5111321_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是這樣嗎！？",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "仔細觀察就能知道了，",
        "unit_id": 106211,
        "voice": "vo_adv_5111321_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我猜他應該是在將力量累積到鎖鏈上。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "要是被他集滿了會很不妙，但是，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果在那之前阻止他，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "應該就能找到勝算。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哇──",
        "unit_id": 124911,
        "voice": "vo_adv_5111321_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然看起來可疑的傢伙腦袋都比較好。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就像我家老大一樣啊。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5111321_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我就當作妳在稱讚我囉。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝了，",
        "unit_id": 125011,
        "voice": "vo_adv_5111321_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然知道亞斯來的目的了，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就一鼓作氣衝吧──！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～這種感覺，",
        "unit_id": 106211,
        "voice": "vo_adv_5111321_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就像回到了那個時候呢。",
        "unit_id": 106211
    }
]