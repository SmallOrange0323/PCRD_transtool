[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吶，",
        "unit_id": 124011,
        "voice": "vo_adv_5106302_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那棵聖誕樹",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "又開始動了喔？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "復活得太快了吧～",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "到底還要再來幾次？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經動不了了……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果敵人會復活，不管幾次都要再戰，",
        "unit_id": 124213,
        "voice": "vo_adv_5106302_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這才是",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正義的天使吧？",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茜里！",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是沒錯……",
        "unit_id": 124011,
        "voice": "vo_adv_5106302_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n可是都已經激戰了一輪，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "用盡各種方法進攻了，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為什麼它還不升天呢？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里又沒有鬆懈～",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然啊！",
        "unit_id": 124213,
        "voice": "vo_adv_5106302_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茜里不可能會鬆懈。",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再撐一下，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也會幫妳一把，",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一起讓那傢伙升天吧！",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好嗎？",
        "unit_id": 124213
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "原來像純小姐這麼單純的人，",
        "unit_id": 124111,
        "voice": "vo_adv_5106302_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n甚至不會注意到茜里話中的毛病啊。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣啊……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那我也加入吧。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "目標是讓它升天！",
        "unit_id": 124111
    }
]