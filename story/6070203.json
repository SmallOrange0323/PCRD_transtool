    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "好きよ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n豪華じゃなくたって、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
