        "words": "ついでに、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "救護院でご飯食べていきなさいよ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "みんな喜ぶわ。",
