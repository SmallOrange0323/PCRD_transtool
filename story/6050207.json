[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鬼屋也開始營業了，",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也算是終於適應這套衣服了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟穿著洋裝去嚇人，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可不是經常能做的事情，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是很有趣的經驗呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微有一點。",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "充其量只限在鬼屋裡面而已喔。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要我平常就去惡作劇什麼的……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n去對那些貴族的傢伙惡作劇，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說不定很不錯呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我、",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我姑且還是有照自己的方式努力，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有讓你感受到、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我似乎沒辦法",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好好地對著你演戲呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希也這麼說了呢。",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一開始我還認為怎麼可能會開心，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過我",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是不是意外地蠻有惡作劇的才能呢？",
        "unit_id": 114011
    }
]