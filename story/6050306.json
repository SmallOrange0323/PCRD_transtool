    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一旦站在要嚇人的立場，",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺就能夠理解馬修他們的煩惱了。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "光憑那個外表的話，那個……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會有很多困難呢。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是說啊……",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "給我等一下。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n莫非",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也在吉祥物範圍裡？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我才不是吉祥物呢！！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不用安慰我啦……",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是安慰我嗎？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n用外表",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓人家放下戒心……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是有可能的呢！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不要放棄，嘗試思考也是很重要的啊！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為你也是和恐怖無緣的人嘛。",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果你能和我一起想點辦法就太感謝啦。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要是這樣還是不行，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再去和紡希討論吧。",
        "unit_id": 114111
    }
]