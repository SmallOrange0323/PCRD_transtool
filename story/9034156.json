[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位",
        "unit_id": 105911,
        "voice": "vo_adv_9034156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都沒有受傷吧！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，",
        "unit_id": 106011,
        "voice": "vo_adv_9034156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還行。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9034156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豆子魔物",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "逃掉了呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是豆子啦！　",
        "unit_id": 106011,
        "voice": "vo_adv_9034156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那不管怎麼看都是花的魔物吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的食慾讓眼睛都出問題了嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_9034156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳太在意細節了啦☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是魔物掉下的豆子，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們一起吃吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106011,
        "voice": "vo_adv_9034156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "遇到那種事竟然還……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是有各式各樣的魔物呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n竟然有讓人以為是花，一靠近就攻擊的魔物呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然貪吃佩可小姐不是被花給吸引，",
        "unit_id": 105911,
        "voice": "vo_adv_9034156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是被豆子引誘的就是了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這的確是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前幾乎沒見過的種族。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然在這座島上，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一般的思維是行不通的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 106011,
        "voice": "vo_adv_9034156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不知道前方有怎樣的魔物。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n繃緊神經前進吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的！　",
        "unit_id": 105811,
        "voice": "vo_adv_9034156_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天的晚餐就吃豆子飯！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "速速解決牠們，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "收割很多回家吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "豆子飯……",
        "unit_id": 105911,
        "voice": "vo_adv_9034156_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下非常想讓主人也享用看看。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n機會難得，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下也",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大展廚藝煮一道菜。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就去追上豆子魔物吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連、",
        "unit_id": 106011,
        "voice": "vo_adv_9034156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連可蘿仔都……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們都給我稍微反省一下啊！",
        "unit_id": 106011
    }
]