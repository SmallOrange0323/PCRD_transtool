[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "行軍訓練の地。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n新兵たちの奮戦により多くの魔物が討伐され、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nかつての平穏を取り戻していた。"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "魔物もだいぶ減ったようだし、",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_000"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "残りは私たちで片付けられそうだ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ありがとう、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "エリコちゃん、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "マコトちゃん。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "それに新兵たちも、",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_001"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ずいぶん強くなった。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n君たちに教官になってもらえて、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "本当に助かったよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "最初はどうなることか",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_002"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "って思ってたけどな～",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "教官役を頼まれた時も、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコが入ってきた時も、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "さ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "しかし彼らも、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_003"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "一人前を名乗れるほどには育ちましたし。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n十分な結果でしょう。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "そうだな。",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_004"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ま、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "やるべきことは何とかこなせたみたいで",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "何よりだぜっ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ふふっ……",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_005"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "何とかこなせた、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "というレベルではないけれどね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n二人は教官としても、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "とてもいいコンビだったよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "コンビって、",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_006"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あたしとエリコが？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "そんな大層なもんじゃ……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "そう呼ぶべき間柄なのかはわかりませんが、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_007"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n仲のよいお友達ではありますわね。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコ……",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_008"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "何せマコトさんは、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_009"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私とあのおかたが絆を結ぶ姿に深く感激したらしく、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n身を尽くして",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私たちを応援すると言ってくれましたので。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "いや言ってねえ！",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_010"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nおまえの中であたしはどういうキャラになってるんだ！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "深くは聞かないでおくけれど。",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_011"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n二人の存在が",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "新兵たちにいい影響を与えたのは事実さ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "騎士団の一員となるなら、",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_012"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "自分の体を鍛え",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "技を磨くだけでは足りない。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n命を預ける仲間として、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n周りのみんなと",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "確かな信頼関係を築く必要がある。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "それぞれが違った強みを持ち、",
        "unit_id": 104711,
        "voice": "vo_adv_5142702_013"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "補い合って困難に挑む……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nそんな君たちの信頼関係も、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "新兵たちにとって",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nいい目標になったんじゃないかな。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "それは、",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_014"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "まあ……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "確かにそっか。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あたしだけじゃ多分、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ここまでみんなを引っ張ってくなんて",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nできなかっただろうし。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "なんだかんだで",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_015"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコが来てくれて助かったよ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "それを言うなら、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_016"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私も同じですわ。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "マコトさんの協力がなければ、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "我流の訓練にこだわって",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n勲章をもらうどころではありませんでした。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "それは本当にその通りだな……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_017"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "この先も",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_018"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "マコトさんの協力が得られるのなら、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "頼もしい限りです。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "これからも私たちの愛を、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "応援してくださいますわね？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あー、",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_019"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "いや",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコ……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "それなんだけど、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あたしは正直言うとだな……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "正直言うと……",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_020"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "なんです？　",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "やはり私たちの邪魔を？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n雌犬どころか、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "人の純心を裏切り陰で嘲笑うような女狐でしたか？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "いやっ、",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_021"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "大丈夫！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nとりあえずいいお友達でいさせてくれ！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "クスクス、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_022"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "ありがとうございます♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "末永く、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "よろしくお願いいたしますね。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "ではみなさん、",
        "unit_id": 129911,
        "voice": "vo_adv_5142702_023"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "任務完了までもう一息です。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n仲良く協力して頑張りましょう。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "そう、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私とマコトさんのように♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "新兵たち",
        "words": "はいっ！",
        "unit_id": 1,
        "voice": "vo_adv_5142702_024"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ああもう、",
        "unit_id": 129811,
        "voice": "vo_adv_5142702_025"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "なんでこんなややこしいことになるんだよ……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あたしか？　",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "あたしが素直になれないせいなのか？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "訓練を乗り越え、団結力も高まった新兵たち。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n一方でマコトは、エリコとの奇妙な関係がまだまだ続きそうなことに"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n頭を抱えるのだった。"
    }
]