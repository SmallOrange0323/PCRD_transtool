    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在散步的{player}，\n偶然發現了莫妮卡。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還以為是誰呢，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來是閣下啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n怎麼了嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你想知道",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我在做什麼嗎……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒什麼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是什麼大事。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我作為軍人為了要提升自己，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以正打算和朋友們去訓練。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下也一起來嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下似乎很感興趣啊。",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就跟過來吧。",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很好，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到啦。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n今天要在這裡訓練喔。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的朋友們，差不多也快來了吧……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "莫妮卡！",
        "unit_id": 211,
        "voice": "vo_adv_1053005_005"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "久等了！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔。",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說人人就到。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n他們正好來了呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "莫妮卡",
        "unit_id": 111,
        "voice": "vo_adv_1053005_007"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "真早到耶。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是當然。",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "作為軍人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "自當要恪守時間啦。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來吧，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "開始今天的特訓！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n首先，列隊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_1053005_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才不是遊戲！",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是真正的訓練喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下……",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是在取笑我嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我可不是來玩的喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "模擬在多人數狀況下的戰鬥訓練。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "孩子們身手很敏捷。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也可以藉此鍛鍊我的腰腿──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "啊，",
        "unit_id": 211,
        "voice": "vo_adv_1053005_014"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "是我爸爸！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "爸爸──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "這裡這裡──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "謝謝大家和我女兒一起玩。",
        "unit_id": 1411,
        "voice": "vo_adv_1053005_015"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "今天我也帶點心來了喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好耶──！",
        "unit_id": 1,
        "voice": "vo_adv_1053005_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為有點心就這麼興奮……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以說你們還是孩子呀。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……但、",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果就只有我不拿，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n會破壞團體秩序。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣不太好。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "莫妮卡",
        "unit_id": 1411,
        "voice": "vo_adv_1053005_019"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "也請拿吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯、",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "每次都承蒙你關照了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎、",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了，{player}？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n為什麼用疑惑的眼神看我？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下是想說我是為了拿點心",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才會來這裡的嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才、才不是！ ",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼可能有那種事呢！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了點心，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才和小孩一起玩什麼的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我身為一個光榮的軍人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是不可能做這種事情的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我說的是實話喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "莫妮卡！",
        "unit_id": 211,
        "voice": "vo_adv_1053005_025"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "快點繼續剛才的特訓吧──！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我得去陪孩子們了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先這樣啦，{player}！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "莫妮卡，",
        "unit_id": 111,
        "voice": "vo_adv_1053005_027"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "這種點心好好吃喔。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "分妳一半。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可以嗎？",
        "unit_id": 105311,
        "voice": "vo_adv_1053005_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好吧，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那我的也分一半給妳。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}欣慰地看著和孩子們打成一片的莫妮卡。"
