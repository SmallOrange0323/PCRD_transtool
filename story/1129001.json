    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣一來鐵定錄取！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "作品名當然是──",
        "unit_id": 101112,
        "voice": "vo_adv_1129001_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我最重要的",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "朋友之名。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿……",
        "unit_id": 101112,
        "voice": "vo_adv_1129001_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好想秀給誰看一下喔……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說到要讓誰看的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是──",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "──哥～哥♪",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等很久了嗎？",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抱歉，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "花太多時間準備了……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是……嘿！",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥你看",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這套衣服♪",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚呀……",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥好直接……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是好開心啊～～～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哦，",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥還記得嗎？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這件衣服的設計和當時……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被不可思議的書吸進去時穿的衣服是",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n是一樣的！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實我之前就開始做了，",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n直到最近",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "終於完工囉！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "做好之後",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "馬上就想穿給哥哥看呢！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如何如何，",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這可是我的得意之作喔！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "盡量稱讚我沒關係，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不用客氣♪",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "身為妹妹，",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不管被哥哥稱讚幾次都會很開心的！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被哥哥摸頭真的好舒服喔～",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……雖然在大庭廣眾之下被摸頭",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有點害羞，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是現在的我，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才不在意旁人的眼光！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "製作出自己也夠滿意的作品後，",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在覺得天下無敵呢～♪",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "接下來",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是在這次考試把這件衣服當成作品交出去了。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然筆試我沒什麼自信，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但靠這件衣服",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "術科一定沒問題的！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說不定",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只靠術科我就可以錄取囉～♪",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "這可難說了。",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請、",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請問您是誰？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嚇我一跳……！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "我只是個路過的阿姨。",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_022"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "不好意思啊，打斷你和男朋友相親相愛了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "男男男、",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "男朋友！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不、",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是啦，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個人",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是我的哥哥，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才不是我的男……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "未來會怎麼發展我也不確定就是了！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來！",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "剛才您的話是什麼意思？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是我的衣服",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有什麼問題嗎……？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "呵呵。",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_025"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "神色變來變去的，真是有趣的孩子。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "……雖然我也不想",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "讓這樣的妳露出難過的表情，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "但我就直說了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "這套衣服還有不足之處。",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_026"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "沒錯。",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_027"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "以這套衣服應試的話，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "不管筆試分數多高，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n都會在術科被刷掉吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼可能！",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這可是",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的得意之作耶……！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "的確，",
        "unit_id": 1511,
        "voice": "vo_adv_1129001_029"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "這件衣服非常可愛。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "設計精緻，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "也相當有獨創性。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "但……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "在找出不足之處前，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "都不算是完成品。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "您是說……",
        "unit_id": 112912,
        "voice": "vo_adv_1129001_030"
    },
    {
        "type": "dialogue",
