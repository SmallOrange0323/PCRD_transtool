    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們現在除了繼續攻擊下去之外也沒有其他辦法了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我完全聽不懂妳們在講什麼，",
        "unit_id": 106113,
        "voice": "vo_adv_2015003_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但妳們說得很對！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿啊啊啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真無聊。",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "果然就跟妳本人一樣，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "已經沒有意義了呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……！",
        "unit_id": 104711,
        "voice": "vo_adv_2015003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n危險，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "矛依未！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純、矛依未",
        "words": "啊啊啊啊！\n啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_2015003_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾……",
