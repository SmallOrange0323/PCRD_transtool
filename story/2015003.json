    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔……！",
        "unit_id": 104311,
        "voice": "vo_adv_2015003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然我們的攻擊並不是完全沒用……",
        "unit_id": 104311
