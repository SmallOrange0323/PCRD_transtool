        "voice": "vo_adv_2015003_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這根本",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是助燃大水呀！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是竹籃打水唷，",
