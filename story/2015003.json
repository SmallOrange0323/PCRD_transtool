        "name": "矛依未",
        "words": "這次，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我一定會把她砍成兩半！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍――！",
        "unit_id": 106113,
        "voice": "vo_adv_2015003_015"
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……怎樣呀！？",
        "unit_id": 106113,
        "voice": "vo_adv_2015003_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個嘛……",
