        "voice": "vo_adv_2015003_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真要我說的話，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我希望你們能再多加把勁呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……竟然連恢復魔法都能使用！",
        "unit_id": 105911,
