    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就像是我小時候，",
        "unit_id": 101711,
        "voice": "vo_adv_2015003_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n為了修行而去打大石塊一樣的感覺呀……！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就再來一次……",
