        "voice": "vo_adv_2015003_025"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "矛依未！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n團長！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上前掩護的純小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2015003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n連同矛依未小姐……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅憑一擊就將兩人……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唉……",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真無聊，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "實在是太無聊了啊。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不論是你們，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是這個世界。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這一切的一切…………",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我究竟",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是從何時開始犯了錯呢……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n說到底……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "太過急於完成阿斯特朗，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而去借助其他七冠的力量這件事，說不定本身就是個錯誤呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即使我不惜借助他人之力或放入其他雜念，",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來努力地加快開發進度，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但結果，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "等到完成時……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也已經不再是",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n適合夢與冒險的世界的年紀了……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霸瞳皇帝……？",
        "unit_id": 100211,
        "voice": "vo_adv_2015003_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……草野",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "優衣。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我啊……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管以身為「神」的自己感到自豪。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但如果真有一個人，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠讓我感到羨慕的話……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那個人，",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就是妳喔。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_2015003_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "像妳這樣",
        "unit_id": 106915,
        "voice": "vo_adv_2015003_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被每一個人所愛戴……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "甚至被命運所眷顧著的",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n宛如公主殿下一般的女孩子，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我必須像這樣與妳敵對。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還得被那些淨說些漂亮話的傢伙們",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "刀劍相向。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真的，",
        "unit_id": 106915,
