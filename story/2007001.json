[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，往這邊請。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n還有",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可可蘿也請。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一路上有點顛簸，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請小心",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不要摔倒了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您的忠告。",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下本來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就已經習慣穿梭在森林之中了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以沒有什麼問題。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您多加小心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若不介意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "需要攙扶您嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可不足掛齒。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管何時何地，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從每日一早醒來到入夜就寢為止，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n全心全力地支持著主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呣。",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從主人口中說出的『沒問題』，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太能讓人信服呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您看，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡有個突起的樹根。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不忍看了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還是讓在下牽著您走吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將手緊緊握好……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩位",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感情很好呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真棒呢，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就像親人一樣。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "常常被這麼說呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明就只是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "單純的主從關係而已，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻被說是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「像是兄妹一樣呢」或",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「像是父女一樣呢」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之類的話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也……",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偶爾會不小心的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就稱",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人為",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哥哥",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "爸爸",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽起來好像很愛撒嬌呢，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下自己都覺得有些害臊了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣沒有什麼不好的呀。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且可可蘿",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳的年紀也還小……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n已經可以看到精靈族的村莊了唷。",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦……",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和在下的故鄉相較起來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然還是有相異之處呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也曾聽過，依據分支的族群不同，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會發展出不同的文化。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒錯呢。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可可蘿的故鄉是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼樣的感覺呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有點難說明呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該說更加的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正經八百嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "環境相當整潔，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但該說是人與人之間的關係較為冷淡嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n整體來說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有些冷冷清清的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就地理位置來看，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "村子位於跟這裡有段距離的北部。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n相當寒冷呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個「精靈之森」，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n給人的感覺就像是最原始的大自然……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很討人喜歡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是個洋溢生命力的地方呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼看來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n完全沒有遭受到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前些日子的大量破壞魔法的災害影響。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之前還令人相當擔心呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟離爆炸中心處的山林間相當近。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以為了理解現況，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "才得像這樣特地爬山呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有需要，也打算提供援助，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但還是得先來實地訪查一番。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n栞小姐，真的非常感謝您願意親自引路，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可真是幫了個大忙呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n其實我的姊姊，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就居住在這個村落之中……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n距離並不是很遠，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以經常會來拜訪，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以才會熟識這條路。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為了【伊麗莎白牧場】的警備及狩獵，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我經常會穿梭在這片森林之中呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若需要嚮導，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就交給我吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且牧場的重建工作，也受到你們的幫忙呢，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果能報恩就好了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "並且，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也很擔心姊姊的安危。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然是因為",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大量的破壞魔法，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這裡的魔力依舊相當混亂……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也完全無法接上通訊魔法，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n看來得實際到現場呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呣！？",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請稍等一下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看到不可思議的東西唷？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩位，請先",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "退下。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可能因為魔力混亂的影響，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也增加了不少奇妙魔物的目擊資訊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像是有貌似由多個魔物合成的奇怪魔物，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在到處閒晃",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的樣子。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n若被危險的魔物襲擊就不妙了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就先讓我用弓箭來應對。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乍看之下似乎不是魔物呦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那、那是什麼……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像是誰，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很不自然地飄浮在空中的樣子？",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200700101"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……哇唔哦！？",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n哦～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是嚇死人了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還真以為要掛了呢～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你把我給接住了呢，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝囉～☆",
        "unit_id": 101211
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這一位，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是栞小姐的姐姐吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照往例，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然也是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人所認識的人嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人還真是不管到哪個地方，",
        "unit_id": 105913,
        "voice": "vo_adv_2007001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都會有感情很好的女孩子出現呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸？",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n{player}和",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有沒見過的女孩子！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這是什麼情況？",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那個……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "各位",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "到精靈族的村莊有什麼事嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然不是很清楚狀況，",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但還是歡迎你們來！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，村莊的人們為了調查附近發生的大爆炸，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n都出門去了～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但也不能讓村子就這樣空著，",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以我就留下來看家了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說回來小栞，",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "反倒妳們那沒問題嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不但就在爆炸的附近，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "且好像還有大量的魔物到處發狂四竄對吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n從這都能看到牧場的方向燃起大火呢，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我可是捏了把冷汗唷～？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我呀，",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_040"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為很擔心小栞。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以就和公會的夥伴們，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n一路上痛扁魔物，一面朝著牧場前去呀。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結果竟然是個空城……",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真是的，我都快被嚇死了呢～？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只是暫時到蘭德索爾的近郊避難而已。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在已經回到牧場，",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n開始進行重建了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家都沒事，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請不用太擔心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣啊～",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嗯，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "的確有從哪兒聽來",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你們避難去了的傳聞。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但通訊魔法接不上，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "完全搞不清楚狀況……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞～！",
        "unit_id": 101211,
        "voice": "vo_adv_2007001_046"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n妳沒事真是太好了……♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n抱歉讓妳擔心了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事了。",
        "unit_id": 103811,
        "voice": "vo_adv_2007001_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且姊姊看起來",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也毫髮無傷，我也安心了……♪",
        "unit_id": 103811
    }
]