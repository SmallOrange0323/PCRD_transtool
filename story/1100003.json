[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈與攝影師正在討論――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想要衝浪的照片？",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_000"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "不只是拍攝沙灘的照片，",
        "unit_id": 1212,
        "voice": "vo_adv_1100003_001"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n我們也想要拍一些特別場景！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "因此，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "想說如果請妳衝浪的話如何呢――",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "我們有這個想法。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像很有趣！！",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為模特兒之間很流行，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我很早就有興趣了～♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想試想試！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "就知道妳會這麼說，",
        "unit_id": 1212,
        "voice": "vo_adv_1100003_003"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "所以已經為妳準備衝浪板了唷！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "準備好周到唷！",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我就來衝浪囉♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n你說我真的能用這個板子衝浪嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不能衝浪就趕不上流行了～",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒問題沒問題～♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我出發啦♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "――浪過來了！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是現在……！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "用手划水～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後在感覺對的時候站起來……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "站起來……",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哇哇！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n哇啊啊啊！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊――！　",
        "unit_id": 411,
        "voice": "vo_adv_1100003_009"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可惜！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "好唷――",
        "unit_id": 1212,
        "voice": "vo_adv_1100003_010"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "鈴奈！　",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "就這樣繼續下去！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "海水好鹹――！！",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺好像能站起來！！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "噗啊！",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "試了好多次都站不起來～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "別灰心別灰心！　",
        "unit_id": 1212,
        "voice": "vo_adv_1100003_013"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "我們休息一下！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好～……",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呼，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看起來很簡單的樣子說……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才不好意思呢――",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你在旁邊看也不有趣吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說我不斷挑戰的樣子很酷嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不用這麼客套～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家跟秀才是朋友吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不過，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家打起精神了。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "衝浪還真難～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "本來以為馬上就能站起來的說～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是啊。",
        "unit_id": 411,
        "voice": "vo_adv_1100003_018"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n希望太陽下山前，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "能拍攝成功……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "晚上不能衝浪嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "天色變暗之後就不行囉。",
        "unit_id": 411,
        "voice": "vo_adv_1100003_020"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n因為很危險。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哇哇！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那現在可不是休息的時候！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "重來重來！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺力量好像……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你該不會強化人家了？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "的確在這種狀態下，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "應該可以衝浪成功……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "真的嗎！？",
        "unit_id": 1212,
        "voice": "vo_adv_1100003_023"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n那麼，趕快來拍攝吧――",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "――",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等等！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "鈴奈？",
        "unit_id": 411,
        "voice": "vo_adv_1100003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才的心意",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我心領了……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這次",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想靠自己的力量達成。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "投機取巧，卻說這是人家的實力，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說這種謊不是很遜嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "身為專業模特兒，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這點我可不會讓步！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "會讓你看見我成功衝浪的樣子，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n請幫我加油～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哈哈，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不用道歉啦～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你是為人家才這樣做的吧？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你♪",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我要再次",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "挑戰唷～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇！　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哎呀呀……！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n哈啊啊啊！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "鈴奈，",
        "unit_id": 411,
        "voice": "vo_adv_1100003_032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "太厲害了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n好像漸漸可以在衝浪板上站起來耶！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "應該再練習一下，抓住訣竅後就能站起來吧～！",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n到底哪裡不對呢～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？　",
        "unit_id": 110011,
        "voice": "vo_adv_1100003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "冷靜好好觀察海浪？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對呢！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我只注意看著自己的腳下，",
