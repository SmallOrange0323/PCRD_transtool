[
    {
        "type": "background",
        "background": "502130"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その日クレジッタは、古代遺物の引き起こした騒動の爪痕を"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n確認して回っていた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "はぁ……",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_000"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "人的被害や大きな損傷はなく、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nイベント開催には支障はありませんけど、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nやはり無傷というわけにはいきませんでしたわね……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "飾りが壊れたくらいで済んだのは不幸中の幸い。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_001"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ですが、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "早急に代わりを用意しなくてはならないのは",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nなかなか厳しいですわ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "予算も納期も。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "前と同じ物、",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_002"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あるいは見劣りしないものとなると",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n入手に時間がかかりそうですし……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いっそ思い切って変えてしまうというのも手かしら。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "って、",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_003"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あら？　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あらあら？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "破損個所がバラの花で飾られて……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n傷がうまく隠されていますわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いったい誰が……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "って。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "こんなマネをするのは",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_004"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしの知る限り一人しかいませんわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そうでしょう？　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "『隻眼の悪魔』。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あら、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_005"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "バレバレみたいね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "さすがね、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "クレジッタ・キャッシュ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n温泉のとき以来かしら♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そんな名推理みたいに言われましても。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_006"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n貴女を知っている人なら誰でも思い浮かびますわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n他にこんなことする人、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "おりませんでしょ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "それじゃあ正解のご褒美に、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_007"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "サービスしてあげちゃうわ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "これだけバラの花があれば、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "破損部分の目隠しにも、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n新しい飾りつけにも使えるでしょ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "どう？　",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_008"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "色合い的に",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "クリスマスっぽくできるわよ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "見た目も十分豪華になるしね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "リースもあるわ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "こうして取れた飾りつけの代わりにすれば……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……悪くないですわね。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_009"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n鮮やかで大人な雰囲気、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いいと思いますわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "それで、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いくらお支払いすればよろしいかしら？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あら、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_010"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "お金なんて気にしなくていいのよ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "私とあなたの仲じゃない？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そんな深い仲になった覚えはありませんでしてよ。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "それに、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "「無料」なんて言葉に喜ぶほど",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nかわいいお嬢さんでもありませんの。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "さ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_012"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お値段を言ってくださいまし。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "うふふ、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_013"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "あなたのそういうところ、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "結構好きよ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "じゃあお言葉に甘えて、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "お支払いお願いするわね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "物々交換でいいかしら。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "この時代に貨幣経済じゃないってどういうことですのよ……",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_014"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これって……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "薬の材料のリスト、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ですわね？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "しかもだいぶマイナーな……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ええ、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_015"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "なかなか手に入りづらい材料でね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\nあなたの商人としての伝手を頼りたいの。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まあ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_016"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これくらいならすぐに……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "と言いたいところですけれど。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nクリスマスイベントとその片付けが終わるまでは待っていただけます？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n生憎わたくしスケジュールがビッシリですの。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "せっかくのクリスマスだというのに",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_017"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "働きづめなんて寂しいわねぇ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "フン。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_018"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nその言葉、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そっくりそのままお返しいたしますわよ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "心外だわ。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_019"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "薬の材料のこともあったけど、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n普通にあなたのお手伝いもしたかったのよ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "イベント、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "楽しみにしてるもの。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……ちょっと。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_020"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nもしかして憐れみですのそれ？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "まさか。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_021"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "クリスマスに一人身は寂しいなんて思うタマじゃないでしょ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "100％純粋な応援よ。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "でも、",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_022"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "闇医者に言われましてもね……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "うふふ、",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_023"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "悪徳商人に言われましてもね。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "ああ、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "そうだ、",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n材料とは別にこれも手配してほしいんだけど。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "全部揃ったら知らせに来てちょうだい。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_024"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "だからわたくしは忙しいって……",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_025"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "なんですの、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "これ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nおススメのワインやおつまみだとか、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "わたくしに頼まなくても……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "あ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "今日の夜までにお願いね。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_026"
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "さすがにそんな遅くまで働かないでしょ？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "ミツキ",
        "words": "それじゃあね♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まったく、",
