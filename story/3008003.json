[
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在公會小屋裡，秋乃和珠希兩人，\n正跪坐在美冬面前聽訓。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳們兩個都太浪費了！",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃本來花錢就沒有節制，",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希也買太多貓飼料了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然我不想說太過嚴厲的話，",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但再這樣下去，就不得不動到",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們運用來投資和貸款的錢了喔？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我一直都只過著這樣的生活……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在才要我改變，我做不到。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也是，一看見貓咪們那副",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「給我飼料」的表情，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就無法視而不見喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "找藉口也沒用！",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n總之，我會暫時將妳們兩個減薪！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "唉……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這下傷腦筋了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是的喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣下去，就沒辦法給貓咪們飼料了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？ 在那裡的是？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂――聽我說喵！\n美冬好過分喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因為花費過度，",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n竟然減薪這麼多……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們接下來該怎麼辦才好呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有效利用……",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我想到了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "賺錢……！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我有好方法喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "多虧你讓我想到好辦法喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "錢變少的話，我們只要自己想辦法賺就好了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話是這麼說沒錯……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但該怎麼增加呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我知道一個好地方喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "跟我來喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "看起來只是普通的餐廳呀？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實這間店裡有人在玩紙牌賭博喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果我們參加的話，一定能賺錢喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "背地裡賭博……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的沒問題嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只是店裡的顧客彼此在玩而已，不是犯罪喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我沒有擊潰這裡就是最佳證據喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "確實。若有做壞事的人，",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "珠希就不可能會介紹給我吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，我們馬上參戰吧喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這裡玩的是五張換喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃妳仔細聽好。首先將牌……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……葫蘆。",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我贏了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "湊熱鬧的",
        "words": "好厲害－！",
        "unit_id": 811,
        "voice": "vo_adv_3008003_023"
    },
    {
        "type": "dialogue",
        "name": "湊熱鬧的",
        "words": "\n那位小姑娘，這麼算下來可是十連勝了！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有我的好運加持的話，贏紙牌遊戲再簡單不過！",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我會繼續贏下去喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "嘿嘿嘿……是三條。",
        "unit_id": 1411,
        "voice": "vo_adv_3008003_025"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n很遺憾，這次是我贏了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等喵！ ",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這傢伙出老千喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n他偷換牌喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n藏在袖子內的紙牌就是證據喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "可、",
        "unit_id": 1411,
        "voice": "vo_adv_3008003_027"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "可惡！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n為什麼會露餡……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "別想逃過我的法眼喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我和珠希聯合起來就是最強的呢。",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n感覺不會輸啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趁著這個氣勢，大賺一筆吧──！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_030"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "數天後──"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好奇怪……",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我還以為兩個人差不多也該有所反省，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n哭著跑來央求了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "最近她們反倒好像很開心？",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該說是生氣勃勃……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真可疑……似乎有什麼隱情呢。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉呢。讓你幫忙買東西，",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_034"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n還問你這種事……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不，你也是重要的參考人喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_035"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n而且你和秋乃她們感情又不錯。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我就是因為這件事，今天才找你過來的！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你知道最近那兩個人發生什麼事了嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "靠賭博來賺錢！？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那兩個人真的是……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "賭博可是節儉的敵人喔！",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_038"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n優花梨，來幫忙！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好是好，但我該做些什麼呢……？",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_039"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔呵呵呵！ ",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "又是我贏了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n贏成這樣，連我都害怕自己的好運呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要有我跟著，",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就不用擔心有人出老千而輸喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "賺飽飽，狂歡了喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃？ 珠希？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n妳們在做什麼？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬！？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、這是、那個……不是的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃，冷靜喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們並沒有做壞事喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要怎麼用自己的錢，是我們的自由喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算是這樣，賭博也太超過了。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_045"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為我們受妳的父親所託，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "得要教妳腳踏實地的生活方式。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但是就結果來看，我們並沒有輸喔？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有賺到錢這點，對美冬而言不也是件開心的事嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳們兩個異口同聲地說賺到錢了，",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_047"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n荷包卻似乎意外地空呢？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_048"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是因為……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "賺到的錢馬上就花掉了，這也是沒辦法的事喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我可是為了矯正妳們浪費的習慣才減薪喔？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_049"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣一來豈不是一點意義也沒有了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唔……但是，這是我們自己贏來的錢喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_050"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要怎麼花都隨我們高興喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣啊……",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_051"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看起來相當有自信呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，我和優花梨組成一隊，和妳們以紙牌決勝負吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我會賭上我所有的存款。誓約書已經寫好帶來了。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_052"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "順帶一提，如果贏了我們，妳們以後要繼續賭博也沒關係。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這也……可以嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是，妳們也必須賭上相同的金額喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_054"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且若是我們贏的話，妳們就不能再賭博！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n沒問題吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "求之不得喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_055"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我會讓妳們後悔向我們挑戰喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "兩對！",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "想贏我和珠希，妳們還早一百年呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們立馬就佔了優勢喵。",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_057"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "順著這個氣勢贏下去吧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "讚！不愧是秋乃姑娘！",
        "unit_id": 1111,
        "voice": "vo_adv_3008003_058"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "就這樣把他們手頭的錢都贏光光吧－！",
        "unit_id": 1411,
        "voice": "vo_adv_3008003_059"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……優花梨。還能繼續下去吧？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_060"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是的，還可以喔。",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵呵呵……看來手上的錢相當多呢喵♪",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "秋乃，既然如此，我們就從她們身上多榨點錢吧！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "了解！",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_063"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "葫蘆喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是一對……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_065"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這點錢算不了什麼！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "別在意！現在開始才是勝負！",
        "unit_id": 1111,
        "voice": "vo_adv_3008003_066"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒錯……才這點錢，",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_067"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n之前我也曾經逆轉翻盤。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這次絕對不會輸的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一對……",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_068"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣就分出勝負了吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不，等一下喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_069"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一口氣就被逆轉了喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼一回事喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "同花順喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_070"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……是我們贏得壓倒性的勝利，沒異議吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、這是怎麼回事……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_071"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n竟然讓我們束手無策！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很簡單呀。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_072"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我靠著紙牌上的刮痕，將所有的數字背了起來。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "紙牌不可能會有那麼明顯的刮痕才對喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_073"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為是紙做的，只要動作粗魯一點，就會刮傷了對吧？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_074"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳看，像是這裡。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這也太小了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_075"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳是在比賽進行時確認刮痕的嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那當然。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_076"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且妳們讓優花梨和我一起對戰，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n是很失策的。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為我很了解妳們兩個的習性，",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_077"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "只靠表情和動作舉止，就能知道妳們抽到什麼牌。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "竟然有這種方法……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_078"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還有，周圍的觀眾全部都是幫手喔。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_079"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在每個人進到店裡之前，我就幫他們付了酒錢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳說什麼！？",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_080"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "奇怪喵，妳如果出老千的話，我一定會察覺到的喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_081"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為了讓妳們在一定的程度上輕鬆獲勝，",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_082"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我可是拜託大家拚命幫妳們加油喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n妳們兩個，比到一半就對我們放下戒心了對吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也就是說，",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_083"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n周圍的人只是在免費的吃喝，幫妳們加油而已。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "效果很棒對吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "優花梨！下次好好地來喝一杯吧！",
        "unit_id": 1411,
        "voice": "vo_adv_3008003_084"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "很少看到你這種沒喝醉的樣子，真有意思！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈……如果我心情好的話。",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_085"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "被、",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_086"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "被擺了一道喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為跟出老千不一樣，所以我沒看穿喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼……我們贏了也就代表……",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_087"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還記得約定吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……我知道了。",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_088"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我不會再賭博了",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "應該不是只有這樣吧？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_089"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我們可是賭上了全部的存款喔？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也就是說，妳們輸的金額比手頭上的錢還要多。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_090"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "金額相當大呢……妳們兩個的薪水支付得起嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_091"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "若是付不起的話，即使借錢也要還喔♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n說到這個，我們公會有提供借貸服務……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼會喵啊啊啊啊！ 我討厭借錢喵啊啊啊啊啊……！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_092"
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "工、工作結束了喵……",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_093"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……文件擬好了。",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_094"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，接下來就麻煩妳們打掃房間，",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_095"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n之後幫忙完成新事業的計劃書。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚……妳也讓我們做太多事了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_096"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "反對不當勞動喵！ 我們也應該擁有權利――！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼我們會被欺負到這種地步呢……！",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_097"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果不多做些工作，不就無法償還向公會借的款項了嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_098"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且作為賭博的懲罰，妳們的薪水又更少了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為公會日益壯大，人手真的不足。",
        "unit_id": 103411,
        "voice": "vo_adv_3008003_099"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉兩位，我今天要先走了，之後就麻煩妳們囉。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "辛苦了，優花梨。",
        "unit_id": 104811,
        "voice": "vo_adv_3008003_100"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……在她們把錢還清之前，就由我會代理公會長一職喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喏，手腳俐落點！ 時間就是金錢喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我……",
        "unit_id": 103211,
        "voice": "vo_adv_3008003_101"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我已經受夠賭博了──！！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我最討厭借錢了喵啊啊啊……！！",
        "unit_id": 104611,
        "voice": "vo_adv_3008003_102"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "秋乃和珠希在心裡深深地發誓，\n這輩子絕對不會再賭博了。"
    }
]