[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定一起度過假期。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們並沒有下水，而是在沙灘上玩砂。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拍拍拍拍～☆",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "上次玩砂還是小時候！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們一起建造蘭德索爾吧♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "首先中心是王宮！",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n周圍有城市……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "星形的牆壁也不能忘記！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為有很多人海裡在玩，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我打算讓給他們。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很驚訝這裡人居然這麼多！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這應該就表示",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡是可以放心玩樂的地方吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我當然",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也想要",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和你到水裡互相潑水，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是在海邊追逐嬉戲……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我畢竟是",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「微服出巡」的公主。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想在不打擾其他人的情況下，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "偷偷享受這個夏天！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且……",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很久沒有和你一起出來了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是難得的",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩人獨處！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "生活不只是只有冒險，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "偶爾悠閒地度過假期也不錯☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你在蘭德索爾過得如何？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一直打工是不是很忙？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想知道",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "更多你的事情！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～！",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那家店，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只有晚上才有魔物肉嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到郊區還有不為人知的名店！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好哦……",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也想和大家一起去……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在遇到小雪菲的稍微之前一點……",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的貪吃佩可，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和小凱留、小可蘿……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有你一起冒險。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但現在",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經沒辦法了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說實話，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這讓我覺得有點寂寞……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過我會忍耐！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管怎麼說，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我現在身負守護蘭德索爾的",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "重大任務！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說著說著就完成了！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用砂子堆成的蘭德索爾！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拍手拍手～☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我還得繼續努力，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓現實的蘭德索爾也能像這樣復興成功。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……謝謝你。",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣還不夠。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要得到大家的信賴，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還要繼續努力。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實際上，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是最近才放下劍",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "登上王座的。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且一國之主",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是個不懂政治的小孩子。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "周圍的人會覺得不安也很正常。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老實說，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也很迷惘。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家每天都能和",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自己珍視的人一起享用美味的飯菜……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我希望這個國家的人",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都能理所當然地享受到這種小小的幸福。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唯有這份發自內心的信念",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是絕對不會動搖的。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我已經下定決心，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去盡力做自己能做的事。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對於王位，我現在能確定的是……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只靠決心和理想",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是沒辦法",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "改變任何事情的。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以──",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "砂堆成的蘭德索爾",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被海浪沖垮了……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "費了不少苦心才做好的，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真可惜……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這種時候",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會讓我忍不住去想。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想打造的蘭德索爾",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是否也會這麼脆弱……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會像這樣一下子就垮掉了？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與其我自己努力，",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是否將王位讓給更適合的人，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾會更安穩和平，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家也過得更幸福呢？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……說、",
        "unit_id": 107512,
        "voice": "vo_adv_1075006_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說說而已啦！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我最近",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比較容易悲觀呢！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
