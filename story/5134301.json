        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "能不能順利地按照作戰計畫，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "把它破壞掉呢！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是已經被破壞過、削減了一圈的隕石。",
        "unit_id": 128311,
        "voice": "vo_adv_5134301_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n只要用拳頭揍過去就好了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果還是很不安的話，",
        "unit_id": 128511,
        "voice": "vo_adv_5134301_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不要再看一次預知夢呢？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "假想訓練跟預演都是很重要的。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣一定能讓妳抱有信心。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來如此……！",
        "unit_id": 128411,
        "voice": "vo_adv_5134301_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說得也是呢～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼我就",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想著要夢到隕石……！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
