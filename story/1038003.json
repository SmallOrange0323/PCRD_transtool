[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，這裡有空位呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們就坐這裡吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你也不用客氣，請坐。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "作為你今天陪我買了一整天的東西的謝禮……",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請讓我請你吃晚餐吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我不知道這頓飯是不是能當成我的報答。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我都是稍微買點東西後",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就先休息一下……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "平常大概都是像這樣的感覺。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我總是還沒買齊想買的東西，",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一天就已經結束了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天多虧有你幫我提東西……",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我把想去的店都徹底地逛了一遍。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我感到非常滿足。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對你來說，",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果今天也是很有意義的一天的話就好了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是老是勞煩你照顧我，你應該不覺得開心吧？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你說很開心嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣嗎……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或許你是顧慮我的心情才會這麼說。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是也讓我鬆了一口氣。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也是，我比以往還要買得更心滿意足。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然是這麼說。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我很久沒有走這麼多路了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "覺得累了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且我今天也比往常還要亢奮……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不知道是不是疲倦的關係，我似乎沒什麼胃口。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不然吃些水果就好了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就只點些甜點吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我應該多吃點，好好補充營養呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……{player}，你要點什麼嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這家店的菜色應該很豐富的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的，你是要點肉類料理吧，我叫店員來喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "料理的份量似乎很多呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你吃得完嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣呀……",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "男生真的很會吃呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，你只點甜點夠吃嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你再多點一些都沒關係的……",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "託你的福，我買到便宜的中古書，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我的手頭很寬裕。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說你也要自己付飯錢……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯～你是不好意思讓年紀比你小的女孩子請客嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你其實不用在意的，別跟我客氣。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "………♪",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n啊，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我翻閱了一下我買的書。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我這樣不行吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我明明就在與人一起用餐，卻在做別的事。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣很沒禮貌吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。以往我都是住在牧場裡一間有點像病房的房間，",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n在那裡一個人用餐……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以與其說是我不習慣與人同桌吃飯，不如說是我沒規矩呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這本書是我一直都很喜歡的作者所出的新書。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n無論怎麼樣我都忍不住，很想快點讀這本書♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是關於生活在某個很遙遠、所有常理",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n都與我們所處世界不同的異世界少年和少女的故事……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是我卻覺得莫名地有共鳴，非常喜歡這個故事。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我非常推薦這系列的書。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "特別是從第三集開始回收伏筆，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n劇情突然有大進展讓人看得目不轉睛……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對、對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我自顧自地講得很開心，很沒禮貌吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我只要提到喜歡的書，就會說得渾然忘我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……餐點已經送來了呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們就專心用餐吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說要再多聽我說一些關於書的事……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我好開心。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為我身邊的人都不太看書的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒有可以一起聊的對象。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以累積了「一大堆」讀後感還有想分享的事情呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我得馬上吃完飯回牧場去。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真要聊的話會聊很久……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n讓你一直陪我也很不好意思。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼？",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說你隨時都可以再來陪我……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝、謝謝你。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼我們就下次再見面吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "到時候，我會帶喜歡的書來借你看喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我每次來城鎮都會帶著書的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想說不定這樣隨身帶書走路，可以鍛鍊臂力……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要是{player}也喜歡",
        "unit_id": 103811,
        "voice": "vo_adv_1038003_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我所喜歡的事物的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會非常開心的。",
        "unit_id": 103811
    }
]