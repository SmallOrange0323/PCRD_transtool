[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "結婚之後就要找新家",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我終於也要",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "過上定居在一處的生活了啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為我至今一直在各地旅行，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以現在感覺很不可思議呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你已經和咲戀談過",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想要什麼樣的家了嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……嗯嗯，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也有好好考量到育幼院",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的孩子們呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你問我有沒有什麼需求嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n是指想要怎麼樣的房間嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是傷腦筋啊……",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我從來沒想過這件事呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對於一直在旅行的我來說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n只要有屋頂",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能夠遮風避雨就足夠了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真要說的話，",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可能會想要一間東國風格的房間吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是地板都鋪著塌塌米的那種房間。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是有鋪上塌塌米的房間",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就能好好放鬆了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n還可以盤腿坐著讀書、寫東西之類的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n小哥你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "習慣之後一定也會喜歡上的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其他就沒有什麼特別想要的了。",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "廚房和客廳",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就照咲戀的喜好來選，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n應該也不會有什麼問題吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "個人房間？",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……啊啊，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是指可以兩人獨處的房間嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不需要",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那種東西。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果我想和小哥你獨處的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我會準備好釣魚竿約你出去外面的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後就在河川邊垂釣，",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "悠哉地度過兩人時光。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "彼此肩靠著肩，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "靜靜地",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "耐心等待魚上鉤。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對你來說可能會覺得太無聊吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……謝謝你的理解。",
        "unit_id": 127612,
        "voice": "vo_adv_5128082_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "找上咲戀三個人一起去也不賴呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "無論是靜靜地釣魚，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還是熱鬧地釣魚，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該都會成為很棒的回憶。",
        "unit_id": 127612
    }
]