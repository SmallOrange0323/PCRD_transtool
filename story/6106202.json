    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミに相談したいことがあるにゃ！",
        "unit_id": 107911,
        "voice": "vo_adv_6106202_000"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お店に来てくれる猫たちのために、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫専用のメニューを",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n考えようと思うのにゃ！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "どんなのがいいかにゃ？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それは名案にゃ！　",
        "unit_id": 107911,
        "voice": "vo_adv_6106202_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "牛のお乳はお腹を壊しちゃう子もいるからにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nおっきな猫も子猫も、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "安心して飲めるメニューだにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "早速、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "【牧場（エリザベスパーク）】に仕入れに行くにゃ～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "にゃっ！？　",
        "unit_id": 107911,
        "voice": "vo_adv_6106202_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "なんて独創的なメニューなんだにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それなら、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ろうそくみたいに小魚をケーキに並べて差して……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "むふふ、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫まっしぐらの大人気メニューになるに違いないのにゃ～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "爪とぎし放題のプランにゃ！？　",
        "unit_id": 107911,
        "voice": "vo_adv_6106202_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それはみんな大喜びするにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n早速メニューに書いて……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "って、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お店がボロボロになっちゃうにゃ～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nキミ、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "この話はなかったことに……",
        "unit_id": 107911
    }
]