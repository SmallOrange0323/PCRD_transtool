        "voice": "vo_adv_1252004_043"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要開始忙著接待客人囉。",
