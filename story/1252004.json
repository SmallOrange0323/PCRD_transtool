        "voice": "vo_adv_1252004_037"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "導致動線重疊了嗎。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這確實會造成碰撞呢。",
