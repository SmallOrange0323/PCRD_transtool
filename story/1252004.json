        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但也不適合穿著圍裙到處晃啊。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話說回來，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_065"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "終於告一段落了呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然有一度",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還在想會變成怎樣，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過最後結果很不錯。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到事先準備的食材",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會全部用完……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然多虧於此我們也好好能休息，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但還是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有點可惜啊。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過同學們似乎都很開心，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是太好了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "特別是我和閣下的共同戰線",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "表現得令人驚嘆！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到我這樣的體型也能派上用場……",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "至今為止都以為這只是個缺陷，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來偶爾也能派上用場呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只有今天……",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也許我應該感謝自己很矮小這件事。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……當然，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只有今天喔？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說到感謝，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_070"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我反而",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該對閣下道謝呢。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n如果閣下不在的話，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "事情會變得怎麼樣呢……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要再次向你道謝。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不只是讓模擬咖啡廳重整旗鼓，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_071"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n讓我能夠用全新的角度看待事情。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也讓我完成了名為",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「全力享受青春」的",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "個人任務啊！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_072"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你又在謙虛了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這也是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下的作風啊。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過呢，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_073"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們稍微",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "慰勞一下自己吧？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以我",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "提議現在來辦個小小的慶祝會！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "場地當然就是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那間懷舊點心店！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "當然，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_075"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下你也贊成對吧？",
        "unit_id": 105331
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1252004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "兩位的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "合作真的很厲害呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n默契十足，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺完全就是夥伴了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且，",
        "unit_id": 190011,
        "voice": "vo_adv_1252004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果有稍微化解她的煩惱就好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我是覺得不用這麼在意也沒關係。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n小小隻的也很可愛嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過每個人的煩惱因人而異呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1252004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她似乎也做了各種努力，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得為她加油才行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了讓那孩子以後也能露出笑容，",
        "unit_id": 190011,
        "voice": "vo_adv_1252004_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要加油喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_080"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡是……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我剛才",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "睡著了嗎。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下也睡著了嗎？",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_081"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可能都累了呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "話說回來，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_082"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到我們連在夢裡還是在一起工作……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然是個奇怪的夢……",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_083"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感覺還不差。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然我剛才",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_084"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱怨被當成小孩子看待……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不過這個體型讓他們比較容易對我傾訴的話，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我就當作是我的優勢吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_085"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然剛才不小心睡著了，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在就必須全力以赴囉！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "最近",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_086"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只專注在前來諮商的人們，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今後",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還要致力於邀請大家成為公會成員！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要再麻煩你幫忙囉，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_087"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "{player}！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了回應莫妮卡的幹勁，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}用力地點著頭。"
