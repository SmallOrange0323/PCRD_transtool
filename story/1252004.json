    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "稍微往裡面一點，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n走廊那一側",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先維持原樣……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "多虧大家的幫忙，",
