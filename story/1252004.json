        "type": "dialogue",
        "name": "莫妮卡",
        "words": "久等了！",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_054"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這是",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你的蘋果茶！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這位客人點的",
