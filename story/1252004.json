[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走進店裡時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一個孩子正在和莫妮卡說話。"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這樣啊……",
        "unit_id": 111,
        "voice": "vo_adv_1252004_000"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我懂了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n如果遇到那孩子的話我會試試向他搭話的！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣就好。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對方一定會很開心。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯！",
        "unit_id": 111,
        "voice": "vo_adv_1252004_002"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n謝謝妳聽我說！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "歡迎隨時過來。",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "當然，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來買點心也可以喔。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你來啦。",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "{player}。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你問剛才的男孩子嗎。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他是來找我諮商的。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "前幾天走失兒童那件事",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "似乎在孩子們之間傳開了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡好像就被當成能夠理解孩子心情的懷舊點心店",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n而大受好評的樣子。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "煩惱這種事",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不只大人有，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "孩子們也會有煩惱。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n而這些孩子們也開始來這裡諮商了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然大部分都是一些小煩惱，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過聆聽也是很重要的對吧？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有時間的話我就會聽他們訴說。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "認真對待小孩子",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是年長者",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該做的。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為這裡是懷舊點心店。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以這也是接待客人的一部分。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "他們也有可能順便買點心吃，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n將來",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也有可能加入我們公會哪！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有點在意，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n孩子們有時候",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會把我當成同齡的兒童。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就像朋友一樣很容易就對我傾訴什麼的……",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣下，",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你從剛剛就很安靜，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n有話想說就說啊？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦？",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為我很小隻所以沒辦法……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可沒辦法當作沒聽見啊！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等一下！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給我道歉！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦……",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好像有東西在發光……！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 125212,
        "voice": "vo_adv_1252004_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼回事……",
        "unit_id": 125212
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "歡迎來到椿丘高中！",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡是模擬咖啡廳。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們有罕見的點心、紅茶、",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "花草茶應有盡有！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了今天，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們還準備了其他各種東西！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一定要來逛逛喔！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難得的文化祭，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這次的模擬咖啡廳企畫是我們全班一致通過的！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是都沒有客人會感到很落寞呢！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實地完成工作是一名優良軍人的職責。",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來吧，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "打起精神囉！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了不要輸給其他班，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再大聲一點！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "快，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下不出聲的話",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是不會有客人進來的喔？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感覺很好！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好──",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也來！！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "排隊隊伍已經這麼長了啊。",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n應該暫時先少招攬一些客人嗎。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "裡面的人也很忙的樣子……",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒問題嗎。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……你說要去看看狀況？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "麻煩了。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "你看你看，",
        "unit_id": 1,
        "voice": "vo_adv_1252004_024"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "這個模擬咖啡廳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "裡面很多人呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n聽說好像有很罕見的點心。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "多瑙波紋蛋糕……",
        "unit_id": 1,
        "voice": "vo_adv_1252004_025"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "蜂螫蛋糕……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n感覺名字都很不可思議，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "可是看起來都很好吃呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n進去……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "的話要排隊啊～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "這個",
        "unit_id": 1,
        "voice": "vo_adv_1252004_026"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "排隊要等多久？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不、",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_027"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不好意思。",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n現在",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正在確認，",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請稍等一下──",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔，",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來得正好！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n裡面",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "狀況如何？",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……這樣啊。",
        "unit_id": 105331,
        "voice": "vo_adv_1252004_029"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105331
    },
    {
