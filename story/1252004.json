    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "和座位數都能獲得改善！",
        "unit_id": 105331
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "可以讓客人進來了嗎？",
