        "type": "dialogue",
        "name": "同學",
        "words": "這樣啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "\n如果是莫妮卡的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "就算通道狹窄",
