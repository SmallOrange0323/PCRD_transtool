        "type": "dialogue",
        "name": "同學",
        "words": "為了讓他跟莫妮卡可以更方便行動，",
        "unit_id": 1,
        "voice": "vo_adv_1252004_061"
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "\n我來負責引導客人",
        "unit_id": 1
    },
