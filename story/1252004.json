        "voice": "vo_adv_1252004_050"
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "那個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "雖然增加座位確實很好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "\n但是通道空間也變小了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學",
        "words": "\n大家來回走動",
