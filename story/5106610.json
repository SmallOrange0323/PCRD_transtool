[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在拉菲和艾米的帶領下，{player}、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n依里、茜里及純走在充滿聖誕氛圍的蘭德索爾街道上。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105913,
        "voice": "vo_adv_5106610_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、依里小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "茜里小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有純小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大家聚在一起是怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 124112,
        "voice": "vo_adv_5106610_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可可蘿。",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哈囉～！",
        "unit_id": 124012,
        "voice": "vo_adv_5106610_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 124214,
        "voice": "vo_adv_5106610_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們現在在幫這幾位天使的忙。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們在街上四處轉轉，",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幫助實現大家的願望。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105913,
        "voice": "vo_adv_5106610_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也在幫忙嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是了不起。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對主人的溫柔",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到十分自豪。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "艾米，",
        "unit_id": 5512,
        "voice": "vo_adv_5106610_005"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳有感覺到嗎……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "有……",
        "unit_id": 8912,
        "voice": "vo_adv_5106610_006"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我感受到一股很強烈的願望的能量……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是可可蘿散發出來的嗎？",
        "unit_id": 124112,
        "voice": "vo_adv_5106610_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那麼強烈的願望",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "會是什麼呢？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好令人好奇呀～♪",
        "unit_id": 124012,
        "voice": "vo_adv_5106610_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你說是吧！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果妳有什麼願望的話，就說出來吧。",
        "unit_id": 124214,
        "voice": "vo_adv_5106610_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這幾位天使會幫妳實現願望的。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來",
        "unit_id": 105913,
        "voice": "vo_adv_5106610_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位都是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "優秀的天使呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "區區在下的願望……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好了，好了♪",
        "unit_id": 124012,
        "voice": "vo_adv_5106610_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳就說說看嘛！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 124112,
        "voice": "vo_adv_5106610_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這些孩子",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "來這裡就是為了實現別人的願望的。",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n妳就當作是幫個忙吧。",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣呀。",
        "unit_id": 105913,
        "voice": "vo_adv_5106610_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那在下就接受這份好意了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的願望是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望主人和",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位所有人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都過著健康快樂的日子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太、",
        "unit_id": 5512,
        "voice": "vo_adv_5106610_014"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太厲害了……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這是發自內心的強烈願望啊。",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "那麼，",
        "unit_id": 8912,
        "voice": "vo_adv_5106610_015"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "這個願望就由我……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "咦，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "奇怪？",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不知道從哪裡突然傳來了鐘聲？",
        "unit_id": 124214,
        "voice": "vo_adv_5106610_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳們看！",
        "unit_id": 124112,
        "voice": "vo_adv_5106610_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "天空照下來了一道光！",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 124012,
        "voice": "vo_adv_5106610_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "彩虹出現了！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "艾米，",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是怎麼回事呀？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "在動用天使的力量之前，願望就實現了，",
        "unit_id": 8912,
        "voice": "vo_adv_5106610_019"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "居然有這種事……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n什麼？",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "甚至還有天界傳來的訊息？",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "唔，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "「神會保佑妳的美好願望」……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "訊息是這麼說的。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這是",
        "unit_id": 5512,
        "voice": "vo_adv_5106610_020"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "什麼啊……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n感覺受到特定的神",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "賜予了特別偏愛的眷顧……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望",
        "unit_id": 105913,
        "voice": "vo_adv_5106610_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的願望可以實現……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她純潔的願望傳至天界，{player}一行人\n又再次盡到天使的職責。"
    }
]