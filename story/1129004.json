[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "璃乃終於恢復了自信。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而幾天後，她又急急忙忙地"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現在{player}面前。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥──哥──！",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不好了，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不好了啦！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妹妹陷入危機了！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該哥哥出場了！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你問我又有什麼問題，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次已經不是問不問題了啦哥哥！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再這樣下去",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "考不上設計師養成學校了！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在我的命運就好像風中山竹一樣！",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "根本是甕中之龜了～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽不懂嗎……？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姊姊竟然也說，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「璃乃比平常更璃乃了呢～」",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很過分吧！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……這句話是什麼意思啊？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總之，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你可能已經猜到了，不過！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這段時間",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我太專注在裁縫上了……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "──所以完全沒有念書！",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當我打開了久違的課本後，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "突然覺得",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "題目怎麼這麼難啊～",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我之前明明看得懂喔？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼辦啊哥哥！？",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好不容易有自信能夠通過術科了，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再這樣下去",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就要因為筆試落榜了啦～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉唉，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "前途一片睡翻～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼變亮了……？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是什麼啊～！？",
        "unit_id": 112912
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你今天",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n邀我一起念書，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒想到哥哥竟然會主動聯絡我，",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好開心喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……其實",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我本來以為是要邀我約會，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n又驚又喜又害羞的說。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但仔細想想，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也算是圖書館約會啊！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為什麼會突然說要念書啊？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道說",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我最近一直沉迷裁縫，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n沒有專心念書的事情",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被你發現了嗎！？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊？",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你早就猜到是這麼一回事？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不愧是哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這麼了解我！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……對不起，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會認真念書的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我真的知道快考試了要好好念書喔～！",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原本只是想喘口氣，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘗試一下裁縫，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但就是在這種時候",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "人會變得欲罷不能啊～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你想知道我在做什麼嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是一件有點複雜的衣服，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "完成之後",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會第一個給哥哥看的！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼我就",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "趕快回去繼續做裁縫囉～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……對喔。",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n好，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來念書吧……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊～",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不覺得有點餓嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來這邊的路上，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "外面有在賣",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看起來很好吃的可麗餅對吧！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "俗話說人是鐵，飯吃光，",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "先吃點甜食",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之後再開工吧～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……是～",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然念書是很重要啦，",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可是難得有機會跟哥哥兩個人獨處說～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……哥哥",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你應該要再多了解一下妹妹心。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不對，",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話不能這麼說。哥哥也是為了我好才約我出來的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難得來圖書館，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼可以不認真用功呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好～",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "專心專心──",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "──啊！",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你記得這個繪本嗎",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小時候",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你曾經唸給我聽過喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……",
        "unit_id": 101131,
        "voice": "vo_adv_1129004_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
