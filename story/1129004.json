    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……完全沒反應耶。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喂～",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再不起床的話，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就要惡作劇了喔～？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "戳戳。",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘻嘻……",
