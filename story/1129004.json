    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯──",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再這樣下去，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "根本念不了書了。",
