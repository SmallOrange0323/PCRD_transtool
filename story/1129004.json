        "unit_id": 112912,
        "voice": "vo_adv_1129004_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "念書還是要靠自己的力量才行。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不能一直依賴哥哥！",
