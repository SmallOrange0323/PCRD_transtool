    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妹妹遇到危機的時候，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "竟然睡得這麼香甜～！",
