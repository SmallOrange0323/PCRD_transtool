        "voice": "vo_adv_1129004_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才能抬頭挺胸和哥哥說",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n「我靠自己的努力考上了」。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣一來",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_070"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該也會很開心吧。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為了那一天的到來，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一定要努力！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要是為了哥哥，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可以忍住不吃充電用的甜食！",
        "unit_id": 112912
