        "type": "dialogue",
        "name": "璃乃",
        "words": "我要靠自己的力量努力念書，",
        "unit_id": 112912,
        "voice": "vo_adv_1129004_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n考上設計師養成學校。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
