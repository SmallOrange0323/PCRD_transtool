[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}走在城鎮裡時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽見了從草叢後傳來了年幼女孩子說話的聲音。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的命運",
        "unit_id": 1,
        "voice": "vo_adv_1110001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就到此為止了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我竟落得如此下場，",
        "unit_id": 1,
        "voice": "vo_adv_1110001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這可真是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n許久未曾過的探索之旅，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟會迷失了初衷啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n如此不幸早逝之事，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "故鄉的前賢師長們會予以原諒嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "回頭一瞧，我這一趟人生可謂平庸呀。",
        "unit_id": 1,
        "voice": "vo_adv_1110001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我就淨是躲在安然無慮的環境下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n一日復一日永無止境地細嚼著本本書卷。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如何呀？羅塞塔。",
        "unit_id": 1,
        "voice": "vo_adv_1110001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n時至今日，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我究竟為世間留下了些何物？",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "111000101"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯啊？",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n好像有人來了唷，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "羅塞塔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀……",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "儘管我孤高一世以至於辭世之際連個親友的送別都盼不得，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然而竟讓一名相見不相識的少年如此這般地替我送終，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想必這定是在偉大的意志下所連接而成的緣分吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "機會難得，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "少年。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n做為黃泉之路的餞別，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能否將你的名字告訴我呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你叫{player}呀。\n真是個好名字呢，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為了來世，得記下來才行。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "筆記筆記……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我叫優妮。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n過去曾在聖德蕾莎女子學院的「象牙之塔」中勤於學術，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如今只是彌留在此片無名之原野猶如風中殘燭的孤魂野鬼罷了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這青澀又惹人憐愛的容貌，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n或多或少會遭人誤會之事我也早已習慣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管因此常遇不便，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但此刻我就做為你的讚美之言收下了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是個困難的問題。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n儘管並非是能以一言以蔽之的生平，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n然而我也不是幼稚到會予以反駁的年紀了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在的我便是",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "處於非幼童也非成人的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "過渡時期。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是即將由少女蛻變成女人的化蛹時節哦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管與同年代的人們相比之下，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的發育似乎顯得略為遲緩就是了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我恐怕是比你還要年長呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你可以帶著",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敬意與友愛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n稱呼我為優妮學姐，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這也是身不由己呀。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n若是運氣不好，沒人對我伸出援手的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我這孱弱之身，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不用多久便會淒涼地斷送了這條小命吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話說回來，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓我們換個話題吧，學弟，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不知道你是否聽過「間接故意」這個詞呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "例如在嚴冬的寒冷之夜中，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有位酒醉的男子在路邊睡著了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n倘若有人經過了卻沒叫醒該名男子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使得他在翌日早晨被人發現\n凍死了的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼未叫醒他的人便是有罪……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是這樣的觀點。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，失禮了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不小心話題就扯遠了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這是個與恰巧通過的你",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "毫無任何關聯的話題呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "接下來就將一切託付給你那社會通念了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請多指教。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說我看起來有精神？",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "先不論我如此逼真動人地演得如此要死要活，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看起來有精神？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你是看到我那吹彈可破的臉蛋才這麼說的吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "眼見為真——",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不覺得人類差不多也該是時候推翻此一命題了嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管這僅僅是性格扭曲的我所提出的假設，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但我認為這個世界，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "本來就被覆上了一層虛偽。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "倘若如此，那麼擁有雙能看透本質的雙眼可是很重要的呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是我無時無刻都在找尋的答案。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我們活著，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n究竟代表著什麼意思呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換個角度想，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "或許你的問題，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "便是生命真正的本質也說不定。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "永遠無解的自問自答，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "才是我們人生的伴奏曲。",
        "unit_id": 111011
    },
    {
        "type": "still",
        "still": "111000102"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你一臉這傢伙在講什麼鬼的樣子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是我已經累到做什麼事情都提不起勁了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若要再補充幾句的話，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是我的肚子已經餓到腦袋沒辦法好好運作了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我現在其實是憑感覺在跟你說話。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以講實在的我也不曉得我在胡言亂語些什麼——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n很遺憾的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那便是這段毫無建設性的討論的真相。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以說呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你現在",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "手上是否有什麼",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能夠打從根本",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n解決這個虛無狀況的關鍵道具呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "舉個具體的例子來說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你有沒有正好帶著什麼能解決空腹問題的碳水化合物，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n亦或是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能夠一口氣解決疲勞的藥水等等的東西呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦、",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦哦！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這不是……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "最適合在肉體疲勞時拿來補充營養的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那個用氯化鈉醃製而成的穀物嗎！",
        "unit_id": 111011
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈呼……",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感謝你的招待。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀呀，這可真不好意思呢。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然我沒有這個打算的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但結果就像是我裝得要死要活，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後強迫你將身上帶著的食物分給我呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而還是多虧了你，我才能不費吹灰之力地活了過來。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "果然外出時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎還是有必要攜帶著固態的食物來攝取營養呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "進食啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是不分時代，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "全人類普世一同的行為呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我平時都只靠吃營養藥錠來維生喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你沒聽過嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是將營養物質萃取出來所製成的藥丸喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天我為了某個探索之旅，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以才難得出了趟門，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟平時我從早到晚都躲在「塔」裡呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若要說到運動量，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "頂多就是拿書提筆等不足掛齒的程度，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以也不太會餓肚子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說到底要花時間來進食我也嫌煩。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n哦？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說進食是件值得享受的行為嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的確如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼做能刺激味覺，促使腦內物質分泌，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n從主觀上來看，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不否認能將那一類的報酬視為欣快感喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過對我來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我沒有感覺過多少次那樣的事就是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個流言我儘管時常有耳聞，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而做為事例仍稍顯不足吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就我個人來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那不但並非是種安慰劑，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n甚至已經能算進玄學的範疇之內了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話雖如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你剛才的意見是一次罕見的反證素材。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n畢竟在「塔」裡，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可沒有人會像你這樣跟我唱反調呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "趁我還沒忘記之前還是先記下來吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "筆記筆記。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n啊啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正如我剛才所說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在學院中擁有學籍。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然而，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我和一般學生的狀況又稍顯不同。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此我不僅沒什麼機會能夠見到她們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更不用說是與她們交談了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n儘管和那些像傭人的教職員多少會有事務上的交談，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但想來我似乎已經很久沒有和像你一樣同年代的人閒話家常了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "先跟你致謝。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你對我所講的每句話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都能即時一一予以回應，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這是即便提交了一份份厚厚論文，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也得不到的有趣體驗。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你問什麼意思？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是呀，你也給我動點腦筋吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點就是有些令人難為情，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是說……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能和你說上話我很開心。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你說證明，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是證明什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這就是你所提倡的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「和其他人一起吃飯會更開心的說法」嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "被你反將一軍了呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "挺會耍小聰明的嘛，學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只不過",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該從何說起呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若要說那是事例的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不確定的要素實在太多了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比方說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n自從我離開故鄉了之後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "長時間一直以來皆是離群索居的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就算客觀上來看，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也很明顯地欠缺與人之間的交流。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "甚至是會將路旁的小石子",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "做為寵物來解悶的程度呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我說的對吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "羅塞塔？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從以上的事實來看，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可以得知現在的我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "非常地嚮往與人之間的往來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此我也無法否認，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "單單光是能與他人講上話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就能使我心情嗨翻天的這個可能性。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這股亢奮的心情，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在進食的行為上能發揮多少功用依舊是未知數。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若你是學會的一份子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我或許會要求你進行更多的驗證與觀察吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說到這個，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n剛才",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我說過，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我正在探索的途中對吧？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我正致力於進行某個考古學的自由研究，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換句話說就是在進行所謂的田野調查。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的目標是那傳說中的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一個被叫做「碧之深淵」的地方喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你該怎麼做才好呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就說了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你別再那給我東張西望了啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我是在問你的意願啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就再說一次唷。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如此孱弱的我隻身一人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正在一趟孤獨之旅的途中。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你該怎麼做才好呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_057"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你別再那給我東張西望了啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我正在詢問的是你的意願。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我並沒有惡意到擺出學姐的架子，強迫你非得與我同行。",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我至少會給你做選擇的權利。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要去還是不去，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就隨你高興來做決定。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話說回來，學弟，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n儘管與此事是截然不同的話題，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不過在極東的一個小島國，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像有著這麼一句俗諺。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "出外靠朋友，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "處世靠人情。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若大膽地講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n似乎便是「幫助別人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "超重要。」",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的意思呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "失禮，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我離題了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這只是一個毫無脈絡可言的冷知識罷了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110001_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就要獨自孤伶伶地重新開始這趟充滿危險的探索了唷？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你該怎麼做才好呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被那字裡行間無不滿溢著學姐架子的口吻所煽動，\n幾乎可說是沒有其他選項的{player}，\n便決定陪著她一起去探索。"
    }
]