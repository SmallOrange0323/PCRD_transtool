[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬就這樣氣勢洶洶地打倒了許多魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n其中有大半的魔物因為害怕美冬而逃走，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而迎戰美冬的最後一隻魔物也——"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是最後一隻了！",
        "unit_id": 104811,
        "voice": "vo_adv_7013005_000"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼。",
        "unit_id": 104811,
        "voice": "vo_adv_7013005_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "比我原先預想的",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還多花了些時間呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在我看來這些魔物是轉眼間就被收拾乾淨了……",
        "unit_id": 102611,
        "voice": "vo_adv_7013005_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這種程度還搆不上",
        "unit_id": 104811,
        "voice": "vo_adv_7013005_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我的高效率戰鬥水準呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看來雖然我以為已經充分地休息過了，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但身體還殘留著一絲疲倦的樣子。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，",
        "unit_id": 104811,
        "voice": "vo_adv_7013005_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們已經爬得這麼高了",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼會一點線索也沒有……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯？　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是什麼？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼有個奇怪的石頭。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n難道是從逃跑的魔物身上遺落的嗎。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個石頭的確很奇怪。",
        "unit_id": 102611,
        "voice": "vo_adv_7013005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然看起來不像是寶石之類的東西，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但搞不好",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這就是你記憶的線索之類的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇哇！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "突然間有道光！？　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這道光是怎麼回事！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我",
        "unit_id": 104811,
        "voice": "vo_adv_7013005_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也不知道！！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這是怎麼回事？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你、",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你等一下！　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你想想辦法嘛～～！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們還是回去吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n外行人做的紅豆麵包",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼可能賣得出去嘛。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且，",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼我得做這種事啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在義賣市集裡",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "賣自己的手工麵包這種事，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比去學校上學",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "的難度還要高耶。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你要我怎麼放心？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我在說",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不想出現在人群面前欸。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你的意思是說",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們跟客人的往來只限於今天，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以比上學的難度還要低是嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對吧、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這件事的麻煩程度",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是一點都沒有改變喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果你說除了做麵包以外",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其他雜事工作你都會負責的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那我倒是無所謂。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就假裝",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在那邊晃一下，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "等等就自己回去囉。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊、",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你啊！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我等了半天你都沒來，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所以我就來找你了！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？　",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她是誰？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀？　",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "難不成",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳就是",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "鈴？",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是啊……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是鈴",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒錯。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳怎麼會",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "知道我？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為我聽說有個女孩會製作好吃的紅豆麵包。",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以我就跟他提議說",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要不要",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "試著在市集裡賣賣看。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊、",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "抱歉！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我還沒自我介紹呢。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我叫大神美冬。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n因為打工那邊的人拜託我來幫忙，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所以由我負責這次市集的營運委員會。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n請多指教。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "請多多、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "指教。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然這傢伙",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟妳說很好吃，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n說到底",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也只是外行人做出來的麵包而已喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這次參加市集的人全都是外行人，所以請放心吧。",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "說得也是，如果賣的是外行人做得難吃的麵包",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那可就行不通了。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我可以",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "試吃一個看看嗎？",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝。",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "等一下、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你們不要擅自進行下去啦！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "外表確實看起來很好吃呢。",
        "unit_id": 104831,
        "voice": "vo_adv_7013005_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那我就",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "開動了。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊呣。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯、",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔呣……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這、",
        "unit_id": 102631,
        "voice": "vo_adv_7013005_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這種東西根本不能賣錢的吧！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會乖乖回去的。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n哎呀～真是可惜啊～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "美冬",
