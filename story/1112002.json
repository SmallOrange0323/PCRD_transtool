    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被禊叫來\n神秘森林的{player}，\n見到了不知為何掉到洞穴裡的禊。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "救我――！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一個人沒辦法爬上去～！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "謝謝你，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你說怎麼可以掉到自己挖的洞穴嗎？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不是喔～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個不是禊挖的哦～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是很久以前有人挖的樣子，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "剛剛完全沒注意到呢～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過不過！　",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "在洞穴裡發現了這樣的東西哦！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是信？　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還有古老的地圖！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n雖然信裡的文字斑駁得看不清楚，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但地圖的部分卻看得很清楚！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為好像有叉叉的記號，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以一定是藏寶圖哦！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個地方……",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是墳墓",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗎？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "走吧！　哥哥！",
        "unit_id": 111211
    },
    {
        "type": "background",
        "background": "500530"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然來墳墓裡看看了，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "卻什麼都沒有呢～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥有發現什麼嗎？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "記號的地點還在更前面？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真的呢！　",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "再前進一點看看吧！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這裡也什麼都沒有啊～！！",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n好像不過就是堆積了很多石頭嘛～！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這張地圖是不是只標記了",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "墓碑材料的地點呢～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣的東西好無～聊！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！？",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n從石頭後面冒出魔物！？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "等、",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "等一下！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊現在用摔炮趕跑它！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n嘿～～！！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太好了～",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n魔物",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "逃跑了。",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那個魔物，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像掉了什麼東西。",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "發光的",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "石頭？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你看魔物逃跑的方向？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！　",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "掉了好多發光的石頭！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "該不會，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n地圖上的記號",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是指可以拿到這個石頭的地方？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個石頭是什麼呢～？",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看起來不像是寶石呢～？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "信裡嗎？",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "字幾乎都看不到了啊――",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過收件地址好像還能看清楚！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯――？",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這個收件地址，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "該不會是……",
        "unit_id": 111211
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "果然！",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是禊常常去買惡作劇道具的店！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "怎麼了怎麼了，",
        "unit_id": 611,
        "voice": "vo_adv_1112002_019"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "發出那麼大的聲音。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊啊，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這不是常常來光顧店裡的小妹妹嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "老婆婆！　",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊啊，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "今天在墳墓裡撿到發光的石頭，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為不太知道是什麼，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就拿過來老婆婆這裡了！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然不太懂妳在說什麼……",
        "unit_id": 611,
        "voice": "vo_adv_1112002_021"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯？　",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "怎麼了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這位小兄弟。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n小妹妹掉到",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "森林裡古老的陷阱，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "並發現了地圖和信，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n靠著上面的線索來到我這裡的意思嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哪個，",
        "unit_id": 611,
        "voice": "vo_adv_1112002_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "拿來讓我看看。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "來，",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是這個哦！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還真是讓人懷念～",
        "unit_id": 611,
        "voice": "vo_adv_1112002_024"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這張地圖和信",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是我丈夫寫的東西唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小妹妹掉進去的洞穴",
        "unit_id": 611,
        "voice": "vo_adv_1112002_025"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "應該也是我丈夫挖的吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n因為在年輕的時候東挖西挖",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "製造了很多陷阱，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也埋了很多東西呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "對小妹妹",
        "unit_id": 611,
        "voice": "vo_adv_1112002_026"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "做了不好的事呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "沒有受傷吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒事喔！",
        "unit_id": 111211,
        "voice": "vo_adv_1112002_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且因為玩得很開心，",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以禊不在意唷！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是嗎？　",
        "unit_id": 611,
        "voice": "vo_adv_1112002_028"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝妳，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小妹妹。",
        "unit_id": 611
