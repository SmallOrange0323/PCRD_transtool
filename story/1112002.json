    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然不是什麼高貴的東西，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n只是在萬聖節",
