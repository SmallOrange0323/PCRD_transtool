    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管明天還是後天，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都～能這樣和樂融融在一起吃飯呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以",
