[
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}～！",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終於找到你了！　",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愛梅斯小姐，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然有告訴我們{player}你在這裡就是了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你在這裡做什麼呢？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不應為『愛梅斯小姐』，",
        "unit_id": 105931,
        "voice": "vo_adv_2012011_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請以『愛梅斯大人』來做稱呼吧，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼嚴格！？",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之這事先放一邊，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "瞭望台對吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "景色真棒～！　",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然聽說這裡",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是『真正的現實』，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但所有的東西感覺都沒有看過呢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像『王宮』一樣宏偉的建築物蓋了一大堆唷！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是在觀光一樣的心情可不行呢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還得要找到小凱留才行。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105931,
        "voice": "vo_adv_2012011_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人所見的方向，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有看起來像凱留小姐的人唷！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說『看起來像』，",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼要講得這麼曖昧……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦？",
        "unit_id": 105831
    },
    {
        "type": "still",
        "still": "201201101"
    },
    {
        "type": "dialogue",
        "name": "凱留？",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_2012011_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的看起來像小凱留！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一個除此之外沒得解釋的女孩子，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "站在瞭望台柵欄的另一邊呢！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在、",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在那種地方究竟在做些什麼呢？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來像小凱留一樣的妹妹！　",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很危險的唷！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n站在那種地方不小心滑一跤的話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可就頭下腳上掉下去了喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成是厭於世，",
        "unit_id": 105931,
        "voice": "vo_adv_2012011_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此打算一了百了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若隨便地去搭話",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而驚動到了她，或許就真會摔落了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人才只能於此處見著而別無他法呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該、",
        "unit_id": 105931,
        "voice": "vo_adv_2012011_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之，",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們先慢慢接近她！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在看準時機",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起把看著像是小凱留一樣的妹妹抱起來，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拖到柵欄的這一邊……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看起來像小凱留的妹妹看著的那個方向，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像有著不可思議的東西唷……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個是，",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾的……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們常去的那家餐廳吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但該說是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "景色有一點不太對勁嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺像是有異物混在裡頭喔！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105931,
        "voice": "vo_adv_2012011_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "餐廳之中",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有我們一行人的身影！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐的記憶……？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那樣子的可能性很高呢。",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我全部都",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "記得喔……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和大家一起",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開心地聚在餐桌前的回憶，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都沒有忘記。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是……",
        "unit_id": 105831,
        "voice": "vo_adv_2012011_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒記錯是大家",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起去幫忙割稻之後，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃著用當作報酬讓我們帶回來的白米",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所做出來的料理――",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯哈，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃～☆　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自己用自己所收穫的東西做成料理來吃，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這真的是最棒的享受了唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我嚼我嚼我嚼！",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可是經過太陽公公充分的日曬，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且吸收乾淨的水所長大的嘛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "簡直就是米界的公主殿下！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像公主殿下一樣的米飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "簡稱公主米……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "公主米是什麼鬼……",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎樣都好隨便妳但別給我邊吃邊說話啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳噴了一大堆飯粒過來呀！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2012011_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如凱留小姐所說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您這樣可不成體統唷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是～",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想和大家聊天啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想把這多麼美味的感想分享出去呀！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但也因為這樣",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就不得不停止吃東西，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "顧此失彼就是這個意思呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "假如我全身上下都有一大堆嘴巴就好了呀……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一個就夠了好嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘴巴這玩意兒。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全身長嘴巴是哪樣的魔物啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在的妳也充分地",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像是魔物一樣就是囉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好過分！　",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留總是說一些捉弄人的話啊～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀，真有那麼像魔物嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2012011_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同魔物一般具有旺盛的食慾，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐之述是以此意在稱讚您的唷♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇耶～",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被稱讚了耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好開心～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一樣超級喜歡小凱留的喔～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩死了！　",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別不管怎樣都要抱上來啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我才沒有在稱讚妳！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果真的放著",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看到啥就吃啥的妳不管，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就好像會引發糧食危機嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不幾乎和魔物沒兩樣了嘛！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才沒辦法吃那麼多的唷。",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是我還是分得出來什麼該吃什麼不該吃的喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就我一個人全都吃光了也沒意思嘛，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以有好好地把大家的份都留下來了唷～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看！　",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我借了店內的廚房",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做了各式各樣的料理呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n別客氣儘管吃吧～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再怎麼說主角可是米飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主米……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是不管怎樣，",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都真心想讓那個奇妙的稱呼固定下來嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2012011_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也許是想要做為",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一種品牌米來販售嘛。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並且實際上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可真是相當美味的白米。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知是否是因炊飯技術良好的緣故，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這米越嚼越回甘呢……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_2012011_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您也好好地嚼過以後",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再「吞」下去唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請隨著在下的動作一同，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚼嚼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚼嚼♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "母子嗎！",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們倆感情還真好呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都讓人有點無言了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2012011_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很令人羨慕對吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點也不～",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來就不是很喜歡和人黏在一塊的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我家裡的人",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是放任主義的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也從來就沒有被人給抱過嘛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以看起來很怪的應該是你們不是嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？　",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明是家人卻不擁抱才奇怪吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "算是替你的雙親由不成熟而……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子餓得咕嚕咕嚕叫的貪吃佩可來好好抱抱妳吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱抱♪",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎樣呀小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開心嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不要生氣氣了嘛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳那嬌滴滴又可愛的笑容就讓我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘛～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吼呦，",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就說妳很煩了啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話說",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那白飯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "冷了就會硬掉囉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以趁還熱騰騰的時候趕快吃吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說的對呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可惜了可惜了……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……雖～然怎樣都沒差。",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但這飯，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也一次煮得太多了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先不講妳這傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們幾個可是沒有辦法吃完的喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們把吃剩的就都做成飯糰吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果加了酸梅的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大概撐到明天早上都沒有問題嘛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算搗碎了做成炒飯也是絕品唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食譜，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等等告訴妳唷♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我到小凱留妳家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幫妳做吃的也沒關係的唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是不要來我家比較好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼呀，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳就連家住在哪裡都不告訴我們呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明我們感情都已經這麼好了，",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是愛搞神祕的少女呢……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……如果妳知道了真相的話，",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳一定",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會討厭我的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2012011_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說什麼？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳再說一次吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛太吵了我沒有聽清楚！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒～事。",
        "unit_id": 106012,
        "voice": "vo_adv_2012011_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼都沒有……",
