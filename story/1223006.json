[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受伊莉亞的蝙蝠呼叫，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了古城。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}。\n等你很久囉。",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_000"
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀噗呀……！",
        "unit_id": 8311,
        "voice": "vo_adv_1223006_001"
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚咿……！",
        "unit_id": 8311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是這點！",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身就是想談這件事！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先是事情的來龍去脈……",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把班比從故鄉擄走的「伯爵」，",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身已經得知他的所在地了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是棟叫做「受詛咒之館」，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "本身有些問題的宅邸。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也順便調查了他本人……",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "據說伯爵出了名地討厭人族，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對魔族非比尋常地崇拜。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不僅接觸可疑的魔法、",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n身邊帶著魔物，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "甚至──",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還投入所有的私人財產，",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "挖掘調查遺跡。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而那些也都是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "過去魔族的據點。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "他是從那裡將班比…………",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還不能確定真是如此。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總之妾身",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想說先只告訴你，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才在這裡等你的……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到班比卻先向妾身的蝙蝠們問出來了。",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然後……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_011"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要去和伯爵談談！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n晚餐前就會回來了！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "幫班比跟僕從說一聲唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……就是這樣。",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身還沒能來得及阻止，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她就跑出門了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚……",
        "unit_id": 8311,
        "voice": "vo_adv_1223006_013"
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀噗呀嗚……",
        "unit_id": 8311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "貝斯。",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n連你們也被丟下，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或許會不禁悲嘆……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但那女孩可能是努力考慮過，",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才故意不帶你們去的哦。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為對班比來說，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們是特別的啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚──！",
        "unit_id": 8311,
        "voice": "vo_adv_1223006_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就知道你會這麼說。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒辦法。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都在一條船上了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也助你們一臂之力吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然決定了，",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就使出很久沒用的轉移魔法吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……但是，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為轉移三位會有困難，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只能讓兩名前往。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……所以。",
        "unit_id": 104412,
        "voice": "vo_adv_1223006_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來這裡……",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伯爵──！",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_020"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n現在馬上出來見班比！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "在那裡的",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_021"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "該不會是……",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你就是伯爵？",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_022"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比有話",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要跟你說！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比已經知道了，",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_023"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n是你綁架了班比！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "雖然不知道你為什麼這麼做，",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_024"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n但因為你做了壞事，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以要先跟班比道歉！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "…",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_025"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "…唔！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……幹嘛？",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_026"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n一直盯著班比看。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "…………請、",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_027"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "請？",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_028"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "請",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_029"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "收我為僕從吧！！！！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "咦咦咦！？",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_030"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n為什麼突然……？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "我",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_031"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "很崇拜崇高的古老魔族！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "若能遇見適合的主人，",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_032"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "我想捨棄汙穢的人族身軀，",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "以僕從的身分重獲新生……",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "這是我一直以來的願望！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "然後我",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_033"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "終於遇見了！！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "我在據說是吸血鬼生活過的城堡遺址中……",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_034"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "發現了耀眼的透明箱子裡，",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "與龍一同沉睡的妳！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "咦？",
        "unit_id": 122311,
        "voice": "vo_adv_1223006_035"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "「遺址」……？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "而後我",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_036"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "為了迎接妳，",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n準備了這棟宅邸！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "接著就只要等待妳的到來，",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_037"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "明明滿心期待的……",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "當我聽到妳從馬車裡消失時，",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_038"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "我陷入絕望。",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "\n",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "但妳卻甦醒了，",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "並且來到我面前！",
        "unit_id": 2513
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "這一定就是……",
        "unit_id": 2513,
        "voice": "vo_adv_1223006_039"
    },
    {
        "type": "dialogue",
        "name": "伯爵",
        "words": "命運！！",
        "unit_id": 2513
    },
    {
