[
    {
        "type": "background",
        "background": "502130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天的克蕾琪塔為了確認古代遺物引起的騷動"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n所造成的損害而四處奔波。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉……",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒有人員受傷，也沒有造成過大的損害，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n雖然活動可以正常舉辦沒問題，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但果然沒辦法說是毫不受影響呢……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "壞掉的東西僅止於裝飾品倒是不幸中的大幸吧。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要馬上找到替代品",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在有些困難……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無論是在預算上還是期限上。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果想準備和之前一樣",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或是同等級的裝飾品，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n似乎會花上不少時間……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "又或者乾脆大膽一點，徹底換成別的風格或許也是一個方法。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦，",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼有人用玫瑰把毀損的地方裝飾起來了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n漂亮地把痕跡都藏住了呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到底是誰……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就我所知，",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會做這種事情的就只有一個人。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我說得沒錯吧？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「獨眼惡魔」。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "原來早就露餡了嗎。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不愧是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "克蕾琪塔‧凱許。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n自溫泉那時以來就不曾見過了吧♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算妳誇得好像我說出了名推理一樣，我也不覺得高興。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只要是認識妳的人，不管是誰都會先想到妳吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n除了妳",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒有別人會做這種事了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼為了獎勵妳答對，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我就送妳一點福利吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有這麼多玫瑰花的話，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不管是想遮住毀損的部分，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還是重新布置新都能派上用場吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如何？",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "配色方面",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也可以弄得接近聖誕節的氣氛喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "外觀看起來也會顯得十分豪華。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "甚至也有聖誕花圈。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要像這樣把壞掉的裝飾替換掉……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……還不賴呢。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n看起來亮眼又散發著成熟的氣氛，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我覺得不錯。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我該付妳多少錢才好呢？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "錢這點小事不用在意啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我跟妳都這麼熟了不是嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我不記得我有跟妳熟到哪裡去啊。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也不是聽到「免費」",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就會感到開心的那種可愛小女孩。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "快把價格告訴我吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我就是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喜歡妳這點喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那就恭敬不如從命，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請妳支付報酬給我吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "用以物易物的方式可以嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都這個時代了怎麼還會有人選擇貨幣以外的交易方式啊……",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "製藥的材料的清單",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對吧？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且還是相當少見的……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都是一些取得不易的材料。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以我才想仰賴妳身為商人的人脈。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這點東西我馬上就能弄到手……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我很想這麼說。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但能拜託妳等到聖誕節活動和事後的收拾工作結束嗎？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n很不巧，我目前的行程滿到不能再滿了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明是難得的聖誕節，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳卻要埋頭工作，真是寂寞呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那句話",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我原封不動的還給妳。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太令人心寒了。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然我才剛拜託妳幫我找製藥的材料沒錯，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但我的出發點只是單純想幫妳的忙喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我自己也很期待活動。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……等一下。",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n難不成妳是在憐憫我？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼會。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳才不是會對一個人過聖誕節而感到寂寞的人吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是100％單純的支持。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過，",
        "unit_id": 128011,
        "voice": "vo_adv_5132066_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "密醫可沒立場這麼說我吧……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "黑心商人可沒立場這麼說我呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊啊，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n除了材料之外，我還想請妳幫我準備這個。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "全部準備齊全了之後再過來通知我吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5132066_024"
    },
    {
        "type": "dialogue",
