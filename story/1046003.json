[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}被珠希叫出來，\n來到市區的大宅邸旁。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝你來喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天有點事想跟你說喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你知道，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n最近在這附近出沒的，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n義賊・幻影貓的事嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你不知道嗎？",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鋤強扶弱的美少女義賊……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "人稱幻影貓……！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "她的真正身分到底是誰呢喵……！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵―！ 誰是大叔啊喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咳、咳咳，她一定不會是大叔的喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "奇蹟般的可愛，身材超好，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n性格超棒的美少女……？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就、就算你抱有這樣的期待，那個……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總、",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我聽說幻影貓是位可愛的美少女義賊喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……不過，說到義賊……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你對義賊有什麼看法呢喵……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "她只盜取壞人的錢財，是正義的小偷……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "假設喵，那個義賊出現在你眼前的話……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、那樣不行喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你這樣不是更壞嗎喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你、你真的要說得這麼決絕嗎喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……果然不能輕率地表露身分喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就算是你……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "算了，先不說這個。",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實我今天是有事要和你商量，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n才找你出來的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這間宅邸是在街上做貪圖暴利的高利貸，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n被稱為惡德伊之家喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "他從好人身上非法奪取財產，中飽私囊……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一定是即使受到義賊的懲罰也不足為惜的傢伙喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……那個……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這和剛剛說的話題無關喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天接下來這條逃生路線……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咳咳，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你要不經意地看守這裡，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不要讓人通過這條路喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你問為什麼喵？ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那個……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想練習被人看見的話",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n會很害羞的魔法喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今晚公會的大家都走不開……",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n拜託你啦喵！ 我能拜託你嗎喵……？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的嗎喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你願意幫忙嗎喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不愧是你喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n果然是我看中的人喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，在我回來之前，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你就在這裡看守喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "拜託你了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵ー！ 大豐收，大豐收♪",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "久等了―，喵！ 謝謝你在這裡看守喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在意這種小事可是不行的喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，我在這裡已經沒事了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n快點走吧喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你要發呆到什麼時候喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不快點逃走的話會被發現的喵……呃呃。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也已經很晚了，不快點回去的話會很危險喔喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎呀，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "已經來到岔路了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天就這樣吧……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，我忘了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝你今天陪我喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這是謝禮喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是我打工的地方提供的食物，",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "綜合鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "非常好吃喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我想你一定也會喜歡的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，再見喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046003_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天真的非常感謝喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}目送著心情愉快的珠希離開。\n隔天，幻影貓出現的新聞，\n在蘭德索爾引起了騷動。"
    }
]