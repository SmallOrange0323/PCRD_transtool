[
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──哦，",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "好硬好硬。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "比外表看起來還要堅硬……",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "像金剛不動明王一樣威猛呢。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711,
        "voice": "vo_adv_9077156_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳才是。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n從小小的身體，根本沒辦法想像妳有這等怪力……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只能用「驚人」來形容了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……所以，",
        "unit_id": 106011,
        "voice": "vo_adv_9077156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這兩個人還在打……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100511,
        "voice": "vo_adv_9077156_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n順帶一提，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那隻魔物被捲進戰鬥裡，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n早就被打飛了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_9077156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們兩個──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我消停一點吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要去跟貪吃佩可還有薇歐莉特打小報告了喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔！？",
        "unit_id": 104711,
        "voice": "vo_adv_9077156_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n等等",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "凱留──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "別東張西望！",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "──啊啊！？",
        "unit_id": 104712,
        "voice": "vo_adv_9077156_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 100511,
        "voice": "vo_adv_9077156_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n純的頭盔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……嘖。",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……！？",
        "unit_id": 104712,
        "voice": "vo_adv_9077156_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n剎鬼……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不繼續攻擊我？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看妳在戰場上露出破綻，",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我忍不住給了妳一擊──",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是妳的面具掉下來的瞬間，",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "連鬥志都一起沒了。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就算打倒這種沒骨氣的傢伙，",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也沒什麼意思。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……還有，",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n那東西很適合妳。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n既然適合就沒必要拿下來──",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "來，",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "拿去吧。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剎鬼……",
        "unit_id": 104711,
        "voice": "vo_adv_9077156_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳的面具，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也很適合妳喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦……",
        "unit_id": 100511,
        "voice": "vo_adv_9077156_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這就是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "透過面具結交的友情！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n兩個人終於找到，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只有同為戴面具的人才能理解的羈絆。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純的那個不是面具，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是頭盔啦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種東西怎麼可能",
        "unit_id": 106011,
        "voice": "vo_adv_9077156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會生出什麼羈絆啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了妳們兩位，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然結束了就快點回去──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "妳在說什麼蠢話。",
        "unit_id": 135913,
        "voice": "vo_adv_9077156_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n怎麼可能在這種半調子的情況下結束。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──是吧，",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "團長啊！",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……！",
        "unit_id": 104711,
        "voice": "vo_adv_9077156_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n作為【王宮騎士團】的代表，我的能耐",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要是被人以為只有這種程度就頭疼了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要上了喔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剎鬼……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦──！？",
        "unit_id": 100511,
        "voice": "vo_adv_9077156_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼還要打架啊！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不是已經透過面具萌生出友情了嗎！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106011,
        "voice": "vo_adv_9077156_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼喵──！",
        "unit_id": 106013,
        "voice": "vo_adv_9077156_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦──！",
        "unit_id": 100511,
        "voice": "vo_adv_9077156_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n凱留妳的面具",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是從哪裡拿出來的啊！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算戴上面具也不會有什麼羈絆啦",
        "unit_id": 106013,
        "voice": "vo_adv_9077156_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只會讓視野變狹窄而已吧",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n說到底戴面具的傢伙根本都很亂來啊！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我轟飛妳們，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "格林炸裂～！！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純、剎鬼",
        "words": "──啊啊啊！！？",
        "unit_id": 1,
        "voice": "vo_adv_9077156_023"
    }
]