    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽我講件事好嗎──？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了？",
