    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過不能很常用就是了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "放心吧。",
        "unit_id": 109811,
        "voice": "vo_adv_6017306_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我不會對你使出這個魔法。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "除非你與拉姆為敵。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是當然。",
        "unit_id": 109811,
        "voice": "vo_adv_6017306_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "我可是拉姆。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n既然這樣，你想不想親眼見識一下？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "開玩笑的啦。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n請你不要用那麼興奮的眼神看著我。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然我不曉得你腦中有什麼想像，",
        "unit_id": 109811,
        "voice": "vo_adv_6017306_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過肯定跟巴魯斯差不了多少吧。",
        "unit_id": 109811
    }
