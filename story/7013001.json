[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬和{player}意氣風發地踏入露娜之塔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n才發現到處不見鈴的蹤影。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？　",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "鈴？　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳在哪裡？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n喂～",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "鈴～！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "…………不在這呢。",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n應該不至於這麼快就走散吧，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還是她決定掉頭回去……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "之類的？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "說得也是。",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真的要回去的話，剛剛早就回去了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們再仔細找找吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真的到處都沒看到她耶。",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "其他還沒找過的地方",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就只剩塔的上方了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你認為鈴已經先出發了嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然我不覺得有這個可能性，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過她也不是那種會默默消失的人是吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯～",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不管怎麼樣，要找回你的記憶還是得登塔，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一邊爬上去一邊找也比較有效率！　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "向前進吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哇、",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "馬上就出現了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "擋路！　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "喝啊啊啊啊啊！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "比想像中還要弱耶。",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "照這個樣子就算只有我一個人也可以想辦法應付呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼！　",
        "unit_id": 104811,
        "voice": "vo_adv_7013001_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就讓我們有效率地前進吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_009"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼好像",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有好多魔物……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼辦……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺光靠我一個人根本無法打倒它們……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～～～～……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "乾脆來睡覺好了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不！　",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不行不行！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再怎麼樣也不能這樣做吧！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡到底是塔的哪個位置啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那裡有樓梯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n看來沒有辦法再往上，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就只能往下走了吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底要走幾層才能夠回家呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "魔物好像沒有注意到我的存在。",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "照這樣看來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要避開牠們偷偷前進也不是很困難的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就這樣順利和他們兩人會合，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就再好不過了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～～",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒想到平時瞞過真陽在牧場裡偷懶的技巧",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n竟然能派上用場～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "人生真的是沒有沒用的經驗呢。",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以後我也要",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "繼續這樣拚命偷懶下去。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "——咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇！？　",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好險好險。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一不小心差點被魔物給發現了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我得小心前進才行。",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟魔物戰鬥這種事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才不幹呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～～～",
        "unit_id": 102611,
        "voice": "vo_adv_7013001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好想趕快回家吃橡果喔……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "獨自陷入危機的鈴。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n究竟能否平安和{player}他們會合呢？"
    }
]