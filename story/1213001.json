    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這次即將於牧場上演的舞台劇，由胡桃負責撰寫劇本。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幫忙完牧場的工作之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她雖然在書桌前準備提筆奮鬥，但卻遲遲沒辦法下筆。"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔……",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唉，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不行。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "完全沒有靈感……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然美咲給了我很大的支持，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但我真的辦得到嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "當時我覺得自己應該可以，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但看來",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我還是沒辦法……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想在舞台上表演、",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呈現的東西……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然有很多……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但我最想做的，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是用戲劇來鼓舞大家。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "帶給大家感動，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓大家鼓起勇氣，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n努力迎向未來……！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我沒辦法這麼快就想到",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "該寫什麼故事。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……嗚嗚～",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大家都在",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "等我。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我得好好",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "加油才行……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……呼、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呼……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……呼、",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呼……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "奇怪？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "睡著了嗎……？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對了，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我在想劇本……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……這條毯子，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是誰幫我蓋的……？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……？",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你為什麼在這裡……？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "物產展的準備工作還沒結束，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以才留下來……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是這樣嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……忙到這麼晚，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真是辛苦你了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你中午需要打工，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "之後又來陪我們。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "工作到這麼晚……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n千萬要注意身體，別太操勞了哦……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n……那這條毯子",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是你拿來的嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "原來是這樣。",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝你。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你之所以",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會照顧我，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n應該不是出於工作上的原因吧……？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀哇！？",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n別、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "別摸我的頭……！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我知道了啦，你沒有把這當成工作！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀啊，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "頭髮全都亂掉了，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不能再摸囉！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你說，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小孩子該睡覺了……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "的確是",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣沒錯……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過我現在",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在寫戲劇的劇本。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只是一直遲遲沒有進展……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才需要熬夜。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒關係，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不需要了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我還要再",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "努力一下",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "問我會不會睡不夠？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "剛剛有睡了，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以沒關係♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "話說回來，哥哥。",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你不是很累了嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n中午打工完之後，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還一直工作到現在。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那先",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "別管我了……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請你坐在這裡♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我現在馬上幫你泡",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "特製的可可。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n又甜",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "又加了很多牛奶，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "喝了馬上就能消除疲勞哦。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我想答謝你幫我蓋毯子。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鍋子鍋子……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n啊，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鍋子好像不見了？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我記得備用的鍋子",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就在這附近……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有了，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "找到了♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "砂糖罐在這，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可可粉在這……♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把牛奶加熱，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "再輕輕",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "攪拌……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "拌好之後，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "消除疲勞的",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "香甜可可就泡好了♪",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "來，",
        "unit_id": 121311,
        "voice": "vo_adv_1213001_027"
    },
