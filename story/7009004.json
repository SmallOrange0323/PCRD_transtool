    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不知不覺",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "走到很深的地方了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n說起來，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒有找到什麼奇怪的東西就是了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是呢。",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生記憶的線索，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該不會不存在吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一開始就很在意了，",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步稱呼",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "王子先生的這個叫法",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真不錯呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也想",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "試試看呢",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n稱呼{player}",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "王子陛下之類的……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果我這樣叫",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會願意",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "回應我嗎……？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "王子、",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "陛下……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀―！　",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "回應了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能這麼自然的回覆，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是被叫得很習慣了呢……！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉、",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n難不成",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳想把王子先生從人家身邊搶走嗎！？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不會把王子先生交給妳的呦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊！",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不是妳想的那樣，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我只是想叫叫看王子陛下。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為像我這種人，對開口叫王子陛下的事",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "十分憧憬呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪。",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n「我這種人」，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是不能說的喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪可是",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國裡",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "高貴的獨角獸呢！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要多點自信才行！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我可不是真步真步王國的子民啊～！！",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "再說，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我什麼時候說要當獨角獸了啊～！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然覺得莉瑪",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會是很出色的子民……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但如果目標是王子先生的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是和人家爭奪王子先生的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n敵國的公主了呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "從子民",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "升格到了公主……！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這不是飛黃騰達了嗎！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太高興了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪公主",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是打算用那軟綿綿的毛皮",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來誘惑王子對吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可不會輸的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n莉瑪公主的挑戰，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不正面迎擊可不行……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪公主和真步公主不得不戰鬥嗎！？",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣不行啊！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n總之以和平為基礎，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在外交層面上解決吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "既然決定了，",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家不會輸給莉瑪的呦，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不先找到王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "記憶的線索",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可不行呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105211,
        "voice": "vo_adv_7009004_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n變成這種競賽了嗎！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為是為了王子先生努力，",
        "unit_id": 101011,
        "voice": "vo_adv_7009004_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請不要看漏了喔～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莉瑪和{player}一臉困惑的跟著"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n率先邁開腳步的真步。"
    }
]