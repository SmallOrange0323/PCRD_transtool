        "name": "好朋友社",
        "words": "不是，",
        "unit_id": 1,
        "voice": "vo_adv_5140101_041"
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "你們的腦袋是切嚕了嗎───！！",
