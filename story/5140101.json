        "voice": "vo_adv_5140101_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，什麼？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我也還沒有聽聞詳情，",
        "unit_id": 7112,
        "voice": "vo_adv_5140101_038"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n但聽說是要前往雪山穿著泳裝。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "啥！？",
