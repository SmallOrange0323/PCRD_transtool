        "voice": "vo_adv_5140101_036"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "「寒冬的盛夏計畫」。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "寒冬的……",
