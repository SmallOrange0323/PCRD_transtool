[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮＆克蘿依，",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "歡迎兩位回來～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "公會管理協會找妳們過去，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "結果怎麼樣？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊……",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們受到了",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n針對本公會冒險進行方針",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的「指導」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對方似乎認為我們與危險的魔物對峙時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會經常性地掉以輕心、志得意滿。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是喔……",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "講白一點的話？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們在戰鬥前的對話，",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太長了。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是這樣嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我不覺得有這種事呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是故意找碴啦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們最近捉弄花凜可能捉弄得太過頭了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來她是那種意外地會記恨的人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以就報復性地來訓話嗎？",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，妳這樣子講，又會引起事端的。",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然還不到訓話的程度，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但對方還滿認真地跟我們商量的。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n像是能不能再長話短說一點",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之類的。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦～！",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "用這種像是在指導短劇演出的感覺！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "明明我們",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也不是因為喜歡，才開那麼長的作戰會議啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "文書人員還真是輕鬆。",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把在前線拼命的我們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只當作是棋盤上的棋子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然無所謂，",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是要求暴怒發狂的魔物配合我們，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「抱歉，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為上面的人很囉唆，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "今天的戰鬥麻煩縮短」",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這種事，\n是有可能的嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "它們基本上都是聽不懂人話的吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那就來試試看吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n用幻影魔法創造出假想魔物",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘿。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "虛擬魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可惡，出現了啊！",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這個企圖消滅世界的",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "混帳宇宙暗黑大魔王！",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "慢著慢著。",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n克蘿依，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "假想敵的規模太過宏大了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是說啊。",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那種賭上世界命運的冒險，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "協會也不會交給我們處理呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "稍微會威脅到城鎮和平的敵人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種程度應該比較實際吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，是嗎？",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那就重來一次。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "小短劇，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "魔物來襲。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "虛擬魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可惡，出現了啊！",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "叼走魚的混帳野生喵特！",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "停下。",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "等一下，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "赤腳追趕的陽光克蘿依。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個再怎麼說，也太過安逸了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家都笑了。",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "連太陽公公也笑了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，好難。",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我不知道啦，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "到底要怎麼樣的敵人才行啊。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個嘛。",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n看上去很強但其實不強，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過還是有點強……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣是最理想的呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "瞭～",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那麼Take ３，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "開始。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "虛擬魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可惡，出現了啊！",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "身手還行的混帳強敵！",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "城鎮的和平由我們來守護！",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要上了，各位！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力上吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好朋友社，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出全力上吧！",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "虛擬魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，Cut──",
        "unit_id": 110812,
        "voice": "vo_adv_5140101_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n什麼嘛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "成功縮短了啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "成功了呢。",
        "unit_id": 110911,
        "voice": "vo_adv_5140101_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "連我都嚇一跳。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不對，",
        "unit_id": 7112,
        "voice": "vo_adv_5140101_028"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "根本沒有成功。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n已經太長了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "長到令人吃驚。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學生會長，妳怎麼突然冒出來？",
        "unit_id": 111011,
        "voice": "vo_adv_5140101_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "手上還拿著拍攝用的魔導具。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "長過頭了。",
        "unit_id": 7112,
        "voice": "vo_adv_5140101_030"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "以行銷素材來說，內容長到很難使用。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "一般來說，這不是能投稿在魔石通訊網上的影片長度。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我要重新拍攝了，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "禁止超長台詞並請保持良好的節奏。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
