[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美美、禊與鏡華三個人和平常一樣，\n在蘭德索爾一起遊玩。"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "妳們看妳們看～我畫了兔子先生～很可愛吧～♪",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，是很可愛……",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過加上角比較酷呦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不、不可以啦～禊～！",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n因為這幅畫是要給哥哥看的～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥？",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n美美有哥哥嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～是祕密呦～♪",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唔－－－－！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "美美小氣鬼－！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n沒關係！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊也不告訴美美哥哥的事！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳們兩個都在說哥哥、哥哥的，",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不知道妳們在說什麼……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要更認真集中精神在公會活動上！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是～雖然說是公會活動，",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n今天不就只是在畫圖嘛！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為今天美美猜拳贏了，所以就做美美想做的事。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才會三個人一起畫圖呦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣就是公會活動～？好無－趣！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊以為公會就是要做些更帥氣的事－！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊如果猜拳贏了，",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也會一起做禊想做的事呦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是，如果太奇怪的事是不會准許的～",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "噗－－－！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n鏡華這個認真鬼－－－！優等生－－－！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊，妳那樣說，",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n到底是在罵人，還是稱讚人",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我搞不懂呦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～可愛的兔子先生～♪",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_013"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n把這幅畫給哥哥～……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼了，美美？",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美今天有事呢！",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_015"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不快點走不行了！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼今天的公會活動就到此為止吧。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "贊－成！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，禊接下來做什麼好呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對了！想起一件好玩的事了！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊也要回家了－！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "禊拜～拜！",
        "unit_id": 102011,
        "voice": "vo_adv_3013002_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華也是～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊，美美再見。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……呼～我該做些什麼好呢。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "回精靈之森還太早，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但在蘭德索爾也只有他們兩個玩伴……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……啊！之前遇到的那個人，不知道還在不在？",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總覺得是個奇怪的人，不過稍微找尋一下他吧……",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，找到了！",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天也是到處東張西望呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還是老樣子，像個可疑份子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "午安。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你東張西望的在做什麼呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？迷路了嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唉……你到底要到何時",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才會熟悉這個城鎮的道路呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真拿你沒辦法，我來替你帶路。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有地圖或是筆記之類的東西嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是筆記嗎。咦……",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "奇怪？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n難道說你是和別人有約嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n約定的時間似乎快到了呦？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不快一點的話會來不及的！",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n用跑的吧！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哈、哈、哈……",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那個去目的地最短的路線就是轉過這條巷子……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "痛痛痛……",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什麼，這是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "陷阱？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好、好痛！",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請讓開！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n為什麼走在前面的我掉下去了之後，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你也跟著就這樣掉下來了！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀哈哈哈！中計了中計了－！",
        "unit_id": 1,
        "voice": "vo_adv_3013002_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "奇怪？這個笑聲是……？",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哥哥，不要緊吧－！？",
        "unit_id": 1,
        "voice": "vo_adv_3013002_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我現在就把繩子放下去，所以爬上來吧！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥不多注意一下周圍是不行的呦！",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊不是說過很多次，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要小心陷阱～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊！",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這個陷阱是禊挖的嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？鏡華？",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_037"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為什麼妳和哥哥在一起？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我正在替這個人帶路。",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊妳為什麼也會認識這個人？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊是哥哥的教官～",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_039"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為了讓遲鈍的哥哥不要掉進陷阱",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n正在特訓！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好像是個很適合的人選，又好像錯得很離譜……",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！不好了！",
        "unit_id": 103611,
        "voice": "vo_adv_3013002_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n約定時間已經過了喔！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們快點走吧！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊的特訓很嚴格呦～對吧，哥哥……",
        "unit_id": 100411,
        "voice": "vo_adv_3013002_042"
    },
    {
