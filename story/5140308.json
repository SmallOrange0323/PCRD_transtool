[
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "喲，",
        "unit_id": 18211,
        "voice": "vo_adv_5140308_000"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「逃犯＜豬隻＞」們！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n真高興呢，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "又能「見到」妳們了啊！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗚哇……",
        "unit_id": 110811,
        "voice": "vo_adv_5140308_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太纏人了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好恐怖……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "呵呵呵……",
        "unit_id": 18211,
        "voice": "vo_adv_5140308_002"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "也不是不能理解妳們的「情況＜心情＞」啦。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "畢竟小官過去也是有「前科＜各種經歷＞」的。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "沒錯，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "那是鬼之副團長摩根卿",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "還待在騎士團時的事了……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "出、",
        "unit_id": 110911,
        "voice": "vo_adv_5140308_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "出現了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一有機會就自吹自擂！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "笨～蛋！",
        "unit_id": 18211,
        "voice": "vo_adv_5140308_004"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "是給人機會的那一方不對吧。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我無話可說呢。",
        "unit_id": 111011,
        "voice": "vo_adv_5140308_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n急於分出勝負的我們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "的確是露出了被趁虛而入也不奇怪的破綻。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這簡直就跟那時候一樣啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯，",
        "unit_id": 111011,
        "voice": "vo_adv_5140308_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是在我",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "將要滿八歲的一個月前。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在我去參加常去的幼稚園",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所舉辦的小孩子模擬家庭演練時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n將帶隊的鈴莓給捲了進來，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要求她進行模擬哺乳的我──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "什、",
        "unit_id": 18211,
        "voice": "vo_adv_5140308_007"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "什麼！竟然反過來自吹自擂！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "這傢伙，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n衝著小官一瞬間的破綻……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "真是了不起的「自我主張＜敘事＞」力……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "受到衝擊的點",
        "unit_id": 110811,
        "voice": "vo_adv_5140308_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "居然是那個嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呵呵呵……",
        "unit_id": 111011,
        "voice": "vo_adv_5140308_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "修女，怎麼啦？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n可以自吹自擂的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就只有做好覺悟要聽人自吹自擂的人喔？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可是有這個覺悟的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無止盡地自吹自擂下去的覺悟！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "…………",
        "unit_id": 190811,
        "voice": "vo_adv_5140308_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_5140308_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐，不好了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n綠之監視員在對面面露凶光啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個人為什麼不管在哪裡都會出現啊？",
        "unit_id": 110811,
        "voice": "vo_adv_5140308_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘖，",
        "unit_id": 111011,
        "voice": "vo_adv_5140308_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有辦法，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "今天就到此為止。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n克蘿依、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "迅速地解決掉吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒＆克蘿依",
        "words": "瞭～！",
        "unit_id": 1,
        "voice": "vo_adv_5140308_014"
    }
]