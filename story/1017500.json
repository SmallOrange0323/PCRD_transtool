        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼一副認真的表情～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊！　",
        "unit_id": 101711,
        "voice": "vo_adv_1017500_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "該不會是要跳舞～？　",
