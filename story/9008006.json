    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n──咬下！！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……！",
        "unit_id": 100213,
        "voice": "vo_adv_9008006_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真驚人，",
        "unit_id": 100213
