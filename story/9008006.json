        "words": "優衣小姐──！",
        "unit_id": 1,
        "voice": "vo_adv_9008006_006"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "\n麻煩妳撐場面，代替她們進行美食報導吧～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "欸！？",
        "unit_id": 100213,
        "voice": "vo_adv_9008006_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我嗎！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼辦……！",
