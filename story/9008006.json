    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大間那邊的漁協",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "送了本節目一條很漂亮的金槍鮪～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然當地曾有過島鯨事件那樣的艱辛時期，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過今年聽說也是大豐收喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "貪吃佩可……",
        "unit_id": 100213,
        "voice": "vo_adv_9008006_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就算妳在廣播節目上說「請看～」",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聽眾們也是看不見的唷？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_9008006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都忘了～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這看起來超級好吃耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們今天要在播音間實際品嚐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "替大家進行美食報導喔～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_9008006_003"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n這我喜歡。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "（嚼嚼）",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔～！",
        "unit_id": 105812,
        "voice": "vo_adv_9008006_004"
    },
    {
