        "unit_id": 106311,
        "voice": "vo_adv_1063003_075"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n耶嘿嘿……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n感覺，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "雖然不知道為什麼……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "但好開心呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "都是多虧了{player}哦。",
        "unit_id": 106311,
        "voice": "vo_adv_1063003_076"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n因為有{player}注視著我……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以我，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "才能拿出勇氣。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "謝謝你，",
        "unit_id": 106311,
        "voice": "vo_adv_1063003_077"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
