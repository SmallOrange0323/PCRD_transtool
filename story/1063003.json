        "voice": "vo_adv_1063003_074"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "怎麼會……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我一點也不可愛，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "也說不上厲害……",
        "unit_id": 106311
    },
    {
