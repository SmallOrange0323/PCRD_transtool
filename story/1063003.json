    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "才厲害……！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "我們沒辦法做到這種事呢！",
        "unit_id": 1211,
        "voice": "vo_adv_1063003_073"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n不但可愛又厲害，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "簡直太完美了！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "怎、",
