[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一小時後。"
    },
    {
        "type": "dialogue",
        "name": "魔物A",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 713
    },
    {
        "type": "dialogue",
        "name": "魔物B",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 714
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喝、",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喝！　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總算是趕上了！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我這樣不太能奔跑呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為鎧甲太重了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你也知道我必須遵守家訓……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是說少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你怎麼也跟過來了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你還是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "趕緊避難為上喔？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔～……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說能加強夥伴的能力這點很派得上用場。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但真的很危險，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請盡量離遠一點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總之……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n已經無路可逃了喔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "快乖乖就範！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團（NIGHTMARE）】的全員，快包圍敵人！",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n先擊倒削弱他們再進行綑綁！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若是抵抗，即使砍斷手腳也在所不惜！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "敵人可是沒有肉身這樣不可思議的存在……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n恐怕是與寄宿著生命的鎧甲同類，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這種程度的攻擊是殺不死的！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也因此不會沾上敵人的血，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不需懷著罪惡感也能安心入睡！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光明正大地！",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像故事中正義的一方打倒敵人一般，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n華麗的擊退敵人吧！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我不太習慣大聲說話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但這還是必要的呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看到自己的冒牌貨到處施暴，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而【王宮騎士團】的成員們皆受到動搖。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若我表現的堅定一點，",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家應該也能安心下來的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純！",
        "unit_id": 100511,
        "voice": "vo_adv_5006005_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這這這、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這是什麼情況！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉、",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "茉莉？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼說來茉莉住在這附近嘛……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真的太危險了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身為新人的你應該快點去安全的地方避難。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不，",
        "unit_id": 100511,
        "voice": "vo_adv_5006005_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也要參加戰鬥！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為這可是我的城鎮！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且戰力也不夠是吧，",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請讓我助你一臂之力。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智也是……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼你們兩個都在這邊呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是剛好而已。",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "剛跟茉莉吃完飯後，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n正要送他回家的途中，就遇到這怪事。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這些傢伙",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在搞什麼？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有兩個純……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是傳說中的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "『闇影』嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我覺得不同，",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但也不是很清楚。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且也不清楚真實身分，也無法坐視不管……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這些傢伙模仿我們的模樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "並且為所欲為。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "絕對不可原諒！。",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就是因為這些傢伙，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以才覺得被大家討厭吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "害我心理那麼煩躁。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n原來如此，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼一來就說得過去了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到是冒牌貨呢……",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我都沒想到，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n明明之前也有聽到關於『闇影』的目擊情報的說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來我還是不夠成熟呢。",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "被純的冒牌貨那樣對待，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我受的傷好像比自己想像的還要重。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我竟然都沒想到，",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還懷疑你，真抱歉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也要反省……",
        "unit_id": 100511,
        "voice": "vo_adv_5006005_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "冒牌的英雄這種老套的劇情，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為何我沒有立刻發現呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嘻嘻。",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這也沒辦法吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為外觀一模一樣呀……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望我們關係越來越親，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n親到一眼就能分出本尊跟冒牌貨的差別。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了達成那目標。",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別為了互相懷疑的事而受傷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了成為互相友愛的夥伴……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一起攜手解決，",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這些可怕又不尋常的事件吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們兩個",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都會幫我吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "當然！",
        "unit_id": 100511,
        "voice": "vo_adv_5006005_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "必須要向",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "爸爸跟媽媽，還有住在獸人居住區的大家證明……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n做壞事的是冒牌貨！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不僅打倒敵人，還能洗刷純的汙名，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是一石二鳥呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "該不會，",
        "unit_id": 103711,
        "voice": "vo_adv_5006005_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你就是為了這個而把敵人追到獸人居住區的？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉呀還真的服了你，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "竟然還有這種方法呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦……",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我只是專心追了過來，剛好到了這個地方而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可真辛苦呢。",
        "unit_id": 104711,
        "voice": "vo_adv_5006005_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且克莉絲還",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
