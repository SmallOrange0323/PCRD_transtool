    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "世界で一番の悪いヤツを目指しているノウェムは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n今日もしっかり（？）鍛錬に励んでいた。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はっはっはっは～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……いや、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "微妙に違う気がするな～？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nもう少し、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "低い声でやった方が……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "む……？",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_001"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\nオクトー、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "ノウェムは何をやっているんだ？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "突然笑い出したかと思えば、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "逆に黙り込んだりしているが。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あー、",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_002"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あれねー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n悪党らしい高笑いの練習だってさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクにはさっぱり理解できない趣味だけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "な、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_003"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "なんということだ！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "高笑いはむしろ、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "正義の味方の特権……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n彼女の認識を正す必要があるな！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_004"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "忘れてた。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nベクトルが違うだけで、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "この人も似たようなもんだったよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "めんどくさい展開にならないといいけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おーほっほっほっほ……",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_005"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いや、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "これも違う！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ぐへへへへ～……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちょっと、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いやらし過ぎるなぁ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n悪党らしい高笑いって、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "かなり難しいぞ……！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "当然だぞ、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_006"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "ノウェム！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\nなぜなら",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "澄み渡る空に向かって高らかに笑うのは、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\nいつだって正義の側だと相場が決まっているからだ！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんだと～！？",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nじゃあ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエの高笑いを見せてみろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nちゃんと立派な、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "正義感あふれる高笑いなんだろうな！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "いいだろう、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_008"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "しっかりと目と耳に焼き付けてくれ！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "……あー、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "あー、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "コホン。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "ふふふ……",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_009"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "ククク……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "あーはっはっはっはっは！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\nふははははははははははははははははははは！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "どうだ、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_010"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "私の高笑いの完成度は！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\nいつか我が主にも披露したいと考え、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n毎日早起きして練習し続けた",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "とっておきだぞ！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "す、",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "すご",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "い……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "すごく、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "悪党っぽい！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "感動したぞ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "マサキ！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "悪党の才能があるんじゃないか！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nこんなに邪悪な高笑いができるなんて！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "なっ、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_012"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "私の高笑いが邪悪だと！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "オクトーは",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "私の「正義の」高笑いをどう感じた！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "情けは無用だ、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "忌憚のない意見を聞かせてほしい！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "物語の折り返しくらいで倒されるぱっとしない中ボス、",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nって感じの笑い方だったかなー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あと、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ご主人様の前ではやらない方がいいよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "えっ、",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_014"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "そこまでだったか……？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "このままでは、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "我が主をお守りすることができないではないか……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いや、",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "単なる笑い方の話なんだけど。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どんな笑い方してても、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "強さには影響しないでしょ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム・マサキ",
        "words": "する！　",
        "unit_id": 1,
        "voice": "vo_adv_5110607_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム・マサキ",
        "words": "絶対にする！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "えぇ……？",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_017"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なぁ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_018"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いったん",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "悪と正義で手を取り合わないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "このままちゃんとした高笑いができなかったら、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n共倒れになっちゃうからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "私も同じ提案をしようとしていたところだ！",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_019"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "正義と悪の決着は、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "高笑いを極めてから改めてつけるとしよう！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "じゃあ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_020"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクは正義も悪も高笑いもどうでもいいんで、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nこの辺で失礼するよ～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ノリが悪いぞ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110607_021"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "一人だけ逃げられると思ってるのか！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "その通り！",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_022"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "さぁ、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "共に目指そうじゃないか……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "至高の高笑いを！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ホント、",
        "unit_id": 106211,
        "voice": "vo_adv_5110607_023"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "勘弁してよ……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n明らかにボクのキャラじゃないからさ～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "恥ずかしいのは最初だけだ！",
        "unit_id": 191011,
        "voice": "vo_adv_5110607_024"
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n人前で何度も繰り返せば",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "羞恥心も薄れる！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "さて、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "マサキ",
        "words": "行くぞ……",
        "unit_id": 191011
    },
    {
