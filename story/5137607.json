[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その日、一仕事を終えたノウェムとオクトーは、帰路についていた。"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "んー、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_000"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今日はサクッと終わったね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "とりあえず",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ご飯でも行こうか。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……なあオクトー、",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_001"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "前から気になってたんだけど、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nオマエのモンスターを操る能力、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "あれって楽しいのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なんだい、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_002"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "藪から棒に。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "だって戦闘って、",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_003"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "自分の手でぶっ飛ばしてこそだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそれが楽しいとこじゃないのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なのに",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "モンスターにやらせて",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "自分は見てるだけなんて、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシには全然分からないぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うーん、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "これは一生埋まらない見解の相違だね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まずボクは",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "戦闘が好きなわけではないし、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "痛いのとか本当に勘弁してほしいよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんなボクみたいな人間にとって",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_007"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "モンスターを操る能力は、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n楽できて最高なんだよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……そっかぁ。",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あれ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_009"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "今なんか",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "かわいそうな目で見なかった？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そんなことはないぞ！",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "じゃあ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "お気に入りのモンスターとかっているのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そうだね、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_011"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "単純に火力の高いのはいいよね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n戦闘がすぐに終わるから",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "すごくありがたいよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "逆に長期戦狙いなら",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_012"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "デバフ要員が輝くね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "じっくりと攻め落とすのも",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "乙なもんさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あとは",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_013"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "弱めのモンスターでも",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "使い方次第で",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "相手の虚をつけるから、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nそこはボクの",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "腕の見せ所だね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "へぇ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_014"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "色々考えて戦ってたんだな？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "やっと分かってくれた？　",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "結構苦労してるんだからさぁ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ああ",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_016"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そういえば、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "最近扱いの難しいじゃじゃ馬がいてね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n強さはピカイチなんだけど、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ここがちょっとね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "まあ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_017"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "モンスターだもんな。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "仕方ないだろ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それだけならまだしも、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_018"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ちっこくてうるさくて、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "さすがのボクも手を焼いてるよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おい待てオクトー、",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_019"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そのじゃじゃ馬ってもしかして──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "は～、",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_020"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "お腹空いたね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "早くお店に行こうか、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェム♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おいコラ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_021"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちゃんと答えろ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "この野郎ー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "そそくさと逃げ出すオクトーの背を追いかけるノウェムだった。"
    }
]