        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只是想",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "摸她的腳吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你有時候會突然做出很反常的事嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_1087007_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以就",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "姑且",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "問一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂，",
        "unit_id": 190011,
        "voice": "vo_adv_1087007_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別把視線移開。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒關係。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以後當日和心情低落時，就要像這樣替她加油。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1087007_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "平常都是別人在替你加油吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能自然地互相鼓勵是很棒的一件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你好好珍惜吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就下次見。",
        "unit_id": 190011
    },
