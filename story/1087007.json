[
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利將詐欺犯們交給【王宮騎士團】後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和及{player}一邊尋找拍攝的好地點，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊徒步返回蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那位老奶奶的信",
        "unit_id": 108711,
        "voice": "vo_adv_1087007_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還放在我們這裡，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以得趕緊回去呢。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是再慢吞吞的話，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太陽就要下山了。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看，",
        "unit_id": 108711,
        "voice": "vo_adv_1087007_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "夕陽都已經……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在還很早嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這道光是……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎、",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！？",
        "unit_id": 108711
    },
    {
        "type": "background",
        "background": "510363"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "才剛過年幾天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}走在路上要前往附近的神社，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時他看到一個熟悉的人蹲在路邊。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "痛痛痛……",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗯～",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是太勉強自己了嗎……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你怎麼會在這裡……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要說的話我也一樣呢。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "新",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "年快樂。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗯。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我現在正要去神社。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長果然也是要去神社吧。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你知道嗎？",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n聽說那座神社",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能保佑大家的腳和腰喔！",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我奶奶的腰好像很痛，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以我想要去那參拜，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "祈禱她能趕快好起來……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但卻被穿不慣的木屐",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咬腳……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不對，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是被木屐繫帶？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "磨傷腳趾縫了。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦！",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那樣子",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不好啦……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我現在",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "穿的是和服，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以衣襬很窄……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你說，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然這樣就借我搭個肩，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是嗎？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這本來就是我自己準備不足……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的……",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽你那麼一說",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就無法拒絕了嘛……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就麻煩你囉。",
        "unit_id": 108732
    },
    {
        "type": "background",
        "background": "510303"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}讓日和搭著肩，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊尋找能小歇一會兒的地方。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n到這裡就行了。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n再繼續走",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也很引人注目……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我坐著休息一下",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就沒事了。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要我等你。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你真是溫柔。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n明明可以丟著我不管的……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有啦，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開玩笑的。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我其實",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有那麼想。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明自己也",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "覺得很丟臉，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "卻還向學長撒嬌了。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唉……",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都是因為一時衝動穿了新年和服來，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n才給學長添麻煩了……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才剛過新年",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就諸事不順，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "心情真是開心不起來……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "需要別人加油的人，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是這樣的心情吧。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再說，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會這麼認真打扮，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就是因為想說，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有可能在路上碰巧遇到學長嘛……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "遇是遇到了，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但竟然演變成這樣，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這我根本沒想過啊～！",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可能因為在過新年，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就有點太興奮了……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等學長回來後",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就要告訴他，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我能夠自己",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "叫計程車回去。",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n咦，",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "他好像提著什麼……？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺體積很大，",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看起來很重還冒著煙……",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是什麼呢？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很大的桶子裡裝滿了",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "熱水！？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這一定很重吧？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你還好嗎？",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你去附近的店家借的啊……",
        "unit_id": 108732,
        "voice": "vo_adv_1087007_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼",
        "unit_id": 108732
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這究竟要做什麼？",
        "unit_id": 108732
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
