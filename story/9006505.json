[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "快看，",
        "unit_id": 100611,
        "voice": "vo_adv_9006505_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姐姐！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是拉菲的弓箭～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "它、",
        "unit_id": 102211,
        "voice": "vo_adv_9006505_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "它接收了名叫彌勒的壞蛋的力量，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "又失控了啊……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "得快點去幫助它才行！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "弓箭",
        "words": "──！",
        "unit_id": 13811
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_9006505_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這道光",
        "unit_id": 100611,
        "voice": "vo_adv_9006505_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我有印象……！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這該不會是……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "果然",
        "unit_id": 1,
        "voice": "vo_adv_9006505_004"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "交換身體了～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "這是……！",
        "unit_id": 100711,
        "voice": "vo_adv_9006505_005"
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "\n宮子的",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "靈體……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "\n靈媒師",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "成了靈體……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "唔！？",
        "unit_id": 103111,
        "voice": "vo_adv_9006505_006"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "這身體沒有尖牙，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "妾身不就無法吸血了嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n你啊，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "稍微讓妾身試一下！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "不對，",
        "unit_id": 104412,
        "voice": "vo_adv_9006505_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "等一下！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "\n和那比起來，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "應該先讓我變成巨乳才對！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "\n喂！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": " 現在立刻抱緊我──！！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "不可以喲～！",
        "unit_id": 2411,
        "voice": "vo_adv_9006505_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "和那比起來，重要的是布丁喲！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "\n把布丁交出來～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不好了～！",
        "unit_id": 102211,
        "voice": "vo_adv_9006505_009"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n不能像之前一樣，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "靠茜里和姐姐的力量變回來嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "沒、",
        "unit_id": 100611,
        "voice": "vo_adv_9006505_010"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "沒辦法……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我們現在",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "並沒有接收拉菲的力量……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "只能直接這樣戰鬥了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "大家",
        "unit_id": 100611,
        "voice": "vo_adv_9006505_011"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "冷靜下來！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n大家或許不習慣目前的身體，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但現在也只能這樣戰鬥了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "現在重要的是",
        "unit_id": 103111,
        "voice": "vo_adv_9006505_012"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "先讓妾身吸血！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "不對，",
        "unit_id": 104412,
        "voice": "vo_adv_9006505_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "是巨乳優先才對！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "絕對是布丁喲～！！",
        "unit_id": 2411,
        "voice": "vo_adv_9006505_014"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯～",
        "unit_id": 102211,
        "voice": "vo_adv_9006505_015"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n照這情況來看，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "要讓他們冷靜下來",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好像有點難～？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "真沒辦法……",
        "unit_id": 100711,
        "voice": "vo_adv_9006505_016"
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "不好意思，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "請你讓爸爸他們冷靜下來。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子？",
        "words": "\n這裡就先靠我們來堅持住……！",
        "unit_id": 100711
    }
]