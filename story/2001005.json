[
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂！",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們這些傢伙冷不防的搞什麼呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n如果想要打架的話，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我隨時奉陪啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "趕緊放馬過來呀，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我心情可正不爽呢！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們這些傢伙，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是哪個公會的！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵呵♪",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "儘管被問了就乖乖報上名號，有點俠禮殺氣～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家～！",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我想璃乃呀，大概",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是想要講『傻里傻氣』唷♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是那個，靜流姐！",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "鄭重地再一次……",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "儘管被問了就乖乖報上名號，有點傻里傻氣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但我們就是，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "探究著世界之謎的祕密社團",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "【拉比林斯】！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "儘管和妳們沒有過什麼恩怨情仇，",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但還是讓我們也來參上一腳吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在在那，",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那邊那個叫什麼……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "諾維姆若被人給回收，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還被藏在個哪裡隔離起來，我們會很困擾的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃～。",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n明明是祕密社團，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "卻還正大光明地報上名號是有毛病……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呀☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚呀！？",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就只有頭槌",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就只有頭槌還請放過人家吧！姐姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這超痛的欸！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有啊，",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "本來應該要好好保密的目的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳這可不就全都給說出來了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呀☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇啊，",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說別再用頭槌了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐，就饒過我了吧！",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我有在反省了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n璃、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "璃乃會當個乖寶寶的啦……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "究竟在演哪齣，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那一副來亂的雙人組到底……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說是【拉比林斯】嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是個沒有聽過的公會啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n還自稱是什麼祕密社團？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哎唷，",
        "unit_id": 101112,
        "voice": "vo_adv_2001005_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大意吃津粥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓我來掩護妳，妳就趁機確保住我們的目標！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "了解～♪",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想不是『吃津粥』，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "『失荊州』唷……☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦哦～",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然單槍匹馬就殺了過來呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來還挺帶種的嘛！",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n來啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不逃不閃等妳正面上！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再怎麼說我也是獸人，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n可不會像隻小兔子，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n乖乖的毫無反抗",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就讓人給吃得死死的啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}你們閃遠點，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不然危險嘿！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來單挑！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳這傢伙！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狀、",
        "unit_id": 105911,
        "voice": "vo_adv_2001005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狀況在轉眼間就變得相當混亂了呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請往這邊！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是{player}啊！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還真常巧遇呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓女孩子家來保護自己可是很丟臉的……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈！",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那呆傻萌的台詞！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還真是像{player}會說的話呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能夠在這相遇真讓人開心啊♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……您與那位女性也是舊識呢，",
        "unit_id": 105911,
        "voice": "vo_adv_2001005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為何感覺，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您似乎和全世界的人類都早有照過一面的趨勢呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘻嘻～♪",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為{player}可是個特別的存在呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "處於這龐大的命運洪流之中心唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是就如同那，",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "第一主角一樣的人喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以這也是無可奈何的呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哎唷……",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還真是失禮了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這次的目的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可不是{player}呢♪",
        "unit_id": 104911
    },
    {
        "type": "still",
        "still": "200100501"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這傢伙，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還順勢利用了斬擊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n彈躍了那麼遠的距離！？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "言行明明就像個笨蛋，",
        "unit_id": 104311,
        "voice": "vo_adv_2001005_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但這不意外地還挺強的嘛！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還真有趣，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這不是越來越讓人熱血了嘛！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n給我等一下，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我們再來戰幾回嘛……☆",
        "unit_id": 104311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所～以～說～",
        "unit_id": 104911,
        "voice": "vo_adv_2001005_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要和汪汪玩再等下一次的機會啦！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
