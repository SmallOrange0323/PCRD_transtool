[
    {
        "type": "background",
        "background": "501620"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而另一方面，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從可可蘿一行人身邊抓走{player}的美空，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了「漆黑薔薇城」。"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呼～",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_000"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然只能算得上是",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_001"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "勉強過關，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過也算是進展順利了……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "接下來只要等厄莉絲大人回來，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我就可以下台一鞠躬了吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我接下來",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要做什麼才好呢……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……彌勒先生",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "比我預期的還要失控……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可能要想辦法",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "做點什麼比較好。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過如果不想妨礙到厄莉絲大人，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_005"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "想阻止他應該很困難吧──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……唔嗯～",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_006"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你醒啦？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你問這裡嗎？",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這裡是",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人的城堡，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "城堡裡頭的最深處。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這座城堡一直到剛剛",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都還躲在非常靠近世界背面的地方。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過我很努力地空間跳躍、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "用念動力把它搬上來，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以我們現在",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就在索爾之塔的旁邊喔～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……對不起。",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_010"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學你這個遊戲贏家的「願望」，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n其實我應該要聽從才對，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人也對我",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "許了「最後的願望」，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而我也已經約好",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要替她實現了說。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還有沒有什麼",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其他的？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我是說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學你想要我實現的願望。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果都沒有，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_013"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我呢……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我就只好試著分裂成兩個人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n讓美空A和美空B互相殘殺，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "然後讓活下來的那一個，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n實現你們其中一人的願望了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好的～",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_014"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……啊，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我話先說在前頭，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那句「不要做」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不能當作願望喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "話說回來，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_015"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人好慢喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "看來要控制那座塔，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "需要花上不少時間呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_016"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那還用說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "當然是要做之前說過的",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那件事啊。",
        "unit_id": 192011
    },
    {
        "type": "background",
        "background": "500602"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "總之，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_017"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "優衣會被永遠關起來──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而騎士同學",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會跟厄莉絲大人結為連理──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n然後，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個世界就完蛋了♪",
        "unit_id": 192011
    },
    {
        "type": "background",
        "background": "501620"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其實呢，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_018"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "優衣可以被抓起來是最完美的，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過既然她現在被拉比林斯達小姐藏得那麼隱密，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我們現階段就只能賭賭看了，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_019"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大概就是這樣吧～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過呢，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果只是要打造專屬於騎士同學你和厄莉絲大人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n兩個人的小小世界，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那勝算也很足夠了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒錯。",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_020"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就只是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "看是要把阿斯特朗連同優衣整個人「壓縮」呢，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或是如果做不到的話，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那就從時間的流速來下手。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在的阿斯特朗，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_021"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n時間流速雖然提升得比現實世界快很多。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過我們要反過來把它調得",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "非～常非常慢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "把這個世界邁向終結所需的時間",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_022"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "拉得無限漫長……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "然後騎士同學你和厄莉絲大人就在這段期間，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n慢慢享受新世界。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "很妥當的安排吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過嘛，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_023"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果要和「辭去世界營運裝置的職務」、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n「把優衣關起來」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "並「打造新世界」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這個100分滿分的計畫相比，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "頂多只能打個60分而已。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以我想到頭來……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_024"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n還是需要騎士同學你的協助，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或者該說是要依你的選擇而定～呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒錯沒錯。",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_025"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n因為厄莉絲大人她呢，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "除掉面具之後也是個一般的純純少女。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她好像認為，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_026"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n只要是她渴望的事，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學就一定也會認同的呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而且……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_027"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我能提供給厄莉絲大人的協助，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好像也只到這裡了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為啊，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_028"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我會覺得厄莉絲大人很可憐的最大原因，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就是因為她只能一直以局外人的身分在一旁旁觀。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為那所謂世界的規則，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_029"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "讓她必須一而再再而三地……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n被迫看著喜歡的人",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "和其他女孩打情罵俏、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被迫目睹他的死亡。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不僅如此，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_030"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她甚至連讓對方知道自己的存在、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n明白自己的心意都無法做到。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果是我……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我應該會受不了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_031"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過啊。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n因為有了我和小R他們的努力，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在的厄莉絲大人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n已經獲得了一定程度的自由。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "更重要的是，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_032"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學你也知道了她的存在，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n現在她已經不再是連要追求你",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都做不到的狀態。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……所以我覺得～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她的可憐程度已經",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "減少很多了呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不要誤會，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我當然覺得那是好事喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不過呢……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我會覺得，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那她是不是已經",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不需要我的協助了呢……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯～",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_034"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "正好剛剛",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也在煩惱這件事呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……畢竟",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_035"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好像也不能再到處玩耍了，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以我想就邊吃些甜點……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "邊爬上哪個視野良好的地方，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n然後見證世界的終結？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大概就是這樣吧～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……雖然好像有些人另有其他打算，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_036"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n正虎視眈眈地等著世界毀滅的瞬間，不過……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯，我想，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "事情應該不會那麼順利的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不是什麼說不定，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_037"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是一定會消失的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其實啊，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我並不怎麼害怕那件事呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我反而覺得這個結局",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_038"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好像還不錯呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果我能拯救可憐的厄莉絲大人，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那麼達成那件事的我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也就不顯得可憐了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_039"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……因為對象是你，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_040"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我才告訴你的喔……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我這個人啊，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_041"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n天生就和其他人不太一樣。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是人家所謂的",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_042"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有特殊能力？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也就是超能力少女啦。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "爸爸媽媽他們",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_043"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "對此興奮得沖昏了頭，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n竟然試圖讓還在讀幼稚園的我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "上電視表演。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "結果，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_044"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你猜發生了什麼事？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……我竟然",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "被邪惡的祕密組織綁架，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就這樣長達十年左右的時間，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "都被當作實驗動物對待。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過呢……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_045"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真正擁有超能力的人",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其實非常罕見，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以我除了沒有自由之外，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "他們還是對我很好的……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說是這樣說啦。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_046"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我會這樣覺得，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也許是因為被洗腦了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "或是所謂的斯德哥爾摩症候群吧。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "他們利用我的能力，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_047"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在那裡製造出來的武器……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不曉得究竟",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "造成了多少人的傷亡。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過。",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_048"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我啊？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n其實並不打算",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "把所有的責任都推到組織身上。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我不會去說",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "自己是可憐的受害者。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_049"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "如果當初我沒有帶著超能力出生，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n應該就不會有誰因此受傷、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "為此死亡了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……呵呵♪",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_051"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n不好意思喔～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一不小心就談起無聊的話題了★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊♪",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_052"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n厄莉絲大人應該就快回來囉～！",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "等她回來之後……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_053"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n告別的時間",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就要到了吧？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……哈哈★",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_054"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "哈哈哈哈♪",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_055"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n真是太感謝你了～★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是說啊♪",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_056"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n的確是不可原諒呢♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n因為，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我就是個壞孩子嘛★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "蘭法姐、優衣還有貪吃佩可她們，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_057"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n一直以來都不責怪我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n老實說，我其實覺得很不耐煩呢。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以能聽到騎士同學你主動這樣說我，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_058"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我真的真～的好高興喔★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "感覺好像會上癮呢……♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "話說回來……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_059"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "騎士同學，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你的對象不是我，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而是厄莉絲大人。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "請你要認真面對她……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要有～耐心地",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "聽她訴說喔。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_060"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n接下來",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要我為騎士同學你們……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是嗎？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個嘛，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_061"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "畢竟騎士同學你是有權利「許願」的，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "所以如果一定要的話……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "…………",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_062"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "無論做了多少好事，",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_063"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n也不能將曾經犯下的罪過",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "一筆勾銷的。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "即使如此……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_064"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n騎士同學，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你也希望我那麼做嗎？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_065"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n可、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_066"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "時、",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "時間好像",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "差不多……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "要到了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那個……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "話說回來……",
        "unit_id": 192011,
        "voice": "vo_adv_2114010_067"
    },
    {
