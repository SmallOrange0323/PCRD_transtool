    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲和{player}攜手合作，在塔的內部不斷前進，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n終於抵達塔的最上層……"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這裡，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是最上層……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n在這個世界中不斷拒絕所有人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "未知的領域。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "作為隱藏程式的地點，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "應該是最合適──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那裡，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有人在……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是誰？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n現出真面目來。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………歡迎妳來，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "厄莉絲。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "又是騎士先生。",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是塔的Bug嗎。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或者是，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "新的幻影……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "喲，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_004"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "「我」。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "真虧你能來到這裡啊。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我不是其他人，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "就是你自身。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "你可能不曉得，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_005"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n我一直在等待著你的到來。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n我，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "一直很想見你……",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……跟途中見到的，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "由記憶重現的幻影不同。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n看起來比剛剛的騎士先生們，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "更像本尊。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "眼神很銳利……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "沒錯。",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_007"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "而且，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我的願望終於實現了。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "謝謝你把她帶來，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "「我」。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "很簡單。",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_008"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "來，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "厄莉絲……",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "跟我一起走吧。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "咦……",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什、",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼意思？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n一起，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "去哪裡……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我一直在等待著妳的到來。",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_010"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "沒錯，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "就只等著妳。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "所以我今後，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_011"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "會一直在厄莉絲身邊的。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n來，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "到我這裡──",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎、",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……！？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n怎麼辦，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有兩個騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "正在爭奪我……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不對，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "現在不是心跳加速的時候。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "請你別來妨礙我。",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_013"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n跟我在一起，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "對厄莉絲來說才是最幸福的。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n你就退出吧。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我的話，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_014"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "能實現厄莉絲的願望。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n畢竟厄莉絲想要的一切，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "都在這座塔裡。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我、",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想要的……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在這座塔裡……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這是什麼意思……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "厄莉絲妳……",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_016"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "一直都在看著對吧。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n看著為了其他人努力的",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "「我」。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "並且，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "希望在那裡的人",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "是自己……",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我絕不會讓妳有這種寂寞的感受。",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_017"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "過去對其他人做過的事，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n今後全部",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "都只對厄莉絲做……",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我們可以一起修行、",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_018"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "去冒險、",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n用餐、",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "悠哉放鬆……",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n一直在一起。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊啊，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "他朝我伸出了手。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n注視我的",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "溫柔笑容",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和甜言蜜語。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……是的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒錯。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我知道。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直都渴望著──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣的情景。",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒錯，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要是連那些朝向其他女孩",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "的眼神、笑臉和日常對話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都可以只屬於我",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "的話。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這些，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "好嗎？",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_022"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "來，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "快過來這裡──",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊啊……",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "原來如此。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這座塔是──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這座露娜之塔，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是跟我合為一體的米奈娃，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n利用醒過來的短暫時間所建造。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為了向騎士先生他們展示「現實」的光景，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n然後",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "結束「禁錮」。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在頂端等待的「他」會盯上我……",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是因為這是為了將我跟米奈娃分離開來，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所準備的功能嗎……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "………………對不起。",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會去。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你不是真正的騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "妳怎麼會這麼想？",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_029"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n妳心裡，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "一直期望著這些。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n明明我",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "可以為妳實現。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會看著我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不是別人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而是我……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "他會專心注視著我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你給我的，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就只是重複過去的回憶。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n用對其他人做的事情，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "來實現我的願望……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果是真正的騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "絕對不會這樣想。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為我",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "喜歡的騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是這樣的人。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "那真是",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_033"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "遺憾。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我還以為能跟妳在一起。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "既然如此，",
        "unit_id": 15811,
        "voice": "vo_adv_7030002_034"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我不會再讓你們離開這座塔。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n得讓你們一直待在塔裡才行。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不論是Bug，",
        "unit_id": 129011,
        "voice": "vo_adv_7030002_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是幻影，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要對有著騎士先生樣貌的存在出手，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "讓我感到很抱歉。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是還請你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "原諒我──",
        "unit_id": 129011
    }
]