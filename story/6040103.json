    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪一直都很一心一意地拼命努力，",
        "unit_id": 103311,
        "voice": "vo_adv_6040103_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很感謝她呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "希望大家也能",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "更理解莉瑪莉瑪的優點的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果她不會再被誤認成牛就好了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對啊。",
        "unit_id": 103311,
        "voice": "vo_adv_6040103_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要慢慢解開大家對莉瑪莉瑪的誤解，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她應該就能夠自由地去更多地方了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "並不是因為我希望她能",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "幫忙我去賣東西之類的喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪的溫柔",
        "unit_id": 103311,
        "voice": "vo_adv_6040103_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能夠傳達給能傳達的人啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然人們都說不能以貌取人，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但會用外觀來評斷的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一直都是大人們呢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對啊。",
        "unit_id": 103311,
        "voice": "vo_adv_6040103_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真搞不懂",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼會被搞錯呢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過至少她沒有被當成魔物攻擊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n是不幸中的大幸呢……",
        "unit_id": 103311
    }
]