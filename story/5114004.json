        "words": "那個，",
        "unit_id": 413,
        "voice": "vo_adv_5114004_000"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "我點紅茶，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "請幫我做成鮮奶茶。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "這位要咖啡。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "還有，",
        "unit_id": 415,
        "voice": "vo_adv_5114004_001"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "給貓咪吃的零食！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "喵，",
        "unit_id": 1713,
        "voice": "vo_adv_5114004_002"
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "喵～！",
        "unit_id": 1713
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "好的好的，",
        "unit_id": 413,
        "voice": "vo_adv_5114004_003"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "妳等一下喔。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n我也有點給貓咪吃的零食了。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幫您點好餐了喵──！",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請稍待片刻喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "不好意思，",
        "unit_id": 411,
        "voice": "vo_adv_5114004_005"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "有其他",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "鯛魚燒以外的菜單嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "也吃了很多懷舊點心，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "想來點不一樣的。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵……",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們這裡是",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒咖啡廳和懷舊點心店喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我想要別的啦～～！",
        "unit_id": 416,
        "voice": "vo_adv_5114004_007"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "真是的，",
        "unit_id": 411,
        "voice": "vo_adv_5114004_008"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "別那樣耍任性了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "店員小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "不好意思，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "我們家孩子淨說些無理的要求……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "紅豆餡、卡士達和什錦鯛魚燒，",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "口味種類非常多……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是我能提供的只有鯛魚燒……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是不是必須再想更多種選擇的菜單不可喵……？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請問妳碰到什麼困難了嗎？",
        "unit_id": 1,
        "voice": "vo_adv_5114004_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的！",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n狹路相逢也是天注定！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是命運呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的！",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天跟姐姐換班了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我聽說有家人氣鯛魚燒咖啡廳，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就跑來偵察囉～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聽說",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最近才剛開幕，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n然而卻氣勢如轟、萬馬奔騰！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只不過我沒想到哥哥也會在。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我看妳似乎有困難呢。",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我來幫忙吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "常言道",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不行一善，焉得虎子……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我聽不懂妳在講什麼喵……",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "借用一下",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "廚房！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來，",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請問這樣如何？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這是用餅乾和棉花糖做成的可麗餅♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇！",
        "unit_id": 416,
        "voice": "vo_adv_5114004_018"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這個好酷喔！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n看起來好好吃！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "啊，",
        "unit_id": 414,
        "voice": "vo_adv_5114004_019"
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "我也好好奇，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "可以給我一份嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次我試著放了搗碎的糖果，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "搭配鯛魚燒的卡士達醬♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這邊的是",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "用有點鹹鹹的零嘴，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n和帶出紅豆餡甜度的可麗餅！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇～！",
        "unit_id": 416,
        "voice": "vo_adv_5114004_022"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好好吃～！！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好厲害喵……",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從有限的材料裡，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n生出了無限組合的可麗餅……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也必須再多多思索才行喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n好……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "加了果凍的紅豆鯛魚燒喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這邊的是",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雲朵棉花糖軟綿綿的鯛魚燒♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有卡士達醬裡面",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "加了餅乾和巧克力，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n極為奢侈的鯛魚燒喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "我也要！",
        "unit_id": 6511,
        "voice": "vo_adv_5114004_027"
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "是隱藏菜單嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "麻煩給我一份──！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵，",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請稍待片刻喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵呵，",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我稍微抓到訣竅了喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就像這樣增加花樣喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那我就來製作",
        "unit_id": 101112,
        "voice": "vo_adv_5114004_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "用可麗餅包起來的鯛魚燒可麗餅吧♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "既是鯛魚燒",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但又不是鯛魚燒，能和這樣的美味相遇……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "包起來包起來，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "任何東西都能包起來做可麗餅──！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我開的是鯛魚燒店喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要賣可麗餅就去自己的店賣喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉……",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是意料之外的刺客喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然商品還需要多一點花樣喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只有研究一途了喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "順利的話……",
        "unit_id": 125111,
        "voice": "vo_adv_5114004_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一定可以讓更多更多的",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人滿意喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此，",
        "unit_id": 125212,
        "voice": "vo_adv_5114004_034"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以妳開始下各種功夫了呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也來",
        "unit_id": 125212
    },
