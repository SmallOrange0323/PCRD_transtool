[
    {
        "type": "background",
        "background": "500091"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊少年，晚安。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n最近經常見面呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "每到傍晚，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n與你在這裡聊天已經完全變成例行公事了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，我並不覺得有被打擾。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n倒不如說，每天若沒看見你的臉，就無法靜下心來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你的存在，對我來說是種療癒。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為每天每天，若光是站著，內心會變得散漫呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，雖然是我多管閒事的勸告……",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但你還是別太常來王宮比較好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這裡再怎麼說也是這個國家的政治中樞，因此戒備極為森嚴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我知道你是個好孩子。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我們團員……【王宮騎士團】，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並不一定都抱持相同意見。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你頻繁來往王宮，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此被懷疑可能是來探查情況的間諜黨羽。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "與我親近地搭話，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也是為了知道王宮的內部情況……等等的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，實際上，像我這樣粗魯的鎧甲女……",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也想不出其他會自願來跟我搭話的理由呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "客觀來看，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n確實是很有說服力的意見。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為你往返於打工地點時會經過王宮旁邊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此順便前來這裡～你之前是這麼說的吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是我稍微委託我的部下，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n調查了你的事情之後……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你所工作的店家，地點距離王宮有些遙遠。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也就是說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你是特地繞道來拜訪我的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比起因為實在是太想見我，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n才頻繁的往來這裡的想法……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你是為了某種目的而來到王宮，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的判斷還比較實際。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "至少，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】的夥伴們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是下了這樣的結論。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以少年，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你不要再來見我比較好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你也不喜歡被懷疑是可疑人士吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對我個人來說… …",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n與你見面聊天非常開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這讓我度過了非常有意義的時間喔，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n絕不是謊言。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我曾認為我的人生，直到這副身軀腐朽為止，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n都只能佇立在王宮前，如同擺設。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，我與像你這樣的好孩子相遇了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是個幸運的人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正因如此。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不想讓你增添多餘的操勞，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也不想給你添麻煩。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你能理解的吧，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎……",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，我也很寂寞。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，這是沒辦法的事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我們的立場不同，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是應該要能判斷是非的大人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然想和你見面聊天……但絕不能為了我這樣的任性，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而給你添麻煩。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你能理解的吧，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，請你離開吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然演變成這樣的離別令人難受，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我真的很慶幸能與你相遇。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你對外表看起來這麼可怕的我，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也能直爽的搭話。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "願意接近我並且變得親近。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真是難得的孩子呢，是個能坦率地去愛其他人的好孩子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正因為是這樣的你，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一定會受大家所喜愛的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你與下次相遇的人不會有寂寞的離別，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能夠友好的相處，我會為你祈禱的喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得好像很嚴肅，像是要分手一樣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們明明，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就只是擦身而過的陌生人，偶然相遇了而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真對不起呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我不太常與人來往，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還不太習慣這種事呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再見了，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有什麼話想說嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n造成我的困擾你也感到很抱歉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以會乖乖聽話……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是在最後，想要拍攝紀念照？",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你以前曾聽我說過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有照相機的存在而感到很有興趣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你說，剛好得到了便宜的照相機，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n最近到處拍攝照片……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n代替不能移動的我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n到處去城鎮各處拍攝照片……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原本是打算讓我看看那些照片的啊。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n今天，也是為此而特地來到王宮的對吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很開心你有這份心意。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n果然，你是個溫柔的好孩子呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n話雖如此，在離別的時候拍攝紀念照什麼的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你也真是誇張呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，確實，你失憶了呢……",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這成為你第一次的離別了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "人生充滿著離別。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你也是，得趕快習慣才行喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，也好。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我不擅長照相，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且從警戒上的觀點來看，也是不該允許的行為。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是因為你接受了我的請求，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也不能不聽你的拜託呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "搭肩吧，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "照相機借我。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，這個角度的話……兩個人都能拍進照片裡了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼要拍囉。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然因為頭盔而看不見我的表情，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但希望你能笑著。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n笑一個笑一個，Peace……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "☆",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n守護城鎮的和平，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n明明是我們【王宮騎士團】的使命。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但將來每當聽到「和平（Peace）」時，",
        "unit_id": 104711,
        "voice": "vo_adv_1047003_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n似乎就會想起今天的離別而難過呢。",
        "unit_id": 104711
    }
]