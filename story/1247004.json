    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "年初診所最後一天的夜晚。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看完診的深月，單手拿著麥酒自暴自棄。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗝。",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大家氣氛和樂融融的……",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "地新會的患者們",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為了迴避，突然全都不來了……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結果……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我又變回能讓溫泉顧客們放鬆的形象了……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗝。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是不是沒事，",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才在這裡喝酒啊～？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……你看啦～～",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個眼罩的彈力繩，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "變得鬆垮垮的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……得重新縫了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼！？",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你剛剛說親切！？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說了親切吧，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是這張嘴、",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這張嘴說的──！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗝。",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……真是的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不應該是這樣的啊～",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗚嗚。",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗝。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……嗚嗚。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗝。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗚嗚。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗝。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗚嗚。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "囉嗦～！",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "囉嗦囉嗦。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我才沒有哭呢。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……真是的，不要看我～",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………嗝。",
        "unit_id": 124711,
        "voice": "vo_adv_1247004_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那是什麼……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那道光。",
        "unit_id": 124711
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………唉。",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………唉唉。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………我不該來的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──是你啊！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在做什麼？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n過年怎麼",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "會在這種地方？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「妳才是，在這裡做什麼」？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……是啊，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "的確。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天是同學會，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是新年的慣例。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n接下來要續攤，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "正要去下一間店。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……咦？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說「但妳看起來心情不太好」",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……是嗎？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討厭啦～",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼都瞞不過你",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這場同學會",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "每年都會辦。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可是每次都有來喔，雖然很讓人意外。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "已婚的同學越來越多……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n理所當然的，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "關於家人和孩子的話題也會變多嘛。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "並沒有認為結婚就是一切喔？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在不是那種時代，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也還有",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想做的事。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只是……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼說呢……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "明明大家",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都在人生階段中不斷前進，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n卻好像只有我",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一直",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在原地踏步的感覺……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當然，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是我自己的人生。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n既不可能要別人等我，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n也沒辦法",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓別人拉著我前進，這我明白。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然明白，但……",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我在想，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是自己的研究能拿出成果，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "心情可能還會好一點吧？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之類的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之類的之類的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n呵呵，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討厭，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大過年的卻說這種事。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大人就是會這樣",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "思考些無聊的事情呢……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即使如此，在不久之前……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺和大家什麼都能聊。",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無論是焦躁、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不安、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是希望，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼都可以。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為大家都站在起跑線。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "然而現在，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有種彼此",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好像無法再更進一步的感覺……？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對處於不同人生階段的人，要是聊得太過深入，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n無論是受傷、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是被傷害，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都令人害怕。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "即使像這樣每年聚在一起，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n感覺好像也只能",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說些不著邊際的表面話……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不論喝多少麥酒，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺還是",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一點都開心不起來……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……你看，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就像現在。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你年紀這麼輕，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們到底是什麼關係，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n他們雖然一直好奇地往這裡瞧……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "卻沒半個人過來問。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………咦？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道說……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是因為我來參加，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大家才難以說出真心話嗎……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "破壞氣氛的人，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是我……？　",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……………這樣啊。",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n原來是這樣啊……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說，",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你啊。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們兩個，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "接下來要不要一起去新年參拜？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等我一下，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我去跟他們說我不去續攤了──",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦……",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_034"
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "（騷動聲）……",
        "unit_id": 1,
        "voice": "vo_adv_1247004_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦！！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說你！？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等一下──！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦咦！？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在說什麼──！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "男朋友！？",
        "unit_id": 1,
        "voice": "vo_adv_1247004_038"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n哇～真的！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "深月真厲害～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不不，等等！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "年、",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "年紀差！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼看都差太多歲了吧！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等一下！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在說什麼──！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "兒子！？",
        "unit_id": 1,
        "voice": "vo_adv_1247004_041"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "\n深月，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "妳什麼時候！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "\n不過這麼一說……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "臉好像確實有點像……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "臉哪裡像了啊！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有嗎！？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等等……",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你啊！？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "實驗品！？",
        "unit_id": 1,
        "voice": "vo_adv_1247004_044"
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "\n雖然沒辦法大力吐槽……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "\n但好像可以理解……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種事不要理解！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討厭……！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_046"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣下去會更被大家白眼的──",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "這樣啊～",
        "unit_id": 1,
        "voice": "vo_adv_1247004_047"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "你",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "和深月是那種關係啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n雖然挺意外的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "但感覺",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "一下就接受了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……咦？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_048"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說不是這樣──",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "我說，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_049"
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "你啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "\n既然你們是那種關係，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "那你要為深月……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "\n為深月的實驗",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學3",
        "words": "加油喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦……",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_050"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "嗯嗯！",
        "unit_id": 1,
        "voice": "vo_adv_1247004_051"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "實驗一定很辛苦吧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "我想。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "\n應該也有令人沮喪的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "事情吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "\n我們無法理解的事情",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "肯定也很多。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "所以希望在她身邊的你，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_052"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "能夠",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "好好支持她。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "欸～也讓我說句話嘛～",
        "unit_id": 1,
        "voice": "vo_adv_1247004_053"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n跟你說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "深月啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "從學生時代就一直在說呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n說「想做新藥」、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "「想用藥來拯救世界」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "這類的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦？",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唔，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "當我們正在戀愛、玩耍、",
        "unit_id": 1,
        "voice": "vo_adv_1247004_055"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "享受青春的時候，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n深月為了實現夢想，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "都在聚精會神地努力念書……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "然而，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_056"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "無論何時，深月總是看起來最開心的那個人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n她那時",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "就是如此拚命。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n不對，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "她現在也還是和那時一樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "非常拚命！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……！",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_057"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_1247004_058"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "\n因為深月她",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "是我的「希望之星」啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "妳幹嘛說得那麼自豪啊～",
        "unit_id": 1,
        "voice": "vo_adv_1247004_059"
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "\n她不是妳的希望之星，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學1",
        "words": "而是「我們的」希望之星才對吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_060"
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "這樣啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "嘿嘿，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學2",
        "words": "抱歉抱歉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……",
        "unit_id": 105131,
        "voice": "vo_adv_1247004_061"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……大家……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "對啊，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_062"
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "所以，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "拜託你！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1247004_063"
    },
    {
