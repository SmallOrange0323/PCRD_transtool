[
    {
        "type": "dialogue",
        "name": "忍",
        "words": "魔物的身體，",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "像霧一樣散掉了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這樣算是打倒了嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也就是，",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "由影子而生最終也回歸影子的魔物，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是嗎。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然相當難纏，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但似乎還是不敵",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我那深淵般的黑暗的魔力呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈──哈哈哈！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦？",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "復活了……！？",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "杏奈，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "危險──",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "忍小姐、",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小杏奈！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳們沒事吧！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦哦！",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n幫大忙了，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "暴食的公主！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "豐滿的公主來啦──！",
        "unit_id": 2411,
        "voice": "vo_adv_9073156_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n幫大忙了～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你要是再繼續說這種失禮的話──",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "──就會變成這樣哦。",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "噫！？",
        "unit_id": 2411,
        "voice": "vo_adv_9073156_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這次總算是打倒了嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "忍的攻擊，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓他不只是身形",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "連氣息都被消滅了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎、",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "貪吃佩可？",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳有哪裡受傷了嗎……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎、",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼連身體都消失了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像是肉什麼的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "至少也留個骨頭啊～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳是打算吃嗎！？",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為肚子剛好有點餓……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來到這個世界時，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我跟大家走散了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我一直到處走動，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尋找其他人。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "原來如此……",
        "unit_id": 100911,
        "voice": "vo_adv_9073156_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "無須擔心。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就按照這個步調跟吉格魯特他們會合吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "即使黑暗的軍隊進攻過來，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也無法切斷我們的羈絆！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就趕快出發吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是說貪吃佩可。",
        "unit_id": 103111,
        "voice": "vo_adv_9073156_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳想要肉我還可以理解，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但骨頭是？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是啦～",
        "unit_id": 105811,
        "voice": "vo_adv_9073156_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想說應該能夠熬成不錯的湯頭。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "暖呼呼的熱湯加上鮮美的味道……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "噫！！",
        "unit_id": 2411,
        "voice": "vo_adv_9073156_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n別一邊看著我一邊流口水！！",
        "unit_id": 2411
    }
]