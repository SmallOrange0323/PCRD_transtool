[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是{player}為了準備修練，\n和怜一起出門買糧食時發生的事情。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……接著要買什麼好呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "問你一下，購物清單上還有什麼――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好了！",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你快來這邊一下！",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……還好，到了這邊應該可以放心了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我看到家裡的人了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並不是不想見到他們，",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是因為現在跟你在一起……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚！這道光芒是怎麼回事！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n好刺眼……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼也……",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看不見了……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "士條同學也是這麼認為嗎？",
        "unit_id": 1231,
        "voice": "vo_adv_1003004_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "委員會的事嗎？",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n請不用擔心。妳沒有任何的錯。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這件事可以交給我來處理嗎？",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會好好地將大家的意見做個統整。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "太好了！ 真的可以嗎？",
        "unit_id": 1231,
        "voice": "vo_adv_1003004_010"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那就萬事拜託妳呢。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "感謝妳，士條同學。",
        "unit_id": 1231,
        "voice": "vo_adv_1003004_011"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n請問妳待會有時間嗎？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那個……妳方便的話，今天的事情，我想向妳道謝。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "道謝就不用了。有妳這份心意就足夠了。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且我待會跟別人有約……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "原來是這樣啊？",
        "unit_id": 1231,
        "voice": "vo_adv_1003004_013"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那麼明天學校再見喔。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n我先告辭了。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，明天見。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呼。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n預定外的商談，花了不少時間。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "差不多到約定的時間了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呦，是你啊。你已經到了啊。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那麼走吧。",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "關於下次要挑戰的任務……",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是時候該提高難度了吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也變強了許多，",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們也熟悉彼此的行動，變得更容易發動協力攻擊了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "作為提升到下一個階段的時期，你不覺得正好嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謙虛……",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺好像也不是呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你應該對自己多點自信。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你確實一直有在變強喔。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我這麼說準沒錯。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的到了那時候，",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也會保護你的，不用擔心喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總之先提升任務難度……",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼……要挑戰哪個呢♪",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你臉色很難看喔，沒事吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你那麼不安的話，再來接低難度的任務也沒關係喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說不是這個原因？",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那你在想什麼呢？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……被你看到了啊。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個人是學校的……",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "同班同學喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也許你已經知道了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我現在就讀的是間名校喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使是跟朋友說話，",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也不得不用那種死板的說話方式。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我家的情況也跟在學校一樣。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然習慣後就沒那麼辛苦了……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……果然還是很麻煩呢。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那間學校的氛圍跟我不太合的樣子。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和阿斯特朗的夥伴在一起的時候，我可以用原本的說話方式交談，",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以感覺輕鬆多了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……和你在一起時候最感到開心喔。",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……那個，不是，不是這樣的！",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我只是把想到的話說出來而已……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "………………",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起",
        "unit_id": 100331,
        "voice": "vo_adv_1003004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們繼續討論任務的事情吧！",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來，你也提出些意見吧！",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。 ",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你醒來以後很快就會忘記的， ",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，怜是大小姐呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看她平常跟你在一起的樣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很難想像呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我對大小姐生活還挺憧憬的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是作為大小姐才有的苦處，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只有她自己才明白呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她和你在一起的時候，真的很有朝氣呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果她自己覺得這樣就很滿足了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也一如往常和她相處不就好了？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼閒聊就到這裡。",
        "unit_id": 190011,
        "voice": "vo_adv_1003004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉～ ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？ ……這裡是？",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和剛剛一樣的地方……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也睡著了呢……",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼會在這種地方……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還做了奇怪的夢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，我和你在咖啡廳……",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道你跟我做了同樣的夢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……感覺好像被看到很糗的地方。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n連在夢中",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也被家中的事所束縛呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是我們睡著前，我跟你說的那件事。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才看到家裡的人，然後我就逃跑了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好歹也是貴族的大小姐呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和相關的人見面時，只能用層層禮節的談吐方式來交談。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "實在不想被你看到那樣的我……",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為在你面前我不需要掩飾自己，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以我不想再回到從前的我了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不久前……在離家出走之前，",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就像在夢中和朋友說話一樣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n用所謂大小姐的說話方式來和人交談呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很奇怪對吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是說……你比較喜歡那種說話方式的我？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了……在你面前，我不想偽裝自己。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n希望能和至今為止一樣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今後真正的我也請你多指教了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003004_051"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在接受了真正的自己的{player}面前，\n怜露出了真誠的笑容。"
