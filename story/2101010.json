[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——同一天‧傍晚前。\n　蘭德索爾城、謁見之廳——"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……當貴族議會直屬‧",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_000"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "【黃金之手】的主力部隊抵達現場後，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n魔物們便因畏懼而往地下逃亡了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "有賴他們的活躍，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "災害並未繼續擴大下去。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哦哦！",
        "unit_id": 1,
        "voice": "vo_adv_2101010_001"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n真不愧是【黃金之手】啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "然而……",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_002"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "遺憾的是，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "魔物們留下的傷痕實在太過巨大。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "包含預定竣工的克蕾琪塔之塔在內，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "廣場周邊共有15棟樓倒塌。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n負傷者也不在少數，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "目前仍在搶救當中。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_003"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……以上，",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_004"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "便為這次魔物騷動的現況報告。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n而希望陛下能做出緊急決策的，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "便是關於本次事件特別預算的核可——",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪紳。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有小可蘿她們呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "什麼？",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_006"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n不知道",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您說的究竟是？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我說的是我的朋友們。",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他們在【黃金之手】的人們抵達前，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該還待在那個廣場",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和魔物戰鬥著的才是！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你應該也有看到他們才對？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "啊～……",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_008"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您說那群人啊。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……嗯。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n嗯嗯……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "傷患的名單上，",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_009"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "似乎沒有見到像是他們的名字呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "他們難道不是",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "回到自己的公會小屋了嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯～。",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那樣的話就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得去公會小屋看看他們怎麼樣了才行……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……陛下。",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_011"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "方才",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是這邊不願還去追究此事……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n然而都已經發生這種事情了，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n您還沒有身為執政者自覺，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "而是打算以個人身分出去溜達嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗚！",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不是要去玩……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "咳！　",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_013"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您聽好了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n陛下您",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在核可過此預算後，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還得將書記官記錄下的，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n關於應對這次事件的安全聲明稿默背下來。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說安全聲明稿……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是的。",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_015"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n霸瞳皇帝之亂才剛過去不久，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "魔物卻像這樣又\n再一次出現了，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "想必這會使蘭德索爾的人民感到不安及恐懼吧。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "而能夠將如此的不安拭去的，",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_016"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不為他人……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是身為此國度最高權力者的",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n您的職責喔。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說的對。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也覺得……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "確實有這個必要呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "真不愧是",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_018"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "賢明的尤絲蒂亞娜陛下。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n能夠獲得您的理解，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "下屬",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "著實倍感欣慰。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那麼我等，",
        "unit_id": 1,
        "voice": "vo_adv_2101010_019"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這就去研議聲明稿的內容。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n暫且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "失禮了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在廣場的緊急修繕結束之後，",
        "unit_id": 191411,
        "voice": "vo_adv_2101010_020"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "便會聚集人民，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n讓陛下",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您能夠發表安全聲明。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在那之前，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還得勞煩您確認這些預算核可書了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哎……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}和大家……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果沒有受傷那就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這個樣子看來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "暫時是沒有機會可以去看他們了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個時間，",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道大家是不是正在吃點心呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我肚子餓了呀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……王宮的料理，",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說好吃是很好吃沒錯……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但餐桌禮儀好麻煩，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "害得我都沒辦法放開心胸去吃東西了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n上菜加上試毒又很花時間，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "弄到最後菜都冷掉了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……熱騰騰的飯糰，",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可麗餅、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "烤魚、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "章魚燒……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是想像了一下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的肚子就餓扁了呀……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "失禮了。",
        "unit_id": 711,
        "voice": "vo_adv_2101010_027"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n陛下。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請問有什麼事嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我在外頭的攤販",
        "unit_id": 711,
        "voice": "vo_adv_2101010_029"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "買來了肉包。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n這些",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "要獻給陛下您。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊～！！",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常感謝你！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我開動啦！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嚼嚼嚼……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～～",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好吃～！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個鮮嫩甘甜又滿溢在口中的肉汁，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真讓人受不了呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……等等，咦！？",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛那名親切的士兵先生去哪了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……您今天依舊如此美麗呢，",
        "unit_id": 107011,
        "voice": "vo_adv_2101010_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤絲蒂亞娜女王陛下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的小禮物，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能受到您的青睞可真是光榮呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似似花！？",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛的那個士兵，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是似似花變的嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是這麼回事。",
        "unit_id": 107011,
        "voice": "vo_adv_2101010_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果想要毒殺您，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "似乎是易如反掌的事情呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請您別講這麼恐怖的事情嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的確是吃了呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肉包，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳的招待！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的非常好吃唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105812,
        "voice": "vo_adv_2101010_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳來找我有什麼事嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特地瞞過警衛的目光也要來找我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有什麼",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很重要的事情要跟我說對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2101010_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那我就開門見山地",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼告訴妳好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "——這是世界的危機，",
        "unit_id": 107011,
        "voice": "vo_adv_2101010_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陛下。",
        "unit_id": 107011
    }
]