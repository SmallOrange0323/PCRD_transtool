[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在大家的同心協力之下，一行人終於擊退了大量湧入首都的魔物和闇影。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，本來已經被逼至絕境的霸瞳皇帝，\n卻變身成巨大的異樣之姿，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "並以壓倒性的力量凌駕著{player}一行人！"
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來吧――",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "世間萬物，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "跪倒在「神」的面前吧！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "呀啊啊啊～～！！",
        "unit_id": 1,
        "voice": "vo_adv_2015001_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好、",
        "unit_id": 100211,
        "voice": "vo_adv_2015001_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好痛啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "霸瞳皇帝",
        "unit_id": 100311,
        "voice": "vo_adv_2015001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "竟然變身……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "了嗎！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我還以為",
        "unit_id": 101711,
        "voice": "vo_adv_2015001_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們好不容易把她逼到絕境了呀！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡，",
        "unit_id": 104311,
        "voice": "vo_adv_2015001_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多麼驚人的魔力啊……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使跟至今以來交手過的",
        "unit_id": 105911,
        "voice": "vo_adv_2015001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所有魔物相比，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也無法跟她相提並論……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但、",
        "unit_id": 105811,
        "voice": "vo_adv_2015001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要大家同心協力的話……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "――",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「就能夠贏過我。」",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是想這麼說嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n事到如今，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳還無法理解我們之間的差距嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……不過，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是呢……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管你們聚在一起",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看似聲勢驚人，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然而一個個的實力",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "卻都遠遠不及克莉絲提娜……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "既然如此，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "分不清彼此的實力差距",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是無可奈何的嘛。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "別在那邊囉唆了！",
        "unit_id": 190711,
        "voice": "vo_adv_2015001_010"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n大嬸的一箭之仇，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "就讓老子來替她報啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲可還沒死唷……",
        "unit_id": 107011,
        "voice": "vo_adv_2015001_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然她跟我一樣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都已經",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "奄奄一息了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……咳、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "咳。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人……！",
        "unit_id": 191011,
        "voice": "vo_adv_2015001_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "傷了似似花大人的這筆帳，",
        "unit_id": 191011,
        "voice": "vo_adv_2015001_013"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我現在就要妳來還！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "霸瞳皇帝！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼。",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如此枝微末節的小事，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "光是能讓你們……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n見識到我這「神」的姿態，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就已經夠划算了吧――！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "大吾、真軌",
        "words": "唔啊啊啊啊！\n哇啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_2015001_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軌……！",
        "unit_id": 107011,
        "voice": "vo_adv_2015001_016"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "大吾！",
        "unit_id": 107312,
        "voice": "vo_adv_2015001_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……唉。",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n即使是公主騎士，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也只有這點程度嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是說，",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就只是{player}比較優秀而已嗎……？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n畢竟就連我家的凱留，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是派不上用場的廢物嘛？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗚……",
        "unit_id": 106011,
        "voice": "vo_adv_2015001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留……",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳不但背叛了我，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還恩將仇報。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n事到如今，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "少給我擺出一副被拋棄的樣子啊。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……既笨拙",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "又愚蠢，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "毫無用處，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "偶爾卻又惹人憐愛的──",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的凱留。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳究竟會在",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "何時",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "何地，以什麼方法被我丟棄呢……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我有時候會想像起這些事情，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從以前開始就是如此了。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣好了，",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "機會難得……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就讓妳成為",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我這個姿態下的第一個獵物吧？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n呵呵，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "很光榮吧？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛、",
        "unit_id": 106011,
        "voice": "vo_adv_2015001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請您原諒我！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請您原諒我……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵！",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n太好了，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n再更苦苦哀求、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哭天喊地一點吧――！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊！",
        "unit_id": 106011,
        "voice": "vo_adv_2015001_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦！？",
        "unit_id": 104911,
        "voice": "vo_adv_2015001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n她在瞄準哪――",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "望等人",
        "words": "哇呀啊啊――！",
        "unit_id": 1,
        "voice": "vo_adv_2015001_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡！",
        "unit_id": 104311,
        "voice": "vo_adv_2015001_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n剛才那一擊",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是在瞄準『慈樂之音』的飛空艇嗎！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "飛空艇……",
        "unit_id": 101112,
        "voice": "vo_adv_2015001_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再這樣下去",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就要翻覆了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們就是靠那艘飛空艇",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "找到被我操控的闇影……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然後群起圍攻，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n才將我的霸瞳天星",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給阻擋掉的對吧？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "實在太",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "令人火大了。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 105811,
        "voice": "vo_adv_2015001_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "住手……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "飛空艇……！",
        "unit_id": 100211,
        "voice": "vo_adv_2015001_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "爆炸",
        "unit_id": 100111,
        "voice": "vo_adv_2015001_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希――！！！",
        "unit_id": 100311,
        "voice": "vo_adv_2015001_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳這傢伙……！！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵。",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哈哈哈哈。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不錯呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那表情還真不錯……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "打著夥伴間的羈絆",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或友情之類的名義來跟我作對，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n儘管你們這群人，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都是如此無趣",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "且教人心煩，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但就只有你們那因為失去夥伴",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而露出的驚愕表情……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠稍微",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "討我歡心呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛、",
        "unit_id": 106011,
        "voice": "vo_adv_2015001_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n您剛才不是說",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是您的第一個目標嗎……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是啊。",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我剛才的確是覺得那麼做也不錯呢？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "凱留……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "害妳決定背叛我的──",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那些妳最愛的夥伴們，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n只要我可以在妳眼前",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "把他們一個個都變成肉片的話，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n對妳來講，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那不正是最完美的教訓了嗎……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咿――！",
        "unit_id": 101112,
        "voice": "vo_adv_2015001_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那個人的眼神，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太可怕了啦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n連腳都抖個不停……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚嗚～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "冷、",
        "unit_id": 104911,
        "voice": "vo_adv_2015001_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "冷靜一點，璃乃！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的是非常驚人的魔力……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "大家，",
        "unit_id": 104311,
        "voice": "vo_adv_2015001_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "做好覺悟！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n只要感到一絲恐懼，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就會受到影響的！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這傢伙現在",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也許真的能將我們全都殺光啊……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳說我也許能將你們全都殺光",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "毫無理解力呢……！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我都已經",
        "unit_id": 106915,
        "voice": "vo_adv_2015001_045"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "變為這副「姿態」了――",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n區區你們這種程度的傢伙，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無論要我殺光幾次我都辦得到啊！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗚……啊啊啊啊啊啊――！！！",
