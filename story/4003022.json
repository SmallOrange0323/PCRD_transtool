    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是……",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "稻荷壽司，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是狐狸大人賜與的禮物……",
        "unit_id": 105913,
        "voice": "vo_adv_4003022_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有一股醬油與砂糖的香味♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺非常入味，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好吃的樣子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一放鬆下來肚子就餓了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "時機正好，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我來試試味道……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊──♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我等一下！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "傳球！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，貪吃佩可小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_4003022_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n試吃和偷吃",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都暫且停下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊！",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n討厭，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留真是壞心眼～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從看到吃也太沒有猶豫了吧！",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼妳的動作會這麼直接連結起來啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…我說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然由我開口有點奇怪，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過妳都不會想到裡頭可能有什麼問題嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳之前",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "曾經因此而吃了苦頭對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～？",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起懷疑著誰而吃下去的飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n相信著誰而吃下去的飯",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比較美味不是嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的話絕對會這樣說的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "問這種早就知道的答案，我是笨蛋吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_4003022_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為貪吃佩可小姐的胃",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不同於常人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是那個問題，但……",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "相對地，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一開始就由我來吃。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不是要試毒，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過以防萬一。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦～？",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明看起來那麼好吃～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留真是愛操心～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這邊剛剛烹調的料理",
        "unit_id": 105913,
        "voice": "vo_adv_4003022_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "馬上就完成了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下活用了季節食材，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "試著打造出質樸而細緻的味道。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105812,
        "voice": "vo_adv_4003022_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個壽司也可以一起擺盤呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳也快點快點！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說，",
        "unit_id": 106012,
        "voice": "vo_adv_4003022_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n下次",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也教教我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所謂細緻的調味吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為我或許……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會有要自己料理的機會。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然沒問題。",
        "unit_id": 105913,
        "voice": "vo_adv_4003022_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n下次再一起採集食材、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "製作料理，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一起享用美味的食物吧♪",
        "unit_id": 105913
    }
]