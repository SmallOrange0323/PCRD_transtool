[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "クロエ君か？　",
        "unit_id": 111011,
        "voice": "vo_adv_6023303_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "今日はバイトがあると言ってもう帰ったぞ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼女は半ばワーカホリックなところが",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "心配といえば心配だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nときに君は、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "クロエ君についてどういう印象を持っているね？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うむ、",
        "unit_id": 111011,
        "voice": "vo_adv_6023303_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "心身ともに極めて強靭だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何故だろうね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼女は自身のプライベートについて",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "多くを語らないが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nきっとそうで在るべき必要があったのだろうな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "長女気質とでもいうのか、",
        "unit_id": 111011,
        "voice": "vo_adv_6023303_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼女はあれで面倒見がいいからな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "家庭には歳の離れた幼い弟が",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "三人いるらしい。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nおそらく君のことは、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "四人目の弟とでも思っているのだろう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "然り。",
        "unit_id": 111011,
        "voice": "vo_adv_6023303_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼女はさながら食後の肉食獣だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくらの戯れ言も、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "日頃は尻尾で蠅を追うようにあしらっているが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "仮に本気で怒らせてしまった場合は……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あばばばおそろしや……",
        "unit_id": 111011
    }
]