[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣來到美食殿堂的公會小屋，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與可可蘿一起做飯。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由於食材不足，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿和雪菲要一起出門採買，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而這段期間就由優衣負責看顧睡著的{player}。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "慢走喔～！",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可可蘿跟雪菲",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看起來好開心。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還說「為了主人，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在下想盡可能選擇更好的食材」",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n可可蘿",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的很重視騎士先生呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "睡得真熟。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "睡著的時候",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就跟原本的騎士先生一樣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼又變得像小嬰兒了呢……？　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也不知道",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "卡里莎或其他人",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n什麼時候又會打過來，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在我就代替可可蘿跟大家，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好好地照顧",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……啊，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "醒了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "早安，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是優衣喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你肚子餓不餓？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "需要上廁所嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你要去哪裡！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n等一下！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可可蘿跟雪菲，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "暫時出門了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在她們回來之前，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會陪著騎士先生的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其他人事情辦完之後，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也一樣會過來這裡。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以不要慌，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好不好？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對喔……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在的騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幾乎沒有與其他人獨處的機會，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也許是因為太過安靜，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以有點嚇著了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……即使是和這樣的騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我好像還是，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "無法好好和他說上話……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可可蘿年紀比我小那麼多，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n卻能把騎士先生照顧得那麼好……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n她真是厲害……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "別哭嘛……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n怎麼辦……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要不要吃點心？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不想吃？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這樣啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真對不起。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n看來，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我沒辦法盡到媽媽的職責呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然只靠我一個人還是沒辦法嗎……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生他，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "遇到有困難的人，都不會置之不理。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "換成騎士先生遇到困難，我也想幫助他……！　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也一樣，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "必須盡力去做我能做的事……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "媽媽以前",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是怎麼照顧我跟弟弟們的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就用同樣的方式對待騎士先生就好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我記得，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在這種時候她會把我們摟在懷裡……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……等一下！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "摟、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "摟在懷裡！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起喔，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我聲音太大了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n嚇到你了吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是害羞的時候了……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n現在能撫慰",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生內心寂寞的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就只有我一個人。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在的騎士先生是小嬰兒。",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "小嬰兒。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "小嬰兒……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還需要媽媽溫暖的",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "年幼孩童……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像是要",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "連心靈一起擁抱一樣，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "將騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "溫柔地摟在懷裡……",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "180200101"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……沒事了，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不要怕喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有我陪在你身邊。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家都不在，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你很不安吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你覺得很寂寞吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會陪著你喔。",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n直到你不再寂寞為止，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我都會一直陪著你……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以放心吧……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "來，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "試試看，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "把我緊緊抱住。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我現在就跟騎士先生在一起，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以感覺到嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒錯，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是優衣喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在緊緊抱著騎士先生的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是我喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能感受到",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的體溫嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n剛才真是抱歉，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就在你身邊，卻沒有察覺到你的感受。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不會再讓你孤單了。",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我會一直、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一～直陪在你身旁……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一開始還在發抖，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但現在已經停了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n太好了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他心中的不安應該消失了吧……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……好乖好乖。",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我還是第一次",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼近距離",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "接觸到騎士先生的身體……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我的心好像",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也跟著平靜下來了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n已經……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒事了嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那就好。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就鬆手囉。",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看來總算解決問題了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他的表情也不再緊張，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個做法確實有效呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不過，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我從來沒有想過，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n自己會像這樣緊緊抱住騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我現在的感受，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟至今我對騎士先生的感受，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "完全不同。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並不是臉紅心跳的感覺，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而是從內心深處",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "湧現出一股溫暖。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難道這不是戀慕……",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而是愛情、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "肚子餓了呀？",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n看來這也是原因之一吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯～",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等一下就要吃飯了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果只是做一點東西吃墊墊肚子，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n應該沒關係吧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等我一下喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要做什麼好呢……♪",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_042"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……果然一個人，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是覺得很寂寞嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然因為等一下可能會用到火，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_043"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我比較希望你能乖乖待在一旁……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……不過這麼做，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_044"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "反倒對騎士先生沒有幫助吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "問你喔，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你能不能乖乖聽我的指示，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當我的小幫手呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好棒喔！",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_046"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我們就一起做吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n等可可蘿她們回來，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也請她們吃好吃的！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "無論是多麼微不足道的小事，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_047"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都有可能成為讓騎士先生恢復原狀的契機。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我一定要相信這一點。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為此，我希望像今天一樣，",
        "unit_id": 100211,
        "voice": "vo_adv_1802001_048"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要是能為騎士先生做的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不管大事小事，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我都要盡量去做。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是優衣和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人一起做著料理，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊等待可可蘿她們回來。"
    }
]