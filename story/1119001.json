[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在新年的節慶氣氛開始趨緩的時候，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n小小嚮導久違地打開了【美食殿堂】公會小屋的門。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是可可蘿，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下回來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下的老家",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "離蘭德索爾有點遠，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以花了好一段時間",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才回到主人身旁……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您頭髮睡亂了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……拍呀、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拍呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如您所見，在下已經回來了，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從今天起，請讓在下繼續全心全意地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照顧您的生活起居。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "離新的一年開始以來，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經過了一段時間，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n差不多",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也該注意",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "服裝儀容等方面的事情了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經有一段時間未幫您清潔耳垢了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事不宜遲，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下看看吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請把頭躺在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的大腿上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掏呀、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "掏呀♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很癢嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還差一點點而已，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望您能再忍耐一下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不如",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來聊天轉移注意力吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是怎麼度過新年的呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請說給在下聽吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您有沒有夢到很吉利的",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "新年初夢呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到是……！",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n差點被大量分身的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐給吃掉",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而到處逃跑的夢啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那還真是不幸呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且您還",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直忙著打工，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法好好休息啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那還真是遺憾，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是您從新年起就在工作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在很了不起。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來擔任您新年的嚮導吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下在回來的路上",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經過了繁華街，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡還有在辦廟會，非常熱鬧喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾節慶的",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n舉辦期間這麼長，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對我們來說很剛好呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然沒辦法",
        "unit_id": 105913,
        "voice": "vo_adv_1119001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從新年第一天就引導您……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下已經回到主人身旁了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從現在開始，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來擔任您的嚮導吧。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "元旦都過一段時間了，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是非常熱鬧呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "走吧，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們先去做新年參拜，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "許下今年的願望吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是主人",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要享受新年，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為自己",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也應該穿上合適的服裝",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "隨侍在您身旁才恰當。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開始擔任主人的嚮導，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對在下而言",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是件值得慶祝的事情。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，今天請讓在下",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這樣",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "穿著新年和服隨侍在您身旁吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "神殿職員",
        "words": "歡迎來喝溫暖的甜酒～",
        "unit_id": 1,
        "voice": "vo_adv_1119001_020"
    },
    {
        "type": "dialogue",
        "name": "神殿職員",
        "words": "\n請自由取用～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您想喝甜酒對吧？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是讓身體著涼就不好了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們就邊喝",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "邊走到參拜所去吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～……",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請再稍等一會。",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了避免讓主人燙傷，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正在",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把甜酒給吹冷。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您等不及",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想快點喝了嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然可能還有點燙，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但既然主人想喝的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就沒辦法了呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，請用，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小心別燙到了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請慢慢享用。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要慢慢地喔？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　慢慢地……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗯，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有點燙啊。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就繼續為您將它吹冷。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～～",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼～～……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該沒問題了。",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您久等――",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有個人數眾多的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "參拜團體來了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人──",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別走散囉──？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人潮變少了呢……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請享用甜酒吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哎呀？",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　主人您到哪裡去了？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一直在將甜酒吹冷，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經不會燙囉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請喝吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人──？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明馬上就要到參拜所了，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻到處都",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看不到主人的身影。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是被剛才的",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "參拜人潮給擠散才走失的嗎……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人──",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人──？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然試著去找過神社內的各個地方，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但參拜人潮實在太多了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要找到主人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當困難。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好耶！",
        "unit_id": 311,
        "voice": "vo_adv_1119001_040"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "　是大吉～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真厲害，",
        "unit_id": 411,
        "voice": "vo_adv_1119001_041"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "太好了呢！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "聽說這裡的籤啊，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "戀愛之類的內容",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "寫得超準的，非常有名喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他們",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在求籤啊……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "戀愛……",
        "unit_id": 311,
        "voice": "vo_adv_1119001_043"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "『心繫於你的人",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就在眼前』",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "上面是這樣寫的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n就在眼前……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是指妳嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怎麼可能嘛……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……",
        "unit_id": 411,
        "voice": "vo_adv_1119001_044"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那支籤",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "說中了喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦！",
        "unit_id": 311,
        "voice": "vo_adv_1119001_045"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "　真的嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我也",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "從很久之前就……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦……！",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來這裡的籤",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是真的很靈驗呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也來求支籤看看吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許會有",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關於主人所在之處的線索。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然平時",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太敢接受來自愛梅斯大人之外的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神諭，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但現在主人都走失了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼做也是無可奈何的。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "懇請您諒解……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凡事都要試試看才好。",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n上頭到底",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會寫些什麼呢……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n『等待之人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在身旁",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n幸運之鑰",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是溫暖的飲品』……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是因為",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等待之人不在身旁，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下才感到困擾啊……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算幸運之鑰",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是溫暖的飲品，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下手上",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也只有這杯早就冷掉的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甜酒……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拿到這杯甜酒的地方，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還沒回頭去找過呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說不定……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來您在這裡啊。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您等了這麼久，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的非常抱歉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼時候到這裡來的？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您被捲入剛才的參拜團體",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟在下走散後，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就先回到我們一開始就來過的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "分發這杯甜酒的地方了？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會注意別再與您走散了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經回到了主人的身旁。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請把您手上的甜酒給在下吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您才剛拿到而已，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還非常燙吧？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要像這樣……",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和在下這杯冷掉的甜酒混在一起，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該就能變成剛好適合飲用的溫度了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……來，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請用。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 111911,
        "voice": "vo_adv_1119001_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那真是太好了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總算讓主人",
        "unit_id": 111911
    },
