    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "它大概逃到哪裡去了吧……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊、姊姊！？",
        "unit_id": 103811,
        "voice": "vo_adv_5001004_057"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼……對不起哦小栞、{player}……",
        "unit_id": 101211,
        "voice": "vo_adv_5001004_058"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n超能力用過了頭……睡意湧上來了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}……",
        "unit_id": 101211,
        "voice": "vo_adv_5001004_059"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞就……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "拜託你了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……",
