[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "特別講座的事前說明會——"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在秋乃等人口頭告知細節後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n引起了聖德蕾莎女子學院的學生一陣騷動。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果提出好點子，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "財團就會提供經濟上的協助，協助將點子具體化。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n原來這次講座的主旨是這樣啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我聽說沒有經驗和信用的創業家，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很難得到一般投資人的支持，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以會尋找叫做商業天使的有錢人資助。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想她們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一定就是我們的天使。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "天使‧龍殺手……",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n屠龍者天使…………",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不錯嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀～",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然是在修女的校權騷擾之下，才勉為其難地參加了這個講座，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但沒想到居然有機會晉升成為名媛，真是驚人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n別說是從天而降的禮物了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這可以說是鵝生下黃金和菓子的等級了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這裡不用特別用和菓子來比喻吧。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那不重要～！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "平常學校辦的這種特別課程，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大多是要被逼著聽一些又臭又長的演講，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後再要我們寫一些又臭又長的報告不是嗎！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "的確。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "關於這一點，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這次只要在正式發表時，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好好展現成果就行。這真是太有利了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只要展現出成果就好了呀……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "既然如此，不是已經有了嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "用那個不就好了？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就是優妮學姐飼養的那個，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是那個，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "偶爾會被拿來壓紙的那個——",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳是說羅塞塔啊。",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼一說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那種可以立即做出來的簡易仿魔像，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n便是我的繭居族精神——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是由我的原創想法所孕育出來的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n瘋狂的產物——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我嶄新技術的結晶。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "完全符合財團的要求。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的假的。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，那就選那個啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不就已經有成果了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要命，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們這樣就不戰而勝了耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "已經沒有什麼事可做了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼。",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n以上，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "便是有關特別講座的內容。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也許各位還有些困惑。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但各位要做的事情",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "非常簡單。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "——那就是挑戰",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "身為邁向未來的學生，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n將妳們想實現的夢想，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "具體呈現在我們的面前吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼覺得秋乃學姐這句話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好像是看著我們講的？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼回事。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐翻譯一下，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "講白話一點。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "挑戰精神……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不只看結果，還要看過程……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看來，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎是在告訴我們不可以作弊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這次這個並不是商業行為，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而是學習商業的課程。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果是商業行為，結果就會是一切。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但如果是課程就不一樣了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n財團",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "恐怕也是尊重委託人的意見吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "委託人？　",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是我們學校。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是。",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡的學院，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一定有要求她們必須注意我們四個人的行動。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這很像希爾達修女會做的事。",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小希爾修女",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "最近都能看透我們的思路耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，還有。",
        "unit_id": 103211,
        "voice": "vo_adv_5038600_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這次的特別講座，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們也很重視過程。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "發表的時候，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請將相關資料統整成一份報告提交出來！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……這",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也是委託人要求的內容吧？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把過程做成報告嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是要我公開自己的思考模式嗎。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是太過分了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "本校的教師們，難道沒有隱私權這種概念嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且，",
        "unit_id": 110811,
        "voice": "vo_adv_5038600_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "單純就是很麻煩。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所謂的報告，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是指像作文之類嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那類型的東西，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我都不太擅長耶……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是說要這麼做的話，",
        "unit_id": 110911,
        "voice": "vo_adv_5038600_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "約束學生的時間不會太長嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這不會有點黑心嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在現今的社會風氣下，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的不要緊嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我雖然同意琪愛兒的想法，",
        "unit_id": 111011,
        "voice": "vo_adv_5038600_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但這並不是工作。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很遺憾，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "目前我們國家，還沒有迎來有關學習的革命。",
