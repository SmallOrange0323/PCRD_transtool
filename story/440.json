[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵，",
        "unit_id": 128311,
        "voice": "vo_adv_0000440_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總算過完年了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是屬於我的一年啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽好了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我祈梨大人",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是今年的老大啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n來吧，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "壓歲錢拿來喔。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好了好了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快一點！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "新年快樂。",
        "unit_id": 127712,
        "voice": "vo_adv_0000440_001"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n希望今年也會是很棒的一年。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……好了，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆也好好問候。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "新年快樂。",
        "unit_id": 127812,
        "voice": "vo_adv_0000440_002"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "今年也請多指教──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……唉。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "令人難過的是，從元旦開始就有工作……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127712,
        "voice": "vo_adv_0000440_003"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我說烏爾姆！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "身為萊拉耶爾殿下的隨從，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這種時候就必須好好問候──",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂，",
        "unit_id": 128311,
        "voice": "vo_adv_0000440_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那邊的兩位！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不要乾脆忽視別人，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n悠哉地進行什麼新年問候啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_0000440_005"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "對不起。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但一年之計在於元旦，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "所以，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n為了成就美好的一年，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也必須好好進行才行。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "又",
        "unit_id": 127812,
        "voice": "vo_adv_0000440_006"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "要打掃了喔？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……穿著女僕裝。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咿！",
        "unit_id": 128311,
        "voice": "vo_adv_0000440_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我絕對不要！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我拒絕！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "…",
        "unit_id": 128311,
        "voice": "vo_adv_0000440_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "…咳咳，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "新年快樂！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n今年絕對也會是很棒的一年！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "儘管放心",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一起冒險吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請多指教喔，",
        "unit_id": 127712,
        "voice": "vo_adv_0000440_009"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "請多指教。",
        "unit_id": 127812,
        "voice": "vo_adv_0000440_010"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……我主要是對老姊說的。",
        "unit_id": 127812
    }
]