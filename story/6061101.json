        "words": "啊啊，",
        "unit_id": 105214,
        "voice": "vo_adv_6061101_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真教人難以置信！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我竟然可以出席憧憬的舞會！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這未免進行得太順利了，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該、",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該不會",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是在做夢吧？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "既然你這麼說了，",
        "unit_id": 105214,
        "voice": "vo_adv_6061101_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那這肯定不是夢。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "發生了比夢還要更不可思議的事……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人生實在是令人難以捉摸啊。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀啊！",
        "unit_id": 105214,
        "voice": "vo_adv_6061101_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你這是在做什麼啊……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為了確認這是不是夢？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我的確已經知道這不是在做夢了，不過，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n除了我之外，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你可別對其他女孩子也這麼做喔。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 105214,
        "voice": "vo_adv_6061101_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這個嘛……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果是做夢那也無所謂。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就算是做夢，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我所憧憬的舞台還是沒有改變。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不好好享受就太可惜了♪",
        "unit_id": 105214
    }
]