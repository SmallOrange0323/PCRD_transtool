    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兩位",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "很會衝浪，讓我嚇了一跳……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真的是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "才貌雙全呢……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "沒有那麼厲害啦～？",
        "unit_id": 131111,
        "voice": "vo_adv_5148067_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那種事情，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "只要靠感覺就可以辦到了吧♪",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那是兩位發揮了相應的能力啊……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "沒有正確的姿勢",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "和適度掌握力量的話，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n一定",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "會摔進海浪裡的……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是「豁出去啦」，",
        "unit_id": 131213,
        "voice": "vo_adv_5148067_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這種感覺吧★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "用就算失敗了",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也沒關係啊～的感覺♪",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是……",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要說連使劍才能都沒有的我，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有沒有辦法像多才的兩位一樣，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "輕靈地衝浪的話……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯～",
        "unit_id": 131213,
        "voice": "vo_adv_5148067_005"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我開始覺得麻煩起來了！",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n在夏天結束之前，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "再帶莉莉",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n去做衝浪的特訓吧★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "喔，",
        "unit_id": 131111,
        "voice": "vo_adv_5148067_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不錯呢。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "妳看嗎，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "要用那個～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "什麼來著？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "愈挫愈痛的精神啦～♪",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您那樣",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "會變成單純的失敗啊……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "若我用愈挫愈勇、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「不屈不撓」的精神",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n去練習的話……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊～",
        "unit_id": 131111,
        "voice": "vo_adv_5148067_008"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "對對對～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就是那種感覺？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然我不懂是什麼意思，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "總之就先",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n準備衝浪板吧～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "莉莉想要什麼顏色的衝浪板？",
        "unit_id": 131213,
        "voice": "vo_adv_5148067_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想應該可以從很多種類中挑選喔～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可以的話請選保守一點的顏色……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n不過要問我具體來說是什麼顏色的話，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也不清楚……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那麼",
        "unit_id": 131111,
        "voice": "vo_adv_5148067_011"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我幫妳預約金色的吧～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "會閃亮亮的那種～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦咦……！？",
        "unit_id": 131611,
        "voice": "vo_adv_5148067_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那不是離保守最遠的顏色嗎……！？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請等一下，涅婭小姐，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請您務必三思啊……！",
        "unit_id": 131611
    },
