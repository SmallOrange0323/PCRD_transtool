[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "熱死了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全身都是汗，黏答答的……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳快想想辦法啦～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105911,
        "voice": "vo_adv_9067155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算您這麼說……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使借用風之精靈的力量，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這裡也會變成熱風……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很遺憾，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許只能去習慣吉歐‧格黑納的環境了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩位，",
        "unit_id": 105811,
        "voice": "vo_adv_9067155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請看那邊打起精神來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那植物",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會結出像火焰般的果實喔～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是在嗨什麼……",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那植物怎麼看都很危險，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不能隨便靠近吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不能吃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對不吃！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_9067155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我什麼都還沒說耶？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳那口水直流的樣子毫無說服力啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是食蟲植物對吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "尺寸大到誇張，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "與其說是食蟲，更像是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是食人植物呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9067155_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9067155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有大型野獸被逮住，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正在被溶解掉耶。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說，",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們的處境",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "豈不是更加不妙嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如此可怕的地方，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "人真的能活下來嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說吉歐‧格黑納",
        "unit_id": 105911,
        "voice": "vo_adv_9067155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是弱肉強食的世界。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是人沒有同樣地變強，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必無法生存下去吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說起來，",
        "unit_id": 105811,
        "voice": "vo_adv_9067155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這裡遇見的人們也很強悍的樣子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟吉歐‧提格尼亞的人們相比，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺又是截然不同呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就連魔物",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也明顯地有差耶。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n又大",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又強悍，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來全都很危險……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一定不正常啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛抵達這裡時，",
        "unit_id": 105911,
        "voice": "vo_adv_9067155_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n馬上被雙冠龍般的魔物追趕，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是嚇出一身冷汗……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 106011,
        "voice": "vo_adv_9067155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話才剛說完，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是那時的雙冠龍！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該不會",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直追到這裡來吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如此深的執念",
        "unit_id": 105811,
        "voice": "vo_adv_9067155_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也很不正常耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始戰鬥吧！",
        "unit_id": 105811
    }
]