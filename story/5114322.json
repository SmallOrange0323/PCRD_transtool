[
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好巨大的招財貓……",
        "unit_id": 125211,
        "voice": "vo_adv_5114322_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有點可愛──",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感覺牠好像散發著不祥的氣息。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到底是……？",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……有種很不好的感覺喵。",
        "unit_id": 125111,
        "voice": "vo_adv_5114322_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那傢伙的周遭，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼聲音都沒有喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有能力的貓咪會將爪子藏起來……",
        "unit_id": 125111,
        "voice": "vo_adv_5114322_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠一定",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "藏有什麼不得了的密技喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒有聲音……？",
        "unit_id": 125211,
        "voice": "vo_adv_5114322_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來如此，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "牠是想打斷我們詠唱嗎？",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣的話，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就不能再拖拖拉拉的了。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無論如何",
        "unit_id": 125211,
        "voice": "vo_adv_5114322_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都要阻止牠的計謀。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別給牠蓄力的機會！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要一口氣攻進去！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "交給我喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114322_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可別小看貓咪的靈敏度喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就讓牠見識一下強力的貓拳，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "使牠喪失戰意喵！",
        "unit_id": 125111
    }
]