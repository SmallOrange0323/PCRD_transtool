    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "兔子先生就不會怕我們了呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥也試試看～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "唔哇～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥，學得很像、很像～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "沒事的喔～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥一定會是一隻可愛的兔子先生～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥，和美美一起做吧～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這樣的話，兔子先生就會立刻出現了吧？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美呢～如果見到兔子先生的話，",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n一定要盡情地撫摸牠～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好想快點見到兔子先生呀～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "毛茸茸、毛茸茸、兔子先生～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_008"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n快點出現吧，蹦蹦跳～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊！哥哥，你聽見了嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "現在的聲音是兔子先生的叫聲呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是從森林那裡傳來的。",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我們過去看看吧～！",
        "unit_id": 102011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥，",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_011"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這邊這邊～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "兔子先生，等等～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_012"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n是、是魔物！？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_013"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這個叫聲原來是魔物先生的聲音嗎……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不是兔子先生呀～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美還以為總算找到了呢……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗚嗚……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？哥哥，怎麼了？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_015"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n你說魔物先生的後面……？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――呱歐歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊～是兔子先生的叫聲！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n原來是小小格里芬先生的聲音呀～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "牠怎麼了呢～？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n小小格里芬先生一臉悲傷的表情呦～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美試著問牠看看喔～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_018"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "大、大事不好了，糟了～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "牠正在向我求救呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這隻魔物先生似乎正在欺負牠。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "可以呦～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美就是知道牠應該是在說這件事～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是真的呦～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_021"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊，哥哥也來聽聽看吧～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "對吧？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_022"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n「好可怕～！救救我～！我會被吃掉的～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美、哥哥～！」",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "牠是這麼說的吧？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我們得幫幫小小格里芬先生才行！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "魔物先生雖然很可怕……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但是欺負別人是不對的～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？哥哥也要幫忙嗎？",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_024"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "謝謝哥哥～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n我們一起幫幫小小格里芬先生吧～",
        "unit_id": 102011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "太好了～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_025"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n魔物先生逃走了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "因為哥哥一起幫忙的關係，",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_026"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n所以美美也很努力呦～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這樣小小格里芬先生就可以放心了吧～",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_027"
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，咕嚕咕嚕～♪",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊哈哈，",
        "unit_id": 102011,
        "voice": "vo_adv_1020005_028"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好癢呀～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n但是牠全身毛茸茸、軟綿綿的～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n摸起來真舒服～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是得到幫助的小小格里芬也因此非常親近美美。"
    }
