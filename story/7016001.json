        "voice": "vo_adv_7016001_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且還飄在空中……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "做什麼？",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "當然是要收下布丁啊！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你才是，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在這種地方做什麼？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "難道，",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們認識嗎……？",
        "unit_id": 104211
