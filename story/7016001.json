    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這位宮子小姐……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想起來了！",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是望的朋友，伊莉亞小姐的公會……",
