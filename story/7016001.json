        "type": "dialogue",
        "name": "宮子",
        "words": "你們",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_035"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要往上登這座塔嗎？",
