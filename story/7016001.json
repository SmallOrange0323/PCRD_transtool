        "voice": "vo_adv_7016001_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在的宮子只是個流浪布丁鬼魂喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "比起那個更重要的是布丁喲！",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這個行李裡面有布丁的氣息！",
