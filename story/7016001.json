    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子可是知道的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的確是有帶著布丁沒錯……",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我就知道！",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_016"
