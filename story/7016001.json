        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂！",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不要妨礙人家啊！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這個就由宮子收下了──！",
