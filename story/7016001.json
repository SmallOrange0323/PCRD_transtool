        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是精靈。",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_026"
    },
