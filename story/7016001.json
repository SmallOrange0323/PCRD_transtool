        "type": "dialogue",
        "name": "千歌",
        "words": "沒錯，",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是【惡魔偽王國軍】的宮子小姐對吧？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不是。",
        "unit_id": 100711,
        "voice": "vo_adv_7016001_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_7016001_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那種盡是些無情傢伙的公會我才不要！",
