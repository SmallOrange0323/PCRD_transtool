        "voice": "vo_adv_7016001_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "行李又飄在空中了……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚呀！",
