    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一個接著一個逃出城外的蘭德索爾居民之中，\n【惡魔偽王國軍】的成員們，\n為了守護難民們正在努力奮戰當中。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎哦哦哦哦哦！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "避難民眾（中年男性）",
        "words": "呀啊啊啊！",
        "unit_id": 1411,
        "voice": "vo_adv_2013008_000"
    },
    {
        "type": "dialogue",
        "name": "避難民眾（中年男性）",
        "words": "\n誰、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "避難民眾（中年男性）",
        "words": "誰來救救我！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "嗚哇啊啊啊！",
        "unit_id": 111,
        "voice": "vo_adv_2013008_001"
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "爸爸、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "媽媽，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "你們在哪裡～！？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎哦哦哦哦哦！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里，",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那孩子就交給妳了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "乖喔乖喔，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "來我這邊～？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經沒事了唷♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "嗚、",
        "unit_id": 111,
        "voice": "vo_adv_2013008_004"
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "嗚嗚？　",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "避難民眾（少年）",
        "words": "嗚哇哇！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你這傢伙，",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "竟然敢把這麼小的孩子嚇成這樣！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n給我滾到一邊去啦！笨蛋！",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嗷嗚嗚嗚嗚嗚！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼，",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "吼～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這到底是怎樣啦",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可惡可惡可惡！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到處都有一大堆魔物！",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然現在還勉強擋得下來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但照這樣下去",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不用多久就會撐不住了呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳冷靜點，",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n妳那樣反而會更累唷？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "乖唷乖唷，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓茜里抱抱治癒妳唷～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呣咕！　",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等一下啦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳這樣抱上來我不是很難走路嗎！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳別把我當成小孩來哄了呀，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n雖然我們同年紀",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但怎麼說我也是姐姐吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚呼呼～♪",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就算是當姊姊的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "偶爾也會有想要向人撒嬌的時候不是嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……每次總是讓妳來幫我的呀，",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "偶爾",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳也依賴一下茜里嘛。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "依里、",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "茜里，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳們辛苦了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要能夠確保了逃到這個區域的人們的退路，",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就暫時能夠放心了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "城內居民的避難，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該不用多久就能夠結束了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是、",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是那樣嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太好了啊～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "再怎麼說我都快要到極限了啊……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯～",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是在大家都去避難之後，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n佔據在城裡頭的魔物",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還是得要盡可能處理掉才行吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果城中到處都被魔物佔據了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那大家就會回不來了嘛。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因此，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是得盡可能的再加把勁了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若不出所料其他的公會，",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "特別是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "武鬥派的【哞哞自衛隊】之類的公會，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該會對這次城內發生的危機採取些動作才是……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們也盡可能與她們協調來行動，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後一同攜手突破困難的局面吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這場前所未聞的災厄，",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就讓我們同心協力來闖過吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然連占卜的時間都不剩了，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因此只能靠直覺來說這番話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們的未來一定還留有希望的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唉……",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過再怎麼說一直持續著如此激烈的戰鬥，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是相當辛苦呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳沒事吧！忍！",
        "unit_id": 2411,
        "voice": "vo_adv_2013008_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n妳從小就沒有什麼體力，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "所以可不要太勉強自己了呀？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好呀，",
        "unit_id": 2411,
        "voice": "vo_adv_2013008_021"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這裡就包在老子的身上吧！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這也是剛剛那對雙胞胎讓我們知道的，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n若要治癒那疲憊不堪的心靈，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就要靠家族之間的溫暖呀！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "來吧忍～",
        "unit_id": 2411,
        "voice": "vo_adv_2013008_022"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "讓拔拔好好的蹭蹭妳那軟嫩的小臉蛋吧……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我蹭我蹭",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我蹭蹭蹭♪",
        "unit_id": 2411
    },
    {
        "type": "still",
        "still": "201300801"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……看來別無他法了。",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n事態演變至今，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只能使上我的最終奧義了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "先在父親您體內注入滿滿的魔力，",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n然後再扔到敵陣之中～",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "的一種強力招式。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要用上了這招，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不論敵人還是父親全都會死去。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咦？　",
        "unit_id": 2411,
        "voice": "vo_adv_2013008_025"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是開玩笑的吧，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "但這孩子的眼神完全是來真的啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我家那溫柔可愛的小女兒，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是不會做出這種喪心病狂的事情對吧……？",
        "unit_id": 2411
    },
    {
        "type": "still",
        "still": "201300802"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "開玩笑的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是為了緩和緊張的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一則小玩笑話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不不，",
        "unit_id": 2411,
        "voice": "vo_adv_2013008_027"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "從妳嘴巴講出來的玩笑話怎麼聽起來特別恐怖啊！？",
        "unit_id": 2411
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "still",
