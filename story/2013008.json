    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了，",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們幾個。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可別把緊張感都拋諸腦後啦，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在才是我等一行人",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真正的考驗呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過嘛",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒法兒變回原貌，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "根本稱不上戰力的妾身，就算說這番話也沒什麼說服力呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕嗚，",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可真不中用呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真抱歉呢，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "光是讓妳們來面對戰鬥呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不要這麼沮喪嘛伊莉亞。",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也一樣不知道為什麼感覺很不舒服，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以沒有精力去戰鬥，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n要說派不上用場的話我們兩人都一樣喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且有個伴也讓人很開心嘛，",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "耶嘿嘿～☆",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦？　",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才感覺妳的動作有些遲鈍……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳感覺不舒服嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "宮子？　",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒事吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好擔心呀！　",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還以為宮子，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n妳就只是像平常一樣沒有幹勁而已呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里，",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這就到附近的店裡頭去拿個布丁回來！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要有布丁的話，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "宮子就會有精神了對吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n買布丁的錢，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要有放在櫃台上就沒關係了嘛～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯。",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然原先就知道伊莉亞只要{player}不在身邊，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就只能維持著幼年的狀態而不能夠戰鬥。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然而宮子感到的不適也令人很在意呢，",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "畢竟她平時",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是有活力到令人稱羨的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "由於宮子是幽靈的緣故，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以對他人所散發出來的感情或魔力相當的敏感呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而現在城內滿溢著恐懼和混亂",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等等的負面情感，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才因此受到影響",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而導致感覺不適了吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若要拿我等來做比方，",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或許比較接近感冒的狀態呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管是門外漢的意見，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然而仍不希望她太過於勉強了呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯。",
        "unit_id": 103111,
        "voice": "vo_adv_2013008_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "持續面對著戰鬥到至今，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大家也",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幾乎精疲力盡了呢……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n看來該是找個安全的室內",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "靜候躲避，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "稍微休息一下較好呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也贊成這個提議。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身以【惡魔偽王國軍】之盟主下令……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "全員，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "暫時退避！　",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "以便養精蓄銳！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102211,
        "voice": "vo_adv_2013008_043"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這麼說來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我們公會的會長",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是伊莉亞來著？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊哈哈。",
        "unit_id": 100611,
        "voice": "vo_adv_2013008_044"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "實際上，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "經常都是忍在發號施令",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以差點就忘記了呢♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦咦？　",
        "unit_id": 104412,
        "voice": "vo_adv_2013008_045"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別忘記這事兒啊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們不都是因為",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "受到妾身的領導者魅力吸引才會聚集於此的嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是這樣的吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們都是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的屬下對吧！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不對。",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_046"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算一開始真的是這樣，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n現在是因為最喜歡這些夥伴們了才會聚集起來的喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "很開心的喲……",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_047"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就算變成了幽靈之後，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還能像這樣和誰連接起了羈絆呢。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "欸嘿嘿。",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_048"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這個世上除了布丁之外，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還有很多美妙的事情呢♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是大家",
        "unit_id": 100711,
        "voice": "vo_adv_2013008_049"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "讓宮子明白了這件事的喲。",
        "unit_id": 100711
    }
