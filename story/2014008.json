[
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝和誓約女君・克莉絲提娜兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在展開一場炙熱的戰鬥。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n愉快！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真愉快呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "――……！",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可真是令人愉快呀！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在更早一些",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就這麼做不就得了嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我能施展出絕對命中之斬擊！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而同時你能預知之，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再以最少的魔力採取防禦！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "互換立場也亦然！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "永遠觸不及對方的孤獨！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要瞬間的失誤就會崩壞，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有如沙堡一般！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡直就像舞蹈一般！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真想如此這般一直跳下去啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跳這場求愛與",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相殺的圓舞曲呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "――……",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_006"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這就是，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "克莉絲提娜的――",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『誓約女君』的全力。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管早已知悉，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但果然很棘手呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且逃走了的{player}他們，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n似乎也有想要做些什麼事的樣子。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可以的話得盡早，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給克莉絲提娜致命一擊才行呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有思考的餘裕呢！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可真令人受傷呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果要思考的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "希望你心中想的只有我一人啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯――",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再多看著我一點呀！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "恨我吧！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愛我吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從今以後每一日都互相殘殺吧！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如同這般，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每一日都相愛相殺吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你不覺得這樣實在太美好了嗎！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "霸瞳皇帝！！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "――",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那的確是……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一件相當美好之事吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n對於如同妳這般，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "必須得和他人交會才能得到快樂的人來說。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦？",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到你竟然會回應我的追求呢――",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但是呀――",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『我』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並不是那種人呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "克莉絲提娜，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳剛才這麼說了吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳被我的美貌，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被才能，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被我這扭曲的靈魂給吸引了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "才會想與我一同。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說得沒錯！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n從各種角度來說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如同你一般優異的人類！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n擁有這種素養能夠讓我如此心儀的人類，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論到哪都不存在呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "當然，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒錯――",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然而呀。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n如此優異的『我』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並不需要什麼友人。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『我』是……",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為了成為『神』而被養大的。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n神不論友人或是戀人，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妻子亦或丈夫都不需要。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所謂絕對之神，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論何時",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "皆是孤高之物啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n由於你是那絕對之神的緣故，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我才會如此心儀於你――",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而也就因為這個緣故，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我也才會被你給甩了嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀真困擾，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是所謂的矛盾嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "似乎是呢――",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那麼，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能不能請妳放棄呢？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不成，",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不成不成！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若如此――",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就靠蠻力硬是將你從絕對之神的位上給拉下！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用我的刀刃和你相吻！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而後除了再一次提出相同問題外別無他法啦！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊――",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒有比這還令人不愉快之事了呢！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那無法將事遂成之人的高談闊論！",
        "unit_id": 106914
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……克莉絲提娜",
        "unit_id": 107312,
        "voice": "vo_adv_2014008_023"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "那渾身的一擊……",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n即便如此，",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "仍被擋下來了……！",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……似乎是這樣呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "您怎麼了呢？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做為防禦所使用的魔力，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎比方才所使用的來得更多了唷？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『霸瞳天星』的精準度，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "正在下降……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不只是終端的魔物而已，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就連闇影們也被一一剔除的樣子呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來是將此處的機關給看破的那似似花，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n將這件事告訴那孩子了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "太令人不悅了……！　",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……給我從那兒讓開，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "克莉絲提娜。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓開？",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無聊的笑話就免了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可是被人拜託了",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說要拖延你的腳步……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可沒有要失約的打算。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更別說――",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要我從如此令人愉快的嬉戲，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在中途退出豈有可能呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我們也是，",
        "unit_id": 107312,
        "voice": "vo_adv_2014008_030"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "已經做好覺悟才會與你有所牽扯的。",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "如此一來，",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我們自然也得讓你付出相應的代價唷，",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "霸瞳皇帝。",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是夠了，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們一個又一個……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可真是一群令人無言以對的人呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我明白了……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那麼我這兒，",
        "unit_id": 106914,
        "voice": "vo_adv_2014008_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也就跟著換一副手牌來打吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "儘管……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也是千百個不願意。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "克莉絲提娜……",
        "unit_id": 107312,
        "voice": "vo_adv_2014008_033"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "小心一點。",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n她的氛圍變了。",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎是呢――",
        "unit_id": 107111,
        "voice": "vo_adv_2014008_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎樣都行。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要他能繼續陪我玩下去就行。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就讓我們繼續把這場舞跳下去吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下！",
        "unit_id": 107111
    }
]