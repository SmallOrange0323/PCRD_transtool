[
    {
        "type": "background",
        "background": "500940"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\t{player}",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您記得今天",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是什麼的紀念日嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步時遇到了惠理子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n惠理子一開口便提出了感覺很麻煩的……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n更正，感覺意味深長的疑問──"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果真是如此，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就可以請您替我慶祝了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是很可惜，答錯了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是的，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您搞錯了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "第一次見面的日子",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n可是我們的命運當中，史上最大的紀念日唷？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您居然忘了那是哪一天，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我有點受傷呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您對於我的提問努力思考的專注模樣……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "以及為此道歉的溫柔態度……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您這麼直率的性格",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "實在是太棒了……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咳咳。",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "答案是，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您第一次吃了我做的便當，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n因為藥的效果",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而靠在我肩膀上睡著的日子……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我命名為",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「晚安便當紀念日」！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "順帶一提昨天是",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「100萬朵麻痺花紀念日」，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而明天居然是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「第一次互看５秒鐘紀念日」唷！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接連有這麼多的紀念日，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這可不能不慶祝。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以說呢，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要送禮物給您。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請儘管說出任何您想要的東西吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是財力？",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是權力？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "或者是國家……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "無論什麼東西，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我都會去取來給您的！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是多麼地無欲無求……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣子",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就不能慶祝紀念日了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不慶祝與您的回憶之日是萬萬不可的！",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "究竟",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "該怎麼辦才好……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "分隊長，",
        "unit_id": 1,
        "voice": "vo_adv_5142000_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就位──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是怎麼了呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n大街那邊好像很熱鬧……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "發令員",
        "words": "向前看──",
        "unit_id": 1,
        "voice": "vo_adv_5142000_013"
    },
    {
        "type": "dialogue",
        "name": "發令員",
        "words": "起步走！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那是……",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "【王宮騎士團】。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n人數相當地多呢，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "究竟是在做什麼？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "哦？",
        "unit_id": 1411,
        "voice": "vo_adv_5142000_015"
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "小姐，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "妳不知道嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "那是從【王宮騎士團】訓練所畢業的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n新兵們的遊行！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來您也喜歡那種活動嗎。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n要不要移動到最前排呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "哦！",
        "unit_id": 1411,
        "voice": "vo_adv_5142000_017"
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "你也喜歡這種活動呀？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n很棒對吧～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "我也很喜歡，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "每一期我都會來看喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "接下來，",
        "unit_id": 1411,
        "voice": "vo_adv_5142000_018"
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "會在王宮前舉行新兵們的受封儀式。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "有興趣的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "要不要一起去看呢？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一起……？",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這種專給陌生一般市民觀賞的活動，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n與我們沒有關係，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "恕我拒絕──",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣呀。",
        "unit_id": 102711,
        "voice": "vo_adv_5142000_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說的也是。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n既然是您想看的活動，那麼",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "絕",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對要去看才行。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n現在就出發吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "立刻出發吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "翻、",
        "unit_id": 1411,
        "voice": "vo_adv_5142000_021"
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "翻臉像翻書一樣快呢，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "這位小姐……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n算了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "那麼",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "往這邊走吧，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "跟我來！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "本期的新兵訓練所畢業生，",
        "unit_id": 104711,
        "voice": "vo_adv_5142000_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "共56名。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在此",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "表揚結束所有訓練課程的各位。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我以【王宮騎士團】騎士團長之名，",
        "unit_id": 104711,
        "voice": "vo_adv_5142000_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n冊封各位",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為「騎士」。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "成績優秀者，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請代表上前。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新兵",
        "words": "是！",
        "unit_id": 711,
        "voice": "vo_adv_5142000_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "此人，",
        "unit_id": 104711,
        "voice": "vo_adv_5142000_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "將成為所有侍奉吾王之人的",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n守護者。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即將成為騎士之人，",
        "unit_id": 104711,
        "voice": "vo_adv_5142000_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n必捍衛真理、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "守護所有祈禱並且勞動的人們──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
