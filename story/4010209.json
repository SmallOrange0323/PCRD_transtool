[
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "510230"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼，",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天也很忙碌呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "回家後還有生日派對……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n校門口真熱鬧呢？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這感覺，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真令人懷念──",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "──果然，",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是你啊！",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是的，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前也發生過同樣的事吧？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明跟你說過櫻庭學院的戒備森嚴，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要多注意一點。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有事……",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這件事的話，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "事先聯絡我不就好了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們也不是打通電話還要猶豫的關係吧？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟是青梅竹馬啊。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看，",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為你這麼突然，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看看四周。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "學生們都看著這邊，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "產生不必要的誤解了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明天就會成為",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "學院裡的傳聞──",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "─",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "─嗯，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會成為傳聞呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "絕對會。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過……",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n反正也來不及了，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也沒必要",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "隱藏我們關係很好這件事嘛？　",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我會珍惜",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你送的禮物。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這之後有時間嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "偶爾也一起回去吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "接送的車……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "賽巴斯欽",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很貼心地先回去了呢。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就享受和青梅竹馬度過，",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "輕鬆愉快的",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "生日吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以你……",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個叫法",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也改回去吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要叫小咲戀了，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "叫咲戀就好，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好嗎？",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很好！",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那我們",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牽著手回去吧。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也去看看",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那間懷舊點心店好了。",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺好像",
        "unit_id": 102831,
        "voice": "vo_adv_4010209_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "回到以前一樣了",
        "unit_id": 102831
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呢……♪",
        "unit_id": 102831
    }
]