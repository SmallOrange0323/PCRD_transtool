[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n大致上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能夠把握現況了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "狀況比預想的要好上許多。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被抓起來的，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只有蠢到一股腦往前衝的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳而已……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而妳其他的同伴們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n和【拉比林斯】",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "順利的逃過了一劫。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這話還真是刺中痛處呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過嘛，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也覺得自己失控這件事，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實在是有夠笨～",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有在反省就是了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}他們，很擔心我的安危吧……",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真對不起他們。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是多擔心妳自己的事比較好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n聽了妳剛才說的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們當前的利害一致……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n能同心協力的話就幫大忙了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤絲蒂亞娜大人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個。",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果可以的話，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請叫我",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃佩可吧。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是大家替我取的，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我非常喜歡的綽號。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唉……",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要怎麼稱呼都好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對改變外貌、姿態或名稱，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以各種身分活著的我來說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "稱呼不過是微不足道的問題。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n現在要趕緊",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓妳從這個地下監獄中脫逃出去才行吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然目前看起來尚未對妳有任何危害之意，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但會持續到何時呢……",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "200900601"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "恐怕在近期內",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就會讓妳接上與我相同的魔法裝置，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n榨取妳的生命力與魔力吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……最壞的情況，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是即刻處刑。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "奪走了妳的身分，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "取而代之的真那……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對於現在以尤絲蒂亞娜自稱的他來說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n沒有讓妳繼續存活下去的理由。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……確實是這樣呢。",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『真貨』的我，",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對『假貨』的那傢伙來說，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是非常礙眼的存在吧。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算留我這條命，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是百害無一利呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n您的這條命",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以說是風中殘燭吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不如說",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有把妳盡快解決掉，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n讓妳活蹦亂跳的在這裡才是弔詭之事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是我站在那個立場，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "肯定會立刻將妳給處死。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是為了要把我當成那個叫魔力裝置的動力源嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現狀來看，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只需要我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "，就有一定程度的能量了才對。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "順帶一提，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那魔法裝置的能力是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "洗腦……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n諸惡的根源真那",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "＝尤絲蒂亞娜為了方便行事所用，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n有能夠將人們的思考給扭曲的機能。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "包括自稱為國王陛下代理人的那個凱留，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "加上",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n【王宮騎士團】等等人物",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "皆在這個魔法的影響之下，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n遭受了洗腦，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "成了尤絲蒂亞娜的掌中魁儡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣呀……",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留的樣子才會那麼奇怪呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了。",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是被她討厭，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒有失去我們之間的羈絆……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我是這麼深信著，",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但果然還是會不安呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在這樣就安心了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留就只是單純被洗腦，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被操縱了而已呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "恐怕是如此。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n順帶一提，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個洗腦裝置位於王宮最深處的王座之廳，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n被設置在地板上蔓延著魔力的湧泉之下。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "作為該裝置的動力源被連接上的我的本體，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也位於那裡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不管如何，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有把那個裝置破壞的必要。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果可能，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "同時將我的本體救出的話，就非常感謝了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼做？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我和似似花醬一樣都是被囚禁之身……",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然我也覺得那怪怪的裝置必須要破壞掉才行，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但也沒有什麼方法吧？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "方法是有。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n正如您所見，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我能夠派遣自己的分身前往各處。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n利用此分身，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "便能向外頭的同伴們進行聯絡。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若能夠取得聯繫，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不論是洗腦裝置的破壞工作……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或者是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "將被囚禁的我們給救出，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n各種作戰就能進行研討與實行吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了這些，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳的知識是必須的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在這座王宮內成長的公主殿下，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤絲蒂亞娜‧F‧阿斯特賴亞。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳如果將以防衛作為理由而未向世間公開的，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n王宮內的房間配置",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或祕密的出入口等資訊告訴我們……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n將大幅地，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "提升作戰的成功率。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是為此，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我才會前來與您接觸。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "冒著這麼大的風險呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相信您能夠理解的吧，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "公主殿下？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來完成交接的獄卒回來了呢，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "腳步聲正在接近。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會變成那邊的小石子。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而妳，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請將它好好藏起來吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一到吃飯的時間，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會再變身成為吃剩的碎屑。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而再請妳將那個碎屑，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n放在用餐的托盤上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "某個不顯眼的地方吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "廚餘都是當日會被處理掉的，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而我會藉此進行移動，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和外頭的同伴們進行接觸。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸？",
        "unit_id": 105813,
        "voice": "vo_adv_2009006_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算不用這麼大費周章……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能變成個蝴蝶或什麼的話，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就能輕輕鬆鬆從窗戶逃出去了不是嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想必是相當困難的吧。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n支配著這個王宮的尤絲蒂亞娜，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對於我的能力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她也略知一二。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不論陷阱還是監視裝置，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在各處都有被設置的跡象。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算只是讓分身逃到外頭，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也有絞盡腦汁的必要唷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "王宮四周都設置著結界，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n如果直接逃出去，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也會被人給察覺。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和廚餘一起被倒掉，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n走這條路線",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是現在逃脫成功率最高的方法。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即使和廚餘混在一起可稱不上是什麼有趣的體驗，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但也無可奈何呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起就這樣作為魔法裝置的動力源，",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n直到生命力被榨乾殆盡後死去還來的好多了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算臥薪嘗膽我也要活下去唷……",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而最後，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會回到屬於我的生存之地。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這就是，我的大義。",
        "unit_id": 107011,
        "voice": "vo_adv_2009006_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若能理解，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "且助我一臂之力就真幫了大忙了呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "公主殿下。",
        "unit_id": 107011
    }
]