    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──雖然遇到了各式各樣的問題，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但「蘭德索爾文化祭」終於安穩落幕。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隔天，智被純給叫出去。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳來啦。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n抱歉突然叫妳來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不會，",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是理所當然的。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不用介意……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有新的任務",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要委託給我嗎？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這次的任務，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟前幾天的蘭祭也有點關係……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "跟蘭祭有關的任務……",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是嗎？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智在那個活動上，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "參與了許多事，大放異彩對吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像是Cosplay、劍舞、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有阻止了直播主獵人小輝美的惡形惡狀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那些事蹟在",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "街頭巷尾十分受到好評呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】好像也有收到許多人詢問",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "關於小智的事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因此，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n連克蕾琪塔",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都對此特別關心呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "克蕾琪塔小姐……",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對我……？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊！",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為【王宮騎士團】",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正急著招募新血呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克蕾琪塔似乎是希望",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智可以擔任我們",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】成員招募海報的",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "形象大使。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦咦！？",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算妳突然這麼說……！？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這不是要勉強妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克蕾琪塔的想法",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也覺得是個好主意。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果有崇拜小智的孩子們加入我們，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n蘭德索爾的治安也會變得更好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也就是說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能夠更好地守護大家「喜歡」的這份心情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "守護大家的「喜歡」……",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以說，",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智妳",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "覺得如何呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n願意協助我們嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我知道了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我還有點困惑……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我希望能夠幫",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "蘭德索爾盡一份心力。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝妳。",
        "unit_id": 104711,
        "voice": "vo_adv_5102601_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事不遲疑，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我已經準備好攝影師了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n正確來說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是她積極地毛遂自薦",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才對。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總之，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓我介紹一下……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請進吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "呵呵……",
        "unit_id": 1,
        "voice": "vo_adv_5102601_017"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "我們又見面了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "智小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳是……！？",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那個時候，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說會一直支持我的人……！",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "是的。",
        "unit_id": 1,
        "voice": "vo_adv_5102601_019"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "我非常希望能夠再次拍攝智小姐的照片，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n所以積極跟【王宮騎士團】聯絡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n就被選為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "這次拍攝的攝影師了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "嘿嘿嘿！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "話雖如此，",
        "unit_id": 1,
        "voice": "vo_adv_5102601_020"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "但這是工作！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n我會",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "盡量壓抑自己的私情，好好完成海報照片拍攝的工作！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這、",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "拜託妳了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "也請妳多指教！",
        "unit_id": 1,
        "voice": "vo_adv_5102601_022"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n因此，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "首先希望妳能夠再穿一次",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "蘭祭時的變裝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼……！？",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n為什麼團員招募的海報照片，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還需要變裝啊？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "這是我的喜好……",
        "unit_id": 1,
        "voice": "vo_adv_5102601_024"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "不是啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n果然還是因為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "那套衣服",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "比較能夠展現出警察的感覺嘛！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n這樣看起來更可以強調【王宮騎士團】",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "的風格。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原、",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原來如此……？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "被妳這麼一說，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像也有點道理……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "對吧！",
        "unit_id": 1,
        "voice": "vo_adv_5102601_026"
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "所以啦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "就請妳趕快",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "換裝吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "\n別擔心！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "我會把妳拍得很",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智的粉絲",
        "words": "帥氣的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103712,
        "voice": "vo_adv_5102601_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "拜託妳了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……老實說，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我對變裝還是有點害羞……",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過又有機會可以穿上那套衣服，覺得有點期待呢……♪",
