        "voice": "vo_adv_1223005_000"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牛奶～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n咕嘟咕嘟咕嘟～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n變好喝吧～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不曉得",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_001"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從會不會喜歡",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比煮的湯呢～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚！",
        "unit_id": 8311,
        "voice": "vo_adv_1223005_002"
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀噗呀～！",
        "unit_id": 8311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "咦？",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從來了！？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從～♪",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_004"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比好想你～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "快點快點！",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_005"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比有抱抱你了，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你也要抱抱班比才行！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "聽好囉？",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n打招呼是很重要的哦！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚咿！",
        "unit_id": 8311,
        "voice": "vo_adv_1223005_007"
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "\n呀噗呀嗚呀～！",
        "unit_id": 8311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "哇哇！？",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真的耶！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "湯快滿出來了！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "呼……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好險……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從，",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_009"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "料理馬上就好了，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你去那裡和伊莉亞一起等著吧♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔唔……",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n好累…………",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "班比她啊……",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n她為了答謝在妾身城裡受到關照，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "開始做家事了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但她老是把用不到的東西給翻出來，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把屋內弄得亂七八糟……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "後來甚至",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盡是引出一些惡靈……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n結果",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "搞得妾身必須替她收拾善後。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "出現的惡靈都是",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像那種……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "生理上讓人無法接受的類型……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……多虧如此讓妾身吃了不少苦頭。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對了，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在班比來之前，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身有話想先告訴你。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身有問過班比",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "關於她故鄉的事情，但是……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳仔～細看這張地圖，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳知道自己的故鄉在什麼地方嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "唔～嗯…………",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_017"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_018"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沉睡了很長一段時間，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n所以腦袋",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "還轉不太過來呢……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比是在一座很大的城堡裡",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_019"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "和大家一起生活。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "明明非常喜歡大家……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可是",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_020"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "卻完全想不起來。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……這是為什麼呢？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不曉得班比究竟沉睡了多久，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但她的記憶似乎變得很模糊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n貝斯也一樣。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要讓班比回到故鄉，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只能逮到綁架她的",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "罪魁禍首「伯爵」，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並且逼問他了吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身已經派出蝙蝠們",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "去找伯爵的所在之處。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你今天就先",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好好品嚐班比煮的料理吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從！",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_024"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伊莉亞！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "讓你們久等了～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯！",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_025"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n可以幫忙擺餐具嗎！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚！",
        "unit_id": 8311,
        "voice": "vo_adv_1223005_026"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "鏘──！",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_027"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這是班比特製的湯♪",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_028"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n請慢用♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就不客氣了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從？",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_030"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "如何？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好喝嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿♪",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_031"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你也要多吃點，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "快快長大喔～",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯的是水果！",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_032"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n如何？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好吃嗎～？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "貝斯",
        "words": "呀嗚～！",
        "unit_id": 8311,
        "voice": "vo_adv_1223005_033"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比煮的湯，",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_034"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伊莉亞喜歡嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然妳打掃是慘不忍睹，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但料理似乎還可以。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "唔～",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_036"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "只是煮湯的話，班比也是會的～",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "當然一開始是先跟別人學──",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "…………",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_037"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "咦？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了？",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_038"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "……班比是跟誰，",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_039"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n學習怎麼煮湯的呀……？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不用著急，妳慢慢想起來就行了。",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身會和他一起尋找妳的故鄉，",
        "unit_id": 104412,
        "voice": "vo_adv_1223005_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好讓妳能回去的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n沒錯吧？{player}。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從……",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_042"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯，",
        "unit_id": 122311,
        "voice": "vo_adv_1223005_043"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "謝謝你們♪",
