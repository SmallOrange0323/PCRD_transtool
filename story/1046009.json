        "words": "\n沒辦法的話放棄也……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "貓1",
        "words": "喵～♪"
    },
    {
        "type": "dialogue",
        "name": "貓2",
        "words": "喵喵喵～！"
    },
    {
        "type": "dialogue",
        "name": "貓3",
        "words": "……喵♪"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼已經這麼親近了喵——！！",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為、",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這些孩子",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "應該不會親近我以外的人才對喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎、",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎喵會……！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我居然敗給食物了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不過，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幫忙餵牠們還是只能向你道謝喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呃…",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_064"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個嘛……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快說他沒有資格啊，",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "珠希！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然情況演變成這樣，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "理由什麼的之後再想就好了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "明明只要先說他沒有資格，就可以結束了呀喵！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不、",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_066"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不能被那雙孩子般閃閃發光的眼神",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "給影響了喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這都是、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了{player}好喵！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "——上吧，",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_067"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不要想太多，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "告訴他不合格喵～～！！！！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "………………如、",
        "unit_id": 104611,
        "voice": "vo_adv_1046009_068"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果只是在一旁協助的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也不是不能讓你跟著喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——如此這般，珠希"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}，\n將一同面對全新的敵人。"
    }
