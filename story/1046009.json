        "type": "dialogue",
        "name": "常客2",
        "words": "……偷偷告訴你們，",
        "unit_id": 1411,
        "voice": "vo_adv_1046009_014"
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "物價會上漲都是因為，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n商人們互相勾結，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "操弄價格的樣子。",
