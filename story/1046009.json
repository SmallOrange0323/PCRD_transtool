    {
        "type": "dialogue",
        "name": "常客2",
        "words": "不過如果謠言是真的，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "常客2",
        "words": "\n現在那些傢伙一定笑得合不攏嘴吧。",
