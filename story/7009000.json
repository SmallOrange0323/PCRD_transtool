        "voice": "vo_adv_7009000_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "總之！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這座塔裡",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有取回{player}記憶的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n線索對吧！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "似乎是這樣呢。",
        "unit_id": 101011,
        "voice": "vo_adv_7009000_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，",
        "unit_id": 105211,
        "voice": "vo_adv_7009000_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們三個一起爬上去吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣也比較容易找到線索對吧！",
        "unit_id": 105211
