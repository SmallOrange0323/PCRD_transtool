    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100213,
        "voice": "vo_adv_5136101_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n差不多該休息一下了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "蘭德索爾……",
        "unit_id": 100213,
        "voice": "vo_adv_5136101_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n已經離得這麼遠了呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家現在",
        "unit_id": 100213,
        "voice": "vo_adv_5136101_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在做什麼呢？",
        "unit_id": 100213
    },
    {
        "type": "background",
        "background": "502050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣她",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經抵達精靈族之村了嗎～？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是沒有這麼快的吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過她自己一人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "半路也可能會有魔物出現！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔嗯～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當初果然應該送她去的～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣的話一定沒問題的。",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n比賽結束了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "結果如何？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有沒有受傷？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當然是贏了，",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也沒有受傷。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是場很棒的對戰。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了～！",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那我就放心了～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接著輪到妳了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n趕緊準備好吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……優衣外出修行了。",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也不能輸給她呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說的也是！",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟我們是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "【破曉之星】嘛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n即使分隔兩地，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但心意也是一樣的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯，",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論何時，我們的心意──",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都是一樣的。",
        "unit_id": 1,
        "voice": "vo_adv_5136101_013"
    },
    {
        "type": "background",
        "background": "502050"
    },
    {
        "type": "dialogue",
        "name": "日和、怜",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5136101_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才，",
        "unit_id": 100111,
        "voice": "vo_adv_5136101_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像聽到了什麼聲音……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是錯覺……",
        "unit_id": 100311,
        "voice": "vo_adv_5136101_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5136101_017"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「I Wish　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "緊握的這雙手」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "502050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我們是不是稍～微有點太早出現了啊？",
        "unit_id": 1,
        "voice": "vo_adv_5136101_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n剛才應該不要出聲比較好嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………別問我。",
        "unit_id": 1,
        "voice": "vo_adv_5136101_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我很困擾。",
        "unit_id": 1
    }
