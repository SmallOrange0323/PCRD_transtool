[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天王宮內──"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下～♪",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "月光學院重建結束，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n並寄了封感謝的信過來唷。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "來，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請收下。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～",
        "unit_id": 105812,
        "voice": "vo_adv_1180007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "…………",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_003"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，另一天──"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不行，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您這樣不行唷陛下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不是已經約好了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "點心時間是下午三點才開始嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起嘛……",
        "unit_id": 105812,
        "voice": "vo_adv_1180007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我忍不住，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不小心就……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "…………",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_007"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──經過一番波折後，克蕾琪塔宣誓效忠貪吃佩可。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她憑著經濟方面的知識及行動力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當上貪吃佩可的左右手，日日勤奮工作……"
    },
    {
        "type": "background",
        "background": "500095"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "……真是令人不愉快哪。",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_008"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "那隻商人出身的女狐狸……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n既然不把我們這些正統貴族放在眼裡，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "擺出這麼大的架子。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n啊，著實令人不悅……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "聽聞她也不出席社交宴會，",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_009"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "整日都在工作呢。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "不想與同樣是在管理政務的我們進行交流，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n只管著要討陛下歡心，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "那膚淺的企圖心可真是明顯哪。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "她可當然要有企圖，",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_010"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n畢竟聽說那個女人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "身世比野貓還要來得卑賤呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n竟然重用那種人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "真不曉得陛下在想什麼……",
        "unit_id": 2511
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……最近在貴族之間，",
        "unit_id": 6111,
        "voice": "vo_adv_1180007_011"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "似乎在傳著這樣的壞話。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……哼。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感謝妳的報告，秘書一號。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大致上和料想的一樣啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會嫉妒成功的人這點，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不管是商人還是貴族都一樣哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您有打算",
        "unit_id": 6111,
        "voice": "vo_adv_1180007_013"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "採取什麼對策嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就隨便他們去說吧……",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是很想這樣說啦。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但要是放著不管，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "他們那種人",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就會越講越有一回事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而我現在可是",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "受陛下信賴的對象。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也因此，他人對我的看法，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也會左右陛下的評價。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以必須要將這件事處理妥當才行。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那麼，",
        "unit_id": 6111,
        "voice": "vo_adv_1180007_016"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您計畫要怎麼做呢？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我想想。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "用錢讓他們閉嘴？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "反過來散播他們的謠言？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n掌握弱點，讓對方失勢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或是讓他們反目成仇？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我隨便一想",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就有許多能整治他們的方法……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……又都是",
        "unit_id": 6111,
        "voice": "vo_adv_1180007_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這種方法……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但這次還是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "堂堂正正迎擊吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟我現在可是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下信任的對象呢。",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著來到隔天──"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，少年！",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n過來這邊一下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……不，我不是來打招呼的。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你稍微",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陪我去個地方吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n反正你",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該很閒吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n雖然由我來說可能有點不妥。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但你的警戒心",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再更高一點會比較好喔。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別這麼說！",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我會確實給你報酬的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好嘛！！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "──總之呢，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然說好要陪我了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n接下來該準備換套衣服了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "出發去租借服裝的店家吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你也得換套裝扮啊！",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "放心吧，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我會證明何謂「佛要金裝，人要衣裝」的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "錢就是該",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "花在這種地方！",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "501242"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──當天下午。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的貴族們，聚集在某間宅邸內，舉行宴會。"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "這樣好嗎？",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_027"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "沒有招待陛下，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n就我們自己",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "像這樣",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "享用美味的餐點。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "別這麼說。",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_028"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n這是我們互相加深交流、",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "並討論要如何替陛下立功的機會。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n況且陛下似乎也不太享受",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "與我們一同共進美食呢。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "即便您提到",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_029"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "我們……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "當初豪紳議長還在的時候，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "社交宴會可是更加熱鬧啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "這一切都要",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "怪那個女商人背叛……",
        "unit_id": 2511
    },
    {
        "type": "still",
        "still": "118000701"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "哦？",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_030"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n那邊那位美麗的女性──",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "是新面孔呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "噢……",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_031"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "確實美艷動人哪。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "妳好，",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_032"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "這位小姐。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n歡迎蒞臨本宴會。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "妳是初次參加這類社交宴會嗎？",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_033"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n能招待像妳這般有氣質的淑女，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n我們也是倍感榮幸哪。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "來，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "請往這邊──",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呵呵。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n呵呵呵……",
        "unit_id": 118011
    },
    {
        "type": "still",
        "still": "118000702"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "伯爵大人。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是我呀♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "唔……？",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_036"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "妳、",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_037"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "妳該不會是，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "克蕾琪塔‧凱許……！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正是♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n今日承蒙您邀請我來如此氣派的宴會，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是深感榮幸哪♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "我、",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_039"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "我的確……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "是有寄邀請函給妳。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n但沒想到",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "妳真的會來……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀？",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n難道那張邀請函",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是一種禮貌性的問候？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那就很不好意思了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟我出身卑微，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "較不懂禮節。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "妳還真會說笑，",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_041"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n我當然",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "歡迎妳來參加啊。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "只不過……",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "我確實有些驚訝。",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_042"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n畢竟沒想到背叛豪紳議長的人，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n會這般恬不知恥地出席我們主辦的宴會哪。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "就、",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_043"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "就是啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n妳明明也利用議長的人脈，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "賺取了不少甜頭，卻還……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "在妳身旁的",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_044"
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "那位少年……",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "看來妳的隨扈不過就一名男僕。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "我可是能立即叫守衛來，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "將妳給壓制住喔？",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "\n反正就算這麼做，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "目前在場的人也都不會張揚出去。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀哎呀哎呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n討厭啦，伯爵大人。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可不是來此",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "找諸位吵架的唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更何況，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "關於您提的事，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我原本",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可還打算和平一點解決的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但先用強硬手段搶奪走我的【里士滿工商會】的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是議長呀？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有呀？",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_047"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n您要呼叫守衛來是無所謂，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但可別以為我會什麼準備都沒做，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就前來參加宴會哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是您想",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "採取粗暴的手段壓制住我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就別怪我幫您複習一下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n豪紳議長當初是怎麼失敗的囉？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "唔……",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我再重申一次。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我今天可不是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "來找諸位吵架的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "倒不如說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正好相反。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族2",
        "words": "……喔？",
        "unit_id": 2512,
        "voice": "vo_adv_1180007_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "儘管確實有過令人惋惜的事件，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但各位貴族",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都是執行國政時",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不可或缺的人才，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這也是不爭的事實。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此？",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就讓我們把那些無聊的紛爭",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "徹底放下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不再顧忌前嫌，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "坦承地",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "交換彼此的意見吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也認為是時候",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "學習一些應對禮節，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n好成為不會讓陛下丟臉的部下。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因此想向各位",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "虛心討教。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "那麼……",
        "unit_id": 2511,
        "voice": "vo_adv_1180007_055"
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "\n妳又能",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族1",
        "words": "貢獻什麼樣的意見來與我們交流呢？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的話，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_056"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然是──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會仔細替各位分析，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們的陛下有多麼偉大！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……您看如何♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，克蕾琪塔‧凱許"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n成功地將失去豪紳議長的貴族議會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉攏成為支持貪吃佩可的勢力。"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呼。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n終於能換衣服了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "頂著那身穿不慣的打扮，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真讓人肩頸痠痛啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你也是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "今天辛苦了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……要是出席宴會，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "卻連一個隨從都沒帶，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n一定又會",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "被他們給看扁……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會被他們抓到機會找碴吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個嘛……",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_060"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……那邊對我而言，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就有如敵方陣地。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過要是能借助你的力量，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "便有辦法排除大部分的威脅，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這之前",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我已經親身體會到了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有就是……",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n在採取少人數的行動時，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再怎麼說……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "都需要這樣的人選。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "能超出金錢僱傭關係……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用擔心會背叛的保鑣。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你領悟力真弱耶。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n意思是說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我對你還是有著這種程度的信任啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可以不要逼我說得這麼明白嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總而言之，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "目的也已經達成了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "今晚就到此結束吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n報酬的部分，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我改天會確實支付──",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……？",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_065"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊？",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你這什麼意思？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_067"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你要這樣說的話……",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也是啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果只是為了自己的利益，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "大可採取其他的手段……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好的，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_069"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再見。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你給我稍等一下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我果然不太能接受",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不給報酬。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n畢竟我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "打從骨子裡就是生意人哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……這樣好了。",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_072"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就到",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那邊的酒吧請你喝一杯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你好像還未成年嘛。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_073"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓我請你吃一碗附近路邊攤的拉麵吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這樣總可以吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180007_074"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "很好♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──經過一番波折，向貪吃佩可宣示效忠的克蕾琪塔。\n以往只願相信金錢的她，\n如今也似乎漸漸地對{player}等人敞開心房。"
    }
