[
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接獲魔物們越發猖獗的通知，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}造訪了蘭德索爾外圍的森林。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前腳才一踏入，就聽見了魔物的咆哮聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}馬上急忙趕往現場……"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "魔物大聲咆哮著。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}將劍緊握手中――"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……為什麼逃走呢。",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是誰……？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不認識的人。",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_002"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_003"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n…………露娜。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……大哥哥，",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_004"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你來這裡做什麼呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "討厭……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不認識的人。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "魔物？",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "討厭魔物。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為不會跟我當朋友……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n而且還會逃跑。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "想要有朋友呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_009"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我很寂寞。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n但是，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大家都會逃走。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n為什麼呢……？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……我沒關係唷。",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_010"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n但是，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "作為交換……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "――你可以當露娜的朋友嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_011"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "真的嗎！？",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_012"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "太好了！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那麼……",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_013"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "絕對，",
        "unit_id": 111412,
        "voice": "vo_adv_1114001_014"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不能逃走唷！",
        "unit_id": 111412
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……！\n為什麼！？",
        "unit_id": 111412,
        "voice": "vo_adv_1114001_015"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "為什麼，",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不能為我死掉呢！",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥也是騙子……！",
        "unit_id": 111412,
        "voice": "vo_adv_1114001_016"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n跟魔物都一樣！",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……、",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_017"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "算了！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "什麼大哥哥，",
        "unit_id": 111411,
        "voice": "vo_adv_1114001_018"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "最討厭了！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "說完露娜就跳進樹叢內。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}放棄了追上露娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定先打敗森林的魔物。"
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}成功討伐魔物後，離開了森林。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接著，在森林的出口站著一位老婆婆。"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……那邊的那位。",
        "unit_id": 611,
        "voice": "vo_adv_1114001_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你剛剛進了那座森林吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "有沒有看見一位女孩子呢？",
        "unit_id": 611,
        "voice": "vo_adv_1114001_020"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n年紀還很小……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊，",
        "unit_id": 611,
        "voice": "vo_adv_1114001_021"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是嗎……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我對那個孩子做了很過分的事。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……希望她能原諒我。",
        "unit_id": 611,
        "voice": "vo_adv_1114001_022"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n那個孩子，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "還什麼都不知情呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "全部都……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不對的人……是我呀。",
        "unit_id": 611,
        "voice": "vo_adv_1114001_023"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我對",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "在這個森林中發生的事……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……啊啊、",
        "unit_id": 611,
        "voice": "vo_adv_1114001_024"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不行。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "老人家的陳年往事，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你應該不想聽吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不好意思呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "總之，",
        "unit_id": 611,
        "voice": "vo_adv_1114001_025"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "最好不要靠近這裡唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n很危險的……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "目送老婆婆離去的背影，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}隨後就返回了蘭德索爾。"
    }
]