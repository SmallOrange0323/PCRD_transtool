        "voice": "vo_adv_5012005_034"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說教什麼的，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我並沒有這麼想……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，不管要做什麼，",
