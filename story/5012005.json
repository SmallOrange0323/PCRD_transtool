[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天早上――"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩。",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "醒了吧，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "早安。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有睡好嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？　",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你問我為什麼不是穿睡衣",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那是、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那是因為……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一直穿著很害羞啊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴說要去巡邏，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n所以出門去了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在我起床時已經不見了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有可能是在房間裡進行些調查，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴說的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔～",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}早啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n步未，也謝謝妳看家囉。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "歡迎回家，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這一帶沒什麼可疑的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n可以暫時安心了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……話說回來，",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哀嘆之女神啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然被那種可怕的傢伙\n給盯上啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？　",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞還窩在房裡嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞～！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，抱歉，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "剛剛在查點東西。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大家早啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為對印象中的",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "古老文獻有點在意，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以再查了一下。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "確定了一件事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要聽聽看嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以『馬車競賽與哀嘆之公主』……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為題，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不為人知的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "古老傳說。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "――某一個王國中，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有一位嚴格的國王，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n及他的女兒……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是心地善良的公主。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n她被國王",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "許配給一位",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "鄰國的王子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公主也",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接受了這個安排……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "本應如此。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是她",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因國事出訪馬車競賽，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而與一位男子相遇。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那名男子",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一位被大家稱作馬車競賽英雄的年輕人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "兩人在瞬間墜入情網。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "國王非常震怒。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並且下諭令，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在賽事中暗殺了年輕人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "知道了這件事，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "卻無法將國王定罪的公主，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在失意之中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "了結了自己的生命，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想讓兩人在天上相遇――",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也就是說……",
        "unit_id": 105511
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "放心吧。",
        "unit_id": 11111,
        "voice": "vo_adv_5012005_018"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n你啊，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "什麼事都做不了。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我是知道的。",
        "unit_id": 11111,
        "voice": "vo_adv_5012005_019"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n因為你",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "跟以前的我有著相同的氣味。",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……？",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_020"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "篤定自己什麼都不會而自我決斷……",
        "unit_id": 11111,
        "voice": "vo_adv_5012005_021"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n當一切都染上絕望後，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "開始詛咒自己……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那種",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "愚者的氣味。",
        "unit_id": 11111
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "…………",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸，霞。",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "馬車競賽的英雄，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就是之前在鎮上看到的海報上畫的",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個人對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但他和公主曾是戀人的事",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "卻沒聽說過呢……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "傳說這種東西，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "常常會衍生出不同的故事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而這世上",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所流傳的資訊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "往往也只會留下\n對傳出去的人有利的一面。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此啊……",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞認為那位公主\n就是哀嘆之女神啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過雖說是傳說……",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還真是個悲傷的故事呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對啊。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n即使這位公主獻身於惡魔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也是沒辦法的事吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真想幫她……",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "步未？",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_029"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊、",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_030"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對不起。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩都被盯上了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還說這種話真不得體。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_031"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "若這是真的話……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有點想幫助她。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n總覺得，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "她好像至今仍在",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "承受著悲傷痛苦一樣……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
