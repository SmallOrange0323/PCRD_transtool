    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都得先找出她才能開始啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也就是說，從現在起，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是開心的推理時間。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "快看看這個。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你打開蘭德索爾的示意圖，",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要做什麼？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要做記號啊。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "昨天馬車衝進的地方，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這裡。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真琴，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生頭上有花瓶掉落的地方在哪裡？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_038"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這邊吧，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "步未。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你曾說一直在看著助手先生",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你可以把助手先生被盯上的地方",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "標示在這個地圖上嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_040"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我知道了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯，",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_041"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前天是這邊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大前天是這邊，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和那邊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n再之前是這邊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "再更之前是那裡。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然後更更之前是這邊，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有――",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂喂喂。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n步未這傢伙，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底是能記到多久以前啊？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，\n開始感到危險也不過是",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在這2、3天而已吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "意思是在那傢伙注意到之前，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "老早就一直在看著他了！？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真、",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真厲害呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n某種意義上來說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是超越哀嘆之女神的跟蹤……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，我什麼都沒說。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "――",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_045"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呼。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "久等了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這些就是全部……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳們兩位怎麼了？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一言不發的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊！　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不小心愣了一下。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總、",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看了步未幫忙記下的地方，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有發現什麼事情嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？　",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "鎮上……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也有些地方不是。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "住宅區裡，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "集會所前……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？　",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "該不會……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都是在人多的地方！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也這麼認為唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多虧了步未。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "犯人的樣貌似乎浮現在眼前囉。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哀嘆之女神。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她想要",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在眾人的面前",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n加害助手先生，絕對沒錯。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯……",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "重現她所遭遇的悲劇。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n被禁錮在這種固執的想法之中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣絕對不算少見。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "同時，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想將周圍的人全部捲入恐怖的氛圍之中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有點像愉快犯呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們沒有時間害怕。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哀嘆之女神，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "曾這麼多次",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "試圖接近助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說她",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "認為隨時都能",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "殺了助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n她對自己的力量過於自信，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不得不這麼說呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那不過是僥倖。",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣反倒讓我們能趁虛而入。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 104311,
        "voice": "vo_adv_5012005_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這話有點難懂呢……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "打算怎麼找出她呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這不是有個能聚集許多觀眾的大活動",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_057"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "即將要舉行了嗎。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "和她淵源至深的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "馬車競賽嘛。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果助手先生參賽的話，",
        "unit_id": 101411,
        "voice": "vo_adv_5012005_058"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她會做些什麼呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "毫無疑問，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想必會現身吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但、",
        "unit_id": 105511,
        "voice": "vo_adv_5012005_059"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣前輩便會陷於危險的境地……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
