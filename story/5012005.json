        "voice": "vo_adv_5012005_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是個貪心的傢伙呢，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "步未。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n除了守護{player}，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n也想對哀嘆之女神說教啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說、",
