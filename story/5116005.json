    {
        "type": "dialogue",
        "name": "旁白",
        "words": "度過了一夜，就在天空亮起之時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n栞他們抵達了某處瀑潭。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "循著途中發現的河川是正確答案呢……",
