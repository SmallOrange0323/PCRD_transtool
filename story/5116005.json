        "type": "dialogue",
        "name": "可可蘿",
        "words": "才抵達了這邊。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "咕嚕咕嚕咕嚕……♪",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈，",
        "unit_id": 125413,
        "voice": "vo_adv_5116005_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特，",
        "unit_id": 125413
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好癢喔……♪",
        "unit_id": 125413
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "汪汪！",
        "unit_id": 1812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔，",
        "unit_id": 125313,
        "voice": "vo_adv_5116005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好乖好乖……♪",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一直都好想見您，",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，栞小姐，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n人類的主人在哪裡呢？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於昨天分頭行動，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下很擔心主人，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨晚都睡不太著覺。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸虧有喵特在，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才稍微安心一點。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n他沒有和可可蘿在一起嗎？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託主人",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n去追栞小姐了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這麼說來，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成主人",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在是獨自一人……？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有什麼東西",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從那邊的草叢過來了！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "…………",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那是……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "昨天的",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大猿……？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐……！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔唔…………",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒有",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "攻擊過來？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼您會和那隻魔物一起……",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起那個，您有受傷嗎！？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "……嗚吼，",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_019"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼吼。",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您能聽懂牠說什麼嗎？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……該怎麼辦才好？",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人跟著那隻魔物走了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……我們跟過去看看吧。",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或許能夠掌握那隻魔物大鬧的原因。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只不過，",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請不要放鬆警戒。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n做好能夠隨時撤退的準備，要是判斷有危險，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就帶著{player}撤走。",
        "unit_id": 125411
    },
    {
        "type": "background",
        "background": "501850"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這裡……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是果樹林？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有好多的果實呢……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n密林裡竟然有這樣的地方……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼。",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是大猿先生採的果實嗎？",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗅嗅……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是沒什麼毒性的種類。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是要給我們的？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼……？",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠溫馴到令人難以相信之前",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n曾那樣大鬧呢。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且感覺牠是在歡迎我們……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠用非常水汪汪的眼睛看著我們。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n簡直就像汪汪主人一樣──",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "汪汪！",
        "unit_id": 1812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊、",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要一直舔在下。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "壞壞喔。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼說來，肚子餓了呢……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為緊急糧食都吃完了，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "天亮後就什麼都沒……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕…………",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來似乎沒有像昨天那樣的危險，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們就心懷感謝地接受款待吧。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大猿先生，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼吼，",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_034"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼嗚吼，",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼吼！",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那、",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大猿，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我很高興你把水果分給我，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但這個量有點太多了……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦……",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "堆成跟我們身高相當的小山了呢。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就心懷感激地享用了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊嗯。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，主人，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸好您平安無事。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還以為您跟栞小姐在一起，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以得知您是獨自一人時，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺背脊都發涼了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被大猿先生……？",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來如此，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以才沒有被其他的魔物襲擊吧。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這隻大猿先生",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是這個魔物保護區中的老大……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也就是所謂的「霸主」。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「霸主」……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗎？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是根據在此處調查的",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n遊俠的報告書……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位大猿先生以魔物而言，似乎是相當少見的",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "性格友好且穩重。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說牠也曾被目擊，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在魔物之間有紛爭時，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會親自來調解的舉動……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠大多棲息在有許多果樹的密林，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甘甜的果實似乎是牠最愛的食物……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼說來，大猿",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_046"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一口都沒吃呢？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼一說，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠都只是一直為我們採摘而已。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的肚子不餓嗎？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼……",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_048"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼吼……",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您現在口水也都從嘴巴流出來了，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以在下想您一定是很餓的……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔，",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_050"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔唔唔唔……",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然牠拚命想別開視線……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_051"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好像在忍耐什麼似的……？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你不介意的話，要一起吃嗎？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "唔嗚……？",
        "unit_id": 1812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪主人把水果……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n交給大猿先生了呢。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔，",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_053"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼…………",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "唔嗚…………？？？",
        "unit_id": 1812
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "嗚吼…………",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_054"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔、",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_055"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔唔唔唔……！",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這……",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大猿先生",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全身的葉子都豎起來了……！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔、",
        "unit_id": 17411,
        "voice": "vo_adv_5116005_057"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔、",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔……",
        "unit_id": 17411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17412,
        "voice": "vo_adv_5116005_058"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這副模樣",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是那時候的……！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為什麼會突然……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_060"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原因是什麼？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為吃了那個水果嗎？　",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_061"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們也吃了同一種水果，並沒有問題。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原因究竟是什麼……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17412,
        "voice": "vo_adv_5116005_062"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唔",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們現在先撤退吧。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是跟之前一樣，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那牠應該是無法溝通的狀態……！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可可蘿……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我知道了。",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我用煙霧來擾亂牠，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就趁那個空檔撤退吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我要用",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_067"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "煙霧彈了！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！？",
        "unit_id": 17412,
        "voice": "vo_adv_5116005_068"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家，",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_069"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "趁現在！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17412,
        "voice": "vo_adv_5116005_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請快來這邊！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "唔唔唔唔…………",
        "unit_id": 17412,
        "voice": "vo_adv_5116005_072"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總算是逃掉了呢。",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_073"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n為什麼會突然",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "發生那種事……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個白色的碎片……",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "石頭嗎？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原來如此……",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_075"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這麼一回事嗎。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這會成為突破口也說不定。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐？",
        "unit_id": 125311,
        "voice": "vo_adv_5116005_076"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 125411,
        "voice": "vo_adv_5116005_077"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們先回集訓所吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們的體力也都耗盡了……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且我也有各種事想要確認。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，回到集訓所的一行人──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}撿回來的碎片，",
        "unit_id": 125414,
        "voice": "vo_adv_5116005_078"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那似乎是大猿",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「牙齒」的一部分。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想",
        "unit_id": 125414,
        "voice": "vo_adv_5116005_079"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這恐怕是在牠用力咬的時候碎掉的，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但必須注意的",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是那個斷面──",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──這個",
        "unit_id": 125414,
        "voice": "vo_adv_5116005_080"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "被蛀牙侵蝕的部分。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這也就是說，",
        "unit_id": 125312,
        "voice": "vo_adv_5116005_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得出的結論是，",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大猿先生受不了蛀牙的疼痛，所以才會失控暴衝。",
        "unit_id": 125312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要是打倒那隻大猿，",
        "unit_id": 125414,
        "voice": "vo_adv_5116005_082"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想問題確實就會解決。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "作為遊俠，",
        "unit_id": 125414
