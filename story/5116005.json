        "voice": "vo_adv_5116005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下發現了栞小姐留下的標記，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n於是就追蹤標記，",
        "unit_id": 125311
    },
