[
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀呀，",
        "unit_id": 116011,
        "voice": "vo_adv_5061302_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物的公主殿下",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "情緒很激動呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，",
        "unit_id": 115911,
        "voice": "vo_adv_5061302_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是第二回合要開打了嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真有趣！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就讓她瞧瞧我們的真本事！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "上吧上吧──！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等等，",
        "unit_id": 115811,
        "voice": "vo_adv_5061302_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……沒辦法，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "看來她已經徹底熱血沸騰了。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要接近已經變成那般狀態的真琴",
        "unit_id": 116011,
        "voice": "vo_adv_5061302_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是非常危險的喔。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "莉瑪，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳就和咱們一起",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "專注於後方支援吧？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這、",
        "unit_id": 115811,
        "voice": "vo_adv_5061302_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣好嗎……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也要跟",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真琴一起到前頭作戰！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我想這才是",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "拯救公主殿下的捷徑！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以，真步，",
        "unit_id": 115811,
        "voice": "vo_adv_5061302_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就拜託妳支援我們了！",
        "unit_id": 115811
    }
]