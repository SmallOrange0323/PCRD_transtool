    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今年就快要結束了呢——！",
        "unit_id": 108711,
        "voice": "vo_adv_5010101_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得，",
        "unit_id": 108811,
        "voice": "vo_adv_5010101_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一下子就到年底了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來我們曾經投入過的事情有這麼多啊。",
        "unit_id": 108911,
        "voice": "vo_adv_5010101_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "愈忙碌的話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會感覺時間過得愈快唷。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣下去的話，",
        "unit_id": 108711,
        "voice": "vo_adv_5010101_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得到明年也只是一下子的事呢——",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是說呀……",
        "unit_id": 108811,
        "voice": "vo_adv_5010101_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "既然這麼難得，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好想和大家一起",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "來創造今年最後的回憶啊。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好主意呢！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010101_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來找找看，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "三個人能一起做的事吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我贊成。",
        "unit_id": 108911,
        "voice": "vo_adv_5010101_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "首先，先到花凜小姐那裡吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得這個時期的話也許會有什麼工作也說不定。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！　",
        "unit_id": 108811,
        "voice": "vo_adv_5010101_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們去看看吧！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和、優衣、怜",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5010101_008"
    },
    {
        "type": "dialogue",
        "name": "日和、優衣、怜",
        "words": "「新春破曉之星大危機！」",
        "unit_id": 1
    },
    {
