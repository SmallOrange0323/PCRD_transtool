    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茜里打算作為天使展開活動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而將{player}找了出來。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿。",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你覺得怎麼樣，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這衣服",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "超可愛的對吧♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了不辜負這身可愛的打扮，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會作為天使好好努力的！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……話又說回來，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "天使的工作……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "具體來說應該做些什麼才好？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是茜里的第一次",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以不太懂呢……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要和哥哥在一起，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就沒什麼好擔心的呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "無論有多麼激烈，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里一定都能挺得住！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不曉得之後",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會變得怎樣呢～♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "薩克斯風的聲音",
        "words": "～～～♪"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦……？",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這聲音……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是薩克斯風呢！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好像是有人在附近吹奏的樣子，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該怎麼說呢……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不行……",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這種話，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里實在說不出口～！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔唔……",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你有時候很壞心眼耶……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我知道了……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里就",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "老實地親口說出來喔。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "剛才聽到的薩克斯風的音色……",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "感覺",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吹得不是很好呢……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然茜里的薩克斯風也沒有好到",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可以對別人說三道四……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只是對方",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "或許是才剛開始在學薩克斯風的人……？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果是這樣，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那茜里說不定能夠教對方怎麼吹薩克斯風。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也是",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓哥哥陪茜里練習了好久的",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n薩克斯風之後，才吹得比較好了。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n如果是簡單的部分，茜里應該可以教那個人。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這種幫忙",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也是身為天使的職責對吧？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這是首次的工作，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會加油的！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯～",
        "unit_id": 411,
        "voice": "vo_adv_1137001_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "果然",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "沒辦法吹出好聽的聲音……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉。",
        "unit_id": 311,
        "voice": "vo_adv_1137001_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "都怪我教的方式不好……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "大姐姐，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你們在煩惱怎麼吹薩克斯風嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "對啊。",
        "unit_id": 411,
        "voice": "vo_adv_1137001_019"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我最近才剛開始學，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "於是就請有吹奏經驗的他來教我，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "但還是一直吹不好……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我也是以自己的方式摸索學會的，",
        "unit_id": 311,
        "voice": "vo_adv_1137001_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是我第一次教人。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "看來自己吹奏和教人怎麼吹奏",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "果然不一樣啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果你們不介意，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可以讓我",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "協助你們練習嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "傳遞活力給有困擾的人就是",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我的……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不對，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是我身為天使的使命。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "而且",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我其實也有在吹",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "薩克斯風哦♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然吹得不是說很好，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但我或許",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能夠幫得上你們的忙。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還有旁邊這位哥哥",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他是我的教練。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n他總是會陪我一起練習呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼，",
        "unit_id": 311,
        "voice": "vo_adv_1137001_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就務必拜託妳了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你也可以幫忙嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯，",
        "unit_id": 411,
        "voice": "vo_adv_1137001_026"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那當然。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請多指教。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好，",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請交給我們吧♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請告訴我",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你們目前在進行什麼樣的練習。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呃……",
        "unit_id": 411,
        "voice": "vo_adv_1137001_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "說來真不好意思，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是最基礎的部分。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我連基礎音都還吹不好。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "雖然他有示範吹給我看，",
        "unit_id": 411,
        "voice": "vo_adv_1137001_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "但我的手指反應不過來。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一想到要邊吹氣邊動手指，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "腦袋就整個打結了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯嗯。",
        "unit_id": 113711,
        "voice": "vo_adv_1137001_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能請妳",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吹給我聽聽看嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好。",
        "unit_id": 411,
        "voice": "vo_adv_1137001_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那我要吹了……",
        "unit_id": 411
    },
    {
