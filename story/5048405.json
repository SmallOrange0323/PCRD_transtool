    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太好了，",
        "unit_id": 113711,
        "voice": "vo_adv_5048405_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，我們辦到了！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "打倒了這麼多敵人呢！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 113811,
        "voice": "vo_adv_5048405_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就連我也很意外呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "和茜里並肩作戰，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "居然能夠變得這麼強。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯！",
        "unit_id": 113711,
        "voice": "vo_adv_5048405_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要我們姊妹聯手就沒有什麼好怕的。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們是蘭德索爾……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不對，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們是世界第一的雙胞胎♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳、",
        "unit_id": 113811,
        "voice": "vo_adv_5048405_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳太誇大了吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也覺得這句話沒有說錯。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這代表我們確實變得夠強大了吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果真的是這樣，就太令人高興了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811,
        "voice": "vo_adv_5048405_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們也不能就此滿足。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n沒有錯，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這只是一個必經階段而已。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓他們見識見識，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們的實力不只這樣！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 113711,
        "voice": "vo_adv_5048405_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊幹勁十足呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好～",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也要好好努力，不會輸給姊姊的♪",
        "unit_id": 113711
    }
]