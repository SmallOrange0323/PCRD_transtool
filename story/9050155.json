[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管走了多遠，",
        "unit_id": 105911,
        "voice": "vo_adv_9050155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都只看得到沙漠呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n先不提這炎熱的氣溫，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也已經懷念起",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不同於沙漠的景色了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說啊～",
        "unit_id": 105811,
        "voice": "vo_adv_9050155_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然拜小雪菲的魔法之賜，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有冷凍保存的肉類",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以及蔬菜可以吃……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我也開始懷念起新鮮蔬菜了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比方說沙拉啦、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是現採水果之類的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管在下指的並不是用餐那方面……",
        "unit_id": 105911,
        "voice": "vo_adv_9050155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實如此。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說真的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也想",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人在任何狀況下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都能夠攝取",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "均衡的飲食。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哎呀？",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "前面一點的岩石後面，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好像有一抹綠色……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那會不會是可供食用的植物呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總感覺在圖鑑上頭看過。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_9050155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是真的耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太棒了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天吃得到新鮮的沙拉囉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我倒不……",
        "unit_id": 106011,
        "voice": "vo_adv_9050155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種看起來就像有毒的綠葉",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳還真有辦法提得起吃它的慾望啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貓咪也一樣，不乖乖吃蔬菜是不行的～",
        "unit_id": 105811,
        "voice": "vo_adv_9050155_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n況且",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一旦挑食",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對健康也不好！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟吃飯這種事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "質和量是同等重要的☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "質就先不提了，",
        "unit_id": 106011,
        "voice": "vo_adv_9050155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說起量這方面",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳吃得太過頭了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且就算是我，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沙拉還是吃得下的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "前提是普通的沙拉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沙拉",
        "unit_id": 105811,
        "voice": "vo_adv_9050155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很棒耶！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那種蔬菜該怎麼調味好呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沙拉醬就拿鹽、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "胡椒和",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "手邊的材料進行調配……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還得考慮配餐用的肉類……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子都餓了起來呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106011,
        "voice": "vo_adv_9050155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別把我的話當耳邊風好嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9050155_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是那種蔬菜呀。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "長了好多呢……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雪菲小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "麻煩妳像這樣",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從根部",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將它整株摘採下來。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是像",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣嗎……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好久沒吃到新鮮蔬菜了……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛剛",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這棵蔬菜，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是不是在動啊？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下啦雪菲！",
        "unit_id": 106011,
        "voice": "vo_adv_9050155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別悠哉地說那種話了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "前面！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點看妳前面！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留妳也真是的，",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有什麼好緊張……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……吶，",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難道說……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然我覺得不可能，",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但這葉片，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是你的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哇────！",
        "unit_id": 106411,
        "voice": "vo_adv_9050155_016"
    }
]