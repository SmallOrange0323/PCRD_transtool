[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──雖然發生了被流氓集團闖入作亂的意外插曲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但因為事件很快獲得解決，所以宴會仍照常舉行。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不久，{player}找到了正在休息的真琴她們。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你那邊怎麼樣？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "玩得開心嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也玩得很開心喔。",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來那個執事……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是當家大概是有跟其他人說了吧，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們可以不用在乎禮儀什麼的，的確輕鬆多了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "即便如此，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在重新再看一次真的很讚呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n家庭宴會可以辦成這樣，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那到城堡辦宴會不就更誇張……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像有音樂響起……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "大小姐１",
        "words": "您願意跟我跳一支舞嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1159004_003"
    },
    {
        "type": "dialogue",
        "name": "紳士",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1159004_004"
    },
    {
        "type": "dialogue",
        "name": "紳士",
        "words": "我很樂意。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來是",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "舞會已經開始啦。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n穿著漂亮可愛的洋裝，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跟喜歡的人一起跳舞……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這就像是",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "故事中會有的舞會場景……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…………",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒什麼啦！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說回來，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你有想吃什麼嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這邊的料理很好吃喔……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你身上",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像發出很亮的光耶～！",
        "unit_id": 115911
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──喂。",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～～！！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然在文化祭當天發呆，",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你還挺從容的嘛。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你知道你今天要做的事嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喂，",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你真的沒問題嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們班的節目是",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "中世紀貴族文化的展示與體驗會。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你是舞蹈示範，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "以及負責教導體驗者的指導員之一啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…真是的，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你給我振作點。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "同樣負責舞蹈示範的優衣，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n因為可以跟你一起跳舞，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一直都很認真在練習呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為這樣，連陪她一起練習的我也都會跳了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在這時候，",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她說想做最後確認，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n明明就快要開場了，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "卻還待在教室的展示會場練習。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……唉，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她的努力如果有讓她想表達心意的人感受到就好了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……你問我在說什麼嗎？",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有什麼啦。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n比起這個，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可要跟優衣好好跳，懂嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是讓優衣的努力白費，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我絕不饒你！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……你怎麼看起來",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還一副沒有精神的樣子。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "拿去，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "毛巾借你，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快去洗把臉……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "不好了！",
        "unit_id": 6932,
        "voice": "vo_adv_1159004_015"
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "剛剛接到通知說，",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "\n負責舞蹈的田中",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "同學１",
        "words": "因為感冒不能來了！！",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "咦，",
        "unit_id": 6832,
        "voice": "vo_adv_1159004_016"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "這下該怎麼辦！",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n負責舞蹈的人本來就不多了！",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "笨、",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "笨蛋！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你幹嘛說出來……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "安藝同學，",
        "unit_id": 6732,
        "voice": "vo_adv_1159004_018"
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "妳會跳舞是嗎！？",
        "unit_id": 6732
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……啊～",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為我有陪優衣練習所以也會跳了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我是負責後台，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以就算加入你們應該也不成問題。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…不過！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是不行啦！！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我從沒想過要在大家面前跳舞。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再說，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果我長得像優衣那樣，是美如畫般的「女孩子」那還有話說。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是我要跳舞耶！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你們不妨想像一下我跳舞的樣子！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……咦，",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在說什麼啊……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "我也有同感。",
        "unit_id": 6732,
        "voice": "vo_adv_1159004_022"
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "\n安藝同學長得高，",
        "unit_id": 6732
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "應該很適合跳舞。",
        "unit_id": 6732
    },
    {
        "type": "dialogue",
        "name": "同學４",
        "words": "沒錯沒錯！",
        "unit_id": 6632,
        "voice": "vo_adv_1159004_023"
    },
    {
        "type": "dialogue",
        "name": "同學４",
        "words": "我認為安藝同學給人一種正氣凜然的感覺，",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "同學４",
        "words": "\n具有不同於草野同學的魅力呢～！",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎、",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼連妳們也……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "……好，",
        "unit_id": 6832,
        "voice": "vo_adv_1159004_025"
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "就這麼決定了！！",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n女生去幫安藝同學換衣服，",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "\n我們",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "同學２",
        "words": "要先去作為展演會場的體育館。",
        "unit_id": 6832
    },
    {
        "type": "dialogue",
        "name": "同學們",
        "words": "好～的。",
        "unit_id": 1,
        "voice": "vo_adv_1159004_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等、",
        "unit_id": 104331,
        "voice": "vo_adv_1159004_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等一下！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔哇，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別拉我裙子啦～！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "同學３",
        "words": "啊，",
        "unit_id": 6732,
        "voice": "vo_adv_1159004_028"
    },
    {
