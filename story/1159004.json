    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是、",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_053"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是夢嗎……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺好恐怖的夢……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我做了一點也不像我的事，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而且，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然還",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "穿上了洋裝……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嚇、",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_054"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嚇了我一跳！？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你什麼時候來這裡的……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你剛剛說了",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我覺得很適合妳穿，對吧？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難道說……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你做了看到我穿著洋裝開心不已的夢？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_055"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是這樣嗎。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n想不到有這麼奇妙的事～",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈哈……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你現在馬上給我忘掉～～！！",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說要揍了你才忘得掉！？",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_057"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n現在不管什麼我都願意做，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你敢跟我說該怎麼做才能忘的話，就給我試試看，混蛋！！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_058"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼變成這樣……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n明明是我一直藏在心裡的祕密，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "偏偏是被這傢伙給……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……事情才沒這麼簡單！",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n每個人都有自己的形象……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再說，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這根本不是我的風格。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是在這裡被發現的，或許也算是慶幸吧。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接下來，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就能毫無顧慮地欣賞了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n……欣賞我從小就十分嚮往的",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種舞會。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……真的很棒。",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_061"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n既優雅……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "又光彩奪目……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我所嚮往的光景就是這個。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_062"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說既然那麼嚮往，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就該親自去體驗一下？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我剛剛也說過了吧。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這根本不是我的風格……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你幹嘛拉著我的手……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哇哇！？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你要帶我去哪裡啊～！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "大小姐１",
        "words": "──咦，",
        "unit_id": 1,
        "voice": "vo_adv_1159004_063"
    },
    {
        "type": "dialogue",
        "name": "大小姐１",
        "words": "那不是真琴大人嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大小姐２",
        "words": "還有那個人是……",
        "unit_id": 1,
        "voice": "vo_adv_1159004_064"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_065"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說你啊，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這裡是舞會正中央耶！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好了，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在妨礙到他人之前趕快……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……唔！？",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_066"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……這傢伙真的是，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_067"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n明明對戀愛很遲鈍，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也不懂得男女之間的距離感，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然在這時候表現得那麼完美……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯，",
        "unit_id": 115911,
        "voice": "vo_adv_1159004_068"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我很樂意！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在舞會的中心開始跳起舞的兩人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那樣子就好像是故事中的王子和公主在跳舞一般。"
    }
