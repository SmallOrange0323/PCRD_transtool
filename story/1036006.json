    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為，再怎麼看，它就是塊普通的青椒啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚……說、說的也是……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這也是你特地替我去採回來的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、那我吃吃看……",
