[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}偶然遇見了正在買東西的鏡華。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哎……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，午安。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你正在散步嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……嗯，我是來買東西的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我、我看起來有那麼的不情願嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚，真讓人不好意思。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哎……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實呢，在媽媽開出的購物清單裡頭，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有我最討厭的青椒……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒錯，最討厭了！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然紅蘿蔔也很討厭，但青椒更是吃不下去……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？為了能吃它們而要特訓？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、我不要！這和翻上槓是完全不一樣的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也不是說學校有考試！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為、為什麼要捉住人家的手！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你、你想把人家帶去哪裡！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果、果然……你就是變態對吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "放、開、我──！！！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_007"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "來了喔，是全青椒料理的全餐唷！",
        "unit_id": 311,
        "voice": "vo_adv_1036006_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你看你點了些什麼東西呀！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我是真的，最討厭青椒了呦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "全部！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "青椒聞起來有個臭青味，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嚐起來又苦，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "觸感硬硬又軟軟的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n名字聽起來很奇怪，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "形狀也很奇怪，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且一點也不可愛……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你說如果用鼻栓塞住鼻子，或許就不會在意味道了？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你竟然連這種東西都放在身上呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "知道了，我就戴戴看吧。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像這樣把鼻子給夾住……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！變鵝鼻較不在意味奧了鵝！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咕……果南還是鼻戴惹……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是就是{player}，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "縮要偶戴上的嗎",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！！\n真宿的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "偶才鼻要戴惹！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……如果嚐起來不苦的話，說不定就吃得下去嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "話是這麼說也沒錯，但該要怎麼做呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "來囉！青椒蛋糕，上菜囉！",
        "unit_id": 311,
        "voice": "vo_adv_1036006_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！確實如果做成蛋糕的話，又甜又可愛，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n說不定真的能吃……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……可是，這個蛋糕。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過就是把普通的草莓蛋糕的草莓，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n全都換成了青椒了而已嘛！！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣子，和普通直接吃青椒，根本沒什麼兩樣啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果然我，還是沒有辦法吃青椒啦！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我要回去了！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後――"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哎……這陣子，都沒見到那個人的身影呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明平常都是來蘭德索爾這附近時，就會碰巧遇上的說……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒、沒碰上面也不會怎樣……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只是總感覺，有一點寂寞……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只、只有一點點，而已……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這陣子都沒看到你，讓人好擔……，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在意、讓人有一點點在意啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而、而且。你那破破爛爛的樣子究竟是……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你這陣子究竟在做什麼啊？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你說你去找「傳說中的青椒」了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……在書上，翻到了人間美味的「傳說中的青椒」，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以才跑到了火山口裡頭想要去採嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……還遇上了傳說中的「青椒騎士」、「青椒殭屍」，",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n甚至還有「青椒龍」，非常辛苦？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……哎。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就算我還是個小孩子，要撒謊也稍微有點分寸！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這種違背常理，又荒唐至極的事！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就算是從你口中說出來的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我也不可能會相信的呀！真是受不了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算是……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}說的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、這個人，因為喪失記憶，所以不怎麼會說謊。",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n而且總是很真誠，還對人都很親切……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "──這樣說起來的話……？？？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你說的都是真的嗎！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……這就是，「傳說中的青椒」嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、這種事不是重點！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以你真的去了趟火山口，然後在那裡和魔物戰鬥了嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "笨蛋！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是笨蛋笨蛋笨蛋！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}真的是一個大笨蛋呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "絕對不能再去做這種事情了！",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果不小心死掉了的話，你說該怎麼辦啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果不小心死掉了的話……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n嗚哇……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒，沒事……你也是為了我著想，才會特地去做這些……",
        "unit_id": 103611,
        "voice": "vo_adv_1036006_039"
    },
    {
