        "voice": "vo_adv_5044323_001"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "唔唔唔……",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦哦，",
        "unit_id": 113211,
        "voice": "vo_adv_5044323_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總算是安靜下來了嗎！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯～",
        "unit_id": 113311,
        "voice": "vo_adv_5044323_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很遺憾，好像還沒有喔～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n他正在凝聚很不得了的力量……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是比之前都還更驚人的力量～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "算了！",
        "unit_id": 13511,
        "voice": "vo_adv_5044323_004"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n不懂本大爺魅力的女孩子，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺不需要！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然說",
        "unit_id": 113111,
        "voice": "vo_adv_5044323_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不需要……？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你把人當成物品看待的態度真是不知節制呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "礙眼。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太礙眼了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這種行為……！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咱們這邊也在凝聚很不得了的力量喵～",
        "unit_id": 113311,
        "voice": "vo_adv_5044323_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔、",
        "unit_id": 113211,
        "voice": "vo_adv_5044323_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不禁令人寒毛直立……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺說不需要就是不需要啦～！",
        "unit_id": 13511,
        "voice": "vo_adv_5044323_008"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n本大爺要讓妳們後悔",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "沒有加入本大爺的後宮！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺不會再手下留情了！！",
        "unit_id": 13511,
        "voice": "vo_adv_5044323_009"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n本大爺要使出真本事",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "讓這裡所有人",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "都沉進銀河之中～！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正合我意。",
        "unit_id": 113111,
        "voice": "vo_adv_5044323_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就用這把刀，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "斬斷你那扭曲的性格吧！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n讓你知道什麼叫作",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一敗塗地、片甲不留！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這、",
        "unit_id": 113311,
        "voice": "vo_adv_5044323_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這不是能夠保留實力的氣氛呢……！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊。",
        "unit_id": 113211,
        "voice": "vo_adv_5044323_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也解放",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所有的力量吧……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "走，我們上！",
        "unit_id": 113111,
        "voice": "vo_adv_5044323_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "杏奈、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "七七香、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥！！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n使出我們的全力，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "狠狠教訓那傢伙吧！！",
        "unit_id": 113111
