[
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──權能，",
        "unit_id": 106811,
        "voice": "vo_adv_5085321_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "解放。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大概就是這樣了。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n嗯嗯，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以我的標準來說重現度真不賴。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 121011,
        "voice": "vo_adv_5085321_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉比林斯達小姐……？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是什麼，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底怎麼回事！？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們怎麼會又……！？",
        "unit_id": 121111,
        "voice": "vo_adv_5085321_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼會穿成這樣……！？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀，",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉啊，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們幾個。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這是我做出來的空間。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n希望妳們來陪我一下。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "陪妳一下，",
        "unit_id": 121011,
        "voice": "vo_adv_5085321_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又要",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟那個人戰鬥嗎……？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是我的力量做出來的東西。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n任何事",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的基本都是調查、觀察、實驗，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了不讓這種事再次發生，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有必要先掌握才行。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……當然，",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那時候的",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "超乎想像的巨大力量",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無法照原樣重現出來。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了從別的角度重現當時的力量，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我加了各種創意變化。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我取名為：",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「迷宮女王」的",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "特別戰鬥～！",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳那一副期待人拍手的表情是什麼意思！",
        "unit_id": 121111,
        "voice": "vo_adv_5085321_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才不奉陪！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼我們非得參與那種實驗不可……！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓我們卯足全力地上吧！",
        "unit_id": 121211,
        "voice": "vo_adv_5085321_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要把別人講的話當耳邊風啦────！",
        "unit_id": 121111,
        "voice": "vo_adv_5085321_012"
    }
]