        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過前陣子，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "因為是我不小心讓他逃走的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n為了以示負責，我得再把他抓回去啊──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那位豬先生，",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_041"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是做了多餘的事呢──",
