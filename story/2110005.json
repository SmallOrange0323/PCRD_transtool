    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可可蘿！",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你們那邊怎麼樣！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有找到優衣嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2110005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她不在這邊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們每個房間都仔細找過了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也試著出聲叫她。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是這樣……",
        "unit_id": 105913,
        "voice": "vo_adv_2110005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實應當假設她已經離開宅邸了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒辦法了……",
        "unit_id": 100311,
        "voice": "vo_adv_2110005_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們先去跟到鎮上找尋的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "【哞哞自衛隊】她們會合吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯、",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "501430"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "唔～",
        "unit_id": 101711,
        "voice": "vo_adv_2110005_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這邊也沒看到人～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她該不會，",
        "unit_id": 101011,
        "voice": "vo_adv_2110005_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經走到",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "城外去了吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這樣啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2110005_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n優衣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔、",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和？",
        "unit_id": 100311,
        "voice": "vo_adv_2110005_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……優衣她，",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會不知道跑到哪裡去這件事。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都是因為我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有好好地跟",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣把話說清楚……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是，",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我有早點……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "告訴她……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n從諾維姆那裡聽到的消息，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "以及菲歐的事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣她肯定",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就不會受到那麼大的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "打擊……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和……",
        "unit_id": 100311,
        "voice": "vo_adv_2110005_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這件事……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也有責任。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也跟日和一樣，",
        "unit_id": 100311,
        "voice": "vo_adv_2110005_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一直有祕密",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "瞞著優衣沒說出口……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜……",
        "unit_id": 100111,
        "voice": "vo_adv_2110005_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "…………",
        "unit_id": 101411,
        "voice": "vo_adv_2110005_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_2110005_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……怎麼了？",
        "unit_id": 101711,
        "voice": "vo_adv_2110005_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n霞。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這種情況下，",
        "unit_id": 101411,
        "voice": "vo_adv_2110005_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還做出",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "更讓大家為她擔心的事──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "優衣她是這麼輕率的人嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我實在",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不這麼認為。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊！",
        "unit_id": 104311,
        "voice": "vo_adv_2110005_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我也不認為",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣是這麼輕率的人……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在的優衣她……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哼～",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n草野優衣她，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "目前不在嗎──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個人是！？",
        "unit_id": 101711,
        "voice": "vo_adv_2110005_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "尾狗刀前輩……！？",
        "unit_id": 104311,
        "voice": "vo_adv_2110005_022"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唷。",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這串燒，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是在那邊的攤販買的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n味道很不錯呢──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我還以為獸人族之國",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "會是個野蠻至極的地方。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n想不到食物這麼好吃，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "水和空氣也很乾淨，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是個好地方。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n果然不該抱有偏見，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我會好好反省反省的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個……",
        "unit_id": 101011,
        "voice": "vo_adv_2110005_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝誇獎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該這麼回答嗎……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主！",
        "unit_id": 104311,
        "voice": "vo_adv_2110005_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n別說得那麼悠哉！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n尾狗刀前輩可是……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯！",
        "unit_id": 100312,
        "voice": "vo_adv_2110005_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你既然",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經倒戈投向敵人的懷抱……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還有臉敢出現在我們面前！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦？",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_028"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳這話很奇怪耶？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "說什麼倒戈，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我打從一開始就不是你們的同伴啊──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106113,
        "voice": "vo_adv_2110005_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "各位──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n城鎮守衛說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n他剛剛有看到優衣出城去了──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "諾維姆小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2110005_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔！！",
        "unit_id": 106113,
        "voice": "vo_adv_2110005_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n尾狗刀！！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……哈。",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_032"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這麼說來妳也在呢──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n真不想見到妳啊──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "因為妳實在有夠囉嗦的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 106113,
        "voice": "vo_adv_2110005_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n到底在打什麼主意！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n竟然和那些傢伙合作……！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這種事，",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_034"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還需要問嗎──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "──因為我想得到米奈娃，",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_035"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯。",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_036"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n像她那麼驚人的存在，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "任誰都會想納為己有吧──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊，",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_037"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "趁你們還沒開口問，我話先說在前頭。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我是不會告訴你們",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "米奈娃現在在做什麼的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n不過……",
