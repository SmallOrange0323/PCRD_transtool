        "name": "可可蘿",
        "words": "\n你這次又來找我們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是為了帶走主人……！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒錯。",
        "unit_id": 106211,
        "voice": "vo_adv_2110005_040"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "雖然我這個人",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一向很怕麻煩……",
        "unit_id": 106211
