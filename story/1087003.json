        "name": "迷路的少年",
        "words": "再見～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "迷路的少年",
        "words": "掰掰～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "掰掰～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_077"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那孩子能敞開心胸真是太好了呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "攤位的銷售量也很讓人吃驚啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1087003_078"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真的幫了大忙。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "吵、",
        "unit_id": 911,
        "voice": "vo_adv_1087003_079"
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "吵死了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "我才不是──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "──到此為止了！",
        "unit_id": 711,
        "voice": "vo_adv_1087003_080"
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "\n你這傢伙，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "就是在這附近搗亂的男人嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請問怎麼了嗎？",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_081"
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "我們接到了通報，說這附近從新年開始不時有個傢伙在起衝突，",
        "unit_id": 711,
        "voice": "vo_adv_1087003_082"
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "\n因此來這巡邏看看，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "沒想到他竟對女性動手動腳……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你誤會了！",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_083"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個人直到剛剛都跟我們一起，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n幫一個迷路的男孩子，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "找和他走散的母親！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且，",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_084"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在這家店的大叔不在的這段時間，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n他還幫忙做了章魚燒來賣！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我沒有騙人！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "日和妹妹說的是真的，",
        "unit_id": 1411,
        "voice": "vo_adv_1087003_085"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "王宮騎士先生。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這個人不管是我這店，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還是迷路的孩子，他都伸出援手幫忙了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "……",
        "unit_id": 711,
        "voice": "vo_adv_1087003_086"
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "嗯，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "的確看起來沒有人受傷，也沒有打鬥胡鬧的痕跡。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "\n然而，你平時的所作所為風評不佳，這個事實也不會因此改變。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "若你幹了什麼壞事，我們還是會馬上把你抓起來的。",
        "unit_id": 711,
        "voice": "vo_adv_1087003_087"
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "\n……那麼，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王國的騎士",
        "words": "失禮了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "可惡……",
        "unit_id": 911,
        "voice": "vo_adv_1087003_088"
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "反正那小鬼也回家了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "我也要閃人了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "等一下！",
        "unit_id": 1411,
        "voice": "vo_adv_1087003_089"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這章魚燒，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是你做的對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "啊？",
        "unit_id": 911,
        "voice": "vo_adv_1087003_090"
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "是啦，怎樣……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "非常好吃喔！",
        "unit_id": 1411,
        "voice": "vo_adv_1087003_091"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我平時開的是料理店。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你願意的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "希望你能來店內的廚房幫忙……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你覺得怎麼樣？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "……呃，",
        "unit_id": 911,
        "voice": "vo_adv_1087003_092"
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "啥？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "……",
        "unit_id": 911,
        "voice": "vo_adv_1087003_093"
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "唉，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "我如果有那個心情的話……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無禮男子",
        "words": "掰啦……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個大哥他……",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_094"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有打從骨子裡就是壞蛋的人呢。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果今天這事情，",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_095"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能讓那個大哥他的心底，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有那麼一點點的變化，就讓人更高興了呢。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是的呢！",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_096"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定會！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生你也是這麼想的呢！",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_097"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟呀，",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_098"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就只是一天而已小哥他的周圍，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就有這麼多的改變了嘛，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以能夠改變的！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "迷路的男孩子，也找到他的媽媽了，",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_099"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n攤販的大叔也找到有可能到他店裡幫忙的人了呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那位大哥他，",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_100"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是大家所需要的人……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不只是今天而已，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今後也會是！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然有困難的時候",
        "unit_id": 108711,
        "voice": "vo_adv_1087003_101"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就互相幫助幫助，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在親眼見到人的內心能有所改變的那瞬間，\n日和心滿意足地對著{player}露出了一抹微笑。"
    }
]