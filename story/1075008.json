[
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了人變少的沙灘，悠閒地眺望西沉的夕陽。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯──♪",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今天玩得真盡興！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "歡樂的時光",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一眨眼就結束了！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的臨時打工，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就到這裡結束囉☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過很可惜呢。",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n接下來暫時",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又沒辦法和你見面了……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想見的話",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "確實還有辦法見面，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但從明天起，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就是尤絲蒂亞娜陛下了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不能再像今天這樣對你撒嬌，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n給你添麻煩了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當夕陽西沉後，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個閃亮的魔法就消失了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這麼一想",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的有點捨不得……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不想回去。",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好想讓你繼續當我的達令，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再給你",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "添麻煩……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開玩笑的啦☆",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該給你什麼報酬呢？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n先告訴我你要什麼吧！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n去一個地方？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "喂～！",
        "unit_id": 1,
        "voice": "vo_adv_1075008_010"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "小兄弟！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n我準時到了～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "船上好像有人在揮手……",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難道我們接下來",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要出海嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此～",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你有什麼驚喜要給我嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然可以延長約會時間，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很願意陪你去♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼達令♪",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我只是個柔弱的女孩子，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n麻煩你",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "護送我上船囉♪",
        "unit_id": 107512
    },
    {
        "type": "background",
        "background": "500841"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海、",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海、",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一望無際的大海！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n景色真是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太棒了♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來你想來的就是這裡☆",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從船上看夕陽，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的好浪漫哦♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那裡……",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "燈塔嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1075008_017"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "前不久才蓋好的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這都多虧了我們的陛下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_018"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這附近",
        "unit_id": 1,
        "voice": "vo_adv_1075008_019"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "之前有魔物作亂……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n沒辦法出海捕魚。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "也沒有觀光客。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n我們的生活",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "都快過不下去了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "畢竟蘭德索爾也正在復興。",
        "unit_id": 1,
        "voice": "vo_adv_1075008_020"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n老實說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我根本不敢期待中央會對這種鄉下地方伸出援手……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n不過，當時的情況也顧不了",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這麼多，反正就先提出請願書看看。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "然後",
        "unit_id": 1,
        "voice": "vo_adv_1075008_021"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "蓋燈塔的計畫就開始了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n我們全都嚇了一大跳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "多虧有那座燈塔，不但船難變少，",
        "unit_id": 1,
        "voice": "vo_adv_1075008_022"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n魔物也不再靠近。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n所以現在我們都能安心生活了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不、",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對於陛下，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家似乎",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是有不少疑慮……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1075008_024"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我們一開始",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "的確是不放心。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n不過啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我們現在",
        "unit_id": 1,
        "voice": "vo_adv_1075008_025"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "全家都有美味的飯吃……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n這種幸福的生活",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "是陛下幫我們討回來的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "所以",
        "unit_id": 1,
        "voice": "vo_adv_1075008_026"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我支持現任的陛下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n……嗯。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "至少她還幹得比前任好一點嘛！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會努力的。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_1075008_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒什麼！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的意見很有幫助～！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個。",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這件事情，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}應該已經知道了吧？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那是當然的！",
        "unit_id": 1,
        "voice": "vo_adv_1075008_031"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "這位小哥",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "好像是陛下的粉絲！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n他似乎還會到其他陛下視察的地方，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "追著她四處跑的樣子。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "不過，就算你是陛下的粉絲，",
        "unit_id": 1,
        "voice": "vo_adv_1075008_032"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n在夏天和女朋友約會的時候，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "也不需要來這邊看燈塔吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係！",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我很開心☆",
        "unit_id": 107512
    },
    {
