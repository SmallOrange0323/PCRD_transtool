    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來你是",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "陛下的粉絲啊！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不好意思。",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以在這裡",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "待久一點嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想將這副景色，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "深深烙印在腦海裡面！",
        "unit_id": 107512
    },
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿♪",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你給我的驚喜，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的讓我嚇了一大跳☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在回去之前，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以稍微聊聊嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所謂的告白時間♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "船長剛才不是說了嗎？",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之前他們沒辦法去捕魚，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒有觀光客來這裡。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但多虧了燈塔，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他們的煩惱解決了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天一起吃海鮮，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一起拜訪擠滿觀光客的海邊，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n最後還帶我來看那座燈塔……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你做的這一切是",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都是為了我，對吧☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "決定留在王宮後，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在我心裡的一個小小角落，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一直覺得見不到你很寂寞。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你其實一直默默站在遠方，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n關心著我身為陛下時所做的事。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你始終都是站在我這邊的……",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且還告訴了我，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "距離不會阻隔你的心意！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以……",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "下次再碰到難過的事情的時候，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會回想起今天！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n回想起和最喜歡的人共度的夏天♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以後還要",
        "unit_id": 107512,
        "voice": "vo_adv_1075008_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再和我來這裡約會哦。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n達令☆",
        "unit_id": 107512
    },
