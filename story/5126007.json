    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "各位，你們說對吧！？",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "對啊，",
        "unit_id": 1,
        "voice": "vo_adv_5126007_038"
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "凱留，這很不像妳喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "嗯！",
        "unit_id": 1,
        "voice": "vo_adv_5126007_039"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "像平常那樣就行了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們……",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶！",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴、",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴奈！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等等，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹嘛把我的信拿走啊！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_043"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對不起！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的意見也跟大家一樣呢♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓我們聽聽，",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_044"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶真正的想法！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}……",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那你們就聽好了！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就老實說了，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我超討厭學校的！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "來賓",
        "words": "咦……",
        "unit_id": 1,
        "voice": "vo_adv_5126007_048"
    },
    {
        "type": "dialogue",
        "name": "來賓",
        "words": "凱留同學！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "來賓",
        "words": "\n身為優等生的妳怎麼能這樣說！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "噓～！",
        "unit_id": 915,
        "voice": "vo_adv_5126007_049"
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "大人不要干擾她。",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我一直",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都這麼想。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n學校這種東西，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺就像是不自由的牢籠。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被不講理的校規束縛，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被奪走自由和時間，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n拿來學習自己不想學的東西……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種地方",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟牢籠沒有兩樣。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而你們，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實也是這麼想的。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是你們啊，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是沒有能力獨自生活的雛鳥。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以要和其他弱小的人成群結隊，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拚命地配合步調以免自己落後。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然而",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對於無法配合上步調的人，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就當作異類加以排除……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以無論是學校，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是你們這種在學校就讀的學生，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我都超討厭的！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5126007_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我本來以為所謂的「青春」，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n根本就只是拿來美化這些死板日子的詞彙罷了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為不承認自己每天都過得很無趣，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以就說這是青春吧！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這樣",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "裝作好像過得很耀眼，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n拚命地蒙騙自己。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……因此，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是為了確認這點",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才試著來這裡上學的。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想證明學生放學後",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看似開心的表情",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是假的，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "證明自己",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就不羨慕什麼青春……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……但是，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_058"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我錯了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實際體驗過後，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_059"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我發現學校其實也沒有那麼糟。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在這裡，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "享受到了青春。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然說我討厭成群結隊，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但如果只有我一個人",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是絕對沒有辦法體會到的。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以說……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我很感激。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝你們。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……以上。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_062"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我好像說了些很莫名其妙的話……！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在馬上給我忘了！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拍手拍手拍手拍手！"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唔。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_064"
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "嘿嘿！",
        "unit_id": 814,
        "voice": "vo_adv_5126007_065"
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "妳一樣還是那個講話很惡毒的臭眼鏡女！",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "\n",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "不過，",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "我就是想聽妳說這些！",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "不良學生",
        "words": "\n這真是最棒的致詞了！！",
        "unit_id": 814
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "呵呵，",
        "unit_id": 1215,
        "voice": "vo_adv_5126007_066"
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "凱留同學，",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "我們才要謝謝妳。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "\n",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "然後，",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "委員長",
        "words": "也恭喜妳畢業。",
        "unit_id": 1215
    },
    {
        "type": "dialogue",
        "name": "學生們",
        "words": "恭喜畢業！！",
        "unit_id": 1,
        "voice": "vo_adv_5126007_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……謝謝。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……鈴奈！",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_069"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "！",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_070"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什、",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼事？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也要向妳道謝。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多虧有妳陪著我，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才能這麼開心。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝妳。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "握手。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_073"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "握手。",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "騙妳的。",
        "unit_id": 127212,
        "voice": "vo_adv_5126007_074"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抱緊～～～～～～！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶……！！",
        "unit_id": 127312,
        "voice": "vo_adv_5126007_075"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家能跟凱留寶一起上學",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也是超×100兆",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n開心的……！！",
        "unit_id": 127312
    },
