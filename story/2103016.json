        "voice": "vo_adv_2103016_007"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n畢竟我這雙手最擅長的器具……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "便是右手持刀，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "左手持叉",
        "unit_id": 191911
    },
