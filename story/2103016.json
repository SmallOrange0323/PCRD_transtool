    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n這可真是的，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "多麼令人畏懼呀。",
