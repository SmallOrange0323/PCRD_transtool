        "type": "dialogue",
        "name": "怜",
        "words": "……唔！",
        "unit_id": 180311,
        "voice": "vo_adv_2103016_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從剛才開始，",
        "unit_id": 180311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明明就完全壓制住他了……",
        "unit_id": 180311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n卻遲遲無法了結他！　",
        "unit_id": 180311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難不成……",
