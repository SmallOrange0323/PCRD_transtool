        "type": "dialogue",
        "name": "怜",
        "words": "……你這傢伙。",
        "unit_id": 180311,
        "voice": "vo_adv_2103016_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可別跟我說",
