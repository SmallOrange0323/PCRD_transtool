[
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "えへへ、",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_000"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃん私たちのこと、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ちゃんと覚えててくれたんだね！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\nうれしいなぁ♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "それに",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "平均点超えだって！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんすごいね！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "そうね、",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_001"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ちゃんと頑張ってるみたいで",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "安心したわ。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "私とお姉ちゃんが入れ替わってたんだもんね。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_002"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "今思うと",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "すごく不思議な感じだよ。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "しかも",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_003"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "私たちだけじゃなくて",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "街中の人たちまで巻き込んで……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ホント、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "よく解決できたわよね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "でも、",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_004"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "そんなラフィちゃんのおかげで、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n私たちはハッピーになれたんだよ。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ええ、",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_005"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "間違いなく",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ラフィはハッピーエンジェルだったわね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "それにしてもあの子、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "『エンジェルがんばってるですか？』って……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "もう、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ちゃんと約束したわけでもないのに。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんには分かってたんだよ。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_006"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "お姉ちゃんなら絶対にエンジェルをやってくれるって。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "それに",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_007"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "私も結構エンジェルの活動気に入ってるんだ。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんみたいな力はなくても、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "心はちゃんとエンジェルだよ！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "……そうね。",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_008"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "あの子と再会したときに",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n恥ずかしいところを見せないように、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "私も頑張らないとね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "うんうん！　",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_009"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "それじゃあ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんが送ってくれたキャンディ、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n一緒に食べようよ？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "……待ってアカリ！",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_010"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n思い出した、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "これって『大天使の泪』だわ！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "『大天使の泪』……？",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_011"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "前に",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_012"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "イリヤさんの魔力を取り戻すアイテムを探してたときに、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n本で見たことがあるの。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ものすごい高額で取引されてる",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_013"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "幻のアイテム……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "こんな貴重なものをあっさり送ってきちゃうなんて……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\nやっぱりあの子、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "本当のエンジェルだったのね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "うーん、",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_014"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "そんな貴重なものだと",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "さすがに食べづらいよね。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "どうしようお姉ちゃん、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "売れば私たちお金持ちになれるよ？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "……ううん、",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_015"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "これはとっておきましょ。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\nラフィの成長の証みたいなものだもん、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "大事にしたいじゃない。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "お姉ちゃんならそう言うと思ったよ。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_016"
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "それじゃあ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "キャンディの代わりに、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "何か甘いもの食べに行こう♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "\n私たちから",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "アカリ",
        "words": "ラフィちゃんへのお祝いだよ。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "全く、",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_017"
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "アカリってば調子がいいんだから。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "でも、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "今日くらいはいいわよね。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "私たちのハッピー、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "ヨリ",
        "words": "ラフィに届くといいわね。",
        "unit_id": 102211
    }
]