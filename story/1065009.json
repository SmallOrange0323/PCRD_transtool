[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "閒得發慌的{player}無所事事地漫步於街上時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在路的前方發現了朝自己走來的嘉夜。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "受不了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該怎麼辦才好……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你啊……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要怎麼說才好咧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想想……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我剛剛在想點事情啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我要去那邊了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n再見啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔～呣……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不用啦，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你不需要這麼替我操心……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂！",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別推我！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n好啦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會讓你送的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以你不必那樣子推我！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我剛才沒講，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不過回到地盤這點小事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我一個人也是能做到的喔……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這一點算是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的優點",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "送了我一程，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是多謝你啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你現在有空嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我有一件事想跟你聊聊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "完全沒有架可以打啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之前",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是用上覺醒的力量，打了一場架嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜那場架所賜，我聲名大噪，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但同時間也讓周遭的人怕我怕得要死。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再加上，幫派那邊",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也完全安定下來了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "世界",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "非常和平。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當然",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是會有小紛爭之類的事情喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可不能特地出馬去處理那種小事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而且底下那些傢伙也需要點能活躍的場面，不是嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就結果而言，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我失去了大顯身手的揮拳擂臺。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好不容易快要掌握到的覺醒感受，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也感覺要消失得無影無蹤了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟我除了鍛鍊自己以外，就沒其他事可做了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n到了空閒時間，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就會像飢渴的魔物一樣徘徊在城鎮裡。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是沒轍啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣下去的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺不管對象是誰，我都會揍下去。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊是啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "經由你介紹的工作也沒了喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "「走到窮途末路」就是我的現況……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "願意聽我說這些。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我今天會在城鎮裡多晃一下看看的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你回家時可要注意安全啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣好嗎？",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你自己也有事要忙吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的好意我就心領了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣啊……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呵呵。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你這位死黨果然是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最棒的！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……說是",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼說啦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我們現在能做的事",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟之前沒什麼兩樣吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是到處露個臉，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n找找看哪邊可能會發生騷動。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呆站在這裡也無濟於事。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有句俗話叫",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "滴水",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼石的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那我們",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就出發吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，兩人在蘭德索爾漫步而行，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向許多人搭了話。但是──"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哦～",
        "unit_id": 1411,
        "voice": "vo_adv_1065009_025"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是嘉夜！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "麻煩事？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "託你的福，那些事已經被處理得乾乾淨淨啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這也要感謝嘉夜喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "之後又發生什麼事的話，就再麻煩你們了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "呃！",
        "unit_id": 414,
        "voice": "vo_adv_1065009_026"
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "嘉夜！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "妳有什麼事？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "妳問我有沒有什麼困擾！？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "我當然很困擾啊！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "我這邊啊，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "\n因為輸給了妳，生意都做不起來了！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "打手",
        "words": "快給我走開！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "最近完全沒聽說過",
        "unit_id": 511,
        "voice": "vo_adv_1065009_027"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "有誰陷入了麻煩之中呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n要是一直都這麼和平就好了……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怎麼了嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們要是碰上麻煩隨時和我說啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我會幫忙的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
