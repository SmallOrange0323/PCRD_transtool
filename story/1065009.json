    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近都是這個樣子啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就算知道這樣不好，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我還是希望能發生點事件。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟在這裡主動引發事端，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我覺得有點不太對……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "──很痛耶！",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_032"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳連走路要看路這點小事都做不到嗎！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天搞不好中獎了喔！",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們過去看看吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "對、",
        "unit_id": 6511,
        "voice": "vo_adv_1065009_034"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "對不起，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我剛剛在想一點事情……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "所以就可以撞人嗎！",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_035"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我還真是被妳看扁了啊！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂喂，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她都道歉了，你就原諒她吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n她又不是抱著惡意去撞你的，對吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "嘉夜！？",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_037"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "是、",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "是啊，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳說得對。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n好了，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "既然妳已經道歉了，妳就走吧。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "咦……？",
        "unit_id": 6511,
        "voice": "vo_adv_1065009_038"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "啊，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "好、",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "好的……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n對不起……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在幹什麼啊！",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_039"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳說幹什麼……",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_040"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "就是照妳說的放她走啊。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是要你不要照著我的話去做啊！",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_041"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "為啥啊！？",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_042"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "……",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "哼哼──",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我猜",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳是想做打手的工作對吧？",
