    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，沒錯。",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有意見嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "不，",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_044"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "沒什麼。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "但在事情演變成那樣之前，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "就由我退讓一步吧。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "畢竟我可不是妳的對手。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話是這麼說沒錯……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但惡人可以輕易地放低身段嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "在妳是對手的情況下，哪能去在意面子啊。",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_046"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n打架不挑對手，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "那只是個笨蛋而已。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我有說錯嗎？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說得對。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就只是個笨蛋而已。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我知道啊。",
        "unit_id": 6311,
        "voice": "vo_adv_1065009_048"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "像我們這種狡猾的人啊，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n最怕的就是那樣子的笨蛋，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "所以才沒辦法和妳打。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "就這樣啦。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "下次就讓我在妳不在的地方",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "做壞事吧。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "小心別鬧到讓人要叫打手來喔──！",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是會變成這樣呢。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉～",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是哪裡有",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n和我差不多程度的笨蛋在就好了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……打手這工作，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或許是時候可以到此為止了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟這或許也是時代的潮流，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是把心思花在幫派上吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就說你不用在意了啦。",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "光是你有心想幫忙，就讓我很開心了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是沒有你在身邊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我就會那樣一直獨自煩惱。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我總是受到你幫助。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……要是",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我放棄打架，不再戰鬥了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你還願意像今天這樣",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "待在我身旁嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_057"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然你都這麼說了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_059"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真不可思議。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然不知道這是為什麼，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我的雙眼無法從{player}身上移開……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不僅如此……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_060"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一被他這樣子盯著看，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們之間的距離就越來越近，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺要被吸過去了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_061"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣下去的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘴唇好像就要碰在一起了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是怎麼了……",
        "unit_id": 106511
    },
    {
