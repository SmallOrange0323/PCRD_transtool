        "voice": "vo_adv_1065009_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還真是什麼事都沒發生呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我已經束手無策了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "至於你……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "連問都不用問了啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過",
        "unit_id": 106511,
        "voice": "vo_adv_1065009_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "試著實際走過一遭，你就明白了吧？",
