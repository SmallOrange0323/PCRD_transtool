[
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居然要給高貴的本小姐更多懲罰！",
        "unit_id": 1,
        "voice": "vo_adv_5205061_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n本小姐可是一點都無法接受～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊啊，",
        "unit_id": 51611,
        "voice": "vo_adv_5205061_001"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎士閣下先生～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n華音小姐她又惹事了……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "因為戰鬥的餘波弄壞了小孩子的玩具",
        "unit_id": 134912,
        "voice": "vo_adv_5205061_002"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就讓本小姐去當街頭藝人，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "或是對本小姐高貴的笑聲處以封口刑罰……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "如此眾多不合理的懲罰，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "總有一天本小姐要兆倍奉還給涅妃‧涅羅！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "如你所見，",
        "unit_id": 51611,
        "voice": "vo_adv_5205061_003"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "她一直是這個樣子～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n就算被皇女大人懲罰",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "也完全沒有學乖～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎呀騎士閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_5205061_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁來得正是時候。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論奴家如何施以懲罰，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無奈只添怨懟於其心。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n只見華音之叛逆愈發煽動，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實令奴家傷透腦筋。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因此暫時之間，",
        "unit_id": 129711,
        "voice": "vo_adv_5205061_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n關於華音那傢伙，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還望恁能賜以良策。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下親自勸誡所授之苦藥，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許反能成為有益於她的良方。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "等一下！",
        "unit_id": 134912,
        "voice": "vo_adv_5205061_006"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你們怎麼可以擅自做決定！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n退個一萬步來說，如果是打贏本小姐的涅妃",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那還勉強可以接受！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "但讓阿貓阿馬來負責懲罰本小姐",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "到底是在想什麼！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下如此仁厚，",
        "unit_id": 129711,
        "voice": "vo_adv_5205061_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在令奴家感激不盡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "容奴家冒昧",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奉上一句建言。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "管教野獸，不得單靠鞭子，",
        "unit_id": 129711,
        "voice": "vo_adv_5205061_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "更不能僅以糖果馴之。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唯有兩者兼備，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才方能成事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "別無視當事者在那擅自決定啊！",
        "unit_id": 134912,
        "voice": "vo_adv_5205061_009"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐可是",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "絕對不會對這種",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "阿貓阿馬屈服的～！！",
        "unit_id": 134912
    }
]