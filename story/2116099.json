        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n聯合國",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "以及國際刑警",
        "unit_id": 1
    },
