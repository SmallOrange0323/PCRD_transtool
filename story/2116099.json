        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵♪",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你要我",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說點什麼？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n該、說、什、麼、好、呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過我覺得？",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "繼續保持沉默，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "吊吊你胃口也不錯呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不覺得",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "挺有趣的嗎……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉呀，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "講話真不留情。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人家好受傷喔……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而且呀──",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵♪",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我可不是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼虐待狂喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只不過……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是不想讓你以為，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要是女孩子就會對你百般親切，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n僅、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "此、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "已。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我記得是叫菲歐吧？",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n和那個嚮導小妖精不同，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我並沒有站在你這邊。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的立場是公平中立的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以不論是之前、",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現在",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還是以後，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我都不會特別優待你。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這點你要記好喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈♪",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你搭訕的台詞，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還真是老套呢～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過嘛……",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣好了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我給你一點提示。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "用「這個樣貌」和你見面，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "的確是第一次。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你已經認識",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「我」了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "之前好像……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喪失記憶了？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我們是在那之後認識的喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而且除了你之外，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其他人也都認識",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「我」。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "提示就到這邊。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如何？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n有想起來了嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……這樣啊。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我想也是～♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也不覺得我跟你講這點提示，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你就能明白啦？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起這個──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你苦惱的表情，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是棒呢……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總覺得",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要看上癮了……♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好啦，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你就死心吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這裡，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就只有我和你，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒有其他人了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "誰知道呢？",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總之不會掉下去，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你就放心吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在夢裡，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不就是會這樣嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我剛才說了什麼，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你已經忘了嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……算了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "再告訴你一個提示也無妨……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不是索爾之塔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你的妖精當作據點的地方，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在遙遠的彼方喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉呀？",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n時間好像差不多要到了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這次",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就先到這邊吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我和你聊得很開心喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就再告訴你一件事，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "當作是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝禮吧。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我叫媞雅。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_033"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n是不偏向任何一方，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "公平中立的存在。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "總之，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_034"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "請你多多指教囉。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n感覺還會跟你相處很長一段時間，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n之後我也會",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好好捉弄……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好好疼",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "愛",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "沒錯。",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_035"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就算你不想，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我和你，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "之後還是會見面的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我想你也知道──",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_036"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你的故事，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還沒有結束。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "有許多問題還沒解決，",
        "unit_id": 193211,
        "voice": "vo_adv_2116099_037"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還有人在等待幫助。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
