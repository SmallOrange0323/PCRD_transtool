    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "陸續甦醒了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n如同前面所報導的，",
