        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "正在進行追緝──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──接續",
        "unit_id": 1,
        "voice": "vo_adv_2116099_070"
    },
