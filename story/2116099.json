    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "更加惡化──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──激進抗議分子闖入王宮，",
        "unit_id": 1,
        "voice": "vo_adv_2116099_071"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "根據當地媒體報導，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n出資贊助的王族已遭到處刑。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n本台會為您查明消息真偽，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "提供後續報導──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──接著，",
