    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "全世界都為此感到欣喜──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──然而，",
        "unit_id": 1,
        "voice": "vo_adv_2116099_069"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "「禁錮」所造成的經濟損失無可估計，",
        "unit_id": 1
    },
