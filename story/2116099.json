    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n《阿斯特朗傳奇》",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "相關的最新消息──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "──數天前，「米奈娃的禁錮」忽然解除，",
        "unit_id": 1,
        "voice": "vo_adv_2116099_068"
    },
    {
        "type": "dialogue",
        "name": "新聞網站的記者",
        "words": "\n被困在遊戲中的人們",
