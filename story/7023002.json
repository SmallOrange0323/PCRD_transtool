    {
        "type": "dialogue",
        "name": "旁白",
        "words": "登塔時，茉莉不停地邀請著日和。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦咦？",
        "unit_id": 100511,
        "voice": "vo_adv_7023002_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是不行嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "與其說不行……",
        "unit_id": 100111,
        "voice": "vo_adv_7023002_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是覺得自己做不到",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啦。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有那種事。",
        "unit_id": 100511,
        "voice": "vo_adv_7023002_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只要有正義感，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就應該要挺身而出！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～",
        "unit_id": 100111,
        "voice": "vo_adv_7023002_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不能當",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "協助茉莉英雄的幫手就好嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳的意思是",
        "unit_id": 100511,
        "voice": "vo_adv_7023002_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只負責",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "支援嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃，",
        "unit_id": 100111,
        "voice": "vo_adv_7023002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那叫什麼呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "搭……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳要說的是搭檔啦！！",
        "unit_id": 100511,
        "voice": "vo_adv_7023002_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈，",
        "unit_id": 100111,
        "voice": "vo_adv_7023002_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抱歉抱歉。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳說的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "搭檔，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是幫助英雄的人吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我當那個不行嗎？",
