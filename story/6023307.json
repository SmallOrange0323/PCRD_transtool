[
    {
        "type": "background",
        "background": "500740"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如你所知，",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不太喜歡外出。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n相反的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你倒是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "常常前往各種地方嘛。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有什麼景點能夠喚起我",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個家裡蹲的求知慾呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "海水浴場嗎……",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "老實說，我完全沒興趣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "由於我是在山裡長大，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "作為未來的參考，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該要去一次看看呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個叫作泳裝的不知羞恥的衣服……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔唔唔唔……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦，",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我聽說過那裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像是充滿東國風情的城鎮呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所謂遠東文化是怎麼樣……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽說腐爛的大豆或是魚的遺體，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不管什麼都會呼啦呼啦的淋上醬油吃掉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔唔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "象牙之塔？　",
        "unit_id": 111011,
        "voice": "vo_adv_6023307_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你是指",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沉眠著稀有古書的那個地方？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n好，走吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呃，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是這裡的圖書館！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "才不是呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n幹嘛讓充滿智慧的我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "進行有生以來第一次吐嘈啊。",
        "unit_id": 111011
    }
]