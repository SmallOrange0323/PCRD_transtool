    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜和大吾之間的對決之日終於到來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了見證兩人的戰鬥，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n無論是騎士、貴族或無賴都聚集在會場邊。"
