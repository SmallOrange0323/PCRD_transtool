[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……找我有事嗎，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，失禮了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嚇到你了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我經常在這蘭德索爾王宮的正門前，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n挺直站立，紋風不動呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也曾有過被誤會成是銅像，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或者擺設品的事情發生。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "偶爾也會有觀光客，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n與我搭肩拍照。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "照片，你不知道嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然只是個小小的魔法，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但能把影像轉印在紙上。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但因為能使用便宜的魔法道具重現，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此普通平民似乎也能輕鬆拍照。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "過去，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有若被拍照靈魂就會被奪走……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的迷信呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然被拍攝紀念照，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並不是太讓人開心的事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從防衛觀點來考慮，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也不太希望王宮被拍照。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說如此",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也不是需要皺著眉頭，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並且加以處份的壞事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，目前就睜一隻眼閉一隻眼了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為王宮的守備，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是我應該最優先執行的任務……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此這可不是值得被誇獎的應對方式呢，嗯",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……你很沉默寡言呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我也不是喋喋不休的那種人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也不太擅長對話。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但若你什麼都不說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就變成我單方面在講話的奇怪情況了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那我重新問一次。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n來王宮有什麼事情嗎，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你叫……{player}對吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，沒認錯人太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "老實說，因為頭盔的關係，我的視野很不好啊……",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n臉不靠得相當近的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n連說話對象的容貌都無法看清",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為自幼就帶著頭盔，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n二十四小時都這樣度過……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然在日常生活方面並沒有特別不便，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但像服務業之類的就應付不來了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有，僅是我單方面的知道你而已。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以前，陛下曾讓我看過你的畫像呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……啊啊沒什麼，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是一點私事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n請你忘了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總而言之。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我從以前，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就很想與你談談了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能在這裡相遇也算一種緣份，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你能陪我聊一下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然能明白是重要的工作，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但守衛也就只是站立著而已……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也因此出乎意料的空閒呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請你當寂寞大姐姐的聊天對象吧，\n{player}。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，我好歹是名女性。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然是無關緊要的事，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但可能因這身魄力滿滿的鎧甲，我常被誤認為是男性。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不，雖說別人怎麼想都無所謂。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但看見路上盛裝打扮的年輕女孩子們，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有時也會感到非常羨慕呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我因為家中的規矩，鎧甲及頭盔都不能脫掉，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以無法實現那種憧憬。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不談這個了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓我重新自我介紹吧。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "200300301"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是擔任【王宮騎士團】",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n團長職務的純。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，之後還望你能多多指教。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】是\n名為【公主騎士】的國營公會……",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也就是所謂的，政府機關的其中之一。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "主要的任務，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是守衛王宮及城鎮。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以前戰爭的時候，以軍隊身分工作，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n代替手無縛雞之力的人民，在第一線橫衝直撞。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也就是我們國家自豪的軍事力量。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然因為最近很和平，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，就像輕鬆的保安一樣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我們也擁有逮捕權，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此最好不要在我們面前做壞事喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對於擾亂城鎮治安的犯罪者，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】是絕對不會留情的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我祈禱著你不會成為我們的敵人喔。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_039"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想說的就是這些，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有什麼事嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你迷路了嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知道投宿旅館的地點，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n已經一籌莫展了啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的話，希望你一開始就能告訴我呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "滔滔不絕地，講了多餘的話。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我還以為你肯定是來探查王宮的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以戒備著呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為你，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對陛下來說是個礙眼的存在呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說了像威脅般的話，失禮了。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若只是單純迷路的話，就是我應該守護的市民。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n旅館的名字，知道嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我畫地圖給你吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n蘭德索爾非常錯綜複雜，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不熟悉的話很容易迷路。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "又找不到路的話，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只要向著在城鎮何處都能看見的王宮就好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我無論何時，都會站在這裡喔。",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下次，也讓我為迷路的你指示方向吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒什麼，",
        "unit_id": 104711,
        "voice": "vo_adv_1047001_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不用道謝……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n溫柔地對待小孩子，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是作為「正義的夥伴」的職責哦。",
        "unit_id": 104711
    }
]