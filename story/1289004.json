    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎，",
        "unit_id": 190011,
        "voice": "vo_adv_1289004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次和志那都她們發生了很多事嘛？",
