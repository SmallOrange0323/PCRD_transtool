        "voice": "vo_adv_1289004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她總有一天就能原諒自己。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為，",
        "unit_id": 190011,
        "voice": "vo_adv_1289004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n遊戲是能拯救人心的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1289004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我最後要跟你說件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有關你和優衣選的花。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種花名叫瑪格莉特。",
