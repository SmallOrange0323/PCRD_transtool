        "voice": "vo_adv_1289004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但既然是你選的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肯定沒意識到吧。",
