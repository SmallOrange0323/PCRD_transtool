        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但多虧有你，幫了我大忙喔。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……謝謝你。",
        "unit_id": 100231,
        "voice": "vo_adv_1289004_061"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我也很開心。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "明天……",
        "unit_id": 100231,
        "voice": "vo_adv_1289004_062"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也對，",
        "unit_id": 100231
