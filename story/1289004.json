    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不如說",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這本來就是為了明天而買的。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "得將我們選的這束花，",
        "unit_id": 100231,
        "voice": "vo_adv_1289004_063"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好好裝飾在教室裡。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎？",
        "unit_id": 100231,
        "voice": "vo_adv_1289004_064"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真開心。",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我變得越來越期待",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "明天到來了。",
        "unit_id": 100231
    },
