        "voice": "vo_adv_1172001_047"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這個地區的在地料理……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "對中暑很有效。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n這次的演唱會……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "一定也會變得很熱，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "希望妳不會輸給暑氣。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n所以說，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那個……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳不介意的話，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就吃吃看吧。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好香的味道！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看起來好好吃……！",
