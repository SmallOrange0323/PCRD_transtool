    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……是招待。",
        "unit_id": 414,
        "voice": "vo_adv_1172001_046"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n因為我是，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那個……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "慈樂之音的，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "望望的忠實粉絲。",
