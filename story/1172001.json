        "voice": "vo_adv_1172001_044"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n還有……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這是",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們店裡的招牌菜。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "奇、",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "奇怪……？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們好像沒有點這個……",
