    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一直在用跳舞跑步健身，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也有仔細控管飲食……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為這是……",
        "unit_id": 414,
        "voice": "vo_adv_1172001_051"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們的招牌菜。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n你也",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "一起吃吃看吧。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "甜甜鹹鹹的香味好誘人……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "又軟又嫩的肉充滿了光澤，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這應該很下飯吧……",
