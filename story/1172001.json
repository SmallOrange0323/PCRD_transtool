    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚～～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看起來真的好好吃喔……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在蘭德索爾吃不到的菜吧，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定是這樣。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……可是，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "該怎麼辦？　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了夏日演唱會，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "努力讓自己瘦下來了啊……",
