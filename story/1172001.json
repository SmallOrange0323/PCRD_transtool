        "voice": "vo_adv_1172001_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚇我一跳……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起，",
        "unit_id": 117211
    },
