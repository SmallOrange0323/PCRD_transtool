    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只吃一點的話，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒關係",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧？　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行不行！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我絕對不可以鬆懈下來。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看你吃得那麼香，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n讓我的肚子越來越餓了……！　",
        "unit_id": 117211
