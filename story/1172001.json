[
    {
        "type": "background",
        "background": "500710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "慈樂之音巡演中的某個夏日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在望休假時和她一起行動。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～～～～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "天氣真棒♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說到夏天，果然就是南方的島嶼呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天可以休息一整天，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就來盡情地享受吧♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}跟我一起來是很好，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但你為什麼拿出了筆記本呢？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "貼身採訪？",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是怎麼回事──？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──原來如此啊。",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把巡演中的休息時間都在做些什麼記錄下來，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等巡演結束後就拿來刊登在預計出版的雜誌上……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是這樣啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n製作人",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想得真周到呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓你來採訪，我可能會覺得有點不好意思。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "該說這會",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓人搞不太懂",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這要算是在工作，\n還是要當成是私人行程嗎……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我並不是討厭……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我大概是覺得",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有點害羞吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "走吧。",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇……！",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "街上的景色和蘭德索爾完全不同呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到處都有",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "許多小小的船。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各種地方都有放動物的擺設！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是用來驅魔的嗎……？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小小的，真可愛～～♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很喜歡像這樣，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在巡演地點的城鎮裡四處逛。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為我打氣的各位粉絲",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "居住在什麼樣的地方，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還有",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他們都會吃什麼樣的東西……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之類的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在了解這些事情之後啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就能更加貼近地感受到大家的存在。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我流了不少汗呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在演唱會上搞不好也能用這股熱氣來炒熱氣氛！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "奇怪？",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是什麼啊？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有股好香的味道……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗅嗅……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是從那家店傳出來的嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也渴了，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就去休息一下吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "邊逛邊吃也是遊覽各地的樂趣之一呢。",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思～",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_016"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "喂……",
        "unit_id": 1,
        "voice": "vo_adv_1172001_017"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "那是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "望望對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我聽說她為了巡迴演唱會而來到這座城鎮，",
        "unit_id": 1,
        "voice": "vo_adv_1172001_018"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n但沒想到居然能在這種地方遇見她……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完全引來別人的注目了呢……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好意思～！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在我們用餐的時候，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n可以拍攝",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "餐點的照片嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "…………",
        "unit_id": 414,
        "voice": "vo_adv_1172001_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……？",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_022"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "…………啊，",
        "unit_id": 414,
        "voice": "vo_adv_1172001_023"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不管要坐哪裡",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "都可以。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n拍照也……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "沒問題。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你～！",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗯，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們也取得拍攝的許可了，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣就萬無一失了吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我看看……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這應該是能把照片拍得最好看的座位吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要點什麼？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的話……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就點冰淇淋汽水吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "充滿夏天的感覺，很棒吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在等待的時候，要來訪談嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "禁止問太過火的內容喔。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……所以說啊，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在這次的演唱會中，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也受到了紡希和千歌的許～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多幫助。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我真的一直都很感謝她們。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也想問問你，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在之前的演唱會上，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你對誰的表現最有印象？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我！？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘻嘻，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我在這次的演唱會上也會像太陽一樣閃閃發光的，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就拜託你為我打氣囉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管是你，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是大家，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我都會讓你們對我更加入迷的，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以要一直看著我喔！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗚，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然用若無其事的表情勉強掩飾過去了，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這樣啊，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是我啊……！　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼辦……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "心跳得好快……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的臉",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有沒有變紅啊！？　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌啊～",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為她的聲音很有延展性，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n獨唱時會讓人聽得如癡如醉呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以我的角度來看，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也會覺得贏不了她啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌啊……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔唔唔，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是個難纏的對手啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也該以氣質系美少女的路線為目標嗎？　",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算我模仿千歌，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不可能贏過本人……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是可是，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果能成為你的第一名，我一定會那麼做……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哦……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "居然點明了紡希，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你挺有眼光的嘛。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希啊……",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我懂。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是說啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為看到她專心致志地努力的模樣，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就連我都會想為她打氣啊。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n然後",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她還對別人很體貼，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "又比其他人",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "更加溫柔……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有點不太坦率，",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這一點也是她的魅力所在呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為紡希是這樣的人，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想會對她印象深刻也是理所當然的，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我果然",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也想成為你的第一名……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你問我",
        "unit_id": 117211,
        "voice": "vo_adv_1172001_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼了？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒什麼。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼都沒有！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "…………那個。",
        "unit_id": 414,
        "voice": "vo_adv_1172001_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚哇！？",
