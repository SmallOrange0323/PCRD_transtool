    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難得來觀光景點遊玩，",
        "unit_id": 105311
