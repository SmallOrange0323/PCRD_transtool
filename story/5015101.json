        "voice": "vo_adv_5015101_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過有點難行動呢……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就這樣被虐待狂先生帶到暗處，",
