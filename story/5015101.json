    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n為什麼要這麼辛苦啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5015101_004"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「將軍道中記　",
