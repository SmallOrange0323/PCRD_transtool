        "voice": "vo_adv_5015101_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們在城鎮上大吵大鬧，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n竟然都沒有人罵我們……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這城鎮裡",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "發生什麼異常情況了嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔！？　",
        "unit_id": 109611,
        "voice": "vo_adv_5015101_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那一定是因為",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有人擾亂了這個城鎮的和平！",
        "unit_id": 109611
