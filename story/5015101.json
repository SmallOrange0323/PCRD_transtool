        "voice": "vo_adv_5015101_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不要在鎮上扔手裏劍！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然這件衣服很美，",
