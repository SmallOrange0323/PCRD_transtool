[
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因牧場著火而逃了出來的【伊麗莎白牧場】等人，\n總算順利來到山腳下避難。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一、",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "二、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "三……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，包含動物們在內，大家都沒事♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼～",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "事發突然都不知道會演變成什麼狀況呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也因為急著從山路上跑下來，腳好痛唷～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞，",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可以幫我揉揉腳底嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要溫柔點哦～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好。",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n鈴有時候",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n感覺就跟老奶奶一樣呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳可以不用對她那麼好哦～",
        "unit_id": 105211,
        "voice": "vo_adv_2005001_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n小栞。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴也真是的，",
        "unit_id": 105211,
        "voice": "vo_adv_2005001_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n才走到一半就開始喊說『我走不動了！』。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都是因為妳那樣撒嬌，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以我才抱著妳走下山呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的……",
        "unit_id": 105211,
        "voice": "vo_adv_2005001_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n才正覺得對妳另眼相看了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但小鈴果然就是小鈴呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "完完全全地，\n變回原本的那個小鈴了呢。",
        "unit_id": 105211,
        "voice": "vo_adv_2005001_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈……",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n鈴如果太認真的話，反而有點可怕，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以看見這個『平常的鈴』倒是讓我很放心呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿嘿。",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n對吧對吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可以再多誇獎我一點哦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "人家才沒有在誇妳好嗎……",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過真是太好了，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n畢竟幾乎沒什麼人受傷呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然【伊麗莎白牧場】的建築物，",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n成了那副慘狀就是了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只不過是棟房子而已，修一修就好囉。",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n受到魔物襲擊也是在保險範圍內嘛，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果能因此重建的話，感覺好像還賺到了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，真陽真是堅強呢，",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真讓人敬佩。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，讓大家留下了可怕的回憶了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n實在不想再遇到這種事情的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但到底是怎麼回事啊，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那些魔物們竟會如此失控……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總覺得，有些不太尋常。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過【王宮騎士團】的那些人，\n也說願意幫忙調查了呢。",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且還派了很多人來，",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n甚至還保護著我們到這裡來了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然，【王宮騎士團】對獸人的態度相當嚴厲，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n讓我不太擅長面對他們。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我這次刮目相看了。",
        "unit_id": 103811,
        "voice": "vo_adv_2005001_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說不定，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "他們其實都是些好人呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該怎麼說呢……",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就發現狀況並且快速趕來這一點來看，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n感覺有點準備得太過齊全，而且動作也太迅速了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得～那樣有點可疑耶？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n請問妳們對我們有什麼不滿嗎，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【伊麗莎白牧場】的各位？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有啊……",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n很感謝你們保護我們。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611,
        "voice": "vo_adv_2005001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們今天要在哪裡睡覺才好啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n沒有幫我們，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "準備旅館之類的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～……",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "人類跟獸人是還好處理，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但還有很多動物嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實在沒辦法馬上幫各位準備好住宿的地方。",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天就希望各位在野外紮營過夜了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "帳篷之類的必要物資跟食物等等，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們會盡量幫忙準備的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那樣實在是太好啦～",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我已經快累到不行了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好想趕快躲到被窩裡休息。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，妳是【王宮騎士團】的……",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n小智，對嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "明明還是個孩子，居然工作到這麼晚，真了不起♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為這是我份內的工作。",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個，有件事想冒昧請教，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳的年紀有比我大嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總覺得，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "被當成小孩子來看待有點怪怪的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯啊，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我可是二十歲了～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話說回來，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在是好孩子的就寢時間了呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那孩子，也是一臉睡意……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們已經沒事了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你們也趕快回去休息吧♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "…………",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒關係，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我還不睏啦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳可以去睡沒關係哦，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不用，",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為我也是【王宮騎士團】的一員。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼可以讓前輩一個人工作，",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "自己跑去休息呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我也要加油。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那孩子，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是【王宮騎士團】的人嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然有聽說你們人手不足，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但連這麼小的孩子都被派了出來，感覺好像怪怪的啦～？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這孩子該說是見習生嗎……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n其實，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是我被迫要好好照顧她的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "原本是想讓她待在據點裡的，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但還是跟來了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔～",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我不喜歡被拋下的感覺！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n英雄的守則第7條，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n『集合眾人的力量，對抗巨大的邪惡』！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯。",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我聽說【王宮騎士團】，\n和獸人的關係似乎不太好的樣子。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這孩子，該不會也是獸人……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不能說出來！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n正義的夥伴有很多祕密，就是這麼回事的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳們知道有個叫{player}的人嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為陛下親自下令召見他。",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可以的話，希望立刻請他",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n前往王宮參見陛下。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}？\n要找他的話，因為有個名叫貪吃佩可的孩子還沒回來……",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n他很擔心，就到山裡去找人了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我們有跟他說，\n那樣很危險，大家應該一起行動。",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_046"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過無論有沒有找到貪吃佩可，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_047"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我們都約好了之後要再會合。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要稍等一下，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "應該就會自己現身了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_048"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳說的陛下，指的是蘭德索爾的國王陛下嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那麼偉大的人，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n找{player}到底有什麼事啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不知道……",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我只在執行我的任務。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我個人也有些問題想問{player}，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可以的話，實在很希望能當面跟他說幾句話呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 100511,
        "voice": "vo_adv_2005001_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看來茉莉已經輸給睡意，睡著了呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我先把這孩子送回家裡去。",
        "unit_id": 103711,
        "voice": "vo_adv_2005001_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果那個叫{player}的人回來的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n希望妳們能幫我留住他。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "知道囉！",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳也是，這麼晚了，走在路上要小心一點唷。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～……",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_054"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然想說",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "事情已告一個段落了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但總覺得還是有點可疑啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有種討厭的感覺，",
        "unit_id": 103311,
        "voice": "vo_adv_2005001_055"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "無論何時和平都是最重要的說。",
        "unit_id": 103311
    }
]