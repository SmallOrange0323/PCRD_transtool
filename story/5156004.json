[
    {
        "type": "background",
        "background": "502390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "車輛終於完成，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了襲擊蘭德索爾"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天的早上。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "天就快亮了。",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n動作快！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真討厭～",
        "unit_id": 130212,
        "voice": "vo_adv_5156004_001"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n雜碎哥哥真是的～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "也太雜碎了吧～♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "雖然我早就知道了♡",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "值得關注的財寶能裝就盡量裝，",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n結果變成這麼多的量……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "拿走這麼多，沒問題嗎？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "還問「沒問題嗎？」",
        "unit_id": 130212,
        "voice": "vo_adv_5156004_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "說什麼啊！",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "妳也裝太多了！",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n又不是市場特價",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "讓妳一袋蔬菜裝到滿……",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "的說！",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊哇哇！",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n別坐在袋子上呀～！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "別吵，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n會吵醒那些傢伙！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們要借的，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是那台車。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n快把財寶放上去！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機、若菜",
        "words": "……好～",
        "unit_id": 1,
        "voice": "vo_adv_5156004_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……可是",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "真的嗎？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n格羅哥團的團員竟然",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "各自都有弱點。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "準沒錯。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "宴會那天晚上，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我在瘋狂喬的房間看到的團員名單上",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n寫著所有人的弱點。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "說到頭來，這些住在吉歐‧格黑納，被稱為「妖魔人」的傢伙，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n以生物來說特長似乎很刁鑽……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "有點難懂的事先不提。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可是，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可以「利用」的事實是──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "瘋狂喬這傢伙雖然拳頭大頭腦也好，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但腳程卻極慢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那隻三流青蛙的眼睛",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "則非常怕光。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "其他團員們也是，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就算有腕力或體力，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n也是耳朵不好",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "或重度近視，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "總之有各式各樣的狀況。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "正因如此，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "他們才會一人分配一台車，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n希望能透過仔細客製化的戰鬥車",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n完善補強各自的弱點。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……這樣一說，喬先生",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_015"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在提到新型車輛的話題時，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n首先就說想加快速度……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對他來說，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n提升機動力是必備條件吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對那些傢伙而言，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "車子不僅是武器，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n更是隱瞞弱點的障眼法。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "意思是，",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_018"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "只要針對弱點……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……不。",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_019"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n畢竟有100人呢，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "一個一個應付的話，情況只會越來越糟。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "倒不如──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真正該下手的，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_020"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n他們的致命傷是",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "會「陶醉在借用來的力量上」這一點。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "他們沒有靠肉身戰鬥的能耐。",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "偏偏又陶醉在",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "補強自己弱點的車輛性能之中。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "如果重要關頭車子不見，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "他們應該就沒辦法作戰了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "原、",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_022"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "原來如此！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這樣的話，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就算不交戰，應該也可行……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "給我",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_023"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "聽好了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "首先我們要跟他們一起",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "從這裡出發去襲擊蘭德索爾。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "然後一看到通往蘭德索爾的門，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_024"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n就用布武機的裝置",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "讓他們的引擎熄火。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "同時一口氣加速唯一還能動的我們的車，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_025"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "載著財寶，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "直衝進門。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "然後，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_026"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "一口氣成功脫逃到蘭德索爾……！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "成功……",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_027"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "脫逃……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是啊，",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_028"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "成功脫逃！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這次一定──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "會是【蠻賊三姊妹】的勝利計畫。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳們",
        "unit_id": 130012,
        "voice": "vo_adv_5156004_029"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再怎樣也不准搞砸囉！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "喵哈好～♡",
        "unit_id": 130212,
        "voice": "vo_adv_5156004_030"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……好、",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_031"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好的！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "…………",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_032"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如果拿到財寶……",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_033"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不管是找住的地方，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "或是從事修繕……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "剩下的錢應該足以和姊姊她們",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_034"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n快樂",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "安穩地生活……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "才對。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就不用每天再吃節儉咖哩……",
        "unit_id": 130112,
        "voice": "vo_adv_5156004_035"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
