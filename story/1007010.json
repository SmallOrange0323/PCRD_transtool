        "type": "dialogue",
        "name": "宮子",
        "words": "人家不要……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎麼覺得抗拒的心情……",
        "unit_id": 100711,
        "voice": "vo_adv_1007010_034"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "比以前強烈太多太多了。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n原本宮子認為什麼時候成佛都無所謂的說……",
