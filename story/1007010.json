        "type": "dialogue",
        "name": "宮子",
        "words": "接下來只要等那傢伙獻上供品就好！",
        "unit_id": 100711,
        "voice": "vo_adv_1007010_028"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n然後等拿到供品之後，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "再和那傢伙一起吃～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真是完美的計畫喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯哼♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……咦？",
        "unit_id": 100711,
        "voice": "vo_adv_1007010_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n先等一下喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "和那傢伙一起？",
