    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}尋找著宮子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n宮子偷偷地跟在他的身後。"
