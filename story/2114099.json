        "voice": "vo_adv_2114099_062"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也會慢慢地，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "花時間……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "告訴你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也想要",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_063"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "知道更多更多，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "關於騎士先生的事情。",
