[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是乎──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}，\n在一望無際、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美麗絢爛的花田裡醒了過來。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……♪",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "早安。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不是的。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這個",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並不是夢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "夢，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經結束了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我而言──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所謂的惡夢是無盡反覆的",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "旁觀之時。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這裡，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是阿斯特朗。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──目前，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "馬上就要關閉了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後這裡，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就會變成我和騎士先生的……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "理想鄉。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你很睏嗎……？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你至今為止經歷了許多戰鬥，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "肯定很累了呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒問題的。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n好好睡吧。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "當你再次醒來的時候……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "世界的扭曲就已經消失了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那樣的話，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在那之後，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我們，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就能永遠在一起了喔。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "世界重置這種事，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會再發生了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "編織的回憶，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會變成永恆。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "成為只屬於我們兩個人的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "永恆。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……的確，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的是……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "非常悲傷的事。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可能只覺得是敵人而已。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你放心。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並不是敵人。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "比任何人，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n都還要……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "更加地，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "愛著你……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這是，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的喔？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我所積累的思念程度，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和其他的人大不相同。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我用了比起任何人都還要長的時間，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直不斷地想著你的事。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我跟其他人不一樣。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我的思念，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會被重置。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我啊。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在看著騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "看到騎士先生",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "受傷、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "倒下。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n看到你因為建立起的羈絆被破壞……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而痛苦的樣子。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我其實，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是很想幫你的。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但我能夠介入的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "總是只有在你已經不存在的世界。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……而且……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果跟米奈娃同化後的我，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是掌管世界運作的人，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那麼騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是因為我的關係，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連受了傷害這件事，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都無法察覺……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再而三地……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你放心。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那樣悲傷的命運，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "結束了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經不會再受傷了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n已經再也，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會痛苦了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就算你不知道我的事，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也會慢慢地，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "花時間……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "告訴你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也想要",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "知道更多更多，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "關於騎士先生的事情。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為我在此之前，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都只能遠遠地觀望著你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "今後，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我可以更加深入地……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與你接觸。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連同身上的每一根汗毛，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "甚至是肉體和靈魂資訊的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "每一個位元組……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "來，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "拜託你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和我",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一起──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "將理想鄉給，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "關閉起來吧？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎麼會……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為什麼……？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這樣啊……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是這樣的人嘛……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_032"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不管你想去哪，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都無法離開這裡喔。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "直到你點頭答應為止，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不管幾次",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我都會問你。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不論多少次，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我都會告訴你我的心意。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒錯，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就連這些對話，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我而言，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是非常甜美的──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有某種",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "干涉……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……七冠……？",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不只是七冠。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "難道說……！",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生──！！",
        "unit_id": 100211,
        "voice": "vo_adv_2114099_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "！",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "美空她，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n遵守了和我的約定，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n把騎士先生和我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "送到了這裡。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我真的，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_041"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "很感謝美空。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n要不是她用盡一切方法，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我們兩個，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一定無法抵達這個結局。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這裡，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_042"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是阿斯特朗。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──目前，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_043"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "馬上就要關閉了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後這裡，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就會變成我和騎士先生的……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "理想鄉。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_044"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你很睏嗎……？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你至今為止經歷了許多戰鬥，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "肯定很累了呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒問題的。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_045"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n好好睡吧。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "當你再次醒來的時候……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "世界的扭曲就已經消失了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那樣的話，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_046"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在那之後，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我們，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就能永遠在一起了喔。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "世界重置這種事，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_047"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會再發生了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "編織的回憶，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會變成永恆。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "成為只屬於我們兩個人的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "永恆。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……的確，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_048"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是呢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的是……",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_049"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "非常悲傷的事。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可能只覺得是敵人而已。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你放心。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_050"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並不是敵人。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_051"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "比任何人，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_052"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n都還要……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "更加地，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "愛著你……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這是，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_053"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "真的喔？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我所積累的思念程度，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_054"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和其他的人大不相同。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我用了比起任何人都還要長的時間，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直不斷地想著你的事。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_055"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我跟其他人不一樣。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我的思念，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不會被重置。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我啊。",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_056"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一直，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在看著騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "看到騎士先生",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "受傷、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "倒下。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n看到你因為建立起的羈絆被破壞……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而痛苦的樣子。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我其實，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_057"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是很想幫你的。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但我能夠介入的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "總是只有在你已經不存在的世界。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……而且……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果跟米奈娃同化後的我，",
        "unit_id": 129013,
        "voice": "vo_adv_2114099_058"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是掌管世界運作的人，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那麼騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是因為我的關係，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連受了傷害這件事，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都無法察覺……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再而三地……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
