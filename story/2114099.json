    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "連同身上的每一根汗毛，",
