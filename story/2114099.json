        "voice": "vo_adv_2114099_060"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你放心。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那樣悲傷的命運，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "結束了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
