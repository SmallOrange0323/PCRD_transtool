        "voice": "vo_adv_2114099_061"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經不會再受傷了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n已經再也，",
