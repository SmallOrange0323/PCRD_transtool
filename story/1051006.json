[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天{player}也陪伴深月進行了實驗。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……今天就到此為止吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "辛苦了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，你看起來真的挺累的呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過我想實驗的魔法多得像山一樣呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還得讓你加把勁。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……話說回來，你不用魔法嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "和流夏不同，你是有魔力的吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要不要學學看？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就當是陪我到精疲力盡的謝禮，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會手把手地教你哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼就開始吧！",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "上過深月老師的特別課程，從今天開始你是魔法師唷！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要從哪個魔法開始呢……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "發火魔法挺好的呢，因為總能派上用場。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "首先得記住要詠唱的咒文。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「熊熊的火焰唷，從我手中現身吧」……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "記住了嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "然後是要控制好自己的魔力。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "做不到的話就無法靠詠唱轉換魔力哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一開始說不定會有點困難，不過你先試試看吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，控制好呼吸的節奏……讓意識竄流全身每一處……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你要找到力量集中的地方唷……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就在這附近……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……怎麼了？ 這裏唷，肚臍的附近。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再往下面一點的地方出力……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不行唷。你要專心啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很癢嗎？ 忍耐一下。你的肚子，摸起來還挺舒服呢……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然很軟，卻又有男孩子應有的身材……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，你要集中精神……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n要通過我的魔力",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓你的魔力覺醒過來哦……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……呵呵，似乎感覺到了呢。這就是魔力唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一旦感覺到就再也忘記不了，對吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……那就繼續下一個步驟吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "終於要詠唱了呢。我會在你耳邊小聲唸出來，你就跟著唸吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "熊熊的火焰唷，從我手中現身吧……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……怎麼了？ 你呼吸的節奏很亂哦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再一次集中精神……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道你的耳朵很敏感？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "發現了你的弱點♪ 呼……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，說笑而已。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來詠唱咒文吧……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓魔力從你的下腹部通往身體的中心，再流到指尖上去……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很健康的心臟……隔了層衣服卻也能感覺到你跳動的心臟……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n跳得有點快呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過這樣可就無法專心詠唱了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼試著和我分享感覺吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就像我剛才做的一樣，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你也感受一下我跳動的心臟吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，把手放上來。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就這樣……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……怎樣，感覺到了嗎？再大力點摸下去也沒關係唷？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n好好感受著我……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，那是你的心跳？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n還是我的呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "別害羞，專心感受那份感覺就好。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，難道是太緊張了嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這種程度就……你真可愛耶。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過沒關係。這是情緒高漲起來的證據唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這個感覺會提升魔法的成功率……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對，就是這樣……",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……就是現在。再詠唱一次咒文……！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……什麼也沒發生呢。看來是失敗了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過我覺得快要成功了，要繼續下去嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀真可惜。不過算了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你讓我玩……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我學了一課。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我正好也有了魔法的新靈感。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n接下來要研究兩個人合作齊發的魔法哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只要和你在一起，我的想像力就好像比平時還要活躍。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你真擅長激發我的能力呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "至於你的魔法呢……下次就從別的角度來試試看吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051006_032"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，又是實驗呢。真令人期待♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然深月笑得像個孩子似的，\n但{player}並沒有看漏潛藏於笑容中的妖豔。"
    }
]