    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "明天見！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n明天中午的",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "鐘聲響起時，我們在",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "廣場前的樹下碰面可以吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我很期待喔！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "問題，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對吧……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "這樣啊。",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_066"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "那我們今天就差不多喝到這邊吧。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "優花梨？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "喂～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "優花梨～？",
        "unit_id": 1211
    },
    {
        "type": "background",
        "background": "500038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出了餐廳獨自返家的優花梨，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在酒醒後想起了剛才發生的一切。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……多虧了他總算是沒有被揭穿。",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_067"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這麼突然的邀約，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真對不起他啊……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我都說了那種話，",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_068"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "依他的性格，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n明天真的會到碰面地點等我吧……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "到了那時，我得準備賠禮",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_069"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "向他賠罪。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和他單獨、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "過聖誕……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_070"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聖誕節，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有行程了……？",
