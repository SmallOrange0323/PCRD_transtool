    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話雖如此，就只有我一個人無所事事也太淒涼了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "反正她那天要跟男友約會，也不會和我見面……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "稍微裝模作樣一下應該",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒關係吧……？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也和妳一樣喔！",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_017"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "啊哈哈，",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_018"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "也是，要不然妳也不會聖誕前夕",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n一個人窩在這喝酒了嘛～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是說啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈哈……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一豁出去就裝過頭了……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我這個笨蛋笨蛋笨蛋！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "所以啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_021"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "優花梨的男友是什麼樣的人啊？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n我好好奇喔～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嘛……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說到我很熟的男生……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也就只有他了吧……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他的年紀",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "比我小……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "哦～～",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_025"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "有點意外耶。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "這樣啊，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "原來優花梨喜歡年紀小一點的類型啊～～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_026"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "該不會是因為沒有理想型，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "所以乾脆自己養成一個吧？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不是那樣啦。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然他也是有讓人放心不下的地方……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但他遇到陷入困境的人，會和對方一起煩惱、阻止對方犯錯……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也會繼續在對方身邊提供幫助，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還很有責任感……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "像我上次喝過頭的失敗之類的……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "該怎麼說，",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他雖然有時很神秘，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但為人既率直又老實，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "和他待在一起很讓人安心……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "聽起來不太像年紀小的男生呢。",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_031"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "我有點感興趣了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "那麼，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "他平時都在做什麼？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_032"
    },
    {
