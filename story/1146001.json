        "voice": "vo_adv_1146001_010"
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "我男友",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "要到聖誕節當天才有空～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "當然，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "那天的行程是一整天膩在一起♪",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喔～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她有男友啊……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "酒友",
        "words": "那優花梨呢？",
        "unit_id": 1211,
        "voice": "vo_adv_1146001_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我呢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒有特別的事……",
        "unit_id": 103411,
        "voice": "vo_adv_1146001_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，應該說根本沒有行程……",
