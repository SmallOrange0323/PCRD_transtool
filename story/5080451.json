        "voice": "vo_adv_5080451_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好險事情結果還算圓滿呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好吃的點心當然會被認可！",
        "unit_id": 119311,
        "voice": "vo_adv_5080451_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "宮子也很努力呀！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為了布丁努力是理所當然的喲！",
        "unit_id": 119911,
        "voice": "vo_adv_5080451_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不過，",
        "unit_id": 119911,
        "voice": "vo_adv_5080451_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "當婆婆露出笑容時，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子會感受到和吃布丁時",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "相同的心情……",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……這樣啊。",
        "unit_id": 119211,
        "voice": "vo_adv_5080451_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就好好",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "珍惜那份心情吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "難道說",
        "unit_id": 119911,
        "voice": "vo_adv_5080451_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "婆婆也和布丁一樣好吃！？",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "宮子……",
        "unit_id": 119311,
        "voice": "vo_adv_5080451_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n氣氛都被糟蹋了唷……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈哈，",
        "unit_id": 119211,
        "voice": "vo_adv_5080451_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真有宮子的風格。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可不能真的把婆婆吃掉喔？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家知道啦！",
        "unit_id": 119911,
        "voice": "vo_adv_5080451_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子才不會把給人家布丁的人吃掉呢！",
        "unit_id": 119911
    }
]