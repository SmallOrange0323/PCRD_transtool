[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自長高特訓以來數個月後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n終於來到大賽受理報名當日……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}幫莫妮卡量了最後一次的身高。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼樣……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔嗚嗚……！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果量100次都一樣，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就不是一場夢也不是自己多心了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我這次終於能參加大賽了……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一路走到這裡",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是崎嶇坎坷啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不過",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "多虧有閣下的支持",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱歉，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我真是急性子！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我實在太高興了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一不小心就……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我真正的目的，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是在決鬥大賽中奪得冠軍。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然知道可以參賽，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就得馬上前往賽場才行……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是不介意啦……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天只是申請參賽，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還沒有要進行比賽喔？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……你想看我",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "報名成功的那個瞬間？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下人真的很善良呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你就盡情地看到最後吧。",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "要參加大賽的人",
        "unit_id": 1,
        "voice": "vo_adv_1053010_006"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "請到這邊排隊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n我們將依照順序受理報名！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊啊，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼不快點輪到我呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n期待測量身高到這種程度，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是我有生以來第一次啊♪",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過話說回來，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "參賽者人數真多啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "更確切來說，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好像都和我一樣",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身邊帶著同伴……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_009"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "麻煩下一位！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哎呀，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "輪到我出場了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給我盡量測量吧！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "……雖然差距僅小，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_011"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "但確實",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "滿足了參賽條件。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n我們受理妳的報名。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你聽見了嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剩下的目標只要取勝就──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "那麼接下來……",
        "unit_id": 1,
        "voice": "vo_adv_1053010_013"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "莫妮卡小姐的組隊搭檔，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n是要登記旁邊這位先生嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有同樣疑問，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到底是什麼意思啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是決鬥大賽對吧！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不是一對一",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "的正式對決嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "其實參賽規則有重新修正，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_015"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n今年起更改為兩人一組共鬥",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "的「武鬥大賽」了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "規則修訂的公告，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_016"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n有透過公佈欄、傳單發送，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "以及通訊魔法來傳達給大眾……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "本大賽畢竟是例行賽事，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_017"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n新規則也才剛發表不久……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n所以也有很多人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "是在這裡才聽到說明，初次知道詳情的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是、",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是這樣子啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為我們有段時間每天都在森林裡特訓……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是我的失誤。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不過，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼要改規則……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "本大賽過去",
        "unit_id": 1,
        "voice": "vo_adv_1053010_019"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "是一直交由貴族議會在營運的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n但現在決定要全權委託給公會管理協會負責。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "營運權轉交時，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_020"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "規則也一同更改了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n獨自一人勝出的力量雖然也很重要，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n但是現在",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "普遍需要的，是與他人相互配合的能力……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "事情就是這樣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是、",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是嗎……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然規則是如此，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那我也會遵守。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "搭檔啊……",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果是{player}，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是能夠把背後託付給他。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但就算如此，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也不能夠讓他再繼續遷就我的任性了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "若沒有決定好的對象，",
        "unit_id": 1,
        "voice": "vo_adv_1053010_023"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "請到裡面的空地處去看一看吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n我想會有許多在找組隊搭檔的人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我知道了！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感謝妳",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "提供情報。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……閣下，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很抱歉，你在這邊等我吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等事情結束後我們一起吃個飯吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可不是小孩喔……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別擔心，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我很快決定完就回來。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下你這個人……",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_026"
    },
    {
        "type": "dialogue",
