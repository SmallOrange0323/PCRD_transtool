        "unit_id": 711,
        "voice": "vo_adv_1053010_061"
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "看來妳有點底子啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "\n皮球小朋友，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "把手從劍上拿開，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "妳要是拔劍可不只是受傷能解決的啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我才不會在這裡拔劍。",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們要",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在這場大賽裡做了斷！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "就我看來，",
        "unit_id": 712,
        "voice": "vo_adv_1053010_063"
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "妳連搭檔都沒有的樣子？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "\n說到底，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "憑妳一個人是要怎麼出席大賽？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣、",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_064"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你不用出面……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這是我自己的問題……！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "什麼啊？",
        "unit_id": 711,
        "voice": "vo_adv_1053010_065"
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "這次是根瘦竹竿跑出來了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "\n我今天早上吃的帶骨肉，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "反而還有更多肌肉……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "戰士1",
        "words": "\n他似乎比剛才的男人還弱呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂！你！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別用外表來評判別人！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你要是敢羞辱這個人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可不會善罷甘休！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給我聽仔細了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們會奪得冠軍！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把你們通通打倒！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "那麼，",
        "unit_id": 712,
        "voice": "vo_adv_1053010_068"
    },
    {
        "type": "dialogue",
        "name": "戰士2",
        "words": "我就不抱期待地等你們來吧。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我說了……！！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n結果，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "竟然把{player}給捲了進來……！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_070"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "笑得那麼開心……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你說能成為莫妮卡的搭檔",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很高興……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_071"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "其實我也……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n…………",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "老、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "老實說其實我也",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很高興喔！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我從一開始就一直",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想著如果和閣下搭檔就好了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……可是",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_072"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下人很善良，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果我開口邀請，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你就不會拒絕我對吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因此",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我就不由得……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對邀約一事猶豫不決了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_073"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "{player}，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n對我說了「能成為莫妮卡的搭檔很高興」。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……對這個沒被任何人選擇的我，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說了這句話。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "託你的福，我下定了決心！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就如同你為了我參與作戰一樣，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我發誓直到最後我也不會放棄，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會全力以赴去戰鬥！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好！",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_075"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這份信賴，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我確確實實地收到了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "首先去報名大賽吧，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n然後……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "直到正式比賽前的幾天，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都要猛烈特訓。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "最應該要戒備的對手",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_076"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是那對兄弟，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n對方",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "能夠輕而易舉使出一擊",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "破壞掉牆壁，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不曉得他們動真格攻擊過來時，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們能否防禦得了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_077"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我打算學習新的招數。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那是祖國流傳至今的奧義。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很抱歉，",
        "unit_id": 105311,
        "voice": "vo_adv_1053010_078"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我還想聽聽閣下給予的意見，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你願意",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "陪我練習嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}欣然答應莫妮卡的請求。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們以冠軍為目標，展開新的特訓。"
    }
]