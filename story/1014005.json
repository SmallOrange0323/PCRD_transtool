[
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔～嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n搜查進度",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒如預期一般地順利呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在懷疑「闇影」的出現地點",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n持續埋伏監視，來來回回",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也過了三天……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "至目前為止，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "仍沒有半點收穫。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這還真是連「闇影」的影子也沒瞧見。",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這算哪門子的比喻……？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "究竟是我的推理哪裡出了差錯，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還是單純",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就只是倒楣了點，才導致無法按著計劃來走呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "埋伏監視就到今天為止吧……",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n若還是沒有任何成果，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼就應該要修正一下思考方向了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不能像這樣，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直浪費時間呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然能和助手一起，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "閒話家常、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比手畫腳，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "吃吃紅豆麵包打發時間……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n像這樣子的埋伏監視，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實挺有趣的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但現實中，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n仍然有人對「闇影」感到畏懼。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才會有人委託我這種工作。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若繼續散漫下去，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直解決不了事件的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "問題就大了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是個",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "名偵探。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n得依著委託人的期望，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "去徹底解決問題。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n想說在預測「闇影」出現的地方",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "閃過了個人影……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼嘛～",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來是助手先生呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是幹勁十足呢，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n已經來到現場了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」主要",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被目擊的時間都在晚上，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以從晚上才開始埋伏監視……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不是這麼說過了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一整天",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都得讓你陪著也過意不去。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然我在旁邊借了間空屋，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直都待在這埋伏監視就是了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也只有在你有來的夜裡，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "交接了監視工作後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才有時間小憩一下……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可能是睡眠時間不太充足的關係，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "到現在都還有一些迷糊呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣子的生活，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n若長時間持續下去，身體鐵定會被搞壞呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天就當作監視工作的最後一天……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那是……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n難不成，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是「闇影」嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "終於現身了嗎！",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n太好了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然我的推理是正確的呢！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要如作戰計畫，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "把那傢伙給抓起來唷！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你去吸引住那「闇影」的注意，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你曾經有過",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被「闇影」給盯上的經驗……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "假設「闇影」是把你當成目標的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那應該就是個很好的誘餌。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在你吸引住它時，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我在趁機用專用的魔法道具，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來捕獲「闇影」！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有在聽的話就應個聲，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還是說有什麼問題嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣才對嘛，助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要來把事件給解決囉！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼還傻～在那邊呀？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖說現況來看「闇影」不具有多大的危險性，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但也有襲擊人的案例啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若掉以輕心的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會受傷的唷！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯！",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你先暫時來這邊等著……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來。",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼搞的，你怎麼還那樣待在「闇影」的旁邊呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不是很危險嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然似乎有著「闇影」並不存在著自我意識",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣的說法……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以就算被發現我們在這埋伏監視，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也應該不會出太大的亂子才是。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你說，因為「闇影」和我長得太像了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n一開始還誤以為是我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以就搭上了話……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的確",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個「闇影」，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n看起來就像是我的雙胞胎呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就好像在照鏡子一樣，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還真是不禁令人覺得不太舒服呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都在預料之中。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」不知道為什麼，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總是會和真實存在的人物",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有著一樣的樣貌。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n碰巧遇到長的和我一樣的「闇影」……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n只是這樣而已吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也許和我們這幾天以來，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直都待在這附近埋伏監視著，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有什麼關係也說不定？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說不定那東西有著會複製周遭人物樣貌",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n的特性也說不定呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先別想這麼多了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當前最重要的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一定要成功捕獲那個「闇影」呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要上囉，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n希望能用上你那不可思議的力量",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來強化我！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可是頭腦派的呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "和其他【哞哞自衛隊】的大家比較起來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種粗活我可不太擅長啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯嗯！",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很好，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺力量全都湧出來了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝你，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來吧！「闇影」！",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n趕緊乖乖束手就擒吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_045"
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「對不起。」",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……！？",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「對對對、",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_048"
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "對不起」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "\n「對不起」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "\n「對不起、",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "對不起」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為、",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼要道歉？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不等等，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」確實，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有著會不斷重複毫無意義用語的特性？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別在意，",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "趕緊捕獲它！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這應該",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才是正確的！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「除了我之外，",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_051"
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "還有其他的偵探呢。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "\n",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「難道忘掉了嗎？",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "偵探的鐵則。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "閉、",
        "unit_id": 101411,
        "voice": "vo_adv_1014005_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "閉嘴！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n別用和我一樣的聲音說話！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得令人感到不安！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「對不起」",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_053"
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "\n",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「真是丟人呢。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "\n「請你忘了吧，",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "學長。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "「那就是，",
        "unit_id": 101421,
        "voice": "vo_adv_1014005_054"
    },
    {
        "type": "dialogue",
        "name": "闇影",
        "words": "我理想中的樣貌。」",
        "unit_id": 101421
    }
]