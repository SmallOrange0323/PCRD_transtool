[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以攻略索爾之塔為目標進行冒險的【破曉之星】，\n她們三人，被捲入了一連串不可思議的現象之中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於索爾之塔的上層中，\n接觸到被包覆在結晶之中那謎之少女・愛梅斯的瞬間，\n不知道為什麼就僅僅只有怜和日和，被帶到了奇妙的夢境之中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在夢境中與愛梅斯的對話，雖然只在記憶中剩下朦朧的印象，\n然而怜和日和依舊留下了不可思議的感慨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，唯有她一個人沒有進到夢境，被留下來的優衣，\n則是拚了命試著想辦法讓自己的伙伴們甦醒過來。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜～！",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n日和！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哇？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "奇怪？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡是……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是太好了，怜！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我可是一直叫著妳們還一直搖晃，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "甚至試了各種魔法但妳們都沒有反應，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓我很擔心呀～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然不知道怎麼了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在如此危險的冒險之中竟然敵不過睡魔，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這真是要不得的失態。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯～……",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n意識還有些混淆，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒辦法釐清現況。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "且記不得來龍去脈了。",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "奇、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "奇怪？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為什麼我們",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會在蘭德索爾呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不清楚呢……",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就只有想著要再努力讓大家趕快醒過來而已。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後接著就",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "突然被不可思議的光芒壟罩，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等我回過神以後，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就已經在蘭德索爾的馬路上了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "又想著如果放著不管的話，",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說不定會被馬車什麼的撞到，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以又努力地",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "將妳們從路中央移過來椅子上坐了唷。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真累死我了……",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是太好了呀～",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳終於醒過來了啊。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n真的很抱歉，優衣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓妳操心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯～！　",
        "unit_id": 100111,
        "voice": "vo_adv_2011001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呀啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "睡得真舒服！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "精神百倍呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和也醒過來了？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "終於能鬆口氣了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳們倆，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像一直在咕噥著些什麼，讓我很擔心唷？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "耶嘿嘿～",
        "unit_id": 100111,
        "voice": "vo_adv_2011001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然不知是怎麼回事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但沒事沒事的，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "人家可是元氣充沛的唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚呀！？　",
        "unit_id": 100111,
        "voice": "vo_adv_2011001_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嚇死人了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才那是？　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "爆炸……！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又話說，",
        "unit_id": 100111,
        "voice": "vo_adv_2011001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這裡好像很熱鬧的感覺？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從今天開始的幾天",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n蘭德索爾好像有要舉辦一場祭典來著？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哼哼。",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果能和大家一起逛攤販就好了呢，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢竟是難得的祭典嘛！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 100111,
        "voice": "vo_adv_2011001_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為什麼我們會在蘭德索爾啊？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又踩到轉移的魔法陣了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這份疑問的解釋暫且先留到之後吧。",
        "unit_id": 100311,
        "voice": "vo_adv_2011001_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起此事……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大家還是先繃緊點神經，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n似乎正發生著緊急的事態。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來吧，正義的伙伴、",
        "unit_id": 106113,
        "voice": "vo_adv_2011001_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "主角，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們又愛又恨的敵人！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我們來找回那段幸福的時光吧，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "即便只是一瞬間就會消失的夢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦咦？　",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼會變成這樣……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那孩子究竟",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在說些什麼呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是……",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不知道為什麼，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "心中感到了不安。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "全都是我的錯？　",
        "unit_id": 100211,
        "voice": "vo_adv_2011001_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從頭到尾都是？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這話到底是什麼意思……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她說我的願望，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那又是什麼？",
        "unit_id": 100211
    }
]