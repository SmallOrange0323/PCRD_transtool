[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔……",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這就是所謂的海啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這還是在下第一次看到呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下的故鄉在深山裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那一帶不過就只有小小的泉水池罷了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下雖然擁有相關的文獻知識。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但實際親眼目睹還是第一次呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下十分感動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您看看，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n陽光反射在海面上，就像寶石般閃閃發光。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊主人，有螃蟹。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小小的螃蟹們並排著走，會不會是親子螃蟹呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "螃蟹真的是橫著走呢……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唉唷。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一不小心興奮過頭了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們不是專程來海邊玩的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本連到海邊的計畫都沒有的說。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "髒衣服也累積了不少，所以在下正在尋找乾淨的水源。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然也有專門洗衣服的公會，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但委託費用有點貴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "生活上的瑣事還是想自己來做。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己做就可以省錢了。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下對做家事很在行喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了伺候主人，在下在故鄉做了不少修練。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的衣服如果被其他人碰過的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會有一點抗拒感。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的任何一切，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都想親自準備和管理 ……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之……在下把找水源一事跟附近的大嬸說了之後，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她就把這裡介紹給在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她甚至還在地圖上標註此地，算是幫了大忙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過看來是在下表達得不夠清楚，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被她誤會我們是想找地方玩水。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明明就不是在兒童水池裡",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n玩水的小孩。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海邊沒辦法洗衣服呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真困擾，我們該怎麼辦？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說什麼？",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……海水是鹹的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，在下用手掌撈了一些海水。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您要嘗嘗看嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n瞧您一臉驚訝呢，在下也來嘗一口……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔，不但有鹽的鹹味還有苦味，充滿獨特的風味呢",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必海水也含有不少雜菌呢，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是在這裡洗衣服，搞不好反而會弄髒衣服。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使用洗衣精的話，還會汙染環境。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且這裡離蘭德索爾有點遠，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每次洗衣服時都得跑到這裡來，那也太麻煩了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很可惜的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要在這個地方洗衣服，看來是不太可能了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉，主人……還勞煩您專程跟在下一起來，",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n結果讓您白跑一趟。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帶過來的髒衣服，就這樣帶回去吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在非常抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下願意負起責任，請您懲罰在下吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……？",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是懲罰嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下心甘情願接受了，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是突然用海水潑人，還是饒了在下吧。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海水都跑進眼、眼睛了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為是鹽水，在下的眼睛好痛啊。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚～眼睛都要變紅了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n本來就是紅的？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……還真的是這樣呢，呵呵呵♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀……哇，欸？",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼要摸在下的頭呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣與其說是懲罰，不如說是獎勵呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也是第一次看到海，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說因為太感動了，想要表達那份心情嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說比起懲罰，更想獎勵在下嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒想到您不但沒有追究在下的失職，還獎勵在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人真的是很溫柔的人呢♪",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "105900201"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n機會難得，我們到海邊走走吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "髒衣服就跟籃子一起放在岩石上面就可以了吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，一起來吧……",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們手牽手吧，海邊很難行走的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大海真是不可思議呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n海浪也總是滔滔不絕的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊哈哈。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n腳趾間進了沙，好癢啊♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下所穿的鞋子很像涼鞋，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海邊行走的時候，腳趾可以完全感受到海水和細沙。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也把鞋子脫掉比較好喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n襪子也已經弄濕了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種有趣的感受，在下也想讓主人體驗看看……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊主人，海鷗在我們的正上方飛舞喔。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們像貓咪一樣喵喵叫呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n浪潮聲也夾雜其中，所有的聲響都像是充滿情趣的音樂呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，主人……真是不可思議。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和主人在一起的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n無論多麼微不足道的事情也都顯得閃亮耀眼呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果主人也能有同樣的感受……",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那真是在下的無上光榮。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是在深山被撫養長大，沒見過世面。",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也跟失去記憶的主人一樣，對這個世界一無所知。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以讓我們兩人一起一點一點地認識這個世界吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩人一起四處邊看邊聽、邊聞邊嘗，親身感受……",
        "unit_id": 105913,
        "voice": "vo_adv_1059002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果能像這樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一直一直伴隨在主人身旁，在下就覺得很幸福了。",
        "unit_id": 105913
    }
]