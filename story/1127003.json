[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "盜賊團被摧毀之後，鈴的名聲也開始在一般市民之間廣為流傳，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被稱作「橡子遊俠‧鈴」的她，非常受人歡迎。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嚼嚼，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "工作前的紅豆麵包真是太美味了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再來一份，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "經紀人。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼～",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經到了？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是沒辦法，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就去稍微露個臉吧。",
        "unit_id": 112711
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼就有請她上台吧。",
        "unit_id": 1,
        "voice": "vo_adv_1127003_002"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "遊戲新作發表會的\n特別來賓，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "橡子遊俠‧鈴小姐～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來了來了，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家好～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我才剛來，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我可以回去了嗎？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "啊哈哈哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_1127003_004"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "鈴小姐妳太突然了！",
        "unit_id": 1,
        "voice": "vo_adv_1127003_005"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n大家～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "為了讓鈴小姐有精神努力，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n請把橡子丟向舞台～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "小鈴～！",
        "unit_id": 211,
        "voice": "vo_adv_1127003_006"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "加油～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有好多點心喔，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是太感謝了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就再努力一下下吧～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "活動結束後我可以收下這款遊戲嗎？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "啊哈哈哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_1127003_008"
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "橡子遊俠‧鈴小姐的握手會會場在這邊～！",
        "unit_id": 1,
        "voice": "vo_adv_1127003_009"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n請按照整理券上的號碼順序排隊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "小鈴，",
        "unit_id": 211,
        "voice": "vo_adv_1127003_010"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "我會一直為妳加油打氣的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "要加油喔！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝妳。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我不太想加油呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "我、",
        "unit_id": 311,
        "voice": "vo_adv_1127003_012"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "我是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "小鈴妳的",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "大粉絲……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "那個可以的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "請妳叫一下我的名字！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦～",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好麻煩，不要。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "唔喔～！",
        "unit_id": 311,
        "voice": "vo_adv_1127003_014"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "這冷淡的態度，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "真讓人受不了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "謝謝妳！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "累了累了。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，之後的預定行程是什麼？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好麻煩喔～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "畢竟我很強，這也是沒辦法的事嘛。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過真沒想到我",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "居然會這麼努力地工作呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還被大家叫作什麼橡子遊俠，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "被捧得高高在上的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n人生真是難以預料啊。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "完全不會唷？",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是啊，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我只要稍微努力一下，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就可以大把大把地賺到錢喔。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算隨便應對，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "周遭的人也會自己炒熱氣氛、感到高興，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "即使是困難的工作，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也只要讓你來幫忙就能解決。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "勞動還真是簡單啊！",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這也是多虧了我這麼強啦。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真希望能就這樣",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "繼續度過簡單模式的人生啊。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也會",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "分一些好處給你的，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就拜託你囉～",
        "unit_id": 112711
    },
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哼哼～",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "順利順利超順利～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天也來悠哉地",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大賺一筆吧～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看看，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎麼樣的委託──",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喔～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "擊退魔物是吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果是平常的話我只會覺得麻煩，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但今天我的心情莫名地好。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這點程度的魔物沒問題的，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也得好好展現一下我強大的一面嘛。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，那我要出發囉～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明平常我說不要你也會叫我去的說，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這次是怎樣啊。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說危險？",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個討伐對象也沒什麼大不了的吧？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "振作一點啦經紀人。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是不知道你為什麼不想讓我去啦，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果是現在的我明明沒問題的說。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了沒關係，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反正我也沒有一定要去。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那我就去處理這邊這份比較輕鬆的工作囉。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不需要跟著我一起來啦，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這也不是那麼困難的工作。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我出發了～",
        "unit_id": 112711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼，",
        "unit_id": 112711,
        "voice": "vo_adv_1127003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比想像中還要早結束。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
