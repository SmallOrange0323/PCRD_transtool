        "voice": "vo_adv_2013004_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只有我的友人啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是呀。",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n自然是知悉此事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以才會如此稱呼妳的？",
