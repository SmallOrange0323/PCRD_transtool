    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……？",
        "unit_id": 107111,
        "voice": "vo_adv_2013004_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總而言之，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
