    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2013004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她仍舊沒有恢復意識，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也因此使人相當的擔憂呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是魔力的暴走已經停了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她只是睡著了的樣子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這方面似乎能讓人安心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的看起來就只是睡著的感覺呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且嘴邊還流著口水……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可愛呀♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧～♪　",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真不愧是{player}耶，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和我的喜好一致呢……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你先像這樣繼續抱好她唷，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我來負責幫她擦掉口水，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我擦我擦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不管什麼事都還沒有解決……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但太好了呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之小凱留沒事了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可真是毫無緊張感呢，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳們幾位。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不久前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "霸瞳皇帝",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是才自己將『王宮』給毀壞，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n打算將我們一行人給活埋了的呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若我沒及時變身成黑箱，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n並且收容各位，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大家可是都要當場投胎去囉。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且變身可是要耗費大量的體力……",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是連動指尖的力氣都沒了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且啊，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "直到不久前我都還被禁錮在那洗腦的魔法裝置之中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不間斷地被霸瞳皇帝吸取生命力呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n儘管我是『七冠』的一人，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也近乎是處於瀕死的狀態了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吸取生命力",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "霸瞳皇帝在前些日子，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "包括使用了大量破壞魔法在內，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因眾多因素為緣由而",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陷入了昏睡的狀態……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了復活",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和甦醒，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且恐怕還有其他目的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才奪取別人生命力的樣子。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個洗腦魔法裝置，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正如其名",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是對『王宮』內之黨羽進行洗腦，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "進而將之化為能便於使用的棋子所用的裝置……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而這個裝置，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n同時也具有著能夠從他人身上吸取生命力的功能。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而被直接連接上裝置，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n全身都被搾取著生命力的我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也差一些就一命嗚呼了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "光是像這樣說幾句話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都很痛苦呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦……",
        "unit_id": 105812,
        "voice": "vo_adv_2013004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但妳看起來還挺有生氣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且很有精神地講著話就是了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是不太會表現疲勞感的人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或者說是工作性質上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "必須得壓抑情感而經過了日積月累的訓練呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……哼哼。",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "乍看下來看起來蠢蠢的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但意外地挺敏銳的嘛。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n竟然察覺到了我還留有一些餘力的這件事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但殺手鐧可是得要留一手的唷，",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "『公主殿下』。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我在真軌的體內，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n瞞著他本人偷偷地儲存了我的魔力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以在",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能夠和真軌再會時，才會那麼開心呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n當然，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我可沒有什麼其他會開心的理由呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我是說真的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呃，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我到底是在向誰解釋啊？　",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總之。",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不管此戰是真那……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "霸瞳皇帝取得了勝利，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n又或是他敗下了陣來。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我只要再打敗因為那場戰鬥而有所消耗的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "『勝者』，就是我贏了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵呵。",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了取得最終的勝利，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n現在就先演得像是孱弱的模樣",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "來減少消耗吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我",
        "unit_id": 107011,
        "voice": "vo_adv_2013004_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可還沒有打算要從這場遊戲中退出呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不管是正是邪，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳們就好好地替我派上一點用場吧。",
        "unit_id": 107011
    }
]