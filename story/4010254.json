        "name": "布武機",
        "words": "\n是想～把我綁起來",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "才",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "選的嗎～？",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "討厭～",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "雜碎哥哥",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "的私心也太明顯了吧♡",
