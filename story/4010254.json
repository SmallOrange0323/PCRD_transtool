    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "當然，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "是雜碎哥哥請客♪",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "欸～",
        "unit_id": 130231,
        "voice": "vo_adv_4010254_002"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "可以吧～？",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n畢竟是我一年一度的生日嘛♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "你甚至應該感謝我",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "讓你幫我慶祝才對～♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "……咦？",
        "unit_id": 130231,
        "voice": "vo_adv_4010254_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不不不，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "這完全是兩回事吧。",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n冰淇淋跟飲料只能算是入場費啦！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不算數啦！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不算數！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不算數！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
