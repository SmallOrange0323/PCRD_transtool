    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n這三球冰淇淋",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "有草莓、香草和巧克力，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "還有雜碎哥哥錢包的味道～♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "接下來想喝飲料耶～？",
