[
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖說是冒牌貨，",
        "unit_id": 111511,
        "voice": "vo_adv_5029322_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但還真是給我大鬧了一番啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一想到馴鹿們是這樣看待我的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我克莉絲提娜還真有點心痛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔喔！",
        "unit_id": 111711,
        "voice": "vo_adv_5029322_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　克莉絲提娜在反省耶！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個克莉絲提娜！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　竟然在反省自己耶！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了……",
        "unit_id": 111611,
        "voice": "vo_adv_5029322_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿牠們的感受\n也傳達給製作人了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……我是什麼妖魔鬼怪嗎？",
        "unit_id": 111511,
        "voice": "vo_adv_5029322_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先不管這個了，",
        "unit_id": 111511,
        "voice": "vo_adv_5029322_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "馴鹿們似乎還打算繼續打的樣子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就讓牠們來療癒我受傷的內心吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身可不覺得這是什麼療癒。",
        "unit_id": 111711,
        "voice": "vo_adv_5029322_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那隻馴鹿，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠的力量好像又更加強大了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盡可能不要被正面擊中比較好。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒問題！",
        "unit_id": 111611,
        "voice": "vo_adv_5029322_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要我們大家同心協力，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不論是怎樣的攻擊都不成問題！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿先生！",
        "unit_id": 111611,
        "voice": "vo_adv_5029322_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們是不會輸的！",
        "unit_id": 111611
    }
]