        "voice": "vo_adv_1124002_026"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "夢想能夠實現嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我可不這麼認為喔。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦……？",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_027"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "活到現在，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_028"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "經常能夠看到像那樣高談著夢想的孩子呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n但是到最後，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "夢想破滅導致心上破了個大洞的人卻占了大多數。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "像我也是啊，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_029"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "年輕時也曾有過憧憬的夢想，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "只是一直以來都無法如願以償，就到了這年紀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那跟卯月的目標也沒有任何關係——",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "有關係。",
        "unit_id": 611,
        "voice": "vo_adv_1124002_031"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "所謂夢想",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "只有那些特別的人能夠實現。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "對像小妹妹這樣",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "普通的女孩子來說，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是無法觸及的星星啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "因為身為普通人",
        "unit_id": 611,
        "voice": "vo_adv_1124002_032"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "而難以得償所願的例子",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "多到數不清。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "明知如此，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "為什麼卻還是想要去嘗試呢？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……的確，",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_033"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "老太太說的",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "都是不爭的事實。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我能不能夠成為偶像，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我也完全不清楚。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我想，",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_034"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "途中一定也會跌跌撞撞的吧。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可是，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "一想到可能成為改變自己的契機，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我就想去試試看。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "和遠大的夢想相比，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_035"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n妳的心態似乎很輕鬆呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "說不定，",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_036"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "實現夢想並不是我的目標吧。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我只是想要找到自己真正",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "想做的某件事。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我認為以偶像為目標，",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_037"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "只是我跨出的一步。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "畢竟我",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "現在還不知道",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "想要成為怎樣的自己呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是，",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_038"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "只要和小凜和未央一起的話，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n就一定能找到想追尋的目標……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "的……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦、",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_039"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦……？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "突然……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "想睡…………",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "藥效終於發作了呢。",
        "unit_id": 611,
        "voice": "vo_adv_1124002_040"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "明明有可能遇到像我這樣的盜賊，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真是不小心呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……不過，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_041"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "該怎麼辦呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "突然沒有心情工作了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明是盜賊卻不偷東西嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "噫呀啊啊啊！！？",
        "unit_id": 611,
        "voice": "vo_adv_1124002_043"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們！　",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "為什麼還醒著！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她是說絕對不要吃來路不明的人給的東西，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我忘記了所以很自然地喝下去了呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "安眠藥沒有作用嗎？",
        "unit_id": 611,
        "voice": "vo_adv_1124002_045"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "到底怎麼回事……！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉呀，",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有用也是無可奈何的呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老太太妳什麼都不做嗎？　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明是盜賊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……不過是心血來潮罷了。",
        "unit_id": 611,
        "voice": "vo_adv_1124002_047"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n和那位姑娘聊過以後，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我想起",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "以前的事情。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我也曾經像她那樣，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "積極誠實地生活著。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "自從放棄夢想後，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_048"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "誤入歧途做盡了壞事……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "總感覺現在的我，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真是很不像樣啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在開始把夢想中的自己當作目標不就好了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "坐而言不如起而行，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哈，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_050"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "對我這種老太婆來說，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可能已經為時已晚了喔？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……真是的，",
        "unit_id": 611,
        "voice": "vo_adv_1124002_051"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "居然被這麼年輕的孩子們鼓勵了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "幫我跟",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這女孩說",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "有人來接我，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "所以",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我先離開了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可不能再打什麼壞主意囉？",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多多保重喔～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺解決了一件事呢☆",
        "unit_id": 105812,
        "voice": "vo_adv_1124002_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼安眠藥對我沒有起作用呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是因為吃了一大堆飯的關係嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "呼啊……",
        "unit_id": 112411,
        "voice": "vo_adv_1124002_054"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "睡著了嗎？",
        "unit_id": 112411
    },
