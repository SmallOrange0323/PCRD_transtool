[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 112011,
        "voice": "vo_adv_5031323_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是個讓人傷腦筋的神明呢～！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到底要鬧到怎樣才肯罷休啊！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚……",
        "unit_id": 112111,
        "voice": "vo_adv_5031323_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "山神大人，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一直不願平靜下來呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就表示",
        "unit_id": 111911,
        "voice": "vo_adv_5031323_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "競速賽讓祂興奮到",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法平復呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不能這樣放著祂不管……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n接下來應該會是一場必須傾盡全力的最終決戰。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管是對方還是我們",
        "unit_id": 112011,
        "voice": "vo_adv_5031323_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都差不多到極限了呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然這樣，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就來作個了斷吧！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 111811,
        "voice": "vo_adv_5031323_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是最後一戰了！！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家就盡全力上吧！！",
        "unit_id": 111811
