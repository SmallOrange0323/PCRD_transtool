        "type": "dialogue",
        "name": "車夫",
        "words": "搬上車吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等等！",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_073"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們現在就把事情弄清楚吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_074"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你究竟在做些什麼？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然我知道你有在做送貨的打工，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但卻突然就不來找我了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_075"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你可是我的助手，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n至少可以告訴我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你在做什麼事吧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_076"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "嗯，",
        "unit_id": 311,
        "voice": "vo_adv_1157001_077"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "我準備好了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n那麼就出發吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_078"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生……！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "祕密……",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_079"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "居然說是祕密？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "面對我這位名偵探，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_080"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n竟然敢堂堂正正地說出祕密這兩個字……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_081"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好吧，助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我就把你這句話",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當成是對我的挑戰了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就由我名偵探霞，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_082"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來揭穿助手先生",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想要隱藏的真相吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞燃起了身為偵探的探求心。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她抱著這份熱情，開始追查{player}。"
    }
]