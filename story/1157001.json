[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞除了是【哞哞自衛隊】的一員，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n同時也從事著偵探的工作，因此每天都很忙碌。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好了好了，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "給我住手。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不可以在這種地方吵架喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "怎樣啦，",
        "unit_id": 1011,
        "voice": "vo_adv_1157001_001"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是這個傢伙先來找碴的！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "什麼？",
        "unit_id": 1111,
        "voice": "vo_adv_1157001_002"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n明明就是你先瞪我吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是放著不管，感覺立刻就要打起來了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "身為【哞哞自衛隊】的一員，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可不能坐視不管。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，我同時也是一名偵探，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種時候比較想要睿智地解決事件。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，助手先生。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種時候",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要怎麼做才對呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "打聽情報可是基礎中的基礎。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n看來助手先生也開始理解個中道理了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在波及到四周之前，先拘束起來也是一種手段。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果是真琴應該就會立刻抓住他們，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一邊說「吵架兩敗俱傷！」，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一邊各給他們一拳吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，這次我就用更簡單的方法，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來解開兩人之間的糾葛吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先是你。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "怎麼了？",
        "unit_id": 1011,
        "voice": "vo_adv_1157001_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當我說話的時候，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你也是瞇著眼睛，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像在瞪我一般……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以我的觀察，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你的視力應該很差吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "嗯，",
        "unit_id": 1011,
        "voice": "vo_adv_1157001_011"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "的確……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是這樣沒錯……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再來輪到你。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看樣子你的心情很不好……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n嗯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雜亂的頭髮",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "加上紅腫的雙眼……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你剛剛應該是剛哭過吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大概是被女朋友甩了是嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "嗚！",
        "unit_id": 1111,
        "voice": "vo_adv_1157001_013"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n妳、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "妳怎麼會知道……！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要好好觀察就能知道囉。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n畢竟，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可是一名偵探。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "這就是……",
        "unit_id": 1,
        "voice": "vo_adv_1157001_015"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "偵探……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來兩位都已經冷靜下來了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n由於我們還在巡邏，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就先走一步了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼樣，助手先生。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n只要看清楚並解開命運的糾葛，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就能辦到這種事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很睿智對吧？",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──助手先生！",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n牠往那邊去了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請你先繞過去！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵！？",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很好，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生做得漂亮！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "毛色跟花紋",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都符合特徵。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你應該就是委託人在找的貓咪沒錯了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵嗚～♪",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵♪",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也不能小看找貓咪的工作呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "鎖定搜索目標的行動範圍，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並跟附近的居民打聽目擊情報，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "最後要確實地逮捕目標，不讓對方逃走。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是在考驗偵探的基本功呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生也辛苦了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝你，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "幫了我一個大忙。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來的工作是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生，有什麼事嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就讓我來推理看看吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從你看著我的眼神來判斷……",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你是在",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "擔心我吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你在擔心我會不會太累嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這點的話",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "完全沒有問題。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然最近工作的確很多，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n像是【哞哞自衛隊】的巡邏，以及偵探的委託……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但這些都是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我自己喜歡才做的事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算忙了點也沒問題。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為我不是一個人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n除了有【哞哞自衛隊】的大家，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "更重要的是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我還有一位非常值得信賴，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n能夠補足我缺點的助手呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就拜託你囉。",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──我會更努力的。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從他說完這句話已經過了幾天。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生都沒有來～～",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "自從說了要更努力後，就再也沒出現了。",
        "unit_id": 101411,
        "voice": "vo_adv_1157001_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這究竟是怎麼一回事啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟",
