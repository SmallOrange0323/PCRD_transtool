[
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔……",
        "unit_id": 124811,
        "voice": "vo_adv_5110204_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不喜歡這地方……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感覺很不舒服……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是說啊……",
        "unit_id": 124911,
        "voice": "vo_adv_5110204_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n啊啊，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個魔物",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就在這裡，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且有好幾隻。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來這裡應該就是",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "它們的巢穴了。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不僅如此，",
        "unit_id": 125014,
        "voice": "vo_adv_5110204_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "它們看起來比先前對戰過的傢伙們還強呢！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不會被嚇傻了吧？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不要小看",
        "unit_id": 124811,
        "voice": "vo_adv_5110204_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像的膽量哦。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我不知道那個魔物是什麼，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但我絕不會放任不管的。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都來到這裡了，誰還會怕啊。",
        "unit_id": 124911,
        "voice": "vo_adv_5110204_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都還沒好好地大打一架呢！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要打就來打吧！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很好，",
        "unit_id": 125014,
        "voice": "vo_adv_5110204_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這樣！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那麼，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "進入第二回合囉！",
        "unit_id": 125014
    }
]