        "type": "dialogue",
        "name": "莉莉",
        "words": "代表我們確實花了這些時間來將鎮上整理乾淨呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦？",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_060"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您說不合期待，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是什麼意思呢……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "噢，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_061"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人真是的……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "絕對沒有",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那回事。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "所謂冒險者，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_062"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是一個守護無辜百姓生活的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n了不起職業，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我是這麼認為的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "並且，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_063"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "今天兄長大人所進行的活動……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "此維護鎮上美觀的行為，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也對居住在此地的人們",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "內心安寧做出了貢獻。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "證據就是，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_064"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n今天",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們在鎮上所看到的每位市民，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n都是些心地誠樸善良的人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "總歸來說……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_065"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n託兄長大人的福，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "今天鎮上又得以維持和平。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我是如此",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "認為的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_066"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n別說誇張，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這甚至還未能充分表達您的功勞。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "…………",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_067"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……兄長大人。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_068"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n或許這樣有些失禮，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但還請恕我直言……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人才是，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_069"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您是否有些",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n過於看輕自身價值了呢……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_070"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是拯救世界無數次的英雄。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "至今為止，兄長大人阻止了好幾次邪惡野心被實現，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也拯救了無以數計",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "的人。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "再加上，您甚至還不會四處吹噓自身事蹟，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_071"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可謂有著謙恭的修養。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因此我會對您懷抱敬意，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "實為天經地義……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "更何況……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_072"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我以前也曾",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_073"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "被兄長大人給拯救過。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "若不是有兄長大人在……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_074"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我恐怕就會繼續傷害更多人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "累積更多的罪過吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "當然，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_075"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對兄長大人而言，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我大概也不過是",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您所拯救過的多數對象其中一人，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您會沒有印象也是理所當然的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "即使如此……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_076"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我已在心中決定，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要以自己的一輩子來償還",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n您的這份大恩大德。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_077"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那個，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "怎麼說……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……是的。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_078"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我的決心便是如此堅定……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n還請您",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "理解成這個意思……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "～～唔，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_079"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我這個笨蛋，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "竟順著氣勢就說出那種不莊重的發言……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真的很抱歉，兄長大人，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_080"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n今天還請容我",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就此失陪……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新加入成為夥伴的【幻變少女】公會的莉莉。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}今後會有一段時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n要教導她學習冒險者須知事項了。"
    }
]