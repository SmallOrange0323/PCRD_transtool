[
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在「背面世界」的冒險仍繼續著，但某一天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人為了處理貪吃佩可的政務等事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n暫時回到蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不好意思……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "能夠",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "耽誤您一點時間嗎……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗯、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "嗯……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n其實……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "十分抱歉。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n像這樣鄭重地",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "向您搭話……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n會讓我不禁有些緊張……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "儘管當初我跟著",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "璃亞和普蕾西亞一起",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n決定",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "稱呼您為「兄長大人」，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但其實",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我對此",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "仍感到十分難為情……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦！？",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是指",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "練習稱呼您嗎？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……我明白了。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n以我的立場而言，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這也是求之不得的可貴機會。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那麼，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "失禮了──",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "唔……",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n呼……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "謝、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "謝謝您。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n多虧您的幫助，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我似乎多少有些習慣此稱呼了……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我想您應該也已經知道，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要論身為一名冒險者，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我還相當不純熟。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "儘管非我本意，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_013"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但在背面世界的冒險中，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我的確是成了各位的拖油瓶。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "相對地，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人是位",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n千錘百鍊、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "英勇不屈的冒險者。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因此，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "如果您不介意，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我想藉此機會……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請教您一些冒險者須知的應對表現，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_015"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不知是否可以呢？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我自己也十分明白，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "提出此種要求相當厚顏無恥……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常感謝您……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這份大恩大德，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我一定會償還的……！",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……璃亞曾給過一些建議，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n教導我如何順利讓兄長大人答應幫忙。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但未料事情會發展得如此順利……！　",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人……！",
        "unit_id": 125812
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這就是冒險者管理協會所掌管的",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "冒險委託公告欄……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我之前不曾利用過這服務，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n上面貼了許多委託，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真令人目不暇給呢。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "到了兄長大人這般水準，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_020"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "應該無須特地去尋找，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n也有接不完的委託吧。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但若要",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "從這之中選一個的話……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「逮捕大盜賊團」、",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_021"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「搜尋逃進下水道的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "巨大魔獸」、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「徹底攻略海底遺跡」、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「封印企圖征服世界的",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "吸血鬼女王」……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "候補大概就是這幾項吧？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……！",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_022"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真、",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真的很抱歉。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是我疏忽了……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這點程度的委託，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_023"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "若是兄長大人獨自處理，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n肯定輕輕鬆鬆便能解決……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但畢竟今日要加上我，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n屆時我恐怕就會在旁礙手礙腳，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還希望",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人多多包涵。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "哎呀。",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_024"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "您竟然如此謙虛，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是才高行厚呀。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……不，",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_025"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n不僅是如此，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這應該是考量到我，不想讓我感到太有壓力……？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "兄長大人",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是個溫柔的人……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還麻煩您",
        "unit_id": 125812,
        "voice": "vo_adv_1258001_026"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "用不著太顧慮我，請選吧。",
        "unit_id": 125812
    },
    {
