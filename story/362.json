[
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您覺得怎麼樣呢？",
        "unit_id": 190811,
        "voice": "vo_adv_0000362_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果能為各位帶來一些幫助的話就太好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n接下來，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也請繼續帶來大量的討伐證。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "隨著推進活動冒險而出現的魔物，",
        "unit_id": 190811,
        "voice": "vo_adv_0000362_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n既凶暴又難纏，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "想必討伐起來一定很辛苦吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是，",
        "unit_id": 190811,
        "voice": "vo_adv_0000362_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "若能夠漂亮地取得勝利的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就可以獲得大量的討伐證！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n試著推進冒險，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "並向魔物發起挑戰吧！",
        "unit_id": 190811
    }
]