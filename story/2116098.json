[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "世界的終結，對多數人來說是突如其來的。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們既不能理解究竟發生了什麼事，也無法掌握當下情況。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──除了幾個人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n擁有罕見力量的創造者──"
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "終究，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只是場飄渺的夢──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就像被戳破",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而輕易消失的泡沫……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是虛幻。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦咦？",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還真是稀奇呢～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真那居然會講這種傷感的話。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "晶，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別故意刺激我。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "因為計畫失敗而感到不悅，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這點妳也一樣。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而且，我啊。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n只是因為",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "至今耗費心思整治的城鎮毀於一旦，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n想發發牢騷而已。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……啊哈哈。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "等這次的資料重組與再構築──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「再再構築」結束之後，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所誕生的世界說不定會更方便喔？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為真那投注過心力的資料，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n應該會確實累積進伺服器的記錄裡呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哼。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那種事，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不確定因素太多了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我可和妳不同，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒那麼樂觀。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……也是。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "況且，也不知道「另一邊」的伺服器狀況如何……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "聯合國那些既得利益者，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也不全都是笨蛋。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n他們一旦察覺這狀況，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一定會馬上有所行動。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "更重要的是，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_010"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "之前保持沉默的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「幻境龍后」，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n似乎也開始有動作了……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……唉，真是的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "頭好痛。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的確是。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要是沒有尾狗刀的努力，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就真的束手無策了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……以為她沒來到這個世界，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "結果我們對她就太過鬆懈了呢……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且……",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n居然在我",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有米奈娃都沒察覺的情況下，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n竄改了安全裝置程式。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也就是說，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "幻境龍后在上次",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「再構築」之前，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就已經動過手腳……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只能這麼推斷了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "她的目的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "果然是想得到米奈娃……？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不好說～",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為「她」的價值觀和道德觀等方面",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都很獨特嘛。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要說這點很有七冠風範也是可以啦。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論如何，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "現在米奈娃下落不明……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就這樣返回「現實」，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n感覺會遇到比整頓城鎮基礎建設還大的麻煩。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "唉，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真的是──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是讓我來處理，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要能駕馭米奈娃。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n第一天我就能攻破主要國家的伺服器防護。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "第二天，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就能掌控全世界通訊網路，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "第三天就能控制所有虛擬貨幣了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣創造完新世界，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n神能在第七天好好休息嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是讓我來，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要五天就夠了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "神也得跟上時代吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n創世也要",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "週休二日才行。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有力氣開這種玩笑，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n看來就算兩手空空回到「現實」",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也沒問題呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果我留在那邊的信徒，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n有好好保護我的身體那就沒問題。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要是落入國際刑警手裡，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那可就糟透了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這倒是。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不然好不容易才從這裡逃獄，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在另外一邊又得吃牢飯了呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳不也一樣，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n要擔心到另一邊",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "得進牢房嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然我想妳之前回到現實之後，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "應該有採取一些對策──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難說～",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那時候太趕了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也不能說是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做足了萬全準備。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的身體是不是平安無事……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "得看",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「長老」而定。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「嚮導老君」",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗎。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然他的能力無庸置疑……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但他太死板，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也太厭世了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不知道靠不靠得住。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你還是一樣不喜歡長老呢～",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他的確有點太溺愛小孩了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真那你",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也挺寵親戚的小孩呢～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我討厭的",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不只長老……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還有他徒弟。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不僅不敬畏我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還敢跟我套近乎。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果不是妳，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我早就讓這種人身首分離了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──哦，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就算現在動手，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "似乎也不算遲……？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉呦～",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在這種不穩定的空間打架，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只會兩敗俱傷而已呦～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就不要跟我耍這種無聊的嘴皮子。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是的……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在世界「再再構築」之前，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我本來想試著垂死掙扎，看能不能介入些什麼──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n結果得到的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只有和妳聊這些",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒營養話題的時間啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "遊戲不是常會有",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "開發者座談會之類的嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n之前我們偶爾也會接受採訪的……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過現在，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該沒什麼玩家看了會開心吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "的確。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n在另一邊，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我們應該",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被當成罪大惡極的重罪犯了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那些庸俗的市井小民有什麼反應，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對我來說根本無所謂。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但對我而言，能不能讓人開心，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n算是一件重要的事喔。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……我真的是一直在做些",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓自己覺得後悔的事呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "剛才那句話原封不動地還給妳──",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還真是稀奇呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "晶。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳居然",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "會講這種傷感的話。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會嗎？",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我一直都是這樣啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只是沒表現給你看而已。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……被你將了一軍，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "面臨「再構築」這種事件，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓少年他們吃盡了苦頭。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像現在這個狀況也──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算四處發送可麗餅，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為角色進行追加更新，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看來光靠妳和幾個夥伴，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "人手還是不夠呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "舉例來說，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "像是控制食材流通，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n或是利用追加更新，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "強制召集為妳所用的軍隊之類的。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要妳認真起來，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "分明有其他更有效率的方法……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拘泥於手段，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "最終也只是徒增懊悔而已。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "和那些庸俗之人走太近，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳也會淪為平庸之輩喔？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你這麼看得起我，我也很為難耶。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像真那你那種君主制，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我實在學不來啦。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且那種方式，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會有無法拯救到的事物……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若以醫生的角度來看。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……？",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "～唉。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n戰鬥結束之後，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是還能有一點時間，只要一點點就好……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就可以和璃乃她們一起",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "把可麗餅發完。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後拜託貪吃佩可、",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_045"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可可蘿、",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "怜和真步，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有其他人……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將遭到認知修正所扭曲的真相，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n告訴世界上的大家了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……我無法理解。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n既然要將律令周知萬民，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那不是更應該",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "運用如君王般的強大權力嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那樣子，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家情感上沒辦法接受啦～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "單方面地發號施令，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "終究是會招致反彈的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真那你",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也不想被這樣對待吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這我是同意。",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但妳前面說的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「情感上沒辦法接受」……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哦，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "原來如此。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這樣對妳而言，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "確實是會埋下未來的火種呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不不不。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你別一副事不關己的樣子啊～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們是共同開發者耶。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_051"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳真的有時間──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要導正認知修正對眾人的影響，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "應該也會是一件苦差事。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "畢竟那是由我們數人聯手建造，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "完成度不容小覷的世界。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……是啊。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n除了我們七冠，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有聯合國、",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "WISDOM、",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "贊助商",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟外部合作者……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "阿斯特朗傳奇的開發過程，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有各種人參與，他們不同的想法也交織其中。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不否認其中有些意圖並不良善。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我個人還是希望，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n玩家們都能玩得開心，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "希望他們",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會喜歡這個虛假的世界。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然發生了「禁錮」，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n沒辦法說有提供給玩家當初理想中的遊玩舞台。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "俗話說",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "久居則安嘛。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都對這個世界有了感情。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n最後還願意對我們說",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「不想回去」。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n能聽見這句話，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的是開發者最大的福分了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──我希望，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "遊戲能成為",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拯救心靈的良藥。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然隨著醫學進步，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大部分的傷或疾病都能治癒了，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但要撫平心靈的傷痛，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "比醫治任何外傷都還要困難。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以……",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我期望我們製作的遊戲，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能成為那帖良藥。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果是為了製作這樣的遊戲，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果是為了這個目的……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不管過程有多艱辛，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我都會持續摸索找出解決之路。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……原來，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_060"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳背後還藏著這樣的目標啊？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那妳應該",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "早點告訴我的。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈。",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n才不要呢，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種幼稚的願望，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n感覺聽了",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你會笑我的吧？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如果妳是認真的，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_062"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不會笑妳。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "依我對妳的評價，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不會認為妳在痴人說夢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而我──",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_063"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的願望是……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將世界",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_064"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "映入我的眼瞳。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我想在遙不可及之處，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "眺望世間萬物的運行。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將世間森羅萬象，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_065"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所有的一切，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n全部納入我的知識，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將我自身化為一切的法則。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒錯──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我要成為永恆不朽，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_066"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n如同神明，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n猶如母星般的存在。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而阿斯特朗傳奇，",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_067"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是成就這個願望的第一步。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我絕不能在這種地方",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "停下腳步──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論前方",
        "unit_id": 106914,
        "voice": "vo_adv_2116098_068"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "有何種阻礙等著，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我都會將其蹂躪，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將之粉碎，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "宣揚我的霸道──",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就算是充滿苦難的千里道途，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也無法阻止我。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們所製作的阿斯特朗傳奇，",
        "unit_id": 106815,
        "voice": "vo_adv_2116098_069"
    },
    {
        "type": "dialogue",
