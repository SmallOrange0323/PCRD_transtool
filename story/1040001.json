[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一天，為了躲開強大的魔物，\n{player}在精靈之森中迷路了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在他徬徨地找尋出口時，\n不知從何處聽到少女的說話聲。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵，今天玩什麼好呢……",
        "unit_id": 1,
        "voice": "vo_adv_1040001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這個嘛……大家平常都在玩些什麼呢……",
        "unit_id": 1,
        "voice": "vo_adv_1040001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我是真的想不到……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只收集沙朗牛排的肥油之類的遊戲嗎……？",
        "unit_id": 1,
        "voice": "vo_adv_1040001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，反正明天也要一起玩耍喔！",
        "unit_id": 1,
        "voice": "vo_adv_1040001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦……？你、你是活的……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是人類嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？啊，那個嘛，我在自言自語。",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我剛才是在跟……這、這個練習用的鐵皮人偶說話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n它叫「有我在喔好朋友1號」。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呃、",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，我不是和人偶聊天的怪人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我只是一時慌張，那個嘛，我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我不是奇怪的人，奇、奇……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎著白馬的天才棋士――――！！！",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_008"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後{player}追了幾十公尺，\n終於追到了少女。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼、呼……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈……呼……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不、不！我才不是奇怪的人……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我只不過是在跟人偶說話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以其實我們都不是奇怪的人……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對、",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對不起……我剛才太過慌張了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來你叫作{player}啊……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我叫碧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是住在這個森林的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "精靈族。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？只是因為不知道出口在哪裡，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以想問我而已嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、原來是這樣啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對不起，我還跑掉了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道這個森林的出口在哪裡，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我幫你帶路吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我果然是太厚臉皮了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吧……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們又不是朋友，還說要和你一起去什麼的，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真是厚臉皮的厚片女孩……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然我住在這個森林裡，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n可以跟動物和植物交流……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我連一個人類的朋友也沒有……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一直、一直、一直都想要",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有個朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "產生這種想法之後，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我好幾年都對著自己做的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔好朋友1號」說話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是話題很快就用完了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿……因為交到朋友呢，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是一件很了不起的事啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "像我這樣的人，肯定要再花個十年的時間。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但總有一天……總有一天我想要脫離邊緣人的生活！",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這就是我微小的夢想……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，已經看得到出口了……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要跟你道別有種依依不捨的感覺呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好了，這裡就是出口了。辛苦了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，請你保重……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "希望你在未來十年內能想起我一次……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咦？怎……怎麼了嗎？",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好主意……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、那是什麼意思……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "喔……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你失去記憶了啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然你也沒有很多朋友……",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但因為你經常都會到人多的街上走動，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以問我要不要一起研究交朋友的方法……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸欸欸――――！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這是真的嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你真的願意陪我做這種",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n有如精靈族榮譽獎",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一樣棒的事情嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了和你一起認識新朋友，",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而組成新的團隊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇――――！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太棒了――――！",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "BB團！BB團！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "BB團！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個！我之後每天都會在這個森林裡",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n等你來找我！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你有空再來就可以了……拜託！",
        "unit_id": 104011,
        "voice": "vo_adv_1040001_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "BB團的未來活動！就請你多多指教了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇！哇！超幸福的――――！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然這只是隨口說出的提議，但因為碧比想像中要來得開心，\n所以使{player}感到有點困惑……"
    }
]