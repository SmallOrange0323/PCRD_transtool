[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "貪吃佩可小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是她的氣質吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你總是只看到她充滿活力的樣子，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以可能不知道吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我指的是她有時候",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會展露出身為王族的風範呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是……",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我時常會在街上的餐廳看到她，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她吃東西的樣子",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很那個呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以我個人來說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是建議她吃東西時能夠更細嚼慢嚥。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果吃太多也會有礙美容，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這就是我給她的建議♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可可蘿",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她說話總是彬彬有禮，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非常美麗呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她很懂",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所謂的美，並非只是表現在外表上而已。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得她很有前途喔♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個嘛，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要我給她可以變得更美的建議……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她總是會",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "低調地待在他人的身旁對吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她只要主動站出來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "多展現自己的魅力就可以了吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "凱留小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是那犀利的吐槽呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們的公會長偶爾會說",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「吐槽的人不夠」，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以我有在考慮要不要挖角她看看……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊～不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她說話的用字遣辭上",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有一點問題呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她經常掛在嘴邊的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「我宰了你喔！」，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這句話",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不太美麗啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "改成像是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「我會宰掉你唷♪」",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣更加美麗的說法吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雪菲小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這根本不用說吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那對優雅的羽翼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "與壯碩的尾巴。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以及襯托",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那些部分的冰之結晶。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全都是我沒有的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可說是她獨特的美……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_5120062_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她還不懂得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "該如何展現自己美的魅力。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然有這麼高超的操冰技術，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我認為她應該",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "先在城鎮中打造出",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n許多自己的冰像。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "至少",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "換做是我就會這樣做。",
        "unit_id": 126311
    }
]