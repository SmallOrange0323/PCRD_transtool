    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人找我有什麼事嗎。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您、",
        "unit_id": 102711,
        "voice": "vo_adv_1027500_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您記得我的生日？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的確",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "以前",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有和您說過……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您連那種小事都記下來了嗎。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "謝謝您。",
        "unit_id": 102711,
        "voice": "vo_adv_1027500_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我真的很開心。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "光是這一句話",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然能讓人感覺如此溫暖……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然{player}大人是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我命中註定之人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼",
        "unit_id": 102711,
        "voice": "vo_adv_1027500_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一副沒自信的樣子？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人說哪天是我的生日",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那天就是我的生日！",
