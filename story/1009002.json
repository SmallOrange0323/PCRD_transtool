[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "修特帕魯展露出無所畏懼的笑容，\n一副沒勁兒地打算離開街道。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵呵……哈哈哈……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到我的錢包竟然會變得空空如也……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "舊書啊，真的是太可怕了……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這樣一來今天的晚餐也沒著落了。",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "即使是我，要是不吃飯的話也活不下去……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "之前獲得的獎金也全都花光了……",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……沒辦法了。只好再抓通緝犯了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，在餓著肚子的情況下，",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n一個人去抓通緝犯也太危險了……有沒有別的辦法……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔喔！我還以為是誰呢，這不是吉格魯特嗎！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你出現得正好！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "其實我缺錢……",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我打算現在去抓通緝犯，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你願意幫我個忙嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道你也缺錢嗎？",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵……看來我們命中注定是同路人呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n歡喜吧吉格魯特。 我們的靈魂在現世中也是相連的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "決定了的話，我們現在就立刻去抓通緝犯吧！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n奏響出發的號角吧！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，你要好好跟著我啊？",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "根據他人提供的情報，在這前方就是通緝犯的藏身之處。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這次的作戰就是……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "正　面　出　擊 ！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼了？",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你覺得我修特帕魯，會使用一些卑鄙的手段嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要上了喔吉格魯特！前進吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "給我出來，通緝犯！我知道你在這裡！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如果你不乖乖出來的話，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就用被封印在我右手的最強魔法來殲滅你！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "怎樣了怎樣了？是來賺取獎金的嗎？",
        "unit_id": 811,
        "voice": "vo_adv_1009002_014"
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "記得她叫修特帕魯，不對，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "\n是蘭德索爾的「行走龍捲風」啊！ 這傢伙真有趣！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "哈，那傢伙要跟我們幹架嗎？",
        "unit_id": 911,
        "voice": "vo_adv_1009002_015"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "我就當妳的對手吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你還有同夥嗎……",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但那種程度的同夥不成問題。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不管來多少人，都不會是我的對手！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "妳還真是大言不慚啊！",
        "unit_id": 911,
        "voice": "vo_adv_1009002_017"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n你們！都給我上！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "手下們",
        "words": "哦哦哦哦",
        "unit_id": 1,
        "voice": "vo_adv_1009002_018"
    },
    {
        "type": "dialogue",
        "name": "手下們",
        "words": "！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我接受你的挑戰！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，要戰鬥了！來吧，拿起你的劍！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就讓他看看，我們暗黑騎士的力量吧！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……嗚！ 不可能！我竟然會陷入苦戰……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_020"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "怎麼了，只有這點能耐嗎！？只會耍嘴皮子結果卻不怎樣啊！",
        "unit_id": 911,
        "voice": "vo_adv_1009002_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比我想像得還厲害……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然如此，我要使出我的最強究極殲滅魔法挽回劣勢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "魔瞳開眼！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "覺醒吧、統率幽世的冥界之主……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n賜予他們至高無上的毀滅吧――！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "你們！拖拖拉拉在做什麼！",
        "unit_id": 911,
        "voice": "vo_adv_1009002_024"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n快點給我收拾他們！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "是的，大哥！",
        "unit_id": 811,
        "voice": "vo_adv_1009002_025"
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚……！敵人的攻擊相當激烈！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這樣的話詠唱會……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，難道你要去當誘餌……！？　",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_027"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……我明白了。你不能死啊、吉格魯特……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這是團長的命令！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……祝你武運昌隆！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "怎樣了？你一個人要當我們的對手嗎？",
        "unit_id": 911,
        "voice": "vo_adv_1009002_029"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "真有膽量啊！就來大幹一場吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "手下",
        "words": "啊，你這傢伙！不要一直動來動去啊！",
        "unit_id": 811,
        "voice": "vo_adv_1009002_030"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "可惡！攻擊都打不中他！",
        "unit_id": 911,
        "voice": "vo_adv_1009002_031"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n閃躲的速度真快！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，你做得很好……我的詠唱結束了！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你們就仔細地品嚐蘊藏著我全部魔力的最後一擊吧！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "那驚人的魔力是！？",
        "unit_id": 911,
        "voice": "vo_adv_1009002_033"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "這樣沒關係嗎，妳的同伴也會受到牽連……！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看招吧！滅龍爆炎業昇波──！！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_034"
    },
    {
        "type": "dialogue",
        "name": "通緝犯們",
        "words": "嗚哇啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1009002_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵……這就是所謂實力上的差距。",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "高興吧吉格魯特，我們勝利了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉、吉格魯特……！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你怎麼變成這副德性！全身都燒焦了啊！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是他們幹的吧……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_038"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n哼……你們這群混帳通緝犯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在我詠唱的時候，竟然做了這麼過份的事！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是因為我的關係嗎！？我還以為你一定已經躲開了……",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……萬分抱歉。下次我會小心謹慎一點……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你、你在說什麼！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我怎麼可能會沮喪啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊……沒、沒有！",
        "unit_id": 100911,
        "voice": "vo_adv_1009002_041"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你在說什麼？",
        "unit_id": 100911
    },
    {
