[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人踏進了露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n期間，走在最後面的克蕾琪塔"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n像是想起了什麼一般，向似似花搭話。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說妳叫",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "似似花吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "此次，我認同妳跟我們同行。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "妳突然說什麼呢",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有些事情一開始就要說明清楚！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n此行雖然倉促，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我們是奉陛下之命出使的調查團。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而隊長當然是我克蕾琪塔‧凱許。",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沒問題吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳說什麼？",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n隊長當然是由有能力的人擔任。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "換句話說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現場就屬我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最合適。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳才是在說什麼？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正因為是以能力有無來判斷，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以才是由我擔任啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "此番調查",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可不是妳最擅長的文書工作喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳就別動歪腦筋，少出風頭吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是陛下指派的任務！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳才應該要服從親自領受陛下內政委託的我啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是內政委託，我也有收到喔。",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳接到和我一樣的委託？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就憑妳這一身魔法師打扮？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n真的嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來妳已經忘記，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是誰阻止妳的帳簿竄改術。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原來如此，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_011"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "妳是那時候的……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就算如此！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這次應該是第一個被委託的我才有指揮權啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說到底，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "此次的露娜之塔調查是關於他的事情。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "管理他",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是我的工作，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以按照妳的邏輯，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就是第一個被委託的人了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳負責……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "管理少年？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種事",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是第一次聽說……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但是",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_015"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "說得通呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n跟克蕾琪塔小姐相比，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "他們相處的時間確實比較久。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂，秘書一號！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你到底站在誰那邊啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我站在工作上正確的那一方。",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_017"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "現在僱用我的人",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是這個國家，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不是克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你就是這種人……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是可是！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起普通的魔法師，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我才是能幫上陛下的人啊……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果你希望得到我的幫助，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就不要再說下去了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知曉我身分的人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是愈少愈好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果你是為了我才想說出來的話……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n……我就稱讚你的善良吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咕",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明就是我接到陛下的命令，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n她是哪裡來的自信……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "她一定是",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "得到陛下的寵愛才敢那麼囂張！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "居然想跟我搶功勞……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此，",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "必須由我來讓她知道誰才是有能力的人吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "唉……",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_025"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，現在是說這個的時候嗎……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "時機正好！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我就讓她看看",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的實力吧！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在克蕾琪塔大聲說完話後過了數小時……"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "出、",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "出現啦啊啊啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唉……",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳比魔物還吵耶。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就不能稍微安靜一下嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳才是",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼那麼冷靜啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我們被包圍了耶！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這種程度就驚慌失措，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "前途堪憂啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳會讓我分心，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先退下吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真從容呢……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳身為魔法師的能力，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就由我來審查吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n快讓我大開眼界……",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一擊擊倒……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這種程度的魔物",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒必要展示我的能力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
