    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也能變得像王宮的騎士一樣。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是一種能發揮力量的強力加護呢。",
