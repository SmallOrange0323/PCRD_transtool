        "type": "dialogue",
        "name": "似似花",
        "words": "好吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我會把你們通通擊潰。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
