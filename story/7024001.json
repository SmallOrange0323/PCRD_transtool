    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我不覺得是普普通通啦，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_046"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不過這樣就審查通過了吧？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我知道了啦！",
