    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這也沒辦法吧！？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就算身體再怎麼強化，我還是一名商人啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "戰鬥這種野蠻的行為本來就不是我的工作！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那您就安分點不就好了……",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我怎麼可能讓那個魔法師在我面前擺架子呢！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_072"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我必須以隊長的身分",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "掌握主導權啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "唉，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_073"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原來如此。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "先不說這個了……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "小心後面。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咿咿咿！？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_074"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是太危險了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "光看是滿有趣的，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_075"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但您要是在這裡倒下去我也會很困擾。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔小姐，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請把眼睛閉上。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你在說什麼蠢話啊，秘書一號！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_076"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要是閉眼，不就看不見敵人了嗎！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會沒辦法進行攻擊耶！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您就算看見了",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_077"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "打不中也是一樣。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "來，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "快點吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊啊啊！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_078"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "討厭！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我知道了啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這樣就行了吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就這樣把弩往右移15度左右……",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_079"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n維持高度，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "然後射擊。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到底要做什麼啦……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_080"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "討厭！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_081"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "原地不動，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_082"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "腰部以上往左90度回頭……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n伸直手臂發射。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀哎呀？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_083"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "最後往正上方瞄準……",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_084"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就是現在！",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喝！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_085"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好了。",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_086"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您可以睜開眼睛了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……？",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_087"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "打、",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_088"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "打贏了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n大家看見了嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我大顯身手的樣子！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵呵呵，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號也做得很好呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊。",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_089"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真是了不起的才能呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "似似花",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_090"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對吧對吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這就是我的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我說的是",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_091"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那邊那位。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "…………",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_092"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以立體的視角俯瞰戰場，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_093"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並給予準確的指示。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "身經百戰的將領也做不到這種程度吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……不敢當。",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_094"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_095"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n關鍵在於我才對吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n實際上打倒敵人的是我耶！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然秘書一號確實有提供協助，",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_096"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但能充分發揮部下才能的卻是隊長的資質啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是按照那位部下的指示去做的人，",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_097"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我不覺得會有隊長的資質呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳所擁有的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只有扮演魁儡的才能吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼！！",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_098"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳什麼意思～！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_099"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "秘書吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "希望你可以在今後的戰鬥，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "幫忙關注敵人的動向。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n請從最後方給我們建言。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我明白了。",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_100"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你好像也沒有受傷。",
        "unit_id": 107011,
        "voice": "vo_adv_7024001_101"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們就繼續前進吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好的，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_102"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "似似花小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_103"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你為什麼要那麼老實地服從她啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n她是個可疑的魔法師耶！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "因為我覺得，",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_104"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這種時候",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "服從似似花小姐，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n工作起來會比較有效率。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "有什麼問題嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯……",
        "unit_id": 118011,
        "voice": "vo_adv_7024001_105"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你就是這種人……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你為什麼要叫她似似花小姐！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要不是週末陪你喝一杯，你還不會稱呼我為小姐耶！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "再拖下去我們就丟下妳先走了喔？",
        "unit_id": 6111,
        "voice": "vo_adv_7024001_106"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔。",
        "unit_id": 6111
