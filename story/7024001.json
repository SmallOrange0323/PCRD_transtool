        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼都沒有人知道，世上還有這麼厲害的魔法師呢？　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼了？",
