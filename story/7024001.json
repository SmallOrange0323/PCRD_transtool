        "voice": "vo_adv_7024001_047"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n說她是我看過最厲害的魔法師也不為過！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n行了吧！？",
