    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼多的魔物就這麼輕易被……！",
