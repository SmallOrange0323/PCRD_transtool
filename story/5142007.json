[
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "既漫長又短暫的訓練期間也結束了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而今天──本期新兵訓練所的受封儀式，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n則於王宮前舉行……"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "各位。",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這20天的訓練，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "辛苦你們了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然期間短暫，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但此次訓練",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想必使各位學到許多，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並得到了更多力量吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……呼～",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這一期因為惠理子的關係而一片混亂呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "終於結束了啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真沒禮貌。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我可沒有製造什麼騷動。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "騙誰啊！",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳知道妳害我有多麼擔心嗎……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……咳咳。",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚嗚……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "本期的新兵訓練所畢業生，",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "共62名。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在此",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "表揚結束所有訓練課程的各位。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我以【王宮騎士團】騎士團長之名，",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n冊封各位為「騎士」。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "成績優秀者……",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請代表上前。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喔。",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "終於要公布成績優秀者了啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哼……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我對拿不到的勳章",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才沒有興趣。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……哼，",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呵呵呵。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳是在笑什麼？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿，",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒什麼～",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我只是感覺嚇人計畫進行得很順利，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以很高興。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼──？",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_014"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "是、",
        "unit_id": 711,
        "voice": "vo_adv_5142007_015"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "是的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n我是本期首席，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "弗萊迪！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "──！？",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "弗萊、",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "迪？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "騎士弗萊迪。",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我在此，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "授予你新兵訓練所",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "首席畢業徽章。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "恭喜你。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "謝、",
        "unit_id": 711,
        "voice": "vo_adv_5142007_018"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "謝……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "謝謝騎士團長！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那、",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n怎麼一回事……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘿嘿嘿……",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "關於這點，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳要不要直接去問問看騎士團長大人？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "──接著，",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請這位新兵的指導教官上前。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在叫妳了！",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快去吧！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好、",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好的……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "騎士教官，",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "惠理子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n貴官",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "培育出了健壯且堅忍不拔的騎士，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n給予他們",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "許多的教導、傳授。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我在此……",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "授予妳名譽教官勳章。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "收下吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……惠理子？",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳不收下嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不、",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要收下。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "非常感謝妳。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼是我呢？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是因為……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我從真琴那裡聽說了妳的活躍表現啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "活躍表現，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是嗎……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "惠理子和新兵們早一步發現有魔物襲擊過來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而聯手擊退了魔物不是嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "特別是那位名為弗萊迪的新兵……",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那位騎士，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我聽說多虧有他自願擔任誘餌，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才使誘敵作戰成功的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實騎士團",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也為了要怎麼處理那隻魔物而傷腦筋。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是多虧有妳的指揮，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以及妳班上新兵們的強韌才能立下的功勞。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n呵呵，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真的很謝謝妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是這樣嗎……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咳咳……",
        "unit_id": 104711,
        "voice": "vo_adv_5142007_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "繼續受封儀式吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "指導教官請回。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好、",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好的……",
        "unit_id": 129911
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼～！",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_039"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "結束了結束了！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n受封儀式好嚴肅啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我很不擅長面對這種場面呢，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼啦，惠理子。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一臉悶悶不樂的樣子。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好不容易拿到想要的勳章了耶。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是妳做的好事對吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好事？",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不懂妳在說什麼呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳打算裝傻嗎？",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只挑好的部分",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "向那位騎士團長報告的人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是妳對吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "新兵跑到區域外，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還有我前去救援新兵，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這些事都沒有向她告知不是嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～？",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是這樣的嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為發生了很多事，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我都不記得細節了呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以就把這當作是事實",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也沒關係吧？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就這麼辦吧♪",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_048"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好了好了！",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這件事就到此為止！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n來吧，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看看風景如何？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "從王城眺望街景果然很美啊～♪",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感、",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺事情好像變得很麻煩了……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我本來就得幫優衣加油了，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在連惠理子也是……！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼了嗎，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看妳有點混亂的樣子……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒事，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼事都沒有啦！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142007_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真琴……？",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "她似乎一個人陷入了沉思呢……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_055"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該是有什麼需要一個人思索的事情，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就先別打擾她吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_056"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼{player}大人……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要把得到的勳章送給您。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_057"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這一天終於到來了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個給您。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您收下……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_058"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "慶祝紀念日的勳章吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……？",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_059"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您之前",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不是說了勳章很帥嗎。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您千萬別客氣，",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_060"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_061"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……我明白了。",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_062"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這也算是",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我與您之間的回憶，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就由我來嚴加保管吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是的……",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_063"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我明明是想送您禮物的，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒想到又從您那裡",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n收到這麼重要的東西了……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來又增加了一個──",
        "unit_id": 129911,
        "voice": "vo_adv_5142007_064"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n與您之間的紀念日了呢♪",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與{player}、真琴，以及新兵們共同度過了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n短暫卻重要的時光。惠理子將這些回憶珍藏於心中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n抬頭仰望了晴朗無比的天空。"
    }
