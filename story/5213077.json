    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感動到停不下來……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n一旦嚐到這樣的刺激，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n再也沒辦法從那邊回來了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "原來世上竟然有這麼美妙的刺激，",
        "unit_id": 104511,
        "voice": "vo_adv_5213077_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花之前完全不知道……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "吉歐‧格黑納，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那裡正是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花所追求的",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "天堂……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好想和虐待狂先生一起定居在那裡……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_5213077_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n縱是煉獄首屈一指的豪傑，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一入口便",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "涕淚滂沱，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n翻滾哀嚎，醜態畢露，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此惡名昭彰之調味料……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵、",
        "unit_id": 129711,
        "voice": "vo_adv_5213077_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n世間當真廣闊無比，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家亦不過見識淺薄。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那個、",
        "unit_id": 104511,
        "voice": "vo_adv_5213077_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不好意思……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可以",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "再來一份嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這種刺激，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花還想再多品嚐一些……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的全身，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都在發出悲鳴！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "因為喜悅！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦咦！？",
        "unit_id": 104511,
        "voice": "vo_adv_5213077_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這也太殘忍了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "竟然要空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要空花",
