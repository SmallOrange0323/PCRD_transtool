    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨成為【龍族巢穴】的新老大之後過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我現在來發表新制度！",
        "unit_id": 106611,
        "voice": "vo_adv_5066003_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n嘉夜夜",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要繼續當幹部扶持我！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥",
        "unit_id": 106611,
        "voice": "vo_adv_5066003_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "則在我身邊服侍我！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n有誰有意見嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "沒有異議！",
        "unit_id": 811,
        "voice": "vo_adv_5066003_002"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "沒有異議！",
        "unit_id": 911,
        "voice": "vo_adv_5066003_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣沒關係嗎……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後！",
        "unit_id": 106611,
        "voice": "vo_adv_5066003_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我不再是從前的可愛龍龍了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如今我是超越老大的存在──",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "Big Boss",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓們",
        "words": "Big Boss！",
        "unit_id": 1,
        "voice": "vo_adv_5066003_007"
    },
    {
        "type": "dialogue",
        "name": "流氓們",
        "words": "Big Boss！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之你先來",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "替我揉揉肩膀。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "是！",
        "unit_id": 811,
        "voice": "vo_adv_5066003_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯嗯，",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你按得挺好的。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "下次交易就交給你啦。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "啊，",
        "unit_id": 811,
        "voice": "vo_adv_5066003_011"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "謝謝老大！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到交易，",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "前幾天採購點心真是戰果豐碩呀。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可以想買就買真是太讚了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……哎呀？",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想起來了，點心快不夠吃了。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那邊那個！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你去買些點心回來！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "是！",
        "unit_id": 911,
        "voice": "vo_adv_5066003_014"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我這就去買！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了，",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣太麻煩了，直接把整間店買下來也不錯呀！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n把它變成我的專用店好了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你先跑一趟",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去跟他們交涉！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "是！",
        "unit_id": 911,
        "voice": "vo_adv_5066003_016"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "包在我身上！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵，",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對現在已經成為大咖的我來說……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大的椅子坐起來還不賴呀。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "今天也要辦就職派對喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n快去準備！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "是，",
        "unit_id": 6311,
        "voice": "vo_adv_5066003_019"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "馬上辦！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈～哈哈哈哈～！",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n超棒的啦～！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這下看來，",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她很明顯地又得意忘形了啊……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果關鍵的祈梨是這副德性，暫時也回不去吧？",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "先觀察一陣子看看……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要去派對會場了喔！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n快點快點！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好好好。",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "知道了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n話說妳那是",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼打扮啊……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼樣？",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是不是很帥！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是是是，",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很帥啊。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……對喔，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n畢竟妳是從形式開始著手的類型嘛……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "知道就好！",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "知道就好！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "前老大也沒有要回來的意思……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這就是",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所謂的黃金時期啦～！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那之後又過了幾天，公會小屋裡傳出祈梨震天的怒吼聲。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這……",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是什麼狀況啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我說呀！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "非、",
        "unit_id": 811,
        "voice": "vo_adv_5066003_029"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "非常抱歉！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "\n都、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "都是我的錯……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以你乖乖去跟人交易，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n結果上當了，被人塞了破爛玩意嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次交易",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我投入了巨額的公會資金呀。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這這、",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這下子會怎麼樣？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "這個嘛，",
        "unit_id": 911,
        "voice": "vo_adv_5066003_032"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "交易對象已經逃得只剩空殼了……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "而且這次的事情",
        "unit_id": 6311,
        "voice": "vo_adv_5066003_033"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "不知不覺間",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "在這一帶傳開了……",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "我們徹底淪為笑柄了啊！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "事已至此，",
        "unit_id": 811,
        "voice": "vo_adv_5066003_034"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "我只有切腹謝罪了啊啊啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "你、",
        "unit_id": 911,
        "voice": "vo_adv_5066003_035"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "你這傢伙……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "唔喔喔喔！",
        "unit_id": 6311,
        "voice": "vo_adv_5066003_036"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "那我也",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "跟他同罪！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……唉。",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳好像有什麼話想說呢。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒啦。",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是在想",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果是之前的老大，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該會在演變成這樣之前",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就看出端倪吧。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜……",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了？",
        "unit_id": 116611,
        "voice": "vo_adv_5066003_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……我有些話要跟妳說。",
        "unit_id": 116511,
        "voice": "vo_adv_5066003_042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你們先去外面等。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大……",
        "unit_id": 811,
        "voice": "vo_adv_5066003_043"
    },
    {
        "type": "background",
        "background": "501330"
