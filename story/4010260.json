[
    {
        "type": "background",
        "background": "509011"
    },
    {
        "type": "background",
        "background": "510081"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "歡迎回來。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要吃飯？",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n洗澡？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "選‧",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我‧",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呢？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等等。",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你是想打給誰？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n３位數號碼能打通的地方可沒幾個呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "令人唏噓。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n明明我特地出來迎接你，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒想到卻被當成可疑人物對待。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "非法入侵？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我有獲得你母親的許可，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以沒有問題。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唔。",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你一點頭緒都沒有嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這個問題可是很重要的喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果答錯的話……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的心情會變得不好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會有一點不好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很好。",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然在你回答出來之前，我多少有點在意，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，答對了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你為什麼",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這副表情？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「七冠生日時還特意親自過來，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是很閒嗎？」",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你的想法都寫在臉上了呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「我在百忙之中，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還特意來訪」",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你這樣理解。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嘛，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這充其量只是個冠冕堂皇的藉口，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不過是順道而來罷了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "至於我是來調查",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n晶和克莉絲是否留下痕跡這件事，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就先保密吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謝了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……哦？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼還有禮物？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對你來說，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的到來應該不在預料中才對。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把自己喜歡的遊戲",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓給我啊。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還滿有心的嘛。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣我又多了解",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你的一個嗜好了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有蛋糕嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_4010260_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那就",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和我一起去買吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所謂的生日，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是挺不錯的嘛。",
        "unit_id": 107031
    }
]