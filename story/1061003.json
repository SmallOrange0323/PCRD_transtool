[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在與剛從昏睡狀態中清醒的可可蘿聯絡後，\n矛依未等人開始準備同時營救貪吃佩可\n以及襲擊王宮的兩種作戰。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣就沒問題了……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "傳信鴉也送回去了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n接下來就只剩準備執行了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "配置已經想好了。",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "日期時間也已經決定好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有就是……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡啊……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的沒問題嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們的作戰計畫，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "贏得過真那嗎……？　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種時候要是有尾狗刀在，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一定能更順利的……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果那傢伙在的話，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n肯定會一臉嫌麻煩卻想出一個",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聰明又狡猾的作戰計畫……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你現在，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "究竟在哪裡，在做什麼呢……？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就不能一臉嫌麻煩地",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從哪裡冒出來嗎……！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "怎麼了？",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_007"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳看起來好像很煩惱，",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_008"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才、",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才沒有煩惱呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "作戰計畫順不順利什麼的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才沒有在擔心呢！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啥？",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_010"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳這傢伙，該不會在害怕了吧？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "可別到這地步才說要臨陣脫逃喔？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才不會呢！",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_011"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "有什麼煩惱的話請說出來，",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_012"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳還得",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "領導我們才行。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "沒錯！",
        "unit_id": 191011,
        "voice": "vo_adv_1061003_013"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "因為如果要救吾主似似花大人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就必須要有妳的協助！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真軌……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哼！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_015"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "總算變得像話一點了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "只要露出這種表情就好了啦，妳啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你……！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底想說什麼？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這就讓我來說明吧！",
        "unit_id": 191011,
        "voice": "vo_adv_1061003_017"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "大吾所說的這些話，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n都是用來激勵妳的！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啥！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_018"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "真軌你這傢伙！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n別隨便拆穿別人啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "激勵……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你那是在安慰我嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那一開始這麼說就好啦──！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很難懂欸！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳居然還有意見……！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_020"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊啊是喔！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我不會再做第二次了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "絕不！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳就沮喪一輩子吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幹嘛突然生氣！",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我又沒說不喜歡！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是、",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_022"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是嗎……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那就好啦……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "總之真軌！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不要動喔？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哈哈哈哈！",
        "unit_id": 191011,
        "voice": "vo_adv_1061003_023"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你幹嘛握起拳頭啊，大吾！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這不是一副要把我打飛的架式嗎！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "知道就好！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_024"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那你就乖乖給我挨揍！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "又來了……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不要鬧得太誇張喔！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還有就是別弄壞東西啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是的……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那些傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從以前感情就不好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在索爾之塔時兩人也針鋒相對過。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "太好了。",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_027"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳終於恢復笑容了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我之前的表情真的那麼難看嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_028"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "就我看過妳擺出的表情裡，",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_029"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我覺得那算是相當愁眉苦臉的喔。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一直到前不久，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我一直努力獨自處理所有事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也覺得那樣就好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是現在，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "必須大家一起努力。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不知為何……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總覺得很不安。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不安",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_033"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是嗎……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "如果有什麼",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是我們能做的就好了……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳是笨蛋嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_034"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "一個人一直亂想一點意義都沒有。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我們一起大戰一場然後贏得勝利！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不就是這樣而已嗎！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_035"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我也跟大吾有相同想法！",
        "unit_id": 191011,
        "voice": "vo_adv_1061003_036"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "若是想太多，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n會容易畫地自限！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真軌……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_037"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "沒問題的，",
        "unit_id": 107311,
        "voice": "vo_adv_1061003_038"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳已經不再孤獨。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "和我們一起，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "同心協力戰鬥吧。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基……",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我真是笨蛋。",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的很笨。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾說的沒錯。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以不如就像笨蛋一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大戰一場然後贏得勝利吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喔！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_041"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "去大鬧一番吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是淺顯易懂的目的！",
        "unit_id": 191011,
        "voice": "vo_adv_1061003_042"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我也會全力揮舞這劍！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……一路走到這裡，雖然發生了很多事，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但有他們真是太好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若和他們一起，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一定沒問題的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n尾狗刀，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我一定會把你找回來！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……大家，",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝你們啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有你們在",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今後也請",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "多多指教！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……妳剛剛說了什麼嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說什麼！？",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別裝傻啦，大吾！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你一定有聽到吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哈！",
        "unit_id": 190711,
        "voice": "vo_adv_1061003_048"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "還不是某人說什麼講話很難懂，\n害我這麼丟臉！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這是回敬妳的！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你、",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這……！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你給我記住──！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我絕對不可能會忘記的！",
        "unit_id": 106112,
        "voice": "vo_adv_1061003_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n把真那打倒，將全部奪回！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家的記憶、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有搭檔！　",
        "unit_id": 106112
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――接著在作戰當日，\n矛依未完美的扮演了誘餌的角色。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "――想跟我戰鬥的都放馬過來！！",
        "unit_id": 106114,
        "voice": "vo_adv_1061003_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要把你們全部一起打飛！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用這把天樓霸斷劍！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來吧，",
        "unit_id": 106114,
        "voice": "vo_adv_1061003_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來換誰！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不自己來的話我要過去囉！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "嗚、",
        "unit_id": 711,
        "voice": "vo_adv_1061003_053"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "嗚喔喔喔喔！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怕了吧！？",
        "unit_id": 106114,
        "voice": "vo_adv_1061003_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就是你輸了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔啊啊啊啊啊啊啊！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "哇啊啊啊啊啊！！",
        "unit_id": 711,
        "voice": "vo_adv_1061003_055"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼哼！",
        "unit_id": 106114,
        "voice": "vo_adv_1061003_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就這點本事？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再來啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放馬過來！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是諾維姆！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可是世紀大壞蛋，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "諾維姆大人呢！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我這裡即使只有一個人，",
        "unit_id": 106114,
        "voice": "vo_adv_1061003_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也會盡力做完能做的事……！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "加油啊，各位！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等等我啊，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然矛依未一直孤軍奮戰，\n但現在的她開始學會信任夥伴了。"
    }
