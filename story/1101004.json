[
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜光蟲退去，瑪爾傑海岸的海面恢復了夜晚的黑暗。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼晚還把學生帶到外面流連，",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "人家是不是壞老師呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n還有，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也是壞學生唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "開玩笑啦。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯……",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然現在是夏天，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但入夜之後還是有點涼。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "差不多該回去吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "海面又開始發光了呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跟剛剛的顏色好像不同……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個光以前好像有看過～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難道說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！？",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "510190"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得的週末，",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓你來學校一趟，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真不好意思呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為我忘記今天是打掃游泳池的截止日。",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "找不到人幫忙，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我正在煩惱的說。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一起加油吧！　",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我換一下衣服唷！",
        "unit_id": 101831
    },
    {
        "type": "still",
        "still": "110100401"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓你久等了～",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯？",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "穿著套裝的話馬上就會濕掉吧？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n更何況，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "穿泳衣比較好活動。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你說什麼呢～？",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "動口之前，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "先動手吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一鼓作氣打掃吧―！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼，",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都汗流浹背了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是你看，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "泳池亮晶晶的！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "泳池的水也放好了！",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n嗯，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好涼好舒服！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿伊―！　",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "潑你！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊哈哈哈哈！　",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也嚇太大一跳了吧―！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺很好玩呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但是還是不要好了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為我、",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不會游泳呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你問為什麼不會游泳，還要當游泳社的顧問老師？",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那是因為，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一整年都可以來泳池，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺很開心呀！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為我沒辦法拒絕學生的拜託。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你是明明不會游泳卻還擔任游泳社的顧問老師\n這個邏輯本身就有問題……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的表情嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才沒有這回事呢！",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "竟然這麼出言不遜，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿―！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n嘩啦嘩啦―！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊哈哈哈哈！",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "想要贏過老師，你還早十年！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "騙、",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "騙人！　",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你溺水了嗎！？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該、",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該怎麼辦呢！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀―！",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是的！　",
        "unit_id": 101831,
        "voice": "vo_adv_1101004_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被你騙了―！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我可不會手下留情的唷！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看我的，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘩啦嘩啦嘩啦―！",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1101004_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦啦～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說起她穿的競泳型泳衣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該又是不同的風情吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對了，",
        "unit_id": 190011,
        "voice": "vo_adv_1101004_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的鼻子有什麼流出了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼喜歡大的嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使失去記憶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種反應看來是男人的本能吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_1101004_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不知道要怎樣才能變成那種身材……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011,
        "voice": "vo_adv_1101004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這點發牢騷也沒有用。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然外表沒有勝算，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是說到內心大小的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我應該可以一決勝負。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可不是不認輸唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1101004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好吧好吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們快回去吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯嗯……",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼呼～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭。",
        "unit_id": 110111,
        "voice": "vo_adv_1101004_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知道什麼時候我們竟然睡著了？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像夢到跟你一直玩水的夢呢……",
