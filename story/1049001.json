    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……？",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n怎麼辦。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真傷腦筋。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "蘭德索爾",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n土地寬廣，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "道路錯綜複雜……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "完全不知道",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哪裡有什麼東西。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是不是迷路了呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "地圖看起來",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像是舊版的？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "到處都是沒有標示在地圖上的建築物和小巷，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我都要搞不清楚哪裡是哪裡了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我才剛搬到蘭德索爾來，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "幾乎沒有熟識的當地人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也沒辦法找個人",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來替我帶路。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒辦法了……",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然剛搬家開銷很大，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還是找間商店買張最新版的地圖吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "每次出門都要迷路一次的話，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也會對日常生活造成影響的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這就是所謂的先行投資吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是這附近……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像沒什麼店家呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "乍看之下，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n比較像住宅區吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔～",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來我好像得先找到",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n像是商店街的街道。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哦！",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n找到一個像是導覽板的東西。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看一看，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許就能知道自己的現在所在位置了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔～",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好像沒有貼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n像是地圖的東西。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一堆",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "徵人啟事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "蘭德索爾的行政機關\n是不是沒有好好在做事呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇！",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不小心撞到你了……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "奇怪了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你是……\n{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "終、",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "終於見到你了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你長大了呢～！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐好欣慰呀。",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你變得這麼有男子氣概！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多麼令人激動呀……☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你還",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "記得我嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我是靜流姐呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦……？",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不記得我了嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我就是靜流姐呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好久不見了，{player}♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……？",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你怎麼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一臉茫然的樣子？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "莫非",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你已經忘記我了嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔，唔……\n這樣啊，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你失去記憶了呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我有聽說這件事。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想不到",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "連以前的事也通通忘記了呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣啊。",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "實際面對這個事實，打擊還是滿大的……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你問我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n知不知道{player}的事？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "當然知道呀！",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我可是你姐姐呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "關於{player}的事，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我可是比任何人都還要了解喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從食物的喜好",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n到最後一次尿床的年紀♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，嗯……",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我來把大大小小的事",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都說給你聽。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哼哼，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "儘管包在姐姐身上吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然璃乃叮嚀過我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不能偷跑。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該沒關係吧。",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在這裡遇見{player}只是巧合。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又不是我為了搶先一步",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而刻意製造偶遇的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也就是說，",
        "unit_id": 104911,
        "voice": "vo_adv_1049001_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這可是",
        "unit_id": 104911
    },
    {
