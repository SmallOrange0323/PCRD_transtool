        "name": "？？？",
        "words": "嗯，",
        "unit_id": 106813,
        "voice": "vo_adv_1379002_051"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我正在尋找它。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n隱藏在這個世界中的",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "巨大謎團……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我也渴求著查清它的夥伴。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "璃乃，",
        "unit_id": 106813,
        "voice": "vo_adv_1379002_052"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我現在把自己知道的情報都告訴妳。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要不要去個安靜的地方──",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n聊聊",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳重要的「哥哥」？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個人",
        "unit_id": 101111,
        "voice": "vo_adv_1379002_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不管怎麼看都很可疑……",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n全身",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "打扮得紅通通的，又很浮誇。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……不過服裝很適合，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有點帥氣。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 101111,
        "voice": "vo_adv_1379002_054"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她知道我的名字，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也知道哥哥的事……",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n關於現在的哥哥",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「失去記憶的理由」，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "她是不是也知道什麼？",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "…………",
        "unit_id": 101112,
        "voice": "vo_adv_1379002_055"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果只是一下下、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的話……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我願意聽。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，",
        "unit_id": 101112,
        "voice": "vo_adv_1379002_056"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "媽媽跟我說過，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不能跟著不知姓名的人走。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦，",
        "unit_id": 106813,
        "voice": "vo_adv_1379002_057"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是我失禮了。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我還沒報上名字吧──",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──我名叫",
        "unit_id": 106813,
        "voice": "vo_adv_1379002_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拉比林斯達。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是公會【拉比林斯】的首領……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也是試圖解開世界之謎的人。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，與拉比林斯達相遇的璃乃，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以公會【拉比林斯】的一員，\n踏出嶄新的一步──"
    },
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "像那樣",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "加入【拉比林斯】後，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我其實很常在哥哥沒注意時，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n暗中守著你喔。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我非常小心，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "避免被你發現啊。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "據說，我跟姐姐過度接觸，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n或許會對哥哥失去的記憶有不好的影響，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "公會長這麼說。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直都沒辦法當面，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n跟你說上話……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可即便如此，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我還是一直想著哥哥。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_063"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是我很重要的──",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇啊！？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還好……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n鞋帶斷了……！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚……",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對不起，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……話說回來，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之前也",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "發生過這樣的事吧。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在我還更小的時候，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "木屐的鞋帶斷掉。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個時候，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也實在修不好鞋帶。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最終",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是你背著我回家的。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你記得嗎？",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你還跟我說",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「我來背妳，所以別哭！」。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我非常高興……",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n直到現在，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我都還記得你當時的後背。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_070"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在也成長了不少。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次換我把哥哥",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "帶到山頂上了喔♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "意思就是我已經成長到這種程度了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊、",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_072"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……嗯，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很完美！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_073"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也比之前更可靠了♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……好──！",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_074"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n穿著哥哥修好的木屐，我就是無敵的！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n現在的我，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不會輸給任何人。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_075"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對手是誰──",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我絕對",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會贏得優勝的──！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──沒那麼容易喔，",
        "unit_id": 1,
        "voice": "vo_adv_1379002_076"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "璃乃！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃！",
        "unit_id": 137912,
        "voice": "vo_adv_1379002_077"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個熟悉的",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聲音是……！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想要通過這裡──",
        "unit_id": 136511,
        "voice": "vo_adv_1379002_078"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就打倒姐姐吧！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眼前就是福運會的終點，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在通往神社的參拜道路上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現在璃乃等人的前路上的──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正是靜流。"
    }
]