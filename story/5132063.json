[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可獨自於"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在準備聖誕節活動的蘭德索爾街道上散步。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聖誕節的準備",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "順利地進行著呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然克蕾琪塔小姐一副擔心的樣子……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這狀況來看，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當天也一定會成功的♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在就已經興奮起來了☆",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵",
        "unit_id": 1,
        "voice": "vo_adv_5132063_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能夠天真無邪地享受聖誕節，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳可真是樂觀啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "純白公主。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請問妳是？",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "令人欣喜若狂的冬季慶典，",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聖誕節。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看起來妳仍不知曉在那輝煌的另一面，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n有著蠢動的黑暗──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是杏奈！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好久不見了呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n看到妳平安健康的樣子真是太好了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說剛剛",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳提到了什麼聖誕節的黑暗，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是真的嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼，",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那當然。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這個世界還存在著許多",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n不為人知的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "恐怖事物。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那些傢伙時刻監視著我們，",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "只要一有機會就試圖伸出魔爪。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這點",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "即使在聖誕節也不例外。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對，",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "依我看當人們沉醉於歡樂，心靈出現破綻時，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n才是那些傢伙下手的絕佳時機。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "趁機侵入人心的黑暗，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "引誘人們墮入兇惡之道。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "杏",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奈所說的話如果是真的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我身為這個國家的公主",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "絕不能袖手旁觀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了保護人們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳務必將",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那件事說給我聽！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聰明的公主啊。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼就讓我來告訴妳！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "顯現於聖誕節的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "恐怖魔女，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "貝法娜的傳說！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔女、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貝法娜……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "傳說中，貝法娜",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "會送禮物給善良的小孩，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n而壞孩子則會得到黑炭。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "黑炭……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "會有疑問是正常的。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果要勸戒小孩，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n送出更明確會令人厭惡的東西就可以了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "即使贈送黑炭給壞孩子，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也可能被拿去惡作劇。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "黑色魔女的目的究竟為何……",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_017"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "長年以來",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一直被視為謎團。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我得出了一個結論。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那其實是──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "引導具備天分的小孩",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "墮入黑暗的證明！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "黑炭的顏色──",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也就是黑色，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這說白了",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "多半代表著黑暗。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n利用黑色的禮物，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓小孩染上黑色，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n成為自己的眷屬……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "個人認為這種做法",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "的目的就在此。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼一說確實合理！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "此外",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也已確認到了與這個傳說極為相似，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n被稱為黑色聖誕老人的黑衣男人。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那些傢伙在名為聖誕節的光明盛宴背後，",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n在暗夜中",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "潛藏於燭光產生出的些許陰影內，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n持續伸出魔爪！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我不知道的地方",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然有如此駭人的事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳不知道也是正常的。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那些傢伙極為狡猾，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果不是像我以及吉格魯特這種",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n置身於戰爭災難之人，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是無從得知的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳方便的話",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能多告訴我一些事嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
