[
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "哎呀，",
        "unit_id": 16711,
        "voice": "vo_adv_5102302_000"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "追上來辛苦你們了。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "那就",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "讓我們繼續──",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "雖然我想這麼說，但……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "在那之前，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我不介意聽聽你們的遺言，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "有什麼想說的嗎？",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……老實說，",
        "unit_id": 123511,
        "voice": "vo_adv_5102302_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我其實",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "稍微能夠理解妳的感受喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我也是一樣，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在大家都捧著我，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "叫我橡子遊俠的時候，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那種感覺",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的非常好。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是，",
        "unit_id": 123511,
        "voice": "vo_adv_5102302_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總有一條不能跨越的線不是嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n傷害他人、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "摧毀大家喜歡的東西，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一般來說，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "做那種事",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是不對的吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "……就算真的有那條不能跨越的線好了。",
        "unit_id": 16711,
        "voice": "vo_adv_5102302_003"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "如果越過那條線，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "就能取悅到更多人的話……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就會去超越那條線。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就是這種人。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "也就是因為這樣，",
        "unit_id": 16711,
        "voice": "vo_adv_5102302_004"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我才會如此受到歡迎。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n站上名為蘭德索爾第一直播主的巔峰！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……沒想到對認同的渴望，",
        "unit_id": 123711,
        "voice": "vo_adv_5102302_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然可以這麼醜陋呢。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n以前我一直",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "非常支持妳，但……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "遺憾哪遺憾。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "將妳導回正途，",
        "unit_id": 123711,
        "voice": "vo_adv_5102302_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就是曾經身為粉絲的我該做的事！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "輝美小姐，",
        "unit_id": 123611,
        "voice": "vo_adv_5102302_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們不會再讓妳為所欲為下去了！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n為了守護蘭德索爾眾人「喜歡」的自由……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們會在此阻止妳！",
        "unit_id": 123611
    }
]