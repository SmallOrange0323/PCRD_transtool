[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n頭好痛啊，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快來人",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我個能讓人開心的報告啊。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果不拿出點成果，",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下醒來時，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就會被臭罵一頓了嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……閣下。",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總之",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我等就先以祭典做準備為主，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n朝這樣的方針是否無誤？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而【拉比林斯】相關的搜索，",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n仍會指派一些人員進行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就照妳方便的去做吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳的實力與實績可是受到相當的好評唷，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n【王宮騎士團】團長",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "純。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請定期向王宮內報告……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該說",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是前來謁見我。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要別忘記這事，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其他讓妳們自由去做也沒差。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "知道囉！",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了趕緊開始行動……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就先失陪了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好。",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我很期待的喔，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然全力開始搜索",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "得在祭典之後就是……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n盡可能",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我早一點，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n將【拉比林斯】那群賊黨的腦袋",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我拿來唷。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好讓我，",
        "unit_id": 106013,
        "voice": "vo_adv_2009004_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將它們獻在休憩之中的陛下枕邊……♪",
        "unit_id": 106013
    },
    {
        "type": "still",
        "still": "200900401"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唔哇，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好恐怖……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這王宮，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "簡直就像是變成了",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "壞蛋的大本營了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我是不是挑錯工作了啊？",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過我也是，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "比起『正義的夥伴』，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n總感覺『壞蛋』比較適合我就是了～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但這地方沒有對邪惡來說，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "最重要的自由呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不管被上頭的人說了些什麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n自由自在想幹什麼就幹什麼的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "才是真正壞蛋吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒錯吧？",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "…………",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……嗯嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "最近總是有一些奇怪的念頭會閃過呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "到底是怎樣，真噁心。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這個就是那個嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n怎麼看都覺得",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "有進出王宮的人們舉止都很奇怪……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "果然整個王宮中，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n都被設置了能干涉精神的強力魔法嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過嘛，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我早先知先覺有應對了就是！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_018"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好像是單單一個人抵抗不了的",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "強力魔法……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我可不想要變成哪個人手中的魁儡呀，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n今後我還是少進出王宮",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "會不會比較好呢～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不知道是不是對精神已經多少有了些影響，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_019"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這陣子還會夢到奇怪的夢呀。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……！",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尾狗刀副團長？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該是要先回",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】的集合所一趟囉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了能夠順利達成",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "閣下所指派的命令，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n必須先向團員們進行說明，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "且有效率的往各處所進行配置才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好好。",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_022"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n對上頭的意向就只能低頭呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在宮裡當官真累♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……嗯？",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了？",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒事～",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_025"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就只是好像看到像蝴蝶一樣的東西飛過……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個王宮為了防禦有設置結界，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若無許可",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就連一隻蟲子也闖不進來才對。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n難道不是你看錯了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近太累了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟你也才剛進來，",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很多工作都還不習慣吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n盡可能，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別太勉強自己比較好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_028"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果可以",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "能賞個長假就好囉～♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這可能有些困難。",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再怎麼說現在人手依舊不足，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在合理的範圍內，還是得讓你好好幹活喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲……",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲提娜的職責，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望做為接班人的你能一肩扛起呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦～？",
        "unit_id": 106211,
        "voice": "vo_adv_2009004_031"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "怎麼想那個人大概都沒什麼在幹正經事吧，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n接任的我稍微偷懶一點應該也差不多？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別強詞奪理了。",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別看克莉絲提娜那樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她可是把工作都做得很好喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為公務員所以得認真做。",
        "unit_id": 104711,
        "voice": "vo_adv_2009004_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就是這樣我們才有資格拿的起，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
