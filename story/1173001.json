[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "慈樂之音巡演中的某個夏日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n千歌獨自佇立在海灘上。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是覺得難得的假期關在旅館裡也很可惜，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n才會豁出去跑來海邊……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但在海邊",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到底要做些什麼才好……？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我很少從事夏天的娛樂，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以不是很懂……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沙灘上的人",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大多是一家人或情侶……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "落單的似乎就只有我……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這種時候，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是有望或紡希陪在身邊就好了，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但她們都有事出門了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我乾脆乖乖回旅館去吧──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嚇、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嚇我一跳……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n原來是{player}啊……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "難、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "難不成你有聽見",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我剛才的自言自語？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就像你看到的，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒事可做，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不知如何是好。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟你一起玩？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "莫非",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你經常來海邊嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "每、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "每年嗎！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那還真是可靠呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那麼，和我也……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "冷靜想想，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟男性獨處，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在海邊，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且是穿著泳裝一起玩，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是一件非常害羞的事吧……！？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我之前有單獨跟他出門過好幾次，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但海邊跟泳裝的組合，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "難度好像太高了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我果然辦不到！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我原本還以為成功舉辦大型演唱會後，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我已經很有自信了，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但會因為這種小事就亂了手腳，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就代表我還不行啊。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我果然",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不適合",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "享受夏季的大海對吧……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對不起，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我突然覺得很難為情……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你不用管我，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請儘管享受大海吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說來，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟你相遇時的我，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為太過緊張而沒辦法在別人面前唱歌呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……可是，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟你在一起後，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我慢慢變得有辦法在別人面前唱歌，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "後來甚至還開了個人演唱會。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "即使一個人辦不到，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要跟你在一起，就一定沒問題……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "讓你看到我丟臉的樣子了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我要重新拜託你。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "教我享受夏季大海的方法。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來到沙灘上後我再次感覺到……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n人數的多寡跟熱鬧的程度",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該是和蘭德索爾相差不遠，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但氣氛卻因為開放感而顯得完全不同。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好熱……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這就是夏季大海的熱氣……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟演唱會又不同的熱氣……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家就是想感受這種熱氣",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才聚集過來的嗎……？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哇，",
        "unit_id": 1212,
        "voice": "vo_adv_1173001_021"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有很多人呢。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "感覺一不小心",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "就會走散……",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "怕走散的話，喏，",
        "unit_id": 312,
        "voice": "vo_adv_1173001_022"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "只要像這樣牽著手就沒問題了。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呵呵呵，",
        "unit_id": 1212,
        "voice": "vo_adv_1173001_023"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "謝謝。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那我們走吧♪",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……總覺得，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很棒呢……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像那樣牽手的感覺。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呃，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是在",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "胡思亂想什麼啊！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果能像周圍的情侶那樣牽手，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定會……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定會",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "非常快樂……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或許會很有……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "夏日風情……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯。",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "首先要",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起在沙灘上散步……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果有成功……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就試著邀他",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來牽手",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然難度很高就是……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！？",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我沒事喔！？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "話雖如此，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "心臟卻跳得好快……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會不會很奇怪啊？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得大家都在看我……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明明穿泳裝開演唱會時，也是很多人在看，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我現在總覺得靜不下來。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果一開始就這樣，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "後面可就令人擔心了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n對啊，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "確實",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是呢……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聽你這麼一說，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家真的都是笑咪咪的……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n邊走邊聊的情侶，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "笑著玩水的小孩子和",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在旁邊守望的父親，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n在沙灘上運動到滿身大汗的團體。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明明有這麼多人，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卻沒有半個人在注意我們。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家都",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自由地玩耍著。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自由，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我至今都是",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "胸懷身為唱喚士的使命，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n活得十分有紀律。對那樣的我來說，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那或許是沒什麼緣分的字眼。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡是不受那種紀律束縛的",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "自由空間……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果是以前的我，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "肯定會覺得很不自在。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，如果是和你一起……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想跟你一起享受自由。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我現在變得會這樣想了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，我們走吧。",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想去水邊走走。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "第一個目標是達成了……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但明明之前也有牽過手，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒想到光是場面不同，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n居然會顯得這麼困難……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那那……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你你你……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你看",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "天氣很好對吧？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不是要說那個！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "再來一次……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "會不會口渴？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗚，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是說不出「你可以跟我牽手嗎？」\n這句話呢……？　",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "欸～欸～",
        "unit_id": 1011,
        "voice": "vo_adv_1173001_043"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這位小妞？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "妳現在有空嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n要不要跟我",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "去喝熱帶果汁",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "啊？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不行不行。",
        "unit_id": 1011,
        "voice": "vo_adv_1173001_045"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "像你這種不起眼的傢伙",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "根本配不上她。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "可愛的女孩必須跟配得上她的男人在一起。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你是在",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說些什麼……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我還挺有錢的，",
        "unit_id": 1011,
        "voice": "vo_adv_1173001_047"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "而且我有自己的船喔。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "所以",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我們兩個現在",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "去海上約會吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……這種事情，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還需要問嗎。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不用了！",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他才不是不起眼的傢伙！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "噫！",
        "unit_id": 1011,
        "voice": "vo_adv_1173001_050"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_051"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們走吧！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "咦？",
        "unit_id": 1011,
        "voice": "vo_adv_1173001_052"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "等等，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "咦咦？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "什麼嘛，氣死我了……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是的，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那人真的很失禮。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n自由是很好，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但那種人變多可是個問題呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_054"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他居然還說你的壞話，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我饒不了他。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為你才不是不起眼的人──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n啊……！？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "居然抓著{player}的手……！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是那個，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該怎麼說好呢……！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖說是一時氣不過，",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_056"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我竟然做出這種事來……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "得馬上放開才行……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311,
        "voice": "vo_adv_1173001_057"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不行。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n要是現在放開他的手，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就跟以前的我沒有差別了……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在該做的是……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
