    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "『お見合いしましょう』なんて言われても、",
        "unit_id": 114511,
        "voice": "vo_adv_6054202_000"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "興味ないのよね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nそもそも、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "考える余裕だってないし……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……あたしの幸せも考えるべきだって？",
        "unit_id": 114511,
        "voice": "vo_adv_6054202_001"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そんな真剣な顔で言われると",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "調子狂うというか、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あんたの気持ち、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "とってもうれしいわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたし、",
        "unit_id": 114511,
        "voice": "vo_adv_6054202_002"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "実業家としてはまだ新米なのよ？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nそれに救護院のこともあるし……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "え？　",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "手伝う？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ふふ、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "それじゃ今度、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "買い物するのを手伝ってね！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そうよね。",
        "unit_id": 114511,
        "voice": "vo_adv_6054202_003"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしたちにはまだ早いわよね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n真剣に相手を探しに来ている人たちの邪魔はしたくないし……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "今日は久しぶりに、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あんたとゆっくりお話しようかな。",
        "unit_id": 114511
    }
]