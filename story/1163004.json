[
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖學祭落幕，本應結束收拾工作的操場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n學生們再次聚集了起來。"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店的學生",
        "words": "琪愛兒～",
        "unit_id": 3112,
        "voice": "vo_adv_1163004_000"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店的學生",
        "words": "吃的差不多都搬完了喔～！",
        "unit_id": 3112
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的～",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "謝謝妳～！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉呀，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "多虧有大家幫忙，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n後夜祭應該會比預計的還要熱鬧呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然優妮＆克蘿依那兩位還沒到，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但大家都專程跑來了，讓她們等也不太好意思。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們就先開始──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──咦？",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n喂，學長，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請不要這樣，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這陣光是怎麼回事？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦咦？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等一下等一下！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "越來越亮了……！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總覺得好像有印象──",
        "unit_id": 116311
    },
    {
        "type": "background",
        "background": "510050"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好慢。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也太慢了吧？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我說，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣算遲到了吧？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是那個問題啦！",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒已經等了三十分鐘了喔！",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你當女高中生寶貴的星期天",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是什麼了？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼了？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "想反駁嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n想說是我自己早到三十分鐘嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就提早醒來了嘛，我有什麼辦法。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你問為什麼……",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個嘛，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒什麼，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有特別的理由。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就只是不知怎麼地提早醒了過來而已。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦……",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對喔。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總之，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "做什麼都行，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們就先去看個電影吧？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對呀？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n所謂的「有事」就是要打發時間。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有什麼問題嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n昨天",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "打電話給你的時候，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長不也說有空？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不如說，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是琪愛兒願意陪學長打發時間。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你可以好好感謝我喔。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要請我些什麼嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有啦，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我騙你的，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請把錢包收起來啦。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "謝謝學長陪琪愛兒打發時間，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很謝謝你。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要看什麼？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個月檔期還滿不錯的呢，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n正好有很多電影上映。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個啊？",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是路上買的雜誌。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為看到上面有望學──",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我喜歡的偶像。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "姑且問一下，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就算{player}學長在怎麼跟不上時代，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好歹也知道望望吧？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "超級偶像櫻井望。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哈哈哈哈。",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉～",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "罐頭笑聲乾掉了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的有呢，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "講這種上古世紀玩笑的人……",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這點你要改進一下喔？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好吧，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我放心了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n看來你至少知道望學姐……",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是說至少知道望望。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊？",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_022"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你那什麼意思？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n是想跟我風間琪愛兒",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "尬誰比較愛望望嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哼……",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n看來有必要教育你一番。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好喔，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我就給你點切嚕瞧瞧。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉唷～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼辦才好呢～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n本來是不太想給別人看的說～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個呀，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "本來有經過同意可以發到SNS，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但最後還是覺得捨不得所以沒上傳的說──",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n唔～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼辦呢～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長想看嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的這麼想看嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一臉就是很想看的樣子呢，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉唷，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真拿你沒辦法！",
        "unit_id": 110932
    },
    {
        "type": "still",
        "still": "116300401"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "鏘鏘，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請看！",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是青春。",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這是在我們學校文化祭那時候拍的，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "青春的一頁。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是琪愛兒想帶進棺材的照片排行榜第一名。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "當然了。",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n她就是家喻戶曉的超級偶像櫻井望，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怕了吧。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "當然了。",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_031"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n她是超級美少女風間琪愛兒。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好了，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可以了學長，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種笑話就算了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "先不開玩笑了，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_032"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你不覺得這張照片拍得很好嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n啊，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望望的可愛當然是包含在裡面，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但除此之外，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我覺得還有拍出青春洋溢的感覺。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對吧？",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n欸嘿嘿，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其實我超想把這張照片秀給別人看的。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "又不想隨隨便便分享給不熟的人。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對琪愛兒來說，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_034"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這不只是一張一群興奮的年輕人，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n圍著偶像嬉嬉鬧鬧的照片而已。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃～",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_035"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該怎麼說呢……",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "每次辦文化祭啊，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_036"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是都會有",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種人嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n像是覺得「哇～這麼拚喔～",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也太積極了吧？」",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "的人。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "或是覺得「隨便弄弄就好了啦～」",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_037"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "的人，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有「想辦的自己去辦嘛～」",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要這樣比喻的話，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_038"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒一直都想當「很拚很積極」的人。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_039"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "高中的文化祭，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一輩子只有三次耶。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不盡情參與不就太浪費了嗎？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_040"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒就辦了望學──",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望望的演唱會。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "先是申請志願籌備表演。",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_041"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然沒有經驗，但從這裡就開始一路衝衝衝。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還寫了像企劃書？",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_042"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "之類的東西，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "去跟望望的事務所洽談。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n經紀人姐姐人很好，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還教了我很多東西。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後因為學校的照明設備跟音響",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_043"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "實在是太破了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以還去打工租比較好的器材，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也認識了展演廳的姐姐，她還給了一些建議。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一個人這樣忙著忙著，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_044"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不知不覺美衣子跟其他班級的同學也來幫忙了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在文化祭前一天，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_045"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還申請了在學校過夜。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不過說是過夜，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但其實根本沒時間睡。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_046"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喊著",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「不好，天亮了──」，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n然後大家一起吃著泡麵，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嘗起來真的是超級美味的──",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──不對，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_047"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這是騙人的。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大概是經過回憶美化吧。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n其實氣氛並沒有那麼感人。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "實際上，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_048"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家因為趕工跟沒睡覺變的很煩躁，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n還吵了起來吼來吼去的，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也沒在管年級大小了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就只有隔壁班的真步",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "到最後都一樣老神在在。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是當演唱會正式開始，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "現場觀眾都「哇～」地嗨起來。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "明明琪愛兒，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_050"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是想看望望演唱會才寫企劃的，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "卻忙著這樣",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那樣地",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "和照明設備搏鬥，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "根本沒有空看演唱會，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等回過神來都已經結束了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過等望望下場，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_051"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "布幕全部降下來的那瞬間，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家都默默地握拳，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "擺出了勝利姿勢。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_052"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "演唱會結束之後，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子她們就嘩地衝到望望身邊，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嚷嚷著「一張就好！",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "拜託一張就好！",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請跟我們拍張紀念照！」",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像這樣",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "厚著臉皮拜託望望。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "當然，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_053"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒可是制止過了喔。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n有跟她們講過",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不要這樣了喔。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你想，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像這樣拜託超級偶像，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼好意思嘛。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_054"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒想到",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "望望聽了，",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n竟然很隨和地答應說",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「咦～拍幾張都可以啊～」",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "耶！",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我們",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "全都「耶～耶～」地嗨翻了。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這就是這張照片的由來，",
        "unit_id": 110932,
        "voice": "vo_adv_1163004_055"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n也就是",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所謂的青春的一頁。",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n很棒吧？",
        "unit_id": 110932
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有沒有覺得閃閃動人？",
        "unit_id": 110932
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "切嚕～☆",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了孩子！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看到的切嚕，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像是切嚕一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n等你醒來就會切嚕地忘記了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以切嚕哩啵叭嗶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "切嚕啵叭叭。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不錯不錯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "琪愛兒總是盡全力揮灑青春。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我真該向她學學",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那股青春活力呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "青春這個季節",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有多麼短暫、有多麼寶貴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有著明確人生規劃的她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相當清楚這一點呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以她才會在有限的時間裡，",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n盡全力地盡情享受青春，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「切嚕～」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大概就是這樣蹦出來的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你現在也過得不容易，",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正是因為如此──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──你更應該學學琪愛兒，盡全力歌頌青春，",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好好累積切嚕才行喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見了，",
        "unit_id": 190011,
        "voice": "vo_adv_1163004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "切嚕～☆",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友1",
        "words": "啊，",
        "unit_id": 3012,
        "voice": "vo_adv_1163004_063"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友1",
        "words": "找到琪愛兒了！",
        "unit_id": 3012
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友1",
        "words": "\n居然在這種地方打瞌睡！",
        "unit_id": 3012
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唔唔……",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_064"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真步不要……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不要再咕嚕靈波了……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友2",
        "words": "這孩子，",
        "unit_id": 1,
        "voice": "vo_adv_1163004_065"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友2",
        "words": "是在做什麼夢啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友2",
        "words": "\n喂，琪愛兒，起床了──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友2",
        "words": "不是要辦後夜祭嗎──？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "琪愛兒的朋友3",
        "words": "大家都在等囉──",
        "unit_id": 1,
        "voice": "vo_adv_1163004_066"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯嗯……",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_067"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不會吧，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我睡著了！？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊學長也是！",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_068"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請快點起來！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n然後幫忙把優妮＆克蘿依那兩位找來！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "拜託了，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_069"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那這邊琪愛兒就先開場囉！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好～",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓大家久等了！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n從現在起，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "後夜祭（不是晚上版）正式開始！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "簡單來說，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_071"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其實就是單純的吃吃喝喝吵吵鬧鬧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "想做什麼都可以！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大家一起悠哉地延續聖學祭的歡樂吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_072"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "接下來就用這句話，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "來代替開場的乾杯。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n準備好了嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大家要一起喊喔？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "預備──！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～！！",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_073"
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想要，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_074"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "繼續創造回憶。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想要，做一本收集了許多閃耀青春，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_075"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n令人覺得",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "光彩奪目的相簿。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以，",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_076"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我今天也一樣全力衝刺。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n最重要的，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是興致、氣勢和切嚕～",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "至於切嚕～是什麼，這就不重要了。",
        "unit_id": 116311,
        "voice": "vo_adv_1163004_077"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n請大家各自表述。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n感謝收看，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕。",
        "unit_id": 116311
    }
]