[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與【new generations】一起停留在村子裡的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n早上醒來，正在散步的時候——"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦？",
        "unit_id": 112511,
        "voice": "vo_adv_1125004_000"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你已經起來啦。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "早安。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n一大早難道有什麼事情嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……這樣啊，",
        "unit_id": 112511,
        "voice": "vo_adv_1125004_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "只是比較早醒來而已。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我是打算",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "在練習前先去跑步暖個身。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "晨光照起來很舒服，感覺正好……",
        "unit_id": 112511,
        "voice": "vo_adv_1125004_002"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不覺得太耀眼了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……不對，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這不是太陽光，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "為什麼你在發光啊！？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n你那是什麼體質！？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "呀啊啊！",
        "unit_id": 112511
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的假日"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}為了買東西而前往商店街時——"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就算你這麼說，我也很傷腦筋啊……",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_003"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "務必請妳幫個忙！　",
        "unit_id": 1,
        "voice": "vo_adv_1125004_004"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "至少收下名片也好！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不是，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_005"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "現在和名片沒有關係吧。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我是也很想幫你啦，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "唔～嗯……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦？　",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_006"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……啊啊，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你也來買東西啊。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你來得正好。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "可以幫我",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "說服這個人嗎？",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "所以，",
        "unit_id": 1,
        "voice": "vo_adv_1125004_007"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我從剛才不就一直在說了嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n為了讓這次的活動成功，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "絕對需要妳的力量啊～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_008"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好像是",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "商店街今天要辦活動的樣子。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "只是，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好像原本預定要參加那個活動的偶像",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "沒辦法來了。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "聽說那孩子",
        "unit_id": 1,
        "voice": "vo_adv_1125004_009"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "突然發高燒倒下了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n因為突然生病導致工作開天窗這無可奈何，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "但問題是沒人可以替代啊！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一般來說，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_010"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "事務所要是有人休息時，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我想都會從同事務所",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "派替代的人過來才對……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "沒有嗎？",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "關於這個，",
        "unit_id": 1,
        "voice": "vo_adv_1125004_011"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "聽說年齡相近的人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "全都已經有安排工作了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n我們是有稍微放寬條件",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "請他們介紹其他候補的人……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "但根本不符合「料理偶像☆小樁」",
        "unit_id": 1,
        "voice": "vo_adv_1125004_012"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "的形象啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n能夠立刻應對的人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "可是職業摔角類型的偶像耶！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就算是這樣，跑來找我也太莫名其妙了吧……",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_013"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "才沒這回事！",
        "unit_id": 1,
        "voice": "vo_adv_1125004_014"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我在看到妳的瞬間腦中就",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "「叮！」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "地感受到了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n應該說是有偶像的氣場嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "總之我感受到了妳潛藏的才能！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "所以拜託妳了！　",
        "unit_id": 1,
        "voice": "vo_adv_1125004_015"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "請妳參加活動吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這可是讓樁丘商店街原創角色紅起來的機會啊～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯——",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_016"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要我幫忙是可以，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但有些部分讓我在意呢。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "該怎麼辦呢……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……對了，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_017"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "可以請你配合我的說法嗎？",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我會把你",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "說成是我的「經紀人」來跟他談，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就麻煩你囉。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大叔，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_018"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要我代替演出主持活動是可以，但我有個條件。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "已經有所屬的事務所，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "而且已經出道了。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "咦！？　",
        "unit_id": 1,
        "voice": "vo_adv_1125004_019"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "意思是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "妳其實是真正的偶像嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n真、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "真是失禮了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "沒關係，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_020"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我才剛開始活動而已，請別在意。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n這個人是我的經紀人。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我今天",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "休假。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "然後，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_021"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "因為我已經有所屬的事務所了，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n所以要是留下",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "照片或影像等等的紀錄，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "會變得很麻煩。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "而且我也會被事務所罵……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "所以，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_022"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果能完全禁止拍攝之類的行為，我就可以幫你。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我的經紀人",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "也說那樣的話就OK喔。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "若是只需要那些條件的話，",
        "unit_id": 1,
        "voice": "vo_adv_1125004_023"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "完全沒問題！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n再兩個小時後就要正式演出了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我帶你們去準備室！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "來和小樁",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_024"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一起做好吃的",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "神奇料理吧。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "小樁廚房，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "閃亮靈光——",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "用幸福的笑臉",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "讓料理變好吃……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_025"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "原來是這種感覺的啊……",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n這個，",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我覺得比起我，讓其他人來做會更適合呢。",
        "unit_id": 112531
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "慢著，",
        "unit_id": 112531,
        "voice": "vo_adv_1125004_026"
    },
    {
        "type": "dialogue",
        "name": "凜",
