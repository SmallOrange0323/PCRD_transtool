        "voice": "vo_adv_5156431_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "才沒那種事。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我其實稍微有點……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "寂寞哦？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "因為，",
        "unit_id": 130112,
        "voice": "vo_adv_5156431_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "像這麼嚴酷的國家，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也沒有蠻賊貪鯊號，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然一開始真的很不安，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也有點害怕……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但是，",
        "unit_id": 130112,
        "voice": "vo_adv_5156431_003"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "正因為如此，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n才能跟姊姊還有布武機以真心話對談，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "又或者說，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n互相幫助，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "變得更像是姊妹了",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "的感覺……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嘿嘿。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "──呃，",
        "unit_id": 130112,
        "voice": "vo_adv_5156431_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊！？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "布武機！？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n咦、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "已經走到門口了！？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "布武機",
