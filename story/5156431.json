        "voice": "vo_adv_5156431_005"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n被發現了～ｗｗ",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……難道說妳們打算丟下我，",
        "unit_id": 130112,
        "voice": "vo_adv_5156431_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "先回到蘭德索爾嗎！？",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "因為妳實在太陰沉了啦。",
        "unit_id": 130012,
        "voice": "vo_adv_5156431_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想一起回去的話就別碎碎念了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "趕快過來！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚嗚……",
