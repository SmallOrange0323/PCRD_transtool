[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一個晴朗的日子裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一個人隨意地散步著。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我應呼喚",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "飛奔而來，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪啪啪──！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "──咻噠！",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妮諾，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "現正登場是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔？",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你說你",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒有叫我？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這種小事",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "別放在心上，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "別放在心上是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有將軍在的地方",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "自然會有妮諾。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這就是主從關係是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那麼，將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你今天",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要去哪裡呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哪怕是",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在鬼島般的恐怖之境，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也會三步併作兩步來服侍你的！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請好好期待",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我能夠被你認可為忠臣的活躍表現是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦！",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這道刺眼的光",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是之前看過的！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎～麼會～",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太不講理了～～",
        "unit_id": 103011
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也這麼",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "勤奮向學辛苦你了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我已經恭候多時是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果可以的話，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "白天",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也想陪在將軍的身邊，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n保護將軍",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不被可疑人士糾纏",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們兩個就讀不同學校，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以沒辦法這麼做……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在學校，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "椅子上可能會被人放圖釘，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鞋櫃裡",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可能會被人放挑戰書……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是個",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非常可怕的地方……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果在校園裡發生了什麼事，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請立刻",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼喚我！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哪怕是在考試途中，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也會使用忍法‧替身之術，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "馬上趕到你身邊的！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好了，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "話說……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我有個地方想和將軍一起去！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是個",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "安全無虞的地方，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請儘管放心吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "出陣",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦──哦哦──！",
        "unit_id": 103031
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "快點，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "往這邊走！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就和我一起",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看電影吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我心儀的作品",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是這個！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就是這個！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這裡是",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者的發源國……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我從以前就夢想著",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能在日本當地",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看忍者電影！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個電影特輯，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n都是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我在小時候看過",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "並深受影響的作品……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯──",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太令人雀躍了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們一起沉浸在幸福的時光中吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒有！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎麼可能是看6個小時！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "其中一部",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是時長4小時的超級大作，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以總共要看8個小時是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但是，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "劇情就像塌塌米翻身術一樣，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接二連三的出現新展開，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n還可以體驗浩大的場面！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "時間轉眼之間",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就流逝了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我連將軍的電影票",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都預購好了，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們快過去吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪啪！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "8個小時後──"
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯嗯──！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太精采了──！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊……！ ",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_025"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": " 不管看幾次，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "《忍者國的逆襲》",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都讓我",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好感動！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最終決戰就在眼前，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "明知道是一場必敗之戰，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n忍者們",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還是為了替主人洗刷汙名而奮起向上的瞬間……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚嗚……",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "說到這裡我都熱淚盈眶了……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "說到眼淚，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "《隱密之戀",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "～戀慕忍法～》的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最後一幕！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者也是個人……",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了愛慕之人流下的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那些淚水……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正因為有著",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "掛念一個人的心情，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "才有辦法作戰的吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在《寂寞的忍者半藏》中，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也深刻地描繪了",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "主角半藏",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n踏上修羅之路的半輩子……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼──",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n真的是太令人動容了是也……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好想",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_032"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "告訴小時候的自己。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n等妳長大以後，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就能在日本",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看忍者的電影了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是呀！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_033"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我的家人很喜歡電影，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "以前我們經常一起去看電影。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "像是在叢林裡",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和武裝外星人作戰的電影，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n或是鯊魚從天而降的電影，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還有",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "探索古代遺蹟電影……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我看了",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各式各樣的電影喔！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在這之中，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我遇見了日本的歷史劇！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "從來沒有一個題材的電影",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "讓我那麼驚豔！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "武士",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "僅用一把日本刀，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一路",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "斬除邪惡的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "活躍表現，\n還有",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者潛伏在暗處",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "使用五花八門的忍法",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和道具的身影……\n都讓我",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很嚮往！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "然後，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_037"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這些電影裡",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都有一個將軍，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n會為了社會、為了人民而戰，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "並守護住所有人的笑容。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我在心裡發誓，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "總有一天我也要",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了將軍而戰是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "事情的來龍去脈",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_039"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就是這樣。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "回過神來時，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我已經離開法國",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n到日本來留學了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_040"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n看完電影太過激動，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忘得一乾二淨是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛才",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_041"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "從電影院出來的時候，我拿到了這個……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我找一下",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也……",
        "unit_id": 103031
    },
    {
        "type": "still",
        "still": "103001101"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鏘鏘！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_042"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你快仔細看看這張傳單！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "怎麼樣！？",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_043"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這齣歷史劇",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在招募臨時演員是也！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這可是",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_044"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍統一天下千載難逢的機會！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "現在正是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "出陣的時刻！",
        "unit_id": 103031
    },
    {
        "type": "still",
        "still": "103001102"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好！",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_045"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真不愧是將軍！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n掌握作戰的時機也是爐火純青！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘻嘻，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_046"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我能夠來日本",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是太好了。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n電影中的將軍",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也在最後讓大家露出了笑容。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "武士和忍者們",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_047"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一定也",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "相信將軍會",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "打造出一個充滿笑容的世界，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n因此才能一路奮戰下去吧。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_048"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我喜歡的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不只是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "歷史劇中的將軍而已。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也非常尊敬",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "現在",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在我面前的將軍是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "因為",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_049"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你總是能讓我露出這麼開心的笑容呀！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "發自內心",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "慶幸自己能夠來到日本。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n因為",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我遇見了真正的將軍。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103031,
        "voice": "vo_adv_1030011_051"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今後我也會",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "永遠服侍你的。",
        "unit_id": 103031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有做一場好夢嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將軍。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我常常在想，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妮諾的行動力真的很令人欽佩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她可以為了一個憧憬的事物，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從法國飄洋過海到這裡留學。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肯定是她熱愛歷史劇的濃烈情感",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n帶領著她邂逅了能夠被稱作將軍的你吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要打造妮諾口中，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓所有人安居樂業的太平盛世，並不是一件容易的事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟這個世界，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並不是勸善懲惡的歷史劇呀……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有這樣一個仰慕你的女孩子，你可要好好守護她的笑容。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是你……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "身為將軍的職責。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣一來，或許總有一天……",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妮諾理想中的世界會不再只是個夢想。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1030011_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……哇！？",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_060"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我好像不小心睡著了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_061"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你平安無事吧！？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這搞不好是來自敵方武將的奇襲！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我看看，",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_062"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我瞧瞧……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看來是沒有什麼異常。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太好了。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我已經下定決心，",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_063"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "無論要我",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "用什麼東西交換，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我都會保護好將軍的性命。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在這廣闊的世界裡，",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_064"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我遇見了將軍你。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這點程度的小事當然是我的職責是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如同",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_065"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "朝陽會在東方升起一樣，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "成為將軍的家臣也是這麼理所當然，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這麼說完全不為過是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以，",
        "unit_id": 103011,
        "voice": "vo_adv_1030011_066"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "直到成功統一天下為止，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妮諾立誓",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會寸步不離的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在身邊服侍你！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與將軍的邂逅令妮諾感到喜悅，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n無論發生什麼事都要善盡家臣職責的決心也更加堅定。"
    }
]