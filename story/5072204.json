[
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔，",
        "unit_id": 117211,
        "voice": "vo_adv_5072204_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不好了……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "觀眾們的情緒越來越低落了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他們如果感受到了這群陰沉魔物們所帶來的壓力，",
        "unit_id": 117311,
        "voice": "vo_adv_5072204_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這也是沒辦法的事。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然如此，",
        "unit_id": 117411,
        "voice": "vo_adv_5072204_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們只要帶來更多的歡樂就行了！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來就輪到我出場囉！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我引以為傲的舞台服裝的華麗感！",
        "unit_id": 117411,
        "voice": "vo_adv_5072204_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n充分運用了夏日海洋的舞台呈現！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "用我努力的成果，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來掃除觀眾們心中的不安吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_5072204_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這主意不錯！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就拜託妳囉，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希！",
        "unit_id": 117211
    }
]