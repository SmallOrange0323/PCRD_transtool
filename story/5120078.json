[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "霸瞳皇帝～",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得確實掌握了美貌啦。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n言行舉止、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "身上的穿搭",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都很完美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為此一定",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非常努力吧……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那跟我理想的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在方向性上似乎有所不同呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了不讓人靠近、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了隱藏自己而存在的美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要不要",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "試著拋開一切，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "展現出真實的自我呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似似花小姐的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "果然就是出自於她那神秘的氛圍吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "神出鬼沒、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "神秘的言行舉止……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為人類這種生物，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n會對無法理解的事物",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "抱持著憧憬與敬意。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能製造分身真的是超棒的呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果有分身的話，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就能將我的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "傳遞到世界上各個角落了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她能不能",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "教我怎麼製造分身啊……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒辦法嗎……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "矛依未小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有著不管什麼時候，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都能貫徹自己信念的強大呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她是要成為大壞蛋嗎……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我沒有想過要當壞蛋，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以不是很清楚，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是有著遠大的目標應該是件好事吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得……",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她好像對表面上的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒什麼興趣呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "相對的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她有著很堅定的美學，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該是這樣子說的吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我希望她能就這樣繼續向前邁進呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為那一定會是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "通往美的最短捷徑啊♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然沒辦法清晰地想起來……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我好像",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在夢裡遇到了美麗的女孩子啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是個有點虛無縹緲，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "卻又具備了神聖之美的人……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不對，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是妖精吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那到底是什麼啊……？",
        "unit_id": 126311,
        "voice": "vo_adv_5120078_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我也不清楚呢……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不知道為什麼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得不要搞清楚",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比較好呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是為什麼啊……？",
        "unit_id": 126311
    }
]