[
    {
        "type": "background",
        "background": "500740"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳把一堆工具、魔導具通通拿出來是要幹嘛啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這些嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是以珠希的開發設計圖為基礎，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "透過我的魔法理論加以修改的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n高機動萬能鞋──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「神速小子」最終調整。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等──",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又是那種可疑的作品……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "拜託饒了我吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐手上那東西",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "最後鐵定也是會爆炸吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "住口。",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不要散播那種一瞬間會讓人想點頭同意說「的確是」的謠言。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果妳是指好朋友X，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個不管設計還是開發都是由財團進行的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過呢，",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就算發生慣例的爆炸也沒關係吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n秋乃學姐自己",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "被捲進好朋友X大爆炸事件，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n最後也是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「咳咳」幾聲",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就沒事了嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那是因為她是搞笑角色吧？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不可以相提並論啦，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們可是走寫實路線的。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟搞笑角色是無敵的嘛。",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來說到小墨丘利那些人，",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家全都是搞笑角色吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是沒關係啦，",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過妳們不覺得我們身邊",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "搞笑角色的比例高得離奇嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_5064101_009"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "物以類聚！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那碧怎麼樣呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "碧也是啊，",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該說是搞笑嗎……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "基本上就是個喜劇角色啊。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "臉上誇張的表情和尖叫反應的姿勢都很豐富。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小小甜心她們",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感覺就像是很溫馨的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "四格漫畫呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "光是三個人吵吵鬧鬧的樣子，感覺就可以看一輩子啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "優妮學姐前陣子遇到的",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個自稱姐姐的狂人怎麼樣？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靜流嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她是心理驚悚片的角色。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "結果寫實系的只有我們？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這麼認真過活豈不是像笨蛋一樣嗎。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說優妮學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n萬能鞋？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼要做那種東西？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為聖學祭快到了，",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是我獨有的策略手段。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖學祭……",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是什麼啊",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一年級的琪愛兒今年是第一次遇到啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聖學祭──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是本學院最盛大的年度活動，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聞名遐邇、動靜皆備的祭典。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳想想，",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "其他學校",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是有什麼運動會或文化祭嗎？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我們學院腦子比較有問題，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就把那些都攪在一起舉辦啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是什麼惡魔合體狂歡祭典！",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n俗稱德蕾祭，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "突然切嚕起來了啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "諸君也要好好準備。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這場祭典不只是全校學生，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也很受家長、來賓的矚目，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只要在這裡展現出活躍的表現，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該也會更獲得學院器重。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊──",
        "unit_id": 110812,
        "voice": "vo_adv_5064101_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "瞭解。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n也就是只要表現得好，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就會成為獎學金審查的加分材料吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正是。",
        "unit_id": 111011,
        "voice": "vo_adv_5064101_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n要讓優妮們之名聞名天下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯！",
        "unit_id": 110911,
        "voice": "vo_adv_5064101_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n讓我們好朋友社之名",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聞名天下！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "下一回！",
        "unit_id": 1,
        "voice": "vo_adv_5064101_026"
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "「鋼鐵聖女與",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "神聖學院的問題兒童」！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "不守紀律的學院之癌、",
        "unit_id": 7112,
        "voice": "vo_adv_5064101_027"
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "擾亂風紀的萬惡根源──",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "我跟隨主的教誨，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "過去都寬容地予以赦免，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "\n但差不多到了必須將之定罪的時刻了呢。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "接受破滅吧，",
        "unit_id": 7112,
        "voice": "vo_adv_5064101_028"
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "好朋友社。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "\n名校",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "聖德蕾莎女子學院中，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "學生會長",
        "words": "不需要搞笑角色。",
        "unit_id": 7112
    }
]