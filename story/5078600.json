[
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "はて……",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何だね、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これは。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "テレフェスのプログラムです。",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_001"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "え、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "逆になんで知らないんですか？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n生徒全員に配られてるはずですけど。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ、",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そういえば昨日",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『象牙の塔』に教員が何か届けに来たな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうせ遅れている論文の催促状だろうと、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "とくに封は解かなかったが。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "ま、いんじゃないすか。",
        "unit_id": 116211,
        "voice": "vo_adv_5064600_003"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "それキホン来賓向けだし。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n実際そこに載ってないシークレット地味競技とかも若干あるし。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "そういう問題じゃないんですよ！",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_004"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "これは貴重な学園生活を刻んだモニュメントなんです。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nのちに振りかえって記憶の扉を開くための鍵なんです。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "さあ先輩方！",
        "unit_id": 116311,
        "voice": "vo_adv_5064600_005"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "祭りの記憶を掘りおこしてわーわー言うやつをやりましょう！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おお、",
        "unit_id": 116411,
        "voice": "vo_adv_5064600_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "青春っぽい！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "テレフェスねえ……",
        "unit_id": 116211,
        "voice": "vo_adv_5064600_007"
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "クロエ",
        "words": "あんまロクな記憶ないんだけど大丈夫か？",
        "unit_id": 116211
    }
]