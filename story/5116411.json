[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "合宿もようやく最終日……",
        "unit_id": 103811,
        "voice": "vo_adv_5116411_000"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "本当に、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "色々ありましたね。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私、",
        "unit_id": 103811,
        "voice": "vo_adv_5116411_001"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "この合宿にきてよかったです。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "大事にしたい人、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "大切にしたいもの……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "それが何か、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "改めてわかりました。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "だから、",
        "unit_id": 103811,
        "voice": "vo_adv_5116411_002"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "まずは「ただいま」って言いたいです。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私の、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "私たちの帰りを待ってくれている人に。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "わたくしも、",
        "unit_id": 105911,
        "voice": "vo_adv_5116411_003"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "でございます。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n帰りを待っているみなさまに、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nたくさんのお土産話をいたしましょう。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "しかしシオリさま、",
        "unit_id": 105911,
        "voice": "vo_adv_5116411_004"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "まだ合宿は終わっておりませんよ。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "今日この日を、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "最後まで気を緩めずに過ごしましょう。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "きっちり任務を完遂してこそ、",
        "unit_id": 105911,
        "voice": "vo_adv_5116411_005"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "一人前のレンジャーでございますから。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "ふふっ……",
        "unit_id": 103811,
        "voice": "vo_adv_5116411_006"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "そうですね。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n最後まで油断せず、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "ですね。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "みんなで、",
        "unit_id": 103811,
        "voice": "vo_adv_5116411_007"
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "胸を張って",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "「ただいま」を言うために。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "さあ、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "シオリ",
        "words": "今日も頑張りましょうっ。",
        "unit_id": 103811
    }
]