        "name": "杏奈",
        "words": "為什麼──",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊，",
        "unit_id": 100931,
        "voice": "vo_adv_1132004_027"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是這樣啊。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你沒有勇氣去買啊？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "噗、",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "哈哈，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "哈哈哈！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我們居然不約而同帶了同樣的泳衣，",
        "unit_id": 100931,
        "voice": "vo_adv_1132004_028"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n看來我和你的緣分",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "果然是不管走到哪也斷不了呢！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "吉格魯特，",
        "unit_id": 100931,
        "voice": "vo_adv_1132004_029"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你已經做好覺悟了吧。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那麼，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我們「",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "熾炎戰鬼煉獄血盟暗黑團」",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "將統治這片大海！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "先在海裡游個痛快，",
        "unit_id": 100931,
        "voice": "vo_adv_1132004_030"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "然後再吃刨冰！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n還有打西瓜……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "對了！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "還要玩沙灘排球！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "讓我們一起突破",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "沉睡在這片大海的所有考驗！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "只要和你在一起，",
        "unit_id": 100931,
        "voice": "vo_adv_1132004_031"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我就沒有什麼好擔心的！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n走吧，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "讓他們見識見識",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我們之間的羈絆～！！",
        "unit_id": 100931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
