    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1132004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次的夢境如何呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還開心嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在意他人的目光而感到難為情，",
        "unit_id": 190011,
        "voice": "vo_adv_1132004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n杏奈也是個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正值青春期的女孩子呢～♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也因為",
        "unit_id": 190011,
        "voice": "vo_adv_1132004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "同樣穿著學生泳衣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n成功地幫杏奈圓場，做得不錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然平常做了一堆遲鈍男行為，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但在這一點還是可以誇獎你的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然杏奈在「這一側」和「那一側」都經常逞強亂來……",
        "unit_id": 190011,
        "voice": "vo_adv_1132004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她總認為只要有你在就不必擔心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這或許也是信賴的證明吧。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔、",
        "unit_id": 113211,
        "voice": "vo_adv_1132004_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我又",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "夢到前世了……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你也作了同樣的夢嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒錯，",
        "unit_id": 113211,
        "voice": "vo_adv_1132004_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是這個！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "想不到這件泳衣上",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "蘊藏著我們前世以來的連繫！！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香所說的傳說裝扮",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道是這個意思嗎……！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "將我們連繫在一起的羈絆",
        "unit_id": 113211,
        "voice": "vo_adv_1132004_038"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比我想像的要深厚得多，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n而且",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還是以壓倒性的堅韌連結在一起！！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 113211,
        "voice": "vo_adv_1132004_039"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我絕對",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不會離開你的身邊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所以，從今以後我們也繼續",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "共同對抗「機關」吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來，",
        "unit_id": 113211,
        "voice": "vo_adv_1132004_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對這個墜飾許下諾言。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們在前世，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "今世，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n直到來世都是同路人！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈哈哈哈！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後，修特帕魯將學生泳衣"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n視為代表前世羈絆的服裝，令她感到驕傲無比。"
    }
