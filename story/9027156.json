    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不是認真的吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "頭上輕飄飄的這部分好像很好吃的感覺……☆",
        "unit_id": 105811,
        "voice": "vo_adv_9027156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才沒有那回事！",
        "unit_id": 106011,
        "voice": "vo_adv_9027156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從頭到尾巴的末端，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "滿滿都是毒啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從頭到尾巴的末端……",
        "unit_id": 105811,
        "voice": "vo_adv_9027156_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來像美味的鯛魚燒呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "裡頭的內餡可都是毒喔，",
        "unit_id": 105911,
        "voice": "vo_adv_9027156_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這種地方",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被未知的毒物感染的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該不是區區食物中毒就能輕鬆了事的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是放棄吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是可是，",
        "unit_id": 105811,
        "voice": "vo_adv_9027156_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "據說就算是毒蘑菇，滋味也是一絕的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別不惜賭上性命",
        "unit_id": 106011,
        "voice": "vo_adv_9027156_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也想要滿足食慾啊……",
        "unit_id": 106011
    }
