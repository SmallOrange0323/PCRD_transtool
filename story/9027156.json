    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是何等",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n痛苦的經驗呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也要",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "流下感動的淚水了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連可蘿仔也！？",
        "unit_id": 106011,
        "voice": "vo_adv_9027156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以現在是只有我狀況外",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的意思嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好啦，",
        "unit_id": 105811,
        "voice": "vo_adv_9027156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勝利的餘韻就到此為止了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們來貫徹",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】的活動宗旨吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？　",
        "unit_id": 106011,
        "voice": "vo_adv_9027156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳該不會！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想把這條黏濕山寨龍",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給吃下肚吧！？　",
        "unit_id": 106011
