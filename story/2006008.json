[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼什麼？",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是{player}！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩位……",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n妳們都好好地活下來了呢，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真是太好了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "耶嘿嘿。",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你們看，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n喵特也平安無事喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時候場面太混亂，又和妳們走失，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以大家很擔心，一直在找妳們。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是魔物的小孩嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可愛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來好好吃哦～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳剛才是不是說了看起來很好吃？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該是我聽錯了吧……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n喵特可不能吃哦？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n聽說貓肉油脂很多，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不太適合拿來吃的樣子呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n妳知道很多這種相較之下有點無關緊要的知識呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿嘿，",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我每天無所事事的時候，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就會把書拿起來讀，我可不是讀好玩的呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉唷很閒就去工作啦，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞可以",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "去休息沒有關係哦～。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為環境劇變的關係，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳的身體狀況又變糟了吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒問題的哦。",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會好好加油的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟牧場都變成全毀的狀態了，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可不能只有我一個人躺著休息。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是明明遭到摧毀了，",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但現在已經恢復得和原本差不多了吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然恢復的這麼快，",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該是件值得開心的事情才對……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是啊，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為有很多公會趕來幫忙，、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們也是從一大早就開始努力重建了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但現在只有外觀看起來像是修好了，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n其實到處都還滿目瘡痍呢。",
        "unit_id": 103811
    },
    {
        "type": "background",
        "background": "500154"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有一位好像是莉瑪的朋友，",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是個很厲害的魔法師。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才三兩下的功夫，",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就輕鬆地把馬廄都重新蓋好了呢。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過那個人",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底是誰啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那種魔法……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我好像也沒有在城裡見過呢。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳是在說似似花吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n她說這是感謝我平常的幫忙，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以就把力量借給我了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n那孩子真是的，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n平時一副面無表情的樣子，卻很溫柔呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大概是看見住在附近的我們陷入困境，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n無法視若無睹，因此就來幫忙了吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "之後得好好地跟她道謝才行♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似似花……",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這名字好像在那裡聽過的樣子？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有名的魔法師嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像不是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫名地在意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "待會可以請您介紹給在下認識嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但那孩子總是神出鬼沒的，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不是說想找她就有辦法找到她的呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "先不說這個了，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n請問妳",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是哪位呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有先報上自己的姓名，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在相當抱歉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "服侍{player}的隨從……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n名叫可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以後還請多多指教。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哎呀，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是個禮數很足且懂事的孩子呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "隨從是？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n{player}，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你有這麼偉大哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於這一點我也相當在意。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是錯過了問這個問題的時間點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你們兩位是怎麼變這麼熟的啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事情",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說來話長……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與其說明這個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該先去和咲戀小姐報平安才對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 105913,
        "voice": "vo_adv_2006008_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問她……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問咲戀小姐現在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人在哪裡呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【咲戀育幼院】的那位……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她應該是在馬廄附近，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n和真陽及【墨丘利財團】的人們一起整合所有的事務哦。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以的話，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我來帶……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哎呀？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳看，小栞妳真是的……",
        "unit_id": 102611,
        "voice": "vo_adv_2006008_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n走路都走不穩了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "休息一下吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對呀，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是小栞倒下的話，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就得多派人手來照顧妳了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我能理解妳現在坐立難安的心情，",
        "unit_id": 105211,
        "voice": "vo_adv_2006008_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但就先安分一點吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的……",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n說得也是呢，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n大家說的對。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "馬廄是",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從這邊能夠看見的那棟建築物吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣應該不會迷路才對，",
        "unit_id": 105812,
        "voice": "vo_adv_2006008_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不用幫我們帶路沒關係哦～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好保重身體哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝妳們，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳們真的都好溫柔……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果不變強的話就無法生存下去，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但若不溫柔的話就連活著的資格也沒有。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我也想變得既溫柔，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又堅強呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一定，",
        "unit_id": 103811,
        "voice": "vo_adv_2006008_045"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要變得像大家一樣。",
        "unit_id": 103811
    }
]