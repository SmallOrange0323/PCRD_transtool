[
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哦……",
        "unit_id": 16011,
        "voice": "vo_adv_5090322_000"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "沒想到妳們竟能擊退我的收藏品。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "看來有一定的實力嘛。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "接下來就輪到你了，",
        "unit_id": 121611,
        "voice": "vo_adv_5090322_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "莫名其妙的西裝老頭！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哼哼哼……",
        "unit_id": 16011,
        "voice": "vo_adv_5090322_002"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n在那之前，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "先讓妳們看看有趣的東西吧！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖……！",
        "unit_id": 106511,
        "voice": "vo_adv_5090322_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那個混帳……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "竟然用「龍之卵」展開護盾……！！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "沒錯！",
        "unit_id": 16011,
        "voice": "vo_adv_5090322_004"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "這就是用「龍之卵」使出的絕對防禦護盾！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n我就在頭等席上",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "欣賞妳們白費力氣的掙扎吧！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種東西",
        "unit_id": 121611,
        "voice": "vo_adv_5090322_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼才好……！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不可以放棄喔，",
        "unit_id": 121511,
        "voice": "vo_adv_5090322_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "祈梨……！！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一定有方法",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可以解決的……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未未……！",
        "unit_id": 121611,
        "voice": "vo_adv_5090322_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……說得也是呢！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種東西，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n只要一直揍一直揍一直揍下去，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "遲早",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就能打破了！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈，",
        "unit_id": 106511,
        "voice": "vo_adv_5090322_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼簡單不是很好嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那我們",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拿出全力上吧！",
        "unit_id": 106511
    }
]