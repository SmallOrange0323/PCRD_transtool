        "voice": "vo_adv_5066004_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不用了。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我沒事了。",
        "unit_id": 116511
    },
    {
        "type": "background",
