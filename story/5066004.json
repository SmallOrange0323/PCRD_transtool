[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨一行人藉由回到過去，解決了許多接連發生的問題。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一天一天過去，幫派成員對祈梨的信任，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n已經晉升到了信仰的地步。"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大真的超厲害欸……",
        "unit_id": 811,
        "voice": "vo_adv_5066004_000"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "簡直像能看透未來似的！",
        "unit_id": 911,
        "voice": "vo_adv_5066004_001"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "不輸給",
        "unit_id": 6311,
        "voice": "vo_adv_5066004_002"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "上一任老大啊！",
        "unit_id": 6311
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我都聽到了唷，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些稱讚我的聲音……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就這樣讓家族擴張，超越從前……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n再由我統治一切吧……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳還好嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n發生那麼多事",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳也累了吧。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "稍微歇會兒啦。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒什麼大不了的啦……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只是在盡好老大的職責……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然妳這麼說……",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但這傢伙看起來也滿累的……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "……功能、",
        "unit_id": 14611,
        "voice": "vo_adv_5066004_007"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "沒有、",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "問題……",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳每次一有事就回到過去",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓它變成沒發生過……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不過更應該做的是",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "小心避免事情發生吧？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……妳想表達什麼？",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最好別再",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "使用時間儀了吧？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我跟妳說過沒關係了！",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n現在的我可是Big Boss唷。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "卑微的嘉夜夜要干涉老大的方針，",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還早了一百年啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "結果是白費唇舌",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不然老大，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我要休個假，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可以吧？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！？",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……在祈梨的頭腦冷靜下來前，",
        "unit_id": 116611,
        "voice": "vo_adv_5066004_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓我暫時離開吧。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n時間儀我就留在這了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜啦。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "夜……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "隨她去吧。",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n因為……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是老大。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我怎麼可能做出那麼沒面子的事！",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我可是Big Boss喔！？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且，",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要有了這個魔導具",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就是無敵的呢！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "反正嘉夜夜",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "肚子餓就會馬上回來了唷。",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大！",
        "unit_id": 811,
        "voice": "vo_adv_5066004_021"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "不好了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "隔壁那幫傢伙",
        "unit_id": 911,
        "voice": "vo_adv_5066004_022"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "闖進我們地盤找碴啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼！",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來得正好！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓他們看看我的實力！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n全體出擊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "跟我來唷！",
        "unit_id": 116511
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，幾小時後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n祈梨率領的幫派本應兇猛地衝向敵人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n現在卻被魔物不停追著跑。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼會變成這樣啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "對方",
        "unit_id": 811,
        "voice": "vo_adv_5066004_026"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "好像雇用了魔物使！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼我們會因為那點事就輸得這麼慘！？",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_027"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "抱歉，",
        "unit_id": 911,
        "voice": "vo_adv_5066004_028"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我們",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "對付人還可以，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "但還不習慣對付魔物……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "糟糕了",
        "unit_id": 6311,
        "voice": "vo_adv_5066004_029"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "老大！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "\n在所有人外出時",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "據點被攻下啦！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為、",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼呀啊啊啊啊啊！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚，",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是屈辱……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n地盤被占走還跟我們要賠償金……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "輸得一敗塗地啊……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "老大……",
        "unit_id": 811,
        "voice": "vo_adv_5066004_032"
    },
    {
        "type": "dialogue",
        "name": "流氓1",
        "words": "請別這麼消沉。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "我們一直贏到現在了啊，",
        "unit_id": 911,
        "voice": "vo_adv_5066004_033"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "偶爾也會發生一兩次這種狀況啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "這種時候",
        "unit_id": 6311,
        "voice": "vo_adv_5066004_034"
    },
    {
        "type": "dialogue",
        "name": "流氓3",
        "words": "要是嘉夜在就好了啊……",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "喂！",
        "unit_id": 911,
        "voice": "vo_adv_5066004_035"
    },
    {
        "type": "dialogue",
        "name": "流氓2",
        "words": "你啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……我想一個人靜靜。",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_036"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "確實是有點累了……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有沒有什麼可以讓人安心的地方……",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n很久沒去那家店了，來去看看！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂──！",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_039"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好久不見呀！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是、",
        "unit_id": 1511,
        "voice": "vo_adv_5066004_040"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是祈梨……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不對……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是老大……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呃，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是老大沒錯啦……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "您、",
        "unit_id": 1511,
        "voice": "vo_adv_5066004_042"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "您有",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "什麼事嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我已經交過保護費了……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是不是不夠呢？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不，",
        "unit_id": 116511,
        "voice": "vo_adv_5066004_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "並不是那樣……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "託老大的福",
        "unit_id": 1511,
        "voice": "vo_adv_5066004_044"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小店才能生意興隆……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n……所以，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那個，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不嫌棄的話",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "請收下這個如何？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n當然",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不會跟您收錢的……",
