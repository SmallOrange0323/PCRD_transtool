    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}正走在街上時――"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該怎麼辦才好呢～？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，{player}！",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是巧遇呢！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？　",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我看起來",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "面有難色嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其實我有點煩惱……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我覺得",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像還沒有讓小碧",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n見識到我像個前輩的樣子――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該怎麼做，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "才能更有前輩的風範呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說的也是呢～",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然還是得問小碧啊～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小碧希望我為她做什麼呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好！",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n既然這樣，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就直接去問本人吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}也一起來！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "――就是這樣，",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小碧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我來問妳了喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是這樣……",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "指的是哪樣啊！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而且不只初音，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "連{player}也……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那樣看著我的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊～",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不起對不起～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我不是有意要嚇妳的。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不會……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "被嚇到……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個，",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我有點事想要問小碧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為我",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "完全沒有前輩的樣子，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳覺得我該怎麼做，才能展現出前輩的風範呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦～！？　",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種問題要問我嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是要問！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我前陣子當嚮導時",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也在最後睡著了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我覺得這樣很糟糕――，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以一直很在意這件事。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此……",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我覺得沒那回事喔……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n初音妳，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是個很可靠的前輩。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯、",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真要說起來的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一直做得不好的，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實是我……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……？　",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小碧，怎麼了？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "發生什麼事了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實……",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我把今天交易的貨物",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n整理在文件上。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "計算時出了錯……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "造成了許多人的麻煩……",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n現在正在緊急地修改文件。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來是這樣啊……",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……對了！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那份文件現在在妳身上嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n讓我看一下！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就在這裡。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請看……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝～！",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我看看～……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮！　",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然～！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳看這裡。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "中間算錯了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "精靈之森的交易物品，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在每個城鎮都有不同價格喔～。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是但是，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謄寫在文件上的順序並非按照每個不同價格――。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以呢，",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不要同時計算……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要像這樣，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "盡量將",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n交易行情相同的城鎮集中……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "再分開計算各自的總數。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "最後再將那些數字加總計算看看？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……啊！",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣子的確",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "非常容易理解！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初音，",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n下次應該不會再算錯了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了！",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n有幫到妳的話",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就太好了～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……那、",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初音！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？　",
        "unit_id": 101211,
        "voice": "vo_adv_3009003_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼事？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n還有不清楚的地方嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是……",
        "unit_id": 104011,
        "voice": "vo_adv_3009003_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是那樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "初音妳～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
