[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖學祭也有很多攤販呢。",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "記得「清廉」隊是不公正手段的溫床呢。",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "結果而言",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來賓們是留下了深刻的記憶，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但只能說那也是理所當然的。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不不不，",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「賢淑」隊的攤販，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n雖然都是外行人，但也沒有比較差喔。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐的傲嬌女僕咖啡廳之類的！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "其他還有？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其他還有……",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒什麼印象深刻的。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是的，",
        "unit_id": 116411,
        "voice": "vo_adv_5064604_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "明年乾脆派遣克蘿依去所有攤販好了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聽起來很棒耶！",
        "unit_id": 116311,
        "voice": "vo_adv_5064604_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今年是短袖迷你裙的超可愛風格，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n明年就讓她穿雅致古典的正統派女僕裝吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這些傢伙自顧自地在說謝什麼啊……",
        "unit_id": 110813,
        "voice": "vo_adv_5064604_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110813
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總而言之明年的聖學祭就翹掉吧。",
        "unit_id": 110813
    }
]