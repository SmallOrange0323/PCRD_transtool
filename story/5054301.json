[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個巨大的雪人，",
        "unit_id": 114511,
        "voice": "vo_adv_5054301_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是設置在會場入口的雪人吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然外觀相差很多……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似乎是為了避人耳目，而進行過偽裝。",
        "unit_id": 114611,
        "voice": "vo_adv_5054301_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n真是計畫周全呢。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再鎮密的企劃書，",
        "unit_id": 114411,
        "voice": "vo_adv_5054301_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只要是出自惡徒之手，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就一律駁回！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說得沒錯。",
        "unit_id": 114511,
        "voice": "vo_adv_5054301_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種淨給人添麻煩的計畫，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就讓它徹底泡湯吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "另外，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還要和這傢伙索討",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "損害賠償金呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然如此，",
        "unit_id": 114611,
        "voice": "vo_adv_5054301_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請款單就交給我來寫吧！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼大家，",
        "unit_id": 114411,
        "voice": "vo_adv_5054301_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n為了讓派對重新開始，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們各就各位，開始工作吧！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "咲戀、優花梨",
        "words": "了解！",
        "unit_id": 1,
        "voice": "vo_adv_5054301_006"
    }
]