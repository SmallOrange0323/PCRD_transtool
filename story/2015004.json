        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睜開",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙眼吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您如同平時一般，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫柔地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "撫摸在下的頭吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n倘若，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠實現這個願望……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算要在下，",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向您獻上所有的一切也在所不惜……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以請您……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您……",
        "unit_id": 105911
    },
