        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳說的沒錯……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起唷，",
        "unit_id": 104911,
        "voice": "vo_adv_2015004_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐竟然沒辦法保護你。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐這麼沒用，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是對不起呢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……所以，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "至少……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥的這一箭之仇……",
        "unit_id": 101112,
        "voice": "vo_adv_2015004_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就由我們",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來報……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵……",
        "unit_id": 106915,
        "voice": "vo_adv_2015004_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵哈哈哈！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n雖然你們的實力",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "依舊如此無趣……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "――但那顫抖的雙唇。",
        "unit_id": 106915,
        "voice": "vo_adv_2015004_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "咬著牙的憤恨模樣。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n再加上，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一雙雙因哀傷",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而混濁不清的眼睛……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……在這無趣的戰鬥之中，",
        "unit_id": 106915,
        "voice": "vo_adv_2015004_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "反倒稱得上是我所喜愛的景象了唷。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n好了……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "過來吧。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就由我這個「神」來親手",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將你們全都送去跟他一樣的地方吧！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗚啊啊啊啊啊――！！",
        "unit_id": 1,
        "voice": "vo_adv_2015004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，",
        "unit_id": 100211,
        "voice": "vo_adv_2015004_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起唷，騎士先生……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這都是因為",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我力量不足……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚、",
        "unit_id": 105811,
        "voice": "vo_adv_2015004_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你沒有替我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "擋下那一擊的話……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果我",
        "unit_id": 106011,
        "voice": "vo_adv_2015004_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠阻止陛下的話……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "怜、日和",
        "words": "呀啊啊～～！",
        "unit_id": 1,
        "voice": "vo_adv_2015004_043"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜、",
        "unit_id": 100211,
        "voice": "vo_adv_2015004_044"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再這麼下去",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就連她們倆也會……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我馬上就會回到你身邊的！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……即使大家",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拚了命戰鬥……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而對上霸瞳皇帝時，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若沒有主人的力量……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚哇啊～！！",
        "unit_id": 104311,
        "voice": "vo_adv_2015004_047"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呀啊啊～！！",
        "unit_id": 104911,
        "voice": "vo_adv_2015004_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊啊……！",
        "unit_id": 105811,
        "voice": "vo_adv_2015004_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一位",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著一位……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身受重傷",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而倒下。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其中也不乏，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早已無法以一己之力站起身的人了吧……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊啊，",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟是如此軟弱無能啊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅沒有拯救大家的力量……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就連",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引導主人走到最後也……",
        "unit_id": 105911
    },
    {
        "type": "still",
        "still": "201500402"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人……",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您為何",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不睜開眼睛呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做了什麼讓您感到困擾的事情嗎……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然得在此處與您分別，",
        "unit_id": 105911,
        "voice": "vo_adv_2015004_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下無法接受。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不是都約定好了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論天涯海角在下都會與您相伴的嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下不希望讓此處",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成為在下引導您抵達的最後終點……",
        "unit_id": 105911
    },
