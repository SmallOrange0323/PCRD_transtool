        "voice": "vo_adv_1380001_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呼……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n拿、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "拿刀",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真讓人緊張……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "手，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "忍不住發抖……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "明明以我的身體來說，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就算切掉",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一、兩根手指",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也沒關係的……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾國際博覽會"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "舉辦前不久──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n薇歐莉特跟"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一起\n握著菜刀。"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──騎士氏，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "謝謝你願意為薇歐莉特公主",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n上烹飪課。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那當然。",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_002"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……畢竟我們家公主，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "最近很拼命。",
        "unit_id": 133012
    },
    {
        "type": "background",
        "background": "502480"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "怎麼辦，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "怎麼辦……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "都已經",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "找不到適合進行料理對決的食材了，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n竟然還要由我",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這個沒做過料理的人",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "站上廚房……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "畢竟我們國家",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "有很多像殭屍跟幽靈",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這類不需要進食的種族呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我覺得沒有烹飪經驗",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "也是無可奈何的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "即便如此，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_005"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也不能拿這當作不會烹飪的理由吧？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n必須去尋找食材，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "同時也要練習烹飪……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n可是，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也沒剩多少時間了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "該怎麼辦……",
        "unit_id": 133111
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……總之因為這樣，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_006"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "她看起來相當緊繃，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我希望她能好好放鬆身心，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "並拿出成果。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "所以說騎士氏，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_007"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n請幫我們的公主",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "建立一點自信心吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個……",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n所謂的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "十字切，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "該怎麼做才好呢……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎、",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_009"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n為什麼",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "要從後方抱過來……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這就是所謂的",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_010"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "手把手指導吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n不愧是騎士氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "支援技能真讓人安心。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但是",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒有不良意圖",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "＆",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "毫無自覺這點也很可怕。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可、",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這樣的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我會緊張起來……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就更",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "手忙腳亂……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請保持冷靜，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這只是為了學會器具的使用方法。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過就算兩位直接接吻，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "小格蕾也完全無所謂就是。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不要讓我更在意！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "蔬菜",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會被我切壞的……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "啊啊！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_014"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真的要拿這個生物",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來熬高湯嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "觸感非常地黏滑呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那個海參",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "在鬼族之間，似乎是有名的珍饈呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "在蘭德索爾會使用",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "海參高湯嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是、",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_016"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我國的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "飲食文化",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然很特別呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呀！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "海、",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_017"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "海參滑掉了……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "等等！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n別想逃跑──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "啊啊！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "痛痛痛……",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_018"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n對不起，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我太過慌張，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就踩到禮服下襬了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呃，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_019"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n騎士先生去哪了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏的話，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_020"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就在妳的屁股下面。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n妳看。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "咦？",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_021"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……呀！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n真對不起，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我居然對騎士先生的臉",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "做出這種事……！",
