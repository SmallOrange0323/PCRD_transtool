    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n即使算不上順利，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但步驟和處理方式本身沒有錯。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "畢竟我們的公主是一本正經，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_050"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不會在食材上冒險的類型。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n只要味覺沒什麼大問題，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "應該是不會失敗的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是、",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_051"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是這樣嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……難道",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_052"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是我……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n給自己太多壓力了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是嗎。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "身為背負國家之人，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_053"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n不能讓人民蒙羞……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n是這份念頭",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "過於迫切了嗎……？　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒錯。",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_054"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然包含食材的事在內，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "的確還有一堆問題要思考……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但那些就等之後再想吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "妳身為公主，",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_055"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只要維持威儀就夠了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這樣子，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "部下也比較能夠安心。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_056"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……說得也對呢。",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_057"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "光是焦急",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也沒用。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "作為公主，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我會把問題",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一個個解決掉的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "所以兩位，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_058"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "今後也請務必",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "多多鞭策、指教～！！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n還有",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那麼，",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_059"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "事不宜遲……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n再來做一次",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "蔬菜的前置處理吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我要開始了……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "等等。",
        "unit_id": 133012,
        "voice": "vo_adv_1380001_060"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n菫，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "握柄",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是另一邊──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "啊啊……！？",
        "unit_id": 133111,
        "voice": "vo_adv_1380001_061"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n手、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "手指──！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管發生了一些狀況──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是這之後也積極練習"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "的薇歐莉特，\n總算在正式對決前"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "掌握了烹飪技術。"
    }
]