    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "喔喔，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這不是怜小姐嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n在前陣子的宴席上才剛見過……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "別來無恙啊？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "您家老爺正在找您呢？",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_038"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "真是找得眼都紅了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "沒想到居然在這種地方。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "正好。",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_039"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就請您和那位女孩一同移駕這趟吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "您家老爺肯定也會笑逐顏開的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "閉嘴！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "誰要回去那種家裡！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要一看到像你這種，",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以為全世界的一切\n都會照自己意思走的傲慢之人，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我心中的怒火就無法壓抑！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "以為全世界的一切都會照自己意思走？",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_042"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "……呵、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "呵呵呵、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈哈哈哈！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你笑什麼！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼好笑的！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "您是用什麼立場說這話呢……",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_044"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "真要說起來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "您拒絕我的提親才是原因吧？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說什麼……？",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_045"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_046"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "連這點自覺都沒有嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n和我比起來，妳才更加傲慢！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "提親被顏面盡失地拒絕，",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_047"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "在整個家族面前丟臉的我，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n現在正拼命在找結婚對象。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "到底有什麼不對的！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確在之前，",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "爸爸有介紹聯姻的人選。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我說，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對那種事沒有興趣，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就全部回絕掉了……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "怜小姐。",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_049"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "要不是因為妳任性拒絕我的提親，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n那兩人現在就不會遭到這種事情囉？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "還是說，",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_050"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "妳要負起責任跟我結婚嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明白。",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是詭辯。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他那綁架犯一樣的惡行，\n把女子強行擄走，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確是不由分說的事實……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說我的行為，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "導致他做出這種事，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n難道這也是事實嗎……？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我只是！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "沒錯！",
        "unit_id": 411,
        "voice": "vo_adv_1089002_055"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這女孩",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不打算回應任何人的提親啊！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n是這樣吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊、是啊……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這樣。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而你是把我的未婚妻，",
        "unit_id": 311,
        "voice": "vo_adv_1089002_057"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不經她同意就擄走了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那只是單純的綁架！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就算身為貴族，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "犯罪還是犯罪！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你們兩個……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這樣。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像你們說的。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽清楚了！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你蠻橫的暴行，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我絕不原諒！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "咿嗚！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_060"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "什麼啊，這什麼鬧劇啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n掃興！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "真掃興啊！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "喂！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_061"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "把他們痛揍一頓！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n不用手下留情了！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "遵命！",
        "unit_id": 911,
        "voice": "vo_adv_1089002_062"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "你們幾個，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "別想活著回去啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你啊！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能借我力量嗎？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要打就儘管來！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "別太囂張啦！",
        "unit_id": 911,
        "voice": "vo_adv_1089002_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──真弱呢！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "咕啊啊啊啊啊啊！！",
        "unit_id": 911,
        "voice": "vo_adv_1089002_067"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "騙人的吧……？",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_068"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "她有這麼強嗎……！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在可不只我的力量……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這是他交給我，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了一同向前邁進的力量！！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "認命吧！！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊啊啊啊啊啊！！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "咿呀啊啊啊啊！！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又被你幫了一次，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你的話讓我清醒了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在我陷入迷惘的時候。",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "500024"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "可惡────！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_074"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "可惡，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "可惡！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我已經手下留情了。",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不准再靠近我跟那些人。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次姑且放過你們。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "是嗎……",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_076"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你就是傳聞中的對象嗎……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這種看就知道很沒用的軟爛男人竟然比我好嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "傳聞中的對象？",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_077"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的是他？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不要小看我的情報網！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_078"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我可是一直都有在調查的！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "粉絲俱樂部的女會員們，八卦起來可是滔滔不絕的！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_079"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "「怜大人已經有心儀的對象了」什麼的！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "粉絲俱樂部……？",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_080"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "她們居然還把我說成寄生蟲……",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_081"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
