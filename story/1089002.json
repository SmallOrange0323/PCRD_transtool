    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "好不容易將追兵甩開的怜與{player}，\n繼續著不能被發現的逃亡之旅。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經離開城區很遠了，",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也感覺不到追兵……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就在這邊休息一會好了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "求求你！",
        "unit_id": 411,
        "voice": "vo_adv_1089002_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不要再這樣了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你給我差不多一點啊……",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_002"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "快回到馬車上。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "總、",
        "unit_id": 311,
        "voice": "vo_adv_1089002_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "總算追上了……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "把她還回來！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你這邪門歪道！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊啊，",
        "unit_id": 411,
        "voice": "vo_adv_1089002_004"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你追來了呢……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你說誰邪門歪道？",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_005"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我可是拯救了這位從馬車上跳下的女子，你在說我嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼可能。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是他為什麼會在這裡？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與其說是認識……",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那位貴族，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我在之前的舞會上有見過……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "當然就是在說你啊！",
        "unit_id": 311,
        "voice": "vo_adv_1089002_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n分明是你不顧她的抗拒，強行將她帶上馬車！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我相信你會來救我，",
        "unit_id": 411,
        "voice": "vo_adv_1089002_009"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一直都相信著……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道那貴族，",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要強迫那位女性跟他結婚？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_011"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "真是的，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那種村夫野老有哪裡好啊？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "明明跟我結婚肯定會幸福一輩子的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我有",
        "unit_id": 411,
        "voice": "vo_adv_1089002_012"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一個訂下終生的婚約者，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我應該早就說過了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我只要和這個人一起，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "只要一點小小的幸福就足夠了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒錯！",
        "unit_id": 311,
        "voice": "vo_adv_1089002_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱持著這種想法的她跟你結婚，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不可能會幸福的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "放尊重點啊，平民們。",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_014"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你的一舉一動，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n可能會在哪天讓家人或是鄰居遭遇不幸喔？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "當然",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那邊那個男的也是。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "什麼……！",
        "unit_id": 311,
        "voice": "vo_adv_1089002_015"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真、",
        "unit_id": 411,
        "voice": "vo_adv_1089002_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真是非常對不起……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "拜託，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請您息怒吧……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "對了。",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_017"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這樣才對。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "只要有錢有權，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就算她受了傷\n也能馬上叫到醫生，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "房子壞了也立刻就能修理。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "但",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "像你這種什麼都沒有的窮光蛋",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "辦得到嗎……？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這邪門歪道……！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是……！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然你說的沒錯……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這邊引起騷動，",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確會引起追兵們的注意，這點我知道。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算這樣，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也這麼想嗎？",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一起把那傢伙……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不，不行。",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在引起騷動的話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會被追兵發現。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼辦……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "只要權勢財力在手，什麼都辦得到。",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_023"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "連世界都可以改變啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "也就是說，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這種事很簡單就能解決。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "各位！",
        "unit_id": 2511,
        "voice": "vo_adv_1089002_024"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "把她帶到馬車上。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "在這之前……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "把那男的狠狠教訓一番。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "遵命。",
        "unit_id": 911,
        "voice": "vo_adv_1089002_025"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "敢跟這位大人叫囂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "算你倒楣啦小兄弟。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "我會手下留情留個活口的。",
        "unit_id": 911,
        "voice": "vo_adv_1089002_026"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "只是可能會不小心手滑了也說不定喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不能原諒。",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能原諒就這樣袖手旁觀的自己！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可惡……！",
        "unit_id": 311,
        "voice": "vo_adv_1089002_028"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這種……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這種暴行誰能容忍啊！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "誰啊，",
        "unit_id": 411,
        "voice": "vo_adv_1089002_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "誰來救救我們！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請救救我們！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "不可能有人來幫忙的啦！",
        "unit_id": 911,
        "voice": "vo_adv_1089002_030"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "喝啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──喝啊啊啊啊！！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_031"
    },
    {
        "type": "background",
        "background": "500024"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "唔喔！？",
        "unit_id": 911,
        "voice": "vo_adv_1089002_032"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "搞什麼啊這傢伙！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你們幾個退下！",
        "unit_id": 108911,
        "voice": "vo_adv_1089002_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "快點！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好，",
