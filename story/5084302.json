[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "找到了！",
        "unit_id": 106411,
        "voice": "vo_adv_5084302_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……感覺比剛才的傢伙強呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們三人打得贏嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在那說什麼喪氣話啦。",
        "unit_id": 106011,
        "voice": "vo_adv_5084302_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都已經來到這裡了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能還夾著尾巴逃跑呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管沒有主人的力量相助確實會有點辛苦，",
        "unit_id": 105911,
        "voice": "vo_adv_5084302_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但老是依賴貪吃佩可小姐和主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也非好現象。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓我們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "靠自己的力量完成討伐吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……確實，",
        "unit_id": 106411,
        "voice": "vo_adv_5084302_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有道理。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我明白了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "兩位，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拜託妳們幫忙了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交給我吧！",
        "unit_id": 106011,
        "voice": "vo_adv_5084302_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n後方有我在，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳大可不用擔心！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下則會伴在雪菲小姐身旁。",
        "unit_id": 105911,
        "voice": "vo_adv_5084302_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請盡情地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使出全力吧！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好！",
        "unit_id": 106411,
        "voice": "vo_adv_5084302_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想想，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這種時候，貪吃佩可小姐通常會說……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以不用再模仿她了啦。",
        "unit_id": 106011,
        "voice": "vo_adv_5084302_007"
    }
]