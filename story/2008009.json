[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該從哪裡說起好呢……",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉，可能會有點難懂但還是想先問看看。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對這個世界，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有感到過什麼違和感嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不自然的地形、",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "社會制度、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "歷史、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不知道為何異常發達的武器、防具還有攻擊魔法……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "照常理來思考",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "且試著指謫怪異之處的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是數也數不清。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哈……",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼一說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎真的是這樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n同意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是普通地過著生活，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也經常會遇上些許的不便。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了應付最低限度的日常生活",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所必要的事物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也有直到近年",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來才慌張的準備齊全的感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這之前，",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人們究竟是如何過生活的……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甚至該說是真有辦法就此過上生活嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣的疑問也經常浮現於腦海之中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而生活上非必要的種種武器，",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻異常的充實。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "簡直就像是在不久前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每個人都為了戰爭，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是危險的冒險上費盡了心力一樣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "卻沒有任何像是那樣的記錄呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來確實挺奇妙的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而。",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n卻沒有任何人，對此抱持著疑問。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對……",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算自己試著思考，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一旦開始想這些事時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "思考好像就會停止下來？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就變得無法意識到這件事了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明覺得很奇怪。",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但只要有疑問時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會在腦袋裡得到某種解釋，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後就坦然接受了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是因為這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以再去想也不是辦法……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一這麼想之後",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "思考就會停了下來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是為什麼呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像是誰在操弄著自己的腦袋一樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺很不舒服呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像現在也一樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這種事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有更多其它重要的事情吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自然而然，思緒就被牽著鼻子走的感覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是不是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為吃得太多了所以想睡了呢？之類的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會更在意",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人正在打瞌睡的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就像是小嬰兒一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人…",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好可愛……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊！",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否該替主人準備床鋪呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像這樣的想法不斷浮現在腦海裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，目前並不是考慮這些事情的時候呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現在，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "希望你們能夠專注於這重要世界的祕密上。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣的說明，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然不知道你們是否能夠理解。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我們、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界上生活的人們",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幾乎沒有例外，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都同時被一個群體幻覺影響著。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就像是大家，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "做著同一個扭曲的夢境。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夢境……？",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不太明白。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想也是呢。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再說",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "正確來講與其說是夢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該說是遊戲的世界才對。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但如果用了這樣的表現，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "反而會更加混亂吧……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了先讓大家比較好懂",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是先當成是夢境吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎～",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然我很不擅長這種說明啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀如果在這的話就好了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘴巴特別厲害，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以只要扔給他解釋應該就輕鬆多了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是現在，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙也不在嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以只好靠我自己，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再加把勁來說明了。",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200800901"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想想。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個當下，我們每一個人都正在做夢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n並且，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被囚禁在這個夢中無法醒來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對我們來說",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真正的現實則另有別處。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "記得沒錯拉比林斯達，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大概有說過類似的事情……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們大家，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有沒有曾經做過些奇怪的夢呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "與我們所知道的這個世界完全不同，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個格外令人懷念的世界……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n哭著笑著也憤怒著，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "過著普通生活的自己的夢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……確實，",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有此印象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為是在做夢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以只留下相當曖昧模糊的印象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在夢裡有著相似卻不同的名字與樣貌……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但卻理所當然地生活，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對此感到困惑。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莫非，",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個夢境……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個夢境才是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人的現實嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人所生活著的、",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如此深信著的這個世界才是夢境……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被在下等人認為是夢境的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才是為真正的現實……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的事情是有可能發生的嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，腦袋都快轉不過來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但卻不可思議的，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得能夠接受這個事實呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也無數次做過像是那樣子的夢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每次做那種夢時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道為什麼都有種安心感。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，這個才是現實。",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有種這才是真正的自己的實感。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然也想過，是因為自己的立場和名字都被奪走，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感到徬徨無助才會這樣想。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但也許是因為夢裡才是我真正的現實，",
        "unit_id": 105812,
        "voice": "vo_adv_2008009_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會有那樣的感覺吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個感覺是正確的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然聽起來像是騙人的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但那就是事實。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然沒有什麼能證明的證據……",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也不覺得這種像是青春期妄想的事情",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳們能馬上相信。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我用了超能力……",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像是一種特別的魔法。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我用了那個誰也模仿不來的力量，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在所有事情開始改變的決定性瞬間，保護了自己的記憶。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但因為事情實在太突然，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "光只是顧好自己就用盡了全力……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在也還是非常後悔、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "非常不甘心，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼也沒想到會演變成這樣的事態。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是說……",
        "unit_id": 105913,
        "voice": "vo_adv_2008009_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n矛依未小姐，妳仍保留著那『真正的現實』的記憶嗎？",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為太突然，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個想也想不到的巨大力量產生了炸裂……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以沒有辦法完全保護所有的記憶，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因此記憶中還是有欠缺的部分。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但絕大多數的事物都還記得。",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是絕對，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不想忘記的重要記憶。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而這樣的存在，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個世界中似乎除了我之外也沒有其他人了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n明明我說的就是真的事情，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n卻被當成散播著自己妄想的怪人一樣。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也有即使不及我，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n卻殘留著少量記憶，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "或能夠模糊地想起來的人……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個【拉比林斯】的首領，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉比林斯達她就是其中之一。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在我正與她們這樣的人們聯手，",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n試圖想要將這個",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "變得奇怪的世界恢復原狀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種狀況絕對不自然，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不想辦法解決可不行。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且被尾狗刀……",
        "unit_id": 106112,
        "voice": "vo_adv_2008009_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被重要的夥伴忘得一乾二淨，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也相當的難受呢。",
        "unit_id": 106112
    }
]