[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "12月24日、クレジッタと秘書１号はクリスマスで賑わう飲食店で"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n顔を突き合わせていた。"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……はぁ。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_000"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "食欲がないのですか？　",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "クレジッタさま。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "せっかくの特上肉ですのに。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "いらないのでしたら私が──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "食べますわよ！　",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_002"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "勝手に特上頼まれたうえに",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしの分まで取られたんじゃたまりませんわ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "今の溜め息は……",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_003"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "その。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n陛下のことを考えていただけですわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そういえば今日は、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "あの少年と遊びに行ってるはずですね。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nもしかして",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下のことが心配なのですか？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そうではありません。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_005"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下の強さは今さら語るまでもありませんし、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n少年に関しましても、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "悔しいですがわたくしより余程信頼されてます。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そして彼がその信頼を裏切ることもありえませんね。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_006"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……チクリとしますわね貴女の言葉はまったく。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "その通りですわよ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "ではなぜ。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_008"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nそんな筋ばかりの肉を食べたみたいな",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n浮かない顔をしてるのか──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "元はといえば",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_009"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "クレジッタさまの進めたイベントがご満足いただけず、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そのせいで古代遺物に付け込まれてしまいましたし。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "結果的に名誉挽回の機会を得て、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下の理想のクリスマスを",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n叶えることができていますが、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一歩間違えば大惨事でした。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n本当に大変でしたけどね。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……さっくりかつ的確にまとめないでくださる？",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "走馬灯のごとく記憶がよみがえって、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nまた頭が痛くなってまいりましたわ……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "でもその通りですわ。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_012"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n明日のクリスマス本番が上手くいかなかったら、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n陛下はきっと自分を責めてしまわれる……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そう思うと",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_013"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "胸が苦しくて……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……食べすぎでしたら",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_014"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "肉はいただきますが。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "違いますわよ！！",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_015"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nわたくしは",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "明日のイベントのことと",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n陛下のことを心配しているんですのよ！！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そうそう、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_016"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そのお顔です。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "しおらしく心配しているより、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そうやって騒いでいる方が",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nクレジッタさまらしいですよ。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "今回のクリスマス、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_017"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "私は必ず成功すると思っています。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nそして万が一失敗した場合は、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "私も一緒に",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "次の策を考えます。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "だからどうか、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "あなたはいつも通り堂々としていてください。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "自信を持って、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下や少年と",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "最高のクリスマスを楽しみましょう。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nきっとそれが、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "成功への近道です。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まったく、",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_019"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女ときたら。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nいつもいつも、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "１から10まで知ったような口をききますわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "当然です。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_020"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "私はクレジッタ・キャッシュの秘書ですから。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n円滑なサポートが私の仕事です。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……どうやらわたくしは、",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_021"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "いい秘書に恵まれたようですわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "ええ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一流の商人には",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一流の秘書が不可欠ですからね。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "待遇の改善もご検討ください。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "希望としては",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "このくらい……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ、",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_023"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ええ！　",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "貴女はそういう人でしたわよね！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "まあ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "今回ばかりは",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ボーナスくらいつけさせていただきますわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "さすがクレジッタさまです。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_024"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "あ、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "すみません、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "こちらの特選肉セット、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nそれと",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "特上海鮮盛りを追加でお願いします。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "少しは遠慮も覚えてくださります！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_025"
    }
]