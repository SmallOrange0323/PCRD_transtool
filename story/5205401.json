    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總算是結束了……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比起這個，華音！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n妳在戰鬥中，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好幾次想連我一起攻擊對吧！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哎～",
        "unit_id": 134912,
        "voice": "vo_adv_5205401_001"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呀是這樣嗎？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "難道不是妳被本小姐的華麗攻擊給迷住，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n像隻被花蜜吸引",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "的蝴蝶般主動撞上來的嗎？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哪有可能發生那種事啊！",
        "unit_id": 134812,
        "voice": "vo_adv_5205401_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n看來雖然敵人被打倒了，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但戰鬥似乎還沒有結束呢……！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哼，",
        "unit_id": 134912,
        "voice": "vo_adv_5205401_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "想開打嗎？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐可是一點都不介意哦！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "畢竟妳剛剛用絲線把本小姐綁起來丟向敵人的帳還沒跟妳算呢！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "妳這傢伙～～～！",
        "unit_id": 134912,
        "voice": "vo_adv_5205401_004"
    }
]