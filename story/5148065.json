    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真的是UFO呢。",
        "unit_id": 131111,
        "voice": "vo_adv_5148065_000"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這很不妙吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "蘭法小姐雖然嚇到了，",
        "unit_id": 131611,
        "voice": "vo_adv_5148065_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "美空小姐卻在笑呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n該說您真的很厲害嗎，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "十分臨危不亂呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還好啦～",
        "unit_id": 131213,
        "voice": "vo_adv_5148065_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "難得有機會遇到，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我還想是不是應該把它射下來比較好啊～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不過我被蘭法姐阻止了就是。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那樣",
        "unit_id": 131213,
        "voice": "vo_adv_5148065_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我們應該能獲得",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n新的科技之類的？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然我不是很喜歡實驗，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是我有好奇心啊。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小美空，",
        "unit_id": 131111,
        "voice": "vo_adv_5148065_004"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "妳過激的地方跑出來了喔～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n要是發展成跟UFO的戰鬥，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "就不妙了啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n要叫姐姐來，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "用不妙對抗不妙才行啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那可能會是危及蘭德索爾存亡的危機呢。",
        "unit_id": 131611,
        "voice": "vo_adv_5148065_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有蘭法小姐在",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是太好了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是說，",
        "unit_id": 131111,
        "voice": "vo_adv_5148065_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "飄浮在空中的……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是小優花梨吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n她好像被UFO吸走了～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的……",
        "unit_id": 131611,
        "voice": "vo_adv_5148065_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我很在意她之後的狀況。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n優花梨小姐",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有平安回來嗎……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她看起來很有精神喔★",
        "unit_id": 131213,
        "voice": "vo_adv_5148065_008"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "她說她覺得輕飄飄的呢～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n臉也有點紅，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "講話也口齒不清。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊～",
        "unit_id": 131111,
        "voice": "vo_adv_5148065_009"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n那完全就是被改造了啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 131611,
        "voice": "vo_adv_5148065_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個的原因應該是麥酒吧？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看來是平常的優花梨小姐，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓我放心了。",
        "unit_id": 131611
    },
    {
        "type": "still",
        "still": "end"
    }
