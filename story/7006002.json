    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……{player}。\n……老實告訴我。",
        "unit_id": 102811,
        "voice": "vo_adv_7006002_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你對秋乃做了什麼事？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來如此，",
        "unit_id": 102811,
        "voice": "vo_adv_7006002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼都沒做、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……那個，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛好有這個機會就來教教你吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……{player}說的",
        "unit_id": 102811,
        "voice": "vo_adv_7006002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n『什麼都沒做』，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一點都靠不住！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "快點，",
        "unit_id": 102811,
        "voice": "vo_adv_7006002_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說吧！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你對秋乃做了什麼事！！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
