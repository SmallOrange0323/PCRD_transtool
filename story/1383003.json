    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "重建活動告一段落，{player}他們\n為了修復「皇家裝備」的劍，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "四處走訪蘭德索爾的鐵匠鋪。"
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧三男",
        "words": "啊……",
        "unit_id": 811,
        "voice": "vo_adv_1383003_000"
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧三男",
        "words": "沒辦法呢。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧次男",
        "words": "……辦不到。",
        "unit_id": 6311,
        "voice": "vo_adv_1383003_001"
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "嗯～～～～～～～～",
        "unit_id": 911,
        "voice": "vo_adv_1383003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼樣？",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的貪吃劍，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "修得好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "……這是我沒看過的金屬",
        "unit_id": 911,
        "voice": "vo_adv_1383003_004"
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "和技術。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "不是普通手法能夠修得好的東西。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "所以說，",
        "unit_id": 911,
        "voice": "vo_adv_1383003_005"
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "我投降。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鐵匠‧長男",
        "words": "辦不到辦不到。",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家都說沒辦法呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "製作「皇家裝備」的人──",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是能聯絡到拉比林斯達小姐的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就能獲得線索了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是在聯絡上之前，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這樣放著不管的話，感覺也很可憐……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想為它做點什麼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然折斷時",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還說了「至今為止謝謝你了！」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種話。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但觸碰它的時候……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得它好像很失落。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哎呀。",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看你的眼神好像覺得很不可思議呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我偶爾",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠感受到它的心情喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當然，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也可能只是我的妄想。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只靠我們的知識實在無法解決，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這時候就借助大家的力量吧！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500360"
    },
