        "voice": "vo_adv_1383003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不愧是「皇家裝備」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱著姑且一試的心態去了玩具工廠，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n卻被以「傳說級武器沒有使用說明書所以沒辦法」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為理由拒絕了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可是重大事件……！",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n得要填飽肚子才能做大事！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先來吃晚餐吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。「老樣子」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩你了～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～♪",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然熱騰騰的飯糰也很好吃，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但冷卻後入味的飯糰",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也十分美味呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雙手合十──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要開動～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊。",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒什麼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我要開動～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "～～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然不是錯覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛才，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的肚子叫了對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我的貪吃劍！",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像聽到了！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──是啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為自從折斷後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就什麼都沒有吃嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──我懂，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "餓到不行的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼東西看起來都很美味對吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──我要再次向你道歉，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起旅行時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很抱歉",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咬了你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你願意的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們平分飯糰吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──所以說呢，",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我黏、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我黏、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我黏☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n希望可以黏起來～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係。",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這只是在許願。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說不定會發生奇蹟──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n貪吃劍的樣子……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇！？",
        "unit_id": 105812,
        "voice": "vo_adv_1383003_027"
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "個……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "黏起來了！",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它吃的",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是「至高飯糰」喔？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也就是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「連結的心意」",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "本身。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才會接了起來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……看起來不像是完全修復了呢。",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是好不容易治好感冒，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n體力還沒完全恢復的狀態嗎。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是我，這時候……",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃東西☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我先吃，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再讓它吃。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要這樣反覆進食，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定可以恢復精神！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "出發狩獵吧～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食物送上門了♪",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要開動了～☆",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_036"
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要開動了～☆",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_037"
    },
    {
        "type": "background",
        "background": "500521"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要開動了～☆",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_038"
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呼。",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個貪吃鬼♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明吃了這麼多魔物肉，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子又餓得咕嚕咕嚕叫了～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來已經沒事了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n狩獵完",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就吃掉",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再餵它。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然不知道像這樣反覆幾次了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過似乎已經完全恢復了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像蘭德索爾國民",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "成功淨化梅莉莎小姐的毒素一樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「至高飯糰」",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎為它帶來了力量。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「至高飯糰」",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會給予蘭德索爾的國民們力量。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以對它也是──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你也是，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和我們連繫著呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是這麼想的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那時候，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它是不是在吃光國民的力量前",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「故意斷掉」了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸欸，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃劍？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是這樣呢～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你可以像剛剛的肚子叫那樣",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回應我喔～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "暴食",
        "words": "────",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼怕羞☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那我就當作是這樣囉～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……還有，",
        "unit_id": 105811,
        "voice": "vo_adv_1383003_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是肚子又餓了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不用客氣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以直接",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟我說",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「還要再吃」喔。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為你也是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我重要的夥伴。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將復活的「皇家裝備」擁入懷中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那是"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對【美食殿堂】夥伴所做出的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "溫柔擁抱。"
    }
]