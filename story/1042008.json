[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為作曲而煩惱的千歌，\n為了轉換心情而出門散步。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唉……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要把自己的心情寫出來，真是出乎意料之外的辛苦呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n到中途為止本來還很順利的說……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這種時候，如果能遇到那個人的話……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？\n",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你、你在散步嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真是巧呢。我也是想出門稍微走走……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在正好是在創作詞曲的途中……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就是為此而想轉換一下心情。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然稍微有點碰壁，",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但我一定會將它完成的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "到時候請你一定要聽看看喔。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呀！",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好刺眼……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個光，是之前的！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為什麼在這個時候……！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_006"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好。",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n今天你是來散步的嗎？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我接下來要去打工……",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "地點是位在前方的一間爵士風喫茶店。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個！",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果可以的話，你要不要一起來呢？",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我之前所說的歌曲已經完成了，所以希望你能來聽……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你！",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那麼，我帶你去店裡吧。",
        "unit_id": 104232
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然還沒到開店時間，",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是我已經獲得店長的許可，所以請不用在意進來吧。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，我就開始演奏了喔。",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n特別為了你，獻唱這首歌……",
        "unit_id": 104232
    },
    {
        "type": "still",
        "still": "104200801"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你、你覺得如何呢？",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是這樣子嗎？",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說的話，這還是你第一次聽到我演奏樂器呢。",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是的……我的歌可不是安眠曲啊？",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，我能唱出那麼安詳的歌聲，真是太好了。",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，不對，不是這個！",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想聽的不是這種感想……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……那個，你、你覺得歌詞怎麼樣？",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我……試著將某種心情蘊含在裡面……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真、真的嗎！？",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼說的話……那個……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你知道了吧？我的心意……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、那個……嗯……",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果可以的話……我想知道，你的回答……",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……嗚、啊、啊啊啊啊！",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、不行了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n太害羞了，我忍不住了！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、對不起！",
        "unit_id": 104232,
        "voice": "vo_adv_1042008_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我今天先回家了！店長對不起！",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104232
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我身體突然有點不太舒服，先回家了！",
        "unit_id": 104232
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n其實並不知道那首歌的意義吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哈，",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是因為這樣才說你是木頭……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那首歌啊，可是千歌努力寫出來，",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且鼓起勇氣唱出來的喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是因為她有想要向你傳達的事情啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果她還會再唱給你聽的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到時你可一定要仔細聽啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n知道了嗎？絕對要喔！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。既然你了解的話，這次就先這樣吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1042008_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……咦、咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_029"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……在寫歌的時候……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不知不覺竟然睡著了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……可是，剛剛的夢到底是……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "夢裡所唱的歌曲，雖然是我現在正在寫的歌曲……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但好像完成了呢……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "歌詞現在也很清楚地留在腦海裡……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才剛寫到一半的歌詞，竟然在夢裡已經完成了……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_032"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "該不會，現在的不只是單純的夢……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……夢的事情雖然很不可思議，",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "比起那個，既然歌曲已經完成了，那一定要讓他聽看看！",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你過來了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我之前提過的歌曲已經完成了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以，希望你能聽看看……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？啊、是的，在夢裡……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你也夢到了，我們又夢到相同的夢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……就算如此，我還是希望你能再聽一遍！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我要特別為了你，在此獻唱這首歌！",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這、這個是……蘊含著我的心意的歌曲。",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……雖然我在夢裡逃走了……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但這、這次我不會逃走了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請、請讓我聽到……你的回答。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我也能成為一位好作詞家？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……那是，什麼意思……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為，那個……你聽了我的歌曲，然後說傳達到了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "――啊！",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n該、該不會……我的心情根本沒有傳達――",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好、好、好害羞！",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我自己擅自誤會……還逃走了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊……我到底在做什麼呢……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒、沒事……請你不用擔心。",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我沒事……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "被你誇獎歌曲，我非常開心。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "心意沒有傳達給他雖然很可惜，",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是現在我變得能在本人面前唱這首歌，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n應該代表著我有很大的進步了……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果能傳達過去就更好了……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……但是，我不會就這樣放棄的！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……如果我又寫了新歌，你能再聽看看嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果一次傳達不了的話，不管幾次……",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "約定好了喔？",
        "unit_id": 104211,
        "voice": "vo_adv_1042008_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我會加油的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌為了能把自己的心意傳達過去，\n而下了很大的決心。"
    }
]