[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回去蘭德索爾的方法，",
        "unit_id": 105831,
        "voice": "vo_adv_5084700_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回去的方法～",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是什麼食物呀，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請給我一份～！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回去的方法……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這飲料看起來好漂亮喔，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請給我一杯～！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
        "unit_id": 105831,
        "voice": "vo_adv_5084700_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為心急地想著要回去，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "反而使我的肚子拼命咕嚕叫了……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你會不會也餓了呢？",
        "unit_id": 105831,
        "voice": "vo_adv_5084700_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……咦？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食慾？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說起來，",
        "unit_id": 105831,
        "voice": "vo_adv_5084700_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你從剛才開始臉色就不太好耶？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的嘴裡感到又苦",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又辣……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再加上還有點甜甜的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有種甜苦辣的感覺……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身體還像是被雷給劈到一樣",
        "unit_id": 105831,
        "voice": "vo_adv_5084700_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻了起來……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且總覺得似乎",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "整個人在旋轉……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你身上……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟發生了些什麼事呀～～～～！？",
        "unit_id": 105831
    }
]