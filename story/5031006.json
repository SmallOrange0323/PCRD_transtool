        "words": "呼、呼！　",
        "unit_id": 100511,
        "voice": "vo_adv_5031006_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "衝、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "衝太快了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "開始累了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚咿。",
        "unit_id": 104511,
        "voice": "vo_adv_5031006_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花也",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "快到極限了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我就趁現在……！",
        "unit_id": 103311,
        "voice": "vo_adv_5031006_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是很想這樣說，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過我也沒那體力的啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "領先的三人",
        "unit_id": 1,
        "voice": "vo_adv_5031006_014"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "儘管很疲憊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "仍勉強跟山神大人不分軒輊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n後面還有",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "快到極限的鈴莓選手正在追趕！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "能不能撐到終點才是問題！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！？　",
        "unit_id": 12711,
        "voice": "vo_adv_5031006_015"
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆隆隆隆隆隆隆隆隆隆隆！",
        "unit_id": 12711
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "哎────喲好險！　",
        "unit_id": 1,
        "voice": "vo_adv_5031006_016"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "看到在做最後衝刺的鈴莓選手，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n山神大人展現出了幹勁！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "石塊",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "掉落的更激烈了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "噗噗噗噗，",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "小小格里芬",
        "words": "咕嚕咕嚕～",
        "unit_id": 2211
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "蹦蹦跳～♪",
        "unit_id": 102011,
        "voice": "vo_adv_5031006_017"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "美美選手！　",
        "unit_id": 1,
        "voice": "vo_adv_5031006_018"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "騎著小小格里芬先生",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "越過了落石！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～",
        "unit_id": 102011,
        "voice": "vo_adv_5031006_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這樣真有趣～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "咦，",
        "unit_id": 1,
        "voice": "vo_adv_5031006_020"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "美美選手……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "不知道是不是太沉浸於在落石上跳躍的樂趣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n她跑離了路線，往完全不同的方向去了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等等啊美美～！　",
        "unit_id": 103611,
        "voice": "vo_adv_5031006_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "回來啊――！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆隆隆隆隆隆隆隆隆！",
        "unit_id": 12711,
        "voice": "vo_adv_5031006_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇哇！　",
        "unit_id": 100511,
        "voice": "vo_adv_5031006_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在不是跑步的時候了吧──！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "性、",
        "unit_id": 103311,
        "voice": "vo_adv_5031006_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "性命更要緊的啦！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "各位，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "暫時先去避難吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太、",
        "unit_id": 104511,
        "voice": "vo_adv_5031006_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太激烈了。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的身體撐不住。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "三位選手，",
        "unit_id": 1,
        "voice": "vo_adv_5031006_026"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "以及",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "各公會跟著的馬車，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n似乎決定先離開山神大人附近去緊急避難！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n因此，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "第一名是山神大人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "而第二名",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "竟然是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "鈴莓選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇哇哇哇！　",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噢噢噢噢！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噫噫噫噫噫！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她奇蹟似地迴避了落石！",
        "unit_id": 1,
        "voice": "vo_adv_5031006_028"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n但是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這些落石",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "是否會讓鈴莓選手也不得不去避難呢！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會，",
