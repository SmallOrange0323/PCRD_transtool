    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為山神大人參加，山路變得更加險峻，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n位居最後一名的鈴莓，體力也到了極限。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼、",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐……",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐她、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看到這樣子的我",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會說些什麼呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n根本沒必要去跑？　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不用這麼努力也沒關係？　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不對……",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她一定會對我說",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要拿下優勝。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她在終點等我。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "她的溫柔",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就在於她相信著我。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我絕對不能放棄！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我要從",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "老是給人添麻煩的自己",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢業！！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "沒想到！　",
        "unit_id": 1,
        "voice": "vo_adv_5031006_004"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "鈴莓選手的跑速雖然因為山神大人的影響而變慢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n但是她追上",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "領先的選手們了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "眼前",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "變得模糊了……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可是，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的身體告訴我，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這裡停下來的話，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就動不了了……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "窮追不捨的鈴莓選手，",
        "unit_id": 1,
        "voice": "vo_adv_5031006_006"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "讓觀眾響起了熱烈的掌聲！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n誰能預料到",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她居然",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "能跑到這裡呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "看那表情",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她似乎也快到極限了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們相信妳可以的！　",
        "unit_id": 111811,
        "voice": "vo_adv_5031006_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 112011,
        "voice": "vo_adv_5031006_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳幹嘛把話題丟給我啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是她自己說要參加的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果沒有跑到這裡的話我們會很困擾。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "僅此而已唷。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 111911,
        "voice": "vo_adv_5031006_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最先聲援鈴莓小姐的人",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是凱留小姐呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是鈴莓小姐沒問題嗎……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她看起來似乎相當難受……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！　",
