        "name": "實況",
        "words": "再次燃起了鬥志──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n究竟是主人說的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "還是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她自己的內心",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "讓她有如此轉變呢──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！　",
        "unit_id": 12711,
        "voice": "vo_adv_5031006_065"
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！　",
        "unit_id": 12711
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆隆隆隆隆隆！",
        "unit_id": 12711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不會輸，",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_066"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也不會放棄！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐，",
        "unit_id": 111911,
        "voice": "vo_adv_5031006_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳的身體不要緊嗎！？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的！　",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_068"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我從大小姐那裡得到活力了！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n讓妳們",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "擔心了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都到這裡了，",
        "unit_id": 112011,
        "voice": "vo_adv_5031006_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳可別輸唷！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鈴莓，",
        "unit_id": 111811,
        "voice": "vo_adv_5031006_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等妳贏了，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起去吃好吃的食物吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會贏的。",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_071"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的身旁有大家在！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "好快好快好快――呀！　",
        "unit_id": 1,
        "voice": "vo_adv_5031006_072"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這追趕的速度實在是太快了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n苦惱、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "矛盾，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她將這些都拋諸腦後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n看開一切後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "現在她的跑速已經",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "超越極限了了了了了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "對於突然現身的山神大人，",
        "unit_id": 1,
        "voice": "vo_adv_5031006_073"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "本以為各個公會已經束手無策……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n沒想到，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "竟然",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "有一位跑者出面阻止了這個攻勢……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "儘管曾經",
        "unit_id": 1,
        "voice": "vo_adv_5031006_074"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "淪為最後一名，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n但仍讓我們見識到她的死命追趕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這位驚人的巫女，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "鈴莓選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n她就在山神大人身後寸步之遙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "緊追不捨！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "離終點的距離所剩無幾……",
        "unit_id": 1,
        "voice": "vo_adv_5031006_075"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n「新春蘭德索爾的公會競速賽」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "準備要迎向",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "最後的高潮！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500216"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大逆轉呢。",
        "unit_id": 102811,
        "voice": "vo_adv_5031006_076"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓竟然辦到了……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真厲害耶。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們去找大家吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_077"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以再維持這樣一下子嗎……？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_5031006_078"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的腳",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_079"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "已經到極限……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一步也動不了了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……呵呵，",
        "unit_id": 102811,
        "voice": "vo_adv_5031006_080"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "知道了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n既然這樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我給妳個公主抱吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "公、",
        "unit_id": 112111,
        "voice": "vo_adv_5031006_081"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "公主抱！？　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那也未免",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太丟人了～！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哈哈哈，",
        "unit_id": 102811,
        "voice": "vo_adv_5031006_082"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "開玩笑的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在該給鈴莓妳的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是公主抱，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而是慶祝勝利的拋高呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她簡直就是",
        "unit_id": 1,
        "voice": "vo_adv_5031006_083"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "「山神大人的巫女」！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "各位，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "讓我們再給鈴莓選手一次",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n熱烈的掌聲！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "獲勝的是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "【美食殿堂】！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n新春蘭德索爾的公會競速賽，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "她們贏得了出色的勝利啊啊啊啊！！",
        "unit_id": 1
    }
]