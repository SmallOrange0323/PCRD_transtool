    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了配送書本的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}來到聖德蕾莎女子學院──"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，",
        "unit_id": 111011,
        "voice": "vo_adv_9002013_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "抱歉啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓你特地跑一趟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110911,
        "voice": "vo_adv_9002013_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你好切嚕～☆",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "今天沒有迷路呢……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以呢？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這就是那本書吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "配送辛苦了～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "然後學姐，",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這裡就交給我來應付。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n趁這時間，就拜託妳和琪愛兒兩個人儘速完成了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "交給優妮學姐我吧。",
        "unit_id": 111011,
        "voice": "vo_adv_9002013_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼",
        "unit_id": 110911,
        "voice": "vo_adv_9002013_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕去做事了唷～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……總覺得，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很那個吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你很久沒有來學校了吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼樣啊？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學校生活",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "感覺如何？老實說。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "結果是標準答案啊。",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n竟然毫不猶豫的迅速回答。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒有更惡劣的抱怨之類的嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "基本上你一直就是這種感覺吧。",
        "unit_id": 110811
    },
    {
        "type": "still",
        "still": "301600301"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "從你出現之後……",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "團隊創作？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "的那個",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "油漆灑出來……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "曼德拉草噴出劇毒、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "被醜八怪臭遜廢鐵丸毒舌一頓……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這些，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "全都是一些無聊的情況對吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你卻很樂意奉陪呢。",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "多虧了你，我也……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該怎麼說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們也？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n覺得學校生活變得不無聊了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "老實說",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "或許是因為有你在才覺得開心吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也不太清楚啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唷，",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "久等啦──！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，這個，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛剛的書。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n然後呢？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你接下來要去哪裡？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這裡啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "送你到好懂的地方吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_9002013_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不用道謝啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "如果你迷路了，困擾的是我們嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說起來實際上",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "外人的確很難理解啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那裡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是這樣，出發了──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "快跟上──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "加油啊！",
        "unit_id": 111011,
        "voice": "vo_adv_9002013_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "孩子辛苦了！",
        "unit_id": 110911,
        "voice": "vo_adv_9002013_013"
    },
    {
        "type": "dialogue",
