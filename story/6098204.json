    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "漁師さまたちの",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "卓越した腕前、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お見事でした。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "わたくしも",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "みなさまにご満足いただけるお料理が作れるよう、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n日々精進しなければ。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "はい、",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_001"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "本場オーマだからこその",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "極上のお味でした。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\nオーマの町と",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "この味がなくなってしまわなくて、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "本当に良かったです。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "来年もまた、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "オーマのお魚で",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "お正月をお祝いいたしましょう。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふふ……",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_002"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ありがとうございます。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "漁師の方々に",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "調理法をうかがってみますので、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n楽しみにお待ちいただければと。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "で、",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_003"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "弟子入りですかっ？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふむ……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "確かに、",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "主さまたちに喜んでいただけるのならば……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "え？　",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "冗談でございますか？",
        "unit_id": 111911
    }
]