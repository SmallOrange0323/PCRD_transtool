[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗨，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不好意思還特地請你過來這裡。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望你",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天也能夠來協助我的工作。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為「闇影」實在是令人費解，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n調查並沒有如想像中的順利……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說來慚愧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望還能借助你的智慧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你看起來不太自在呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡是",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "由王宮所管理的公營監獄，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n主要用來關政治犯或重罪犯",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而特別打造的牢房喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "過去，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在我還是單獨行動的時期，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解決了某個事件……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當時",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在因緣際會下認識了這裡的獄警，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才特例讓我使用這邊的牢房。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公營的設施卻讓人拿來私用可能會造成不少的問題，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望你能向其他人保密。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "保密的義務，可是偵探的鐵則唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這個牢房裡關著",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們之前好不容易才捕獲到的「闇影」。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當時多虧了你的幫助呢，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "最後總算是如計畫一般，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n將「闇影」成功俘虜雖然已是萬幸。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但這等大事可說是史無前例，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因此為了不讓「闇影」逃走，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡也下了不少功夫呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我拜託了剛才提到的那位獄警",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "派人時時監視，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了不讓「闇影」有機會逃脫，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "甚至還用魔法張設結界。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然這裡再怎麼說也是個監獄，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n警備固然森嚴。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話雖如此，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」本身就是個非常不可思議的存在呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "誰都不知道它會不會用某種意想不到的方法突然消失。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以現在最要緊的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是得趕快搞清楚「闇影」的真面目唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也拜託了認識的人，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n動員了不少專家一同調查此事……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但目前為止，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "依舊沒有任何收穫。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "老實說",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也有點慌了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之前還認為只要能夠捕捉到「闇影」，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就等於破解了事件一樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來現在開始，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才是棘手的部分呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說穿了越是難題，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n順利解出答案時，得到的爽快感也會增加呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總而言之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就先確認一下「闇影」的狀態吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不去面對實物，光在腦海裡推敲，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在多數的情況下，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "最後是什麼結論和答案都得不出來的喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "喂～",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n打擾一下喔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有位想讓妳",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "見上一面的人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n早安。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這段時間不斷地與她搭話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總算是有點認識我了呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若出聲叫她，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n姑且還算是會有反應的喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "儘管，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這還遠遠稱不上是「交流」呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "順帶一提。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「小霧」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是這孩子的名字唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒有名字說實在的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很不方便呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因看起來外表跟我相同，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "叫「霞二號」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之類的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或是「闇影霞」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又覺得有點怪怪的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從她那不斷複誦",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "且不具什麼含義的話語之中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n找出了很像名字的片段……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就先拿來參考並幫她取上了個小名。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望助手你",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也能夠用「小霧」……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來稱呼她。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "盡可能溫柔點，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並且慎重地來對待她。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為雖然「闇影」不具有自我意識……",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就算是遭受到粗魯的對待大概不會抱怨，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也不會因此壞了她的心情吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再怎麼說她的長相跟我一樣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很難對她使出什麼強硬手段。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光只是看著她像這樣被關在牢房裡，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我都不知為何冒了汗。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「早安，",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_036"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "學長。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「非常感謝你貼心的顧慮。」",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_037"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我沒有問題的。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「學長還真是溫柔的人呢。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……？",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "冷不防地就滔滔不絕說起話來了呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為什麼會這樣啊？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以時機點來說，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該可以看做是因為助手先生的關係。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但這沒有道理啊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算了。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再多和她說些話試試吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「嘿嘿♪」",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_041"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「學長你這話還真有趣呢。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「讓我們再多聊聊吧。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔哇，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她回話了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會不會是隨機的發言內容碰巧對上，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "剛好聽起來像是有意義的台詞也說不定？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管怎麼說。",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小霧對助手先生所說的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n確實起了反應呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然依舊",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不明究理，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但這可是個大發現喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對於「闇影」調查進展的可能性，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺突然大增了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呀！？",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n幹嘛突然那麼大聲啦，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊、",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你看！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就連小霧也被嚇到，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n躲到了牆邊了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼說來，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她在害怕……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這也是不可思議的現象呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」基本上",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n應該是沒有這種與生物",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "相似的反應才對。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」一直都不被認為",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是生物。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就連生物最基本",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "天生的自我保護本能，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n或是迴避危機的本能都沒有。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算被劍砍，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也能若無其事地繼續重複一樣的動作。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這明明幾乎都是個定論了……",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但小霧",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "卻對你的喝斥感到了恐懼。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也有可能是剛好看起來像這樣而已？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再稍微",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "實驗看看吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧、",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n乖喔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "過來這邊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "…………",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_056"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_057"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n似乎聽不太進我說的話呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "換你來叫叫那孩子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「你找我有什麼事嗎？",
        "unit_id": 101421,
        "voice": "vo_adv_1014006_058"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "學長？」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「如果是我能辦得到的事就好了。」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔哇，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_059"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "自然而然就朝這走過來了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼只要是助手先生說的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n她就會聽進去呢……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且為什麼會把助手先生",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "叫成「學長」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這件事也都還是個謎呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話雖如此，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_061"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n又從小霧的身上發現了全新的反應。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這可以說是有所進展。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就順這個氣勢，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_062"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n更加詳細地查明「闇影」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "究竟有何內幕吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "調查、",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "考察、推理，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並實證。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n只有不斷的重複，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才有辦法查明真相。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在可全得靠你了呢，",
        "unit_id": 101411,
        "voice": "vo_adv_1014006_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓我們一起",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將這謎團給查個水落石出吧。",
        "unit_id": 101411
    }
]