        "type": "dialogue",
        "name": "雪菲",
        "words": "嚇了一大跳呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "想說要是因為我的變身，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓你承受太大的負擔該怎麼辦……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你能醒過來……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的是太好了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我的話……",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_056"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該沒問題。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想確認一下，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "每次變身成公主型態後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n肚子都會那麼餓嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼會這樣……",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_057"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這會持續多久呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "肯定不是變身個一、兩次就能習慣的吧……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼辦……",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_058"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要是每次變身，都因為肚子餓變回小嬰兒，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那也太羞恥了……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我決定了。",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_059"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不只是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "戰鬥技巧，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也要好好鍛鍊精神才行！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是，",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_060"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不能造成大家的困擾！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n明明戰鬥結束後已經很累了，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n誰都不想再花心力照顧小嬰兒吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個……",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_061"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你說的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒錯。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖說一個人努力也很重要，",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_062"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但只要大家同心協力，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就能發揮出更強大的力量。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我今天……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也實際體會到這一點。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 106412,
        "voice": "vo_adv_1812004_063"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒錯。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "然後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家就一起前往──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n吉歐‧尼布爾黑爾吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲重新面對自己的內心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以及過去所做的事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並再次察覺到許多重要的事物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她下定決心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將前往全新的世界。"
    }
]