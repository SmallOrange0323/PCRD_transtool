[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "510450"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1812004_000"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "你是深月小姐的助手對吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n今天也是來確認紫布菜的狀況嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "我想紫布菜一定也會很高興。",
        "unit_id": 1,
        "voice": "vo_adv_1812004_001"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "那個……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n還請不要太過勉強自己喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "之前也有說過，",
        "unit_id": 1,
        "voice": "vo_adv_1812004_002"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "就理論上來看，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n紫布菜的靈魂",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "的確已經回到肉體裡了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "先不論好壞，",
        "unit_id": 1,
        "voice": "vo_adv_1812004_003"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "接下來都只能靠她自己……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n所以要是大家先把自己的身體搞壞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "可就得不償失了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "這樣啊……",
        "unit_id": 1,
        "voice": "vo_adv_1812004_004"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n看來你真的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "很重視紫布菜呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n其實，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "其他人也都跟你說了一樣的話。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "既然如此，",
        "unit_id": 1,
        "voice": "vo_adv_1812004_005"
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "我也不再多說什麼了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n但請記得",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "務必要好好休息，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "\n這也是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫療人員",
        "words": "為了紫布菜好。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人！",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "原來您也來了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "說到這個……",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "她果然",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還是沒有要甦醒的徵兆。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雖然",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "生命跡象一切正常……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但是不是",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "有著連醫生也無法掌握的問題呢……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人……",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您說得對。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下也真是的，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一不注意就過於操心了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "除了深月小姐之外，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n其他醫療人員",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也都很努力地在釐清原因。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雪菲小姐",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也絕對不會想要這樣繼續下去。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就像跟阿剌克涅女士",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "戰鬥的時候一樣……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "她一定",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會醒過來的對吧。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不對，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "應該叫阿賀斗紫布菜小姐才對。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "曾在網路上",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "欣賞過您的表演。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "紫布菜小姐在冰上滑行時，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不僅英氣風發，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還十分美麗。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下沒想過人可以像那樣在空中飛舞……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一不小心",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就看入迷了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "果然是這樣……",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n她肯定是不停地鍛鍊自己呢。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即便",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是在「另一邊」，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雪菲小姐也是十分努力的人。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下可以想像得出來，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "她即便做不好",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "也絕不放棄……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "無論要試多少次，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n都會帶著堅定直率的眼神，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "努力練習的身影。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "…………",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……主人，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下該怎麼辦才好。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n一聊到",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雪菲小姐的話題，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n就越來越想念她了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "關於雪菲小姐的回憶，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那些跟【美食殿堂】一起度過，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "熱鬧又開心的日子，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都不斷地湧上心頭……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不對，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "紫布菜小姐。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下真的",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好想早點跟您談話。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "像是彼此在這個世界的事情，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_020"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "以及",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您跟家人……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "跟贊恩先生的回憶等等。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不管是想說的話，還是想問的事，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都有好多好多。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不用說，",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_021"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在這邊也請讓在下盡情地照顧您。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "即便是不同的世界……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "依然是您的「媽媽」。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……！",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_022"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n裝置有點不太對勁……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n難不成，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是因為碰到了主人的手……？",
        "unit_id": 105932
    },
    {
        "type": "still",
        "still": "181200401"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "……嗚、",
        "unit_id": 106432,
        "voice": "vo_adv_1812004_023"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "嗚嗚……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "雪菲小姐？",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_024"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雪菲小姐！",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您聽得見嗎！？",
        "unit_id": 105932
    },
    {
        "type": "still",
        "still": "181200402"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "嗚……",
        "unit_id": 106432,
        "voice": "vo_adv_1812004_025"
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "\n",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "這個",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "聲音……",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "是{player}？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "還有可可蘿",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "紫布菜",
        "words": "媽媽？",
        "unit_id": 106432
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……啊啊！",
        "unit_id": 105932,
        "voice": "vo_adv_1812004_026"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯，",
