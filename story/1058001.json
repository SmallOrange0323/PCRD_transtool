[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "歡迎光臨～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請問幾位？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一位嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請問您抽菸嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明白了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在為您帶位！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這邊請，請坐請坐♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我好像",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在哪裡見過你……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之前請我吃美味現煮白飯的好人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是你嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以你是，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n白飯王子……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是白飯王子？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你是叫這個名字嗎，嗯～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我只記得白飯而已……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你請我吃的白飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非～常好吃喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一輩子也不會忘記那份恩情，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n非常感謝你，愛死你了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的名字我也記牢了，完全沒問題☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔耶，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我真開心能在這種地方遇見你～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這只能說是命中註定了☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "順便一提，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最近\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始在這間店打工了喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我因為某些原因一直在旅行，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以也一直很缺錢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因此我會定期回到蘭德索爾，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在餐廳之類的地方打工籌旅費喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在餐飲店工作的話，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有員工餐可以吃呢……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我太開心了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一不小心就跟你聊起來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你怎麼沒什麼反應？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好無趣喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，你還記得我嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，貪吃佩可……？　",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我被取了這樣的綽號啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻～",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n貪吃佩可，好可愛的綽號喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還蠻喜歡這個綽號♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天那個小小隻……",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是那個讓我飽餐一頓美味白飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒半句怨言的好孩子！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n白飯公主不在嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是白飯公主，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是小可蘿？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～……",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱歉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我肚子餓的時候記性特別差！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為腦裡的血流不順暢，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只剩一片空白♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "忘記別人的名字，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的是非常失禮呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊嗚，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聊著聊著肚子就空了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子餓啦～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想要攝取卡路里！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我吃些什麼吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在只要是有機物，我什麼都吃……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子餓得咕嚕咕嚕叫的貪吃佩可！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比本名還要像本名，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個綽號還真適合我呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，對喔對喔！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱歉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聊得太愉快，忘記我們還站著呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚，會被扣薪的～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這邊請～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請坐喔，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個是我們的菜單～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這間店的海鮮真的超讚的喔，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是普通的好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我強烈推薦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說這裡的海鮮是從遠方的海邊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n使用魔法保鮮由高速馬車運過來的喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "海膽之類的很好吃喔，海膽。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好想吃啊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊，口水要流出來了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為何一臉困惑～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你不知道該如何是好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你是第一次來這種店嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以對點餐的方法一頭霧水？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白了。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我剛開始的時候\n也是搞不懂呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那時我還以為只要坐下，\n料理就會自動被端過來呢。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你難道",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不識字？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我們的國家，\n識字率應該幾乎是１００％。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但居然還有人不識字呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我了解了。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼就讓我來協助你點餐吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就當作是報答你，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拯救了肚子空空、差點餓死在路邊的我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然這點小忙，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n恐怕稱不上是報答♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我坐在你旁邊喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n失禮了～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "菜單上只有文字說明，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以很難懂吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是有圖片就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你有什麼想要吃的嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要我一個個為你介紹？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個金槍魚的肥肉，鮮嫩甘甜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好吃得不得了喔～……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "順便一問。\n你的預算是多少？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這間店還蠻高級的，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是點太多的話，荷包很快就會見底了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，你一毛錢也沒有嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼為什麼要進來店裡呢……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被好吃的香味吸引過來了？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你這樣好像野生動物喔～",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可愛♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白了！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼這次\n我來請你吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛好今天是發薪日，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的荷包滿滿的喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就當作是你之前請我吃飯的謝禮！",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "盡量點我想吃的東西～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不用客氣喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔耶，",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要點哪個好呢～……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我待會就下班了。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一起吃飯喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們友好地圍著餐桌用餐吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果你……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "方便的話……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058001_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飯果然還是跟別人一起吃\n才比較美味呢～♪",
        "unit_id": 105812
    }
]