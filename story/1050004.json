    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是在做什麼？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是在不知不覺中",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "睡著了嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呼～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也睡到現在才醒嗎……？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我居然在戶外睡著了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我好像做了一個很開心的夢呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我和你一起玩盪鞦韆……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也做了同樣的夢嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是不可思議呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒錯沒錯，",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那是非常開心的夢――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃、",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才沒很開心呢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我怎麼可能只是玩個盪鞦韆",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就會覺得很開心！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼？",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你想延續那個夢……？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是指想和我一起玩？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就說了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才不會做那種幼稚的行為……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 105011,
        "voice": "vo_adv_1050004_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n陪你玩是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為一個大人的從容！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為拿你沒辦法，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就陪你一起玩！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是之後兩人樂此不疲地玩到太陽下山了。"
    }
]