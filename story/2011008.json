[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "純小姐並沒有追過來呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是怎麼一回事呢？",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的樣子乍看之下有些異常之處呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這樣對我們來說再好不過，所以也無妨就是了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呢？",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在也沒有追兵，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能稍微喘口氣了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然還是下定決心，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "朝著寶物庫出發吧？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n其實",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒有多遠……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然大門被慎重地封鎖住了，",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "知道解鎖的辦法。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被稱呼為『陛下』",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的那個敵人，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像對寶藏一點興趣也沒有呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以應該不會再加上什麼新的鎖，",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n用我知道的開鎖方式就能打開了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於這件事確實沒有審慎思考過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『陛下』到底",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是為了追求什麼呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果對寶藏並不感興趣，",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又為了什麼要奪取整個王家呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "除了將在下等人給排除以外，",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎也沒有做出其他具體的行動？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法猜透他的目的。",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正因為這樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "顯得有點詭異呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～嗯。",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從他講過的幾句話來看，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎是想要什麼權力的樣子呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原以為只是想要高高在上，",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但也不像是那樣……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是搞不懂呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這個世界的真相，",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和那位『陛下』的目的之間，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許有些關連也說不定呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從在下聽說的話來判斷，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那人也是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『七冠』之一的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你是指什麼事呢？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事以後有機會再……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟說來有點複雜。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起這件事，貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個寶物庫在哪裡呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在這條走廊的盡頭喔！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是被",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫做王座之廳的地方，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後在浸滿水的地板……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哦喔！？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊！？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生了什麼事？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似、",
        "unit_id": 105813,
        "voice": "vo_adv_2011008_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎有什麼爆炸了呢……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛才，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "閃過了一道很眼熟的魔力光芒！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難不成是……？",
        "unit_id": 105813
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇哇，",
        "unit_id": 101112,
        "voice": "vo_adv_2011008_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那這樣不是很不妙嗎！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不阻止她不行！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "當然！　",
        "unit_id": 191011,
        "voice": "vo_adv_2011008_020"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "沒有讓正值美好年華的少女逝去的道理！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n而她是被洗腦、",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "被操縱的就更不用說了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "身為一名騎士可無法坐視不管！",
        "unit_id": 191011,
        "voice": "vo_adv_2011008_021"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n請兩位",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "掩護我，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n我趁著空隙上前",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "把她捕捉起來！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不不，別說傻話了啦，",
        "unit_id": 104911,
        "voice": "vo_adv_2011008_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "她可是正在到處亂放誇張的魔法欸……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那孩子！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果隨便靠近會被轟得粉身碎骨的吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可是，",
        "unit_id": 191011,
        "voice": "vo_adv_2011008_023"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "除此之外也別無他法了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n若對柔弱的少女見死不救，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n就算費盡千辛萬苦救出似似花大人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "也會被斥責的！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人她，",
        "unit_id": 191011,
        "voice": "vo_adv_2011008_024"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可是位傾心於正義又溫柔的大人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "故此，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我才如此敬愛她並仕於她的膝下！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔哇～",
        "unit_id": 104911,
        "voice": "vo_adv_2011008_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這告白還真火熱～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我雖然很想支持你，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但你不覺得好像不太可能嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n先別說要接近了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "光要躲開那孩子的攻擊魔法就用盡全力了唷～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈、",
        "unit_id": 106013,
        "voice": "vo_adv_2011008_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈哈哈哈～！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n去死、",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去死、去死！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們全部",
        "unit_id": 106013,
        "voice": "vo_adv_2011008_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都給我死光光吧～！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要是妨礙我和『陛下』的傢伙，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把你們全部全部全部都……！",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小、",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【拉比林斯】的各位！",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到底發生了什麼事情呀，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇喔？",
        "unit_id": 104911,
        "voice": "vo_adv_2011008_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}和大家，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你們怎麼在這？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼說，",
        "unit_id": 105911,
        "voice": "vo_adv_2011008_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以算是因緣際會……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是正巧經過了而已。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又為什麼會在這裡呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃……",
        "unit_id": 104911,
        "voice": "vo_adv_2011008_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們的目標，那個叫洗腦魔法裝置的東西",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就在這個王座之廳唷。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔呣……",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這麼說來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "洗腦魔法裝置似乎是存放在寶物庫呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們看得到嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在蔓延於王座之廳地板的水裡，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "寶物庫就藏在其中喔。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是以魔法的方式",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "慎重隔離起來的異空間，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n的確用來當作保存場所，可以說是最安全的地方了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_2011008_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看起來那個叫做貪吃佩可的，已經成功被救出來的樣子呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真厲害呢，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥不愧是個想做就做得到的人♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可……？",
        "unit_id": 106013,
        "voice": "vo_adv_2011008_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以『陛下』之名到處行騙的大罪人，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎麼從牢裡逃出來的？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是伙伴們伸出援手救了我唷，",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而我們也會連妳一起救出來的，",
        "unit_id": 105811,
        "voice": "vo_adv_2011008_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定會。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後再一起，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n回到我們最喜歡的，洋溢著幸福的日常之中吧。",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "200099901"
    }
