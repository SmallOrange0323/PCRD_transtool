[
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "緊、",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "緊、",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "緊急狀況！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "位於「深域」最深處的「深淵」，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n貌似出現了非常強大的魔物！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐！？",
        "unit_id": 105811,
        "voice": "vo_adv_0000080_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳一路跑過來的嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳說",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "強大的魔物是指……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好的好的，",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟往常一樣",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「更強大的敵人出現了！」",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交給我吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我馬上就去打倒牠！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！？",
        "unit_id": 105911,
        "voice": "vo_adv_0000080_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她一個人走掉了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒問題嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_0000080_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她又回來了哦～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行不行不行不行！",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙的不妙程度不是開玩笑的啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然不是在開玩笑。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為那個魔物可以說是，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n「深域」魔物們的老大……！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來是老大～！",
        "unit_id": 105811,
        "voice": "vo_adv_0000080_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那肯定會很強大……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也很有飽足感對吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話、",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話先說在前頭，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不認為這次那個是可以吃的喔！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且說到底，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種東西到底該怎麼打倒啊～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這個嘛……",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_009"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "關鍵就在於「屬性」。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在「深淵」戰鬥時，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只要跟以前的「深域」冒險一樣",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "善用「屬性之力」，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "便能使自己處於優勢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此。",
        "unit_id": 105911,
        "voice": "vo_adv_0000080_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請繼續",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "留意備齊「屬性」",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來戰鬥吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "戰鬥方針就這麼辦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "獎勵應該會多給一點吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果只給寒酸的道具我可不饒妳哦？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵呵♪",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "關於獎勵的事，就請交給我吧！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n在現場所獲得的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「星素水晶球」與",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「星素碎片」",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就跟之前一樣可以自由地帶回去。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "然後再加上──",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "作為這次的特別獎勵，",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_013"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們會準備「大師碎片的殘片」！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是豪華的獎勵。",
        "unit_id": 105911,
        "voice": "vo_adv_0000080_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要有了那個，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的力量就能變得更強。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說……",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的安排周到得很可怕耶……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會連跑著過來",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是演技的一部分？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "才沒有那種事哦？",
        "unit_id": 190811,
        "voice": "vo_adv_0000080_016"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "事情就是這樣，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這「深淵討伐戰」──",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "拜託大家！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "助我們一臂之力吧！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是為了主人，",
        "unit_id": 105911,
        "voice": "vo_adv_0000080_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下實在無法坐視不管……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "馬上進行編組，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前去挑戰吧！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊──真拿妳們沒辦法！",
        "unit_id": 106011,
        "voice": "vo_adv_0000080_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們會快點把牠收拾掉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以說多～給我準備一點獎勵啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】，",
        "unit_id": 105811,
        "voice": "vo_adv_0000080_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Let's go──☆",
        "unit_id": 105811
    }
]