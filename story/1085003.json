[
    {
        "type": "background",
        "background": "500123"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "約兩週後，平安夜。\n【咲戀育幼院】的臥室內，\n胡桃正過著睡不著覺的夜晚。"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………\n",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不行……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎麼辦，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "完、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "完全睡不著……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明天就是話劇的正式演出了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好緊張喔……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n而且白天",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在【咲戀育幼院】裡的派對上玩得太開心了。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "興奮過了頭，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n已經精疲力盡了身體卻還很亢奮……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想睡卻睡不著，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明明應該是要早點睡好好休息的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣想著想著，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就焦慮的睡不著覺了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼我總是這樣，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "什麼事都做不好……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔……",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎麼了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你睡不著嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音對不起，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "扭扭捏捏的在自言自語……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把你吵醒了嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯……",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是趕緊睡吧胡桃，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "再嘀嘀咕咕就到聖誕節了哦。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聖誕老人就要來了哦，",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一不留神你們眼神對上了不就尷尬了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是說，聖誕老人已經來過了嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n現在，是幾點啊……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽還沒……不對，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n聖誕老人應該還沒來吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你看，枕頭旁邊也還沒放上禮物……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "原來如此。",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿，好期待會是什麼禮物呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好想趕快到明天，我要回去睡了哦……",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃，你也快點去睡吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也想趕快睡了，但怎麼也睡不著……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然很抱歉，可以陪我說一下話到我想睡……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音已經睡著了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "再把他吵醒了就太可憐了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓他好好睡吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也是，該睡了……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "累了應該就會想睡才對，大概是練習還是不夠吧，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為了明天的演出我再去庭院排練一下好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這麼晚了還到外面去，肯定要挨罵的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n而且，咲戀媽媽來放禮物的時候，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n發現我不在一定會很擔心的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我又不想把綾音吵醒，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也不能在房間裡一直製造雜音……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……呀啊？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咦咦，有腳步聲！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "難道，是咲戀媽媽過來了？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "得、得假裝睡著才行……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音也說了。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要是被發現還沒睡著的話，\n一定會變得很尷尬的……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "房間的門要打開了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚啊嗚，腳步聲靠過來了！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我得假裝一下，讓他不會發現我還沒睡著才行……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我，我在睡覺喔！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我睡得很熟喔，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把禮物放著就好了喔……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "睡、睡呀睡呀♪",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n睡呀睡呀……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……嗯！？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚嗚嗚！？　",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？什麼？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n怎麼，好像被碰到腳了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔呀，會發出奇怪的聲音啦！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼要碰我的腳？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n聖誕老人，也就是咲戀媽媽，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不是應該要把禮物放在枕邊的嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀哇哇！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　好、好癢呀！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n腳掌好像，被摸得很徹底呀！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "到底是怎麼一回事？　這到底是怎樣？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不行，停下來停下來停下來……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好、好癢呀，要發出聲來了……！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要、要被發現我還醒著了～……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚欸，變得好可怕了啊！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這是什麼，難道不是聖誕老人嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n到底是誰、為什麼，要一直對我的腳……！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "起、起來吧！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　這絕對不是聖誕老人！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然很害怕，但我一定要起來探個究竟！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要是魔物的話，我一定用錘子把它給打倒……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "住、住住、住手啦！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然不知道你是魔物還是什麼東西，快給我走開……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……咦、奇怪？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是、是、是哥哥？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "果、果然……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然有點暗看不清楚，確實是哥哥的樣子呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太好了，原來不是什麼魔物啊……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呼……呃，我沒事啦。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "與其說是被吵醒，其實我一開始就睡不著所以還醒著的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……不對啊！",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥哥，你在幹嘛啊？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為、為為、為什麼要一直對我的腳……？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥是受了咲戀媽媽的委託，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n給育幼院的孩子們發送禮物才來的嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "今天派對後的善後工作一弄完，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴莓姐就已經累癱睡著了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽要把鈴莓姐姐抬回去臥室，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n禮物的配送就交給哥哥來了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是這樣嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我都瞞著不說了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n結果還是讓哥哥知道了聖誕老人的真面目了呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就是說啊。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_046"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是監護人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n或者家人來當聖誕老人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把禮物派發給孩子們……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥既然已經成為了我們家庭的一份子，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n當然就有作為聖誕老人的權利了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n原來是這麼一回事啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊啊那我就安心了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯嗯，咦？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　那個，對不起……哥哥？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我有點不明白，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以哥哥什麼要碰我的腳呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，奇怪？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_049"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥，你為什麼愣住了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……是、是沒錯……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_050"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n按咲戀媽媽說的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥你便想把禮物放進我的襪子裡……是嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是我，平常睡覺的時候我都會把襪子脫下來的……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_051"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥沒有注意到，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一邊覺得奇怪一邊找著襪子，便一直不斷碰我的腳嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是，是這麼一回事啊……？",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_052"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，偶爾會犯這種奇怪的錯誤呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真拿你沒辦法……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_053"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥喪失了記憶，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也會忘記一些像我這樣的小孩子都知道的事情呢。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_054"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n突然之間碰到人家的腳，超可怕的，又很癢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你要向我保證，以後別再這樣了哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_055"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，我說啊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n你知道襪子是掛在枕邊的這件事嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "禮物，是要往那個襪子裡放的……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_056"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要把很大的禮物放進去，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那就要掛很大的襪子才行……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你不知道，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_057"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就做出了這種奇怪的事呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真是的，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_058"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥真令人傷腦筋呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔唔……",
        "unit_id": 102311,
        "voice": "vo_adv_1085003_059"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃，你還沒睡嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n明天話劇就要正式演出了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你要趕緊睡了啦～……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇，又把綾音給吵醒了……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_060"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，你快把禮物放進襪子裡，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n離開這個房間吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音大概還不知道聖誕老人的真面目，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_061"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要是看見哥哥可能會大受打擊的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_062"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想咲戀媽媽大概，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也會給哥哥準備一份禮物哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥要是還沒去睡的話，",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_063"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽也不能睡就太可憐了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_064"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然也想送咲戀媽媽禮物，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n至少，想和她說聲謝謝呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不過，這些事全部，到明天再說了吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_065"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，那晚安囉……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝你的禮物……",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_066"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥，聖誕節快樂……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵。",
        "unit_id": 102111,
        "voice": "vo_adv_1085003_067"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "又驚訝又慌張的好累了呢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和哥哥聊完了就安心許多了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "終於開始有睡意了呢……♪",
        "unit_id": 102111
    }
]