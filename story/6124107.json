[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公に折り入って相談があるのだが……",
        "unit_id": 125212,
        "voice": "vo_adv_6114107_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "今回、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "タマキには",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nずいぶん世話になっただろう？　",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "特別な形でお礼がしたいのだが",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nなにをすれば彼女は喜んでくれるだろうか？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それはいい。",
        "unit_id": 125212,
        "voice": "vo_adv_6114107_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "私は甘味には少々うるさいからな。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n選りすぐりの甘味を取り揃えて贈るとしよう……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いや、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "しかし",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nいざ選ぶとなると",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "どれも捨てがたいな。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うーむ、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "これは悩みどころだ……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむ、",
        "unit_id": 125212,
        "voice": "vo_adv_6114107_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "だいぶ無理をさせてしまったからな。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ちょうどカフェの運営も軌道に乗って、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "余裕も出てきたことだしな。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "粉骨砕身でがんばってくれた分、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "大いに羽を伸ばしてもらうとしよう。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "！　",
        "unit_id": 125212,
        "voice": "vo_adv_6114107_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "き、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公……！　",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "確かにそうだ、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "その通りだな。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nどんな形で礼をするにせよ、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "まずは言葉で感謝を伝えることからだ。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "少しばかり照れくさくはあるが……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうしてみる。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ありがとう！",
        "unit_id": 125212
    }
]