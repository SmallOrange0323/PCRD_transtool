        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又餓又熱有夠難受……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是啊……",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_001"
    },
    {
        "type": "dialogue",
