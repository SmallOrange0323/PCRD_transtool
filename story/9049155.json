        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要緊嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～",
        "unit_id": 105811,
        "voice": "vo_adv_9049155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒事啦～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟我有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美味的小凱留在～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咬。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等！",
        "unit_id": 106011,
        "voice": "vo_adv_9049155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住口！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要咬我啦～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……必須在凱留被吃掉之前，",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n搶回被魔物搶走的料理工具才行……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9049155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那裡",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有什麼東西……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011,
        "voice": "vo_adv_9049155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是連可蘿仔也瘋了嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳是看到了幻覺嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等，凱留。",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好像是真正的綠洲。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 105811,
        "voice": "vo_adv_9049155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還有看見人影！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就請他們分我們一點食物吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106011,
        "voice": "vo_adv_9049155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可妳先冷靜下來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些不是人，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是剛才那群哥布林！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "終於找到你們了……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "欸，",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那群哥布林",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "手上拿著的該不會是……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊～！",
        "unit_id": 105811,
        "voice": "vo_adv_9049155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那些是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們的料理工具！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是……",
        "unit_id": 105911,
        "voice": "vo_adv_9049155_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是拿來當武器用呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們是不曉得",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "料理工具的使用方式嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊！",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐！？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n正面突擊是很危險的！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那些可是",
        "unit_id": 105811,
        "voice": "vo_adv_9049155_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用來讓大家圍著餐桌愉快用餐的重要工具！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是用來傷人的東西喔～！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106011,
        "voice": "vo_adv_9049155_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明是搞偷襲的大好機會說。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們也跟上吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是！",
        "unit_id": 105911,
        "voice": "vo_adv_9049155_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我明白！",
        "unit_id": 106411,
        "voice": "vo_adv_9049155_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】，",
        "unit_id": 105811,
        "voice": "vo_adv_9049155_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "進行突擊！",
        "unit_id": 105811
    }
