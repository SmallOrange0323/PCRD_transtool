[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人，\n與【拉比林斯】的眾人進行了作戰會議後決定……\n暫時先和她們分開來行動了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "各自從不同的方向來探討，\n進而找尋能夠與王宮對抗的手段……\n――她們談出了如此的結論。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但也因此……\n沒有其他去處的{player}一行人，\n也就只能先回到蘭德索爾了。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖說能平安回到蘭德索爾已算是萬幸，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而往後又該如何是好呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是以在下的個人立場來提議，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "首先應該確保食衣住。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以在下等人處於與王宮敵對的立場來看，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍舊相當有可能是被官方通緝的身分……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論最後是得在何處過夜，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也都不應該回到【咲戀育幼院】。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟也不好將安然地過著生活的【咲戀育幼院】的大家，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n全都捲入了這個危險的狀況之中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若以咲戀小姐的個性，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n極有可能正煩心著在下等人的安危與處境也說不定……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n過陣子，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有必要找時機悄悄地給人家送封信才行呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『因近期身負事務，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時無法回去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也許有耳聞一些關於王宮的傳聞也說不定，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而請別放在心上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也請無須過度操心。』",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……捎封諸如此類的信件。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要用上了在下的傳信鴉，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n捎封信也絕非會是什麼難事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在無法回到【咲戀育幼院】的前提下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須得先確保能夠住宿的場所才行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管最後得野宿，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下來說也無妨就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但若可行還是得讓主人您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n過上健全且能稱得上有文化的生活才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少得是個能遮風避雨的場所……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若能有個舒適的床鋪供您休息更為益善。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知您，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否知道任何適合住宿的場所呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就如同最初我們剛抵達這座城內時一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n除了住飯店以外沒有更好的法子了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這也是，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最方便的選擇之一了呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅有可能會被員工給認出樣貌，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會留下相關的紀錄。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更要緊的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "住飯店的開銷是很可觀的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還得看看荷包是否能承受的了呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管銀行中仍留有一定程度的儲蓄，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而畢竟那也是和王宮息息相關的公家機關呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若是已公告通緝，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也極有可能當場就會被繩之以法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "故此……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竭盡可能地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n節省手邊這些有限的金錢才為上策呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是必要的支出也別無他法，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而過度浪費仍得避免。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是【美食殿堂】的公會小屋，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不僅能夠自由地進出，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也還有一些寢具。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若暫時得低調度日，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可說是再合適不過的場所也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而公會小屋，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【公會管理協會】……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是於公家機關管理之下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要我們仍與王宮處於敵對的狀態下，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不該去利用任何和公家機關相關的場所才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "演變成自投羅網呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而身為【美食殿堂】一員的凱留小姐也當然，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n熟知公會小屋的所在的場所呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管不願意，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但只要與凱留小姐敵對的一天……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "選擇於該棟建築物內過夜便為危險之事吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得找更加安全，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "且任誰也不清楚的躲藏處才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反覆地思考此事後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒更是感到束手無策了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "王宮……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與整個國家為敵的這件事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比想像中更加的窮途末路呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "老實講，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可謂坐也不是站也不是的感覺呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管自知可恥但似乎已無計可施了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明應當為引領主人的嚮導之身",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻如此不中用，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是慚愧至極。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇呀……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您這是安慰在下呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n確實是如此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算於此處灰心喪志也沒有任何的幫助。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐她……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們最珍貴的同伴，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n仍為遭人囚禁之身。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是得用上何等手段，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都得將她給救出來才行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那有些異常的凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也相當令人在意呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "首先，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍然得先確保能住宿的據點與糧食，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一面腳踏實地的調查，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "試著籌畫出足以起死回生的妙策吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不幸中之大幸，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們並非是孤獨地面對此事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【拉比林斯】的大家，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定也願意出份力來協助的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【拉比林斯】的大家，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎決意頻繁地改變躲藏地來進行逃亡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下等人並沒有能夠主動聯繫她們的方法，",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也挺困擾的就是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管依舊是前途多難，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還是再加把勁嘗試看看吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下有許多仍舊靠不住的地方……",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但可可蘿不管何時皆會全力以赴，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為主人您添一份心力。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不。",
        "unit_id": 105913,
        "voice": "vo_adv_2009007_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會永遠伴隨於您身邊的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    }
]