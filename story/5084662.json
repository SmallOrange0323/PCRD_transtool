    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶的公主騎士的昏睡……",
        "unit_id": 107011,
        "voice": "vo_adv_5084662_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不得不說，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是非比尋常的事態呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很遺憾，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他就這麼沉睡不醒的可能性非常高吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我可能已經無法再見到你了呢。",
        "unit_id": 107011,
        "voice": "vo_adv_5084662_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這會讓我很困擾的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟也還沒能模仿你……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "學生就這麼消失，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即使身為七冠也是會感到悲傷的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不該有這樣的結局的。",
        "unit_id": 107011,
        "voice": "vo_adv_5084662_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n曾經擊敗我的你，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "根本不該在這裡結束。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是至今好幾度",
        "unit_id": 107011,
        "voice": "vo_adv_5084662_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "超乎我預期的你，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就應該沒有辦不到的事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以……",
        "unit_id": 107011,
        "voice": "vo_adv_5084662_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我相信你一定會平安甦醒的喔。",
        "unit_id": 107011
    }
]