[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了觀察{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n艾姬多娜開始在夏天的海邊打工了，但是──"
    },
    {
        "type": "still",
        "still": "132000201"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡的沙子",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_000"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還真細呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n是海邊這種地方的特徵嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "原來如此。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_001"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n海邊不只是水，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "連沙子都含有大量的鹽分呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n這就是導致植物無法生長的原因嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "稍微離開一點的地方，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_002"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有長出樹木。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n海的影響",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "會對大地造成何種程度的作用，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "讓我很有興趣呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗯。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_003"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n這個被丟掉的容器使用的素材，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是我沒看過的素材。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n它的原料是什麼啊？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "從它被這樣",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_004"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "隨意丟棄的狀況來看，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n應該不是太貴重的東西的樣子。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是說",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "被大量生產了嗎。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "人的慾望沒有盡頭呢。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_005"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊，不是，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我不是在譴責他們喔。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為慾望",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對我來說",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是伴侶啊。",
        "unit_id": 132011
    },
    {
        "type": "still",
        "still": "132000201"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_006"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這個生物",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有著不可思議的形狀呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想把牠帶回去，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "好好觀察牠的生態啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這邊也有",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_007"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我沒看過的生物……！",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這會讓我忍不住分心呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我希望不只沙灘上，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_008"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "連海裡的生物都能好好地……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_009"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "居然被懷疑我沒有在工作，那讓我覺得很遺憾呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我希望你能好好想一下。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我來這個世界",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_010"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還沒有多久喔？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "換句話說，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我目前的狀態，還沒辦法分辨出",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n打工這項行為所要收集的東西，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是說沒辦法分辨哪些是垃圾啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "正是因為如此，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_011"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我才必須先像這樣好好觀察，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n去理解它們才行喔。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我很高興你能理解。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_012"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然我",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_013"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "並沒有什麼太深遠的意思，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但是在跟我以外的人講話時，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你稍微多抱點疑心應該比較好呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為這世上",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有很多壞人啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼就繼續觀察……",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_014"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "撿垃圾吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那邊也",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有什麼奇妙的──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──嗯。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_015"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_016"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沒什麼事啦。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我只是",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "已經累到站不起來了而已。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我說過了吧？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_017"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我不擅長肉體勞動啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n而且你已經",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "撿了很多垃圾了吧？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就算是你也該……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你看起來還很健康呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "讓我很吃驚啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……抱歉，可以拉我一把嗎？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_018"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n要是我就這樣站不起來，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "被波浪捲走溺死的話，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你的良心也會過意不去吧？",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "謝謝你。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_019"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "好啦……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "應該差不多可以了吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我已經充分享受了這個名為打工的行為了。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_020"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我確實有說我會幫你。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但是，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "已經──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那真是太好了。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_021"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我當然",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是還有餘力啦，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是你說要結束的話，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我很樂意──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……你說什麼？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_022"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "抱歉，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_023"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可能是聽錯了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你剛剛說了什麼，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可以再說給我聽一次嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "接下來是要……",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_024"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在海邊巡邏……？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "難道說你",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_025"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還要繼續這個名為打工的行為嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……老實說這出乎我的預料之外。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_026"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然我本來打算要結束了──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但是我變得",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "想更想了解你了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你的行動本身",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_027"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就是「未知」啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_028"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我當然會幫忙喔。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為說了要幫忙你的人是我啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……但是，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_029"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可不想再繼續肉體勞動了喔？",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是說",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_030"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這次是要確保海邊的安全嗎。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如果是對人來說很好的自然環境的話，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "魔物當然也會靠過來。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡看起來，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_031"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n沒有驅除魔物的結界之類的東西呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不過，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_032"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就算有結界──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在看到面前這麼多的魔物之後，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_033"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n它也應該沒有在運作了吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "情勢看起來對你似乎不太好，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_034"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沒問題嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在我來看，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_035"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你不擅長單獨作戰。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你也可以選擇逃離這裡，不用勉強自己喔。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_036"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "當然，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你要是有什麼絕招的話，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要施展出來也行。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真有個什麼萬一就由我──",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_037"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……我確實在思考為何你只顧防守，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_038"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "原來如此。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你是以我的安全為優先嗎。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真是的，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_039"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "能做到這種程度很厲害啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然你那信念盡頭的結局",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_040"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也讓我很在意──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！\n──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "呵呵。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_041"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "……！？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哎呀。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_042"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "魔物逃跑了呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "牠們是看到什麼恐怖的東西了嗎──",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──終於結束了。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_043"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我才",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_044"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "剛剛鬆了口氣而已耶。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……你還打算繼續嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你看起來也不像是缺錢……",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_045"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "來",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我能理解你慾望的根源了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我說不定是第一次",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_046"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "為了取得金錢類型的報酬",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n而這麼拼命工作啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "然後呢？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_047"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "接下來要做什麼？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡的服務生看起來人數很充足啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我說，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_048"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你是以什麼為基準來選打工的啊？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你該不會是",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n二話不說地",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就答應來請求你幫忙的人吧？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不過，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_049"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如果是那種事情的話",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就交給我吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我當然",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_050"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可以自由使用店裡有的材料沒關係吧？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n這可是能體驗此地飲食文化的",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "大好機會啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "像這種香氣強烈的植物跟果實，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_051"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n也能從外觀",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "來推測它們味道的特徵。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我的腦裡",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也刻劃著有效組合它們的方法。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "呵呵，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_052"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我就用我的知識",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "來創造未知的味道吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──好啦，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_053"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這樣就完成了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要在冷掉之前喝掉喔。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_054"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……居然一口氣喝完魔女拿出來的東西，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_055"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你還真勇敢呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "居然猶豫要不要喝掉少女親手做的料理，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_056"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這很傷人呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你喝下去了吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就讓你來付出代價吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我是",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_057"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "開玩笑的啦。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n那麼，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "讓我聽聽你的感想吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來暫且是成功了呢。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_058"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然在理論上是一定會成功，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但結果",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "並不一定會井井有條地遵循理論，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以這下我放心了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我試著做出新穎又特殊，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_059"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "還有深度的味道。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "如果能讓你覺得不可思議，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那就能說是成功了吧。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "泡法我也整理好了。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_060"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你要讓不管是誰來泡都能泡出一樣的味道來喔。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……嗯？",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_061"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我真的沒有加任何奇怪的東西進去喔。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為是要當商品。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以我只有下了點功夫，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "讓它變成會讓人想喝的味道而已──",
        "unit_id": 132011
    },
    {
        "type": "background",
        "background": "500161"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──到目前為止我們經歷了好幾份打工。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_062"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對很久沒有勞動過的我來說，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_063"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n每個打工都是很新鮮的經驗。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來只要觀察你，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_064"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就能感受到「未知」的這個論點，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n似乎沒有錯呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我必須將我今天一整天的感謝傳達給你才行呢。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_065"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我非常滿足了。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "真的很謝謝你。",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_066"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就是這樣，",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_067"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以差不多該結束──",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "…………",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_068"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "只有你的打工的盡頭在何處這點讓我無法預測……",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_069"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你真的",
        "unit_id": 132011,
        "voice": "vo_adv_1320002_070"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "非常有意思呢……",
        "unit_id": 132011
    }
]