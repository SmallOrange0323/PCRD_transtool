    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼……",
        "unit_id": 130811,
        "voice": "vo_adv_5144411_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然真的直到最後都在手忙腳亂，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但總算是",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "成功舉辦鮮花祭了呢～♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐，",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不可以掉以輕心！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n遠足時，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "直到回家為止都算遠足的一部分。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也就是說，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "祭典也是直到結束為止都算祭典！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，",
        "unit_id": 130811,
        "voice": "vo_adv_5144411_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "確實是這樣沒錯呢。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有很多事情要做，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我可不能在最後的最後冒失出錯，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得小心注意！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要是把準備期間都算進來，",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n妳早就已經冒失超過100次了，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是不得了的次數……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真、",
        "unit_id": 130811,
        "voice": "vo_adv_5144411_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的很抱歉～！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "結果都在讓大家幫忙我，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n真不知道怎麼道謝才好……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐妳",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也有幫助到其他人。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳對煩惱的人很親切，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "無論犯了多少錯也決不放棄……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "能和妳這樣的人",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "一起幫忙籌備鮮花祭，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的是太好了！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n等回家以後，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我想把這些事也告訴美美和禊♪",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿嘿……",
        "unit_id": 130811,
        "voice": "vo_adv_5144411_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝妳，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳跟別人說的時候，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是能把我冒失的部分",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "講得含糊一點，我會很感激",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "的喔……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那樣可不行！",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n鈴莓小姐是發生怎樣的冒失，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "又是怎樣跨越冒失的……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在交給學校的日記裡，",
        "unit_id": 130711,
        "voice": "vo_adv_5144411_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也有仔細寫出來！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不只是美美和禊，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為了讓班上的大家",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n都能瞭解到鈴莓小姐的好，我會努力的！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "算我拜託妳了，",
        "unit_id": 130811,
        "voice": "vo_adv_5144411_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要到處宣揚呀～！",
        "unit_id": 130811
    }
]