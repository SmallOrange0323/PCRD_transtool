    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "接著來喝點茶吧。",
        "unit_id": 112912,
        "voice": "vo_adv_1130003_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我拿這邊的藥草去泡茶囉～",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 113011,
        "voice": "vo_adv_1130003_060"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝妳，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "璃乃。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
