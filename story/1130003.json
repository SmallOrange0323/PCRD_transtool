    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也就代表，",
        "unit_id": 112912,
        "voice": "vo_adv_1130003_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n步未平常真的很照顧我們呀。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好啦～",
        "unit_id": 100113,
        "voice": "vo_adv_1130003_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳就乖乖享受我們的款待吧♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖、",
        "unit_id": 113011,
        "voice": "vo_adv_1130003_070"
    },
    {
