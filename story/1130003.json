        "voice": "vo_adv_1130003_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲真是天才！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那麼，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大家就一起來款待步未吧！",
        "unit_id": 112912
