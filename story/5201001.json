[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──那是"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過去確實存在過的一段時光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n你的意識慢慢地甦醒過來。"
    },
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "與「mimi」的認證，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "已確認。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "準備完畢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n隨時可以開始了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……嗯？",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你怎麼了？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "為什麼這樣直直盯著我的臉……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n該不會是黑眼圈冒出來了吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "討厭啦～",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "開發得太起勁，就忍不住少睡了嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n看來又要被克莉絲罵了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "像是「妳給我多注意自己的形象」",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "之類的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她這樣說，也只是想叫我去買",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n跟她有利益關係的化妝品就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哎呀，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不可以動喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很抱歉讓你這麼不自由，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但你的身體現在連接著很多東西。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為我們所開發的遊戲，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是跟至今的技術體系截然不同的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完全沉浸式的VR遊戲，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以必須連線監控的資料非常多。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那麼～",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "差不多該開始了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "身體放鬆～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啟動的關鍵字……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還沒正式決定呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總之，你只要說",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "「登入」",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就可以了。",
        "unit_id": 106831
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──嗨。",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎你",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來到新世界。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然我這樣耍帥，但其實東西全都還在開發中，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n連場景都還是半成品呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果你能假裝沒看到一堆不堪入目的地方，那就太好了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "身體狀況如何？",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n能隨心所欲地動嗎？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來沒問題。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊、這樣啊，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是太好了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很不好意思，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為你的身體還處於尚未建模的狀態，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以模樣就像是一個毫無表情的人偶……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這點",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之後會改善的。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我下次會跟似似花說，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然她大概會以忙碌為由而拒絕。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝讚美。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……這應該不是反諷吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個身體",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是測試用模型啦，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在製作時好像加上太多個人喜好了呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個應該不會正式實裝，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是現在才看得到的稀有造型喔。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我最近跟克莉絲玩的遊戲是",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "FPS類型，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以下意識就做成跟那邊相似的風格了～",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然與世界觀不合，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但也因此有種",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "開發中的特殊風味，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然已經確認完你的動作了，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n事不宜遲，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就請你來協助我的開發工作吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我目前負責的是物件的相關作業。",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你看，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那邊有個岩石吧？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的工作就是",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "設計、",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "配置那一類的物體。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就像這樣──",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "生成物件。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接著是",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "關於我想要你幫忙的事情。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……不過你今天",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才第一次參與開發嘛，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以首先",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就讓身體習慣潛入遊戲時的感覺吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你就隨意在這附近散散步，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "試著和這個世界接觸吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有什麼感覺？",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很柔軟……？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n哦……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "明明只是暫時將草原紋理給貼上而已，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你竟然會有這種感覺啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或許是你感受性很強的證據。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目前",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能力數值方面還在調整中，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以應該沒辦法忽然就能一拳把岩石擊碎。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然教授可以一副若無其事地辦到就是了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我懂我懂。",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一看到樹，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就讓人想踢踢看呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但很遺憾地，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不管是會掉落的果實，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是會發動攻擊的蟲子，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在都還不存在呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來嘛，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你再繼續進行一定程度的身體活動，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n當出現疲勞之類的感覺時，就立刻告訴我。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "聽好囉，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n千萬不能遺漏任何一項",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "由自己身體所發出的訊息。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟現在的你",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正在試用的連接方式跟我們不太一樣。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n將靈魂半數位化……",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我就不說明這部分的細節了，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總之尚不清楚這對現實中的身體是否會造成什麼影響。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原本應該在進行更多技術檢證後，才進入實驗階段的……",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但其他的七冠",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都堅信天才不會失敗。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他們和「慎重」",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "實在是搭不上邊啊。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……啊，抱歉，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不是在說這項研究很危險。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟我也同樣以天才自居嘛。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我可以斷言，你絕對不會遭遇到危險。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話說回來，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你還好嗎？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在我說話的時候，你一直轉頭看來看去呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "該不會是姐姐我說的話",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "太無聊了？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不過，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個世界會如此吸引人也是當然的吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看到你這樣的反應，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我身為開發者也很高興呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "暫停一下吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然你應該還在興頭上，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但先登出好了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你說你什麼都還沒做？",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "別在意啦，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "今天能確認登入順利就足夠了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我個人是希望",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盡可能",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "慎重地前進。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 133712,
        "voice": "vo_adv_5201001_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就從我這裡讓你登出吧～",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……謹慎起見，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來也該實裝強制登出系統呢。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要謹慎再謹慎",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "才行呢。",
        "unit_id": 133712
    },
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_036"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "辛苦你了～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n抱歉有點手忙腳亂，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "首先要請你接受醫療診斷喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "呼吸、",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_037"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "脈搏……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正常。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n和登入前的數值相同。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在遊戲中出現的身體狀況變化，不會反映在現實的身體上。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_038"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……這個連接系統",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真是不簡單呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只不過……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_039"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這還只是活動身體的程度。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "若是更深入的體驗，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "例如",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "遭受到足以致命的傷害……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……會發生什麼事？",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_040"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_041"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "抱歉抱歉，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n竟然把你晾在一旁了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總而言之，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_042"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你的身體沒有受到影響。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "「頭昏眼花的感覺」",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只存在於那個世界。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "之後也會像這樣，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_043"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "縝密且反覆地",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在遊戲中活動並接受醫療診斷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要是玩了遊戲卻害身體被搞壞，就本末倒置了嘛。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_044"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "尤其這個遊戲的賣點就是逼真，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n會對現實身體造成的影響，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就算只有0.1％也不能存在。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總之",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_045"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大概就是這樣，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "今天先到此為止吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n有沒有什麼問題想問？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但我不太擅長說明，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以恐怕沒辦法回答得很清楚就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……這個問題還真是出其不意呢。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_046"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你該不會是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對我很感興趣？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_047"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "既然其他的七冠現在都不在位子上，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n稍微閒聊一下也沒關係吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然沒什麼好隱瞞的，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_048"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只是講出來很難為情。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我啊……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_049"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "以前非常討厭人類呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "現在回想起來，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_050"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我的思考方式實在是極度傲慢且自我意識過剩，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不久前的我，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完全看不到自己以外的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "任何事物的價值。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "一方面是出於對醫師父親的憧憬，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_051"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我也學習過醫術……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但我",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "卻視為理所當然，沒有好好運用這項專長。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_052"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "自以為很了解",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "人類。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我只注視著惡意，而對善意視而不見，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n並打算棄這個世界於不顧呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這是我走遍地球上的各種地方，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_053"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在自己的雙眼見證下所得出的最終答案。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n實在是個很丟人的故事啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "然而，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_054"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我那年少輕狂到了極致的價值觀，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在與某位少年相遇後，便被徹底粉碎。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_055"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我不是要講什麼卿卿我我的事喔？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我想對方大概也不記得我了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_056"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可以說，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他改變了我的價值觀。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "誤用自身的天賦異稟，總是只看著事物陰暗面的我，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_057"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n彷彿正面撞上了一顆太陽──",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大概是這種感覺吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "多虧如此，我……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_058"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "改變了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我因此得以改變了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這對我而言",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正是最大的救贖。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我想為了他人而努力、",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_059"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我想從自己能做的事開始做起。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "首先，我想帶給人笑容。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_060"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n就像那個少年一樣，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "讓他人",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "展露笑容。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "於是我決定創造出",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很多人都能歡笑、享受快樂的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "某樣東西。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在那之後，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_061"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總之",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我接受了長老之前就一直向我發出的邀約，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n然後直到今日……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "情況就是這樣。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_062"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太好了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我能說",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我喜歡現在的自己。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只要完成了現在正在製作的遊戲，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_063"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應該就能實現我的願望。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_064"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "希望你也能",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "助我一臂之力。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然這對你而言可能是件苦差事或麻煩事，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但你的力量是不可或缺的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "──為了完成",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_065"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "能拯救人心的遊戲。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七冠──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "迷宮女王。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n模索路晶道出了埋藏於她心中的意志。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了將她過去所見到的光芒"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "也分享給他人。"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "──交出妳的工作報告。",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_066"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "咦？",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_067"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真稀奇耶，真那，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n你竟然會親自過來找我，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n明明平常都是隨便找個員工幫你辦事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳睡傻了嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_068"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "實驗品的相關資料是最高機密，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "怎麼可能跟隨便找來的傢伙共享資料。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你說的是。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_069"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，就是這個──",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "最新的同步資料。",
        "unit_id": 106831
    },
    {
        "type": "still",
        "still": "520100101"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_070"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "上面寫的",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_071"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是事實吧？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "難道我會把謊話寫上去嗎？",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_072"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是啊。",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_073"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你未免太不信任我了吧！？",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_074"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應該說我把謊話寫上去又有什麼意義啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳的行動本就毫無道理吧。",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_075"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n正因為無法被理解，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "所以妳才是迷宮女王。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……不過，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這份資料看來不假。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那孩子和角色的同步率真是太驚人了。",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_076"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n光靠「mimi」的潛入功能",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是不可能得出這種數值的。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很厲害吧，",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_077"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "甚至連物件的質感都能感受到喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那孩子能說出我們所無法感受的部分，真的是幫了大忙。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "原來如此……",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_078"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真有意思呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n關於現實中的身體所受到的影響，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "特別是致死程度的痛楚，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n要是能讓那孩子體會看看，真不知道會怎麼樣呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真那……",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_079"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你負責的事務不包括這個吧，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這是我",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "和長老的管轄範圍。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n還有我們做研究就是為了不讓人承受那種感覺。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哎呀，",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_080"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真可惜。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n那就讓我來幫忙吧？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "呵呵。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n例如照顧實驗鼠之類的，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "交給我來做也不錯吧？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你看起來心情很好嘛，真那。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_081"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n和我聊天有那麼有趣嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "既然如此，要不要開開心心一起吃個午餐？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我請客喔？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……要跟他人同桌用餐，我實在敬謝不敏。",
        "unit_id": 106931,
        "voice": "vo_adv_5201001_082"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那我們就聊到這裡。",
        "unit_id": 106831,
        "voice": "vo_adv_5201001_083"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n反正我該給的東西已經給了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你快走吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶、真那",
        "words": "「……真是個麻煩的傢伙。」\n「……真是個狂妄的人。」",
        "unit_id": 1,
        "voice": "vo_adv_5201001_084"
    },
    {
        "type": "still",
        "still": "end"
    }
]