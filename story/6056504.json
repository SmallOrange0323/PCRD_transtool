[
    {
        "type": "background",
        "background": "501161"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……新年的規劃嗎？",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有規劃。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那些季節性的節慶，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我本來就沒什麼閒暇能夠參與。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的，",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "忙那些堆積如山的事。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n當然，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了完成那些事，接下來也會請你四處奔走。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……對於你接下來的表現，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我可是深懷期待的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "死心吧，",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "用那種小狗般期盼的眼神看我",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也沒用的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唉，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是拿你沒辦法……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果只是新年參拜，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n陪你一下倒也無妨就是……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想不到你這人也越來越有一手了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真是的，",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "受不了你這個人。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也必須承認即使是我，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "偶爾也需要休息一下。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你可別因為是新年，就過度鬆懈懶散喔。",
        "unit_id": 115011
    }
]