        "voice": "vo_adv_1056006_049"
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥！",
        "unit_id": 105612,
        "voice": "vo_adv_1056006_050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "助我一臂之力！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我不會讓任何人，",
        "unit_id": 105612
    },
    {
