        "voice": "vo_adv_1056006_058"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "竟然搞這種小手段！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣一來也能分散那傢伙的注意力吧。",
