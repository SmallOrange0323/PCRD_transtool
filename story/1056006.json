        "voice": "vo_adv_1056006_075"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的絕妙刀法！妖刀混帳！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n秘劍，",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "零之太刀！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "水月鏡花！",
        "unit_id": 105612
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "……",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_076"
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "漂亮。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "沒想到你只斬除了我的妖氣……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "\n很好很好……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "如果是你這樣的使刀之人……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_077"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有受傷嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒有事吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太好了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我很久沒使過這招式，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "順利成功真是太好了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其實剛剛那招，",
