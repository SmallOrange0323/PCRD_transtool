        "type": "dialogue",
        "name": "流夏",
        "words": "就算拿著它也沒問題。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "呵、",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_079"
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "呵呵……",
