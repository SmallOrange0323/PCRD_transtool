    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不要亂來啦，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_084"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟你廝殺這種事，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我可不想碰上啊……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是啊！",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_085"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嚇得我以為心臟都停下來了！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那就好……",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_086"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "以後不准再做那種事囉？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好奇怪……",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_087"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在放心的感覺，連自己都嚇了一跳。",
