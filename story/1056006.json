    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥以前陪著我的時候，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都是這種心情嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看到你出事",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_088"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我已經很～清楚地了解那種擔心的感受了……",
        "unit_id": 105611
