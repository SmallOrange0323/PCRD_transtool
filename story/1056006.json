        "name": "流夏",
        "words": "在我的面前死掉──！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "唔！",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_051"
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "嘎哈哈哈哈！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "女人！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
