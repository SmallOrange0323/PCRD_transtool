    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "快消失了。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "我的意志逐漸在消失……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "\n女人啊，妳的名字是？",
