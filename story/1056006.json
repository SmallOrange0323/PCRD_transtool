        "voice": "vo_adv_1056006_073"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你封住了它的行動！？",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難道你……",
