    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_080"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我叫流夏。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "突然問這個做什麼",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想當成帶去冥界的土產嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "我名為",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_081"
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "「波浪丸」",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "……妳正是",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "配得上我的使刀之人……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "\n啊啊，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "這麼一來，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "妖刀",
        "words": "我終於能夠恢復成一把普通的刀了……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_082"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就為了這件事搞那麼多名堂嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n魯莽耿直也要有個限度啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是沒辦法。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟只是一把刀嘛。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
