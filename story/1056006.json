        "voice": "vo_adv_1056006_046"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "不可以逃走！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不要在這裡堅持這種無聊的原則！",
