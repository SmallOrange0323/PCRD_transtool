        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這個笨蛋！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為什麼要那麼做！",
