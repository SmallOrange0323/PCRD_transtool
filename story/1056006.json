        "voice": "vo_adv_1056006_048"
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "連自己有多少斤兩都搞不清楚的蠢貨……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "\n現在就讓你們死在這裡……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "哇、哇啊啊啊啊！",
