[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，外出打工到了深夜才回家的{player}，\n在回家路上遇見流夏──"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？小哥。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼晚要去哪裡啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，你正要回家啊。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那就快點回去吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n最近蘭德索爾出現了隨機殺人的殺人魔，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你應該也聽說了吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家都很怕那傢伙。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我這幾天夜裡在路上看到的，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n只剩下對實力有自信的人，或是騎士團的騎士。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這附近有些店面還開著，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是裡面根本沒有客人。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你問我為何在這裡？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你應該已經猜到了吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是被大家委託來擊退殺人魔的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我很高興你有這個心，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這次真的很危險。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果你有個安全的地方可以待，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就趕快回去吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥……",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "確實如此！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你贏了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我知道了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，你絕對不可以離開我的身邊喔──",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "──哇啊啊啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_1056006_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "馬上就出現了嗎！",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "走囉，小哥！",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂你，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還好嗎！？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔、",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太好了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還有呼吸。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你、你是……",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "發生了什麼事？　",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們，",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "本來想要打倒殺人魔……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n可是，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們完全不是它的對手……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他的臉呢？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你沒有看到他的臉嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "臉……",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那、",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那東西，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "根本不是人類……！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要追過去的話，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們也要小心……！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也是。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果能動的話就趁早逃走吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還是說需要叫人來幫忙？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 1011,
        "voice": "vo_adv_1056006_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我還能動，沒關係……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "等等。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我的搭檔不見了……！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我的夥伴本來也在這裡啊。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們沒有看見他嗎！？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒有耶？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他會不會是跑去叫人來幫忙了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果看見他的話，會幫忙轉達你的狀況。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "再會！",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是人類？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難不成有魔物潛入城鎮來了嗎……？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們得在下一個被害者出現之前，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "找到殺人魔才行！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "喝！",
        "unit_id": 711,
        "voice": "vo_adv_1056006_022"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "──唔哇！",
        "unit_id": 311,
        "voice": "vo_adv_1056006_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是……？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_024"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "……",
        "unit_id": 712,
        "voice": "vo_adv_1056006_025"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "呼。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "終於肯老實聽話了嗎。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "剛剛真的讓我捏了一把冷汗呢。",
        "unit_id": 711,
        "voice": "vo_adv_1056006_026"
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "突然間就暴動起來……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來是不需要我們的幫忙了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "騎士大人啊，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那傢伙是什麼人？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "傳聞中的殺人魔嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "我不知道。",
        "unit_id": 711,
        "voice": "vo_adv_1056006_028"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "他突然攻擊我們。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "\n不管怎麼樣，先把他抓起來帶走。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "武器也得回收……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是刀啊。",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在這一帶很少見的說……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀呀，事情解決了呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "後面交給騎士團，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就先回去吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "嗚啊啊啊啊啊！",
        "unit_id": 711,
        "voice": "vo_adv_1056006_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了！？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_031"
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "唔嗚嗚嗚嗚嗚嗚嗚……！",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_032"
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "還不夠，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "還不夠……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "\n不過這個身體，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "似乎比剛剛的還要堪用一些……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "怎、",
        "unit_id": 712,
        "voice": "vo_adv_1056006_033"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "怎麼回事……！？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "這、到底……！！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "魔物！？",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，不對……！？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "嘎嘎嘎嘎……！",
        "unit_id": 1611,
        "voice": "vo_adv_1056006_035"
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "我的模樣終於也能顯現出來了……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "\n那邊那個女人。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士1（妖刀）",
        "words": "看來是個相當不錯的使刀之人……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "怎麼了！",
        "unit_id": 711,
        "voice": "vo_adv_1056006_036"
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "振作一點！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那把刀……！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還小的時候，曾在故鄉聽過一個故事……",
        "unit_id": 105611,
        "voice": "vo_adv_1056006_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖是物品，卻擁有自我意識的妖刀……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那把刀，一定也是同一種刀！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "喂，",
        "unit_id": 712,
        "voice": "vo_adv_1056006_039"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "發生什麼事了！？",
