[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 105911,
        "voice": "vo_adv_9032156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算是打倒了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過變色龍，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可真是令人好奇的生物呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n靠近一點看看吧……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9032156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貿然接近是很危險的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠已經無法動彈了，",
        "unit_id": 105911,
        "voice": "vo_adv_9032156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請放心吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這不可思議的皮膚",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是怎麼樣的觸感呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下瞭解一下……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀嗚嗚嗚嗚嗚！？",
        "unit_id": 105911,
        "voice": "vo_adv_9032156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "裝死！？　",
        "unit_id": 106011,
        "voice": "vo_adv_9032156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟敢給我耍這種小聰明，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　",
        "unit_id": 105811,
        "voice": "vo_adv_9032156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我馬上來救妳！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n給我乖乖地變成今晚的配菜吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呿，",
        "unit_id": 106011,
        "voice": "vo_adv_9032156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居然隱身逃掉了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要追了喲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……萬、",
        "unit_id": 105911,
        "voice": "vo_adv_9032156_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬分抱歉。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雙腿使不上力了…",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n別管在下了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請兩位快追上去吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在說什麼傻話啊。",
        "unit_id": 106011,
        "voice": "vo_adv_9032156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼可能把妳丟在這種地方。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！　",
        "unit_id": 105811,
        "voice": "vo_adv_9032156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒有打倒鱉先生，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但已經搞清楚事件的真相了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天這樣就夠了☆",
        "unit_id": 105811
    }
]