    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這孩子……",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "放在這邊好了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "咦，",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似似花妳又買了嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n變色龍玩偶。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n很可愛對吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "咦？",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n把親近的東西放在身邊尋求心靈安定",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在醫學上也是個很好的方法呢，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我覺得工作效率也會跟著提升喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我沒有問妳",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "醫學上的見解。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊哈哈，",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那真是抱歉。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我是覺得",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很可愛啦。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n莫非妳",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還有為這些孩子取名字嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "名字嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那不太好喔。",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n名字很重要的吧，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟看妳",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "買了這麼多隻。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是這樣子的嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我覺得沒有特別需要──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "凱思帕魯格，",
        "unit_id": 107131,
        "voice": "vo_adv_5201063_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就這個吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說什麼呢，克莉絲，",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼突然。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我並沒有在募集名字。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "迦羅求羅",
        "unit_id": 107331,
        "voice": "vo_adv_5201063_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "就可以了吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼連教授你也來湊熱鬧。",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就說了我沒有要名字──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家取的名字都有點難懂啊，",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_013"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是不是有點缺乏記憶點？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "既然是似似花的變色龍，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是似似龍吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n不錯吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似似龍。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……………………………………",
        "unit_id": 106931,
        "voice": "vo_adv_5201063_014"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這種名字是想讓人記住什麼啊？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我都聽見了喔～？",
        "unit_id": 106831,
        "voice": "vo_adv_5201063_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不然",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真那你會取什麼樣的名字呢～？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n想必",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "有個了不起的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好名字",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在等著拿出來對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哈，",
        "unit_id": 106931,
        "voice": "vo_adv_5201063_016"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "無聊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "無機物需要什麼名字嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你們的遊戲我可沒有興趣。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯，",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那說得對──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不然就叫希留耶好了？",
        "unit_id": 106931,
        "voice": "vo_adv_5201063_018"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我隨便想的名字。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "結果還是要參加的話",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有必要先說自己沒有興趣嗎，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那？　",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "現士實似似花啊。",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……莫非連長老你也想參加？",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_021"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "不，",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_022"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "我就不參加了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "比起這些，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "有人要我傳話給妳。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不參加……",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "太好了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不會再繼續增加──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……傳話？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是誰……？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「現士實",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "高冠。」",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "是「她」的提案。",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_026"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……所以說，",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_027"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "怎麼辦？",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n既然大家都提出意見，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就該一起來好好決定了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5201063_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……格列戈爾。",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_029"
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "！？",
        "unit_id": 1,
        "voice": "vo_adv_5201063_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這孩子的名字",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是格列戈爾。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "似似花啊，",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_032"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "也該考慮其他意見──",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "格列戈爾。",
        "unit_id": 107031,
        "voice": "vo_adv_5201063_033"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "……那就格列戈爾。",
        "unit_id": 107231,
        "voice": "vo_adv_5201063_034"
    }
]