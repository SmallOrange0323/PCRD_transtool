    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n涅比亞獨自一人在街上散步。"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "之前這裡還是",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "水鄉澤國的感覺，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在全都復原了呢～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "復原當然是很好啦。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n但又回到熱得要命的日常",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "實在讓人很不爽……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n不管是飛是坐都熱死人了……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊！",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "下次試試看把整個城鎮都冷卻下來如何？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n不改變環境，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而是挪動時間之類的？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哈哈！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一定會引發大混亂吧～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是現在已經無法使用環境系統了……",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n唉～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真沒意思……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "！",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你幹嘛！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "為什麼要追上來！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊……",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是來抓我的對吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我就知道。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n肯定是凱留叫你來的吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要你把我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "吃掉。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……她沒叫你來？",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n唔、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你是",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "自己想要",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n來追我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "的啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等一下。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我才不會鬧彆扭而搞破壞好嗎！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你是在擔心那個嗎……？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那好吧。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "欸，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "把時間借我一下吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我正好在思考",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "新的惡作劇方式♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你也提一些點子吧──",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "很遺憾，",
        "unit_id": 1411,
        "voice": "vo_adv_1186003_009"
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "本店不提供賒帳服務喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "抱歉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "不過",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "這個市場明天也會營業。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n只要先付些訂金",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "我就幫妳保留。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯…………………………",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該怎麼辦呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完全超出我的預算啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我雖然想要獨角獸的角，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但光是這樣總覺得不太夠……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "這可是稀世珍寶啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1186003_011"
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "聽說現在已經無法取得了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n更何況",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "大家都說獨角獸絕種了嘛。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n考慮得越久，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "我可就越難幫妳保留下來喔？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽你這麼說我是很心動啦……",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯…………",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦～",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真令人懷念啊♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過既然要主打稀有價值，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只有獨角獸的角怎麼行呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n還得要有金色鬃毛啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但我看",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這裡似乎沒有就是了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對喔！",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "獨角獸的角就該配上金色鬃毛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這樣就能製作出命運之劍了──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好懷念啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是{player}啊。你在這幹嘛？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒錯沒錯♪",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然我根本沒在走就是了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你身邊這個該不會是嚮導小妖精吧！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好久沒看到了耶～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳好啊♪",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "對了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳買獨角獸的角是打算做什麼？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我在店門口看到，",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "突然就覺得很懷念啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}，你還記得嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼嘛～",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不記得啦？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也沒辦法！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在不同以往了嘛。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那個時候可好玩了♪",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "各種惡作劇都玩透透☆",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過話說回來，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "想不到現在還能看到獨角獸的角",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n出現在市面上。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳要買",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這個嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不！",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我決定還是別買了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n冷靜想想",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "覺得實在太貴了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "咦咦！？",
        "unit_id": 1411,
        "voice": "vo_adv_1186003_022"
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "喂喂喂，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "妳這麼輕易就放棄啦？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n這可是稀世珍寶耶？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "剛才不是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "都跟妳說過了嗎！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "妳都不知道我是花了多少錢才買到手的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那麼，",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "只要數量變多",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就沒問題了對吧♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n嘿！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "哇啊啊！？",
        "unit_id": 1411,
        "voice": "vo_adv_1186003_024"
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n獨角獸的角……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "變多了！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n而且還堆積如山……！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈☆",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_025"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n有了這麼多，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就不再是稀世珍寶了吧～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n任何人想要肯定都買得到囉♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "什、",
        "unit_id": 1411,
        "voice": "vo_adv_1186003_026"
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "什、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "什麼……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "這些肯定是假貨吧！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "\n這下妳要怎麼賠我，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "古董店的店長",
        "words": "通通都混在一起了啦……！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是真是假，",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你拿去鑑定一下不就知道了嗎♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然是複製品，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但從數據層級來看全部都等同真品，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你不用擔心啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈☆",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這下被刻意炒作的什麼",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "稀有道具的價格",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就要崩盤囉～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔，",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳真是個大壞蛋啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "之前把蘭德索爾整個泡到水裡的惡作劇",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我也聽說了，妳可真行啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我才不是壞蛋咧。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是普通的嚮導小妖精啦♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只是愛惡作劇而已！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "變成水都的蘭德索爾，",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我沒能親眼見證實在可惜……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但聽說那真的是非同小可。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就連絕世大壞蛋大人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都很難想出那樣的惡作劇啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈！",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "因為我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是為了給大家增添遊戲樂趣而存在的嘛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n無論說我是充滿bug，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還是喜歡惡作劇，其實都一樣。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我就是想讓大家歡度夏日♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_033"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "該發揮的時候我一定放手一搏♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然常常會太過火就是了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "整天惡作劇的日常",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_034"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是很讚的喔。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "凱留的尖叫也總是很悅耳♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……但最近有點不太一樣就是了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然不知道為什麼……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "倒不是",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_035"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "覺得玩膩了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n以前有時候也會因為鬧彆扭而惡作劇，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在只為了找樂子而惡作劇，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "應該啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……哦～",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我問妳，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嚮導小妖精",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有所謂成長要素嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是會隨著環境",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而變化之類的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那樣的話，",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也有可能是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳的惡作劇參數",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n隨著環境而逐漸下降了也說不定啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "應該沒有那種設定才對。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_038"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n如果看起來真有這種傾向，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那應該是某種bug吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "因為之前我有點過度勉強自己，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "導致狀況越來越",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "惡化。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "最近",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_039"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我常會出現各種小毛病。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但也無能為力就是了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊。",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就來實驗看看吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n既然不再像以前那麼愛惡作劇，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就換個路線改當壞蛋，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這樣的變化",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我非常歡迎喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等等，",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_041"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別做那種奇怪的實驗好嗎！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我又不是出於喜歡才充滿bug的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說回來，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "姑且不論會不會壞掉，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "為什麼我要變成壞蛋啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果有個壞蛋嚮導小妖精的話，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會讓人很想打倒她對吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那種妖精",
        "unit_id": 106113,
        "voice": "vo_adv_1186003_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "實在太難得一見了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n顯得特別珍貴啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以我不是認真想打倒妳喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是提出一個假設而已。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……真是的，",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_044"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別喜孜孜地講出那種危險的想法好嗎！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在當事人面前也太不吉利了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n再說",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我哪有可能這麼輕易就壞掉啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就算再怎麼充滿bug，",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_045"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也不會輕易……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n應該啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……唔。",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_046"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你不要",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "每次都突然冒出這句話好嗎。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "說什麼即使……",
        "unit_id": 190911,
        "voice": "vo_adv_1186003_047"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就叫你別說那種不吉利的話了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n不過這話出自你口中，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
