        "type": "dialogue",
        "name": "智",
        "words": "\n妳看，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有一個人。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呵呵……",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄秀都還沒開始，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n就開始幫英雄加油可是不行的喔？",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好，",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_068"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來已經準備好了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "去吧，茉莉。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n當然，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也會為妳加油的♪",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……謝謝，",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_069"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～！",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大家都在等我。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我這就去！！",
        "unit_id": 123912
    },
    {
        "type": "still",
        "still": "510400701"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哼哼哼……！",
        "unit_id": 123911,
        "voice": "vo_adv_5104007_070"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n各位乖孩子，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓你們久等了！！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的名字是",
        "unit_id": 123911,
        "voice": "vo_adv_5104007_071"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "勇氣之虎！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是身為獸人族，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也是來自【王宮騎士團】的……",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "守護大家的，",
        "unit_id": 123911,
        "voice": "vo_adv_5104007_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "正義英雄！！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，經由茉莉等人踏出了邁向和平的一步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而後的【王宮騎士團】不只是人族，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也向各個種族敞開了大門，達到更進一步的發展。"
