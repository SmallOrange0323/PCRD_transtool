        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這裡得要靠我自己",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一個人戰鬥才行……！　",
