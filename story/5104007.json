        "voice": "vo_adv_5104007_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳這種強硬的地方都沒有改變呢。",
