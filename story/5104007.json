    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "馬上就要開場了，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的腳還在不停地發抖啊～！　",
        "unit_id": 123912
    },
