        "voice": "vo_adv_5104007_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡就交給我。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長就去看茉莉的英雄秀吧。",
