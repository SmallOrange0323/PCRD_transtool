    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下個休息日，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳要和我一對一決鬥啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……謝謝妳，",
