        "unit_id": 104711,
        "voice": "vo_adv_5104007_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳把劍立在地上……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是什麼意思……？",
