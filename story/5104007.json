        "voice": "vo_adv_5104007_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感激不盡。",
