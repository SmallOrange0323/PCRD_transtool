        "voice": "vo_adv_5104007_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "認可部下的努力，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也是上司的重要工作之一。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是這麼想的。",
        "unit_id": 107111
    },
