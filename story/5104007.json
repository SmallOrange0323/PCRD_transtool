[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茉莉和克莉絲提娜兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n結束了作為【王宮騎士團】和獸人族和平大使的活動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n久違地享受了休假──"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比我預想中的",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還要更平靜呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n茉莉的衝擊性告白。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然大家都裝作沒發現，",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是幾乎所有團員都已經知道了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話雖如此，",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好像還是有少部分人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n第一次聽說茉莉是獸人族這件事，因此受到了震撼……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過也沒有發生什麼問題，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就這樣子接受真是太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我接下來要去幫忙英雄秀，就先告辭了。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "路上小心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……真是和平呢。",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天感覺也會是個好日子。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "糟透了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既和平又太過乏味到令人煩躁。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼和平的日子，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是什麼都不做，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就會有種血液像是要凝固般的倦怠感。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管是誰都好，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來幫我排解無聊吧……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "啊，",
        "unit_id": 8811,
        "voice": "vo_adv_5104007_009"
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "克莉蹦！",
        "unit_id": 8811
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "\n好久不見蹦～♪",
        "unit_id": 8811
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "這可真巧啊，",
        "unit_id": 8611,
        "voice": "vo_adv_5104007_010"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "一切都好嗎？",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還想說是在哪裡見過的面孔……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這裡做什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "我們正要去看茉莉蹦的英雄秀蹦！",
        "unit_id": 8811,
        "voice": "vo_adv_5104007_012"
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "\n",
        "unit_id": 8811
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "我是第一次看英雄秀，所以很期待蹦！",
        "unit_id": 8811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "英雄秀……？",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼說起來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n茉莉好像有說過呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以說，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要去看英雄秀的人為什麼會在這裡？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是開演前的觀光，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "未免有些太過乏味了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "不，",
        "unit_id": 8611,
        "voice": "vo_adv_5104007_015"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "那是因為……",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那是，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別賣關子快點告訴我吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "那是，",
        "unit_id": 8811,
        "voice": "vo_adv_5104007_017"
    },
    {
        "type": "dialogue",
        "name": "兔子族",
        "words": "因為我們迷路了蹦！！",
        "unit_id": 8811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔……？",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "剛剛一瞬間",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "突然有種刺骨的寒意……！",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒事吧，",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是因為第一次演主角所以在緊張吧？",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是這樣子嗎……？",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只是我的錯覺就好了。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒想到茉莉居然",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會被推選來當超級英雄秀的主角呢。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來團長也是做了個大膽的決定。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為如果都是同樣的戲碼，",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "觀眾也會看膩嘛。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然還是需要有新的變化！",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我自己的話，",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n光看主角演員的動作",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和對打場面的不同就會覺得興奮。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過小孩子觀眾不太在意這種地方。",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這次的英雄秀，",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是和各種不同種族的競爭對手",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "以及夥伴們",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "合力打倒敵人，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "展開讓人心生雀躍的熱血故事……！",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是是。",
        "unit_id": 103712,
        "voice": "vo_adv_5104007_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "熱血沸騰又有幹勁是很好，",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但是要好好準備英雄秀才行啊。",
        "unit_id": 103712
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我把票",
        "unit_id": 123912,
        "voice": "vo_adv_5104007_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "送給那些照顧過我的人了，",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不知道大家會不會來呢……？",
        "unit_id": 123912
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有人來了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在這裡做什麼呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗨，",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如妳所見，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我在當守衛喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲，",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳不去看茉莉的英雄秀沒關係嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我如果有時間的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也是很想去看呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很不巧，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我對那種訴說乏味理想論和正義，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n騙小孩的英雄秀沒有興趣呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "趁機闖上台去搗亂，",
        "unit_id": 107111,
        "voice": "vo_adv_5104007_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種惡作劇以前也做過了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再做同樣的事情也沒什麼意思吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳願意在這裡陪我聊聊天嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我現在還不能離開這裡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈！",
        "unit_id": 107111,
