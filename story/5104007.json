    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………？",
        "unit_id": 104711,
        "voice": "vo_adv_5104007_040"
    },
    {
        "type": "dialogue",
        "name": "純",
