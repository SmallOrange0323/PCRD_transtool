    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "希望她不會緊張就好。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "茉莉的母親",
        "words": "是呢……",
