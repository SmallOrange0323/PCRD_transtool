[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……嗯，",
        "unit_id": 103113,
        "voice": "vo_adv_5084630_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒錯，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幽靈們。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果有什麼萬一，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會拜託大家",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有父親，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n一起去將那個人從夢中帶回來的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……太過擔心了，",
        "unit_id": 103113,
        "voice": "vo_adv_5084630_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……至今為止，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個人的確克服了無數難關。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就連我的占卜也得到了不會發生壞事的結果，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……對不起。",
        "unit_id": 103113,
        "voice": "vo_adv_5084630_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣很不冷靜，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好像比自己想的還要更依賴那個人。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n光是像這樣無法和他說話，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就好不安……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他自在地接納",
        "unit_id": 103113,
        "voice": "vo_adv_5084630_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「看得見」的我，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也接納了幽靈們，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的是非常特別的人……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……所以，就再等等吧。",
        "unit_id": 103113,
        "voice": "vo_adv_5084630_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果是那個人的話，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一定會回到我們身邊的。",
        "unit_id": 103113
    }
]