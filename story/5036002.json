[
    {
        "type": "background",
        "background": "500930"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人為了拯救被囚禁的人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了盆栽小花的附近。"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "繆思小鎮……",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_000"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "直到剛剛",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "明明就還那麼熱鬧呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "現在卻連個人影，",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_001"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "都看不到了呢。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這也沒辦法嘛。",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟「盆栽小花」\n像那樣聳立著嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在下等人，",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得去救出被囚禁在「盆栽小花」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n裡頭的人們才行……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但棘手的，",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_004"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "還是那個花粉呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n會讓人打噴嚏這點自然不必說……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但似乎還有",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "某種魔法效果的樣子。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "如果只是用布蓋住口鼻的話也擋不住，",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_005"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "如果吸太多了，頭還會變得昏昏沉沉的呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "真的令人很困擾呢～！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使從遠處射擊箭矢，",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種程度的攻擊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "它也完全不為所動呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那層外皮，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎比乍看之下還要堅硬的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "擅長魔法攻擊的小凱留被抓走了，",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對我們來說是個重傷呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "而且如果用太強力的攻擊破壞，",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_008"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n有可能導致裡頭的人們受到波及……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這樣很危險呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實相當困擾呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅不得隨意接近，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時也不能草率地破壞……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼究竟",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "皮喵太",
        "words": "皮喵……",
        "unit_id": 4411,
        "voice": "vo_adv_5036002_010"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那樣的話，",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_011"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我們要不要對它唱歌試試看呀！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊，",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_012"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "原來如此～！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "剛才",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "「盆栽小花」也是，\n對我們唱的歌產生反應了嘛！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "未央和卯月，",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_013"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "妳們等一下。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果因為這樣讓「盆栽小花」越變越大，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n不就反而會讓事態更加惡化了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈，",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_014"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "說的也是──",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "欸嘿嘿……",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不……",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定是好主意呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦？",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_017"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "佩可小姐？",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果「盆栽小花」真的\n聽到大家的歌聲就會變大的話……",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就乾脆，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓它變大到極限為止吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦咦咦？",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟「盆栽小花」細細長長",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且頂端渾圓，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果讓它盡可能地變大……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……啊！",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_022"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n那它就會失去平衡……！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105812,
        "voice": "vo_adv_5036002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定會碰咚──☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一聲",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "倒下來呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "咦咦……？",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_024"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真的辦得到嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那種事……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凜小姐的不安，",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實有所道理……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可是，",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_026"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "感覺好像很有趣♪",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯嗯！",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_027"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n反正光想也不會有什麼改變……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那不如就試試看吧，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這個方案！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……哎……",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_028"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真拿妳們沒辦法。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果真要這麼做，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那就要全力以赴喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真不愧是澀凜凜♪",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_029"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼就，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "音樂，開始──",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給我慢著喵────！！！",
        "unit_id": 1,
        "voice": "vo_adv_5036002_030"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦！？",
        "unit_id": 112611,
        "voice": "vo_adv_5036002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個聲音是……！",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳們那麼難聽的歌聲，",
        "unit_id": 1,
        "voice": "vo_adv_5036002_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哪有人聽得下去呀喵──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對呀對呀──！",
        "unit_id": 1,
        "voice": "vo_adv_5036002_034"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦咦咦！？",
        "unit_id": 112411,
        "voice": "vo_adv_5036002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請看那邊！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在「盆栽小花」的嘴邊附近……！",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "503600201"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "凱留凱留～♪",
        "unit_id": 106011,
        "voice": "vo_adv_5036002_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n偶像凱留，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "華麗地、登、場、喵～♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可等人",
        "words": "小凱留！？",
        "unit_id": 1,
        "voice": "vo_adv_5036002_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從現在開始，",
        "unit_id": 106011,
        "voice": "vo_adv_5036002_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡就是我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n【Prosperity‧Cats】的舞台了喵──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "新人偶像們",
        "words": "對呀對呀──！",
        "unit_id": 1,
        "voice": "vo_adv_5036002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她身旁的兩位，",
        "unit_id": 105913,
        "voice": "vo_adv_5036002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是方才也有參加甄選的那兩位呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不、",
        "unit_id": 112511,
        "voice": "vo_adv_5036002_042"
    },
    {
        "type": "dialogue",
        "name": "凜",
