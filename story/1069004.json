[
    {
        "type": "background",
        "background": "500135"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "重獲自由的霸瞳皇帝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與迷宮女王帶領的七冠等人聯手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n試圖牽制終炎巨神的行動。"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "慘不忍睹……",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然擅自把這個世界破壞成這副德性。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別以為塊頭大",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就可以膽大妄為啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……儘管感受很薄弱，",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但我確實",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "因此而感到焦躁。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為什麼呢？",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_002"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這種不如我意發展的世界，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我本該毫不在意才對……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我在不知不覺中，",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n對這個本該處處都看不順眼的世界",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "產生了感情……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我記得那是在……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那是在米奈娃的失蹤公諸於世前發生的事。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現米奈娃失蹤的七冠等人在WISDOM總部，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n召開了一場極機密會議──"
    },
    {
        "type": "still",
        "still": "106900401"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_004"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳的意志甚堅呢，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "晶。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "之後會有什麼下場我可不管喔？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "事情都討論完了吧？",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那我先走了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我不能",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "把米奈娃交給你們。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "驟下結論，妳遲早會後悔的喔，",
        "unit_id": 107031,
        "voice": "vo_adv_1069004_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難得今天我會跟似似花持相同意見。",
        "unit_id": 107131,
        "voice": "vo_adv_1069004_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很遺憾竟然連我們之間的友情都並非絕對……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若妳膽敢妨礙我們，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不會對妳手下留情。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "絕對不會。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也是啊，",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "克莉絲。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n遺憾的是，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對我而言，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n如今也是必須",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "以「絕對」來堅持己見的時刻。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……你們雙方的想法我都不認同。",
        "unit_id": 107331,
        "voice": "vo_adv_1069004_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n今後我還是會",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "繼續照我的方式行動。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "若你有自信打倒我們就請便。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_010"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n到時你自豪的手腳被扯斷了，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "可別在那邊哭天喊地喔。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "真那……",
        "unit_id": 107331,
        "voice": "vo_adv_1069004_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "你那比樹枝還易斷的纖細脖子，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n也就只剩現在",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "能發聲了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n還是早早準備好遺言吧。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哈，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_012"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不敢親臨現場的懦夫",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "還敢大放厥詞？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "跟你們這群自私自利的人不一樣，",
        "unit_id": 107331,
        "voice": "vo_adv_1069004_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我還有課要教。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n要是現實裡可以像阿斯特朗那樣使用跳躍，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n你的心臟現在已經被我捏爛了。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "自私自利……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_014"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n你這個暴力的化身真好意思這麼說。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那兩個人",
        "unit_id": 107031,
        "voice": "vo_adv_1069004_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "永遠都是老樣子呢……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……晶。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們終究",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是分道揚鑣了嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似似花……",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "分道揚鑣了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "分得一乾二淨。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我沒想到製作阿斯特朗……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n培育米奈娃",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是基於那麼自私的理由。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "要說自私，任誰都一樣吧？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_017"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳也",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "照著妳自己想要的方式活下去就好。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n前提是妳要有辦法活下去……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "──妳要走了嗎，",
        "unit_id": 1,
        "voice": "vo_adv_1069004_018"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "晶？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶等人",
        "words": "！？",
        "unit_id": 1,
        "voice": "vo_adv_1069004_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "長老！？",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_020"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太難得了……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你都多久沒露面啦？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是啊，我要走了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也有打算要去日本，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n反正全世界到處跑啦。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我有非做不可的事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "等一下，晶。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_021"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳以為只有妳一個人是正確的？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n如果妳打算獨自使用米奈娃……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我才不會那麼做。",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_022"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也不覺得那孩子會認同我那麼做。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我知道",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你現在也是躍躍欲試，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n但你好歹也要考慮到有可能會被拒絕啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "考慮那是浪費時間。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_023"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "膽敢拒絕我，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n我就不擇手段逼她乖乖就範。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……對了，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_024"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "棗老師。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n你也是",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "來宣告加入這場米奈娃爭奪戰的嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……我對你們的爭奪沒興趣。",
        "unit_id": 1,
        "voice": "vo_adv_1069004_025"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n但要是我女兒的平靜生活受到威脅，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "那就另當別論了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你還是一樣溺愛孩子呢。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_026"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "也罷。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n老師是中立……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不對，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是沒興趣呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那個今天沒有露面的傢伙，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_027"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n就視為態度和老師一致。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "反正她",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就連這種時刻也不跟我們聯絡。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "用行動來證明，",
        "unit_id": 1,
        "voice": "vo_adv_1069004_028"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n你們能夠創造出什麼樣的可能性吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請您不要把世界的命運",
        "unit_id": 107031,
        "voice": "vo_adv_1069004_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "講得像學分課題一樣。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天竟是我們幾個人最後一次聚首。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然我早有預期，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是感到遺憾。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能夠一直合作到今天本來就是個奇蹟。",
        "unit_id": 107131,
        "voice": "vo_adv_1069004_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們可是七冠，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "個個都是頭戴王冠的孤高王者……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n各自也都有自己理想的",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一套治世之道。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……我也曾經試圖相信",
        "unit_id": 106831,
        "voice": "vo_adv_1069004_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這一天不會到來啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不說了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家拜拜。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "……我也還有研究要做。",
        "unit_id": 1,
        "voice": "vo_adv_1069004_032"
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "\n告辭了，各位。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "希望下次相見時，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "長老",
        "words": "各位都一切安好。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "最後再聲明一次，",
        "unit_id": 107331,
        "voice": "vo_adv_1069004_033"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我不打算助晶一臂之力，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "也沒興趣加入你們的行列。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我會照我",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "自己的喜好去行動。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "告辭……",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真那大人。",
        "unit_id": 107131,
        "voice": "vo_adv_1069004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我和似似花先去和WISDOM協商，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n擬訂事情曝光時要採取什麼對策。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n後續行動且容後再議……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先告辭了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲。",
        "unit_id": 107031,
        "voice": "vo_adv_1069004_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在那之前，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我先和日本政府聯絡一下再去跟妳會合。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們晚點見。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_036"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "等著後悔吧，晶。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這場遊戲，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我一定會贏……！",
        "unit_id": 106931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，七冠一分為三：一派選擇獨自行動；"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n另一派選擇追隨真那；其餘則是不加干涉。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那之後又過了一陣子，某一天──"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "今天真的很感謝您",
        "unit_id": 1,
        "voice": "vo_adv_1069004_037"
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "不辭辛勞前來為我們演講！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "\n士條議員以及",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "所有與會者都覺得獲益良多啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真的嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_038"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我才該說謝謝呢，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n能與那麼多堪稱國家棟梁的顯貴人士進行一番深度談話，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n讓我今日倍感充實。還請代我轉達一聲。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "好的！",
        "unit_id": 1,
        "voice": "vo_adv_1069004_039"
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "您方才那段話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "我一定如實轉達！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "\n我們能有今天的成就，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "也是承蒙千里之宮家的庇蔭。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "\n今後還請您務必",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "議員",
        "words": "繼續提攜指教！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……連我對那個家做了什麼都不知道嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_040"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n真是個廢物……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "帶著這種人，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "士條議員他們也真是難為了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "您接下來有何打算？",
        "unit_id": 1,
        "voice": "vo_adv_1069004_041"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這個嘛……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_042"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我想一個人去走走。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "可是……",
        "unit_id": 1,
        "voice": "vo_adv_1069004_043"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你是擔心我",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_044"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "可能會遇襲受傷？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "放心。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不用等你們趕到，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我自己就能把歹徒收拾掉了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那點防身能力我還是有的。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_045"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "所以……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "暫時放我自由吧。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "好嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1069004_046"
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "好的……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_047"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "線索最多只能追蹤到",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_048"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "她來到了這個國家……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "晶……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳現在究竟在哪裡鬼混呢？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_049"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "成果如何？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "很抱歉……",
        "unit_id": 1,
        "voice": "vo_adv_1069004_050"
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "雖然接獲疑似目標出現的情報，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "\n但調查後確認只是幌子。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "我們會試著再擴大搜索網。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "太天真了。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_051"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不能抱著找「人」的心態去找。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n你們要當作在找一個比人類要難纏百倍的怪物。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "……了解。",
        "unit_id": 1,
        "voice": "vo_adv_1069004_052"
    },
    {
        "type": "dialogue",
        "name": "追兵",
        "words": "我會通知所有部下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……看來妳是不打算輕易被我找到呢。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_053"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "也罷。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "再多給妳一點時間慢慢想清楚。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "呼……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_054"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這夕陽餘暉",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_055"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真刺眼啊……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "嗯……？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_056"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "高中生……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_057"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "看起來不是什麼練家子。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "身上也沒藏武器，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是個極普通的路人。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你找我有事嗎？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_058"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……你怎麼會這麼認為呢？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_059"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我只是覺得夕陽很刺眼而已。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_060"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……彷彿要將我整個人燃燒殆盡似的。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "在世人眼裡，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_061"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我才更像怪物吧……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不過",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_062"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那也無妨。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "無論別人怎麼看我，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我對這個世界而言，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n都是唯一",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "且特別的存在，這點是毋庸置疑的。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "受人畏懼反倒",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "正合我意……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我啊，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_063"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "討厭這個世界。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你是這麼認為的？",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_064"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……很遺憾，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我們的",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "觀點不同。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……自懂事以來，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_065"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我一直很討厭這個世界。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不只因為那些陳腐的家規，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "也因為世上所有系統，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n都不把我這個超越「個人」框架的天才",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "當成人看待。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "既然如此，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_066"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就由我來覆寫那些系統。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n於是我開始",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "逐步實現這個想法。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "用一種任誰都絕無從仿效的速度，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "在人生道路上奔馳。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……然而大眾",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_067"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "依然企圖將我吞噬。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "用輕蔑的價值觀來對待我。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "以為用那些過時的詞彙，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "和未曾更新的認知，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就足以理解我。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "儘管這是理所當然的，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_068"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我的靈魂，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n卻無法從中獲得滿足感，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "反倒愈發飢渴……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "既然如此，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這次我乾脆直接覆寫整個世界。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "阿斯特朗",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_069"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就是我所嚮往的世界。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n在那裡",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我可以做回真正的自己……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "為了達成這個理想，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n果然還是必須擊退那個",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "與我程度相當的傢伙……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_070"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "總算理清思緒了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n話說，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "你怎麼會覺得世界……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "咦？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那孩子已經走掉了啊……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_071"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真可惜。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "剛才應該問他叫什麼名字的。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "您沒事吧？",
        "unit_id": 107131,
        "voice": "vo_adv_1069004_072"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哎呀，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_073"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "克莉絲。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "怎麼了嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "請不要丟下護衛自己一個人亂跑，",
        "unit_id": 107131,
        "voice": "vo_adv_1069004_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣很危險。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "妳的擔心是多餘的。",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_075"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n憑血肉之軀有辦法殺死我的，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "大概也只有教授了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "在妳過來之前，",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_076"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我遇到了一個感覺挺有意思的孩子喔。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是個學生，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "雖然看上去不太聰明……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_077"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我說你啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "倘若世界真的不討厭我，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n你覺得在這種現狀之下，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我該如何才能得救？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "事實就是",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這個世界容不下我啊？　",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這世上",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_078"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "盡是些被人際關係和刻板印象給束縛的蠢貨。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就像我出身的家族那樣……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "話說回來，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我好像在某個分家裡，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n見過一個跟方才那位學生",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "年齡相仿的女孩。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "有需要時",
        "unit_id": 106931,
        "voice": "vo_adv_1069004_079"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "就找她來當我的隨從好了。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n根據我的調查，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那孩子肯定也在盼望著有人對她伸出援手……",
        "unit_id": 106931
    },
    {
        "type": "background",
        "background": "500135"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喂喂真那！",
        "unit_id": 106811,
        "voice": "vo_adv_1069004_080"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你在發什麼呆啊！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我還以為你在戰鬥中掛網，嚇死人了！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n資敵行為可是很欠檢舉的喔～！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "給我認真工作～！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳這語氣",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_081"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是方才的回禮嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……我還覺得這樣挺有親切感的呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我完全聽不懂你在講什麼東西！",
        "unit_id": 106811,
        "voice": "vo_adv_1069004_082"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我說你們，也說他個幾句吧！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒用的，晶。",
        "unit_id": 107011,
        "voice": "vo_adv_1069004_083"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若妳以為真那是可以後天培養出善意，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好好傾聽他人說話的那種人……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那我勸妳別再癡心妄想了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說得沒錯！",
        "unit_id": 107111,
        "voice": "vo_adv_1069004_084"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不聽別人說話這點我也一樣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣才更能彰顯出我們的本色吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "說來奇怪，我也有那種感覺。",
        "unit_id": 107312,
        "voice": "vo_adv_1069004_085"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "言歸正題，",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "當前局面亟需團隊合作與精準判斷。",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n霸瞳皇帝！",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "請下達下一個指示！",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯。",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_086"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也不能在這裡倒下，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那些孩子們",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還欠我一件事沒完成。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們幾個",
        "unit_id": 106914,
        "voice": "vo_adv_1069004_087"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "聽好了……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n無論如何都要將我眼中看見的未來，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "掌握在手裡。",
