    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說那孩子",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n家裡非常有錢的樣子！",
        "unit_id": 106011
    },
