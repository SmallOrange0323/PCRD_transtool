        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能用這雙手捧起的",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一點珍貴之物。",
