        "unit_id": 311,
        "voice": "vo_adv_5116004_075"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "在森林中暴衝的",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "那位霸主的模樣。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸主……",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是指那隻大猿先生吧。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完全就是暴徒的樣子啊……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "如妳所見，不只植被，",
        "unit_id": 311,
        "voice": "vo_adv_5116004_077"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "動物和魔物也都受害了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "得趕快查明原因才行──",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_078"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您現在必須治療傷口。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "調查就由我們來進行。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們會送您到森林入口的，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您搭乘馬車回去吧。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "我知道了。",
        "unit_id": 311,
        "voice": "vo_adv_5116004_079"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "我不能待在這裡，成為你們的包袱。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "我就回去總部",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "報告這個情況吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就直接把您送到森林入口。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……當時，",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐的樣子有些不對勁。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就像是注意到什麼",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而停下動作一樣……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快到晚上了呢。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否有成功跟栞小姐會合呢……",
