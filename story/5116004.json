    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你會不會因為可可蘿不在",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_085"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而感到寂寞呢？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……沒事的喔，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就在這裡。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "像這樣把小小的身軀交託給我……",
