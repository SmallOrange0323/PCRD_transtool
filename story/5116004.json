[
    {
        "type": "background",
        "background": "501852"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在遠離集訓所的密林──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由獵人公會管轄的魔物保護區發生了異變。"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "究竟發生了什麼事……",
        "unit_id": 311,
        "voice": "vo_adv_5116004_000"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "這種事",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "在過去的資料中可沒有啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……",
        "unit_id": 1,
        "voice": "vo_adv_5116004_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "什……",
        "unit_id": 311,
        "voice": "vo_adv_5116004_002"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "你……！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔喔喔喔──！！",
        "unit_id": 1,
        "voice": "vo_adv_5116004_003"
    },
    {
        "type": "background",
        "background": "501692"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾乎在同一時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於天亮前集合的栞等人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在接受關於調查異變的說明。"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "你們要前往的",
        "unit_id": 414,
        "voice": "vo_adv_5116004_004"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "是被指定為魔物保護區的密林。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我希望你們與負責這附近地區的遊俠會合，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n並取得調查報告。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "雖然我希望你們盡量不要勉強，",
        "unit_id": 414,
        "voice": "vo_adv_5116004_005"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "但我現在也只能說……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n要配合當地的狀況",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "進行靈活的應對啊。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "一路小心。",
        "unit_id": 414
    },
    {
        "type": "background",
        "background": "501850"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──以上",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是這次的作戰概要。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "去找目標的遊俠吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "途中",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有確認到營地，所以",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該是在這附近才對──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔喔喔喔──！！",
        "unit_id": 1,
        "voice": "vo_adv_5116004_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔唔唔唔唔…………！",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請小心！",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "距離不遠了……！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那隻魔物……",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_011"
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕……",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩位，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你們看一下。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那隻魔物經過的痕跡……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "地面被翻起，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "樹木都被撞倒……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠似乎對自己的力量相當有自信。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "呼……",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_014"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "呼……",
        "unit_id": 17412
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "唔嗚……",
        "unit_id": 1812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有汪汪主人，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請不要離開在下的身邊。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那邊的草叢！",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有什麼東西！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "是誰！？",
        "unit_id": 311,
        "voice": "vo_adv_5116004_017"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "……啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "那身裝扮……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "你們是遊俠嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們是候補生。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們是前來密林進行調查的。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請問",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "究竟發生了什麼──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "…………！！",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_019"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "等一下再說！",
        "unit_id": 311,
        "voice": "vo_adv_5116004_020"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "那傢伙要來了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n快逃！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐！",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唔……",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我、",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不要緊！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是……！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "呼……",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_024"
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "呼……",
        "unit_id": 17412
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "停留在這裡很危險。",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n快點離開這個地方吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "遊俠先生，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你也是！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "……不，",
        "unit_id": 311,
        "voice": "vo_adv_5116004_026"
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "你們就先走吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "遊俠",
        "words": "\n我之後再追上去……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……他的腳受傷了……",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以才會無法逃離，躲在草叢裡吧……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有負傷者，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "眼前還有亢奮的大型魔物。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠對我們抱有敵意……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算一邊保護這個人一邊撤退，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還是會被追上並展開戰鬥……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "變成那樣的話，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就無法保障大家的安全。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果跟可可蘿他們合作，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許能夠打倒牠。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n為了保護我們自身安全，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就把這隻危險的魔物──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "────但是，",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那樣就……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐，",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒事吧！？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "快走吧！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……我來吸引這隻魔物的注意。",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可可蘿你們",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "趁那個空檔，把這個人送到安全的地方！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就請你幫忙運送了。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了！",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "麻煩你們了喔。",
        "unit_id": 125411,
        "voice": "vo_adv_5116004_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──大猿，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這邊！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "快看！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "森林大猿",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17412,
        "voice": "vo_adv_5116004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您去追栞小姐！",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算是栞小姐，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人還是很危險的。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這裡還有喵特在。",
        "unit_id": 125311,
        "voice": "vo_adv_5116004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
