    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在帕菲之城辦完事情之後發生的事──"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_000"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n你來的正好……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不好意思，",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_001"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "你有沒看到烏爾姆？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "明明到了打掃大廳的時間了，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我卻到處都找不到她。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嗯──",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_002"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這樣嗎……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……唉。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆真是的，",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_003"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "她每次都這樣。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n她明明就是萊拉耶爾殿下的女僕，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "卻老是在偷懶……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我今天",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "絕～～",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "對會好好跟她說教的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……不過在那之前，",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_004"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "必須先找出她，然後抓住她才行……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦？",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_005"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "可以嗎？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊……",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_006"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "你很忙吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這樣不好吧……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……那麼。",
