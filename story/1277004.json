    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我就",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "恭敬不如從命了喔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "之後我會跟烏爾姆一起",
        "unit_id": 127712,
        "voice": "vo_adv_1277004_008"
    },
    {
        "type": "dialogue",
        "name": "琳德",
