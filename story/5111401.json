    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "やっ。",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_000"
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "\n少年、",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "調子はどうだい？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "ん？　",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_001"
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "この姿？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "たまにはアタシもイメチェンしてみようかなと思って。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "\nなんて冗談冗談。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "この力がいつか、",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_002"
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "正しい時に、",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "正しい想いで使われるように。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "アタシも手を貸そうと思ってね。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "だから少年。",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_003"
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "\nキミも、",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "遠慮なくアタシを頼ってほしい。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "『絆の力』に",
        "unit_id": 121211,
        "voice": "vo_adv_5085401_004"
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "アタシも加えてくれると、",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "ラビリスタ",
        "words": "うれしいな。",
        "unit_id": 121211
    }
]