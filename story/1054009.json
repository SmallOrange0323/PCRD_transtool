        "voice": "vo_adv_1054009_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是他願意的話，我很希望他能再來幫我的忙，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但這要怎麼表達才好呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要用工作的名義去委託，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生就一定會來幫我的忙。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然都這樣了，就算不是工作也……",
