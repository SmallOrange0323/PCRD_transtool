[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，紡希把{player}叫了出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n說是有工作要做。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你來啦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "打工",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要麻煩你囉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要麻煩你幫忙的不是慈樂之音的工作，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而是裁縫店那邊的差事。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是要去採集染料的素材……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你為什麼要笑成那樣呀？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是發生什麼好事了嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我只是沒辦法才找你來幫忙的啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你願意接受，我當然也很感謝……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們就快點出發吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "詳情",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就邊走邊說！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這次要參加一場時裝秀，叫做蘭德索爾時裝秀。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是知名店家到個人店家都會參加的",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大型時裝秀喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我平常是不會參加這種時裝秀的……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟沒必要宣傳裁縫店，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n最近也有",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "慈樂之音那邊的活動要忙。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "之前在慈樂之音的演唱會上，有人誇獎了我們的衣服……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "自己製作的衣服被他人看見，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n果然是件很開心的事。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想要",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓很多人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看見我製作的衣服。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我所製作的衣服，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該能在每日的生活中，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為穿著它的人帶來光輝──哪怕只有一點也好。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不論是覺得辛苦",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "或沒有精神時，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要穿上這件衣服，就能變得開朗一些……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得這樣",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的非常美好！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "跟騎士先生你",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "講這種事也沒什麼用！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你可以不用太放在心上喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "比起這個，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你只要幫我完成工作就好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要麻煩你認真幹活囉！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你還是老樣子，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幹勁滿滿到讓人瞠目結舌耶。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是騎士先生的優點吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也沒有太多時間，就乾淨俐落地搞定吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n畢竟我還有很多事情要忙。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不但還在構思時裝秀上要展示的衣服該如何設計，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也必須思考該如何拜託怜大人擔任模特兒。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天也是，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "本來是該找怜大人……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再怎麼說也不能拜託她做這種工作吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "相對來說，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是對象是騎士先生，感覺就能輕鬆開口……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對、",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你要是再悠哉下去的話，我就要丟下你囉！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要和騎士先生來到這裡，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就會回想起我們倆相遇的那天呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和那時不同，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次應該不用我來教你了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就先從這邊的樹來小試一下……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好奇怪喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這裡……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這裡也沒有。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我記得是這種樹沒錯，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但完全沒找到果實……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只有枝條",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果實被採走了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……看來是",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有別的裁縫師",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n搶先採走了果實呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我平常不會參加這種時裝秀，所以不太清楚，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過我的動作或許太慢了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟、",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟糕了呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這下得非常仔細地尋找了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "麻煩你負責找那邊！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這裡也沒有。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那邊的果實還沒成熟，所以不能用……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明都找得這麼仔細了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "居然連一顆果實都找不到……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到底，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是大家採得太過頭了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真希望他們能顧慮一下別人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算抱怨也不是辦法。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n時間差不多了，先去和騎士先生會合吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生──",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你那邊狀況怎麼樣──？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你那邊也沒收穫啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我這裡也沒找到。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒辦法。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n太陽馬上就要下山了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就放棄回去吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然沒能採集到素材，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但酬勞還是會好好付給……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再找下去的話，不知道我們能不能在天色變暗前回去……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這樣一來，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也會超過打工的工時。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "染料的話，還請你別擔心。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n搞不好雜貨店會有賣染料，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以我想應該不至於拿不到手。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你為什麼要走向更深的地方……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會按照超過的工時，把酬勞補給你的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可不想欠你奇怪的人情！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你不要那些另外算的酬勞？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是那樣……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是為了我才這麼做的？",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼你要這麼……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是這樣啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生不是為了酬勞，而是為了我才來幫忙的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生是因為想要幫助我，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才這麼努力……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該不會，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "即使這不是工作，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他也願意來幫我",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總、",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會好好付給你加班費的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我果然沒辦法對騎士先生",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n說出真心話……！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是、",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是要去",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "更裡面一點的地方找，對吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "另外一邊還沒去過──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有人在嗎──！",
        "unit_id": 1,
        "voice": "vo_adv_1054009_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有沒有人在──！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛那是……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "人的聲音？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n聽起來好像是在求救……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說得也是。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還不知道發生了什麼事，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就謹慎地去看看情況吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該是在這附近……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救、",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救命啊！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我被絲線纏住了，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "整個人動彈不得！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔哇！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嚇、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嚇死人了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是魔物的絲線",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "啊啊，太好了，",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_048"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "有人來了……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "我是來這裡採集染料的，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "結果碰上了魔物……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你是我的同行嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n對了，我感覺自己好像有見過你。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……把所有果實都採走的人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該不是你吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "不、",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_050"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "不是我！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "我到的時候，果實早就所剩無幾了！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "就因為這樣，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "我才會比平常還更深入……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以就碰上了魔物，是吧？",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "自己一個人進到森林深處",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是很危險的喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "嗯、",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_052"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "嗯……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "\n那個，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "所以你們應該不會不救我吧……？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真對不起。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們現在",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就幫你把絲線解開。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔嗯嗯……！！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這絲線",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還滿牢固的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該不是普通魔物的絲線吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，這絲線……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好像不只是牢固而已，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n觸感也非常不錯……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺似乎是上等的絲線。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "先、",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_056"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "先別管絲線了，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "我希望你們能快點幫我解開……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n呃，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "解開這個地方……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請幫我拿著這裡。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請等一下喔。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n靠蠻力亂扯的話，搞不好會弄斷絲線，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以我想慢慢地解開它。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總算",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "解開了呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "得、",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_060"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "得救了……",
