        "voice": "vo_adv_1054009_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總算是回來了呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也謝謝騎士先生陪我到這麼晚。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後，",
