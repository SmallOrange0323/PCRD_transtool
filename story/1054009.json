    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_076"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣簡直就像是我對騎士先生……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我明明已經有怜大人了……！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_077"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_078"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我對",
