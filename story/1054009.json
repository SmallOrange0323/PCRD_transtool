    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天真的很謝謝你！",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_079"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我會好好支付你酬勞的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就這樣，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_080"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "辛苦你了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希僅僅是向{player}表達出今天的謝意，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隨後便跑著離開了。"
