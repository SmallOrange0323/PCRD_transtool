    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些絲線！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這一定會是很棒的素材喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也多虧有騎士先生細心地幫忙解開，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我才得到了這麼長的絲線♪",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有兩個人一起來真是對極了♪",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們也回去吧！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
