    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "你們兩位……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不不不，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們只是剛好路過而已。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你沒事真是太好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "對了，",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_062"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "妳剛才有說我們是同行……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是的。",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也是來這裡找能做成染料的果實，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就想說我們應該是同行。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請問這附近也有果實嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "是這樣的話，",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_064"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "那個……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "這個給妳……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦……",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這不就是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能做成染料的果實嗎！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我真的能收下嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "嗯……",
        "unit_id": 4911,
        "voice": "vo_adv_1054009_066"
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "雖然不多，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "但我還是想答謝一下。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "那我今天",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男裁縫師",
        "words": "也差不多該回去了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然我覺得應該不會有事，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過你回去時",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要多加注意喔──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……得到",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做染料要用的果實了呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "收穫可不只有這個。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054009_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看看",
