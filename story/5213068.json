    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這次就用這個，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來做做看刺激感十足的甜點吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我以前，",
        "unit_id": 126511,
        "voice": "vo_adv_5213068_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也很怕這種氣泡的口感，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以一直敬而遠之……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過最近開始能食用了，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也漸漸明白它的妙處。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
