    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這種氣泡奶油，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "最大的特色就是在口中彈跳迸裂的口感。",
