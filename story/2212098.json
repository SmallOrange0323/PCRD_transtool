        "voice": "vo_adv_2212098_028"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "平等。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "如果我不這麼做，",
        "unit_id": 193211
    },
    {
