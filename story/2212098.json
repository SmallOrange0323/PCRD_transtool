    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好的，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_000"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "辛苦了～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……真",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_001"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是的～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n術士那些人",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "都老大不小了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "幹嘛要入侵到遊戲裡面亂來啊～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "大叔少在那邊不服老裝年輕啦～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對吧～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "話說",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_002"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你們也是。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n好不容易把他們逼上絕路，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "怎麼那麼簡單就讓他們逃掉啦～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n要好好給他們致命一擊啊，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "受不了～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_003"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "～的不是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我愛說教",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊～？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "說到你們這些人喔，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "每一次",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "每一次都那麼天真……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_004"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然很想這樣訓你啦？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "今天我就",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "大肆誇獎你一番吧♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "【破曉之星】的那群人──",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_005"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n在絕佳的時機派她們加入隊伍，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我真是立了大功呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "呀哈哈♪",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "哼。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_006"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這次借你的人情，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "之後一定會要你還回來──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……是～啊。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_007"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "吉歐‧尼布爾黑爾的公主……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n在巨鯨城使用皇家裝備時，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "她的臉色都像紫堇一樣發紫了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那大概是",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "拋開皇家裝備後真實的她吧……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這次就",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_008"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "沒有發生那種事了嘛。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "她好像",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "找到方法",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "運用？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "了呢，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那件「怠惰」。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n她不再畏畏縮縮，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "而是鼓起勇氣來了──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "因為你的關係。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊～",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_009"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "又開始了，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "大木頭人。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "唉～我不管了啦～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……總之，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_010"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n打倒了術士，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "拿回了黑曜宮，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "在吉歐‧尼布爾黑爾一戰，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "也就此結束了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雪菲的哥哥，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_011"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "普蕾西亞的爸爸，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "以及許許多多",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "消失的人們的靈魂從沉睡中甦醒……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是可喜可賀。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………唉。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_012"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不是。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_013"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n好煩啊，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好像沒辦法這麼順利耶，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這件事情。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "唉。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "位在黑曜宮最深處的控制室──",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_014"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「玄室」，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然可以用薇歐莉特公主拿到的鑰匙進行控制，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n但是那些術士，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "好像留下了妨礙控制的機關……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "他們利用搶先一步的優勢留下了保險，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_015"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "應該是這樣。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "變貌大妃正在試圖解除，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "可是好像要花不少時間。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雖然變貌大妃這個人，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_016"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "一點也不能相信就是了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "總之，如果沒有鑰匙……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "沒有薇歐莉特公主同意的話，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n就不能對「玄室」出手。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雖然我覺得",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "應該不會有問題……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊？",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_017"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n什麼？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "要稱讚表揚我嗎？",
        "unit_id": 193211
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "background",
        "background": "501640"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊？",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_018"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "喔──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……也是啦。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_019"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你這個人，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就是這樣吧……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這次的冒險……",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_020"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n目的是尋找並救回消失的玩家們。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n在途中遇見、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "受到照顧的那些人們──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──他們",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_021"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "並不知道",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "「世界的真相」呢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "即使接下來一切順利，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_022"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "大家一起登出！",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "當這種事情發生時……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "他們大概會很慌張吧，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "一定的。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……唉，",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_023"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "以我的立場來說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我完",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "全不建議你這麼做啦……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過。",
        "unit_id": 193211,
        "voice": "vo_adv_2212098_024"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你想做的話，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就隨便你吧。",
