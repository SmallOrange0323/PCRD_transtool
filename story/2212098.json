    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
