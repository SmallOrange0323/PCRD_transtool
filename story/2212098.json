    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n表面上世界似乎恢復了和平──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而從這一天起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即將再次發生巨大的混亂。"
    },
    {
        "type": "background",
