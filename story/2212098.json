    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n乘坐可蘿操縱的飛天摩托車朝舊WISDOM的總部前進時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n偷聽到了那些異常情形。"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……看來已經開始了，",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_040"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n晶小姐和",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人擔心的事態…………",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "喂，可蘿仔，",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_041"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "發生什麼事啦！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我身上沒有mimi也沒有手機，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n妳說明得清楚一點啦！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「由霞所分類的",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『紅色級別』──",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使回到現實，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n仍然以為《阿斯特朗傳奇》是真實世界的人們，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n漸漸暈了過去……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這樣吧……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……是的。",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_043"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n簡直就像",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "潛入《阿斯特朗傳奇》時一樣。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這會",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在地球上各個角落，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "似乎都出現了同樣的現象……",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼！？",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_044"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "因為……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n受到認知修正的狀態下，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不會知道要怎麼使用mimi吧！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n當然了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "也不是說所有人都是這樣……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「對。",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論是日本、阿斯特賴亞還是其他國家，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n政府應該都在回收mimi才對。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然而，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "世界各地卻發生那種事情……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……一時之間",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_046"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "實在令人難以置信，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但根據晶小姐的說法──",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "七冠的最後一人，",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_047"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幻境龍后。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在開發《阿斯特朗傳奇》的同時，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n她獨自",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "開發了某種粒子。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是的。",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_048"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那種粒子",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在一般情況下無害，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但會對強烈的腦波起反應並聚集起來……",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n聚集到一定數量後，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "便具有奈米機器那樣的功能。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "會對腦波起反應的粒子",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_049"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這種東西",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是什麼啊！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "太誇張了吧！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "呃……",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_050"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不對。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你們搭乘的飛天摩托車，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還有mimi，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n仔細想想也是很不得了的技術……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「正因為是七冠，",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在現實世界那邊好像也很厲害。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我記得奈米機器",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是會使用在醫療上的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常微小的機械吧。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你是說奈米機器",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_052"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這東西",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "具有和mimi類似的功能，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n讓強烈想要回去",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那邊的世界的玩家",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "潛入了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n是這個",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "意思嗎……！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「等、",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下，小凱留。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是不可能的啊。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們前往舊WISDOM開發總部的原因就是……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "為了重置",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_054"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "被國際刑警封鎖的",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n《阿斯特朗傳奇》的",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "登入伺服器。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n若不這麼做，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "就無法「再潛入」那個世界。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊……",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_055"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那麼，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "昏睡過去的那些人會變成怎樣？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "放著他們不管，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "之後就會自己醒過來嗎……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "若是會就好了。",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_056"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n眾人的靈魂",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在登入伺服器前面動彈不得……",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下認為",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這種可能性",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "比較高。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這樣的話，",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說他們會和消失的人們一樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一直昏睡醒不過來，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣嗎……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這不是很奇怪嗎？",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幻境龍后",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該不會不知道",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在的《阿斯特朗傳奇》沒辦法登入啊。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「可是，",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然這樣……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n幻境龍后的目的",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟是什麼呢？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她散播不好的粒子，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓大家昏睡……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是想做什麼？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……的確。",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_060"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n說不定，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "前玩家的集體昏睡，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n是為了達成其他某種目的的副作用……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "也是有可能的呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_061"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "若是晶小姐或是父親大人，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n或許會知曉",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "幻境龍后真正的目的。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但考慮到被國際刑警監聽的風險，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不能輕易與他們進行長距離通訊。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "現在暫時",
        "unit_id": 106031,
        "voice": "vo_adv_2212098_062"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒辦法仰賴晶他們的幫忙呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只靠我們沒問題嗎……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「帶路的話就交給我吧。",
        "unit_id": 105831,
        "voice": "vo_adv_2212098_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之前我曾經利用公務兼贊助商的特權，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n去參觀過開發室。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "連接到登入伺服器的部分",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_064"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請交給在下。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雖僅是基礎，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "但在下也是受過教學指引的。",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且，",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_065"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "最重要的是……",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "父親大人",
        "unit_id": 105933,
        "voice": "vo_adv_2212098_066"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "會佯裝誘餌，",
        "unit_id": 105933
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "替在下等人吸引國際刑警的注意。",
        "unit_id": 105933
    }
]