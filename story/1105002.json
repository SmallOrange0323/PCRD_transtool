    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～。",
        "unit_id": 110511,
        "voice": "vo_adv_1105002_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "思考了也不明白呢～",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝～",
        "unit_id": 110511,
