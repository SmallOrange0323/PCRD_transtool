        "unit_id": 2511,
        "voice": "vo_adv_1105002_022"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "開心也很重要。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n但是這次的舞會，",
