    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "特別的氣氛？",
        "unit_id": 110511,
        "voice": "vo_adv_1105002_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n像是情侶們的",
