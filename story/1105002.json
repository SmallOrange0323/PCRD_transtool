        "voice": "vo_adv_1105002_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這樣的話，",
        "unit_id": 110511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也沒辦法呢～",
