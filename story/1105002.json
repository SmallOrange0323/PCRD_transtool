        "voice": "vo_adv_1105002_020"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n想要辦成很有氣氛的晚會。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "氣氛是什麼～？",
