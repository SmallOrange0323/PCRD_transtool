[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "約在聖誕節前兩週……\n{player}和綾音一起\n在蘭德索爾逛街挑選聖誕節蛋糕。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看你看，哥哥。",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "盤子上裝了滿滿的蛋糕！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂喂，綾音。",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "平時總是叮嚀妳，做事前稍微想想後果啊。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n那麼多妳吃不完吧？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "因為妳的胃很小啊。』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是囉嗦，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉啊～？　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "才不小呢！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "蛋糕是裝在另一個胃的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n反正這裡是吃到飽，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那不管拿多少蛋糕都沒問題吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "吃不完的部分，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就塞進哥哥嘴裡就好啦……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『也想想會不會給人添麻煩啊。",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_004"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n真是抱歉啊，{player}。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n總是讓你陪著綾音任性。』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼♪",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥他也這麼說了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『你別太寵綾音啊，{player}……",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_006"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這傢伙，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "還是要狠狠訓她一次比較好。』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我把看起來很美味的蛋糕都一個個挑了出來！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不只是蛋糕，還有日式糕點、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n冰淇淋和布丁之類的我也都拿了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂喂……",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我們目的是挑選聖誕節蛋糕吧，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "討厭，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉就只會說教……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我想說如果不當乖孩子，聖誕老公公就不會給我禮物，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以我最近都有乖乖聽話喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『是哪個部分啊？　",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_010"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "算了，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒有做壞事是很不錯～",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n但我如果是聖誕老人，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不管怎麼放寬標準，都覺得妳勉強不及格耶？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦～？　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉他是這麼說，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但哥哥是怎麼想的？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有好好當乖孩子對不對？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇？　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥摸我的頭了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這是「綾音是乖孩子」的意思對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我才是正確的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『真是溺愛呢……",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "那種事無所謂，綾音。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳站在通道上，會妨礙到其他客人。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n趕快坐好吧。』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可以坐在你大腿上嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『為什麼啊，",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "{player}對面的位子也空著吧？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦～",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為距離近一點比較開心嘛……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我今天可以一直獨占哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以我要盡情和他撒嬌～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我是姊姊，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以我平常都讓給可可蘿和胡桃了～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "其實想要一直和哥哥撒嬌呀♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快點，哥哥，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "來吃吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這邊是哥哥的盤子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後這邊是我的喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我全部都挑選了不同的種類，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果有好吃的就分我吃一口！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還有其他",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很～多種類的蛋糕……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n等這些全部吃完後，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是還吃得下，我們就再去拿喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『先不說{player}，",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_021"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n綾音連這盤子裡一半的蛋糕都吃不完吧？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我吃得完啦。",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還在發育期啊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我開動了～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊嗯",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嚼嚼嚼♪　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好好吃～！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這個草莓的蛋糕太棒了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉要吃嗎～？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂！",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_024"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "如果沾到奶油會很難清洗，別把蛋糕靠過來！』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呵呵～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為噗吉是小熊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以才不吃蛋糕對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "居然不能吃這麼甜又這麼棒的東西，真可憐！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快點，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥也別看了快點吃！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好吃嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　呵呵。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們要吃好多好多，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後找出最好吃的蛋糕喔！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "畢竟我們的目的是挑選和【咲戀育幼院】的大家，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在平安夜舉辦派對用的聖誕節蛋糕啊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在這種吃到飽的地方，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就能一點一點地品嘗各種類的蛋糕吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n如果要挑蛋糕這樣最適合了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我真是聰明☆",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你因為喪失記憶，所以不知道什麼是吃到飽？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是啊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "隨便你高興怎麼吃！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n陳列的料理或點心之類的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不管是什麼要吃多少都可以喔！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我小時候，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n爸爸媽媽經常帶我來這家店……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真懷念呢，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然我連哥哥的份都幫忙挑好了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但如果哥哥",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也有其他想吃的東西的話，可以去拿沒關係喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇、哇呀？　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎麼了，哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n為什麼，要碰我的嘴唇……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我邊吃邊說話，所以把嘴邊弄髒了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "幫我擦掉了呢～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　謝謝～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥是乖孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以一定會收到聖誕老公公的禮物喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……？",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_036"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『……嗯？",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_037"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n怎麼了，綾音？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉！　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快看！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n窗、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "窗戶外面……！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "～……♪",
        "unit_id": 102321,
        "voice": "vo_adv_1086001_039"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『哦哦？",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_040"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n那是什麼啊，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "窗戶外也有綾音耶！』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對！　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我就在這裡……那個是冒牌貨！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大概就是那個叫做『闇影』的傢伙！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『啊、啊啊……",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_042"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "聽妳這麼一說，她眼睛顏色很奇怪呢，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n那種傢伙這麼普通地走在路上，為什麼沒有引起騷動？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起這件事！　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個『闇影』",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "正在和誰牽著手！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那個是……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是我的爸爸媽媽！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不要！　",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_044"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "別搶走我的爸爸媽媽，『闇影』！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我雖然是個因為做了奇怪的妄想，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而害怕得離家出走的壞孩子！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但就算是這樣，",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_045"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也不要欺負我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n禮物和蛋糕我都可以不要，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以不要搶走爸爸媽媽……！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喂、",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_046"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂，綾音？　",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "冷靜點！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳那樣亂動，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n手腳會撞到桌子受傷的啊！』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『{player}，",
        "unit_id": 2111,
        "voice": "vo_adv_1086001_047"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "讓綾音冷靜下來！』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不要――！",
        "unit_id": 102311,
        "voice": "vo_adv_1086001_048"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸、媽媽！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會當乖孩子的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以不要把我的爸爸媽媽搶走～！",
        "unit_id": 102311
    }
