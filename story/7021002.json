    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管魔物阻擋在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n登塔的{player}一行人面前──"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼……！",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喝！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這樣就結束了！",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是驚人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想不到深月小姐那麼強。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她與純那種",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "以壓倒性力量制服對手的方式不同，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n使用的是抓準對手弱點",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "高效率而確實地解決敵人的戰鬥方式……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只能以厲害來形容了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不必稱讚我哦？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這點程度根本上不了檯面。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說什麼上不了檯面……",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不管怎麼看",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺深月小姐",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n連一半的實力都沒展現出來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算我拿出真本事也沒有取勝把握……",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個人真的是醫生嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從來沒聽說過有醫生這麼厲害的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼又冒出了一大群。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "小智，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這次讓我們聯手──",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒問題的！",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n身為【王宮騎士團】成員，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這種程度",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我一個人就能解決了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼能夠抱著沒有取勝把握之類的畏縮想法。",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n守護城鎮治安的【王宮騎士團】",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n隨時都得保持果敢才行！　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我要上囉！",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看劍看劍看劍！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太慢了！",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n用這招解決你！！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呼、",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "全都打倒了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這種程度我一個人也能──",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "糟糕！",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有倖存的……！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦，",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怪了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來只是迴光返照呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳沒事真是太好了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦……？",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺深月小姐做了些什麼。",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她做了萬一被我目擊會很頭痛的事嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也沒有證據……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，",
        "unit_id": 105111,
        "voice": "vo_adv_7021002_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在魔物再次出現前",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "快點前進吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好、",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說得也是。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "深月小姐……",
        "unit_id": 103711,
        "voice": "vo_adv_7021002_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是位深不可測的人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果有什麼萬一，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一個人真的應付得過來嗎？　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "跟在大大方方走在前面的深月身後的智的步伐，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看起來有些裹足不前。"
    }
]