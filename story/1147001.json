[
    {
        "type": "background",
        "background": "501163"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在大間鎮過新年的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於夜晚的街道上撞見了熟悉的身影。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊呣！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔呣！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嚼嚼……！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n咕嘟……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真好吃──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那裡的人是……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這邊啦這邊──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你最近還好嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我過得很好喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嘛！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就好！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然發生了很多事，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這個城鎮還是個好地方呢！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡的魚超級好吃！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且這裡的夜晚很安靜，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "海浪聲讓人心情舒暢，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n很助眠喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……只不過，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也差不多該回蘭德索爾了。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然有些依依不捨，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但也不能一直在這裡悠悠哉哉的啊。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也很在意",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "蘭德索爾舉辦的那個什麼廟會！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你明天有什麼計畫？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那明天就來陪我吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我打算跟著漁夫大叔",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "出海釣魚喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也跟我一起來！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想在離開這裡之前，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n留下",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最後的回憶！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會這麼說啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是因為我們好不容易",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "變成夥伴了對吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "至今為止都只有和戰鬥相關的回憶，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然如此，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今後再創造一些快樂的回憶",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n應該也不錯，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是這麼想的。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再加上，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能趁新鮮品嚐自己釣到的魚，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這可是相當少有的機會喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就這麼決定了！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽說海釣",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一大早就得出發，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要先去睡了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也別睡過頭囉！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們明天要釣一堆魚，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後吃個過癮──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "明天見啦，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晚安──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快起床──！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天亮啦──！！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你是不是",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "睡傻啦？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快去洗把臉，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們要出海囉──！",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "501163"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這、",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是怎麼回事──！？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n喂，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "海浪怎麼這麼洶湧啊？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "昨天睡前",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是一片平靜的吧……？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你應該還記得吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是有聽說冬天很常出現狂浪，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但會像這樣一夜之間就天翻地覆嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_021"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "早啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n妳起得真早。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "我還以為妳一定會睡過頭。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "誰會睡過頭啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我又不是小孩子！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起這個，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不用為出海做準備嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "就是說啊──！",
        "unit_id": 111,
        "voice": "vo_adv_1147001_023"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "快讓我上船啦──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "\n我都遵守約定，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "元旦好好睡覺沒有守夜耶──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "我今天一定要在船上看日出啦──！",
        "unit_id": 1,
        "voice": "vo_adv_1147001_024"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "\n而且，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "這是我們第一次出海耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "我們已經期待很久了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這我當然知道。",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_025"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "但是啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "你們仔細看看大海吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n風浪這麼大，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "現在還沒辦法開船出海。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "你們想成為獨當一面的優秀漁夫，",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_026"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n就要具備讀浪的能力。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "要開船出海",
        "unit_id": 1,
        "voice": "vo_adv_1147001_027"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "還得等一段時間。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "學會等待也是漁夫的工作。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n太過焦躁而提前收竿的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "就會把魚給放跑。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "大海不會逃走。",
        "unit_id": 1,
        "voice": "vo_adv_1147001_028"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "相反它無邊無際地在你面前展開。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n所以現在就拿出海上男兒的風範，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "沉著地等待時機吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子們",
        "words": "知道了……",
        "unit_id": 1,
        "voice": "vo_adv_1147001_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們給我聽好了。",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別從新年開始就悶悶不樂的啊！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n難得的喜慶氛圍都被破壞掉了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再等等看的話，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說不定天氣就會放晴啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n現在放棄還太早了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "即使不在船上也能看到日出吧。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n和我們一起在岸上等日出吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們雖然是為了海釣而來，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但像現在這樣等日出也不錯。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反正這種象徵吉祥的事物",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "永遠看不膩，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也能算是個美好回憶嘛！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "對耶。",
        "unit_id": 111,
        "voice": "vo_adv_1147001_034"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "你們兩個",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "馬上就要回去了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "那，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "在日出前跟我說說你們的事嘛！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "姐姐在蘭德索爾",
        "unit_id": 1,
        "voice": "vo_adv_1147001_035"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "是做什麼的啊──？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦哦，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想聽大壞蛋諾維姆的故事嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你問得真好……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──然後啊，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我一揮動天樓霸斷劍，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那些小嘍囉就通通被轟飛了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈哈！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "好厲害！",
        "unit_id": 111,
        "voice": "vo_adv_1147001_038"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "我想看看",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "那把大劍！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "妳把它藏在哪裡呀──？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是我的殺手鐧。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只有在幹壞事時──",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我說，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "日出時間",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是不是快到了啊？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不要說天氣變好了，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雲層好像更厚了耶？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "問你喔，",
        "unit_id": 111,
        "voice": "vo_adv_1147001_042"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "爸爸……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "我們是不是",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "看不到日出了？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "看來",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_043"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "是那樣沒錯……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "再加上",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "大海也鬧起脾氣來了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n巨浪一波接著一波，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這下根本無法出海。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "抱歉啊，",
        "unit_id": 1,
        "voice": "vo_adv_1147001_044"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "讓大家白期待了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n我們也同樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "很想出海……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "但是，",
        "unit_id": 1,
        "voice": "vo_adv_1147001_045"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "對手是大自然。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n我們這些渺小的人類，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "也有無法戰勝的時候啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然還打雷了？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n沒辦法……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在下雨前",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "趕緊回旅館吧。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再多待一天，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "明天一定要出海！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所謂「太陽依舊會升起」",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘛！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_048"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "但願如此。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "只是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "這陣雷……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "說不定……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_049"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "那巨大的雷光柱……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "果然沒錯！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "為什麼不祥的預感總是會靈驗啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "抱歉在妳興奮時潑冷水……",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_050"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n這裡恐怕明天也見不到太陽了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "……不，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "何止明天，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "最近暫時都見不到吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "暴風雨就要來了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不就是打雷嗎？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總有停下來的時候吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "那陣雷",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_052"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "可不只是天氣不好造成的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n我們漁夫能分辨得出來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "那是名為",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "「雷雷」的魔物在作祟！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "可惡！",
        "unit_id": 1,
        "voice": "vo_adv_1147001_053"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "本來帶著好心情要出海捕魚的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n新年剛開始就真不走運啊……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼嘛……",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來只是魔物在搗蛋啊。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "什麼「只是」……",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_055"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "每到這個時期，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "我們都很為那傢伙所苦啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n而且，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "要是把它當成普通的雷雷，那可就大錯特錯了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "它吸收了冬季厚重烏雲裡積累的電氣，",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_056"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n比一般的雷雷更加膨大。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "妳也看見剛才的落雷了吧？",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_057"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "它的威力超乎尋常！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "就像",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "脂肪增多後回流的魚一樣！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "我們漁夫",
        "unit_id": 1,
        "voice": "vo_adv_1147001_058"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "是大海的專家。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "抓水裡的魚一向手到擒來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n但是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "遇到雲裡的魔物也只能舉雙手投降了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "根本束手無策啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放心吧！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "包在我們身上！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們會讓你能出海的！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，你們。",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n剛剛說",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想看我的天樓霸斷劍對吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "對、",
        "unit_id": 111,
        "voice": "vo_adv_1147001_061"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "對呀……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "妳該不會",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子1",
        "words": "要去打倒魔物吧？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "雖然妳說那是一把大劍，",
        "unit_id": 1,
        "voice": "vo_adv_1147001_062"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "\n但再怎麼說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子2",
        "words": "要對付雲裡的魔物也太勉強了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要釣很多魚，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後大吃一頓！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是有人想妨礙我，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要把他轟飛就行了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們也好、",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "漁夫大叔們也好，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家都想出海吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那就和我一樣啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，{player}！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_065"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把你的力量借給我！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "輪到大壞蛋出場了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "作惡的傢伙",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就由我來解決！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很好！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "力量湧出來了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n新年第一劍……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要鼓足幹勁，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拿出全力上囉──！！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "顯現吧！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_067"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍──！！",
        "unit_id": 114711
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈～哈哈哈！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_068"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣，認輸了吧！！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "雲散去了……！",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_069"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n也就是說",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "妳只憑一劍",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "就把空中的魔物打倒了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_070"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這就是我們",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和天樓霸斷劍的力量！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就說吧，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "連雲裡的魔物都能轟飛。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有我和這傢伙在，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就沒有什麼是砍不倒的！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子們",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1147001_072"
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子們",
        "words": "好猛喔～～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦？",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_073"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大海的彼端似乎漸漸亮起來了。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……那是！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了！",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_074"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像正好趕上日出喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n今天的太陽看起來",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "格外巨大耶！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然吉祥的事物看多少次都還是很棒呢。",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也和你創造出新的回憶啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫們",
        "words": "哦哦～～",
        "unit_id": 1,
        "voice": "vo_adv_1147001_076"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_077"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大叔們！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們要發呆到什麼時候啊！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "攪亂大海的魔物已經消失了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這下就能開船出海了吧？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "是、",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_078"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "是啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n實在是太厲害了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "不小心嚇了一大跳啊……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "不只天空放晴，",
        "unit_id": 1,
        "voice": "vo_adv_1147001_079"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n連剛才的狂暴的巨浪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "都徹底平息了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "不等能再發呆了！",
        "unit_id": 1411,
        "voice": "vo_adv_1147001_080"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "快準備出航啦──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1147001_081"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "你們也過來幫忙準備！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n想上船的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "就乖乖當個最底層的漁夫助手吧！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "漁夫的孩子們",
        "words": "我們知道了！",
        "unit_id": 1,
        "voice": "vo_adv_1147001_082"
    },
    {
        "type": "background",
        "background": "501161"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎呀～",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_083"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "教訓完作惡的魔物後",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n心情真好！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真痛快！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "它錯就錯在新年這天睡昏頭，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_084"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然躲在烏雲裡繼續睡回籠覺！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "它自己應該也沒想到，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才剛迎來新年竟然就被人教訓了一頓吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說誰啊！？",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_085"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我只是",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想把魔物打倒而已喔！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我叫諾維姆啦！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也差不多該記住了吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_086"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天就不跟你計較了……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起這個，",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們也快去吧！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "錯過上船時間就不好了！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來要大釣特釣，",
        "unit_id": 114711,
        "voice": "vo_adv_1147001_087"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後吃個過癮──！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "矛依未如此說道，將{player}拉上了漁船，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備出海釣魚，留下兩人在大間的回憶。"
    }
]