    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得",
        "unit_id": 100211,
        "voice": "vo_adv_2013016_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就連我也替她們開心了起來呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生他們，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也完全沉浸在",
