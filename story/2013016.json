        "voice": "vo_adv_2013016_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種時候，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為應該要說『在下回來了』",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
