    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯……",
        "unit_id": 106015,
        "voice": "vo_adv_2013016_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪了？",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我……？",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～☆",
